# clangd configuration for the C in this repo.
#
# None of the C here is meant to compile standalone in an editor:
#   - bootstrap/runtime/*.c are templates spliced into bootstrap/seed/bootstrap.c
#   - the C that `glide --emit` (or a failed `glide build`) leaves as *.__glide.c
#     is a single self-contained translation unit the Glide pipeline feeds to
#     `zig cc` / mingw `gcc` with -D_GNU_SOURCE, pthreads, winsock, dbghelp, etc.
#
# clangd uses clang's frontend, which on Windows targets MSVC and has no
# <pthread.h>, so opening any of these files shows phantom "pthread.h not found",
# "implicit declaration", "unknown type" errors even though the real build is
# fine. The settings below feed clangd the same include paths the build uses and
# silence the false positives so the editor only surfaces things that matter.

CompileFlags:
  Add:
    - -D_GNU_SOURCE
    - -Iruntime/zig/lib/libc/include/any-windows-any
    - -Iruntime/zig/lib/libc/include/any-linux-any
    - -Iruntime/zig/lib/libc/glibc/include
    - -Iruntime/zig/lib/include
    - -Wno-everything
    - -Wno-error=implicit-function-declaration
  Compiler: clang

# Global (every C file, not just bootstrap/runtime): the Glide-emitted and
# runtime C reference symbols that come from sibling templates or are provided
# by the link step, so isolated analysis is always noisy.
Diagnostics:
  Suppress:
    - implicit_function_declaration
    - unknown_typename
    - pp_file_not_found
    - undeclared_var_use
    - ovl_no_viable_function_in_call
    - typecheck_invalid_operands
    - err_typecheck_call_too_many_args
