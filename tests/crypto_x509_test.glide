// X.509 parser against a real P-256 self-signed certificate (generated by
// OpenSSL with a SAN and basicConstraints CA:TRUE).
import stdlib::testing::*;
import stdlib::crypto::x509::*;
import stdlib::hex::*;

fn _cert() -> string {
    return hex_decode("").unwrap();
}

fn test_parse_fields() -> i32 {
    let c: !*Cert = cert_parse(_cert());
    assert!(c.is_ok());
    let cert: *Cert = c.unwrap();
    assert_str_eq!(cert.subject_cn, "glide.example");
    assert_str_eq!(cert.sig_alg, "1.2.840.10045.4.3.2");        // ecdsa-with-SHA256
    assert_str_eq!(cert.pubkey_alg, "1.2.840.10045.2.1");        // ecPublicKey
    assert_str_eq!(cert.pubkey_curve, "1.2.840.10045.3.1.7");    // P-256
    assert_eq!(cert.pubkey.len(), 65);                           // 0x04||X||Y
    assert_eq!(cert.pubkey.at(0).to_int() & 255, 4);
    assert!(cert.is_ca);
    return 0;
}

fn test_validity_window() -> i32 {
    let cert: *Cert = cert_parse(_cert()).unwrap();
    // one-year self-signed cert: notAfter is ~365 days after notBefore.
    let span: i64 = cert.not_after - cert.not_before;
    assert_eq!(span, 31536000);   // 365 * 86400
    return 0;
}

fn test_san_dns_names() -> i32 {
    let cert: *Cert = cert_parse(_cert()).unwrap();
    assert_eq!(cert.san_dns.len(), 2);
    assert_str_eq!(cert.san_dns.get(0), "glide.example");
    assert_str_eq!(cert.san_dns.get(1), "*.glide.example");
    return 0;
}

fn test_subject_equals_issuer() -> i32 {
    // self-signed: subject and issuer Names are byte-identical.
    let cert: *Cert = cert_parse(_cert()).unwrap();
    assert!(cert.subject_der.eq(cert.issuer_der));
    return 0;
}

fn test_rejects_truncated() -> i32 {
    let full: string = _cert();
    let cut: string = full.substring(0, full.len() / 2);
    assert!(cert_parse(cut).is_err());
    return 0;
}

fn test_self_signed_signature_verifies() -> i32 {
    let cert: *Cert = cert_parse(_cert()).unwrap();
    // A self-signed cert verifies against its own public key — this drives
    // the whole path: SHA-256 of the TBS, DER-sig -> raw r||s, ECDSA/P-256.
    let v: !bool = cert_verify_signature(cert, cert.pubkey);
    assert!(v.is_ok());
    assert!(v.unwrap());
    return 0;
}

fn test_signature_rejects_wrong_key() -> i32 {
    let cert: *Cert = cert_parse(_cert()).unwrap();
    // Flip a byte of the public key -> signature must not verify.
    let pk: string = cert.pubkey;
    let mut bad: string = "";
    for let i: i32 = 0; i < pk.len(); i++ {
        let b: i32 = pk.at(i).to_int() & 255;
        if i == 40 { bad = bad.concat(((b ^ 1) as char).to_string()); }
        else { bad = bad.concat((b as char).to_string()); }
    }
    let v: !bool = cert_verify_signature(cert, bad);
    // either a hard error (invalid point) or a clean false — both are "not valid"
    assert!(!v.is_ok() || !v.unwrap());
    return 0;
}

fn test_hostname_matching() -> i32 {
    let cert: *Cert = cert_parse(_cert()).unwrap();
    assert!(cert_matches_hostname(cert, "glide.example"));
    assert!(cert_matches_hostname(cert, "GLIDE.EXAMPLE"));          // case-insensitive
    assert!(cert_matches_hostname(cert, "www.glide.example"));      // *.glide.example
    assert!(!cert_matches_hostname(cert, "a.b.glide.example"));     // wildcard = one label
    assert!(!cert_matches_hostname(cert, "glide.example.evil.com"));
    assert!(!cert_matches_hostname(cert, "evil.com"));
    return 0;
}

fn test_time_validity() -> i32 {
    let cert: *Cert = cert_parse(_cert()).unwrap();
    assert!(cert_is_time_valid(cert, cert.not_before));
    assert!(cert_is_time_valid(cert, cert.not_after));
    assert!(!cert_is_time_valid(cert, cert.not_before - 1));
    assert!(!cert_is_time_valid(cert, cert.not_after + 1));
    return 0;
}
