// `?` error propagation across multiple functions and chained calls, for both
// Result (`!T`) and Option (`?T`). The err/none case must short-circuit and the
// original error message must survive every propagation hop unchanged.
import stdlib::testing::*;

fn parse_pos(s: string) -> !i32 {
    if s.eq("") { return err("empty"); }
    if s.eq("bad") { return err("not a number"); }
    return ok(10);
}

// one hop: `?` unwraps parse_pos or bubbles its err.
fn doubled(s: string) -> !i32 {
    let n = parse_pos(s)?;
    return ok(n * 2);
}

// two hops: propagation must thread through `doubled` too.
fn doubled_plus(s: string) -> !i32 {
    let n = doubled(s)?;
    return ok(n + 1);
}

fn test_result_ok_threads_through_hops() -> i32 {
    let r: !i32 = doubled_plus("x");
    assert!(r.is_ok());
    assert_eq!(r.unwrap(), 21);            // (10*2)+1
    return 0;
}

fn test_result_err_propagates_first_level() -> i32 {
    let r: !i32 = doubled("");
    assert!(r.is_err());
    assert_str_eq!(r.unwrap_err(), "empty");
    return 0;
}

fn test_result_err_propagates_across_two_levels() -> i32 {
    let r: !i32 = doubled_plus("bad");
    assert!(r.is_err());
    assert_str_eq!(r.unwrap_err(), "not a number");   // message survives 2 hops
    return 0;
}

// Multiple `?` in one body: the FIRST failure wins and the rest never runs.
fn add_two(a: string, b: string) -> !i32 {
    let x = parse_pos(a)?;
    let y = parse_pos(b)?;
    return ok(x + y);
}

fn test_first_failure_short_circuits() -> i32 {
    let r: !i32 = add_two("bad", "");   // first arg fails
    assert!(r.is_err());
    assert_str_eq!(r.unwrap_err(), "not a number");
    return 0;
}

fn test_second_failure_reported() -> i32 {
    let r: !i32 = add_two("ok", "");    // first ok, second fails
    assert!(r.is_err());
    assert_str_eq!(r.unwrap_err(), "empty");
    return 0;
}

fn test_all_ok_sums() -> i32 {
    let r: !i32 = add_two("ok", "ok");
    assert!(r.is_ok());
    assert_eq!(r.unwrap(), 20);
    return 0;
}

// Chained call directly on a `?`-unwrapped value: `get_s()?.len()`.
fn get_s(fail: bool) -> !string {
    if fail { return err("no string"); }
    return ok("hello");
}

fn len_of(fail: bool) -> !i32 {
    let n = get_s(fail)?.len();
    return ok(n);
}

fn test_chained_method_on_try_value() -> i32 {
    let r: !i32 = len_of(false);
    assert!(r.is_ok());
    assert_eq!(r.unwrap(), 5);
    return 0;
}

fn test_chained_method_err_short_circuits() -> i32 {
    let r: !i32 = len_of(true);
    assert!(r.is_err());
    assert_str_eq!(r.unwrap_err(), "no string");
    return 0;
}

// ---- Option `?` propagation ----------------------------------------

fn even_only(n: i32) -> ?i32 {
    if n % 2 == 0 { return some(n); }
    return none();
}

fn even_plus100(n: i32) -> ?i32 {
    let e = even_only(n)?;
    return some(e + 100);
}

fn two_evens(a: i32, b: i32) -> ?i32 {
    let x = even_only(a)?;
    let y = even_only(b)?;
    return some(x + y);
}

fn test_option_try_some() -> i32 {
    let r: ?i32 = even_plus100(4);
    assert!(r.is_some());
    assert_eq!(r.unwrap(), 104);
    return 0;
}

fn test_option_try_none_propagates() -> i32 {
    let r: ?i32 = even_plus100(3);
    assert!(r.is_none());
    return 0;
}

fn test_option_multi_try_all_some() -> i32 {
    let r: ?i32 = two_evens(2, 8);
    assert!(r.is_some());
    assert_eq!(r.unwrap(), 10);
    return 0;
}

fn test_option_multi_try_one_none() -> i32 {
    let r: ?i32 = two_evens(2, 7);   // second is odd -> none
    assert!(r.is_none());
    return 0;
}

// `?` inside a loop: bubbles out of the whole function on the first failure.
fn sum_all(vals: *Vector<string>) -> !i32 {
    let mut acc: i32 = 0;
    for let i: i32 = 0; i < vals.len(); i++ {
        let n = parse_pos(vals.get(i))?;
        acc = acc + n;
    }
    return ok(acc);
}

fn test_try_in_loop_ok() -> i32 {
    let v: *Vector<string> = vec_of!("a", "b", "c");
    let r: !i32 = sum_all(v);
    assert!(r.is_ok());
    assert_eq!(r.unwrap(), 30);
    return 0;
}

fn test_try_in_loop_bubbles() -> i32 {
    let v: *Vector<string> = vec_of!("a", "bad", "c");
    let r: !i32 = sum_all(v);
    assert!(r.is_err());
    assert_str_eq!(r.unwrap_err(), "not a number");
    return 0;
}
