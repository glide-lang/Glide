import stdlib::testing::*;
import stdlib::os::*;

fn test_os_temp_dir_exists() -> i32 {
    let r: !string = os_temp_dir();
    assert!(r.ok);
    assert!(r.val.len() > 0);
    return 0;
}

fn test_os_home_dir_exists() -> i32 {
    let r: !string = os_home_dir();
