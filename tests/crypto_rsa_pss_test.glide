// RSASSA-PSS verification against an independent implementation (Python
// cryptography, rsa_pss_rsae_sha256 with saltLen=hLen), plus rejection of
// a tampered message and a tampered signature.
import stdlib::testing::*;
import stdlib::crypto::rsa::*;
import stdlib::hex::*;

fn _h(s: string) -> string { return hex_decode(s).unwrap(); }
fn _pub() -> string { return _h(""); }
fn _msg() -> string { return _h("636f6e74656e7420746f206265207369676e6564206279205253412d50535320696e20544c5320312e33204365727469666963617465566572696679"); }
fn _sig() -> string { return _h(""); }

fn test_pss_valid() -> i32 {
    let v: !bool = rsa_pss_verify(_pub(), PSS_SHA256, _msg(), _sig());
    assert!(v.is_ok());
    assert!(v.unwrap());
    return 0;
}

fn test_pss_rejects_wrong_message() -> i32 {
    let bad: string = _msg().concat("x");
    let v: !bool = rsa_pss_verify(_pub(), PSS_SHA256, bad, _sig());
    assert!(v.is_ok());
    assert!(!v.unwrap());
    return 0;
}

fn test_pss_rejects_tampered_sig() -> i32 {
    let s: string = _sig();
    let mut bad: string = "";
    for let i: i32 = 0; i < s.len(); i++ {
        let b: i32 = s.at(i).to_int() & 255;
        if i == 10 { bad = bad.concat(((b ^ 1) as char).to_string()); }
        else { bad = bad.concat((b as char).to_string()); }
    }
    let v: !bool = rsa_pss_verify(_pub(), PSS_SHA256, _msg(), bad);
    assert!(v.is_ok());
    assert!(!v.unwrap());
    return 0;
}
