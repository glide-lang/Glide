// File+folder package: importing the parent file makes referenced folder
// children loadable by their long path (`http::client::…`), and the short
// form keeps working when the child is imported directly.
import stdlib::testing::*;
import stdlib::http;

fn test_long_path_resolves() -> i32 {
    let c = http::client::HttpClient::new();
    assert!(c != null);
    c.free();
    return 0;
}

// Grouped brace import: submodules (and parent-file symbols) in one line.
import stdlib::http::{client, cookies};

fn test_grouped_import() -> i32 {
    let c = client::HttpClient::new();
    assert!(c != null);
    c.free();
    let c2 = http::client::HttpClient::new();
    assert!(c2 != null);
    c2.free();
    let ck = cookies::Cookie::new("alelo", "v");
    assert!(ck != null);
    return 0;
}

// Dir-only package group: `stdlib/net/` has no `net.glide`, the braces load
// the children directly.
import stdlib::net::{ip};

fn test_dir_only_group() -> i32 {
    let a = ip::IpAddr::v4(10, 0, 0, 7);
    assert_str_eq!(a.to_string(), "10.0.0.7");
    return 0;
}

// Nested brace imports: `{client, cookies::{CookieJar}}` — the child module
// loads AND its named symbol comes into scope bare; all three usage forms.
import stdlib::http::{cookies::{CookieJar}};

fn test_nested_brace_import() -> i32 {
    let j1 = cookies::CookieJar::new();
    assert!(j1 != null);
    let j2 = CookieJar::new();
    assert!(j2 != null);
    return 0;
}
