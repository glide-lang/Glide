// RSA PKCS#1 v1.5 signature verification, driven through certificate-chain
// verification of a real OpenSSL-generated RSA-2048 root + leaf.
import stdlib::testing::*;
import stdlib::crypto::x509::*;
import stdlib::crypto::rsa::*;
import stdlib::hex::*;

fn _ca() -> *Cert { return cert_parse(hex_decode("").unwrap()).unwrap(); }
fn _leaf() -> *Cert { return cert_parse(hex_decode("").unwrap()).unwrap(); }

fn test_rsa_pubkey_shape() -> i32 {
    let ca: *Cert = _ca();
    assert_str_eq!(ca.pubkey_alg, "1.2.840.113549.1.1.1");   // rsaEncryption
    assert_str_eq!(_leaf().sig_alg, "1.2.840.113549.1.1.11"); // sha256WithRSA
    assert_eq!(_leaf().signature.len(), 256);                 // 2048-bit sig
    return 0;
}

fn test_rsa_leaf_verifies_against_ca() -> i32 {
    let v: !bool = cert_verify_signature(_leaf(), _ca().pubkey);
    assert!(v.is_ok());
    assert!(v.unwrap());
    return 0;
}

fn test_rsa_chain_valid() -> i32 {
    let leaf: *Cert = _leaf();
    let roots: *Vector<*Cert> = Vector::new(); roots.push(_ca());
    let v: !bool = verify_chain(leaf, Vector::new(), roots, "rsa.glide.dev", leaf.not_before + 1000);
    assert!(v.is_ok());
    assert!(v.unwrap());
    return 0;
}

fn test_rsa_rejects_tampered_tbs() -> i32 {
    // A cert whose signature was made over a different key must fail: verify
    // the leaf against the WRONG (its own) public key instead of the CA's.
    let leaf: *Cert = _leaf();
    let v: !bool = cert_verify_signature(leaf, leaf.pubkey);
    assert!(!v.is_ok() || !v.unwrap());
    return 0;
}

fn test_rsa_wrong_host_rejected() -> i32 {
    let leaf: *Cert = _leaf();
    let roots: *Vector<*Cert> = Vector::new(); roots.push(_ca());
    assert!(verify_chain(leaf, Vector::new(), roots, "evil.com", leaf.not_before + 1000).is_err());
    return 0;
}
