import stdlib::testing::*;
import stdlib::hashmap::*;
import stdlib::http::*;
import stdlib::http::extract::*;

fn _req_with_headers(h: string) -> HttpRequest {
    return HttpRequest {
        method:        "GET",
        path:          "/x",
        version:       "HTTP/1.1",
        headers_block: h,
        body:          "",
        params:        null,
        queries:       null,
        tls:           false,
        headers_cache: null,
    };
}

// ---- Bearer ----------------------------------------------------------

fn test_bearer_extracts_token() -> i32 {
    let r: HttpRequest = _req_with_headers("Authorization: Bearer abc123\r\n");
    let b: !Bearer = Bearer::from_request(&r);
    assert!(b.ok);
    assert_str_eq!(b.val.token, "abc123");
    return 0;
}

fn test_bearer_missing_header_errs_401() -> i32 {
    let r: HttpRequest = _req_with_headers("");
    let b: !Bearer = Bearer::from_request(&r);
    assert_not!(b.ok);
    assert!(b.err.starts_with("401:"));
    return 0;
}

fn test_bearer_wrong_scheme_errs_401() -> i32 {
    let r: HttpRequest = _req_with_headers("Authorization: Basic abc\r\n");
    let b: !Bearer = Bearer::from_request(&r);
    assert_not!(b.ok);
    assert!(b.err.starts_with("401:"));
    return 0;
}

// ---- Headers --------------------------------------------------------

fn test_headers_get() -> i32 {
    let r: HttpRequest = _req_with_headers("X-Foo: bar\r\nUser-Agent: glide/1\r\n");
    let h: !Headers = Headers::from_request(&r);
    assert!(h.ok);
    assert_str_eq!(h.val.get("X-Foo"), "bar");
    assert_str_eq!(h.val.get("user-agent"), "glide/1");
    assert_str_eq!(h.val.get("missing"), "");
    return 0;
}

fn test_headers_has() -> i32 {
    let r: HttpRequest = _req_with_headers("Host: localhost\r\n");
    let h: !Headers = Headers::from_request(&r);
    assert!(h.ok);
    assert!(h.val.has("Host"));
    assert_not!(h.val.has("X-Custom"));
    return 0;
}

// ---- Authorization<Bearer> -----------------------------------------

fn test_authorization_bearer() -> i32 {
    let r: HttpRequest = _req_with_headers("Authorization: Bearer xyz\r\n");
    let a: !Authorization<Bearer> = Authorization::from_request(&r);
    assert!(a.ok);
    assert_str_eq!(a.val.scheme.token, "xyz");
    return 0;
}

fn test_authorization_bearer_missing() -> i32 {
    let r: HttpRequest = _req_with_headers("");
    let a: !Authorization<Bearer> = Authorization::from_request(&r);
    assert_not!(a.ok);
    return 0;
}

// ---- Authorization<Basic> ------------------------------------------

fn test_authorization_basic() -> i32 {
    let r: HttpRequest = _req_with_headers("Authorization: Basic alice:secret\r\n");
    let a: !Authorization<Basic> = Authorization::from_request(&r);
    assert!(a.ok);
    assert_str_eq!(a.val.scheme.user, "alice");
    assert_str_eq!(a.val.scheme.pass, "secret");
    return 0;
}

fn test_authorization_basic_malformed() -> i32 {
    let r: HttpRequest = _req_with_headers("Authorization: Basic noColon\r\n");
    let a: !Authorization<Basic> = Authorization::from_request(&r);
    assert_not!(a.ok);
    return 0;
}

// ---- Path<T> --------------------------------------------------------

fn _req_with_param(name: string, v: string) -> HttpRequest {
    let p: *HashMap<string> = HashMap::new();
    p.insert(name, v);
    return HttpRequest {
        method:        "GET",
        path:          "/x",
        version:       "HTTP/1.1",
        headers_block: "",
        body:          "",
        params:        p,
        queries:       null,
        tls:           false,
        headers_cache: null,
    };
}

fn test_path_string() -> i32 {
    let r: HttpRequest = _req_with_param("name", "alice");
    let p: !Path<string> = Path::extract(&r, "name");
    assert!(p.ok);
    assert_str_eq!(p.val.val, "alice");
    return 0;
}

fn test_path_int() -> i32 {
    let r: HttpRequest = _req_with_param("id", "42");
    let p: !Path<i32> = Path::extract(&r, "id");
    assert!(p.ok);
    assert_eq!(p.val.val, 42);
    return 0;
}

fn test_path_int_invalid_errs_400() -> i32 {
    let r: HttpRequest = _req_with_param("id", "notanint");
    let p: !Path<i32> = Path::extract(&r, "id");
    assert_not!(p.ok);
    assert!(p.err.starts_with("400:"));
    return 0;
}

fn test_path_missing_errs_404() -> i32 {
    let r: HttpRequest = _req_with_param("other", "x");
    let p: !Path<i32> = Path::extract(&r, "id");
    assert_not!(p.ok);
    assert!(p.err.starts_with("404:"));
    return 0;
}

// ---- HttpResponse::from_extract_err -------------------------------

fn test_from_extract_err_with_prefix() -> i32 {
    let r: HttpResponse = HttpResponse::from_extract_err("401:bad token");
    assert_eq!(r.status, 401);
    assert_str_eq!(r.body, "bad token");
    return 0;
}

fn test_from_extract_err_no_prefix_defaults_422() -> i32 {
    let r: HttpResponse = HttpResponse::from_extract_err("plain message");
    assert_eq!(r.status, 422);
    assert_str_eq!(r.body, "plain message");
    return 0;
}
