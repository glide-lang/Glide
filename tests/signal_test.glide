import stdlib::testing::*;
import stdlib::signal::*;
import stdlib::os::*;
import stdlib::time::*;

fn test_signal_to_int_known() -> int {
    assert_eq!(Signal::Hup.to_int(), 1);
    assert_eq!(Signal::Int.to_int(), 2);
    assert_eq!(Signal::Quit.to_int(), 3);
    assert_eq!(Signal::Kill.to_int(), 9);
    assert_eq!(Signal::Usr1.to_int(), 10);
    assert_eq!(Signal::Usr2.to_int(), 12);
    assert_eq!(Signal::Pipe.to_int(), 13);
    assert_eq!(Signal::Term.to_int(), 15);
    return 0;
}

fn test_signal_to_int_other() -> int {
    let s: Signal = Signal::Other(42);
    assert_eq!(s.to_int(), 42);
    return 0;
}

fn test_signal_from_int_known() -> int {
    let s1: Signal = Signal::from_int(2);
    assert_eq!(s1.to_int(), 2);
    let s2: Signal = Signal::from_int(15);
    assert_eq!(s2.to_int(), 15);
    return 0;
}

fn test_signal_from_int_unknown_becomes_other() -> int {
    let s: Signal = Signal::from_int(99);
    assert_eq!(s.to_int(), 99);
    return 0;
}

fn test_signal_name_known() -> int {
    assert_str_eq!(Signal::Hup.name(),  "SIGHUP");
    assert_str_eq!(Signal::Int.name(),  "SIGINT");
    assert_str_eq!(Signal::Term.name(), "SIGTERM");
    assert_str_eq!(Signal::Usr1.name(), "SIGUSR1");
    return 0;
}

fn test_signal_chan_returns_chan() -> int {
    let _c: chan<Signal> = signal_chan(Signal::Usr1);
    let _r: ! = signal_default(Signal::Usr1);
    return 0;
}

fn test_signal_chan_idempotent() -> int {
    let _a: chan<Signal> = signal_chan(Signal::Usr2);
    let _b: chan<Signal> = signal_chan(Signal::Usr2);
    let _r: ! = signal_default(Signal::Usr2);
    return 0;
}

fn test_signal_default_succeeds() -> int {
    let _c: chan<Signal> = signal_chan(Signal::Hup);
    let r: ! = signal_default(Signal::Hup);
    assert!(r.ok);
    return 0;
}

fn test_signal_ignore_succeeds() -> int {
    let r: ! = signal_ignore(Signal::Pipe);
    assert!(r.ok);
    let _r: ! = signal_default(Signal::Pipe);
    return 0;
}

// signal_raise direct-push: works on ALL platforms when subscribed.
fn test_signal_raise_caught_typed() -> int {
    let intr: chan<Signal> = signal_chan(Signal::Usr1);
    let _r: ! = signal_raise(Signal::Usr1);
    let timer: chan<i64> = after(Duration::from_secs(2));
    let mut received_tag: int = 0 - 1;
    select! {
        s = intr.recv()  => { received_tag = s.to_int(); }
        _ = timer.recv() => { }
    }
    assert_eq!(received_tag, 10);
    let _d: ! = signal_default(Signal::Usr1);
    return 0;
}

fn test_signal_raise_other() -> int {
    let custom: Signal = Signal::Other(20);
    let intr: chan<Signal> = signal_chan(custom);
    let _r: ! = signal_raise(custom);
    let timer: chan<i64> = after(Duration::from_secs(2));
    let mut received_signum: int = 0 - 1;
    select! {
        s = intr.recv()  => { received_signum = s.to_int(); }
        _ = timer.recv() => { }
    }
    assert_eq!(received_signum, 20);
    let _d: ! = signal_default(custom);
    return 0;
}
