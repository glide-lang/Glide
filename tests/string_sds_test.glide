// SDS strings: `.len()` is O(1) from a header stored before the data. These
// guard that the header length matches strlen for every way a string is made —
// literals (incl. escapes / hex / UTF-8), concat, substring, format, FFI.
import stdlib::os::*;

fn test_literal_len() -> i32 {
    assert_eq!("".len(), 0);
    assert_eq!("hello".len(), 5);
    assert_eq!("a".len(), 1);
    // simple escapes are one byte each
    assert_eq!("a\nb\tc".len(), 5);          // a \n b \t c
    assert_eq!("\"".len(), 1);               // one quote
    assert_eq!("\\".len(), 1);               // one backslash
    // hex escape is one byte; ANSI reset = ESC + "[0m" = 4 bytes
    assert_eq!("\x1b[0m".len(), 4);
    // data right after the header's octal prefix that starts with a digit
    assert_eq!("123".len(), 3);
    return 0;
}

fn test_utf8_byte_len() -> i32 {
    // multi-byte codepoints count as their UTF-8 byte length (== strlen)
    assert_eq!("áé".len(), 4);               // 2 bytes each
    assert_eq!("héllo".len(), 6);            // h + é(2) + l + l + o
    return 0;
}

fn test_built_len() -> i32 {
    assert_eq!("foo".concat("bar").len(), 6);
    assert_eq!("foo".concat("").len(), 3);
    assert_eq!("".concat("").len(), 0);
    assert_eq!("hello world".substring(0, 5).len(), 5);
    assert_eq!("hello world".substring(6, 11).len(), 5);
    assert_eq!("ab".repeat(4).len(), 8);
    assert_eq!(42.to_string().len(), 2);
    assert_eq!((0 - 123).to_string().len(), 4);   // "-123"
    return 0;
}

fn test_eq_and_at() -> i32 {
    assert!("abc".eq("abc"));
    assert!(!"abc".eq("abd"));
    assert!(!"abc".eq("ab"));            // length differs -> not equal
    assert!("foo".concat("bar").eq("foobar"));
    assert_eq!("abc".at(0).to_int(), 97);
    assert_eq!("abc".at(2).to_int(), 99);
    return 0;
}

fn test_ffi_string_len() -> i32 {
    // os_name() returns a string from a C extern; the adopt-wrap must have
    // given it a header, so .len() and .concat round-trip correctly.
    let name: string = os_name();
    let n: i32 = name.len();
    assert!(n > 0);
    assert_eq!(name.concat("!").len(), n + 1);
    return 0;
}

// A NUL byte in the middle of a string must NOT truncate it: strings are
// length-prefixed, so every op works off the header, not strlen. This is
// what makes binary socket reads / archive bodies survive intact. The NUL
// is introduced via concat of a `\x00`-terminated literal (the unambiguous
// form — a `\x00` immediately followed by hex digits would be swallowed by
// the C hex-escape, a separate literal-emission quirk).
fn test_embedded_nul_is_binary_safe() -> i32 {
    let s: string = "ab\x00".concat("cd");      // 5 bytes, NUL at index 2
    assert_eq!(s.len(), 5);
    assert_eq!(s.at(2).to_int(), 0);
    assert_eq!(s.at(3).to_int(), 99);           // 'c' after the NUL

    // substring across the NUL keeps every byte (no NUL-stop truncation).
    let mid: string = s.substring(1, 5);        // "b" NUL "cd"
    assert_eq!(mid.len(), 4);
    assert_eq!(mid.at(1).to_int(), 0);
    assert_eq!(mid.at(3).to_int(), 100);        // 'd'

    // A leading-NUL slice is still its full length, not empty.
    let head: string = s.substring(2, 4);       // NUL "c"
    assert_eq!(head.len(), 2);
    assert_eq!(head.at(0).to_int(), 0);

    // concat past a NUL preserves both halves' full byte counts.
    let joined: string = s.concat(s);
    assert_eq!(joined.len(), 10);
    assert_eq!(joined.at(7).to_int(), 0);       // second copy's NUL
    return 0;
}

// substring clamps an out-of-range end to the real length instead of
// reading past the buffer.
fn test_substring_end_clamp() -> i32 {
    let s: string = "hello";
    assert_eq!(s.substring(0, 999).len(), 5);
    assert_eq!(s.substring(3, 999).len(), 2);
    assert_eq!(s.substring(10, 20).len(), 0);
    return 0;
}
