import stdlib::testing::*;
import stdlib::io::*;
import stdlib::bytes::*;

fn test_io_write_does_not_hang() -> int {
    io_write("");
    return 0;
}

fn test_byte_buffer_round_trip_bytes() -> int {
    let buf: *ByteBuffer = ByteBuffer::new();
    defer buf.free();

    buf.push(65 as u8);
    buf.push(0 as u8);
    buf.push(255 as u8);

    assert_eq!(buf.len(), 3);
    assert_eq!(buf.at(0) as int, 65);
    assert_eq!(buf.at(1) as int, 0);
    assert_eq!(buf.at(2) as int, 255);
    return 0;
}

fn test_byte_buffer_string_round_trip() -> int {
    let buf: *ByteBuffer = ByteBuffer::new();
    defer buf.free();

    buf.push_str("abc");
    buf.push(68 as u8);
    assert_eq!(buf.len(), 4);
    assert_str_eq!(buf.as_string(), "abcD");
    return 0;
}

fn test_flush_does_not_hang() -> int {
    flush();
    return 0;
}
