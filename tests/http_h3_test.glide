import stdlib::testing::*;
import stdlib::http::*;
import stdlib::http::h3::*;
import stdlib::sync::*;
import stdlib::time::*;

// HTTP/3 loopback. Generates a self-signed cert at test start, spawns a
// minimal h3 server on 127.0.0.1:45330, then drives a client request to
// it. Locks in the server-side handshake + nghttp3 wiring (regression
// guard for the SCID + nghttp3-timing bugs fixed in 7a07bd1).

fn _h3_handler(req: *HttpRequest) -> HttpResponse {
    return HttpResponse::ok()
        .set("X-Echo-Path", req.path)
        .body("h3 echo: ".concat(req.path));
}

fn _h3_server_thread() {
    let r: !int = http3_listen(45330, "h3_test_cert.pem", "h3_test_key.pem",
                                _h3_handler);
    if !r.ok { println!("h3 server: ${r.err}"); }
}

fn _start_h3_server() -> bool {
    let cr: !int = h3_make_self_signed_cert("h3_test_cert.pem",
                                              "h3_test_key.pem",
                                              "localhost", 30);
    if !cr.ok { return false; }
    spawn_thread _h3_server_thread();
    sleep_ms(500);
    return true;
}

fn test_h3_loopback_get_returns_200() -> int {
    if !_start_h3_server() { return 1; }
    let r: !*HttpResponse = http3_request("GET",
                                            "https://127.0.0.1:45330/hello",
                                            "", "", true);
    assert!(r.ok);
    assert_eq!(r.val.status, 200);
    return 0;
}

fn test_h3_loopback_body_echoes_path() -> int {
    let r: !*HttpResponse = http3_request("GET",
                                            "https://127.0.0.1:45330/foo/bar",
                                            "", "", true);
    assert!(r.ok);
    assert_str_eq!(r.val.body, "h3 echo: /foo/bar");
    return 0;
}

fn test_h3_loopback_custom_header_present() -> int {
    let r: !*HttpResponse = http3_request("GET",
                                            "https://127.0.0.1:45330/custom",
                                            "", "", true);
    assert!(r.ok);
    assert!(r.val.headers_block.contains("x-echo-path: /custom"));
    return 0;
}

// Concurrent connection regression: spin up 4 client threads, all sending
// requests simultaneously. Validates that the C-side reader thread can
// multiplex multiple in-flight conns + dispatch them serially through the
// accept loop without dropping any.

fn _h3_conc_client(path: string, sink: *Vector<int>, lock: *Mutex<int>) {
    let r: !*HttpResponse = http3_request("GET",
                                            "https://127.0.0.1:45330".concat(path),
                                            "", "", true);
    lock.lock();
    if r.ok { sink.push(r.val.status); }
    else { sink.push(-1); }
    lock.unlock();
}

fn test_h3_concurrent_connections() -> int {
    let statuses: *Vector<int> = Vector::new();
    let lock: *Mutex<int> = Mutex::new(0);
    spawn_thread _h3_conc_client("/c1", statuses, lock);
    spawn_thread _h3_conc_client("/c2", statuses, lock);
    spawn_thread _h3_conc_client("/c3", statuses, lock);
    spawn_thread _h3_conc_client("/c4", statuses, lock);
    // Poll until 4 statuses landed or 8s budget expires.
    let mut waited: int = 0;
    while waited < 8000 {
        lock.lock();
        let n: int = statuses.len();
        lock.unlock();
        if n >= 4 { break; }
        sleep_ms(100);
        waited = waited + 100;
    }
    assert_eq!(statuses.len(), 4);
    for let i: int = 0; i < 4; i++ {
        assert_eq!(statuses.get(i), 200);
    }
    return 0;
}

// Handler parallelism: with a 400ms-sleeping handler, 4 simultaneous
// clients should complete in ~400ms (handlers run on their own pthreads)
// rather than ~1600ms (serial dispatch). A 1500ms cap leaves headroom
// for handshake overhead + slow CI without giving false positives.

fn _h3_slow_handler(req: *HttpRequest) -> HttpResponse {
    sleep_ms(400);
    return HttpResponse::ok().body("slow: ".concat(req.path));
}

fn _h3_slow_server_thread() {
    let r: !int = http3_listen(45331, "h3_test_cert.pem", "h3_test_key.pem",
                                _h3_slow_handler);
    if !r.ok { println!("h3 slow server: ${r.err}"); }
}

fn _h3_slow_client(path: string, sink: *Vector<int>, lock: *Mutex<int>) {
    let r: !*HttpResponse = http3_request("GET",
                                            "https://127.0.0.1:45331".concat(path),
                                            "", "", true);
    lock.lock();
    if r.ok { sink.push(r.val.status); }
    else { sink.push(-1); }
    lock.unlock();
}

fn test_h3_parallel_handlers() -> int {
    spawn_thread _h3_slow_server_thread();
    sleep_ms(500);

    let statuses: *Vector<int> = Vector::new();
    let lock: *Mutex<int> = Mutex::new(0);
    let t0: int = Time::now().unix_millis() as int;
    spawn_thread _h3_slow_client("/p1", statuses, lock);
    spawn_thread _h3_slow_client("/p2", statuses, lock);
    spawn_thread _h3_slow_client("/p3", statuses, lock);
    spawn_thread _h3_slow_client("/p4", statuses, lock);

    let mut waited: int = 0;
    while waited < 2000 {
        lock.lock();
        let n: int = statuses.len();
        lock.unlock();
        if n >= 4 { break; }
        sleep_ms(50);
        waited = waited + 50;
    }
    let elapsed: int = (Time::now().unix_millis() as int) - t0;
    assert_eq!(statuses.len(), 4);
    // Parallel: ~400-1000ms. Serial would be ~1600ms+. 1500ms cap.
    assert!(elapsed < 1500);
    return 0;
}
