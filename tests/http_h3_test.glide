import stdlib::testing::*;
import stdlib::http::*;
import stdlib::http::h3::*;
import stdlib::sync::*;
import stdlib::time::*;

// HTTP/3 loopback. Generates a self-signed cert at test start, spawns a
// minimal h3 server on 127.0.0.1:45330, then drives a client request to
// it. Locks in the server-side handshake + nghttp3 wiring (regression
// guard for the SCID + nghttp3-timing bugs fixed in 7a07bd1).

fn _h3_handler(req: *HttpRequest) -> HttpResponse {
    return HttpResponse::ok()
        .set("X-Echo-Path", req.path)
        .body("h3 echo: ".concat(req.path));
}

fn _h3_server_thread() {
    let r: !int = http3_listen(45330, "h3_test_cert.pem", "h3_test_key.pem",
                                _h3_handler);
    if !r.ok { println!("h3 server: ${r.err}"); }
}

fn _start_h3_server() -> bool {
    let cr: !int = h3_make_self_signed_cert("h3_test_cert.pem",
                                              "h3_test_key.pem",
                                              "localhost", 30);
    if !cr.ok { return false; }
    spawn_thread _h3_server_thread();
    sleep_ms(500);
    return true;
}

fn test_h3_loopback_get_returns_200() -> int {
    if !_start_h3_server() { return 1; }
    let r: !*HttpResponse = http3_request("GET",
                                            "https://127.0.0.1:45330/hello",
                                            "", "", true);
    assert!(r.ok);
    assert_eq!(r.val.status, 200);
    return 0;
}

fn test_h3_loopback_body_echoes_path() -> int {
    let r: !*HttpResponse = http3_request("GET",
                                            "https://127.0.0.1:45330/foo/bar",
                                            "", "", true);
    assert!(r.ok);
    assert_str_eq!(r.val.body, "h3 echo: /foo/bar");
    return 0;
}

fn test_h3_loopback_custom_header_present() -> int {
    let r: !*HttpResponse = http3_request("GET",
                                            "https://127.0.0.1:45330/custom",
                                            "", "", true);
    assert!(r.ok);
    assert!(r.val.headers_block.contains("x-echo-path: /custom"));
    return 0;
}

// Concurrent connection regression: spin up 4 client threads, all sending
// requests simultaneously. Validates that the C-side reader thread can
// multiplex multiple in-flight conns + dispatch them serially through the
// accept loop without dropping any.

fn _h3_conc_client(path: string, sink: *Vector<int>, lock: *Mutex<int>) {
    let r: !*HttpResponse = http3_request("GET",
                                            "https://127.0.0.1:45330".concat(path),
                                            "", "", true);
    lock.lock();
    if r.ok { sink.push(r.val.status); }
    else { sink.push(-1); }
    lock.unlock();
}

fn test_h3_concurrent_connections() -> int {
    let statuses: *Vector<int> = Vector::new();
    let lock: *Mutex<int> = Mutex::new(0);
    spawn_thread _h3_conc_client("/c1", statuses, lock);
    spawn_thread _h3_conc_client("/c2", statuses, lock);
    spawn_thread _h3_conc_client("/c3", statuses, lock);
    spawn_thread _h3_conc_client("/c4", statuses, lock);
    // Poll until 4 statuses landed or 8s budget expires.
    let mut waited: int = 0;
    while waited < 8000 {
        lock.lock();
        let n: int = statuses.len();
        lock.unlock();
        if n >= 4 { break; }
        sleep_ms(100);
        waited = waited + 100;
    }
    assert_eq!(statuses.len(), 4);
    for let i: int = 0; i < 4; i++ {
        assert_eq!(statuses.get(i), 200);
    }
    return 0;
}

// Handler parallelism: with a 400ms-sleeping handler, 4 simultaneous
// clients should complete in ~400ms (handlers run on their own pthreads)
// rather than ~1600ms (serial dispatch). A 1500ms cap leaves headroom
// for handshake overhead + slow CI without giving false positives.

fn _h3_slow_handler(req: *HttpRequest) -> HttpResponse {
    sleep_ms(400);
    return HttpResponse::ok().body("slow: ".concat(req.path));
}

fn _h3_slow_server_thread() {
    let r: !int = http3_listen(45331, "h3_test_cert.pem", "h3_test_key.pem",
                                _h3_slow_handler);
    if !r.ok { println!("h3 slow server: ${r.err}"); }
}

fn _h3_slow_client(path: string, sink: *Vector<int>, lock: *Mutex<int>) {
    let r: !*HttpResponse = http3_request("GET",
                                            "https://127.0.0.1:45331".concat(path),
                                            "", "", true);
    lock.lock();
    if r.ok { sink.push(r.val.status); }
    else { sink.push(-1); }
    lock.unlock();
}

// Streaming response: handler returns an HttpResponse.stream(source) and
// the H3 server should deliver chunks incrementally via nghttp3's
// data_reader. Tested with a tiny ChunkSource that emits N labeled
// chunks, then EOF. Client receives the concatenated body.

pub struct H3Ticker {
    pub idx: int,
    pub total: int,
}

impl ChunkSource for H3Ticker {
    fn next_chunk(self: *H3Ticker) -> ?string {
        if self.idx >= self.total { return none(); }
        self.idx = self.idx + 1;
        return some("tick=".concat(self.idx.to_string()).concat(";"));
    }
}

fn _h3_stream_handler(_req: *HttpRequest) -> HttpResponse {
    let t: *H3Ticker = malloc(sizeof(H3Ticker)) as *H3Ticker;
    t.idx = 0;
    t.total = 5;
    return HttpResponse::ok()
        .set("Content-Type", "text/plain")
        .stream(t as *dyn ChunkSource);
}

fn _h3_stream_server_thread() {
    let r: !int = http3_listen(45332, "h3_test_cert.pem", "h3_test_key.pem",
                                _h3_stream_handler);
    if !r.ok { println!("h3 stream server: ${r.err}"); }
}

fn test_h3_streaming_chunks() -> int {
    spawn_thread _h3_stream_server_thread();
    sleep_ms(500);

    let r: !*HttpResponse = http3_request("GET",
                                            "https://127.0.0.1:45332/stream",
                                            "", "", true);
    assert!(r.ok);
    assert_eq!(r.val.status, 200);
    // 5 chunks emitted by the ticker.
    assert_str_eq!(r.val.body, "tick=1;tick=2;tick=3;tick=4;tick=5;");
    return 0;
}

// Session cache: a fresh H3SessionCache observes attempts=0/accepted=0.
// After the first request, the new_session callback stamps a ticket into
// the cache (asynchronously — OpenSSL sends NewSessionTicket post-
// handshake, so we sleep briefly to give the client thread a chance to
// process it). The second request finds the ticket and bumps attempts.

fn test_h3_session_cache_resumes() -> int {
    let cache: *H3SessionCache = H3SessionCache::new();
    defer cache.free();
    assert_eq!(cache.attempts(), 0);

    let r1: !*HttpResponse = http3_request_cached("GET",
                                                    "https://127.0.0.1:45330/x",
                                                    "", "", true, cache);
    assert!(r1.ok);
    // First request: cold cache, no attempt.
    assert_eq!(cache.attempts(), 0);
    // Give the ticket time to land via new_session_cb.
    sleep_ms(200);

    let r2: !*HttpResponse = http3_request_cached("GET",
                                                    "https://127.0.0.1:45330/y",
                                                    "", "", true, cache);
    assert!(r2.ok);
    // Second request found the cached session and tried to resume.
    assert_eq!(cache.attempts(), 1);
    return 0;
}

// Cache persistence: save → free → new → load round-trips the entries.
// The cache is empty on the new instance until load picks up the file.

// End-to-end 0-RTT: a fresh cache observes accepted=0 after the first
// (cold) request, then accepted=1 after the second (warm) one. This
// locks in that early data actually engages on the wire — the cache's
// stamped ticket gets installed via SSL_set_session, the custom
// client_initial cb submits the request via nghttp3 with 0-RTT keys,
// the server's recv_stream_data buffers the headers before nghttp3 is
// up, and handshake_completed flushes the buffer through nghttp3 so
// the handler still runs and sends a real response.

fn test_h3_0rtt_engages_on_warm_cache() -> int {
    let cache: *H3SessionCache = H3SessionCache::new();
    defer cache.free();
    let r1: !*HttpResponse = http3_request_cached("GET",
                                                    "https://127.0.0.1:45330/cold",
                                                    "", "", true, cache);
    assert!(r1.ok);
    assert_eq!(cache.accepted(), 0);
    sleep_ms(300);  // let the ticket land via new_session_cb
    let r2: !*HttpResponse = http3_request_cached("GET",
                                                    "https://127.0.0.1:45330/warm",
                                                    "", "", true, cache);
    assert!(r2.ok);
    assert_eq!(r2.val.status, 200);
    // The server accepted 0-RTT — saved an RTT vs a full handshake.
    assert_eq!(cache.accepted(), 1);
    return 0;
}

fn test_h3_cache_persistence_round_trip() -> int {
    let path: string = "h3_cache_test.bin";
    let cache1: *H3SessionCache = H3SessionCache::new();
    let r: !*HttpResponse = http3_request_cached("GET",
                                                   "https://127.0.0.1:45330/p",
                                                   "", "", true, cache1);
    assert!(r.ok);
    sleep_ms(200);
    // Touch the cache so an entry lands.
    let _r2: !*HttpResponse = http3_request_cached("GET",
                                                    "https://127.0.0.1:45330/q",
                                                    "", "", true, cache1);
    let saved: bool = cache1.save(path);
    assert!(saved);
    cache1.free();

    let cache2: *H3SessionCache = H3SessionCache::new();
    defer cache2.free();
    let loaded: int = cache2.load(path);
    // At least one entry survived save→load.
    assert!(loaded >= 1);
    return 0;
}

fn test_h3_parallel_handlers() -> int {
    spawn_thread _h3_slow_server_thread();
    sleep_ms(500);

    let statuses: *Vector<int> = Vector::new();
    let lock: *Mutex<int> = Mutex::new(0);
    let t0: int = Time::now().unix_millis() as int;
    spawn_thread _h3_slow_client("/p1", statuses, lock);
    spawn_thread _h3_slow_client("/p2", statuses, lock);
    spawn_thread _h3_slow_client("/p3", statuses, lock);
    spawn_thread _h3_slow_client("/p4", statuses, lock);

    let mut waited: int = 0;
    while waited < 3000 {
        lock.lock();
        let n: int = statuses.len();
        lock.unlock();
        if n >= 4 { break; }
        sleep_ms(50);
        waited = waited + 50;
    }
    let elapsed: int = (Time::now().unix_millis() as int) - t0;
    assert_eq!(statuses.len(), 4);
    // Parallel: ~400-1500ms on loopback. Serial would be 1600ms+ before
    // including handshake overhead. 1500ms cap is the line that separates
    // "handlers ran concurrently" from "handlers serialized".
    assert!(elapsed < 1500);
    return 0;
}
