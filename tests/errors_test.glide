// Central error model: canonical construction, decoding, and recognition
// of kind/origin.
import stdlib::testing::*;
import stdlib::errors::*;

// emit() -> of() preserves module, op, kind, path, and os_code.
fn test_roundtrip() -> i32 {
    let s: string = Error::new("fs", "open", ErrorKind::NotFound,
                               "no such file or directory", "/tmp/x", 2).emit();
    assert_str_eq!(s, "fs: open: NotFound: no such file or directory [/tmp/x] (os:2)");
    let e* = Error::of(s);
    assert_str_eq!(e.module(), "fs");
    assert_str_eq!(e.op(), "open");
    assert!(e.kind() == ErrorKind::NotFound);
    assert!(e.is(ErrorKind::NotFound));
    assert_str_eq!(e.path(), "/tmp/x");
    assert_eq!(e.os_code(), 2);
    assert_str_eq!(e.message(), "no such file or directory");
    e.free();
    return 0;
}

// A message with an embedded ':' does not confuse the parser (path/os come from the tail).
fn test_colon_in_message() -> i32 {
    let e* = Error::of("net: connect: Other: dns: name not resolved [host:443] (os:0)");
    assert_str_eq!(e.module(), "net");
    assert_str_eq!(e.op(), "connect");
    assert_str_eq!(e.message(), "dns: name not resolved");
    assert_str_eq!(e.path(), "host:443");
    return 0;
}

// Missing optional fields (no path, no os).
fn test_no_optionals() -> i32 {
    let s: string = Error::new("fs", "flush", ErrorKind::Other, "boom", "", 0).emit();
    assert_str_eq!(s, "fs: flush: Other: boom");
    let e* = Error::of(s);
    assert_str_eq!(e.path(), "");
    assert_eq!(e.os_code(), 0);
    assert_str_eq!(e.message(), "boom");
    return 0;
}

// A non-canonical string never breaks: it becomes Other with the whole message.
fn test_non_canonical() -> i32 {
    let e* = Error::of("something went wrong");
    assert!(e.kind() == ErrorKind::Other);
    assert_str_eq!(e.message(), "something went wrong");
    assert_str_eq!(e.module(), "");
    return 0;
}

// OS errno -> ErrorKind.
fn test_from_os() -> i32 {
    assert!(ErrorKind::from_os(2) == ErrorKind::NotFound);        // ENOENT
    assert!(ErrorKind::from_os(13) == ErrorKind::PermissionDenied); // EACCES
    assert!(ErrorKind::from_os(17) == ErrorKind::AlreadyExists);  // EEXIST
    assert!(ErrorKind::from_os(999) == ErrorKind::Other);
    return 0;
}

// to_string <-> from_token for each kind.
fn test_token_roundtrip() -> i32 {
    assert!(ErrorKind::from_token(ErrorKind::NotFound.to_string()) == ErrorKind::NotFound);
    assert!(ErrorKind::from_token(ErrorKind::DirectoryNotEmpty.to_string()) == ErrorKind::DirectoryNotEmpty);
    assert!(ErrorKind::from_token(ErrorKind::WouldBlock.to_string()) == ErrorKind::WouldBlock);
    assert!(ErrorKind::from_token("xyz") == ErrorKind::Other);
    return 0;
}

// The error() shortcut derives kind+message from the errno and stays parseable.
fn test_error_shortcut() -> i32 {
    let s: string = error("fs", "read", "/nonexistent", 2);
    let e* = Error::of(s);
    assert!(e.kind() == ErrorKind::NotFound);
    assert_str_eq!(e.op(), "read");
    assert_str_eq!(e.path(), "/nonexistent");
    assert_eq!(e.os_code(), 2);
    // kind_of agrees with the full decode, without allocating.
    assert!(kind_of(s) == ErrorKind::NotFound);
    return 0;
}
