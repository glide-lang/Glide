import stdlib::testing::*;
import stdlib::hashmap::*;

fn test_new_is_empty() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();
    assert_eq!(m.len(), 0);
    assert_not!(m.contains("anything"));
    return 0;
}

fn test_insert_get_contains() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();

    m.insert("one", 1);
    m.insert("two", 2);
    m.insert("three", 3);

    assert_eq!(m.len(), 3);
    assert!(m.contains("one"));
    assert!(m.contains("two"));
    assert!(m.contains("three"));
    assert_not!(m.contains("four"));

    assert_eq!(m.get("one"), 1);
    assert_eq!(m.get("two"), 2);
    assert_eq!(m.get("three"), 3);
    return 0;
}

fn test_overwrite_keeps_len() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();
    m.insert("k", 1);
    assert_eq!(m.len(), 1);
    m.insert("k", 99);
    assert_eq!(m.len(), 1);
    assert_eq!(m.get("k"), 99);
    return 0;
}

fn test_remove() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();
    m.insert("a", 1);
    m.insert("b", 2);
    assert_eq!(m.len(), 2);

    assert!(m.remove("a"));
    assert_eq!(m.len(), 1);
    assert_not!(m.contains("a"));
    assert!(m.contains("b"));

    assert_not!(m.remove("nope"));
    assert_eq!(m.len(), 1);
    return 0;
}

fn test_grows_past_default_capacity() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();
    for let i: i32 = 0; i < 100; i++ {
        let key: string = "k${i}";
        m.insert(key, i);
    }
    assert_eq!(m.len(), 100);
    for let i: i32 = 0; i < 100; i++ {
        let key: string = "k${i}";
        assert!(m.contains(key));
        assert_eq!(m.get(key), i);
    }
    return 0;
}

fn test_string_value_type() -> i32 {
    let m: *HashMap<string> = HashMap::new();
    defer m.free();
    m.insert("name", "alice");
    m.insert("city", "wonderland");
    assert_str_eq!(m.get("name"), "alice");
    assert_str_eq!(m.get("city"), "wonderland");
    return 0;
}

fn _dbl(x: i32) -> i32 { return x * 2; }

fn test_is_empty() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();
    assert!(m.is_empty());
    m.insert("x", 1);
    assert_not!(m.is_empty());
    return 0;
}

fn test_values_snapshot() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();
    m.insert("a", 10); m.insert("b", 20); m.insert("c", 30);
    let vs: *Vector<i32> = m.values();
    assert_eq!(vs.len(), 3);
    assert_eq!(vs.sum(), 60);
    return 0;
}

fn test_values_empty_map() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();
    let vs: *Vector<i32> = m.values();
    assert_eq!(vs.len(), 0);
    return 0;
}

fn test_map_values_doubles() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();
    m.insert("one", 1); m.insert("two", 2); m.insert("three", 3);
    let d: *HashMap<i32> = m.map_values(_dbl);
    defer d.free();
    assert_eq!(d.len(), 3);
    assert_eq!(d.get("one"), 2);
    assert_eq!(d.get("two"), 4);
    assert_eq!(d.get("three"), 6);
    // original unchanged
    assert_eq!(m.get("one"), 1);
    return 0;
}

fn _add_pair(acc: i32, p: *Pair<string, i32>) -> i32 { return acc + p.second; }

fn test_entries_count() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();
    m.insert("a", 1); m.insert("b", 2); m.insert("c", 3);
    let es: *Vector<*Pair<string, i32>> = m.entries();
    assert_eq!(es.len(), 3);
    return 0;
}

fn test_entries_empty_map() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();
    let es: *Vector<*Pair<string, i32>> = m.entries();
    assert_eq!(es.len(), 0);
    return 0;
}

fn test_entries_sum_via_fold() -> i32 {
    let m: *HashMap<i32> = HashMap::new();
    defer m.free();
    m.insert("a", 10); m.insert("b", 20); m.insert("c", 30);
    let es: *Vector<*Pair<string, i32>> = m.entries();
    let total: i32 = es.fold(0, _add_pair);
    assert_eq!(total, 60);
    return 0;
}

fn test_pair_new() -> i32 {
    let p: *Pair<i32, string> = Pair::new(42, "answer");
    assert_eq!(p.first, 42);
    assert_str_eq!(p.second, "answer");
    return 0;
}
