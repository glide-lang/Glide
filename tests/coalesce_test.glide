// `??` coalesce operator: supplies a fallback for the failure case of an
// Option (`?T`), a Result (`!T`) and a nullable pointer (`*T`). The err-form
// (`opt ?? err(msg)`) converts an Option into a Result so it can be chained
// with `?`.
import stdlib::testing::*;

fn maybe(n: i32) -> ?i32 {
    if n >= 0 { return some(n); }
    return none();
}

fn parse(s: string) -> !i32 {
    if s.eq("bad") { return err("bad"); }
    return ok(7);
}

fn test_option_coalesce_uses_value() -> i32 {
    let v: i32 = maybe(5) ?? 0;
    assert_eq!(v, 5);
    return 0;
}

fn test_option_coalesce_uses_default() -> i32 {
    let v: i32 = maybe(-1) ?? 99;
    assert_eq!(v, 99);
    return 0;
}

fn test_result_coalesce_uses_value() -> i32 {
    let v: i32 = parse("ok") ?? 0;
    assert_eq!(v, 7);
    return 0;
}

fn test_result_coalesce_uses_default() -> i32 {
    let v: i32 = parse("bad") ?? 42;
    assert_eq!(v, 42);
    return 0;
}

fn test_coalesce_default_is_expression() -> i32 {
    // The fallback can be any expression, evaluated only on the failure branch.
    let base: i32 = 10;
    let v: i32 = maybe(-1) ?? (base * 3);
    assert_eq!(v, 30);
    return 0;
}

fn test_coalesce_string_option() -> i32 {
    let name: ?string = none();
    let s: string = name ?? "anonymous";
    assert_str_eq!(s, "anonymous");
    let name2: ?string = some("alice");
    let s2: string = name2 ?? "anonymous";
    assert_str_eq!(s2, "alice");
    return 0;
}

fn test_coalesce_string_result() -> i32 {
    let r: !string = err("oops");
    let s: string = r ?? "fallback";
    assert_str_eq!(s, "fallback");
    return 0;
}

// Nullable pointer coalesce: null falls back to the alternative.
struct Node { v: i32 }

fn pick(b: bool) -> *Node {
    if b { let n: *Node = Node { v: 1 }; return n; }
    return null;
}

fn test_nullable_pointer_coalesce_null() -> i32 {
    let fallback: *Node = Node { v: 77 };
    let chosen: *Node = pick(false) ?? fallback;
    assert_eq!(chosen.v, 77);
    return 0;
}

fn test_nullable_pointer_coalesce_nonnull() -> i32 {
    let fallback: *Node = Node { v: 77 };
    let chosen: *Node = pick(true) ?? fallback;
    assert_eq!(chosen.v, 1);
    return 0;
}

// Coalesce feeding directly into further use.
fn test_coalesce_then_arithmetic() -> i32 {
    let total: i32 = (maybe(-1) ?? 100) + (maybe(4) ?? 0);
    assert_eq!(total, 104);
    return 0;
}

// err-form: `?T ?? err(msg)` keeps Result shape (`!T`) instead of extracting,
// so the none branch becomes an Err that `?` can propagate.
fn test_option_coalesce_err_form() -> i32 {
    let hit: !i32 = maybe(5) ?? err("was none");
    assert!(hit.is_ok());
    assert_eq!(hit.unwrap(), 5);
    let miss: !i32 = maybe(-1) ?? err("was none");
    assert!(miss.is_err());
    assert_str_eq!(miss.unwrap_err(), "was none");
    return 0;
}

// err-form on a Result LHS replaces the error, keeping an Ok untouched.
fn test_result_coalesce_err_form() -> i32 {
    let kept: !i32 = parse("ok") ?? err("replaced");
    assert!(kept.is_ok());
    assert_eq!(kept.unwrap(), 7);
    let swapped: !i32 = parse("bad") ?? err("replaced");
    assert!(swapped.is_err());
    assert_str_eq!(swapped.unwrap_err(), "replaced");
    return 0;
}

fn lookup_name(n: i32) -> ?string {
    if n > 0 { return some("found"); }
    return none();
}

// The err-form result chains with `?` (parenthesized: postfix `?` binds
// tighter than `??`). Also covers a `!T` that only exists via the err-form.
fn chain(n: i32) -> !string {
    let s: string = (lookup_name(n) ?? err("nf"))?;
    return ok(s.concat("!"));
}

fn test_coalesce_err_form_chains_with_try() -> i32 {
    let a: !string = chain(1);
    assert!(a.is_ok());
    assert_str_eq!(a.unwrap(), "found!");
    let b: !string = chain(-1);
    assert!(b.is_err());
    assert_str_eq!(b.unwrap_err(), "nf");
    return 0;
}
