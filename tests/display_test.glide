import stdlib::testing::*;

struct Point { x: i32, y: i32 }
impl Display for Point {
    fn to_string(self: *Point) -> string { return format!("({}, {})", self.x, self.y); }
}

struct Rec { name: string, n: i32, ok: bool, p: Point }

fn test_display_impl() -> i32 {
    let p: Point = Point { x: 3, y: 4 };
    assert!(format!("{}", p).eq("(3, 4)"));
    return 0;
}

fn test_auto_render_with_quotes_and_nesting() -> i32 {
    let r: Rec = Rec { name: "hi", n: 5, ok: true, p: Point { x: 1, y: 2 } };
    assert!(format!("{}", r).eq("Rec { name: \"hi\", n: 5, ok: true, p: (1, 2) }"));
    return 0;
}
