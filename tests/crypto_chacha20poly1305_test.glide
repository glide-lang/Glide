// ChaCha20-Poly1305 AEAD against the RFC 8439 §2.8.2 test vector, plus
// round-trip and tamper-detection checks.
import stdlib::testing::*;
import stdlib::crypto::chacha20poly1305::*;
import stdlib::hex::*;

fn _h(s: string) -> string {
    let r: !string = hex_decode(s);
    if !r.is_ok() { return ""; }
    return r.unwrap();
}

// RFC 8439 §2.8.2 known-answer.
fn test_rfc8439_vector() -> i32 {
    let key: string   = _h("808182838485868788898a8b8c8d8e8f909192939495969798999a9b9c9d9e9f");
    let nonce: string = _h("070000004041424344454647");
    let aad: string   = _h("50515253c0c1c2c3c4c5c6c7");
    let pt: string    = "Ladies and Gentlemen of the class of '99: If I could offer you only one tip for the future, sunscreen would be it.";

    let sealed: !string = aead_encrypt(key, nonce, pt, aad);
    assert!(sealed.is_ok());
    assert_str_eq!(hex_encode(sealed.unwrap()),
        "d31a8d34648e60db7b86afbc53ef7ec2a4aded51296e08fea9e2b5a736ee62d63dbea45e8ca9671282fafb69da92728b1a71de0a9e060b2905d6a5b67ecd3b3692ddbd7f2d778b8c9803aee328091b58fab324e4fad675945585808b4831d7bc3ff4def08e4b7a9de576d26586cec64b61161ae10b594f09e26a7e902ecbd0600691");
    return 0;
}

fn test_roundtrip() -> i32 {
    let key: string   = _h("000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f");
    let nonce: string = _h("000000000000000000000000");
    let aad: string   = "some-associated-data";
    let pt: string    = "the quick brown fox\x00with an embedded nul";   // binary body

    let sealed: !string = aead_encrypt(key, nonce, pt, aad);
    assert!(sealed.is_ok());
    let opened: !string = aead_decrypt(key, nonce, sealed.unwrap(), aad);
    assert!(opened.is_ok());
    assert_eq!(opened.unwrap().len(), pt.len());
    assert!(opened.unwrap().eq(pt));
    return 0;
}

// A single flipped ciphertext byte must fail authentication.
fn test_tamper_detection() -> i32 {
    let key: string   = _h("000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f");
    let nonce: string = _h("000000000000000000000000");
    let sealed: string = aead_encrypt(key, nonce, "attack at dawn", "").unwrap();
    // flip the first ciphertext byte
    let mut bad: string = "";
    for let i: i32 = 0; i < sealed.len(); i++ {
        let b: i32 = sealed.at(i).to_int();
        if i == 0 { bad = bad.concat(((b ^ 1) as char).to_string()); }
        else { bad = bad.concat((b as char).to_string()); }
    }
    let opened: !string = aead_decrypt(key, nonce, bad, "");
    assert!(opened.is_err());
    return 0;
}

// Wrong AAD must fail authentication too.
fn test_wrong_aad_fails() -> i32 {
    let key: string   = _h("000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f");
    let nonce: string = _h("000000000000000000000000");
    let sealed: string = aead_encrypt(key, nonce, "payload", "aad-A").unwrap();
    let opened: !string = aead_decrypt(key, nonce, sealed, "aad-B");
    assert!(opened.is_err());
    return 0;
}

fn test_bad_key_size_errs() -> i32 {
    let r: !string = aead_encrypt("short", "000000000000", "x", "");
    assert!(r.is_err());
    return 0;
}
