// Borrows are second-class and now COMPILE for primitives, fields and
// re-borrows: `&mut i32` write-through was a double-deref ICE before. Each
// case asserts real values so the emitted C is proven correct end-to-end.
struct Box2 { v: i32, w: i32 }

fn bump(a: &mut i32) {
    *a = *a + 1;
}

fn add5(a: &mut i32) {
    *a += 5;
}

fn peek(a: &i32) -> i32 {
    return *a;
}

fn set7(p: &mut i32) {
    *p = 7;
}

fn slen(s: &string) -> i32 {
    return s.len();
}

fn fill(b: &mut Box2) {
    b.v = 10;
    b.w = 20;
}

fn test_mut_borrow_prim_write() -> i32 {
    let mut n: i32 = 41;
    bump(&mut n);
    assert!(n == 42);
    return 0;
}

fn test_mut_borrow_prim_compound() -> i32 {
    let mut n: i32 = 10;
    add5(&mut n);
    add5(&mut n);
    assert!(n == 20);
    return 0;
}

fn test_shared_borrow_prim_read() -> i32 {
    let n: i32 = 33;
    assert!(peek(&n) == 33);
    assert!(n == 33);
    return 0;
}

fn test_mut_borrow_struct_field() -> i32 {
    let mut b: Box2 = Box2 { v: 0, w: 0 };
    set7(&mut b.v);
    assert!(b.v == 7);
    assert!(b.w == 0);
    return 0;
}

fn test_borrow_string_param() -> i32 {
    let s: string = "hello";
    assert!(slen(&s) == 5);
    return 0;
}

fn test_mut_borrow_struct_param() -> i32 {
    let mut b: Box2 = Box2 { v: 1, w: 2 };
    fill(&mut b);
    assert!(b.v == 10);
    assert!(b.w == 20);
    return 0;
}

// ---- Phase 3: exclusivity discipline (NLL-shaped) -------------------------
// A borrow dies at its last use, so these are all LEGAL; the illegal
// counterparts (use-while-mut-borrowed, assign-while-borrowed,
// free-while-borrowed, use-after-move on a copied &mut) are compile errors
// covered by the lsp_smoke diagnostics suite.

fn test_nll_mutation_after_borrow_dies() -> i32 {
    let mut x: i32 = 1;
    let r = &mut x;
    *r = 5;
    x = 99;
    assert!(x == 99);
    return 0;
}

fn test_nll_shared_then_write() -> i32 {
    let mut x: i32 = 1;
    let r = &x;
    let y = *r;
    x = 42;
    assert!(y == 1);
    assert!(x == 42);
    return 0;
}

fn test_shared_borrow_copy() -> i32 {
    let x: i32 = 7;
    let a = &x;
    let b = a;
    assert!(*a == 7);
    assert!(*b == 7);
    return 0;
}

fn test_mut_borrow_copy_moves() -> i32 {
    let mut n: i32 = 1;
    let a = &mut n;
    let b = a;
    *b = 9;
    assert!(n == 9);
    return 0;
}

fn test_free_after_borrow_dies() -> i32 {
    let p: *i32 = malloc(4) as *i32;
    p[0] = 3;
    let r = &*p;
    let n = *r;
    free(p as *void);
    assert!(n == 3);
    return 0;
}
