import stdlib::testing::*;

// Defer bodies run at scope exit AFTER scope-end auto-drops drain (that order
// is deliberate: `defer arena.free()` at fn-top must outlive the drops of
// objects allocated inside it). So a local MENTIONED inside a defer body must
// never get a scope-end auto-drop: even a read-only `defer println!(s.len())`
// would read freed memory, and a deferred `v.free()` would double-free. The
// emitter vetoes the drop for any local a defer mentions — the value leaks (or
// the defer's own free is the cleanup); it must never UAF. If the veto
// regressed, ASAN (or glibc) would abort right here.

// Read-only defer use of an ephemeral string: drop must be suppressed, the
// deferred read must see the live buffer.
fn defer_reads_string() -> i32 {
    let s*: string = "tail".concat("!");
    defer println!("deferred len:", s.len());
    return s.len();
}

fn test_defer_read_string_survives() -> i32 {
    assert_eq!(defer_reads_string(), 5);
    return 0;
}

// Same for the inferred (no `*`) string drop.
fn defer_reads_inferred() -> i32 {
    let s: string = format!("item-{}", 42);
    defer println!("deferred len:", s.len());
    return s.len();
}

fn test_defer_read_inferred_string_survives() -> i32 {
    assert_eq!(defer_reads_inferred(), 7);
    return 0;
}

// A deferred receiver-safe use of an inferred auto-drop vector: the veto must
// keep the vector alive until the defer has run.
fn defer_reads_vector() -> i64 {
    let v: *Vector<i32> = Vector::new();
    v.push(10); v.push(20);
    defer println!("deferred vec len:", v.len());
    return (v.get(0) + v.get(1)) as i64;
}

fn test_defer_read_vector_survives() -> i32 {
    assert!(defer_reads_vector() == 30);
    return 0;
}

// A deferred `v.free()` on an explicitly-owned local must be the ONLY free
// (the scope-end auto-drop is suppressed, not doubled).
fn defer_frees_owned() -> i64 {
    let v*: *Vector<i32> = Vector::new();
    defer v.free();
    v.push(5); v.push(7);
    return (v.get(0) + v.get(1)) as i64;
}

fn test_defer_manual_free_single() -> i32 {
    assert!(defer_frees_owned() == 12);
    return 0;
}
