// Self-test for the testing framework. These tests validate that the
// assertion macros pass when expected and that values are formatted
// correctly in the failure message. Failure paths are exercised in a
// separate "negative" file (testing_fails_test.glide) so this one can
// stay all-green and serve as a smoke test.

import stdlib::testing::*;

fn test_assert_true_passes() -> int {
    assert!(true);
    assert!(1 + 1 == 2);
    assert!(!false);
    return 0;
}

fn test_assert_eq_int() -> int {
    assert_eq!(40 + 2, 42);
    assert_eq!(0, 0);
    assert_eq!(-1, -1);
    return 0;
}

fn test_assert_eq_bool() -> int {
    assert_eq!(true, true);
    assert_eq!(false, false);
    return 0;
}

fn test_assert_str_eq() -> int {
    assert_str_eq!("hello".concat(" ").concat("world"), "hello world");
    assert_str_eq!("", "");
    return 0;
}

fn test_assert_msg_uses_msg() -> int {
    let n: int = 5;
    assert_msg!(n > 0, "n was ${n}");
    return 0;
}

fn test_assert_not() -> int {
    assert_not!(false);
    assert_not!(1 == 2);
    return 0;
}
