// Builtin `vec_of!(a, b, c)` macro. Lowers to a block-expression that builds a
// `*Vector<T>` (T = element type) and yields it, so it works anywhere an
// expression does: let-init, call argument, return value, and nested.
import stdlib::testing::*;

fn test_vec_of_basic() -> i32 {
    let v: *Vector<i32> = vec_of!(10, 20, 30);
    assert_eq!(v.len(), 3);
    assert_eq!(v.get(0), 10);
    assert_eq!(v.get(2), 30);
    v.free();
    return 0;
}

fn test_vec_of_unannotated() -> i32 {
    let v = vec_of!(1, 2, 3, 4);
    assert_eq!(v.len(), 4);
    assert_eq!(v.get(3), 4);
    v.free();
    return 0;
}

fn test_vec_of_single() -> i32 {
    let v = vec_of!(42);
    assert_eq!(v.len(), 1);
    assert_eq!(v.get(0), 42);
    v.free();
    return 0;
}

fn test_vec_of_strings() -> i32 {
    let v = vec_of!("alice", "bob");
    assert_eq!(v.len(), 2);
    assert_str_eq!(v.get(0), "alice");
    assert_str_eq!(v.get(1), "bob");
    v.free();
    return 0;
}

fn _sum(v: *Vector<i32>) -> i32 {
    let mut s: i32 = 0;
    for let i: i32 = 0; i < v.len(); i++ { s = s + v.get(i); }
    return s;
}

fn test_vec_of_as_argument() -> i32 {
    assert_eq!(_sum(vec_of!(1, 2, 3, 4, 5)), 15);
    return 0;
}

fn _make() -> *Vector<i32> {
    return vec_of!(7, 8, 9);
}

fn test_vec_of_as_return() -> i32 {
    let v = _make();
    assert_eq!(v.len(), 3);
    assert_eq!(v.get(0), 7);
    v.free();
    return 0;
}

fn test_vec_of_nested() -> i32 {
    let outer: *Vector<*Vector<i32>> = vec_of!(vec_of!(1, 2), vec_of!(3, 4));
    assert_eq!(outer.len(), 2);
    let inner1 = outer.get(1);
    assert_eq!(inner1.get(0), 3);
    assert_eq!(inner1.get(1), 4);
    outer.free();
    return 0;
}
