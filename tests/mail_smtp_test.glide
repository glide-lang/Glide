import stdlib::testing::*;
import stdlib::net::listener::*;
import stdlib::net::tcp::*;
import stdlib::mail::message::*;
import stdlib::mail::smtp::*;
extern fn __glide_string_from_buf(buf: *void, n: i32) -> string;

fn _send(c: *TcpStream, s: string) { let _r: !i32 = c.write_all(s); }
fn _recv(c: *TcpStream, buf: *u8, max: i32) -> i32 {
    let r: !i32 = c.read_bytes(buf, max);
    if !r.ok { return -1; }
    return r.val;
}

// Fake SMTP server: drives the conversation and returns success codes
// for the standard sequence. Validates the client side runs through
// the state machine without protocol errors. Per-line recording is
// skipped because Glide doesn't have top-level mutable globals — the
// integration smoke (in /tmp during development) does the byte-level
// inspection.

fn _fake_smtp(port: i32) {
    let l: *TcpListener = TcpListener::bind(port).val;
    let c: *TcpStream = l.accept().val;
    _send(c, "220 fake.example.com SMTP service ready\r\n");
    let buf: *u8 = malloc(8192) as *u8;
    let mut data_mode: bool = false;
    let mut data_acc: string = "";
    while true {
        let n: i32 = _recv(c, buf, 8192);
        if n <= 0 { break; }
        let s: string = __glide_string_from_buf(buf as *void, n);

        if data_mode {
            data_acc = data_acc.concat(s);
            if data_acc.contains("\r\n.\r\n") {
                _send(c, "250 OK queued\r\n");
                data_mode = false;
                data_acc = "";
            }
            continue;
        }
        let upper: string = s.to_upper().trim();
        if upper.starts_with("EHLO") {
            _send(c, "250-fake greets you\r\n250 SIZE 10485760\r\n");
        } else if upper.starts_with("MAIL FROM") {
            _send(c, "250 OK\r\n");
        } else if upper.starts_with("RCPT TO") {
            _send(c, "250 OK\r\n");
        } else if upper.starts_with("DATA") {
            _send(c, "354 send the data\r\n");
            data_mode = true;
        } else if upper.starts_with("QUIT") {
            _send(c, "221 bye\r\n");
            break;
        } else {
            _send(c, "500 unknown\r\n");
        }
    }
    c.close(); l.close();
}

fn test_send_completes_full_state_machine() -> i32 {
    spawn_thread _fake_smtp(43525);
    sleep_ms(300);
    let c: *SmtpClient = SmtpClient::new("127.0.0.1", 43525);
    let m: *Mail = Mail::new();
    m.from = "alice@x"; m.to.push("bob@x"); m.subject = "t"; m.body = "hi";
    let r: !i32 = c.send(m);
    assert!(r.ok);
    return 0;
}

fn test_multiple_recipients_all_succeed() -> i32 {
    spawn_thread _fake_smtp(43526);
    sleep_ms(300);
    let c: *SmtpClient = SmtpClient::new("127.0.0.1", 43526);
    let m: *Mail = Mail::new();
    m.from = "a@x"; m.to.push("to1@x"); m.to.push("to2@x");
    m.cc.push("cc1@x"); m.bcc.push("bcc1@x");
    m.subject = "s"; m.body = "b";
    let r: !i32 = c.send(m);
    assert!(r.ok);
    return 0;
}

fn _rejecting_server(port: i32) {
    let l: *TcpListener = TcpListener::bind(port).val;
    let c: *TcpStream = l.accept().val;
    _send(c, "220 fake ready\r\n");
    let buf: *u8 = malloc(4096) as *u8;
    while true {
        let n: i32 = _recv(c, buf, 4096);
        if n <= 0 { break; }
        let s: string = __glide_string_from_buf(buf as *void, n);
        let upper: string = s.to_upper().trim();
        if upper.starts_with("EHLO") {
            _send(c, "250 ok\r\n");
        } else if upper.starts_with("MAIL FROM") {
            _send(c, "550 sender refused\r\n");
        } else if upper.starts_with("QUIT") {
            _send(c, "221 bye\r\n"); break;
        } else {
            _send(c, "500 unknown\r\n");
        }
    }
    c.close(); l.close();
}

// ---- AUTH LOGIN flow ----

fn _login_only_server(port: i32) {
    let l: *TcpListener = TcpListener::bind(port).val;
    let c: *TcpStream = l.accept().val;
    _send(c, "220 fake ready\r\n");
    let buf: *u8 = malloc(8192) as *u8;
    let mut step: i32 = 0;
    let mut data_mode: bool = false;
    let mut data_acc: string = "";
    while true {
        let n: i32 = _recv(c, buf, 8192);
        if n <= 0 { break; }
        let s: string = __glide_string_from_buf(buf as *void, n);
        if data_mode {
            data_acc = data_acc.concat(s);
            if data_acc.contains("\r\n.\r\n") {
                _send(c, "250 OK queued\r\n");
                data_mode = false; data_acc = "";
            }
            continue;
        }
        if step == 1 { _send(c, "334 UGFzc3dvcmQ6\r\n"); step = 2; continue; }
        if step == 2 { _send(c, "235 auth ok\r\n"); step = 0; continue; }
        let upper: string = s.to_upper().trim();
        if upper.starts_with("EHLO") {
            _send(c, "250-fake\r\n250 AUTH LOGIN\r\n");
        } else if upper.starts_with("AUTH LOGIN") {
            _send(c, "334 VXNlcm5hbWU6\r\n"); step = 1;
        } else if upper.starts_with("MAIL FROM") { _send(c, "250 OK\r\n"); }
        else if upper.starts_with("RCPT TO")    { _send(c, "250 OK\r\n"); }
        else if upper.starts_with("DATA")        { _send(c, "354 ok\r\n"); data_mode = true; }
        else if upper.starts_with("QUIT")        { _send(c, "221 bye\r\n"); break; }
        else                                      { _send(c, "500\r\n"); }
    }
    c.close(); l.close();
}

fn test_auth_login_auto_detected_from_ehlo() -> i32 {
    spawn_thread _login_only_server(43528);
    sleep_ms(300);
    let c: *SmtpClient = SmtpClient::new("127.0.0.1", 43528);
    let u: ?string = some("alice");
    let p: ?string = some("pwd");
    c.username = u; c.password = p;
    let m: *Mail = Mail::new();
    m.from = "a@x"; m.to.push("b@x"); m.subject = "s"; m.body = "y";
    let r: !i32 = c.send(m);
    assert!(r.ok);
    return 0;
}

fn test_auth_login_explicit_method() -> i32 {
    spawn_thread _login_only_server(43529);
    sleep_ms(300);
    let c: *SmtpClient = SmtpClient::new("127.0.0.1", 43529);
    c.auth_method = "login";
    let u: ?string = some("alice");
    let p: ?string = some("pwd");
    c.username = u; c.password = p;
    let m: *Mail = Mail::new();
    m.from = "a@x"; m.to.push("b@x"); m.subject = "s"; m.body = "y";
    let r: !i32 = c.send(m);
    assert!(r.ok);
    return 0;
}

fn test_client_surfaces_server_550_error() -> i32 {
    spawn_thread _rejecting_server(43527);
    sleep_ms(300);
    let c: *SmtpClient = SmtpClient::new("127.0.0.1", 43527);
    let m: *Mail = Mail::new();
    m.from = "x@x"; m.to.push("y@x"); m.subject = "s"; m.body = "b";
    let r: !i32 = c.send(m);
    assert_not!(r.ok);
    assert!(r.err.contains("550"));
    return 0;
}
