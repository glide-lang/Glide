import stdlib::testing::*;
import stdlib::net::listener::*;
import stdlib::net::tcp::*;
import stdlib::mail::imap::*;

fn _send(c: *TcpStream, s: string) { let _r: !i32 = c.write_all(s); }
fn _recv(c: *TcpStream, buf: *u8, max: i32) -> i32 {
    let r: !i32 = c.read_bytes(buf, max);
    if !r.ok { return -1; }
    return r.val;
}

fn _fake_imap(port: i32) {
    let l: *TcpListener = TcpListener::bind(port).val;
    let c: *TcpStream = l.accept().val;
    _send(c, "* OK fake IMAP ready\r\n");
    let buf: *u8 = malloc(4096) as *u8;
    while true {
        let n: i32 = _recv(c, buf, 4096);
        if n <= 0 { break; }
        let s: string = malloc(n + 1) as string;
        for let i: i32 = 0; i < n; i++ { (s as *u8)[i] = (buf as *u8)[i]; }
        (s as *u8)[n] = 0 as u8;
        let sp: i32 = s.index_of(" ");
        if sp < 0 { continue; }
        let tag: string = s.substring(0, sp);
        let upper: string = s.to_upper();
        if upper.contains("LOGIN") {
            _send(c, tag.concat(" OK login complete\r\n"));
        } else if upper.contains("SELECT") {
            _send(c, "* 3 EXISTS\r\n* 0 RECENT\r\n");
            _send(c, tag.concat(" OK SELECT complete\r\n"));
        } else if upper.contains("FETCH") {
            let body: string = "From: a@x\r\nSubject: hi\r\n\r\nbody";
            _send(c, "* 1 FETCH (BODY[] {28}\r\n");
            _send(c, body);
            _send(c, "\r\n");
            _send(c, tag.concat(" OK FETCH complete\r\n"));
        } else if upper.contains("STORE") {
            _send(c, "* 1 FETCH (FLAGS (\\Seen))\r\n");
            _send(c, tag.concat(" OK STORE complete\r\n"));
        } else if upper.contains("LOGOUT") {
            _send(c, "* BYE\r\n");
            _send(c, tag.concat(" OK LOGOUT complete\r\n"));
            break;
        }
    }
    c.close(); l.close();
}

fn test_login_select_returns_count() -> i32 {
    spawn_thread _fake_imap(42243);
    sleep_ms(300);
    let s: !*ImapSession = ImapSession::connect("127.0.0.1", 42243, false);
    assert!(s.ok);
    let p: *ImapSession = s.val;
    p.login("alice", "pwd");
    let count: !i32 = p.select("INBOX");
    assert!(count.ok);
    assert_eq!(count.val, 3);
    p.logout();
    p.close();
    return 0;
}

fn test_fetch_captures_literal() -> i32 {
    spawn_thread _fake_imap(42244);
    sleep_ms(300);
    let s: !*ImapSession = ImapSession::connect("127.0.0.1", 42244, false);
    assert!(s.ok);
    let p: *ImapSession = s.val;
    p.login("a", "p");
    p.select("INBOX");
    let body: !string = p.fetch(1);
    assert!(body.ok);
    assert_eq!(body.val.len(), 28);
    assert!(body.val.starts_with("From: a@x"));
    p.logout();
    p.close();
    return 0;
}

// ---- SEARCH ----

fn _search_server(port: i32, search_reply: string) {
    let l: *TcpListener = TcpListener::bind(port).val;
    let c: *TcpStream = l.accept().val;
    _send(c, "* OK ready\r\n");
    let buf: *u8 = malloc(4096) as *u8;
    while true {
        let n: i32 = _recv(c, buf, 4096);
        if n <= 0 { break; }
        let s: string = malloc(n + 1) as string;
        for let i: i32 = 0; i < n; i++ { (s as *u8)[i] = (buf as *u8)[i]; }
        (s as *u8)[n] = 0 as u8;
        let sp: i32 = s.index_of(" ");
        if sp < 0 { continue; }
        let tag: string = s.substring(0, sp);
        let upper: string = s.to_upper();
        if upper.contains("LOGIN") { _send(c, tag.concat(" OK\r\n")); }
        else if upper.contains("SELECT") {
            _send(c, "* 5 EXISTS\r\n");
            _send(c, tag.concat(" OK\r\n"));
        }
        else if upper.contains("SEARCH") {
            _send(c, search_reply);
            _send(c, tag.concat(" OK\r\n"));
        }
        else if upper.contains("LOGOUT") {
            _send(c, "* BYE\r\n");
            _send(c, tag.concat(" OK\r\n"));
            break;
        }
    }
    c.close(); l.close();
}

fn test_search_returns_seq_numbers() -> i32 {
    spawn_thread _search_server(42250, "* SEARCH 2 4 6\r\n");
    sleep_ms(300);
    let s: !*ImapSession = ImapSession::connect("127.0.0.1", 42250, false);
    assert!(s.ok);
    let p: *ImapSession = s.val;
    p.login("a", "p"); p.select("INBOX");
    let r: !*Vector<i32> = p.search("UNSEEN");
    assert!(r.ok);
    assert_eq!(r.val.len(), 3);
    assert_eq!(r.val.get(0), 2);
    assert_eq!(r.val.get(1), 4);
    assert_eq!(r.val.get(2), 6);
    p.logout(); p.close();
    return 0;
}

fn test_search_empty_result() -> i32 {
    spawn_thread _search_server(42251, "* SEARCH\r\n");
    sleep_ms(300);
    let s: !*ImapSession = ImapSession::connect("127.0.0.1", 42251, false);
    assert!(s.ok);
    let p: *ImapSession = s.val;
    p.login("a", "p"); p.select("INBOX");
    let r: !*Vector<i32> = p.search("UNSEEN");
    assert!(r.ok);
    assert_eq!(r.val.len(), 0);
    p.logout(); p.close();
    return 0;
}

fn test_search_from_helper_quotes_addr() -> i32 {
    spawn_thread _search_server(42252, "* SEARCH 1\r\n");
    sleep_ms(300);
    let s: !*ImapSession = ImapSession::connect("127.0.0.1", 42252, false);
    assert!(s.ok);
    let p: *ImapSession = s.val;
    p.login("a", "p"); p.select("INBOX");
    let r: !*Vector<i32> = p.search_from("alice@example.com");
    assert!(r.ok);
    assert_eq!(r.val.len(), 1);
    p.logout(); p.close();
    return 0;
}

// ---- APPEND ----

fn _append_server(port: i32) {
    let l: *TcpListener = TcpListener::bind(port).val;
    let c: *TcpStream = l.accept().val;
    _send(c, "* OK ready\r\n");
    let buf: *u8 = malloc(8192) as *u8;
    let mut append_size: i32 = 0;
    let mut append_tag: string = "";
    let mut append_acc: string = "";
    while true {
        let n: i32 = _recv(c, buf, 8192);
        if n <= 0 { break; }
        let s: string = malloc(n + 1) as string;
        for let i: i32 = 0; i < n; i++ { (s as *u8)[i] = (buf as *u8)[i]; }
        (s as *u8)[n] = 0 as u8;

        if append_size > 0 {
            append_acc = append_acc.concat(s);
            if append_acc.len() >= append_size + 2 {
                _send(c, append_tag.concat(" OK APPEND completed\r\n"));
                append_size = 0; append_acc = "";
            }
            continue;
        }
        let sp: i32 = s.index_of(" ");
        if sp < 0 { continue; }
        let tag: string = s.substring(0, sp);
        let upper: string = s.to_upper();
        if upper.contains("LOGIN") { _send(c, tag.concat(" OK\r\n")); }
        else if upper.contains("APPEND") {
            let open: i32 = s.index_of("{");
            let close: i32 = s.index_of("}");
            if open >= 0 && close > open {
                let nstr: string = s.substring(open + 1, close);
                let nr: !i32 = nstr.try_parse_int();
                if nr.ok { append_size = nr.val; append_tag = tag; }
            }
            _send(c, "+ ready\r\n");
        } else if upper.contains("LOGOUT") {
            _send(c, "* BYE\r\n");
            _send(c, tag.concat(" OK\r\n"));
            break;
        }
    }
    c.close(); l.close();
}

fn test_append_succeeds() -> i32 {
    spawn_thread _append_server(42253);
    sleep_ms(300);
    let s: !*ImapSession = ImapSession::connect("127.0.0.1", 42253, false);
    assert!(s.ok);
    let p: *ImapSession = s.val;
    p.login("a", "p");
    let msg: string = "From: a@x\r\nSubject: drafted\r\n\r\nbody";
    let r: !i32 = p.append("Drafts", "\\Seen", msg);
    assert!(r.ok);
    p.logout(); p.close();
    return 0;
}

fn test_append_without_flags() -> i32 {
    spawn_thread _append_server(42254);
    sleep_ms(300);
    let s: !*ImapSession = ImapSession::connect("127.0.0.1", 42254, false);
    assert!(s.ok);
    let p: *ImapSession = s.val;
    p.login("a", "p");
    let r: !i32 = p.append("INBOX", "", "From: x\r\n\r\nbody");
    assert!(r.ok);
    p.logout(); p.close();
    return 0;
}

// ---- IDLE ----

fn _idle_server(port: i32) {
    let l: *TcpListener = TcpListener::bind(port).val;
    let c: *TcpStream = l.accept().val;
    _send(c, "* OK ready\r\n");
    let buf: *u8 = malloc(4096) as *u8;
    let mut idle_tag: string = "";
    while true {
        let n: i32 = _recv(c, buf, 4096);
        if n <= 0 { break; }
        let s: string = malloc(n + 1) as string;
        for let i: i32 = 0; i < n; i++ { (s as *u8)[i] = (buf as *u8)[i]; }
        (s as *u8)[n] = 0 as u8;
        if !idle_tag.eq("") {
            if s.to_upper().starts_with("DONE") {
                _send(c, idle_tag.concat(" OK IDLE done\r\n"));
                idle_tag = "";
            }
            continue;
        }
        let sp: i32 = s.index_of(" ");
        if sp < 0 { continue; }
        let tag: string = s.substring(0, sp);
        let upper: string = s.to_upper();
        if upper.contains("LOGIN")  { _send(c, tag.concat(" OK\r\n")); }
        else if upper.contains("SELECT") {
            _send(c, "* 5 EXISTS\r\n");
            _send(c, tag.concat(" OK\r\n"));
        }
        else if upper.contains("IDLE") {
            _send(c, "+ idling\r\n");
            idle_tag = tag;
            sleep_ms(50);
            _send(c, "* 6 EXISTS\r\n");
            sleep_ms(20);
            _send(c, "* 7 EXISTS\r\n");
        }
        else if upper.contains("LOGOUT") {
            _send(c, "* BYE\r\n");
            _send(c, tag.concat(" OK\r\n"));
            break;
        }
    }
    c.close(); l.close();
}

fn test_idle_pushes_updates_and_stops() -> i32 {
    spawn_thread _idle_server(42255);
    sleep_ms(300);
    let s: !*ImapSession = ImapSession::connect("127.0.0.1", 42255, false);
    assert!(s.ok);
    let p: *ImapSession = s.val;
    p.login("a", "p"); p.select("INBOX");

    let st: !i32 = p.idle_start();
    assert!(st.ok);

    let l1: !string = p.idle_next();
    assert!(l1.ok);
    assert!(l1.val.contains("EXISTS"));
    let l2: !string = p.idle_next();
    assert!(l2.ok);
    assert!(l2.val.contains("EXISTS"));

    let stop: !i32 = p.idle_stop();
    assert!(stop.ok);

    p.logout(); p.close();
    return 0;
}

fn test_idle_stop_without_start_errors() -> i32 {
    // Use the same fake server but skip idle_start.
    spawn_thread _idle_server(42256);
    sleep_ms(300);
    let s: !*ImapSession = ImapSession::connect("127.0.0.1", 42256, false);
    assert!(s.ok);
    let p: *ImapSession = s.val;
    p.login("a", "p");
    let stop: !i32 = p.idle_stop();
    assert_not!(stop.ok);
    p.logout(); p.close();
    return 0;
}

fn test_store_flag_succeeds() -> i32 {
    spawn_thread _fake_imap(42245);
    sleep_ms(300);
    let s: !*ImapSession = ImapSession::connect("127.0.0.1", 42245, false);
    assert!(s.ok);
    let p: *ImapSession = s.val;
    p.login("a", "p");
    p.select("INBOX");
    let r: !i32 = p.store_flag(1, "\\Seen", true);
    assert!(r.ok);
    p.logout();
    p.close();
    return 0;
}
