// X.509 chain verification against a real OpenSSL-generated P-256 chain:
// a "Glide Root CA" and a leaf (CN=api.glide.dev) signed by it.
import stdlib::testing::*;
import stdlib::crypto::x509::*;
import stdlib::hex::*;

fn _ca() -> *Cert { return cert_parse(hex_decode("").unwrap()).unwrap(); }
fn _leaf() -> *Cert { return cert_parse(hex_decode("").unwrap()).unwrap(); }
fn _roots() -> *Vector<*Cert> { let v: *Vector<*Cert> = Vector::new(); v.push(_ca()); return v; }
fn _empty() -> *Vector<*Cert> { return Vector::new(); }

fn test_valid_chain() -> i32 {
    let leaf: *Cert = _leaf();
    let now: i64 = leaf.not_before + 1000;
    let v: !bool = verify_chain(leaf, _empty(), _roots(), "api.glide.dev", now);
    assert!(v.is_ok());
    assert!(v.unwrap());
    return 0;
}

fn test_rejects_wrong_hostname() -> i32 {
    let leaf: *Cert = _leaf();
    assert!(verify_chain(leaf, _empty(), _roots(), "evil.com", leaf.not_before + 1000).is_err());
    return 0;
}

fn test_rejects_untrusted_root() -> i32 {
    let leaf: *Cert = _leaf();
    // no trust anchors supplied -> chain cannot be built
    assert!(verify_chain(leaf, _empty(), _empty(), "api.glide.dev", leaf.not_before + 1000).is_err());
    return 0;
}

fn test_rejects_expired() -> i32 {
    let leaf: *Cert = _leaf();
    assert!(verify_chain(leaf, _empty(), _roots(), "api.glide.dev", leaf.not_after + 100).is_err());
    assert!(verify_chain(leaf, _empty(), _roots(), "api.glide.dev", leaf.not_before - 100).is_err());
    return 0;
}

fn test_ca_flag_and_leaf_cn() -> i32 {
    assert!(_ca().is_ca);
    assert!(!_leaf().is_ca);
    assert_str_eq!(_leaf().subject_cn, "api.glide.dev");
    return 0;
}
