// Deep coverage of Option (`?T`) and Result (`!T`) intrinsic methods:
// constructors, predicates, unwrap family, and the combinators
// map / map_err / and_then / filter / ok_or / ok. Combinator results are
// asserted through `format!` (the Display shape) and by unwrapping.
import stdlib::testing::*;

// ---- constructors + predicates -------------------------------------

fn test_option_predicates() -> i32 {
    let s: ?i32 = some(1);
    let n: ?i32 = none();
    assert!(s.is_some());
    assert!(!s.is_none());
    assert!(n.is_none());
    assert!(!n.is_some());
    return 0;
}

fn test_result_predicates() -> i32 {
    let o: !i32 = ok(1);
    let e: !i32 = err("x");
    assert!(o.is_ok());
    assert!(!o.is_err());
    assert!(e.is_err());
    assert!(!e.is_ok());
    return 0;
}

// ---- unwrap family: Option -----------------------------------------

fn test_option_unwrap() -> i32 {
    let s: ?i32 = some(42);
    assert_eq!(s.unwrap(), 42);
    return 0;
}

fn test_option_unwrap_or() -> i32 {
    let s: ?i32 = some(5);
    let n: ?i32 = none();
    assert_eq!(s.unwrap_or(0), 5);
    assert_eq!(n.unwrap_or(0), 0);
    return 0;
}

fn test_option_unwrap_or_else() -> i32 {
    let n: ?i32 = none();
    assert_eq!(n.unwrap_or_else(fn() -> i32 { return 7 * 3; }), 21);
    let s: ?i32 = some(9);
    assert_eq!(s.unwrap_or_else(fn() -> i32 { return 0; }), 9);
    return 0;
}

fn test_option_expect_success() -> i32 {
    let s: ?i32 = some(11);
    assert_eq!(s.expect("should be present"), 11);
    return 0;
}

// ---- unwrap family: Result -----------------------------------------

fn test_result_unwrap() -> i32 {
    let o: !i32 = ok(99);
    assert_eq!(o.unwrap(), 99);
    return 0;
}

fn test_result_unwrap_or() -> i32 {
    let o: !i32 = ok(3);
    let e: !i32 = err("bad");
    assert_eq!(o.unwrap_or(0), 3);
    assert_eq!(e.unwrap_or(-1), -1);
    return 0;
}

fn test_result_unwrap_or_else() -> i32 {
    let e: !i32 = err("bad");
    assert_eq!(e.unwrap_or_else(fn() -> i32 { return 100; }), 100);
    return 0;
}

fn test_result_unwrap_err() -> i32 {
    let e: !i32 = err("kaboom");
    assert_str_eq!(e.unwrap_err(), "kaboom");
    return 0;
}

fn test_result_expect_success() -> i32 {
    let o: !i32 = ok(8);
    assert_eq!(o.expect("must be ok"), 8);
    return 0;
}

// ---- map (Option) --------------------------------------------------

fn test_option_map_some() -> i32 {
    let s: ?i32 = some(5);
    let m = s.map(fn(x: i32) -> i32 { return x * 2; });
    assert!(m.is_some());
    assert_eq!(m.unwrap(), 10);
    return 0;
}

fn test_option_map_none() -> i32 {
    let n: ?i32 = none();
    let m = n.map(fn(x: i32) -> i32 { return x + 1; });
    assert!(m.is_none());
    return 0;
}

fn test_option_map_changes_type() -> i32 {
    let s: ?i32 = some(7);
    let m = s.map(fn(x: i32) -> string { return x.to_string(); });
    assert!(m.is_some());
    assert_str_eq!(m.unwrap(), "7");
    return 0;
}

// ---- map / map_err (Result) ----------------------------------------

fn test_result_map_ok() -> i32 {
    let o: !i32 = ok(6);
    let m = o.map(fn(x: i32) -> i32 { return x + 4; });
    assert!(m.is_ok());
    assert_eq!(m.unwrap(), 10);
    return 0;
}

fn test_result_map_err_passthrough() -> i32 {
    let e: !i32 = err("orig");
    let m = e.map(fn(x: i32) -> i32 { return x + 1; });
    assert!(m.is_err());
    assert_str_eq!(m.unwrap_err(), "orig");   // map leaves err untouched
    return 0;
}

fn test_result_map_err() -> i32 {
    let e: !i32 = err("bad");
    let m = e.map_err(fn(s: string) -> string { return "wrap:".concat(s); });
    assert!(m.is_err());
    assert_str_eq!(m.unwrap_err(), "wrap:bad");
    let o: !i32 = ok(5);
    let m2 = o.map_err(fn(s: string) -> string { return "never"; });
    assert!(m2.is_ok());
    assert_eq!(m2.unwrap(), 5);
    return 0;
}

// ---- and_then ------------------------------------------------------

fn test_option_and_then() -> i32 {
    let s: ?i32 = some(4);
    let m = s.and_then(fn(x: i32) -> ?i32 { if x > 0 { return some(x * 10); } return none(); });
    assert!(m.is_some());
    assert_eq!(m.unwrap(), 40);
    let n: ?i32 = none();
    let m2 = n.and_then(fn(x: i32) -> ?i32 { return some(x); });
    assert!(m2.is_none());
    return 0;
}

fn test_result_and_then() -> i32 {
    let o: !i32 = ok(3);
    let m = o.and_then(fn(x: i32) -> !i32 { return ok(x + 100); });
    assert!(m.is_ok());
    assert_eq!(m.unwrap(), 103);
    let e: !i32 = err("stop");
    let m2 = e.and_then(fn(x: i32) -> !i32 { return ok(x); });
    assert!(m2.is_err());
    assert_str_eq!(m2.unwrap_err(), "stop");
    return 0;
}

// ---- filter (Option) -----------------------------------------------

fn test_option_filter_keeps() -> i32 {
    let s: ?i32 = some(8);
    let f = s.filter(fn(x: i32) -> bool { return x > 3; });
    assert!(f.is_some());
    assert_eq!(f.unwrap(), 8);
    return 0;
}

fn test_option_filter_drops() -> i32 {
    let s: ?i32 = some(2);
    let f = s.filter(fn(x: i32) -> bool { return x > 3; });
    assert!(f.is_none());
    return 0;
}

fn test_option_filter_on_none() -> i32 {
    let n: ?i32 = none();
    let f = n.filter(fn(x: i32) -> bool { return true; });
    assert!(f.is_none());
    return 0;
}

// ---- ok_or (Option -> Result) --------------------------------------

fn test_option_ok_or_some() -> i32 {
    let s: ?i32 = some(5);
    let r = s.ok_or("empty");
    assert!(r.is_ok());
    assert_eq!(r.unwrap(), 5);
    return 0;
}

fn test_option_ok_or_none() -> i32 {
    let n: ?i32 = none();
    let r = n.ok_or("was empty");
    assert!(r.is_err());
    assert_str_eq!(r.unwrap_err(), "was empty");
    return 0;
}

// ---- ok (Result -> Option) -----------------------------------------

fn test_result_ok_conversion() -> i32 {
    let o: !i32 = ok(7);
    let opt = o.ok();
    assert!(opt.is_some());
    assert_eq!(opt.unwrap(), 7);
    let e: !i32 = err("no");
    let opt2 = e.ok();
    assert!(opt2.is_none());
    return 0;
}

// ---- chaining several combinators ----------------------------------

fn test_chained_combinators() -> i32 {
    let s: ?i32 = some(5);
    let out = s.map(fn(x: i32) -> i32 { return x + 5; })
               .filter(fn(x: i32) -> bool { return x >= 10; })
               .unwrap_or(-1);
    assert_eq!(out, 10);
    return 0;
}

fn test_chained_to_default() -> i32 {
    let s: ?i32 = some(1);
    let out = s.map(fn(x: i32) -> i32 { return x + 1; })
               .filter(fn(x: i32) -> bool { return x >= 10; })   // 2 fails -> none
               .unwrap_or(-1);
    assert_eq!(out, -1);
    return 0;
}

// ---- Display / format! shape ---------------------------------------

fn test_display_shapes() -> i32 {
    let s: ?i32 = some(3);
    let n: ?i32 = none();
    let o: !i32 = ok(4);
    let e: !i32 = err("bad");
    assert_str_eq!(format!("{}", s), "some(3)");
    assert_str_eq!(format!("{}", n), "none");
    assert_str_eq!(format!("{}", o), "ok(4)");
    assert_str_eq!(format!("{}", e), "err(bad)");
    return 0;
}
