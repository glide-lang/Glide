import stdlib::testing::*;
import stdlib::net::tls::*;
import stdlib::http::client::*;

// Live-internet tests — skip via env-var if offline. Each opens a real
// connection to example.com and walks through TLS 1.2/1.3.

fn test_tls_config_defaults() -> i32 {
    let c: *TlsConfig = TlsConfig::client();
    defer c.free();
    assert!(c.verify);
    assert_eq!(c.min_proto, 2);
    return 0;
}

fn test_tls_config_insecure() -> i32 {
    let c: *TlsConfig = TlsConfig::client_insecure();
    defer c.free();
    assert_not!(c.verify);
    return 0;
}

fn test_https_get_example_com() -> i32 {
    let url: string = "https://example.com/";
    let r: !*HttpResponse = http_get(url);
    assert!(r.ok);
    assert_eq!(r.val.status, 200);
    assert!(r.val.body.contains("Example Domain"));
    return 0;
}

fn test_tls_handshake_yields_modern_version() -> i32 {
    let host: string = "example.com";
    let cfg: *TlsConfig = TlsConfig::client();
    defer cfg.free();
    let r: !*TlsStream = TlsStream::connect(host, 443, cfg);
    assert!(r.ok);
    let s: *TlsStream = r.val;
    let v: i32 = s.version();
    // Must be TLS 1.2 (2) or 1.3 (3); modern servers refuse 1.0/1.1.
    assert!(v >= 2);
    s.close();
    return 0;
}

fn test_tls_invalid_host_errors_out() -> i32 {
    let cfg: *TlsConfig = TlsConfig::client();
    defer cfg.free();
    let host: string = "definitely-not-real-xyz123.invalid";
    let r: !*TlsStream = TlsStream::connect(host, 443, cfg);
    assert_not!(r.ok);
    return 0;
}
