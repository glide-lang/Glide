import stdlib::testing::*;
import stdlib::process::*;
import stdlib::os::*;

fn _hostname_program() -> string {
    return "hostname";
}

fn test_run_simple_program() -> int {
    let c* = Command::new(_hostname_program());
    let r: !ProcessResult = c.run();
    assert!(r.ok);
    assert_eq!(r.val.exit_code, 0);
    return 0;
}

fn test_run_with_capture_out() -> int {
    let c* = Command::new(_hostname_program());
    c.capture_out();
    let r: !ProcessResult = c.run();
    assert!(r.ok);
    assert_eq!(r.val.exit_code, 0);
    assert!(r.val.stdout.len() > 0);
    return 0;
}

fn test_run_program_not_found() -> int {
    let c* = Command::new("definitely-not-a-real-glide-test-program");
    let r: !ProcessResult = c.run();
    if os_is_windows() {
        // Windows: CreateProcess fails synchronously when the program
        // doesn't exist, so `run` propagates an err and there's no
        // exit code to inspect.
        assert!(!r.ok);
    } else {
        // POSIX: fork+exec semantics — when execvp fails the child
        // `_exit(127)`s. The parent's waitpid still succeeds, so
        // `Command::run` returns `ok(ProcessResult { exit_code: 127 })`
        // rather than err. Detecting the exec failure as an err needs
        // a CLOEXEC-pipe handshake (Rust-style) which v1 doesn't ship.
        assert!(r.ok);
        assert_eq!(r.val.exit_code, 127);
    }
    return 0;
}

fn test_spawn_and_wait() -> int {
    let c* = Command::new(_hostname_program());
    let s: !Child = c.spawn();
    assert!(s.ok);
    let child: Child = s.val;
    assert!(child.pid > 0);
    let w: !ProcessResult = child.wait();
    assert!(w.ok);
    assert_eq!(w.val.exit_code, 0);
    return 0;
}

fn test_process_exists_bogus_pid() -> int {
    assert_not!(process_exists(99999999));
    return 0;
}

fn test_process_exists_self() -> int {
    let me: int = os_pid();
    assert!(process_exists(me));
    return 0;
}

fn test_pipe_stdout_via_spawn() -> int {
    let c* = Command::new(_hostname_program());
    c.pipe_stdout();
    let s: !Child = c.spawn();
    assert!(s.ok);
    let child: Child = s.val;
    let out: !string = child.stdout.read_all();
    assert!(out.ok);
    assert!(out.val.len() > 0);
    let w: !ProcessResult = child.wait();
    assert!(w.ok);
    return 0;
}

fn test_capture_with_env_override() -> int {
    if !os_is_windows() { return 0; }
    let c* = Command::new("cmd");
    c.arg("/c").arg("echo %GLIDE_TEST_VAR%");
    c.env("GLIDE_TEST_VAR", "from_glide_test");
    c.capture_out();
    let r: !ProcessResult = c.run();
    assert!(r.ok);
    assert_eq!(r.val.exit_code, 0);
    assert!(r.val.stdout.contains("from_glide_test"));
    return 0;
}
