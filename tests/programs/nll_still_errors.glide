// NLL doesn't relax: if the first borrow IS still used after taking
// a second one, the existing overlap-borrow error stays.

fn still_errors() {
    let mut n: i32 = 0;
    let a: &i32 = &n;
    let b: &mut i32 = &mut n;    // ERROR: a still used below
    *b = 1;
    println!(*a);
}

fn main() {
    still_errors();
}
