// Arena owned by the caller -> safe to pass the derived value into
// the spawned task (caller controls the lifetime).
fn process(p: *i32) {
    println!(*p);
}

fn outer(arena: *Arena) {
    let p: *i32 = arena.alloc(sizeof(i32)) as *i32;
    *p = 99;
    spawn process(p);              // ok: arena came from caller
}

fn main() {
    let arena: *Arena = Arena::new(64);
    defer arena.free();
    outer(arena);
    sleep_ms(10);                  // give the coro a moment to run
}
