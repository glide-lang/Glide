// Plain int passed by value -> no arena involvement, safe.
fn process(n: i32) {
    println!(n);
}

fn outer() {
    let arena: *Arena = Arena::new(64);
    defer arena.free();
    let p: *i32 = arena.alloc(sizeof(i32)) as *i32;
    *p = 7;
    let copy: i32 = *p;            // copy value out of arena
    spawn process(copy);           // ok: capturing the int by value
}

fn main() {
    outer();
    sleep_ms(10);
}
