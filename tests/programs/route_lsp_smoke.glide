import stdlib::http::*;
import stdlib::http::router::*;
import stdlib::http::route::*;

@get("/health")
fn health() -> HttpResponse { return HttpResponse::ok().text("ok"); }

@post("/users")
fn create() -> HttpResponse { return HttpResponse::ok().text("created"); }

@get("/users/:id")
fn show(id: Path<i32>) -> HttpResponse {
    return HttpResponse::ok().text("user");
}

@listen(8080)
fn main() {}
