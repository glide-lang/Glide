// RSA-PSS signing: a fresh signature verifies with the pure-Glide verifier
// (round-trip), and a tampered message is rejected. Cross-impl (sign in
// Glide, verify in OpenSSL/Python) is covered out of band.
import stdlib::testing::*;
import stdlib::crypto::rsa::*;
import stdlib::hex::*;

// A PKCS#8 RSA-2048 private key + its PKCS#1 public key.
fn _sk() -> string { return hex_decode("").unwrap(); }
fn _pk() -> string { return hex_decode("").unwrap(); }

fn test_pss_sign_verify_roundtrip() -> i32 {
    let msg: string = "message signed by the pure-Glide RSA-PSS signer";
    let sig: string = rsa_pss_sign(_sk(), PSS_SHA256, msg).unwrap();
    assert_eq!(sig.len(), 256);
    assert!(rsa_pss_verify(_pk(), PSS_SHA256, msg, sig).unwrap());
    // tampered message must not verify
    assert!(!rsa_pss_verify(_pk(), PSS_SHA256, msg.concat("!"), sig).unwrap());
    return 0;
}

fn test_pss_sign_is_randomized() -> i32 {
    // PSS uses a random salt, so two signatures differ but both verify.
    let msg: string = "same message";
    let s1: string = rsa_pss_sign(_sk(), PSS_SHA256, msg).unwrap();
    let s2: string = rsa_pss_sign(_sk(), PSS_SHA256, msg).unwrap();
    assert!(!s1.eq(s2));
    assert!(rsa_pss_verify(_pk(), PSS_SHA256, msg, s1).unwrap());
    assert!(rsa_pss_verify(_pk(), PSS_SHA256, msg, s2).unwrap());
    return 0;
}
