import stdlib::testing::*;
import stdlib::hex::*;

fn _byte(s: string, i: int) -> int {
    let mut n: int = s.at(i).to_int();
    if n < 0 { n = n + 256; }
    return n;
}

fn _cafebabe() -> string {
    return (202 as char).to_string()
        .concat((254 as char).to_string())
        .concat((186 as char).to_string())
        .concat((190 as char).to_string());
}

fn _round_trip(s: string) {
    let enc: string = hex_encode(s);
    let dec: !string = hex_decode(enc);
    assert!(dec.ok);
    let got: string = dec.val;
    assert_str_eq!(got, s);
}

fn test_empty_encode_decode() -> int {
    assert_str_eq!(hex_encode(""), "");
    let dec: !string = hex_decode("");
    assert!(dec.ok);
    let got: string = dec.val;
    assert_str_eq!(got, "");
    return 0;
}

fn test_ascii_encode() -> int {
    assert_str_eq!(hex_encode("abc"), "616263");
    return 0;
}

fn test_binary_encode() -> int {
    assert_str_eq!(hex_encode(_cafebabe()), "cafebabe");
    return 0;
}

fn test_decode_mixed_case() -> int {
    let dec: !string = hex_decode("CaFe");
    assert!(dec.ok);
    let got: string = dec.val;
    assert_eq!(got.len(), 2);
    assert_eq!(_byte(got, 0), 202);
    assert_eq!(_byte(got, 1), 254);
    return 0;
}

fn test_decode_rejects_odd_length() -> int {
    let dec: !string = hex_decode("abc");
    assert!(!dec.ok);
    assert_str_eq!(dec.err, "odd length");
    return 0;
}

fn test_decode_rejects_non_hex() -> int {
    let dec: !string = hex_decode("zz");
    assert!(!dec.ok);
    assert_str_eq!(dec.err, "non-hex char");
    return 0;
}

fn test_round_trips() -> int {
    _round_trip("x");
    _round_trip("xy");
    _round_trip("abcde");
    return 0;
}
