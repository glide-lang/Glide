import stdlib::testing::*;
import stdlib::iter::*;

// Deep edge-case coverage for the iter combinators (src/stdlib/iter.glide).
// The existing iter_test covers the happy path; these hit the empty/clamped/
// boundary cases: degenerate ranges, zero-count repeat, over-skip, negative
// take, vacuous all/any, and multi-stage chains.

fn is_even(x: i32) -> bool { return x % 2 == 0; }
fn lt3(x: i32) -> bool { return x < 3; }
fn always_false(x: i32) -> bool { return false; }
fn always_true(x: i32) -> bool { return true; }
fn add(acc: i32, x: i32) -> i32 { return acc + x; }
fn dbl(x: i32) -> i32 { return x * 2; }

fn test_range_empty_when_end_le_start() -> i32 {
    assert_eq!(iter_range(5, 5).len(), 0);
    assert_eq!(iter_range(9, 2).len(), 0);
    return 0;
}

fn test_range_step_degenerate() -> i32 {
    // step <= 0 yields empty.
    assert_eq!(iter_range_step(0, 10, 0).len(), 0);
    assert_eq!(iter_range_step(0, 10, -1).len(), 0);
    // end <= start yields empty.
    assert_eq!(iter_range_step(10, 0, 1).len(), 0);
    return 0;
}

fn test_range_step_boundary() -> i32 {
    // Stops strictly below end even when it lands exactly on it.
    let v: *Vector<i32> = iter_range_step(0, 10, 2);
    defer v.free();
    assert_eq!(v.len(), 5);
    assert_eq!(v.get(0), 0);
    assert_eq!(v.get(4), 8);
    // Step overshoots end.
    let w: *Vector<i32> = iter_range_step(0, 5, 3);
    defer w.free();
    assert_eq!(w.len(), 2);
    assert_eq!(w.get(1), 3);
    return 0;
}

fn test_repeat_zero_and_strings() -> i32 {
    assert_eq!(iter_repeat(0, 0).len(), 0);
    assert_eq!(iter_repeat(7, -1).len(), 0);
    let v: *Vector<string> = iter_repeat("x", 3);
    defer v.free();
    assert_eq!(v.len(), 3);
    assert_str_eq!(v.get(2), "x");
    return 0;
}

fn test_take_negative_and_over() -> i32 {
    let v: *Vector<i32> = iter_range(0, 5);
    defer v.free();
    // Negative take clamps to empty.
    assert_eq!(iter_take(v, -3).len(), 0);
    // Over-take clamps to full length.
    assert_eq!(iter_take(v, 99).len(), 5);
    // Zero take.
    assert_eq!(iter_take(v, 0).len(), 0);
    return 0;
}

fn test_skip_over_length() -> i32 {
    let v: *Vector<i32> = iter_range(0, 5);
    defer v.free();
    // Skipping past the end yields empty.
    assert_eq!(iter_skip(v, 99).len(), 0);
    // Negative skip keeps all.
    assert_eq!(iter_skip(v, -1).len(), 5);
    return 0;
}

fn test_take_while_first_false_empty() -> i32 {
    let v: *Vector<i32> = iter_range(0, 5);
    defer v.free();
    // Predicate false immediately -> empty result.
    assert_eq!(iter_take_while(v, always_false).len(), 0);
    // Predicate always true -> whole vector.
    assert_eq!(iter_take_while(v, always_true).len(), 5);
    return 0;
}

fn test_skip_while_variants() -> i32 {
    let v: *Vector<i32> = iter_range(0, 6);   // [0,1,2,3,4,5]
    defer v.free();
    // Skip while < 3 -> [3,4,5].
    let a: *Vector<i32> = iter_skip_while(v, lt3);
    defer a.free();
    assert_eq!(a.len(), 3);
    assert_eq!(a.get(0), 3);
    // Never skip (first is already false) -> full.
    assert_eq!(iter_skip_while(v, always_false).len(), 6);
    // Always skip -> empty.
    assert_eq!(iter_skip_while(v, always_true).len(), 0);
    return 0;
}

fn test_reducers_on_empty() -> i32 {
    let e: *Vector<i32> = Vector::new();
    defer e.free();
    assert_eq!(iter_sum_int(e), 0);
    assert_eq!(iter_count(e), 0);
    // all() on empty is vacuously true; any() is false.
    assert!(iter_all(e, is_even));
    assert_not!(iter_any(e, is_even));
    // min/max on empty is none.
    assert_not!(iter_max_int(e).has);
    assert_not!(iter_min_int(e).has);
    return 0;
}

fn test_find_hit_and_miss() -> i32 {
    let v: *Vector<i32> = iter_range(1, 6);   // [1,2,3,4,5]
    defer v.free();
    let hit: ?i32 = iter_find(v, is_even);
    assert!(hit.has);
    assert_eq!(hit.val, 2);
    let miss: ?i32 = iter_find(v, always_false);
    assert_not!(miss.has);
    return 0;
}

fn test_min_max_singleton() -> i32 {
    let v: *Vector<i32> = Vector::new();
    defer v.free();
    v.push(42);
    let mx: ?i32 = iter_max_int(v);
    let mn: ?i32 = iter_min_int(v);
    assert_eq!(mx.unwrap(), 42);
    assert_eq!(mn.unwrap(), 42);
    return 0;
}

fn test_fold_with_initial() -> i32 {
    let v: *Vector<i32> = iter_range(1, 5);   // [1,2,3,4]
    defer v.free();
    assert_eq!(iter_fold(v, 0, add), 10);
    assert_eq!(iter_fold(v, 100, add), 110);
    return 0;
}

fn test_chain_map_filter_take_sum() -> i32 {
    // range(1..8)=[1..7] -> *2 -> keep even (all) -> take 3 -> sum
    let r: *Vector<i32> = iter_range(1, 8);
    defer r.free();
    let m: *Vector<i32> = iter_map(r, dbl);     // [2,4,6,8,10,12,14]
    defer m.free();
    let f: *Vector<i32> = iter_filter(m, is_even);
    defer f.free();
    let t: *Vector<i32> = iter_take(f, 3);      // [2,4,6]
    defer t.free();
    assert_eq!(iter_sum_int(t), 12);
    return 0;
}

fn test_vec_iter_trait_next() -> i32 {
    // VecIter plugged into the Iterator trait; drive next() manually.
    let v: *Vector<i32> = Vector::new();
    defer v.free();
    v.push_all!(1, 2, 3);
    let it: *VecIter<i32> = v.iter();
    let a: ?i32 = it.next();
    let b: ?i32 = it.next();
    let c: ?i32 = it.next();
    let d: ?i32 = it.next();
    assert_eq!(a.unwrap(), 1);
    assert_eq!(b.unwrap(), 2);
    assert_eq!(c.unwrap(), 3);
    // Exhausted iterator returns none.
    assert_not!(d.has);
    return 0;
}
