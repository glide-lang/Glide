// Box<T>: a safe owning heap box. The handle is a 16-byte VALUE (ptr + arena
// flag); Box::new moves a T to the heap and the local is auto-freed at scope
// end (no manual .free()); get/set round-trip the value.
fn boxed_i32() -> i32 { let b: Box<i32> = Box::new(41); b.set(b.get() + 1); return b.get(); }
fn test_box_i32() -> i32 { assert!(boxed_i32() == 42); return 0; }

fn boxed_string() -> string { let b: Box<string> = Box::new("mur".concat("illo")); return b.get(); }
fn test_box_string() -> i32 { assert!(boxed_string().eq("murillo")); return 0; }

// The value handle is what makes the Rust `?Box<Node<T>>` recursive shape
// work: the option embeds the 16-byte handle by value, no double indirection.
struct LL<T> {
    data: T,
    next: ?Box<LL<T>>,
}

fn test_box_recursive_list() -> i32 {
    let tail: LL<i32> = LL { data: 2, next: none() };
    let head: LL<i32> = LL { data: 1, next: some(Box::new(tail)) };
    let mut sum: i32 = 0;
    sum = sum + head.data;
    match head.next {
        some(b) => {
            sum = sum + b.get().data;
        },
        none => {
            assert!(false);
        },
    }
    assert!(sum == 3);
    return 0;
}

impl<T> LL<T> {
    // Recursive in-place tail insert — get_mut is what makes the recursive
    // structure MUTABLE through the box (get would mutate a copy).
    pub fn push_back(&mut self, data: T) {
        match self.next {
            some(b) => {
                b.get_mut().push_back(data);
            },
            none => {
                self.next = some(Box::new(Self { data: data, next: none() }));
            },
        }
    }
}

fn test_box_get_mut_tail_insert() -> i32 {
    let mut head: LL<i32> = LL { data: 1, next: none() };
    head.push_back(2);
    head.push_back(3);
    let mut sum: i32 = head.data;
    match head.next {
        some(b) => {
            sum = sum + b.get().data;
            match b.get().next {
                some(c) => {
                    sum = sum + c.get().data;
                },
                none => {
                    assert!(false);
                },
            }
        },
        none => {
            assert!(false);
        },
    }
    assert!(sum == 6);
    return 0;
}
