import stdlib::testing::*;
import stdlib::json::*;

fn _near(a: f64, b: f64) -> bool {
    let mut d: f64 = a - b;
    if d < 0.0 { d = -d; }
    return d < 0.0001;
}

fn test_emit_primitives() -> i32 {
    assert_str_eq!(JsonValue::null().emit(), "null");
    assert_str_eq!(JsonValue::bool(true).emit(), "true");
    assert_str_eq!(JsonValue::bool(false).emit(), "false");
    assert_str_eq!(JsonValue::int(42).emit(), "42");
    assert_str_eq!(JsonValue::int(-7).emit(), "-7");
    assert_str_eq!(JsonValue::string("hi").emit(), "\"hi\"");
    return 0;
}

fn test_emit_escape() -> i32 {
    assert_str_eq!(JsonValue::string("a\"b").emit(), "\"a\\\"b\"");
    assert_str_eq!(JsonValue::string("a\nb").emit(), "\"a\\nb\"");
    assert_str_eq!(JsonValue::string("a\\b").emit(), "\"a\\\\b\"");
    return 0;
}

fn test_emit_array() -> i32 {
    let a: *JsonValue = JsonValue::array();
    a.arr_push(JsonValue::int(1));
    a.arr_push(JsonValue::int(2));
    a.arr_push(JsonValue::int(3));
    assert_str_eq!(a.emit(), "[1,2,3]");

    let empty: *JsonValue = JsonValue::array();
    assert_str_eq!(empty.emit(), "[]");
    return 0;
}

fn test_emit_object() -> i32 {
    let o: *JsonValue = JsonValue::object();
    o.obj_set("a", JsonValue::int(1));
    o.obj_set("b", JsonValue::string("hi"));
    assert_str_eq!(o.emit(), "{\"a\":1,\"b\":\"hi\"}");

    let empty: *JsonValue = JsonValue::object();
    assert_str_eq!(empty.emit(), "{}");
    return 0;
}

fn test_emit_nested() -> i32 {
    let o: *JsonValue = JsonValue::object();
    let arr: *JsonValue = JsonValue::array();
    arr.arr_push(JsonValue::int(1));
    arr.arr_push(JsonValue::int(2));
    o.obj_set("xs", arr);
    o.obj_set("ok", JsonValue::bool(true));
    assert_str_eq!(o.emit(), "{\"xs\":[1,2],\"ok\":true}");
    return 0;
}

fn test_parse_primitives() -> i32 {
    assert!(JsonValue::parse("null").is_null());
    assert!(JsonValue::parse("true").as_bool());
    assert_not!(JsonValue::parse("false").as_bool());
    assert_eq!(JsonValue::parse("42").as_int(), 42);
    assert_eq!(JsonValue::parse("-7").as_int(), -7);
    assert_str_eq!(JsonValue::parse("\"hi\"").as_string(), "hi");
    return 0;
}

fn test_parse_array() -> i32 {
    let v: *JsonValue = JsonValue::parse("[1, 2, 3]");
    assert_eq!(v.len(), 3);
    assert_eq!(v.at(0).as_int(), 1);
    assert_eq!(v.at(1).as_int(), 2);
    assert_eq!(v.at(2).as_int(), 3);
    return 0;
}

fn test_parse_object() -> i32 {
    let v: *JsonValue = JsonValue::parse("{\"name\": \"alice\", \"age\": 30}");
    assert_eq!(v.len(), 2);
    assert_str_eq!(v.get("name").as_string(), "alice");
    assert_eq!(v.get("age").as_int(), 30);
    let missing: *JsonValue = v.get("nope");
    assert!(missing == null);
    return 0;
}

fn test_parse_nested() -> i32 {
    let v: *JsonValue = JsonValue::parse("{\"items\":[{\"id\":1},{\"id\":2}]}");
    let items: *JsonValue = v.get("items");
    assert_eq!(items.len(), 2);

    let first: *JsonValue = items.at(0);
    assert_eq!(first.get("id").as_int(), 1);
    let second: *JsonValue = items.at(1);
    assert_eq!(second.get("id").as_int(), 2);
    return 0;
}

fn test_parse_float() -> i32 {
    let v: *JsonValue = JsonValue::parse("3.14");
    assert_eq!(v.kind, JSON_FLOAT);
    assert!(_near(v.as_float(), 3.14));

    let exp: *JsonValue = JsonValue::parse("1.5e2");
    assert!(_near(exp.as_float(), 150.0));

    let neg: *JsonValue = JsonValue::parse("-0.5");
    assert!(_near(neg.as_float(), -0.5));
    return 0;
}

fn test_parse_string_escapes() -> i32 {
    let v: *JsonValue = JsonValue::parse("\"a\\nb\\tc\\\"d\"");
    assert_str_eq!(v.as_string(), "a\nb\tc\"d");
    return 0;
}

fn test_round_trip() -> i32 {
    let o: *JsonValue = JsonValue::object();
    o.obj_set("name", JsonValue::string("alice"));
    o.obj_set("age",  JsonValue::int(30));
    o.obj_set("ok",   JsonValue::bool(true));
    o.obj_set("nada", JsonValue::null());

    let s: string = o.emit();
    let parsed: *JsonValue = JsonValue::parse(s);
    assert_str_eq!(parsed.get("name").as_string(), "alice");
    assert_eq!(parsed.get("age").as_int(), 30);
    assert!(parsed.get("ok").as_bool());
    assert!(parsed.get("nada").is_null());
    return 0;
}

// Recursive JsonValue::free reclaims the arr/obj Vectors of a whole nested tree.
// Access all nested values FIRST (so a premature free would read garbage), then
// free; a double free of any shared child Vector would abort. `free(null)` is a
// no-op. Looped so a leak/UAF would show as a crash or wrong value.
fn test_recursive_free() -> i32 {
    for i in 0..2000 {
        let v: *JsonValue = JsonValue::parse("{\"a\":[1,[2,3],{\"z\":9}],\"b\":{\"c\":[true,\"x\"]}}");
        assert_eq!(v.get("a").at(1).at(0).as_int(), 2);
        assert_eq!(v.get("a").at(2).get("z").as_int(), 9);
        assert_str_eq!(v.get("b").get("c").at(1).as_string(), "x");
        v.free();
    }
    let n: *JsonValue = JsonValue::parse("null");
    n.free();
    return 0;
}
