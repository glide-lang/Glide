import stdlib::testing::*;
import stdlib::bytes::*;

fn test_new_is_empty() -> i32 {
    let b: *ByteBuffer = ByteBuffer::new();
    defer b.free();
    assert_eq!(b.len(), 0);
    assert!(b.cap() > 0);
    return 0;
}

fn test_push_increments_len() -> i32 {
    let b: *ByteBuffer = ByteBuffer::new();
    defer b.free();
    b.push(65 as u8);
    b.push(66 as u8);
    b.push(67 as u8);
    assert_eq!(b.len(), 3);
    let v0: i32 = b.at(0) as i32;
    let v1: i32 = b.at(1) as i32;
    let v2: i32 = b.at(2) as i32;
    assert_eq!(v0, 65);
    assert_eq!(v1, 66);
    assert_eq!(v2, 67);
    return 0;
}

fn test_push_str_appends_all_bytes() -> i32 {
    let b: *ByteBuffer = ByteBuffer::new();
    defer b.free();
    b.push_str("hello");
    assert_eq!(b.len(), 5);
    assert_str_eq!(b.as_string(), "hello");
    return 0;
}

fn test_push_str_concat() -> i32 {
    let b: *ByteBuffer = ByteBuffer::new();
    defer b.free();
    b.push_str("hello, ");
    b.push_str("world");
    assert_str_eq!(b.as_string(), "hello, world");
    assert_eq!(b.len(), 12);
    return 0;
}

fn test_clear_resets_len_keeps_cap() -> i32 {
    let b: *ByteBuffer = ByteBuffer::new();
    defer b.free();
    b.push_str("noise");
    let cap_before: i32 = b.cap();
    b.clear();
    assert_eq!(b.len(), 0);
    assert_eq!(b.cap(), cap_before);
    b.push_str("x");
    assert_str_eq!(b.as_string(), "x");
    return 0;
}

fn test_capacity_grows_amortised() -> i32 {
    let b: *ByteBuffer = ByteBuffer::new();
    defer b.free();
    let initial_cap: i32 = b.cap();
    for let i: i32 = 0; i < 100; i++ { b.push(48 as u8); }
    assert_eq!(b.len(), 100);
    assert!(b.cap() > initial_cap);
    return 0;
}
