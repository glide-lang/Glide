import stdlib::testing::*;
import stdlib::os::*;

fn test_os_name_is_supported() -> int {
    let name: string = os_name();
    let ok: bool = name.eq("windows") || name.eq("linux") || name.eq("macos");
    assert_msg!(ok, "unexpected os_name: ${name}");
    return 0;
}

fn test_os_arch_is_non_empty() -> int {
    assert!(os_arch().len() > 0);
    return 0;
}

fn test_os_windows_and_posix_are_exclusive() -> int {
    assert_not!(os_is_windows() && os_is_posix());
    assert!(os_is_windows() || os_is_posix());
    return 0;
}

fn test_os_path_sep_matches_platform() -> int {
    let mut expected: string = "/";
    if os_is_windows() { expected = "\\"; }
    assert_str_eq!(os_path_sep(), expected);
    return 0;
}

fn test_os_cwd_is_non_empty() -> int {
    assert!(os_cwd().len() > 0);
    return 0;
}

fn test_os_exe_path_is_non_empty() -> int {
    assert!(os_exe_path().len() > 0);
    return 0;
}
