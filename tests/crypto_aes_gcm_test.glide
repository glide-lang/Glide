// AES-128/256-GCM against the classic McGrew-Viega / NIST test vectors,
// plus round-trip, tamper, and empty-input checks.
import stdlib::testing::*;
import stdlib::crypto::aes_gcm::*;
import stdlib::hex::*;

fn _h(s: string) -> string {
    let r: !string = hex_decode(s);
    if !r.is_ok() { return ""; }
    return r.unwrap();
}

fn test_aes128_gcm_vector() -> i32 {
    let key: string   = _h("feffe9928665731c6d6a8f9467308308");
    let nonce: string = _h("cafebabefacedbaddecaf888");
    let aad: string   = _h("feedfacedeadbeeffeedfacedeadbeefabaddad2");
    let pt: string    = _h("d9313225f88406e5a55909c5aff5269a86a7a9531534f7da2e4c303d8a318a721c3c0c95956809532fcf0e2449a6b525b16aedf5aa0de657ba637b39");
    let sealed: !string = aes_gcm_encrypt(key, nonce, pt, aad);
    assert!(sealed.is_ok());
    assert_str_eq!(hex_encode(sealed.unwrap()),
        "42831ec2217774244b7221b784d0d49ce3aa212f2c02a4e035c17e2329aca12e21d514b25466931c7d8f6a5aac84aa051ba30b396a0aac973d58e0915bc94fbc3221a5db94fae95ae7121a47");
    return 0;
}

fn test_aes256_gcm_vector() -> i32 {
    let key: string   = _h("feffe9928665731c6d6a8f9467308308feffe9928665731c6d6a8f9467308308");
    let nonce: string = _h("cafebabefacedbaddecaf888");
    let aad: string   = _h("feedfacedeadbeeffeedfacedeadbeefabaddad2");
    let pt: string    = _h("d9313225f88406e5a55909c5aff5269a86a7a9531534f7da2e4c303d8a318a721c3c0c95956809532fcf0e2449a6b525b16aedf5aa0de657ba637b39");
    let sealed: !string = aes_gcm_encrypt(key, nonce, pt, aad);
    assert!(sealed.is_ok());
    assert_str_eq!(hex_encode(sealed.unwrap()),
        "522dc1f099567d07f47f37a32a84427d643a8cdcbfe5c0c97598a2bd2555d1aa8cb08e48590dbb3da7b08b1056828838c5f61e6393ba7a0abcc9f66276fc6ece0f4e1768cddf8853bb2d551b");
    return 0;
}

// All-zero key/nonce, empty plaintext & AAD: the tag is E_K(J0).
fn test_aes128_empty() -> i32 {
    let sealed: !string = aes_gcm_encrypt(_h("00000000000000000000000000000000"),
                                          _h("000000000000000000000000"), "", "");
    assert!(sealed.is_ok());
    assert_str_eq!(hex_encode(sealed.unwrap()), "58e2fccefa7e3061367f1d57a4e7455a");
    return 0;
}

fn test_roundtrip_both_keysizes() -> i32 {
    let n: string = _h("000000000000000000000000");
    let pt: string = "over the wire\x00binary payload";
    let k128: string = _h("0f0e0d0c0b0a09080706050403020100");
    let s1: string = aes_gcm_encrypt(k128, n, pt, "aad").unwrap();
    let d1: !string = aes_gcm_decrypt(k128, n, s1, "aad");
    assert!(d1.is_ok());
    assert!(d1.unwrap().eq(pt));
    let k256: string = _h("000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f");
    let s2: string = aes_gcm_encrypt(k256, n, pt, "aad").unwrap();
    let d2: !string = aes_gcm_decrypt(k256, n, s2, "aad");
    assert!(d2.is_ok());
    assert!(d2.unwrap().eq(pt));
    return 0;
}

fn test_tamper_and_wrong_aad_fail() -> i32 {
    let k: string = _h("0f0e0d0c0b0a09080706050403020100");
    let n: string = _h("000000000000000000000000");
    let sealed: string = aes_gcm_encrypt(k, n, "secret message", "aad").unwrap();
    // flip a ciphertext byte
    let mut bad: string = "";
    for let i: i32 = 0; i < sealed.len(); i++ {
        let b: i32 = sealed.at(i).to_int();
        if i == 2 { bad = bad.concat(((b ^ 8) as char).to_string()); }
        else { bad = bad.concat((b as char).to_string()); }
    }
    assert!(aes_gcm_decrypt(k, n, bad, "aad").is_err());
    assert!(aes_gcm_decrypt(k, n, sealed, "wrong").is_err());
    return 0;
}
