import stdlib::testing::*;
import stdlib::http::*;
import stdlib::http::typed::*;
import stdlib::http::handler::*;
import stdlib::json::*;
import stdlib::json::derive::*;

@derive(JsonBind)
pub struct Item {
    pub id:    string,
    pub price: int,
}

// Output-only: confirms the @handler wrapper monomorphises
// Json<Vector<Item>> properly on the return path.
@handler
fn list_items() -> Json<Vector<Item>> {
    let xs: *Vector<Item> = Vector::new();
    xs.push(Item { id: "a", price: 10 });
    xs.push(Item { id: "b", price: 20 });
    return Json::wrap(*xs);
}

// Input + output: full round-trip via the macro-emitted body_json +
// Vector::from_json + Json::wrap pipeline.
@handler
fn echo_items(body: Json<Vector<Item>>) -> Json<Vector<Item>> {
    return Json::wrap(body.val);
}

fn _post(body: string) -> HttpRequest {
    return HttpRequest {
        method:        "POST",
        path:          "/items",
        version:       "HTTP/1.1",
        headers_block: "",
        body:          body,
        params:        null,
        queries:       null,
    };
}

fn _get() -> HttpRequest {
    return HttpRequest {
        method:        "GET",
        path:          "/items",
        version:       "HTTP/1.1",
        headers_block: "",
        body:          "",
        params:        null,
        queries:       null,
    };
}

fn test_returns_json_array() -> int {
    let req: HttpRequest = _get();
    let r: HttpResponse = list_items(&req);
    assert_eq!(r.status, 200);
    assert_str_eq!(r.header("Content-Type"), "application/json");
    assert_str_eq!(r.body, "[{\"id\":\"a\",\"price\":10},{\"id\":\"b\",\"price\":20}]");
    return 0;
}

fn test_echo_round_trip() -> int {
    let req: HttpRequest = _post("[{\"id\":\"x\",\"price\":1},{\"id\":\"y\",\"price\":2}]");
    let r: HttpResponse = echo_items(&req);
    assert_eq!(r.status, 200);
    assert_str_eq!(r.body, "[{\"id\":\"x\",\"price\":1},{\"id\":\"y\",\"price\":2}]");
    return 0;
}

fn test_echo_empty_array() -> int {
    let req: HttpRequest = _post("[]");
    let r: HttpResponse = echo_items(&req);
    assert_eq!(r.status, 200);
    assert_str_eq!(r.body, "[]");
    return 0;
}

fn test_echo_bad_element_is_422() -> int {
    // Second element is missing `price` — Vector<Item>::from_json
    // bubbles the err via `?` and the macro converts to 422.
    let req: HttpRequest = _post("[{\"id\":\"x\",\"price\":1},{\"id\":\"y\"}]");
    let r: HttpResponse = echo_items(&req);
    assert_eq!(r.status, 422);
    return 0;
}

fn test_echo_non_array_is_422() -> int {
    let req: HttpRequest = _post("{\"id\":\"x\",\"price\":1}");
    let r: HttpResponse = echo_items(&req);
    assert_eq!(r.status, 422);
    return 0;
}

fn test_echo_invalid_json_is_400() -> int {
    let req: HttpRequest = _post("not json");
    let r: HttpResponse = echo_items(&req);
    assert_eq!(r.status, 400);
    return 0;
}
