// B3 range slicing: `base[lo..hi]` yields a `[]T` fat-pointer subview of base
// (zero-copy). A slice base re-borrows exclusively (sound, mirrors as_slice); a
// raw-pointer base is the manual layer (unchecked). `..=` is inclusive. Each
// case asserts real element values through the subview.

fn test_slice_range_exclusive() -> i32 {
    let mut v: *Vector<i32> = Vector::new();
    v.push(10); v.push(20); v.push(30); v.push(40);
    let sl = v.as_slice();
    let sub = sl[1..3];              // {ptr+1, len 2} -> [20, 30]
    assert!(sub.len == 2);
    assert!(sub[0] == 20);
    assert!(sub[1] == 30);
    return 0;
}

fn test_slice_range_inclusive() -> i32 {
    let mut v: *Vector<i32> = Vector::new();
    v.push(1); v.push(2); v.push(3);
    let sl = v.as_slice();
    let sub = sl[0..=1];            // inclusive -> [1, 2], len 2
    assert!(sub.len == 2);
    assert!(sub[0] == 1);
    assert!(sub[1] == 2);
    return 0;
}

fn test_ptr_range_manual() -> i32 {
    let p: *i32 = calloc(4, sizeof(i32)) as *i32;
    p[0] = 5; p[1] = 6; p[2] = 7; p[3] = 8;
    let s = p[1..3];               // manual layer: {p+1, len 2} -> [6, 7]
    assert!(s.len == 2);
    assert!(s[0] == 6);
    assert!(s[1] == 7);
    free(p as *void);
    return 0;
}

// Empty range is a zero-length subview.
fn test_empty_range() -> i32 {
    let mut v: *Vector<i32> = Vector::new();
    v.push(9); v.push(9);
    let sl = v.as_slice();
    let sub = sl[1..1];
    assert!(sub.len == 0);
    return 0;
}
