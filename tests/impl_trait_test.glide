// `impl Trait` argument sugar: `fn a(ao: impl T)` desugars to a hidden
// generic with the bound — static dispatch. Also covers &self receivers
// through dyn (the vtable thunk must pass the pointer, not deref it).
import stdlib::testing::*;

struct Boxy { n: i32 }

trait Sized2 {
    fn size(&self) -> i32;
}

impl Sized2 for Boxy {
    pub fn size(&self) -> i32 { return self.n; }
}

fn take_impl(x: impl Sized2) -> i32 {
    return x.size();
}

fn take_dyn(x: *dyn Sized2) -> i32 {
    return x.size();
}

fn test_impl_trait_arg() -> i32 {
    let b: *Boxy = malloc(8) as *Boxy;
    b.n = 9;
    assert_eq!(take_impl(b), 9);
    return 0;
}

fn test_dyn_borrow_receiver() -> i32 {
    let b: *Boxy = malloc(8) as *Boxy;
    b.n = 4;
    assert_eq!(take_dyn(b as *dyn Sized2), 4);
    return 0;
}

// Implicit dyn coercion at call sites: a concrete value or pointer whose type
// implements the trait passes straight into a `*dyn Trait` parameter — no
// `as *dyn` spelled out. Also: a trait method with NO receiver dispatches
// through dyn (the vtable thunk must not forward self to a 0-arg fn).
trait Named {
    fn tag() -> i32;
    fn value(&self) -> i32;
}

impl Named for Boxy {
    pub fn tag() -> i32 { return 77; }
    pub fn value(&self) -> i32 { return self.n; }
}

fn describe(x: *dyn Named) -> i32 {
    return x.value();
}

fn test_implicit_dyn_coercion() -> i32 {
    let v = Boxy { n: 3 };
    assert_eq!(describe(v), 3);
    let p: *Boxy = malloc(8) as *Boxy;
    p.n = 8;
    assert_eq!(describe(p), 8);
    return 0;
}


// Auto-ref: a VALUE passes into an `impl Trait` / `<T: Bound>` parameter —
// the typer inserts the `&` (like Rust's auto-ref).
fn test_value_into_impl_arg() -> i32 {
    let v = Boxy { n: 11 };
    assert_eq!(take_impl(v), 11);
    return 0;
}

// A trait DEFAULT method with a non-void return type must return on every path,
// exactly like a free function or an impl method.
struct Gauge { v: i32 }

trait Measured {
    fn reading(&self) -> i32 {
        return 42;
    }
    fn scale() -> i32 {
        return 1;
    }
}

impl Measured for Gauge {
}

fn test_trait_default_returns() -> i32 {
    let g = Gauge { v: 9 };
    assert_eq!(g.reading(), 42);
    assert_eq!(Gauge::scale(), 1);
    return 0;
}

// A module-qualified trait works in `impl mod::Trait for T`, `*dyn mod::Trait`
// param types, and implicit coercion — same-file variant (no cross-file dep).
trait Qual {
    fn q(&self) -> i32;
}

struct QImpl {}

impl Qual for QImpl {
    pub fn q(&self) -> i32 { return 7; }
}

fn _take_qual(d: *dyn Qual) -> i32 {
    return d.q();
}

fn test_dyn_trait_param() -> i32 {
    let v = QImpl {};
    assert_eq!(_take_qual(v), 7);
    return 0;
}

// A trait method with `&self` implemented for `string` is dot-callable on a
// string rvalue (`"".m()`), which lowers a borrowed receiver — the codegen
// must spill the literal to a temp, not emit `&"..."`.
trait Shout {
    fn shout(&self) -> string;
}

impl Shout for string {
    pub fn shout(&self) -> string {
        return self.concat("!");
    }
}

fn test_trait_method_on_string_literal() -> i32 {
    let s = "hi".shout();
    assert!(s.eq("hi!"));
    return 0;
}
