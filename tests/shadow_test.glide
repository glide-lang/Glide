import stdlib::testing::*;

// Variable shadowing: `let b = ...; let b = b.val;` re-binds `b` (often to a
// different type). Codegen alpha-renames the shadow to a unique C name so the
// two declarations don't collide. The RHS of a shadowing `let` reads the OLD
// binding.

fn _get() -> !i32 { return ok(42); }
fn _gets() -> !string { return ok("hi"); }

fn test_shadow_rebind_changes_type() -> i32 {
    let b = _get();        // !i32
    assert!(b.ok);
    let b = b.val;         // i32 (reads the old `b`)
    let b = b + 1;         // i32 again
    assert_eq!(b, 43);
    return 0;
}

fn test_shadow_string_payload() -> i32 {
    let s = _gets();       // !string
    assert!(s.ok);
    let s = s.val;         // string
    assert_str_eq!(s, "hi");
    return 0;
}

// A `let` in a nested block shadows the outer binding only within that block;
// after it, the outer binding is back. (C handles the nesting; this guards that
// the rename pass restores its scope map correctly.)
fn _nested(flag: bool) -> i32 {
    let x = 1;
    let mut total = 0;
    if flag {
        let x = 2;
        total = total + x;
    }
    total = total + x;     // outer x == 1
    return total;
}

fn test_shadow_nested_scope() -> i32 {
    assert_eq!(_nested(true), 3);
    assert_eq!(_nested(false), 1);
    return 0;
}
