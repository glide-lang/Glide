import stdlib::testing::*;
import stdlib::http::hpack::*;
import stdlib::bytes::*;

// RFC 7541 §C.2.1 — Literal Header Field with Indexing
fn test_literal_with_indexing_round_trip() -> int {
    let enc: *HpackEncoder = HpackEncoder::new();
    let buf: *ByteBuffer = ByteBuffer::new();
    enc.encode_header(buf, "custom-key", "custom-header");
    assert_eq!(buf.len, 26);

    let dec: *HpackDecoder = HpackDecoder::new();
    let r: !*Vector<*HpackHeader> = dec.decode_block(buf.as_string(), buf.len);
    assert!(r.ok);
    assert_eq!(r.val.len(), 1);
    assert_str_eq!(r.val.get(0).name, "custom-key");
    assert_str_eq!(r.val.get(0).value, "custom-header");
    return 0;
}

fn test_indexed_static_method_get() -> int {
    let enc: *HpackEncoder = HpackEncoder::new();
    let buf: *ByteBuffer = ByteBuffer::new();
    enc.encode_header(buf, ":method", "GET");
    // Static idx 2 -> single byte 0x82 (1xxx_xxxx high bit + 7-bit value 2)
    assert_eq!(buf.len, 1);
    assert_eq!(buf.at(0) as int, 130);
    return 0;
}

fn test_indexed_static_status_200() -> int {
    let enc: *HpackEncoder = HpackEncoder::new();
    let buf: *ByteBuffer = ByteBuffer::new();
    enc.encode_header(buf, ":status", "200");
    // Static idx 8 -> 0x88
    assert_eq!(buf.len, 1);
    assert_eq!(buf.at(0) as int, 136);
    return 0;
}

fn test_round_trip_three_headers() -> int {
    let enc: *HpackEncoder = HpackEncoder::new();
    let buf: *ByteBuffer = ByteBuffer::new();
    enc.encode_header(buf, ":method", "GET");
    enc.encode_header(buf, ":path", "/");
    enc.encode_header(buf, "user-agent", "glide/test");

    let dec: *HpackDecoder = HpackDecoder::new();
    let r: !*Vector<*HpackHeader> = dec.decode_block(buf.as_string(), buf.len);
    assert!(r.ok);
    assert_eq!(r.val.len(), 3);
    assert_str_eq!(r.val.get(0).name, ":method");
    assert_str_eq!(r.val.get(0).value, "GET");
    assert_str_eq!(r.val.get(1).name, ":path");
    assert_str_eq!(r.val.get(1).value, "/");
    assert_str_eq!(r.val.get(2).name, "user-agent");
    assert_str_eq!(r.val.get(2).value, "glide/test");
    return 0;
}

fn test_dynamic_table_reuse() -> int {
    // The encoder records (name, value) into its dyn table on first
    // encode. The second encode of the same pair becomes one byte.
    let enc: *HpackEncoder = HpackEncoder::new();
    let b1: *ByteBuffer = ByteBuffer::new();
    enc.encode_header(b1, "x-custom", "value-1");
    let first_size: int = b1.len;

    let b2: *ByteBuffer = ByteBuffer::new();
    enc.encode_header(b2, "x-custom", "value-1");
    // Second time should be way smaller (single indexed byte).
    assert!(b2.len < first_size);
    assert_eq!(b2.len, 1);
    return 0;
}
