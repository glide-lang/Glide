// HTTP/3 client probe — issues a single GET via stdlib::http::h3.
import stdlib::http::*;
import stdlib::http::h3::*;
import stdlib::env::*;

fn main() -> int {
    let mut url: string = env_get("URL");
    if url.eq("") { url = "https://127.0.0.1:4433/probe"; }
    println!("GET", url, "via h3");
    let r: !*HttpResponse = http3_get(url, true);
    if !r.ok { println!("h3 failed:", r.err); return 1; }
    println!("status:", r.val.status);
    println!("body:", r.val.body);
    return 0;
}
