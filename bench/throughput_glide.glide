// Throughput: spawn N short-lived coros that do trivial work and exit.
// Measures pure spawn+schedule+exit cost.

extern fn __glide_perf_dump();

fn worker(id: int, c: chan<int>) {
    c.send(id);
}

fn main() -> int {
    let n: int = 100000;
    let c: chan<int> = make_chan(1024);
    for i in 0..n {
        spawn worker(i, c);
    }
    let mut sum: int = 0;
    for i in 0..n {
        sum = sum + c.recv();
    }
    println!("sum", sum);
    __glide_perf_dump();
    return 0;
}
