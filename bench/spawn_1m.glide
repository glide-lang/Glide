extern fn now_ns() -> i64;
extern fn pending_count() -> int;

fn worker() { return; }

fn main() -> int {
    let n: int = 1000000;
    let t0: i64 = now_ns();
    for i in 0..n { spawn worker(); }
    while pending_count() > 0 { }
    let t1: i64 = now_ns();
    println!("spawn+drain", n, ":", (t1 - t0) / 1000000, "ms");
    return 0;
}
