import stdlib::fs::*;
import stdlib::hashmap::*;
import bootstrap::syntax::ast::*;
import bootstrap::syntax::lexer::*;
import bootstrap::syntax::parser::*;
import bootstrap::cli::fmt::*; // for fmt_type signatures
import bootstrap::pkg::manifest::*; // for dep discovery (read_manifest, dep_cache_dir, ManifestDep)

// `glide doc`: walk every `*.glide` under the project root, parse it,
// pull out top-level `pub` items + their `///` doc comments, and emit
// a tiny static HTML site under `build/doc/`. Each source file maps
// to one HTML page; the index lists modules with a short blurb.
//
// We don't try to be rustdoc — no cross-linking, no search. Goal is
// "browseable reference for the API surface you exposed", and the
// expectation is that the user reads `///` content directly in source.
pub struct DocItem {
    pub kind: i32, // 1=fn, 2=struct, 3=enum, 4=const, 5=trait, 6=impl, 7=macro
    pub name: string,
    pub signature: string, // single-line rendered head
    pub doc: string, // raw `///` block, with leading `///` stripped
    pub line: i32,
}

pub struct DocModule {
    pub origin: string, // source file path
    pub display: string, // pretty module path for headings/links
    pub slug: string, // safe HTML filename (no slashes)
    pub items: *Vector<DocItem>,
    pub blurb: string, // first non-empty doc line, for the index
    // Logical bucket for grouping on the index page:
    //   "project" — files under the user's manifest root
    //   "stdlib"  — files from src/stdlib/ (only when --stdlib is set)
    //   "<dep>"   — files from a declared manifest dep
    pub package: string,
    // Package-level metadata, only populated for the first module of a
    // dep. Lets the index page show a one-line summary + repo URL per
    // package without scanning every dep's manifest on render.
    pub pkg_repo: string,
    pub pkg_desc: string,
    pub pkg_ver: string,
}

extern fn __glide_file_exists(path: string) -> bool;

extern fn read_file(path: string) -> string;

extern fn write_file(path: string, content: string) -> bool;

pub fn run_doc(root_dir: string, open_after: bool, serve_port: i32, emit_ai: bool, include_stdlib: bool) -> i32 {
    let out_dir: string = root_dir.concat("/build/doc");
    if !fs_mkdir_p(out_dir) {
        println!("doc: could not create", out_dir);
        return 1;
    }
    let files: *Vector<string> = fs_list_rec(root_dir, ".glide");
    let modules: *Vector<DocModule> = _vec_modules();
    let mut total_items: i32 = 0;
    for let i: i32 = 0; i < files.len(); i++ {
        let f: string = files.get(i);
        // Skip the project's own manifest, the lockfile, and anything under
        // build/ (generated C, the binary, and the dep links under
        // build/deps/ - deps get a dedicated walk below so each one is tagged
        // with its package name).
        if _ends_with(f, "/glide.glide") || _ends_with(f, "/glide.lock") {
            continue;
        }
        if _contains_segment(f, "build") {
            continue;
        }
        let m: *DocModule = _scan_file(f, root_dir);
        if m == null {
            continue;
        }
        if m.items.len() == 0 {
            continue;
        }
        m.package = "project";
        modules.push(*m);
        total_items = total_items + m.items.len();
    }
    // Project deps from the manifest: each declared dep gets its own
    // group on the index page so a project's docs include the API
    // surface of everything it imports. Path deps are visited even when
    // they live outside the project root; git deps need a prior `glide
    // fetch` (we skip unfetched ones with a warning).
    let mf: *Manifest = read_manifest(root_dir);
    if mf != null {
        for let i: i32 = 0; i < mf.deps.len(); i++ {
            let d: ManifestDep = mf.deps.get(i);
            let dep_root: string = dep_cache_dir(mf, d);
            if dep_root.eq("") || !__glide_file_exists(dep_root.concat("/glide.glide")) {
                if !dep_root.eq("") {
                    println!("doc: skipping `".concat(d.name).concat("` (not fetched - run `glide fetch`)"));
                }
                continue;
            }
            let dep_files: *Vector<string> = fs_list_rec(dep_root, ".glide");
            let mut first: bool = true;
            for let j: i32 = 0; j < dep_files.len(); j++ {
                let f: string = dep_files.get(j);
                if _ends_with(f, "/glide.glide") || _ends_with(f, "/glide.lock") {
                    continue;
                }
                if _contains_segment(f, "build") {
                    continue;
                }
                if _contains_segment(f, "tests") {
                    continue;
                }
                let dm: *DocModule = _scan_file(f, dep_root);
                if dm == null {
                    continue;
                }
                if dm.items.len() == 0 {
                    continue;
                }
                dm.package = d.name;
                if first {
                    // Surface package-level metadata on the first
                    // module of the group — the index renders it as
                    // a per-package header.
                    let sub_m: *Manifest = read_manifest(dep_root);
                    if sub_m != null {
                        dm.pkg_desc = sub_m.description;
                        dm.pkg_repo = sub_m.repository;
                        dm.pkg_ver = sub_m.version;
                    }
                    first = false;
                }
                modules.push(*dm);
                total_items = total_items + dm.items.len();
            }
        }
    }
    // `--stdlib`: walk the compiler-bundled standard library too. Each
    // file is scanned with the stdlib's `src/` as its display root, so
    // modules surface as `stdlib::hashmap`, `stdlib::http::client`,
    // etc. — matching the user-facing import path.
    if include_stdlib {
        let std_root: string = _find_stdlib_src_root();
        if std_root.eq("") {
            println!("doc: could not locate the bundled stdlib");
        } else {
            let std_files: *Vector<string> = fs_list_rec(std_root.concat("/stdlib"), ".glide");
            for let i: i32 = 0; i < std_files.len(); i++ {
                let f: string = std_files.get(i);
                let m: *DocModule = _scan_file(f, std_root);
                if m == null {
                    continue;
                }
                if m.items.len() == 0 {
                    continue;
                }
                m.package = "stdlib";
                modules.push(*m);
                total_items = total_items + m.items.len();
            }
        }
    }
    if modules.len() == 0 {
        // No docs to render — but `--ai` should still drop AGENTS.md
        // so the user can wire up agent rules on day one, before any
        // pub item exists.
        if emit_ai {
            let agents_path: string = root_dir.concat("/AGENTS.md");
            if __glide_file_exists(agents_path) {
                println!("doc: AGENTS.md already present, leaving as-is");
            } else {
                _write_agents_md(agents_path);
                println!("doc: wrote agent-rules file ->", agents_path);
            }
        }
        println!("doc: no `pub` items with docs found under", root_dir);
        return if emit_ai { 0 } else { 1 };
    }
    let css: string = _doc_css();
    write_file(out_dir.concat("/style.css"), css);
    _write_index(out_dir, modules);
    for let i: i32 = 0; i < modules.len(); i++ {
        let m: DocModule = modules.get(i);
        _write_module_page(out_dir, &m);
    }
    let index_path: string = out_dir.concat("/index.html");
    println!("doc: wrote", modules.len(), "modules /", total_items, "items ->", index_path);
    if emit_ai {
        let llms_path: string = out_dir.concat("/llms.txt");
        _write_llms_txt(llms_path, modules);
        println!("doc: wrote LLM-friendly summary ->", llms_path);
        let agents_path: string = root_dir.concat("/AGENTS.md");
        if __glide_file_exists(agents_path) {
            println!("doc: AGENTS.md already present, leaving as-is");
        } else {
            _write_agents_md(agents_path);
            println!("doc: wrote agent-rules file ->", agents_path);
        }
    }
    if serve_port > 0 {
        if open_after {
            _open_in_browser("http://127.0.0.1:".concat(int_to_str(serve_port)).concat("/"));
        }
        return doc_serve(out_dir, serve_port);
    }
    if open_after {
        _open_in_browser(index_path);
    }
    return 0;
}

// Drop an AGENTS.md at the project root. Format follows the
// convention adopted by Claude Code, OpenAI Codex, and modern Cursor —
// the agent reads it before doing anything else and treats the
// directives inside as mandatory context. Static template: a
// language overview + a forced redirect to `build/doc/llms.txt` for
// the actual API surface + the project conventions every Glide
// user should know.
pub fn write_agents_md(path: string) {
    _write_agents_md(path);
}

fn _write_agents_md(path: string) {
    let body: string = "# Glide — agent context\n".concat("\n").concat("**Read this file every time you touch Glide code in this repo.**\n").concat("\n").concat("## 1. Required reading\n").concat("\n").concat("Before generating, editing, or reviewing any `.glide` file:\n").concat("\n").concat("1. Open `build/doc/llms.txt`. Every `pub` item in the project\n").concat("   and its dependencies lives there in plain text. If the file is\n").concat("   missing, regenerate with `glide doc --ai`.\n").concat("2. Scan the module(s) you'll be modifying for existing\n").concat("   conventions, then match them.\n").concat("\n").concat("This is not optional. The Glide stdlib has idioms that differ\n").concat("from Rust, Go, and C — guessing leads to non-compiling output.\n").concat("\n").concat("## 2. Language quick-reference\n").concat("\n").concat("- **Errors as values**: `!T` (Result), `?T` (Option), `?!T`\n").concat("  (Option-Result). No exceptions. Propagate with `?` postfix.\n").concat("- **Memory**: arena-allocated by default. `let v* = T { … };`\n").concat("  is auto-dropped at block exit. Raw allocation via `malloc`\n").concat("  + `defer free(p)` is supported but rare.\n").concat("- **Concurrency**: M:N coroutines via `spawn fn_call(args);`.\n").concat("  Channels typed as `chan<T>`; `make_chan(cap)`, `c.send(x)`,\n").concat("  `c.recv()`, `c.close()`. OS threads via `spawn_thread`.\n").concat("- **Methods**: `impl T { fn method(self: *T, …) }`. Macros\n").concat("  attached to types follow the same shape.\n").concat("- **Traits + dyn**: `trait T { fn m(self) }` with\n").concat("  optional default bodies. `*dyn T` for vtable dispatch.\n").concat("- **Generics**: `fn f<T>(v: T)`. Bounds via `T: Trait + Trait`.\n").concat("  Monomorphised; the compiler emits one C fn per concrete T.\n").concat("- **Macros**: builtins `println!` / `format!` / `assert!`;\n").concat("  string interpolation `\"x={x}\"`; `select!` over channels.\n").concat("  Procedural macros by attribute (`@derive(JsonBind)`,\n").concat("  `@handler`, `@logged`, `@trace`) and function-like\n").concat("  `info!` / `warn!` / `error!` / … from `stdlib::log`.\n").concat("- **Doc comments**: `///` triple-slash above the decl. Put\n").concat("  examples in fenced ```glide blocks; show sample output as a\n").concat("  trailing `// result` line — keep this style.\n").concat("\n").concat("## 3. Project commands\n").concat("\n").concat("```\n").concat("glide new <name> [--lib] [--ai]   scaffold a project\n").concat("glide run                        build + run from the manifest\n").concat("glide build [--target=<triple>]  build only (sysroot auto-fetched for cross)\n").concat("glide check <file>               parse + type-check, no codegen\n").concat("glide test [path]                run *_test.glide files\n").concat("glide bench [path]               run *_bench.glide microbenchmarks\n").concat("glide lint [file]                run all lints (project bin by default)\n").concat("glide fix [file]                 apply mechanical fixes\n").concat("glide fmt <file> [--write]       pretty-print, or rewrite in place\n").concat("glide doc --ai                   regenerate llms.txt for THIS file\n").concat("glide add <name> <url> <rev>     add a git dep\n").concat("glide add --local <name> <path>  add a path dep\n").concat("glide remove <name>              drop a dep from glide.glide\n").concat("glide fetch                      pull declared deps\n").concat("glide update                     refresh git deps + rewrite lock\n").concat("glide install <path|git-url>     install a glide binary/tool\n").concat("glide target <list|add|remove>   manage cross-compile sysroots\n").concat("glide clean                      wipe build/ + glide.lock\n").concat("glide lsp                        language server on stdio\n").concat("```\n").concat("\n").concat("## 4. House rules\n").concat("\n").concat("- Don't write `try` / `catch`; use `!T` + `?` propagation.\n").concat("- Don't malloc without a paired `defer free(…)` unless the\n").concat("  value is owned by an arena.\n").concat("- Don't use `*chan<T>` parameters when `chan<T>` suffices —\n").concat("  the value already IS a pointer at the C layer.\n").concat("- Don't import `stdlib::http` from a bootstrap context\n").concat("  (`JsonValue` collides with `bootstrap/json.glide`).\n").concat("- Prefer the method form (`v.push(x)`) over the free fn\n").concat("  form (`push(v, x)`) — matches `stdlib::*` conventions.\n").concat("\n").concat("## 5. Lints (compiler-enforced patterns)\n").concat("\n").concat("`glide lint <file>` and the LSP run these checks. Each fires\n").concat("a lint code that `@allow(\"<code>\")` on the enclosing fn or\n").concat("impl method silences. Don't suppress without a justification\n").concat("in a comment — the lint usually points at a real bug.\n").concat("\n").concat("- `null-deref` — using `*p` / `p.field` / `p[i]` where `p` is\n").concat("  provably null (let-bound, or callee param dereferenced\n").concat("  without an `if p == null` guard).\n").concat("- `bad-free` — never `free()` on a Glide `string`, `*Vector`,\n").concat("  or `*HashMap`. Strings are arena-managed; collections have\n").concat("  `.free()` destructors that release internal buffers first.\n").concat("- `unhandled-result` — calling a `!T`-returning fn and\n").concat("  discarding the value silently swallows the error. Use\n").concat("  `f(...)?`, `let _ = f(...)`, or `let bound = f(...)`.\n").concat("- `ignored-option` — `.val` on a `?T` without a preceding\n").concat("  `is_some()` / `.has` guard reads UB on the none branch.\n").concat("- `use-after-free` — accessing `x` after `x.free()` in the\n").concat("  same scope is a dangling-pointer read.\n").concat("- `arena-set` — `__glide_palloc_set(arena)` without a paired\n").concat("  `defer __glide_palloc_set(prev);` leaks the arena bracket.\n").concat("- `coro-blocking` — calling sync I/O (`fs_read`, `process_run`,\n").concat("  etc.) inside a `spawn fn();` stalls the M:N worker. Switch\n").concat("  to `spawn_thread` or the async variant.\n").concat("- `mutex-unbalanced` — every `.lock()` needs `.unlock()` on\n").concat("  every exit (return / `?` / break / continue / fall-through).\n").concat("  The idiom is `m.lock(); defer m.unlock();` right after.\n").concat("- `chan-leak` — channels missing `close()` on any path will\n").concat("  leave receivers parked forever on `recv()`.\n").concat("- `leak-on-early-return` — register `defer x.free();`\n").concat("  IMMEDIATELY after the allocation, never after a `?`.\n").concat("\n").concat("Patterns to follow as default form:\n").concat("\n").concat("```glide\n").concat("// open a coro-arena bracket\n").concat("let prev: *void = __glide_palloc_get();\n").concat("__glide_palloc_set(__glide_palloc_make());\n").concat("defer __glide_palloc_set(prev);\n").concat("defer __glide_palloc_free(__glide_palloc_get());\n").concat("\n").concat("// allocation + cleanup\n").concat("let v: *Vector<i32> = Vector::new();\n").concat("defer v.free();\n").concat("\n").concat("// mutex\n").concat("m.lock();\n").concat("defer m.unlock();\n").concat("\n").concat("// fallible call\n").concat("let x: i32 = parse(s)?;\n").concat("\n").concat("// option unwrap with check\n").concat("let r: ?i32 = lookup(k);\n").concat("if !r.has { return err(\"missing\"); }\n").concat("let v: i32 = r.val;\n").concat("```\n").concat("\n").concat("## 6. Tool-specific notes\n").concat("\n").concat("- **Claude Code / Codex**: this file loads automatically.\n").concat("- **Cursor**: also reads `AGENTS.md`; for older versions,\n").concat("  copy this file to `.cursorrules`.\n").concat("- **Continue / Aider / others**: point your config at this\n").concat("  file or copy its contents into the tool's rules file.\n").concat("\n").concat("---\n").concat("\n").concat("_This file is auto-generated by `glide doc --ai` only when it\n").concat("doesn't already exist. Subsequent runs leave your customisations\n").concat("alone; the `build/doc/llms.txt` reference is regenerated every\n").concat("time._\n");
    write_file(path, body);
}

// Emit a flat plain-text summary intended for LLM ingestion. Follows
// the llmstxt.org shape: each module is an `## <module>` heading,
// every pub item gets a `### <kind> <signature>` subheading followed
// by its raw docstring. No HTML, no escaping — assistants pasted
// these into a chat get the full surface area in tokens cheaply.
fn _write_llms_txt(path: string, modules: *Vector<DocModule>) {
    let mut out: string = "# Glide API reference (LLM ingest)\n\n".concat("Auto-generated from `///` doc comments by `glide doc --ai`.\n").concat("Each module section lists its `pub` items in source order with\n").concat("the signature on one line and the raw docstring (markdown)\n").concat("immediately after.\n\n");
    for let i: i32 = 0; i < modules.len(); i++ {
        let m: DocModule = modules.get(i);
        out = out.concat("## ").concat(m.display).concat("\n");
        out = out.concat("source: ").concat(m.origin).concat("\n");
        if !m.package.eq("") && !m.package.eq("project") {
            out = out.concat("package: ").concat(m.package).concat("\n");
        }
        if !m.pkg_repo.eq("") {
            out = out.concat("repository: ").concat(m.pkg_repo).concat("\n");
        }
        if !m.blurb.eq("") {
            out = out.concat("\n").concat(m.blurb).concat("\n");
        }
        out = out.concat("\n");
        for let j: i32 = 0; j < m.items.len(); j++ {
            let it: DocItem = m.items.get(j);
            out = out.concat("### ").concat(_kind_label(it.kind)).concat(" ").concat(it.signature).concat("\n");
            if !it.doc.eq("") {
                out = out.concat(it.doc).concat("\n");
            }
            out = out.concat("\n");
        }
    }
    write_file(path, out);
}

// Find the `src/` directory that holds the bundled `stdlib/` tree.
// Same probe `bootstrap/lsp.glide` uses for its stdlib index: prefer
// the installed-binary layout (`<exe>/src/stdlib/...`), fall back to
// running inside a source checkout (`./src/stdlib/...`).
fn _find_stdlib_src_root() -> string {
    let exe_dir: string = __glide_exe_dir();
    if !exe_dir.eq("") {
        let probe: string = exe_dir.concat("/src/stdlib/hashmap.glide");
        if __glide_file_exists(probe) {
            return exe_dir.concat("/src");
        }
    }
    if __glide_file_exists("src/stdlib/hashmap.glide") {
        return "src";
    }
    return "";
}

extern fn __glide_exe_dir() -> string;

fn _scan_file(path: string, root: string) -> *DocModule {
    let src: string = read_file(path);
    if src.eq("") {
        return null;
    }
    let lex: *Lexer = Lexer::new(src);
    let p: *Parser = Parser::new(lex);
    let parsed: *Vector<Stmt> = parse_program(p);
    let items_vec: *Vector<DocItem> = Vector::new();
    let m: *DocModule = __glide_palloc(sizeof(DocModule)) as *DocModule;
    m.origin = path;
    m.display = _module_display(path, root);
    m.slug = _slug(m.display);
    m.items = items_vec;
    m.blurb = "";
    m.package = "project";
    m.pkg_repo = "";
    m.pkg_desc = "";
    m.pkg_ver = "";
    for let i: i32 = 0; i < parsed.len(); i++ {
        let s: Stmt = parsed.get(i);
        if !s.is_pub {
            continue;
        }
        let kind: i32 = _stmt_kind_to_doc(s.kind);
        if kind == 0 {
            continue;
        }
        let doc: string = _strip_triple_slash(s.doc_comment);
        let sig: string = _signature(&s);
        let it: DocItem;
        it.kind = kind;
        it.name = s.name;
        it.signature = sig;
        it.doc = doc;
        it.line = s.line;
        items_vec.push(it);
        if m.blurb.eq("") {
            m.blurb = _first_line(doc);
        }
    }
    return m;
}

// 1=fn, 2=struct, 3=enum, 4=const, 5=trait, 7=macro. impl blocks
// (ST_IMPL=6) are visited at the file level but their methods are
// not surfaced — the methods live inside the type's own page.
fn _stmt_kind_to_doc(k: i32) -> i32 {
    if k == ST_FN {
        return 1;
    }
    if k == ST_STRUCT {
        return 2;
    }
    if k == ST_ENUM {
        return 3;
    }
    if k == ST_CONST {
        return 4;
    }
    if k == ST_TRAIT {
        return 5;
    }
    if k == ST_MACRO_DEF {
        return 7;
    }
    return 0;
}

fn _signature(s: *Stmt) -> string {
    if s.kind == ST_FN {
        return _fn_signature(s);
    }
    if s.kind == ST_STRUCT {
        return "struct ".concat(s.name);
    }
    if s.kind == ST_ENUM {
        return "enum ".concat(s.name);
    }
    if s.kind == ST_CONST {
        let mut head: string = "const ".concat(s.name);
        if s.let_ty != null {
            head = head.concat(": ").concat(fmt_type(s.let_ty));
        }
        return head;
    }
    if s.kind == ST_TRAIT {
        return "trait ".concat(s.name);
    }
    if s.kind == ST_MACRO_DEF {
        return "macro ".concat(s.name).concat("!");
    }
    return s.name;
}

fn _fn_signature(s: *Stmt) -> string {
    let mut out: string = "fn ".concat(s.name).concat("(");
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            if i > 0 {
                out = out.concat(", ");
            }
            let p: Param = s.fn_params.get(i);
            out = out.concat(p.name).concat(": ").concat(fmt_type(p.ty));
        }
    }
    out = out.concat(")");
    if s.fn_ret_ty != null {
        out = out.concat(" -> ").concat(fmt_type(s.fn_ret_ty));
    }
    return out;
}

// Strip the `/// ` (or `///`) prefix from every line of `raw`.
fn _strip_triple_slash(raw: string) -> string {
    if raw == null || raw.eq("") {
        return "";
    }
    let lines: *Vector<string> = raw.split("\n");
    let mut out: string = "";
    for let i: i32 = 0; i < lines.len(); i++ {
        let mut ln: string = lines.get(i);
        let mut k: i32 = 0;
        while k < ln.len() && ln.at(k).to_int() == 32 {
            k = k + 1;
        }
        if k + 3 <= ln.len() && ln.at(k).to_int() == 47 && ln.at(k + 1).to_int() == 47 && ln.at(k + 2).to_int() == 47 {
            let after: i32 = k + 3;
            let mut start: i32 = after;
            if start < ln.len() && ln.at(start).to_int() == 32 {
                start = start + 1;
            }
            ln = ln.substring(start, ln.len());
        } else {
            if k + 2 <= ln.len() && ln.at(k).to_int() == 47 && ln.at(k + 1).to_int() == 47 {
                // Legacy `//` comments — keep as plain text.
                ln = ln.substring(k + 2, ln.len());
                if ln.len() > 0 && ln.at(0).to_int() == 32 {
                    ln = ln.substring(1, ln.len());
                }
            }
        }
        if i > 0 {
            out = out.concat("\n");
        }
        out = out.concat(ln);
    }
    return out;
}

fn _first_line(doc: string) -> string {
    if doc.eq("") {
        return "";
    }
    let lines: *Vector<string> = doc.split("\n");
    for let i: i32 = 0; i < lines.len(); i++ {
        let ln: string = lines.get(i).trim();
        if !ln.eq("") {
            return ln;
        }
    }
    return "";
}

// Convert e.g. "src/stdlib/json.glide" -> "stdlib::json".
fn _module_display(path: string, root: string) -> string {
    let mut rel: string = path;
    let r: string = root.concat("/");
    if rel.starts_with(r) {
        rel = rel.substring(r.len(), rel.len());
    }
    if rel.starts_with("src/") {
        rel = rel.substring(4, rel.len());
    }
    if rel.len() > 6 && rel.substring(rel.len() - 6, rel.len()).eq(".glide") {
        rel = rel.substring(0, rel.len() - 6);
    }
    let mut out: string = "";
    for let i: i32 = 0; i < rel.len(); i++ {
        let c: i32 = rel.at(i).to_int();
        if c == 47 || c == 92 {
            out = out.concat("::");
        } else {
            out = out.concat(rel.substring(i, i + 1));
        }
    }
    return out;
}

fn _slug(display: string) -> string {
    let mut out: string = "";
    for let i: i32 = 0; i < display.len(); i++ {
        let c: i32 = display.at(i).to_int();
        if c == 58 {
            // Collapse `::` into `_` once.
            if i + 1 < display.len() && display.at(i + 1).to_int() == 58 {
                out = out.concat("_");
                i = i + 1;
            }
        } else {
            out = out.concat(display.substring(i, i + 1));
        }
    }
    return out;
}

fn _ends_with(s: string, suffix: string) -> bool {
    if suffix.len() > s.len() {
        return false;
    }
    return s.substring(s.len() - suffix.len(), s.len()).eq(suffix);
}

// True when `seg` appears between path separators in `path` (or at one
// of its ends). Lets the doc walker filter out build output + dep mirrors
// (`<root>/build/deps/...`) and `tests/` trees without false hits
// on names that happen to contain the same substring.
fn _contains_segment(path: string, seg: string) -> bool {
    if path == null || seg == null || seg.eq("") {
        return false;
    }
    let n: i32 = path.len();
    let m: i32 = seg.len();
    if m > n {
        return false;
    }
    for let i: i32 = 0; i + m <= n; i++ {
        let mut hit: bool = true;
        for let j: i32 = 0; j < m; j++ {
            let a: i32 = path.at(i + j).to_int();
            let b: i32 = seg.at(j).to_int();
            if a != b {
                hit = false;
                break;
            }
        }
        if !hit {
            continue;
        }
        let before: i32 = if i == 0 { 47 } else { path.at(i - 1).to_int() };
        let after_idx: i32 = i + m;
        let after: i32 = if after_idx >= n { 47 } else { path.at(after_idx).to_int() };
        let lb: bool = before == 47 || before == 92;
        let la: bool = after == 47 || after == 92;
        if lb && la {
            return true;
        }
    }
    return false;
}

// HTML escape: `<` `>` `&` `"`.
fn _esc(s: string) -> string {
    let mut out: string = "";
    for let i: i32 = 0; i < s.len(); i++ {
        let c: i32 = s.at(i).to_int();
        if c == 60 {
            out = out.concat("&lt;");
        } else {
            if c == 62 {
                out = out.concat("&gt;");
            } else {
                if c == 38 {
                    out = out.concat("&amp;");
                } else {
                    if c == 34 {
                        out = out.concat("&quot;");
                    } else {
                        out = out.concat(s.substring(i, i + 1));
                    }
                }
            }
        }
    }
    return out;
}

// Tiny markdown renderer covering the Glide doc style:
//   - paragraphs separated by blank lines
//   - fenced code blocks: ```glide ... ```
//   - inline `code`
//   - leading `#` / `##` headings
fn _render_markdown(md: string) -> string {
    if md.eq("") {
        return "";
    }
    let lines: *Vector<string> = md.split("\n");
    let mut out: string = "";
    let mut in_code: bool = false;
    let mut code_lang: string = "";
    let mut code_buf: string = "";
    let mut para: string = "";
    for let i: i32 = 0; i < lines.len(); i++ {
        let raw: string = lines.get(i);
        let trimmed: string = raw.trim();
        if in_code {
            if trimmed.starts_with("```") {
                out = out.concat(_render_code_frame(code_lang, code_buf));
                in_code = false;
                code_buf = "";
                code_lang = "";
            } else {
                if !code_buf.eq("") {
                    code_buf = code_buf.concat("\n");
                }
                code_buf = code_buf.concat(raw);
            }
            continue;
        }
        if trimmed.starts_with("```") {
            if !para.eq("") {
                out = out.concat("<p>").concat(_inline_md(para)).concat("</p>\n");
                para = "";
            }
            code_lang = trimmed.substring(3, trimmed.len()).trim();
            in_code = true;
            continue;
        }
        if trimmed.eq("") {
            if !para.eq("") {
                out = out.concat("<p>").concat(_inline_md(para)).concat("</p>\n");
                para = "";
            }
            continue;
        }
        if trimmed.starts_with("# ") {
            if !para.eq("") {
                out = out.concat("<p>").concat(_inline_md(para)).concat("</p>\n");
                para = "";
            }
            out = out.concat("<h3>").concat(_inline_md(trimmed.substring(2, trimmed.len()))).concat("</h3>\n");
            continue;
        }
        if trimmed.starts_with("## ") {
            if !para.eq("") {
                out = out.concat("<p>").concat(_inline_md(para)).concat("</p>\n");
                para = "";
            }
            out = out.concat("<h4>").concat(_inline_md(trimmed.substring(3, trimmed.len()))).concat("</h4>\n");
            continue;
        }
        if !para.eq("") {
            para = para.concat(" ");
        }
        para = para.concat(trimmed);
    }
    if !para.eq("") {
        out = out.concat("<p>").concat(_inline_md(para)).concat("</p>\n");
    }
    if in_code {
        out = out.concat(_render_code_frame(code_lang, code_buf));
    }
    return out;
}

// Render a fenced code block as a windowed frame (title bar + 3 dots),
// running Glide-flavoured syntax highlighting when the language tag is
// empty, "glide", or absent. Anything else (e.g. ```bash) is escaped
// verbatim — keeping shell snippets readable without false highlights.
fn _render_code_frame(lang: string, code: string) -> string {
    let mut title: string = "glide";
    if !lang.eq("") {
        title = lang;
    }
    let mut body: string = "";
    if lang.eq("") || lang.eq("glide") {
        body = _highlight_glide(code);
    } else {
        body = _esc(code);
    }
    return "<div class=\"code-frame\">\n".concat("  <div class=\"code-frame-bar\">\n").concat("    <span class=\"dot\"></span><span class=\"dot\"></span><span class=\"dot\"></span>\n").concat("    <span class=\"code-frame-title\">").concat(_esc(title)).concat("</span>\n").concat("  </div>\n").concat("  <pre class=\"code\"><code>").concat(body).concat("</code></pre>\n").concat("</div>\n");
}

// Single-pass, byte-level highlighter. Walks the source emitting either
// `<span class="...">word</span>` for classified tokens or HTML-escaped
// passthroughs for everything else. Classification:
//   //...     -> .cmt   (line comments)
//   "..."     -> .str   (double-quoted, with `\` escape skip)
//   12 / 1.5  -> .num
//   identifier -> .kw / .ty / .fn  via `_classify_ident`
// We don't model nested expressions or string interpolation slots —
// good enough for the docstring snippets without dragging a real lexer in.
fn _highlight_glide(src: string) -> string {
    let mut out: string = "";
    let mut i: i32 = 0;
    let n: i32 = src.len();
    while i < n {
        let c: i32 = src.at(i).to_int();
        // Line comment: `//` ... EOL
        if c == 47 && i + 1 < n && src.at(i + 1).to_int() == 47 {
            let mut j: i32 = i;
            while j < n && src.at(j).to_int() != 10 {
                j = j + 1;
            }
            out = out.concat("<span class=\"cmt\">").concat(_esc(src.substring(i, j))).concat("</span>");
            i = j;
            continue;
        }
        // String literal — naive: skips one char after `\`.
        if c == 34 {
            let mut j: i32 = i + 1;
            while j < n {
                let cj: i32 = src.at(j).to_int();
                if cj == 92 && j + 1 < n {
                    j = j + 2;
                    continue;
                }
                if cj == 34 {
                    j = j + 1;
                    break;
                }
                j = j + 1;
            }
            out = out.concat("<span class=\"str\">").concat(_esc(src.substring(i, j))).concat("</span>");
            i = j;
            continue;
        }
        // Number
        if c >= 48 && c <= 57 {
            let mut j: i32 = i;
            while j < n {
                let cj: i32 = src.at(j).to_int();
                if cj >= 48 && cj <= 57 || cj == 46 || cj == 95 {
                    j = j + 1;
                } else {
                    break;
                }
            }
            out = out.concat("<span class=\"num\">").concat(src.substring(i, j)).concat("</span>");
            i = j;
            continue;
        }
        // Identifier (letter / underscore start)
        let is_id_start: bool = c >= 65 && c <= 90 || c >= 97 && c <= 122 || c == 95;
        if is_id_start {
            let mut j: i32 = i;
            while j < n {
                let cj: i32 = src.at(j).to_int();
                let cont: bool = cj >= 65 && cj <= 90 || cj >= 97 && cj <= 122 || cj >= 48 && cj <= 57 || cj == 95;
                if cont {
                    j = j + 1;
                } else {
                    break;
                }
            }
            let word: string = src.substring(i, j);
            let cls: string = _classify_ident(word, src, j, n);
            if !cls.eq("") {
                out = out.concat("<span class=\"").concat(cls).concat("\">").concat(word).concat("</span>");
            } else {
                out = out.concat(word);
            }
            i = j;
            continue;
        }
        // Anything else: escape and emit one char.
        out = out.concat(_esc(src.substring(i, i + 1)));
        i = i + 1;
    }
    return out;
}

fn _classify_ident(word: string, src: string, j: i32, n: i32) -> string {
    if _is_kw_word(word) {
        return "kw";
    }
    if _is_ty_word(word) {
        return "ty";
    }
    // ident followed by `(` -> function call
    if j < n && src.at(j).to_int() == 40 {
        return "fn";
    }
    // Capitalised identifier — likely a struct / trait / enum.
    let c0: i32 = word.at(0).to_int();
    if c0 >= 65 && c0 <= 90 {
        return "ty";
    }
    return "";
}

fn _is_kw_word(w: string) -> bool {
    return w.eq("fn") || w.eq("let") || w.eq("mut") || w.eq("if") || w.eq("else") || w.eq("while") || w.eq("for") || w.eq("in") || w.eq("return") || w.eq("spawn") || w.eq("spawn_thread") || w.eq("defer") || w.eq("defer_err") || w.eq("import") || w.eq("pub") || w.eq("extern") || w.eq("struct") || w.eq("enum") || w.eq("trait") || w.eq("impl") || w.eq("match") || w.eq("break") || w.eq("continue") || w.eq("where") || w.eq("const") || w.eq("true") || w.eq("false") || w.eq("null") || w.eq("as") || w.eq("sizeof") || w.eq("self") || w.eq("Self") || w.eq("use") || w.eq("dyn") || w.eq("select") || w.eq("ok") || w.eq("err") || w.eq("some") || w.eq("none");
}

fn _is_ty_word(w: string) -> bool {
    return w.eq("int") || w.eq("bool") || w.eq("string") || w.eq("void") || w.eq("float") || w.eq("double") || w.eq("byte") || w.eq("char") || w.eq("i32") || w.eq("i64") || w.eq("u32") || w.eq("u64") || w.eq("chan");
}

// Inline markdown: just backtick → <code>. Escape everything else.
fn _inline_md(s: string) -> string {
    let mut out: string = "";
    let mut in_code: bool = false;
    let mut buf: string = "";
    for let i: i32 = 0; i < s.len(); i++ {
        let c: i32 = s.at(i).to_int();
        if c == 96 {
            if in_code {
                out = out.concat("<code>").concat(_esc(buf)).concat("</code>");
                buf = "";
                in_code = false;
            } else {
                out = out.concat(_esc(buf));
                buf = "";
                in_code = true;
            }
            continue;
        }
        buf = buf.concat(s.substring(i, i + 1));
    }
    if in_code {
        out = out.concat("`").concat(_esc(buf));
    } else {
        out = out.concat(_esc(buf));
    }
    return out;
}

fn _doc_css() -> string {
    return ":root{--bg:#0b1020;--bg-2:#0f1530;--panel:#121a36;--border:#1e2a5e;--border-soft:#1a2247;--text:#e7ecff;--text-dim:#a4adcf;--muted:#6b769d;--accent:#6b8afd;--accent-2:#3b5bdb;--kw:#c084fc;--fn:#8ab4ff;--ty:#5eead4;--str:#f5b76b;--num:#f08fb8;--cmt:#5b6794;--radius:10px;--radius-lg:14px;--container:1080px}\n".concat("*{box-sizing:border-box}\n").concat("html,body{margin:0;padding:0;background:var(--bg);color:var(--text);font-family:'Inter',system-ui,-apple-system,'Segoe UI',sans-serif;font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}\n").concat("body{background:radial-gradient(900px 480px at 80% -10%,rgba(59,91,219,0.18),transparent 60%),radial-gradient(700px 400px at -10% 20%,rgba(107,138,253,0.10),transparent 55%),var(--bg);min-height:100vh}\n").concat("a{color:var(--accent);text-decoration:none;transition:color 120ms ease}\n").concat("a:hover{color:#9bb0ff}\n").concat("code,pre{font-family:'JetBrains Mono',ui-monospace,'SF Mono',Menlo,Consolas,monospace;font-size:13.5px}\n").concat("h1,h2,h3,h4,h5{margin:0;letter-spacing:-0.02em;color:#f4f6ff;font-weight:600}\n").concat("p{margin:0 0 1em 0}p:last-child{margin-bottom:0}\n").concat(".nav{display:flex;align-items:center;justify-content:space-between;max-width:var(--container);margin:0 auto;padding:22px 28px}\n").concat(".brand{display:inline-flex;align-items:baseline;gap:8px;font-weight:600;font-size:18px;color:var(--text);letter-spacing:-0.02em}\n").concat(".brand:hover{color:var(--text)}\n").concat(".brand-sub{color:var(--muted);font-weight:400;font-size:14.5px;font-family:'JetBrains Mono',monospace}\n").concat(".nav-links{display:flex;align-items:center;gap:24px}\n").concat(".nav-links a{color:var(--text-dim);font-size:14.5px;font-weight:500}\n").concat(".nav-links a:hover{color:var(--text)}\n").concat("main{max-width:var(--container);margin:0 auto;padding:0 28px 80px}\n").concat(".hero{padding:40px 0 28px}\n").concat(".hero h1{font-size:clamp(28px,3.6vw,40px);line-height:1.1;letter-spacing:-0.03em;margin-bottom:12px}\n").concat(".hero .lede{color:var(--text-dim);font-size:16.5px;max-width:680px}\n").concat(".eyebrow{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:11.5px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent);padding:5px 10px;border:1px solid rgba(107,138,253,0.30);border-radius:999px;background:rgba(107,138,253,0.06);margin-bottom:18px}\n").concat(".back{display:inline-block;margin-bottom:14px;font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--text-dim)}\n").concat(".back:hover{color:var(--accent)}\n").concat(".origin{color:var(--muted);font-size:14px;margin-bottom:6px}\n").concat(".origin code{background:rgba(107,138,253,0.10);border:1px solid rgba(107,138,253,0.18);padding:1px 6px;border-radius:5px;color:#c4d0ff;font-size:12.5px}\n").concat(".pkg-group{margin:34px 0 0}\n").concat(".pkg-head{display:flex;flex-direction:column;gap:4px;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--border-soft)}\n").concat(".pkg-head h2{font-size:18px;letter-spacing:-0.01em;display:inline}\n").concat(".pkg-head .pkg-ver{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--muted);margin-left:8px}\n").concat(".pkg-head .pkg-desc{color:var(--text-dim);font-size:14px;margin:0}\n").concat(".pkg-head .pkg-repo{margin:0}\n").concat(".pkg-head .pkg-repo a{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--accent)}\n").concat(".modules{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-top:14px}\n").concat(".module-card{background:linear-gradient(180deg,rgba(30,42,94,0.30),rgba(15,21,48,0.55));border:1px solid var(--border-soft);border-radius:var(--radius-lg);padding:18px 20px;transition:border-color 160ms ease,transform 160ms ease}\n").concat(".module-card:hover{border-color:rgba(107,138,253,0.45);transform:translateY(-1px)}\n").concat(".module-card h3{font-size:15.5px;margin-bottom:6px;font-family:'JetBrains Mono',monospace;font-weight:600}\n").concat(".module-card h3 a{color:var(--text)}\n").concat(".module-card h3 a:hover{color:var(--accent)}\n").concat(".module-card .blurb{color:var(--text-dim);font-size:14px;margin-bottom:10px}\n").concat(".module-card .counts{color:var(--muted);font-size:12.5px;font-family:'JetBrains Mono',monospace;margin:0}\n").concat(".toc{background:linear-gradient(180deg,rgba(30,42,94,0.22),rgba(15,21,48,0.40));border:1px solid var(--border-soft);border-radius:var(--radius-lg);padding:16px 20px;margin:18px 0 30px}\n").concat(".toc h4{font-size:11.5px;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:12px;font-weight:600}\n").concat(".toc ul{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:repeat(2,1fr);gap:6px 18px}\n").concat(".toc li{font-family:'JetBrains Mono',monospace;font-size:13px;display:flex;align-items:baseline;gap:8px}\n").concat(".toc li a{color:var(--text-dim)}\n").concat(".toc li a:hover{color:var(--accent)}\n").concat(".toc li .toc-kind{display:inline-block;min-width:46px;color:var(--muted);font-size:11px;text-transform:lowercase}\n").concat(".items{display:flex;flex-direction:column;gap:22px}\n").concat(".item{background:linear-gradient(180deg,rgba(30,42,94,0.22),rgba(15,21,48,0.40));border:1px solid var(--border-soft);border-radius:var(--radius-lg);padding:22px 24px;scroll-margin-top:24px}\n").concat(".item-head{display:flex;align-items:baseline;gap:12px;margin-bottom:14px;flex-wrap:wrap}\n").concat(".kind{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:11.5px;font-weight:600;padding:3px 9px;border-radius:6px;background:rgba(107,138,253,0.10);border:1px solid rgba(107,138,253,0.22);color:var(--accent);text-transform:lowercase;letter-spacing:0.02em}\n").concat(".kind-struct{color:#5eead4;background:rgba(94,234,212,0.10);border-color:rgba(94,234,212,0.24)}\n").concat(".kind-trait{color:#c084fc;background:rgba(192,132,252,0.10);border-color:rgba(192,132,252,0.24)}\n").concat(".kind-enum{color:#f08fb8;background:rgba(240,143,184,0.10);border-color:rgba(240,143,184,0.24)}\n").concat(".kind-macro{color:#f5b76b;background:rgba(245,183,107,0.10);border-color:rgba(245,183,107,0.24)}\n").concat(".kind-const{color:#ffd166;background:rgba(255,209,102,0.10);border-color:rgba(255,209,102,0.24)}\n").concat(".sig{font-family:'JetBrains Mono',monospace;font-size:14px;color:#d8dfff;word-break:break-word}\n").concat(".doc{color:var(--text-dim);font-size:15px;line-height:1.65}\n").concat(".doc p{margin:0 0 10px 0}.doc p:last-child{margin-bottom:0}\n").concat(".doc h3,.doc h4{color:#f4f6ff;margin-top:16px;margin-bottom:8px;font-size:15px}\n").concat(".doc code{font-size:12.5px;background:rgba(107,138,253,0.12);border:1px solid rgba(107,138,253,0.18);padding:1px 6px;border-radius:5px;color:#c4d0ff}\n").concat(".code-frame{background:linear-gradient(180deg,#0f1633 0%,#0c1228 100%);border:1px solid var(--border-soft);border-radius:var(--radius);overflow:hidden;margin:10px 0 14px;box-shadow:0 1px 0 rgba(255,255,255,0.04) inset}\n").concat(".code-frame-bar{display:flex;align-items:center;gap:8px;padding:10px 14px;background:rgba(255,255,255,0.02);border-bottom:1px solid var(--border-soft)}\n").concat(".dot{width:9px;height:9px;border-radius:50%;background:#2a335a}\n").concat(".code-frame-title{margin-left:8px;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--muted)}\n").concat("pre.code{margin:0;padding:18px 20px;overflow-x:auto;background:transparent;color:#d8dfff;line-height:1.65;font-size:13px}\n").concat("pre.code code{background:transparent;padding:0;border:0;color:inherit;font-size:13px}\n").concat(".kw{color:var(--kw)}.fn{color:var(--fn)}.ty{color:var(--ty)}.str{color:var(--str)}.num{color:var(--num)}.cmt{color:var(--cmt);font-style:italic}\n").concat(".footer{border-top:1px solid var(--border-soft);background:rgba(8,12,30,0.4);margin-top:60px}\n").concat(".footer-row{max-width:var(--container);margin:0 auto;padding:24px 28px;display:flex;align-items:center;justify-content:space-between;color:var(--muted);font-size:13px;flex-wrap:wrap;gap:12px}\n").concat(".footer-row a{color:var(--muted)}.footer-row a:hover{color:var(--accent)}\n").concat(".footer-row code{background:rgba(107,138,253,0.10);border:1px solid rgba(107,138,253,0.18);padding:1px 6px;border-radius:5px;color:#c4d0ff;font-size:12px}\n").concat("@media (max-width:720px){.modules{grid-template-columns:1fr}.toc ul{grid-template-columns:1fr}main{padding:0 20px 60px}.nav-links{gap:14px}}\n");
}

fn _kind_label(kind: i32) -> string {
    if kind == 1 {
        return "fn";
    }
    if kind == 2 {
        return "struct";
    }
    if kind == 3 {
        return "enum";
    }
    if kind == 4 {
        return "const";
    }
    if kind == 5 {
        return "trait";
    }
    if kind == 7 {
        return "macro";
    }
    return "?";
}

fn _write_index(out_dir: string, modules: *Vector<DocModule>) {
    let mut total_items: i32 = 0;
    for let i: i32 = 0; i < modules.len(); i++ {
        total_items = total_items + modules.get(i).items.len();
    }
    let mut html: string = _html_head("API reference", ".");
    html = html.concat("<section class=\"hero\">\n").concat("  <div class=\"eyebrow\">api reference</div>\n").concat("  <h1>Glide modules</h1>\n").concat("  <p class=\"lede\">").concat(int_to_str(modules.len())).concat(" modules, ").concat(int_to_str(total_items)).concat(" public items. ").concat("Auto-generated from <code>///</code> doc comments — each card opens its own page.</p>\n").concat("</section>\n");
    // Walk packages in a stable order: project first, declared deps in
    // the order they appear in the manifest (preserved by `modules`'
    // insertion order), stdlib last.
    let groups: *Vector<string> = Vector::new();
    let seen: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < modules.len(); i++ {
        let pkg: string = modules.get(i).package;
        if pkg.eq("") || seen.contains(pkg) {
            continue;
        }
        seen.insert(pkg, true);
        groups.push(pkg);
    }
    for let g: i32 = 0; g < groups.len(); g++ {
        let pkg: string = groups.get(g);
        // Pick the first module of this group so the group-level metadata
        // (repo/desc/version, captured during the scan) renders once.
        let mut head_idx: i32 = -1;
        for let i: i32 = 0; i < modules.len(); i++ {
            if modules.get(i).package.eq(pkg) {
                head_idx = i;
                break;
            }
        }
        if head_idx < 0 {
            continue;
        }
        let head: DocModule = modules.get(head_idx);
        html = html.concat("<section class=\"pkg-group\">\n");
        html = html.concat("  <header class=\"pkg-head\">\n");
        html = html.concat("    <h2>").concat(_esc(_pkg_title(pkg))).concat("</h2>\n");
        if !head.pkg_ver.eq("") {
            html = html.concat("    <span class=\"pkg-ver\">v").concat(_esc(head.pkg_ver)).concat("</span>\n");
        }
        if !head.pkg_desc.eq("") {
            html = html.concat("    <p class=\"pkg-desc\">").concat(_esc(head.pkg_desc)).concat("</p>\n");
        }
        if !head.pkg_repo.eq("") {
            let href: string = _repo_href(head.pkg_repo);
            html = html.concat("    <p class=\"pkg-repo\"><a href=\"").concat(_esc(href)).concat("\">").concat(_esc(head.pkg_repo)).concat("</a></p>\n");
        }
        html = html.concat("  </header>\n");
        html = html.concat("  <div class=\"modules\">\n");
        for let i: i32 = 0; i < modules.len(); i++ {
            let m: DocModule = modules.get(i);
            if !m.package.eq(pkg) {
                continue;
            }
            html = html.concat("    <article class=\"module-card\">\n");
            html = html.concat("      <h3><a href=\"").concat(m.slug).concat(".html\">").concat(_esc(m.display)).concat("</a></h3>\n");
            if !m.blurb.eq("") {
                html = html.concat("      <p class=\"blurb\">").concat(_esc(m.blurb)).concat("</p>\n");
            }
            html = html.concat("      <p class=\"counts\">").concat(int_to_str(m.items.len())).concat(" item");
            if m.items.len() != 1 {
                html = html.concat("s");
            }
            html = html.concat("</p>\n");
            html = html.concat("    </article>\n");
        }
        html = html.concat("  </div>\n");
        html = html.concat("</section>\n");
    }
    html = html.concat(_html_tail());
    write_file(out_dir.concat("/index.html"), html);
}

// Human-readable title for a package group on the index page.
fn _pkg_title(pkg: string) -> string {
    if pkg.eq("project") {
        return "Project";
    }
    if pkg.eq("stdlib") {
        return "Standard library";
    }
    return "Dep: ".concat(pkg);
}

// Build a clickable URL from a manifest `repository:` value. The
// manifest convention is bare `github.com/u/r`, but absolute http(s)
// URLs are passed through unchanged so users who write the full URL
// still get a working link.
fn _repo_href(repo: string) -> string {
    if repo == null || repo.eq("") {
        return "";
    }
    if repo.starts_with("http://") || repo.starts_with("https://") {
        return repo;
    }
    return "https://".concat(repo);
}

fn _write_module_page(out_dir: string, m: *DocModule) {
    let mut html: string = _html_head(m.display, ".");
    html = html.concat("<section class=\"hero\">\n").concat("  <a class=\"back\" href=\"index.html\">← all modules</a>\n").concat("  <div class=\"eyebrow\">module</div>\n").concat("  <h1>").concat(_esc(m.display)).concat("</h1>\n").concat("  <p class=\"origin\">defined in <code>").concat(_esc(m.origin)).concat("</code></p>\n");
    if !m.blurb.eq("") {
        html = html.concat("  <p class=\"lede\">").concat(_esc(m.blurb)).concat("</p>\n");
    }
    html = html.concat("</section>\n");
    if m.items.len() > 1 {
        html = html.concat("<nav class=\"toc\">\n").concat("  <h4>Items in this module</h4>\n").concat("  <ul>\n");
        for let i: i32 = 0; i < m.items.len(); i++ {
            let it: DocItem = m.items.get(i);
            html = html.concat("    <li><span class=\"toc-kind\">").concat(_kind_label(it.kind)).concat("</span><a href=\"#").concat(_esc(it.name)).concat("\">").concat(_esc(it.name)).concat("</a></li>\n");
        }
        html = html.concat("  </ul>\n</nav>\n");
    }
    html = html.concat("<section class=\"items\">\n");
    for let i: i32 = 0; i < m.items.len(); i++ {
        let it: DocItem = m.items.get(i);
        let klabel: string = _kind_label(it.kind);
        html = html.concat("  <article class=\"item\" id=\"").concat(_esc(it.name)).concat("\">\n");
        html = html.concat("    <div class=\"item-head\">\n");
        html = html.concat("      <span class=\"kind kind-").concat(klabel).concat("\">").concat(klabel).concat("</span>\n");
        html = html.concat("      <span class=\"sig\">").concat(_esc(it.signature)).concat("</span>\n");
        html = html.concat("    </div>\n");
        if !it.doc.eq("") {
            html = html.concat("    <div class=\"doc\">\n").concat(_render_markdown(it.doc)).concat("    </div>\n");
        }
        html = html.concat("  </article>\n");
    }
    html = html.concat("</section>\n");
    html = html.concat(_html_tail());
    write_file(out_dir.concat("/").concat(m.slug).concat(".html"), html);
}

fn _html_head(title: string, css_prefix: string) -> string {
    return "<!doctype html>\n<html lang=\"en\"><head>\n".concat("<meta charset=\"utf-8\">\n").concat("<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n").concat("<meta name=\"theme-color\" content=\"#0b1020\">\n").concat("<title>").concat(_esc(title)).concat(" — glide doc</title>\n").concat("<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n").concat("<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n").concat("<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap\" rel=\"stylesheet\">\n").concat("<link rel=\"stylesheet\" href=\"").concat(css_prefix).concat("/style.css\">\n").concat("</head><body>\n").concat("<header class=\"nav\">\n").concat("  <a class=\"brand\" href=\"index.html\"><span>glide</span><span class=\"brand-sub\">/ docs</span></a>\n").concat("  <nav class=\"nav-links\">\n").concat("    <a href=\"index.html\">Modules</a>\n").concat("    <a href=\"https://github.com/Murilinho145SG/Glide\" rel=\"noopener\">GitHub</a>\n").concat("  </nav>\n").concat("</header>\n").concat("<main>\n");
}

fn _html_tail() -> string {
    return "</main>\n".concat("<footer class=\"footer\">\n").concat("  <div class=\"footer-row\">\n").concat("    <span>generated by <code>glide doc</code></span>\n").concat("    <a href=\"https://github.com/Murilinho145SG/Glide\" rel=\"noopener\">github.com/Murilinho145SG/Glide</a>\n").concat("  </div>\n").concat("</footer>\n").concat("</body></html>\n");
}

// Glide's typer doesn't know how to mono `Vector::new()` for *DocModule
// in a struct-field-position init — pre-bind to a local, the same dance
// as `read_manifest` in manifest.glide.
fn _vec_modules() -> *Vector<DocModule> {
    let v: *Vector<DocModule> = Vector::new();
    return v;
}

extern fn __glide_shell(cmd: string) -> i32;

extern fn __glide_is_windows() -> i32;

fn _open_in_browser(path: string) {
    let mut cmd: string = "";
    if __glide_is_windows() != 0 {
        cmd = "cmd /c start \"\" \"".concat(path).concat("\"");
    } else {
        // xdg-open works on Linux, open works on macOS — try both.
        cmd = "xdg-open \"".concat(path).concat("\" 2>/dev/null || open \"").concat(path).concat("\" 2>/dev/null");
    }
    __glide_shell(cmd);
}

// ---- tiny built-in HTTP server (for `glide doc --serve`) ----------------
//
// Single-threaded BSD sockets in c_raw — bootstrap can't import
// stdlib::http (json typedef collision) and the project doesn't have
// a server-side primitive in stdlib::net. ~140 lines of C is cheaper
// than untangling that.
extern fn __glide_doc_serve(dir: string, port: i32) -> i32;

c_raw! {
    #include <stdio.h>
    #include <stdlib.h>
    #include <string.h>
    #ifdef _WIN32
    #include <winsock2.h>
    #include <ws2tcpip.h>
    typedef SOCKET __doc_sock;
    #define __DOC_INVALID INVALID_SOCKET
    #define __doc_close closesocket
    static int __doc_sock_init(void) {
        WSADATA wsa;
        return WSAStartup(MAKEWORD(2, 2), &wsa);
    }
    #else
    #include <sys/socket.h>
    #include <netinet/in.h>
    #include <arpa/inet.h>
    #include <unistd.h>
    typedef int __doc_sock;
    #define __DOC_INVALID (-1)
    #define __doc_close close
    static int __doc_sock_init(void) { return 0; }
    #endif

    static const char* __doc_mime(const char* path) {
        const char* d = strrchr(path, '.');
        if (!d) return "text/plain; charset=utf-8";
        if (!strcmp(d, ".html")) return "text/html; charset=utf-8";
        if (!strcmp(d, ".htm"))  return "text/html; charset=utf-8";
        if (!strcmp(d, ".css"))  return "text/css; charset=utf-8";
        if (!strcmp(d, ".js"))   return "application/javascript; charset=utf-8";
        if (!strcmp(d, ".json")) return "application/json; charset=utf-8";
        if (!strcmp(d, ".svg"))  return "image/svg+xml";
        if (!strcmp(d, ".png"))  return "image/png";
        if (!strcmp(d, ".jpg"))  return "image/jpeg";
        if (!strcmp(d, ".jpeg")) return "image/jpeg";
        return "text/plain; charset=utf-8";
    }

    // Reject `..` segments and absolute paths so a curl can't escape
    // the serve root via `/etc/passwd` style traversal.
    static int __doc_safe_path(const char* uri) {
        if (uri[0] != '/') return 0;
        if (strstr(uri, "..")) return 0;
        return 1;
    }

    static void __doc_reply_404(__doc_sock cs) {
        const char* body = "404 not found";
        char hdr[256];
        int n = snprintf(hdr, sizeof(hdr),
            "HTTP/1.1 404 Not Found\r\nContent-Type: text/plain\r\nContent-Length: %d\r\nConnection: close\r\n\r\n",
            (int)strlen(body));
        send(cs, hdr, n, 0);
        send(cs, body, (int)strlen(body), 0);
    }

    int __glide_doc_serve(const char* dir, int port) {
        if (__doc_sock_init() != 0) return 1;
        __doc_sock ls = socket(AF_INET, SOCK_STREAM, 0);
        if (ls == __DOC_INVALID) return 1;
        int yes = 1;
        setsockopt(ls, SOL_SOCKET, SO_REUSEADDR, (const char*)&yes, sizeof(yes));
        struct sockaddr_in addr;
        memset(&addr, 0, sizeof(addr));
        addr.sin_family = AF_INET;
        addr.sin_port = htons((unsigned short)port);
        addr.sin_addr.s_addr = htonl(INADDR_LOOPBACK);
        if (bind(ls, (struct sockaddr*)&addr, sizeof(addr)) != 0) {
            __doc_close(ls);
            return 1;
        }
        if (listen(ls, 16) != 0) {
            __doc_close(ls);
            return 1;
        }
        fprintf(stderr, "doc: serving %s on http://127.0.0.1:%d/  (Ctrl-C to stop)\n", dir, port);
        fflush(stderr);
        char req[4096];
        char path[2048];
        char fbuf[8192];
        for (;;) {
            struct sockaddr_in caddr;
            #ifdef _WIN32
            int clen = sizeof(caddr);
            #else
            socklen_t clen = sizeof(caddr);
            #endif
            __doc_sock cs = accept(ls, (struct sockaddr*)&caddr, &clen);
            if (cs == __DOC_INVALID) continue;
            int got = recv(cs, req, sizeof(req) - 1, 0);
            if (got <= 0) { __doc_close(cs); continue; }
            req[got] = 0;
            // Parse the request line: `GET <uri> HTTP/1.x`.
            if (strncmp(req, "GET ", 4) != 0) { __doc_close(cs); continue; }
            char* uri = req + 4;
            char* sp = strchr(uri, ' ');
            if (sp) *sp = 0;
            // Strip the optional query string.
            char* q = strchr(uri, '?');
            if (q) *q = 0;
            if (!__doc_safe_path(uri)) { __doc_reply_404(cs); __doc_close(cs); continue; }
            // Map `/` → `index.html`. Otherwise join dir + uri.
            if (uri[0] == '/' && uri[1] == 0) uri = "/index.html";
            snprintf(path, sizeof(path), "%s%s", dir, uri);
            FILE* f = fopen(path, "rb");
            if (!f) { __doc_reply_404(cs); __doc_close(cs); continue; }
            fseek(f, 0, SEEK_END);
            long size = ftell(f);
            fseek(f, 0, SEEK_SET);
            char hdr[512];
            int hn = snprintf(hdr, sizeof(hdr),
                "HTTP/1.1 200 OK\r\nContent-Type: %s\r\nContent-Length: %ld\r\nConnection: close\r\n\r\n",
                __doc_mime(path), size);
            send(cs, hdr, hn, 0);
            while (size > 0) {
                size_t want = size > (long)sizeof(fbuf) ? sizeof(fbuf) : (size_t)size;
                size_t r = fread(fbuf, 1, want, f);
                if (r == 0) break;
                send(cs, fbuf, (int)r, 0);
                size -= r;
            }
            fclose(f);
            __doc_close(cs);
        }
        __doc_close(ls);
        return 0;
    }
}

pub fn doc_serve(dir: string, port: i32) -> i32 {
    return __glide_doc_serve(dir, port);
}
