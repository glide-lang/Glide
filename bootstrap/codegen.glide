// Codegen — AST to C99. Final stage of the pipeline.
//
// Emits a single self-contained translation unit:
//   1. runtime prelude (chan, sched, result template) — substituted from
//      bootstrap/runtime/*.tmpl with `@T@` / `@TC@` / `@M@` placeholders
//      replaced by per-monomorphization names.
//   2. forward declarations for every type the program reaches.
//   3. struct bodies, trait vtables, dyn fat-pointer typedefs.
//   4. function bodies (monomorphized over generic args) with a Glide-named
//      mangling scheme (`Type_method`, `Type_method__T_int`).
//
// Generic monomorphization is driven on demand: a call site with concrete
// type args triggers emission of a dedicated function. Same for any impl
// touched through `*dyn Trait` (a thunk + vtable entry per impl). The
// emitter is a string builder, not an IR — no SSA, no register allocation.
// The downstream C compiler (zig cc / mingw / cl) does the heavy lifting.

import stdlib::hashmap::*;
import ast;

// Naïve string-replace: walk through `s`, copying bytes verbatim except where
// `find` matches — there we splice in `repl` and skip ahead. Used by the
// templated runtime emitters (chan, result) to substitute `@M@` / `@TC@`
// placeholders at codegen time. O(N*M) but only runs a handful of times per
// compile, on ~250-line templates, so the simple algorithm is fine.
// Locate `::` inside a method name encoded by the parser as `NS::method` (used
// for qualified method calls like `s.cores::red()`). Returns the byte index of
// the first `:` of the separator, or -1 if absent. Plain method names (no `::`)
// are the common case and exit fast.
// `c_safe_ident` mangles user-supplied identifier names that would collide
// with C keywords. Applied at every emit site where a Glide ident reaches
// the C output (let bindings, fn params, EX_IDENT references, for-loop
// counters, match-arm payload bindings, struct field decl/access, struct
// literal field designators, top-level const, fn name, struct/enum typedef
// name). The mangling prefix is `_g_`. Glide-side scope tracking still
// uses the original name; only the C-emit side mangles.
//
// Covers C99 + GCC's `asm`. Glide-keywords already collide before reaching
// the value namespace (lexer emits TOK_KEYWORD), so we don't have to mangle
// `if`/`while`/`for`/etc here.
pub fn is_c_reserved(s: string) -> bool {
    if s.eq("asm") { return true; }
    if s.eq("auto") { return true; }
    if s.eq("case") { return true; }
    if s.eq("char") { return true; }
    if s.eq("default") { return true; }
    if s.eq("do") { return true; }
    if s.eq("double") { return true; }
    if s.eq("float") { return true; }
    if s.eq("goto") { return true; }
    if s.eq("inline") { return true; }
    if s.eq("int") { return true; }
    if s.eq("long") { return true; }
    if s.eq("register") { return true; }
    if s.eq("restrict") { return true; }
    if s.eq("short") { return true; }
    if s.eq("signed") { return true; }
    if s.eq("static") { return true; }
    if s.eq("switch") { return true; }
    if s.eq("typedef") { return true; }
    if s.eq("union") { return true; }
    if s.eq("unsigned") { return true; }
    if s.eq("void") { return true; }
    // stdio.h macros that lower-case Glide users may pick as ident/field
    // names (e.g. ProcessResult.stdout). They expand to function calls in C
    // and break compilation if not mangled.
    if s.eq("stdin") { return true; }
    if s.eq("stdout") { return true; }
    if s.eq("stderr") { return true; }
    return false;
}

pub fn c_safe_ident(name: string) -> string {
    if is_c_reserved(name) { return "_g_".concat(name); }
    return name;
}

fn ns_split_pos(name: string) -> i32 {
    let n: i32 = name.len();
    let mut i: i32 = 0;
    while i + 1 < n {
        if name.at(i).to_int() == 58 && name.at(i + 1).to_int() == 58 {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn _cg_replace(s: string, find: string, repl: string) -> string {
    let n: i32 = s.len();
    let m: i32 = find.len();
    if m == 0 { return s; }
    let mut out: string = "";
    let mut i: i32 = 0;
    while i < n {
        let mut matched: bool = (i + m <= n);
        if matched {
            for let k: i32 = 0; k < m; k++ {
                if s.at(i + k).to_int() != find.at(k).to_int() { matched = false; break; }
            }
        }
        if matched {
            out = out.concat(repl);
            i = i + m;
        } else {
            out = out.concat(s.substring(i, i + 1));
            i = i + 1;
        }
    }
    return out;
}

// Emit a chan-method receiver with `deref_n` leading `*`s. Used by
// the `.send` / `.recv` / `.close` method shim so a `*chan<T>` arg
// passes the inner chan pointer to the helper instead of a
// pointer-to-chan-pointer.
fn _emit_chan_recv(g: *CG, e: *Expr, deref_n: i32) {
    if deref_n <= 0 { emit_expr(g, e); return; }
    print!("(");
    for let i: i32 = 0; i < deref_n; i++ { print!("*"); }
    emit_expr(g, e);
    print!(")");
}

fn format_spec_for(t: *Type) -> string {
    if t == null { return "%p"; }
    if t.kind != TY_NAMED { return "%p"; }
    let n: string = t.name;
    if n.eq("int") || n.eq("i8") || n.eq("i16") || n.eq("i32") { return "%d"; }
    if n.eq("uint") || n.eq("u8") || n.eq("u16") || n.eq("u32") { return "%u"; }
    if n.eq("i64") || n.eq("isize") || n.eq("long") { return "%lld"; }
    if n.eq("u64") || n.eq("usize") || n.eq("ulong") { return "%llu"; }
    // 128-bit ints have no printf length modifier; the arg emit converts them
    // to a string via __glide_i128_to_string / __glide_u128_to_string.
    if n.eq("i128") || n.eq("u128") { return "%s"; }
    // 256-bit ints are software structs, printed via their to_string helper.
    if n.eq("i256") || n.eq("u256") { return "%s"; }
    if n.eq("float") || n.eq("f32") || n.eq("f64") { return "%g"; }
    if n.eq("char") { return "%c"; }
    if n.eq("string") { return "%s"; }
    if n.eq("bool") { return "%s"; }
    return "%p";
}

fn stdlib_method_ret(ty_name: string, method: string) -> *Type {
    if ty_name.eq("string") {
        if method.eq("len") { return ty_named("i32"); }
        if method.eq("eq") { return ty_named("bool"); }
        if method.eq("cmp") { return ty_named("i32"); }
        if method.eq("at") { return ty_named("char"); }
        if method.eq("concat") { return ty_named("string"); }
        if method.eq("substring") { return ty_named("string"); }
    }
    if ty_name.eq("char") {
        if method.eq("to_int") { return ty_named("i32"); }
        if method.eq("is_digit") { return ty_named("bool"); }
        if method.eq("is_alpha") { return ty_named("bool"); }
        if method.eq("to_string") { return ty_named("string"); }
    }
    if _is_int_family(ty_name) {
        // `abs` keeps the receiver's own width (i64.abs() -> i64); `to_string`
        // works on every int type now (codegen routes them all through the
        // 64-bit __glide_int_* runtime helpers).
        if method.eq("abs") { return ty_named(ty_name); }
        if method.eq("to_string") { return ty_named("string"); }
    }
    if ty_name.eq("u256") || ty_name.eq("i256") {
        if method.eq("abs") { return ty_named(ty_name); }
        if method.eq("to_string") { return ty_named("string"); }
    }
    if ty_name.eq("bool") {
        if method.eq("to_string") { return ty_named("string"); }
    }
    return null;
}

// Walk a stmt/expr tree, replacing every EX_FNEXPR with EX_IDENT pointing
// to a uniquely-named synthetic fn collected in g.anon_fns.
fn lift_anons_in_expr(g: *CG, e: *Expr) {
    if e == null { return; }
    if e.kind == EX_FNEXPR {
        // Lift the closure body too — it may contain nested closures whose
        // arg-position lifts (below) need to land before this fn is emitted.
        if e.fn_expr_body != null {
            for let i: i32 = 0; i < e.fn_expr_body.len(); i++ {
                let bs: Stmt = e.fn_expr_body.get(i);
                lift_anons_in_stmt(g, &bs);
                e.fn_expr_body.set(i, bs);
            }
        }
        let id: i32 = g.anon_count;
        g.anon_count = id + 1;
        let name: string = "__glide_anon_".concat(int_to_str(id));
        let af: AnonFn = AnonFn {
            name: name,
            params: e.fn_expr_params,
            ret_ty: e.cast_to,
            body: e.fn_expr_body,
        };
        g.anon_fns.push(af);
        // Mutate expr in place: become Ident with that name.
        e.kind = EX_IDENT;
        e.str_val = name;
        return;
    }
    if e.lhs != null { lift_anons_in_expr(g, e.lhs); }
    if e.rhs != null { lift_anons_in_expr(g, e.rhs); }
    if e.operand != null { lift_anons_in_expr(g, e.operand); }
    if e.args != null {
        // Vector::get returns a by-value copy, so the recursive lift mutates
        // a temporary. Write the (possibly rewritten) copy back so a closure
        // passed as `f(fn(x){...})` ends up as EX_IDENT in the original tree
        // and isn't lifted again by the expression-emit path (which would
        // bump anon_count past the forward-decl set).
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            lift_anons_in_expr(g, &a);
            e.args.set(i, a);
        }
    }
}

fn lift_anons_in_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.let_value != null { lift_anons_in_expr(g, s.let_value); }
    if s.expr_value != null { lift_anons_in_expr(g, s.expr_value); }
    if s.cond != null { lift_anons_in_expr(g, s.cond); }
    if s.for_init != null { lift_anons_in_stmt(g, s.for_init); }
    if s.for_step != null { lift_anons_in_expr(g, s.for_step); }
    // Vector::get returns a by-value copy; write back so lifts inside nested
    // blocks / fn bodies actually persist in the AST. Without the set-back
    // the expression-emit path lifts the closure a second time with a fresh
    // id, beating the forward-decl pre-pass.
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            lift_anons_in_stmt(g, &b);
            s.then_body.set(i, b);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            lift_anons_in_stmt(g, &b);
            s.else_body.set(i, b);
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            lift_anons_in_stmt(g, &b);
            s.fn_body.set(i, b);
        }
    }
    if s.impl_methods != null {
        for let i: i32 = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            lift_anons_in_stmt(g, &m);
            s.impl_methods.set(i, m);
        }
    }
}

// ---- Errors-as-values: collect + emit per-T runtime ---------------------

// Walk a type tree post-substitution, resolving any TY_ASSOC whose owner
// became concrete during mono. Leaves still-generic types intact.
fn resolve_assoc_recursive(g: *CG, t: *Type) -> *Type {
    if t == null { return null; }
    if t.kind == TY_ASSOC {
        let r: *Type = resolve_concrete_assoc(g, t);
        if r != null { return r; }
        return t;
    }
    if t.kind == TY_OPTION { return ty_option(resolve_assoc_recursive(g, t.inner)); }
    if t.kind == TY_RESULT { return ty_result(resolve_assoc_recursive(g, t.inner)); }
    if t.kind == TY_OPT_RESULT { return ty_optres(resolve_assoc_recursive(g, t.inner)); }
    if t.kind == TY_POINTER { return ty_pointer(resolve_assoc_recursive(g, t.inner)); }
    if t.kind == TY_BORROW {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW; p.inner = resolve_assoc_recursive(g, t.inner);
        return p;
    }
    if t.kind == TY_BORROW_MUT {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW_MUT; p.inner = resolve_assoc_recursive(g, t.inner);
        return p;
    }
    if t.kind == TY_SLICE {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_SLICE; p.inner = resolve_assoc_recursive(g, t.inner);
        return p;
    }
    return t;
}

// If `t` is `TY_ASSOC` with a concrete owner, look up the impl in any
// trait/assoc map whose key suffix matches `<owner>::<name>`. Returns the
// resolved type, or null if no match. Walks impl_trait_name keys via a
// linear scan since assoc_table is keyed by trait, but we don't always
// know the trait (TY_ASSOC carries owner + name only).
fn resolve_concrete_assoc(g: *CG, t: *Type) -> *Type {
    if t == null { return null; }
    if t.kind != TY_ASSOC { return null; }
    if t.inner == null { return null; }
    let mut owner_name: string = "";
    if t.inner.kind == TY_NAMED   { owner_name = t.inner.name; }
    if t.inner.kind == TY_GENERIC { owner_name = t.inner.name; }
    if owner_name.eq("") { return null; }
    // Linear scan: try every trait registered in assoc_table.
    let keys: *Vector<string> = g.assoc_table.keys();
    for let i: i32 = 0; i < keys.len(); i++ {
        let k: string = keys.get(i);
        // Key shape is `<Trait>::<Owner>::<Name>`. Match suffix.
        let suffix: string = "::".concat(owner_name).concat("::").concat(t.name);
        if k.len() < suffix.len() { continue; }
        let tail: string = k.substring(k.len() - suffix.len(), k.len());
        if !tail.eq(suffix) { continue; }
        let resolved: Type = g.assoc_table.get(k);
        let p: *Type = malloc(sizeof(Type)) as *Type;
        *p = resolved;
        return p;
    }
    return null;
}

// Walk a type, emitting `typedef struct mangled mangled;` forward
// declarations AND the full body for any TY_GENERIC encountered.
// Lets result/option/optres struct typedefs that wrap a
// `*Vector<X>`-style pointer reference the mangled tag, with the
// body in scope so users that store the value (not pointer) work too.
//
// Skips `chan<T>` — the channel runtime emits its own
// `__glide_chan_T_t` typedef and a stray `chan__T` here would just
// shadow the real one without ever being referenced.
fn forward_decl_generic_monos(g: *CG, t: *Type) {
    if t == null { return; }
    if t.kind == TY_GENERIC && t.name != null && t.args != null
       && !t.name.eq("chan") {
        let mangled: string = mangle_generic(t.name, t.args);
        if !g.emitted_monos.contains(mangled) {
            g.emitted_monos.insert(mangled, true);
            println!("typedef struct ", mangled, " ", mangled, ";");
            emit_struct_mono(g, t);
        }
    }
    if t.inner != null { forward_decl_generic_monos(g, t.inner); }
    if t.fnptr_ret != null { forward_decl_generic_monos(g, t.fnptr_ret); }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            forward_decl_generic_monos(g, &a);
        }
    }
}

// Walk every field type of `s` (a concrete struct stmt) and emit the
// forward typedef + body of any generic mono referenced. Used by the
// result/option/optres pre-passes so a struct wrapped in `!T` / `?T`
// can mention `*HashMap<X>` / `*Vector<X>` as a field type without the
// body referencing an as-yet-undeclared mangled tag.
//
// Also emits the option/result/optres runtime templates for any
// wrapper field types whose inner type is already defined (primitives
// or already-emitted structs). The templates' include guards make
// re-emission later harmless. Same chicken-and-egg as the generic
// monos: if the struct holds `?int`, the body needs `__glide_option_int_t`
// which is otherwise emitted only by the option pre-pass that runs
// AFTER the result pre-pass that triggered this struct emission.
fn _forward_decl_field_monos(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.struct_fields == null { return; }
    for let i: i32 = 0; i < s.struct_fields.len(); i++ {
        let f: Field = s.struct_fields.get(i);
        forward_decl_generic_monos(g, f.ty);
        _emit_wrapper_for_type(g, f.ty);
    }
}

// Emit the option/result/optres runtime template for `t` (and recurse
// into wrappers) when its inner type is already declared, so a field
// reference doesn't outpace its typedef. No-op for non-wrapper types
// or for wrapper-of-named-struct (the named body must come first; the
// guarded later emission picks it up).
fn _emit_wrapper_for_type(g: *CG, t: *Type) {
    if t == null { return; }
    if t.kind == TY_OPTION && t.inner != null && _is_primitive_or_emitted(g, t.inner) {
        _emit_option_template(g, t.inner);
    }
    if t.kind == TY_RESULT && t.inner != null && _is_primitive_or_emitted(g, t.inner) {
        _emit_result_template(g, t.inner);
    }
    if t.kind == TY_OPT_RESULT && t.inner != null && _is_primitive_or_emitted(g, t.inner) {
        _emit_optres_template(g, t.inner);
    }
    if t.inner != null { _emit_wrapper_for_type(g, t.inner); }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            _emit_wrapper_for_type(g, &a);
        }
    }
}

fn _is_primitive_or_emitted(g: *CG, t: *Type) -> bool {
    if t == null { return false; }
    if t.kind == TY_NAMED && t.name != null {
        let n: string = t.name;
        if n.eq("int") || n.eq("uint") || n.eq("long") || n.eq("ulong") { return true; }
        if n.eq("i8") || n.eq("i16") || n.eq("i32") || n.eq("i64") { return true; }
        if n.eq("u8") || n.eq("u16") || n.eq("u32") || n.eq("u64") { return true; }
        if n.eq("usize") || n.eq("isize") { return true; }
        if n.eq("f32") || n.eq("f64") || n.eq("float") { return true; }
        if n.eq("bool") || n.eq("char") || n.eq("string") || n.eq("void") { return true; }
        if g.emitted_named.contains(n) { return true; }
    }
    if t.kind == TY_POINTER { return true; }
    if t.kind == TY_GENERIC && t.name != null && t.args != null && !t.name.eq("chan") {
        let mangled: string = mangle_generic(t.name, t.args);
        return g.emitted_monos.contains(mangled);
    }
    return false;
}

fn _emit_option_template(g: *CG, inner: *Type) {
    let m: string = mangle_type(inner);
    let dedup_key: string = "__rt_option_emit_".concat(m);
    if g.module_aliases.contains(dedup_key) { return; }
    g.module_aliases.insert(dedup_key, "1");
    emit_tuple_typedefs_in_type(g, inner);
    let tc: string = type_to_c(inner);
    let tmpl: string = include_str!("bootstrap/runtime/option.c.tmpl");
    let s1: string = _cg_replace(tmpl, "@M@", m);
    let s2: string = _cg_replace(s1, "@TC@", tc);
    print!(s2);
    println!("");
    // Make the option pre-pass skip this entry — already done.
    let mut already: bool = false;
    for let i: i32 = 0; i < g.option_types.len(); i++ {
        let ex: Type = g.option_types.get(i);
        if mangle_type(&ex).eq(m) { already = true; break; }
    }
    if !already { g.option_types.push(*inner); }
}

fn _emit_result_template(g: *CG, inner: *Type) {
    let m: string = mangle_type(inner);
    let dedup_key: string = "__rt_result_emit_".concat(m);
    if g.module_aliases.contains(dedup_key) { return; }
    g.module_aliases.insert(dedup_key, "1");
    emit_tuple_typedefs_in_type(g, inner);
    let tc: string = type_to_c(inner);
    let tmpl: string = include_str!("bootstrap/runtime/result.c.tmpl");
    // `!void` uses a different template (no `val` field). Fall back to
    // emit_result_runtime by NOT emitting here; the later pass picks it up.
    if inner.kind == TY_NAMED && inner.name.eq("void") {
        g.module_aliases.remove(dedup_key);
        return;
    }
    let s1: string = _cg_replace(tmpl, "@M@", m);
    let s2: string = _cg_replace(s1, "@TC@", tc);
    print!(s2);
    println!("");
    let mut already: bool = false;
    for let i: i32 = 0; i < g.result_types.len(); i++ {
        let ex: Type = g.result_types.get(i);
        if mangle_type(&ex).eq(m) { already = true; break; }
    }
    if !already { g.result_types.push(*inner); }
}

fn _emit_optres_template(g: *CG, inner: *Type) {
    let m: string = mangle_type(inner);
    let dedup_key: string = "__rt_optres_emit_".concat(m);
    if g.module_aliases.contains(dedup_key) { return; }
    g.module_aliases.insert(dedup_key, "1");
    emit_tuple_typedefs_in_type(g, inner);
    let tc: string = type_to_c(inner);
    let tmpl: string = include_str!("bootstrap/runtime/optres.c.tmpl");
    let s1: string = _cg_replace(tmpl, "@M@", m);
    let s2: string = _cg_replace(s1, "@TC@", tc);
    print!(s2);
    println!("");
    let mut already: bool = false;
    for let i: i32 = 0; i < g.optres_types.len(); i++ {
        let ex: Type = g.optres_types.get(i);
        if mangle_type(&ex).eq(m) { already = true; break; }
    }
    if !already { g.optres_types.push(*inner); }
}

fn collect_result_in_type(g: *CG, t: *Type) {
    if t == null { return; }
    if t.kind == TY_RESULT && t.inner != null {
        let m: string = mangle_type(t.inner);
        for let i: i32 = 0; i < g.result_types.len(); i++ {
            let ex: Type = g.result_types.get(i);
            if mangle_type(&ex).eq(m) { return; }
        }
        g.result_types.push(*t.inner);
    }
    if t.kind == TY_OPTION && t.inner != null {
        let m: string = mangle_type(t.inner);
        for let i: i32 = 0; i < g.option_types.len(); i++ {
            let ex: Type = g.option_types.get(i);
            if mangle_type(&ex).eq(m) { return; }
        }
        g.option_types.push(*t.inner);
    }
    if t.kind == TY_OPT_RESULT && t.inner != null {
        let m: string = mangle_type(t.inner);
        for let i: i32 = 0; i < g.optres_types.len(); i++ {
            let ex: Type = g.optres_types.get(i);
            if mangle_type(&ex).eq(m) { return; }
        }
        g.optres_types.push(*t.inner);
    }
    if t.inner != null { collect_result_in_type(g, t.inner); }
    if t.fnptr_ret != null { collect_result_in_type(g, t.fnptr_ret); }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            collect_result_in_type(g, &a);
        }
    }
}

fn collect_result_in_expr(g: *CG, e: *Expr) {
    if e == null { return; }
    if e.cast_to != null { collect_result_in_type(g, e.cast_to); }
    if e.lhs != null { collect_result_in_expr(g, e.lhs); }
    if e.rhs != null { collect_result_in_expr(g, e.rhs); }
    if e.operand != null { collect_result_in_expr(g, e.operand); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            collect_result_in_expr(g, &a);
        }
    }
}

fn collect_result_in_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    // Trait sigs reference Self / Self::Item placeholders; impls collect
    // their own substituted versions.
    if s.kind == ST_TRAIT { return; }
    if s.let_ty != null { collect_result_in_type(g, s.let_ty); }
    if s.fn_ret_ty != null { collect_result_in_type(g, s.fn_ret_ty); }
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            collect_result_in_type(g, p.ty);
        }
    }
    if s.let_value != null { collect_result_in_expr(g, s.let_value); }
    if s.expr_value != null { collect_result_in_expr(g, s.expr_value); }
    if s.cond != null { collect_result_in_expr(g, s.cond); }
    if s.for_step != null { collect_result_in_expr(g, s.for_step); }
    if s.for_init != null { collect_result_in_stmt(g, s.for_init); }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            collect_result_in_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            collect_result_in_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            collect_result_in_stmt(g, &b);
        }
    }
    if s.impl_methods != null {
        for let i: i32 = 0; i < s.impl_methods.len(); i++ {
            let mm: Stmt = s.impl_methods.get(i);
            collect_result_in_stmt(g, &mm);
        }
    }
}

fn emit_result_runtime(g: *CG) {
    if g.result_types.len() == 0 { return; }
    let tmpl: string = include_str!("bootstrap/runtime/result.c.tmpl");
    for let i: i32 = 0; i < g.result_types.len(); i++ {
        let t: Type = g.result_types.get(i);
        let m: string = mangle_type(&t);
        let dedup_key: string = "__rt_result_emit_".concat(m);
        if g.module_aliases.contains(dedup_key) { continue; }
        g.module_aliases.insert(dedup_key, "1");
        // Special case `!void` — a Result with no value. `void val;` is invalid C,
        // so emit a struct without the val field, an ok ctor with no args, an err
        // ctor that takes only the message, and no unwrap (nothing to extract).
        if t.kind == TY_NAMED && t.name.eq("void") {
            println!("#ifndef __GLIDE_RESULT_void_GUARD");
            println!("#define __GLIDE_RESULT_void_GUARD");
            println!("typedef struct __glide_result_void_t { int ok; const char* err; } __glide_result_void_t;");
            println!("static __glide_result_void_t __glide_ok_void(void) { __glide_result_void_t r; r.ok = 1; r.err = (const char*)0; return r; }");
            println!("static __glide_result_void_t __glide_err_void(const char* msg) { __glide_result_void_t r; r.ok = 0; r.err = msg; return r; }");
            println!("#endif");
            continue;
        }
        emit_tuple_typedefs_in_type(g, &t);
        let tc: string = type_to_c(&t);
        let s1: string = _cg_replace(tmpl, "@M@", m);
        let s2: string = _cg_replace(s1, "@TC@", tc);
        print!(s2);
    }
    println!("");
}

fn emit_option_runtime(g: *CG) {
    if g.option_types.len() == 0 { return; }
    let tmpl: string = include_str!("bootstrap/runtime/option.c.tmpl");
    for let i: i32 = 0; i < g.option_types.len(); i++ {
        let t: Type = g.option_types.get(i);
        let m: string = mangle_type(&t);
        let dedup_key: string = "__rt_option_emit_".concat(m);
        if g.module_aliases.contains(dedup_key) { continue; }
        g.module_aliases.insert(dedup_key, "1");
        emit_tuple_typedefs_in_type(g, &t);
        let tc: string = type_to_c(&t);
        let s1: string = _cg_replace(tmpl, "@M@", m);
        let s2: string = _cg_replace(s1, "@TC@", tc);
        print!(s2);
    }
    println!("");
}

fn emit_optres_runtime(g: *CG) {
    if g.optres_types.len() == 0 { return; }
    let tmpl: string = include_str!("bootstrap/runtime/optres.c.tmpl");
    for let i: i32 = 0; i < g.optres_types.len(); i++ {
        let t: Type = g.optres_types.get(i);
        let m: string = mangle_type(&t);
        let dedup_key: string = "__rt_optres_emit_".concat(m);
        if g.module_aliases.contains(dedup_key) { continue; }
        g.module_aliases.insert(dedup_key, "1");
        emit_tuple_typedefs_in_type(g, &t);
        let tc: string = type_to_c(&t);
        let s1: string = _cg_replace(tmpl, "@M@", m);
        let s2: string = _cg_replace(s1, "@TC@", tc);
        print!(s2);
    }
    println!("");
}

// ---- Anonymous tuples: collection + struct emission ---------------------

// Dedup-add a tuple type to g.tuple_types. Nested element tuples are
// registered first so the emission order has inner tuples before the
// containers that store them by value.
fn register_tuple_type(g: *CG, t: *Type) {
    if t == null || t.kind != TY_TUPLE { return; }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            if a.kind == TY_TUPLE { register_tuple_type(g, &a); }
        }
    }
    let m: string = mangle_type(t);
    for let i: i32 = 0; i < g.tuple_types.len(); i++ {
        let ex: Type = g.tuple_types.get(i);
        if mangle_type(&ex).eq(m) { return; }
    }
    g.tuple_types.push(*t);
}

// Walk a type registering every tuple it (recursively) contains.
fn collect_tuple_in_type(g: *CG, t: *Type) {
    if t == null { return; }
    if t.kind == TY_TUPLE { register_tuple_type(g, t); }
    if t.inner != null { collect_tuple_in_type(g, t.inner); }
    if t.fnptr_ret != null { collect_tuple_in_type(g, t.fnptr_ret); }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            collect_tuple_in_type(g, &a);
        }
    }
}

fn collect_tuple_in_expr(g: *CG, e: *Expr) {
    if e == null { return; }
    if e.kind == EX_TUPLE {
        let tt: *Type = infer_for_codegen(g, e);
        if tt != null && tt.kind == TY_TUPLE { register_tuple_type(g, tt); }
    }
    if e.cast_to != null { collect_tuple_in_type(g, e.cast_to); }
    if e.lhs != null { collect_tuple_in_expr(g, e.lhs); }
    if e.rhs != null { collect_tuple_in_expr(g, e.rhs); }
    if e.operand != null { collect_tuple_in_expr(g, e.operand); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            collect_tuple_in_expr(g, &a);
        }
    }
    if e.block_stmts != null {
        for let i: i32 = 0; i < e.block_stmts.len(); i++ {
            let b: Stmt = e.block_stmts.get(i);
            collect_tuple_in_stmt(g, &b);
        }
    }
    if e.match_arms != null {
        for let i: i32 = 0; i < e.match_arms.len(); i++ {
            let a: MatchArm = e.match_arms.get(i);
            if a.body != null {
                for let k: i32 = 0; k < a.body.len(); k++ {
                    let b: Stmt = a.body.get(k);
                    collect_tuple_in_stmt(g, &b);
                }
            }
        }
    }
}

fn collect_tuple_in_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.kind == ST_TRAIT { return; }
    if s.let_ty != null { collect_tuple_in_type(g, s.let_ty); }
    if s.fn_ret_ty != null { collect_tuple_in_type(g, s.fn_ret_ty); }
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            collect_tuple_in_type(g, p.ty);
        }
    }
    if s.struct_fields != null {
        for let i: i32 = 0; i < s.struct_fields.len(); i++ {
            let f: Field = s.struct_fields.get(i);
            collect_tuple_in_type(g, f.ty);
        }
    }
    if s.let_value != null { collect_tuple_in_expr(g, s.let_value); }
    if s.expr_value != null { collect_tuple_in_expr(g, s.expr_value); }
    if s.cond != null { collect_tuple_in_expr(g, s.cond); }
    if s.for_step != null { collect_tuple_in_expr(g, s.for_step); }
    if s.for_init != null { collect_tuple_in_stmt(g, s.for_init); }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            collect_tuple_in_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            collect_tuple_in_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            collect_tuple_in_stmt(g, &b);
        }
    }
    if s.impl_methods != null {
        for let i: i32 = 0; i < s.impl_methods.len(); i++ {
            let mm: Stmt = s.impl_methods.get(i);
            collect_tuple_in_stmt(g, &mm);
        }
    }
}

// Emit one tuple struct typedef, guarded so repeated requests (the inline
// path for `!(tuple)` / `?(tuple)` and the general program-wide pass) emit
// it at most once. Nested tuple element typedefs are emitted first.
fn emit_one_tuple_typedef(g: *CG, t: *Type) {
    if t == null || t.kind != TY_TUPLE { return; }
    let m: string = mangle_tuple(t);
    let dedup_key: string = "__rt_tuple_emit_".concat(m);
    if g.module_aliases.contains(dedup_key) { return; }
    // Element types are stored by value, so each must be fully defined first:
    //   - nested tuples emit their own typedef,
    //   - a by-value user struct/enum emits its body now (the forward typedef
    //     is already in scope; mark it emitted so the later body pass skips it).
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            if a.kind == TY_TUPLE { emit_one_tuple_typedef(g, &a); }
            if a.kind == TY_NAMED && a.name != null && !g.emitted_named.contains(a.name) {
                if g.structs.contains(a.name) {
                    let sd: Stmt = g.structs.get(a.name);
                    _forward_decl_field_monos(g, &sd);
                    emit_struct(&sd);
                    g.emitted_named.insert(a.name, true);
                } else if g.enums.contains(a.name) {
                    let ed: Stmt = g.enums.get(a.name);
                    emit_enum(&ed);
                    g.emitted_named.insert(a.name, true);
                }
            }
        }
    }
    g.module_aliases.insert(dedup_key, "1");
    let cname: string = "__glide_".concat(m).concat("_t");
    println!("#ifndef __GLIDE_".concat(m).concat("_GUARD"));
    println!("#define __GLIDE_".concat(m).concat("_GUARD"));
    print!("typedef struct ".concat(cname).concat(" { "));
    let n: i32 = if t.args != null { t.args.len() } else { 0 };
    if n == 0 {
        // Unit tuple `()` — give it a dummy field so the struct is non-empty.
        print!("char __unit; ");
    } else {
        for let i: i32 = 0; i < n; i++ {
            let a: Type = t.args.get(i);
            print!(type_to_c(&a).concat(" _").concat(int_to_str(i)).concat("; "));
        }
    }
    println!("} ".concat(cname).concat(";"));
    println!("#endif");
}

// Recursively emit tuple typedefs nested anywhere inside `t`. Used by the
// result/option/optres pre-pass so `!(i32, i32)` has its element struct in
// scope before the wrapper struct that stores it by value.
fn emit_tuple_typedefs_in_type(g: *CG, t: *Type) {
    if t == null { return; }
    if t.kind == TY_TUPLE { emit_one_tuple_typedef(g, t); }
    if t.inner != null { emit_tuple_typedefs_in_type(g, t.inner); }
    if t.fnptr_ret != null { emit_tuple_typedefs_in_type(g, t.fnptr_ret); }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            emit_tuple_typedefs_in_type(g, &a);
        }
    }
}

fn emit_tuple_runtime(g: *CG) {
    if g.tuple_types.len() == 0 { return; }
    for let i: i32 = 0; i < g.tuple_types.len(); i++ {
        let t: Type = g.tuple_types.get(i);
        emit_one_tuple_typedef(g, &t);
    }
    println!("");
}

// ---- Concurrency: chan + spawn collection / emission --------------------

fn collect_chan_in_type(g: *CG, t: *Type) {
    if t == null { return; }
    if t.kind == TY_GENERIC && t.name.eq("chan") && t.args != null && t.args.len() > 0 {
        let inner: Type = t.args.get(0);
        let m: string = mangle_type(&inner);
        // dedup via simple linear search
        let n: i32 = g.chan_types.len();
        for let i: i32 = 0; i < n; i++ {
            let existing: Type = g.chan_types.get(i);
            if mangle_type(&existing).eq(m) { return; }
        }
        g.chan_types.push(inner);
    }
    if t.inner != null { collect_chan_in_type(g, t.inner); }
    if t.fnptr_ret != null { collect_chan_in_type(g, t.fnptr_ret); }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            collect_chan_in_type(g, &a);
        }
    }
}

fn collect_chan_in_expr(g: *CG, e: *Expr) {
    if e == null { return; }
    if e.cast_to != null { collect_chan_in_type(g, e.cast_to); }
    if e.lhs != null { collect_chan_in_expr(g, e.lhs); }
    if e.rhs != null { collect_chan_in_expr(g, e.rhs); }
    if e.operand != null { collect_chan_in_expr(g, e.operand); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            collect_chan_in_expr(g, &a);
        }
    }
}

// ---- dyn Trait collection ----
//
// Walk every type appearing in the program; whenever we hit a `dyn Trait`
// (either bare or behind `*`/`&`), register the trait name. Later passes
// emit a vtable struct + fat-pointer typedef + static vtable instance for
// each `(Trait, Type)` pair the program implements.

fn collect_dyn_in_type(g: *CG, t: *Type) {
    if t == null { return; }
    if t.kind == TY_DYN {
        if t.name != null && !t.name.eq("") {
            g.dyn_traits.insert(t.name, true);
        }
    }
    if t.inner != null { collect_dyn_in_type(g, t.inner); }
    if t.fnptr_ret != null { collect_dyn_in_type(g, t.fnptr_ret); }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            collect_dyn_in_type(g, &a);
        }
    }
}

fn collect_dyn_in_expr(g: *CG, e: *Expr) {
    if e == null { return; }
    if e.cast_to != null { collect_dyn_in_type(g, e.cast_to); }
    if e.lhs != null { collect_dyn_in_expr(g, e.lhs); }
    if e.rhs != null { collect_dyn_in_expr(g, e.rhs); }
    if e.operand != null { collect_dyn_in_expr(g, e.operand); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            collect_dyn_in_expr(g, &a);
        }
    }
}

fn collect_dyn_in_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.let_ty != null { collect_dyn_in_type(g, s.let_ty); }
    if s.fn_ret_ty != null { collect_dyn_in_type(g, s.fn_ret_ty); }
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            if p.ty != null { collect_dyn_in_type(g, p.ty); }
        }
    }
    if s.let_value != null { collect_dyn_in_expr(g, s.let_value); }
    if s.expr_value != null { collect_dyn_in_expr(g, s.expr_value); }
    if s.cond != null { collect_dyn_in_expr(g, s.cond); }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            collect_dyn_in_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            collect_dyn_in_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            collect_dyn_in_stmt(g, &b);
        }
    }
    if s.impl_methods != null {
        for let i: i32 = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            collect_dyn_in_stmt(g, &m);
        }
    }
}

// Emit the C runtime support for every `dyn Trait` in use:
//   * Vtable struct (`__glide_<Trait>_vt`) listing every method as a fn ptr.
//   * Fat-pointer struct (`__glide_dyn_<Trait>`) = `{ data, vtable }`.
//   * Static vtable instance (`__glide_<Type>_as_<Trait>_vt`) per
//     `impl Trait for Type` block in the program.
fn emit_dyn_runtime(g: *CG, program: *Vector<Stmt>) {
    if g.dyn_traits == null { return; }
    // Helper: index trait defs by name.
    let traits: *HashMap<Stmt> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_TRAIT && s.name != null && !s.name.eq("") {
            traits.insert(s.name, s);
        }
    }
    // Iterate over the program and emit per-trait runtime support.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_TRAIT { continue; }
        if s.name == null || s.name.eq("") { continue; }
        if !g.dyn_traits.contains(s.name) { continue; }
        let trait_name: string = s.name;
        // Vtable struct: one fn-ptr field per trait method. `data` is
        // always passed as the first arg (`void*`), then the user params.
        println!("typedef struct __glide_".concat(trait_name).concat("_vt {"));
        if s.impl_methods != null {
            for let k: i32 = 0; k < s.impl_methods.len(); k++ {
                let m: Stmt = s.impl_methods.get(k);
                if m.name == null || m.name.eq("") { continue; }
                let ret_ty: string = type_to_c(m.fn_ret_ty);
                print!("    ".concat(ret_ty).concat(" (*").concat(m.name).concat(")(void* self"));
                if m.fn_params != null && m.fn_params.len() > 1 {
                    for let j: i32 = 1; j < m.fn_params.len(); j++ {
                        let p: Param = m.fn_params.get(j);
                        print!(", ".concat(type_to_c(p.ty)).concat(" ").concat(c_safe_ident(p.name)));
                    }
                }
                println!(");");
            }
        }
        println!("} __glide_".concat(trait_name).concat("_vt;"));
        // Fat pointer.
        println!("typedef struct __glide_dyn_".concat(trait_name).concat(" {"));
        println!("    void* data;");
        println!("    const __glide_".concat(trait_name).concat("_vt* vtable;"));
        println!("} __glide_dyn_".concat(trait_name).concat(";"));
        println!("");
    }
    // For every `impl Trait for Type` whose Trait is dyn-used:
    //   - forward-declare each `<Type>_<method>` (the body is emitted later).
    //   - emit a per-method thunk that takes `void* self_p`, derefs to `Type`
    //     by value, and forwards to `<Type>_<method>`. Trait methods are
    //     declared `fn m(self: Self)` — Self desugars to `Type` by value, so
    //     the thunk hides the calling-convention mismatch.
    //   - emit the static vtable instance pointing at the thunks.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_IMPL { continue; }
        if s.impl_trait_name == null || s.impl_trait_name.eq("") { continue; }
        if !g.dyn_traits.contains(s.impl_trait_name) { continue; }
        if s.impl_target == null || s.impl_target.kind != TY_NAMED { continue; }
        let trait_name: string = s.impl_trait_name;
        let type_name: string = s.impl_target.name;
        if !traits.contains(trait_name) { continue; }
        if s.impl_methods == null { continue; }

        // Forward declarations of the real impl methods.
        for let k: i32 = 0; k < s.impl_methods.len(); k++ {
            let m: Stmt = s.impl_methods.get(k);
            if m.name == null || m.name.eq("") { continue; }
            let ret_ty: string = type_to_c(m.fn_ret_ty);
            print!(ret_ty.concat(" ").concat(type_name).concat("_").concat(m.name).concat("("));
            if m.fn_params != null {
                for let j: i32 = 0; j < m.fn_params.len(); j++ {
                    if j > 0 { print!(", "); }
                    let p: Param = m.fn_params.get(j);
                    print!(type_to_c(p.ty));
                }
            }
            println!(");");
        }

        // Per-method thunks. The thunk takes `void* self_p` (the
        // dyn fat-pointer's data slot) and forwards to the concrete
        // `<Type>_<method>` impl. How `self_p` is passed depends on
        // the impl's first-param shape:
        //   self: Self      (by value, traits' default desugar)
        //                   -> deref: `*(Type*)self_p`
        //   self: *Self     (pointer)
        //                   -> cast only: `(Type*)self_p`
        // Without this distinction the C compiler errors with
        // "expected Type* but got Type" (or vice versa) at the call.
        for let k: i32 = 0; k < s.impl_methods.len(); k++ {
            let m: Stmt = s.impl_methods.get(k);
            if m.name == null || m.name.eq("") { continue; }
            let ret_ty: string = type_to_c(m.fn_ret_ty);
            print!("static ".concat(ret_ty).concat(" __glide_").concat(type_name).concat("_as_").concat(trait_name).concat("__").concat(m.name).concat("_thunk(void* self_p"));
            if m.fn_params != null && m.fn_params.len() > 1 {
                for let j: i32 = 1; j < m.fn_params.len(); j++ {
                    let p: Param = m.fn_params.get(j);
                    print!(", ".concat(type_to_c(p.ty)).concat(" ").concat(c_safe_ident(p.name)));
                }
            }
            println!(") {");
            let is_void: bool = m.fn_ret_ty == null
                || (m.fn_ret_ty.kind == TY_NAMED && m.fn_ret_ty.name.eq("void"));
            // Decide the cast form by inspecting the first param.
            let mut self_expr: string = "*(".concat(type_name).concat("*)self_p");
            if m.fn_params != null && m.fn_params.len() > 0 {
                let p0: Param = m.fn_params.get(0);
                if p0.ty != null && p0.ty.kind == TY_POINTER {
                    self_expr = "(".concat(type_name).concat("*)self_p");
                }
            }
            if is_void {
                print!("    ".concat(type_name).concat("_").concat(m.name).concat("(").concat(self_expr));
            } else {
                print!("    return ".concat(type_name).concat("_").concat(m.name).concat("(").concat(self_expr));
            }
            if m.fn_params != null && m.fn_params.len() > 1 {
                for let j: i32 = 1; j < m.fn_params.len(); j++ {
                    let p: Param = m.fn_params.get(j);
                    print!(", ".concat(c_safe_ident(p.name)));
                }
            }
            println!(");");
            println!("}");
        }

        // Static vtable instance — fields point at the thunks.
        print!("static const __glide_".concat(trait_name).concat("_vt __glide_").concat(type_name).concat("_as_").concat(trait_name).concat("_vt = {"));
        let mut emitted_any: bool = false;
        for let k: i32 = 0; k < s.impl_methods.len(); k++ {
            let m: Stmt = s.impl_methods.get(k);
            if m.name == null || m.name.eq("") { continue; }
            if emitted_any { print!(", "); }
            emitted_any = true;
            print!(".".concat(m.name).concat(" = __glide_").concat(type_name).concat("_as_").concat(trait_name).concat("__").concat(m.name).concat("_thunk"));
        }
        println!("};");
    }
    println!("");
}

fn collect_chan_in_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.let_ty != null { collect_chan_in_type(g, s.let_ty); }
    if s.fn_ret_ty != null { collect_chan_in_type(g, s.fn_ret_ty); }
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            collect_chan_in_type(g, p.ty);
        }
    }
    if s.struct_fields != null {
        for let i: i32 = 0; i < s.struct_fields.len(); i++ {
            let f: Field = s.struct_fields.get(i);
            collect_chan_in_type(g, f.ty);
        }
    }
    if s.let_value != null { collect_chan_in_expr(g, s.let_value); }
    if s.expr_value != null { collect_chan_in_expr(g, s.expr_value); }
    if s.cond != null { collect_chan_in_expr(g, s.cond); }
    if s.for_step != null { collect_chan_in_expr(g, s.for_step); }
    if s.for_init != null { collect_chan_in_stmt(g, s.for_init); }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            collect_chan_in_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            collect_chan_in_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            collect_chan_in_stmt(g, &b);
        }
    }
    if s.impl_methods != null {
        for let i: i32 = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            collect_chan_in_stmt(g, &m);
        }
    }
}

fn emit_chan_runtime(g: *CG) {
    if g.chan_types.len() == 0 { return; }
    g.uses_pthread = true;
    println!("#include <pthread.h>");
    println!("");
    // For chan inners that are themselves generic monos (e.g. `Vector<int>`),
    // emit the struct typedef + body up front so the chan struct's `T buf` /
    // `sizeof(T)` references resolve before the chan body referencing them.
    for let i: i32 = 0; i < g.chan_types.len(); i++ {
        let t: Type = g.chan_types.get(i);
        if t.kind == TY_GENERIC && g.generic_structs.contains(t.name) {
            let mangled: string = mangle_generic(t.name, t.args);
            if !g.emitted_monos.contains(mangled) {
                g.emitted_monos.insert(mangled, true);
                println!("typedef struct ", mangled, " ", mangled, ";");
                emit_struct_mono(g, &t);
            }
        }
        // (chan<UserType> body emit moved out of chan_runtime to emit_program)
    }
    // Forward typedefs first so chan<T> bodies that reference each other resolve.
    for let i: i32 = 0; i < g.chan_types.len(); i++ {
        let t: Type = g.chan_types.get(i);
        let m: string = mangle_type(&t);
        let st: string = "__glide_chan_".concat(m).concat("_t");
        println!("typedef struct ".concat(st).concat(" ").concat(st).concat(";"));
    }
    println!("");
    // Body, ops, close — substitute `@M@` (mangle hash) and `@TC@` (element C type)
    // in the chan template per element type.
    let tmpl: string = include_str!("bootstrap/runtime/chan.c.tmpl");
    for let i: i32 = 0; i < g.chan_types.len(); i++ {
        let t: Type = g.chan_types.get(i);
        let m: string = mangle_type(&t);
        let tc: string = type_to_c(&t);
        let s1: string = _cg_replace(tmpl, "@M@", m);
        let s2: string = _cg_replace(s1, "@TC@", tc);
        print!(s2);
        println!("");
    }
}

// M:N coroutine scheduler runtime. Emitted once per program. Defines:
//   __glide_sched_init / __glide_sched_shutdown
//   __glide_spawn(fn, arg)         submit a coroutine
//   yield_now()                    cooperative yield from inside a coroutine
// Backend: Win32 Fibers on Windows; ucontext.h elsewhere. Uses pthread for
// the worker pool everywhere. Default workers = #cpu cores (override via
// GLIDE_WORKERS env). v1 has a single global FIFO queue; per-worker deques
// + work-stealing land in Phase 1.2.
fn emit_scheduler_runtime() {
    println!("");
    print!(include_str!("bootstrap/runtime/sched.c"));
    println!("");
}


// Sync TCP socket runtime + the async reactor that sits on top of it.
// socket.c provides the blocking accept/read/write primitives that
// reactor.c then non-blocks and parks the coroutine on. The async
// wrappers (`accept_tcp_async`, `tcp_read_async`, `tcp_write_async`)
// are what stdlib::net actually calls; on Linux they go through epoll,
// on Windows / macOS they fall back to the sync versions until
// IOCP / kqueue land.
fn emit_socket_runtime() {
    println!("");
    print!(include_str!("bootstrap/runtime/socket.c"));
    println!("");
    print!(include_str!("bootstrap/runtime/reactor.c"));
    println!("");
    print!(include_str!("bootstrap/runtime/http_parse.c"));
    println!("");
    print!(include_str!("bootstrap/runtime/http_sm.c"));
    println!("");
}

// Spawn: collect every spawn site and emit a stub up-front. The same pre-walk
// order is used at emit time to recover the matching ID.
fn pre_emit_spawn_stubs_in_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.kind == ST_SPAWN {
        let id: i32 = g.spawn_count;
        g.spawn_count = id + 1;
        emit_spawn_stub(g, s.expr_value, id);
        return;
    }
    if s.for_init != null { pre_emit_spawn_stubs_in_stmt(g, s.for_init); }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            pre_emit_spawn_stubs_in_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            pre_emit_spawn_stubs_in_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            pre_emit_spawn_stubs_in_stmt(g, &b);
        }
    }
    if s.impl_methods != null {
        for let i: i32 = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            pre_emit_spawn_stubs_in_stmt(g, &m);
        }
    }
}

fn emit_spawn_stub(g: *CG, call: *Expr, id: i32) {
    if call == null || call.kind != EX_CALL || call.lhs == null { return; }
    if call.lhs.kind != EX_IDENT { return; }
    let fn_name: string = call.lhs.str_val;
    if !g.fns.contains(fn_name) { return; }
    let fnstmt: Stmt = g.fns.get(fn_name);
    if fnstmt.fn_params == null { return; }
    let n: i32 = fnstmt.fn_params.len();
    let ids: string = int_to_str(id);
    // Zero-arg fast path: no args struct, no malloc, no free in stub.
    if n == 0 {
        let tmpl: string = include_str!("bootstrap/runtime/spawn_stub_zero.c.tmpl");
        let s1: string = _cg_replace(tmpl, "@ID@", ids);
        let s2: string = _cg_replace(s1, "@FN_NAME@", fn_name);
        print!(s2);
        return;
    }
    let an: string = "__glide_spawn_args_".concat(ids);
    // Build the variable parts: per-arg field decls and the call argument list.
    let mut fields: string = "";
    let mut call_args: string = "";
    for let i: i32 = 0; i < n; i++ {
        let p: Param = fnstmt.fn_params.get(i);
        let ix: string = int_to_str(i);
        fields = fields.concat("    ").concat(type_to_c(p.ty)).concat(" a").concat(ix).concat(";\n");
        if i > 0 { call_args = call_args.concat(", "); }
        call_args = call_args.concat("__args->a").concat(ix);
    }
    let tmpl: string = include_str!("bootstrap/runtime/spawn_stub_args.c.tmpl");
    let s1: string = _cg_replace(tmpl, "@AN@", an);
    let s2: string = _cg_replace(s1, "@ID@", ids);
    let s3: string = _cg_replace(s2, "@FN_NAME@", fn_name);
    let s4: string = _cg_replace(s3, "@FIELDS@", fields);
    let s5: string = _cg_replace(s4, "@CALL_ARGS@", call_args);
    print!(s5);
}

// `int_to_str` and `digit_str` moved to ast.glide so expander.glide can
// reach them without a circular import.

// Any fixed-width integer type (the canonical family).
fn _is_int_family(name: string) -> bool {
    if name.eq("i8")  || name.eq("i16") || name.eq("i32") || name.eq("i64") { return true; }
    if name.eq("u8")  || name.eq("u16") || name.eq("u32") || name.eq("u64") { return true; }
    if name.eq("i128") || name.eq("u128") { return true; }
    if name.eq("usize") || name.eq("isize") { return true; }
    return false;
}

// Unsigned <=64-bit ints. Their methods route through `__glide_uint_*` (%llu),
// not the signed `__glide_int_*`, so to_string is correct above i64 max.
fn _is_uint_family(name: string) -> bool {
    if name.eq("u8") || name.eq("u16") || name.eq("u32") || name.eq("u64") { return true; }
    if name.eq("usize") { return true; }
    return false;
}

// `"u256"` / `"i256"` if `t` is a 256-bit int (the software-struct types whose
// operators dispatch to `__glide_<ty>_<op>` runtime fns), else `""`.
fn _u256_ty(t: *Type) -> string {
    if t == null || t.kind != TY_NAMED { return ""; }
    if t.name.eq("u256") { return "u256"; }
    if t.name.eq("i256") { return "i256"; }
    return "";
}

// C expression for the associated constant `<inttype>::MAX` / `::MIN`. Returns
// "" when `ty` isn't an integer primitive. The <=64-bit widths use <stdint.h>
// limit macros; 128-bit fold the all-ones pattern; 256-bit call struct-valued
// runtime helpers. Doubles as the "is this a valid int-constant type" predicate.
fn _int_limit_c(ty: string, hi: bool) -> string {
    if ty.eq("i8")    { if hi { return "INT8_MAX"; }  return "INT8_MIN"; }
    if ty.eq("i16")   { if hi { return "INT16_MAX"; } return "INT16_MIN"; }
    if ty.eq("i32")   { if hi { return "INT32_MAX"; } return "INT32_MIN"; }
    if ty.eq("i64")   { if hi { return "INT64_MAX"; } return "INT64_MIN"; }
    if ty.eq("u8")    { if hi { return "UINT8_MAX"; }  return "0"; }
    if ty.eq("u16")   { if hi { return "UINT16_MAX"; } return "0"; }
    if ty.eq("u32")   { if hi { return "UINT32_MAX"; } return "0"; }
    if ty.eq("u64")   { if hi { return "UINT64_MAX"; } return "0"; }
    if ty.eq("usize") { if hi { return "SIZE_MAX"; }    return "0"; }
    if ty.eq("isize") { if hi { return "PTRDIFF_MAX"; } return "PTRDIFF_MIN"; }
    if ty.eq("i128")  { if hi { return "((__int128)((~(unsigned __int128)0) >> 1))"; }
                        return "(-((__int128)((~(unsigned __int128)0) >> 1)) - 1)"; }
    if ty.eq("u128")  { if hi { return "(~(unsigned __int128)0)"; } return "((unsigned __int128)0)"; }
    if ty.eq("i256")  { if hi { return "__glide_i256_max()"; } return "__glide_i256_min()"; }
    if ty.eq("u256")  { if hi { return "__glide_u256_max()"; } return "__glide_u256_min()"; }
    return "";
}

// Runtime fn suffix for an arithmetic/bitwise op on a 256-bit int, or "" if
// `op` is a comparison (handled via `_cmp`) or not applicable.
fn _u256_arith_fn(op: i32) -> string {
    if op == OP_ADD { return "add"; }
    if op == OP_SUB { return "sub"; }
    if op == OP_MUL { return "mul"; }
    if op == OP_DIV { return "div"; }
    if op == OP_MOD { return "mod"; }
    if op == OP_BIT_AND { return "and"; }
    if op == OP_BIT_OR  { return "or"; }
    if op == OP_BIT_XOR { return "xor"; }
    if op == OP_SHL { return "shl"; }
    if op == OP_SHR { return "shr"; }
    return "";
}

fn is_stdlib_primitive(name: string) -> bool {
    if _is_int_family(name) { return true; }
    if name.eq("u256") || name.eq("i256") { return true; }
    if name.eq("f32") || name.eq("f64") { return true; }
    if name.eq("char") { return true; }
    if name.eq("bool") { return true; }
    if name.eq("string") { return true; }
    return false;
}

fn emit_stdlib_runtime() {
    print!(include_str!("bootstrap/runtime/stdlib.c"));
    println!("");
}


// Track variable types per scope so method calls (obj.method()) can be
// resolved to Type_method(obj, ...) by stripping pointers and using the
// receiver's named type as the prefix.
// Pending fn monomorphization: original name + concrete type args.
pub struct FnMonoEntry {
    pub name: string,
    pub args: *Vector<Type>,
}

// Anonymous fn that needs lifting to top-level.
pub struct AnonFn {
    pub name: string,
    pub params: *Vector<Param>,
    pub ret_ty: *Type,
    pub body: *Vector<Stmt>,
}

pub struct CG {
    pub scope: *HashMap<Type>,
    pub generic_structs: *HashMap<Stmt>,
    pub generic_fns: *HashMap<Stmt>,
    pub structs: *HashMap<Stmt>,
    pub enums: *HashMap<Stmt>,
    pub fns: *HashMap<Stmt>,
    pub emitted_monos: *HashMap<bool>,
    pub fn_mono_queue: *Vector<FnMonoEntry>,
    // Struct monos discovered dynamically during prescan (e.g. via chained
    // ctor inference where no static `let_ty` exposes the type). Drained
    // after fn-mono drain, before fn forward decls.
    pub struct_mono_queue: *Vector<Type>,
    pub defer_stack: *Vector<Expr>,         // explicit `defer expr;` (fn-scoped)
    pub err_defer_stack: *Vector<Expr>,     // `defer_err expr;` — fires only on err return / `?` (fn-scoped)
    pub auto_drop_stack: *Vector<Expr>,     // `let v*` cleanups (block-scoped)
    // Anonymous fn lifts (collected during codegen, emitted at end).
    pub anon_fns: *Vector<AnonFn>,
    pub anon_count: i32,
    // Concurrency
    pub chan_types: *Vector<Type>,
    pub spawn_count: i32,
    pub uses_pthread: bool,
    // Errors-as-values
    pub result_types: *Vector<Type>,
    pub option_types: *Vector<Type>,
    pub optres_types: *Vector<Type>,
    // Anonymous tuple types `(A, B, ...)`. Each unique element-type combination
    // gets one C struct typedef (`__glide_tuple<N>_..._t`). Collected program-
    // wide, emitted inner-first so nested tuples precede their containers.
    pub tuple_types: *Vector<Type>,
    pub current_ret_ty: *Type,
    // Associated-type lookup for `<Trait>::<Concrete>::<Item>`. Populated
    // up front from every `impl Trait for Type { type Item = X; }`.
    pub assoc_table: *HashMap<Type>,
    // Method-dispatch index for `impl T in NS` blocks. Maps the unqualified
    // `<T>_<method>` name to a `;`-delimited list of full mangled names like
    // `cores_string_red`. O(1) lookup at dispatch time avoids walking g.fns.
    // (Glide HashMap takes a single value type; we encode multi-match as a
    // separator-joined string instead of nesting another Vector.)
    pub method_index: *HashMap<string>,
    // Names that came from an `impl T { ... }` block (mangled `<T>_<m>`).
    // Method dispatch (`obj.method()`) only resolves to entries in this set,
    // so a free fn named `string_legal` won't be sugared into `s.legal()`.
    pub method_fns: *HashMap<bool>,
    // Module-path aliases. Each pub item registers `<module>::<short>` →
    // `<short>`, so user code can write `stdlib::vector::Vector::new()` and
    // codegen can normalise it back to the existing flat C symbol naming.
    // Free functions: key = `<module>::<fn>`, value = `<fn>`.
    // Type names:     key = `<module>::<Type>`, value = `<Type>`.
    pub module_aliases: *HashMap<string>,
    // Named user struct/enum bodies already emitted (e.g. up-front by the
    // chan runtime so chan<UserType> can store T by value). The main body
    // pass skips anything already in here.
    pub emitted_named: *HashMap<bool>,
    // Trait names that appear as `dyn Trait` somewhere in the program.
    // Each one needs a fat-pointer typedef, a vtable struct, and a static
    // vtable instance per `impl Trait for Type`.
    pub dyn_traits: *HashMap<bool>,
    // Trait def index: trait name -> ST_TRAIT Stmt. Populated up front so
    // method-call return types can be looked up when the receiver is a
    // `*dyn Trait`.
    pub traits: *HashMap<Stmt>,
    // Top-level `const NAME: T = ...` table. Populated in the same
    // pre-scan that registers fns/structs/enums, so `infer_for_codegen`
    // can resolve a bare `NAME` ident the same way the typer does.
    // Before this existed, a const-typed string in `println!` codegen'd
    // as `%p` (printf'd a pointer) instead of `%s`.
    pub consts: *HashMap<Type>,
    // Source mapping for crash traces. `current_origin` is the Glide
    // source file currently being emitted (set per-fn / per-impl).
    // `last_line_dir` + `last_origin_dir` track the latest emitted
    // `#line N "file"` directive so we only emit one when the
    // (file, line) pair actually changes — avoids ballooning the C
    // output with a directive per stmt when many stmts share a line.
    pub current_origin: string,
    pub last_line_dir: i32,
    pub last_origin_dir: string,
}

impl CG {
    pub fn new() -> *CG {
        let g: *CG = malloc(sizeof(CG)) as *CG;
        let s: *HashMap<Type> = HashMap::new();
        let gs: *HashMap<Stmt> = HashMap::new();
        let gf: *HashMap<Stmt> = HashMap::new();
        let st: *HashMap<Stmt> = HashMap::new();
        let en: *HashMap<Stmt> = HashMap::new();
        let fnm: *HashMap<Stmt> = HashMap::new();
        let em: *HashMap<bool> = HashMap::new();
        let q: *Vector<FnMonoEntry> = Vector::new();
        let ds: *Vector<Expr> = Vector::new();
        g.defer_stack = ds;
        let eds: *Vector<Expr> = Vector::new();
        g.err_defer_stack = eds;
        let ads: *Vector<Expr> = Vector::new();
        g.auto_drop_stack = ads;
        let af: *Vector<AnonFn> = Vector::new();
        g.anon_fns = af;
        g.anon_count = 0;
        let ct: *Vector<Type> = Vector::new();
        g.chan_types = ct;
        g.spawn_count = 0;
        g.uses_pthread = false;
        let rt: *Vector<Type> = Vector::new();
        g.result_types = rt;
        let ot: *Vector<Type> = Vector::new();
        g.option_types = ot;
        let ort: *Vector<Type> = Vector::new();
        g.optres_types = ort;
        let tt: *Vector<Type> = Vector::new();
        g.tuple_types = tt;
        let at: *HashMap<Type> = HashMap::new();
        g.assoc_table = at;
        g.current_ret_ty = null;
        g.scope = s;
        g.generic_structs = gs;
        g.generic_fns = gf;
        g.structs = st;
        g.enums = en;
        g.fns = fnm;
        g.emitted_monos = em;
        g.fn_mono_queue = q;
        let smq: *Vector<Type> = Vector::new();
        g.struct_mono_queue = smq;
        let mi: *HashMap<string> = HashMap::new();
        g.method_index = mi;
        let mf: *HashMap<bool> = HashMap::new();
        g.method_fns = mf;
        let ma: *HashMap<string> = HashMap::new();
        g.module_aliases = ma;
        let en2: *HashMap<bool> = HashMap::new();
        g.emitted_named = en2;
        let dt: *HashMap<bool> = HashMap::new();
        g.dyn_traits = dt;
        let trts: *HashMap<Stmt> = HashMap::new();
        g.traits = trts;
        let cs: *HashMap<Type> = HashMap::new();
        g.consts = cs;
        g.current_origin = "";
        g.last_line_dir = 0;
        g.last_origin_dir = "";
        return g;
    }

    // Emit `#line <line> "<file>"` so the resulting DWARF / debug info
    // points at the Glide source instead of the generated C. We only
    // emit when (file, line) changed from the previous directive, and
    // we forward-slash the path so the C preprocessor accepts it on
    // Windows without escape headaches.
    fn emit_line_dir(self: *CG, line: i32, origin: string) {
        if line <= 0 { return; }
        let path: string;
        if origin == null || origin.eq("") { path = self.current_origin; }
        else { path = origin; }
        if path == null || path.eq("") { return; }
        if line == self.last_line_dir && path.eq(self.last_origin_dir) { return; }
        // Normalize backslashes to forward-slashes for C string-literal
        // safety. We don't escape quotes — Glide source paths don't
        // legally contain `"`.
        let n: i32 = path.len();
        let mut norm: string = "";
        for let i: i32 = 0; i < n; i++ {
            if path.at(i).to_int() == 92 { norm = norm.concat("/"); }
            else { norm = norm.concat(path.substring(i, i + 1)); }
        }
        // println!() inserts a space between each printf arg — that
        // would break the directive ('#line  4  " ".../foo.glide  "').
        // Build the whole line as one string and emit it via a single
        // printf arg. Leading '\n' guarantees column-1 placement even
        // when the previous emit (e.g. a c_raw! block) didn't end with
        // a newline; the C preprocessor requires `#line` at col 1.
        let dir: string = "\n#line ".concat(line.to_string()).concat(" \"").concat(norm).concat("\"");
        println!(dir);
        self.last_line_dir = line;
        self.last_origin_dir = path;
    }

    // Flush err-only deferred cleanups (LIFO). Called from ST_RETURN when
    // returning `err(...)` and from the `?` propagation lowering. Fires
    // BEFORE regular defers so the err handler sees the same outer state
    // as the regular path.
    fn emit_err_defers_reverse(self: *CG, depth: i32) {
        let n: i32 = self.err_defer_stack.len();
        for let i: i32 = n - 1; i >= 0; i = i - 1 {
            ind(depth);
            let ex: Expr = self.err_defer_stack.get(i);
            emit_expr(self, &ex);
            println!(";");
        }
    }

    // Flush all pending cleanups in reverse order. Called on return / fn end.
    // Auto-drops fire first (innermost block first), then explicit defers
    // (so e.g. `defer arena.free()` at fn-top fires after auto-drops that
    // allocated inside it).
    fn emit_deferred_reverse(self: *CG, depth: i32) {
        let na: i32 = self.auto_drop_stack.len();
        for let i: i32 = na - 1; i >= 0; i = i - 1 {
            ind(depth);
            let ex: Expr = self.auto_drop_stack.get(i);
            emit_expr(self, &ex);
            println!(";");
        }
        let nd: i32 = self.defer_stack.len();
        for let i: i32 = nd - 1; i >= 0; i = i - 1 {
            ind(depth);
            let ex: Expr = self.defer_stack.get(i);
            emit_expr(self, &ex);
            println!(";");
        }
    }

    // Block-exit cleanup: emit (in reverse) and pop only auto-drop entries
    // pushed since `saved`. Explicit defers stay on their own stack.
    fn emit_block_drops(self: *CG, saved: i32, depth: i32) {
        let n: i32 = self.auto_drop_stack.len();
        for let i: i32 = n - 1; i >= saved; i = i - 1 {
            ind(depth);
            let ex: Expr = self.auto_drop_stack.get(i);
            emit_expr(self, &ex);
            println!(";");
        }
        while self.auto_drop_stack.len() > saved {
            let _ev: Expr = self.auto_drop_stack.pop();
        }
    }

    pub fn free(self: *CG) {
        self.scope.free();
        self.generic_structs.free();
        self.generic_fns.free();
        self.structs.free();
        self.enums.free();
        self.fns.free();
        self.emitted_monos.free();
        free(self as *void);
    }

    fn declare(self: *CG, name: string, ty: *Type) {
        if ty != null { self.scope.insert(name, *ty); }
    }

    fn lookup(self: *CG, name: string) -> *Type {
        if !self.scope.contains(name) { return null; }
        let t: Type = self.scope.get(name);
        let p: *Type = malloc(sizeof(Type)) as *Type;
        *p = t;
        return p;
    }
}

// `strip_ptr` moved to ast.glide so typer.glide can reach it without
// importing codegen (which would be a heavy circular dep).

// Best-effort inference of an expression's type for codegen.
fn infer_for_codegen(g: *CG, e: *Expr) -> *Type {
    if e == null { return null; }
    if e.kind == EX_INT {
        // Mirror infer_expr in the typer: literals that overflow 32-bit
        // int widen to i64 so the emitted `let` lands the right C type
        // and downstream format!() picks `%lld` instead of `%d`.
        if e.int_val > 2147483647 || e.int_val < -2147483648 {
            return ty_named("i64");
        }
        return ty_named("i32");
    }
    if e.kind == EX_FLOAT { return ty_named("f64"); }
    if e.kind == EX_STRING { return ty_named("string"); }
    if e.kind == EX_BOOL { return ty_named("bool"); }
    if e.kind == EX_CHAR { return ty_named("char"); }
    if e.kind == EX_NULL { return ty_pointer(ty_named("void")); }
    if e.kind == EX_IF {
        // Both branches share a type by the typer's check; pick whichever
        // we can resolve.
        let then_ty: *Type = infer_for_codegen(g, e.rhs);
        if then_ty != null { return then_ty; }
        return infer_for_codegen(g, e.operand);
    }
    if e.kind == EX_BLOCK {
        if e.operand != null { return infer_for_codegen(g, e.operand); }
        return null;
    }
    if e.kind == EX_MATCH {
        if e.match_arms != null && e.match_arms.len() > 0 {
            let first: MatchArm = e.match_arms.get(0);
            return arm_value_type(g, &first);
        }
        return null;
    }
    if e.kind == EX_IDENT {
        let local: *Type = g.lookup(e.str_val);
        if local != null { return local; }
        // Top-level const: registered in the same pre-scan as fns.
        // Without this, `println!("v=", VERSION)` codegen'd `%p` for the
        // const-typed arg and printed a raw pointer.
        if g.consts.contains(e.str_val) {
            let ty: Type = g.consts.get(e.str_val);
            let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
            *p = ty;
            return p;
        }
        // Top-level fn name as a value: build TY_FNPTR from its signature so
        // generic-fn arg unification can bind type vars from `fn(T) -> U`
        // patterns. e.g. `iter_map(v, _double)` infers U=int from _double's
        // return type.
        if g.fns.contains(e.str_val) {
            let s: Stmt = g.fns.get(e.str_val);
            let args: *Vector<Type> = Vector::new();
            if s.fn_params != null {
                for let i: i32 = 0; i < s.fn_params.len(); i++ {
                    let p: Param = s.fn_params.get(i);
                    if p.ty != null { args.push(*p.ty); }
                }
            }
            let fp: *Type = __glide_palloc(sizeof(Type)) as *Type;
            fp.kind = TY_FNPTR;
            fp.args = args;
            fp.fnptr_ret = s.fn_ret_ty;
            return fp;
        }
        return null;
    }
    if e.kind == EX_UNARY {
        let inner: *Type = infer_for_codegen(g, e.operand);
        if e.op_code == UN_DEREF && inner != null && inner.kind == TY_POINTER {
            return inner.inner;
        }
        if e.op_code == UN_ADDR || e.op_code == UN_ADDR_MUT {
            return ty_pointer(inner);
        }
        return inner;
    }
    if e.kind == EX_MEMBER {
        let recv_ty: *Type = infer_for_codegen(g, e.lhs);
        let stripped: *Type = strip_ptr(recv_ty);
        if stripped == null { return null; }
        // Tuple index `t.0` / `t.1`: numeric field selects the element type.
        if stripped.kind == TY_TUPLE && tuple_field_is_index(e.field) {
            let idx: i32 = tuple_index_value(e.field);
            if stripped.args != null && idx >= 0 && idx < stripped.args.len() {
                let el: Type = stripped.args.get(idx);
                let pp: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *pp = el;
                return pp;
            }
            return null;
        }
        // Built-in field access on the synth Result/Option/OptResult structs.
        if stripped.kind == TY_RESULT {
            if e.field.eq("val") { return stripped.inner; }
            if e.field.eq("ok") { return ty_named("bool"); }
            if e.field.eq("err") { return ty_named("string"); }
            return null;
        }
        if stripped.kind == TY_OPTION {
            if e.field.eq("val") { return stripped.inner; }
            if e.field.eq("has") { return ty_named("bool"); }
            return null;
        }
        if stripped.kind == TY_OPT_RESULT {
            if e.field.eq("val") { return stripped.inner; }
            if e.field.eq("tag") { return ty_named("i32"); }
            if e.field.eq("err") { return ty_named("string"); }
            return null;
        }
        // Slice .len → usize/int placeholder.
        if stripped.kind == TY_SLICE {
            if e.field.eq("len") { return ty_named("usize"); }
            return null;
        }
        if stripped.kind == TY_NAMED && g.structs.contains(stripped.name) {
            let sd: Stmt = g.structs.get(stripped.name);
            if sd.struct_fields != null {
                for let i: i32 = 0; i < sd.struct_fields.len(); i++ {
                    let f: Field = sd.struct_fields.get(i);
                    if f.name.eq(e.field) { return f.ty; }
                }
            }
        }
        if stripped.kind == TY_GENERIC && g.generic_structs.contains(stripped.name) {
            let sd: Stmt = g.generic_structs.get(stripped.name);
            if sd.struct_fields != null && sd.type_params != null {
                for let i: i32 = 0; i < sd.struct_fields.len(); i++ {
                    let f: Field = sd.struct_fields.get(i);
                    if f.name.eq(e.field) {
                        return subst_type(f.ty, sd.type_params, stripped.args);
                    }
                }
            }
        }
        return null;
    }
    if e.kind == EX_CAST { return e.cast_to; }
    if e.kind == EX_STRUCT_LIT { return ty_named(e.str_val); }
    if e.kind == EX_TUPLE {
        let elems: *Vector<Type> = Vector::new();
        if e.args != null {
            for let i: i32 = 0; i < e.args.len(); i++ {
                let a: Expr = e.args.get(i);
                let et: *Type = infer_for_codegen(g, &a);
                if et == null { return null; }
                elems.push(*et);
            }
        }
        return ty_tuple(elems);
    }
    if e.kind == EX_MACRO {
        if e.str_val.eq("format") { return ty_named("string"); }
        return null;
    }
    if e.kind == EX_BINARY {
        let op: i32 = e.op_code;
        if op == OP_EQ || op == OP_NE || op == OP_LT || op == OP_LE
            || op == OP_GT || op == OP_GE || op == OP_AND || op == OP_OR {
            return ty_named("bool");
        }
        return infer_for_codegen(g, e.lhs);
    }
    if e.kind == EX_INDEX {
        let base: *Type = infer_for_codegen(g, e.lhs);
        if base == null { return null; }
        if base.kind == TY_POINTER || base.kind == TY_BORROW
            || base.kind == TY_BORROW_MUT || base.kind == TY_SLICE {
            return base.inner;
        }
        return null;
    }
    if e.kind == EX_CALL {
        // 256-bit constructors `u256::from` / `i256::from` yield their type.
        if e.lhs != null && e.lhs.kind == EX_PATH && e.lhs.field.eq("from")
           && (e.lhs.str_val.eq("u256") || e.lhs.str_val.eq("i256")) {
            return ty_named(e.lhs.str_val);
        }
        // Direct fn ident
        if e.lhs != null && e.lhs.kind == EX_IDENT {
            let nm: string = e.lhs.str_val;
            // Stdlib runtime fns.
            if nm.eq("args_count") { return ty_named("i32"); }
            if nm.eq("args_at") { return ty_named("string"); }
            if nm.eq("read_file") { return ty_named("string"); }
            if nm.eq("write_file") { return ty_named("bool"); }
            if nm.eq("now_ns") { return ty_named("i64"); }
            if nm.eq("pending_count") { return ty_named("i32"); }
            if nm.eq("malloc") || nm.eq("calloc") { return ty_pointer(ty_named("void")); }
            if g.fns.contains(nm) {
                let s: Stmt = g.fns.get(nm);
                return s.fn_ret_ty;
            }
            if g.generic_fns.contains(nm) {
                let gn: Stmt = g.generic_fns.get(nm);
                return _infer_generic_call_ret(g, e, &gn);
            }
        }
        // Path: Type::method (also handles module-qualified `mod::Type::method`
        // and free-fn `mod::name` forms via the alias table).
        if e.lhs != null && e.lhs.kind == EX_PATH {
            let qual: string = e.lhs.str_val.concat("::").concat(e.lhs.field);
            if g.module_aliases.contains(qual) {
                let resolved: string = g.module_aliases.get(qual);
                if g.fns.contains(resolved) { return g.fns.get(resolved).fn_ret_ty; }
                if g.generic_fns.contains(resolved) {
                    let gn: Stmt = g.generic_fns.get(resolved);
                    return _infer_generic_call_ret(g, e, &gn);
                }
            }
            let pname: string = resolve_type_prefix(g, e.lhs.str_val).concat("_").concat(e.lhs.field);
            if g.fns.contains(pname) { return g.fns.get(pname).fn_ret_ty; }
            if g.generic_fns.contains(pname) {
                let gn: Stmt = g.generic_fns.get(pname);
                return _infer_generic_call_ret(g, e, &gn);
            }
        }
        // Method call: receiver_type.method(...) → look up Type_method ret_ty
        if e.lhs != null && e.lhs.kind == EX_MEMBER {
            let rt: *Type = infer_for_codegen(g, e.lhs.lhs);
            let stripped: *Type = strip_ptr(rt);
            // Dyn dispatch: receiver is `*dyn Trait`. Look up the trait's
            // method signature for the return type.
            if stripped != null && stripped.kind == TY_DYN && g.traits.contains(stripped.name) {
                let td: Stmt = g.traits.get(stripped.name);
                if td.impl_methods != null {
                    for let i: i32 = 0; i < td.impl_methods.len(); i++ {
                        let tm: Stmt = td.impl_methods.get(i);
                        if tm.name != null && tm.name.eq(e.lhs.field) {
                            return tm.fn_ret_ty;
                        }
                    }
                }
            }
            if stripped != null && stripped.kind == TY_NAMED {
                // Qualified call `s.NS::method(...)`: look up `NS_<type>_method` directly.
                let qpos: i32 = ns_split_pos(e.lhs.field);
                if qpos > 0 {
                    let ns: string = e.lhs.field.substring(0, qpos);
                    let real: string = e.lhs.field.substring(qpos + 2, e.lhs.field.len());
                    let qmname: string = ns.concat("_").concat(stripped.name).concat("_").concat(real);
                    if g.fns.contains(qmname) { return g.fns.get(qmname).fn_ret_ty; }
                }
                // Stdlib primitive methods.
                if is_stdlib_primitive(stripped.name) {
                    let std_ret: *Type = stdlib_method_ret(stripped.name, e.lhs.field);
                    if std_ret != null { return std_ret; }
                }
                let mname: string = stripped.name.concat("_").concat(e.lhs.field);
                if g.fns.contains(mname) { return g.fns.get(mname).fn_ret_ty; }
                if g.generic_fns.contains(mname) { return g.generic_fns.get(mname).fn_ret_ty; }
                // Namespaced impl (`impl T in NS`): O(1) lookup in the method
                // index. Multi-match returns a `;`-joined list — typer just
                // takes the first; codegen does the same and reports ambiguity.
                if g.method_index.contains(mname) {
                    let entry: string = g.method_index.get(mname);
                    let semi: i32 = entry.len();
                    let mut k: i32 = 0;
                    while k < semi {
                        if entry.at(k).to_int() == 59 { semi = k; break; }
                        k = k + 1;
                    }
                    let first: string = entry.substring(0, semi);
                    if g.fns.contains(first) { return g.fns.get(first).fn_ret_ty; }
                }
            }
            if stripped != null && stripped.kind == TY_GENERIC {
                // Specialized impl wins (`impl Vector<int> { fn sum() }`):
                // its mangled fn already lives in g.fns with concrete ret_ty.
                let spec_prefix: string = mangle_generic(stripped.name, stripped.args);
                let spec_name: string = spec_prefix.concat("_").concat(e.lhs.field);
                if g.fns.contains(spec_name) {
                    return g.fns.get(spec_name).fn_ret_ty;
                }
                let mname: string = stripped.name.concat("_").concat(e.lhs.field);
                if g.generic_fns.contains(mname) {
                    let template: Stmt = g.generic_fns.get(mname);
                    let mut full_args: *Vector<Type> = resolve_method_call_args(
                        g, e, &template, stripped.args);
                    if full_args == null { full_args = stripped.args; }
                    return subst_type(template.fn_ret_ty, template.type_params, full_args);
                }
            }
        }
        return null;
    }
    if e.kind == EX_PATH {
        // Associated int constants `i32::MAX` / `u64::MIN` are values of the
        // int type — needed so println!/format! pick the right format spec.
        if (e.field.eq("MAX") || e.field.eq("MIN"))
           && !_int_limit_c(e.str_val, true).eq("") {
            return ty_named(e.str_val);
        }
        let qual: string = e.str_val.concat("::").concat(e.field);
        if g.module_aliases.contains(qual) {
            let resolved: string = g.module_aliases.get(qual);
            if g.fns.contains(resolved) { return g.fns.get(resolved).fn_ret_ty; }
            if g.generic_fns.contains(resolved) { return g.generic_fns.get(resolved).fn_ret_ty; }
        }
        let pname: string = resolve_type_prefix(g, e.str_val).concat("_").concat(e.field);
        if g.fns.contains(pname) { return g.fns.get(pname).fn_ret_ty; }
        if g.generic_fns.contains(pname) { return g.generic_fns.get(pname).fn_ret_ty; }
        // Enum variant: `Signal::Hup` is a value of type Signal. Without this
        // case, method dispatch on bare variant values (`Signal::Hup.to_int()`)
        // falls through to plain field access.
        let probe: string = resolve_type_prefix(g, e.str_val);
        if g.enums.contains(probe) {
            let edef: Stmt = g.enums.get(probe);
            if edef.enum_variants != null {
                for let i: i32 = 0; i < edef.enum_variants.len(); i++ {
                    let v: EnumVariant = edef.enum_variants.get(i);
                    if v.name.eq(e.field) { return ty_named(probe); }
                }
            }
        }
        return null;
    }
    return null;
}

// ---- type to C name ------------------------------------------------------

pub fn type_to_c(t: *Type) -> string {
    if t == null { return "void"; }
    if t.kind == TY_NAMED {
        let n: string = t.name;
        if n.eq("i8")     { return "int8_t"; }
        if n.eq("i16")    { return "int16_t"; }
        if n.eq("i32")    { return "int32_t"; }
        if n.eq("i64")    { return "int64_t"; }
        if n.eq("u8")     { return "uint8_t"; }
        if n.eq("u16")    { return "uint16_t"; }
        if n.eq("u32")    { return "uint32_t"; }
        if n.eq("u64")    { return "uint64_t"; }
        if n.eq("i128")   { return "__int128"; }
        if n.eq("u128")   { return "unsigned __int128"; }
        // i256/u256 share one software struct (signed ops reinterpret the bits).
        if n.eq("i256") || n.eq("u256") { return "__glide_u256"; }
        if n.eq("usize")  { return "size_t"; }
        if n.eq("isize")  { return "ptrdiff_t"; }
        if n.eq("f32")    { return "float"; }
        if n.eq("f64")    { return "double"; }
        if n.eq("bool")   { return "bool"; }
        if n.eq("char")   { return "char"; }
        if n.eq("string") { return "const char*"; }
        if n.eq("void")   { return "void"; }
        if n.eq("__fn_ptr__") { return "void*"; }
        // User-defined type name (struct/enum). Mangle if it collides with
        // a C keyword so `struct asm { ... }` and friends compile.
        return c_safe_ident(n);
    }
    if t.kind == TY_POINTER {
        // `*dyn Trait` is a fat pointer struct, not a raw pointer.
        if t.inner != null && t.inner.kind == TY_DYN {
            return "__glide_dyn_".concat(t.inner.name);
        }
        return type_to_c(t.inner).concat("*");
    }
    if t.kind == TY_BORROW      { return type_to_c(t.inner).concat(" const*"); }
    if t.kind == TY_BORROW_MUT  { return type_to_c(t.inner).concat("*"); }
    if t.kind == TY_SLICE       { return "/* []".concat(type_to_c(t.inner)).concat(" */ void*"); }
    if t.kind == TY_DYN         { return "__glide_dyn_".concat(t.name); }
    if t.kind == TY_GENERIC {
        if t.name.eq("chan") && t.args != null && t.args.len() > 0 {
            let inner: Type = t.args.get(0);
            return "__glide_chan_".concat(mangle_type(&inner)).concat("_t*");
        }
        return mangle_generic(t.name, t.args);
    }
    if t.kind == TY_FNPTR {
        // Use `void*` for fn-pointer slots; cast at call sites via fnptr_call_str.
        return "void*";
    }
    if t.kind == TY_RESULT {
        return "__glide_result_".concat(mangle_type(t.inner)).concat("_t");
    }
    if t.kind == TY_OPTION {
        return "__glide_option_".concat(mangle_type(t.inner)).concat("_t");
    }
    if t.kind == TY_OPT_RESULT {
        return "__glide_optres_".concat(mangle_type(t.inner)).concat("_t");
    }
    if t.kind == TY_ASSOC {
        // Reaches here only if monomorphization didn't substitute the assoc.
        // Emit a marker so the C compiler errors visibly instead of silently.
        return "/* unresolved-assoc */ void";
    }
    if t.kind == TY_TUPLE {
        return "__glide_".concat(mangle_tuple(t)).concat("_t");
    }
    return "void";
}

// Mangled identifier core for a tuple type: `tuple<N>_<m0>_<m1>...`. The
// arity prefix keeps `((i32,i32),i32)` (tuple2_tuple2_i32_i32_i32) distinct
// from `(i32,i32,i32)` (tuple3_i32_i32_i32).
fn mangle_tuple(t: *Type) -> string {
    let n: i32 = if t.args != null { t.args.len() } else { 0 };
    let mut out: string = "tuple".concat(int_to_str(n));
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            out = out.concat("_").concat(mangle_type(&a));
        }
    }
    return out;
}

// Build the C cast prefix for invoking a void* fn-pointer of this signature.
fn fnptr_cast_str(t: *Type) -> string {
    let mut s: string = type_to_c(t.fnptr_ret).concat("(*)(");
    if t.args == null || t.args.len() == 0 {
        s = s.concat("void");
    } else {
        for let i: i32 = 0; i < t.args.len(); i++ {
            if i > 0 { s = s.concat(", "); }
            let p: Type = t.args.get(i);
            s = s.concat(type_to_c(&p));
        }
    }
    s = s.concat(")");
    return s;
}

pub fn mangle_generic(name: string, args: *Vector<Type>) -> string {
    let mut out: string = name.concat("__");
    if args != null {
        for let i: i32 = 0; i < args.len(); i++ {
            if i > 0 { out = out.concat("_"); }
            let a: Type = args.get(i);
            out = out.concat(mangle_type(&a));
        }
    }
    return out;
}

fn mangle_type(t: *Type) -> string {
    if t == null { return "void"; }
    if t.kind == TY_NAMED { return t.name; }
    if t.kind == TY_POINTER { return mangle_type(t.inner).concat("_ptr"); }
    if t.kind == TY_BORROW { return mangle_type(t.inner).concat("_ref"); }
    if t.kind == TY_BORROW_MUT { return mangle_type(t.inner).concat("_refmut"); }
    if t.kind == TY_SLICE { return "slice_".concat(mangle_type(t.inner)); }
    if t.kind == TY_GENERIC { return mangle_generic(t.name, t.args); }
    if t.kind == TY_RESULT { return "result_".concat(mangle_type(t.inner)); }
    if t.kind == TY_OPTION { return "option_".concat(mangle_type(t.inner)); }
    if t.kind == TY_OPT_RESULT { return "optres_".concat(mangle_type(t.inner)); }
    if t.kind == TY_ASSOC { return "assoc_".concat(mangle_type(t.inner)).concat("_").concat(t.name); }
    if t.kind == TY_TUPLE { return mangle_tuple(t); }
    return "void";
}

// Build the full type-arg list for a method call on a generic receiver,
// including any method-level extra generics. The receiver supplies the
// impl's struct-level args (T...); extras (U...) are inferred from the
// call's argument types against the method's parameter types.
//
// Returns null if any extra param can't be bound (caller treats this as
// "not enough info — skip this call site").
// Infer the return type of a call to a generic free fn (or path-form
// like `Json::wrap(v)`) by unifying the template's parameter types
// against the call's argument types. Without this, infer_for_codegen
// hands back the template's `fn_ret_ty` un-substituted (e.g.
// `Json<T>` for `Json::wrap`), which then breaks downstream method
// dispatch on the returned value (`.into_response()` would emit
// `Json_into_response__T` instead of the substituted mono).
fn _infer_generic_call_ret(g: *CG, call: *Expr, template: *Stmt) -> *Type {
    if template == null { return null; }
    if template.type_params == null || template.type_params.len() == 0 {
        return template.fn_ret_ty;
    }
    let bindings: *HashMap<Type> = HashMap::new();
    if call.args != null && template.fn_params != null {
        let mut n: i32 = template.fn_params.len();
        if call.args.len() < n { n = call.args.len(); }
        for let i: i32 = 0; i < n; i++ {
            let p: Param = template.fn_params.get(i);
            let a: Expr = call.args.get(i);
            let at: *Type = infer_for_codegen(g, &a);
            if at != null && p.ty != null {
                unify_for_inference(p.ty, at, template.type_params, bindings);
            }
        }
    }
    let derived: *Vector<Type> = Vector::new();
    let mut all: bool = true;
    for let i: i32 = 0; i < template.type_params.len(); i++ {
        let tn: string = template.type_params.get(i);
        if !bindings.contains(tn) { all = false; break; }
        derived.push(bindings.get(tn));
    }
    bindings.free();
    if !all { return template.fn_ret_ty; }
    return subst_type(template.fn_ret_ty, template.type_params, derived);
}

fn resolve_method_call_args(g: *CG, call: *Expr, template: *Stmt,
                            recv_args: *Vector<Type>) -> *Vector<Type> {
    if template.type_params == null { return recv_args; }
    let n_total: i32 = template.type_params.len();
    let n_recv: i32 = 0;
    if recv_args != null { n_recv = recv_args.len(); }
    if n_total <= n_recv { return recv_args; }

    let bindings: *HashMap<Type> = HashMap::new();
    // Pre-bind struct-level params from the receiver.
    for let i: i32 = 0; i < n_recv; i++ {
        let tn: string = template.type_params.get(i);
        let av: Type = recv_args.get(i);
        bindings.insert(tn, av);
    }
    // Infer extras from call args. fn_params[0] is `self`.
    if call.args != null && template.fn_params != null && template.fn_params.len() > 1 {
        let nargs: i32 = template.fn_params.len() - 1;
        if call.args.len() < nargs { nargs = call.args.len(); }
        for let i: i32 = 0; i < nargs; i++ {
            let p: Param = template.fn_params.get(i + 1);
            let a: Expr = call.args.get(i);
            let at: *Type = infer_for_codegen(g, &a);
            if at != null && p.ty != null {
                unify_for_inference(p.ty, at, template.type_params, bindings);
            }
        }
    }
    let combined: *Vector<Type> = Vector::new();
    for let i: i32 = 0; i < n_recv; i++ { combined.push(recv_args.get(i)); }
    for let i: i32 = n_recv; i < n_total; i++ {
        let tn: string = template.type_params.get(i);
        if !bindings.contains(tn) { bindings.free(); return null; }
        combined.push(bindings.get(tn));
    }
    bindings.free();
    return combined;
}

// Try to monomorphize a Call expression. Returns true if the callee was
// rewritten to a mangled mono name. Uses both args and an optional return-
// type hint for inference.
fn try_mono_call(g: *CG, call: *Expr, ret_hint: *Type) -> bool {
    if call == null { return false; }
    if call.kind != EX_CALL { return false; }
    let callee: *Expr = call.lhs;
    let mut gname: string = "";
    if callee != null {
        if callee.kind == EX_IDENT { gname = callee.str_val; }
        if callee.kind == EX_PATH {
            // Map qualified path → short C name before mono lookup.
            let qual: string = callee.str_val.concat("::").concat(callee.field);
            if g.module_aliases.contains(qual) {
                gname = g.module_aliases.get(qual);
            } else {
                gname = resolve_type_prefix(g, callee.str_val).concat("_").concat(callee.field);
            }
        }
    }
    if gname.len() == 0 { return false; }
    if !g.generic_fns.contains(gname) { return false; }
    let template: Stmt = g.generic_fns.get(gname);

    let bindings: *HashMap<Type> = HashMap::new();

    // Infer from return-type hint (if provided).
    if ret_hint != null && template.fn_ret_ty != null {
        unify_for_inference(template.fn_ret_ty, ret_hint, template.type_params, bindings);
    }

    // Infer from arg types.
    if call.args != null && template.fn_params != null {
        let n: i32 = template.fn_params.len();
        if call.args.len() < n { n = call.args.len(); }
        for let i: i32 = 0; i < n; i++ {
            let p: Param = template.fn_params.get(i);
            let a: Expr = call.args.get(i);
            let at: *Type = infer_for_codegen(g, &a);
            if at != null && p.ty != null {
                unify_for_inference(p.ty, at, template.type_params, bindings);
            }
        }
    }

    // Build args in declared param order.
    let derived: *Vector<Type> = Vector::new();
    let mut all: bool = true;
    if template.type_params != null {
        for let i: i32 = 0; i < template.type_params.len(); i++ {
            let tn: string = template.type_params.get(i);
            if bindings.contains(tn) {
                derived.push(bindings.get(tn));
            } else {
                all = false;
            }
        }
    }
    if !all || derived.len() == 0 {
        bindings.free();
        return false;
    }

    let mangled: string = mangle_generic(gname, derived);
    callee.kind = EX_IDENT;
    callee.str_val = mangled;
    callee.field = "";
    register_fn_mono_signature(g, mangled, &template, derived);
    if !g.emitted_monos.contains(mangled) {
        g.emitted_monos.insert(mangled, true);
        let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: derived };
        g.fn_mono_queue.push(entry);
    }
    bindings.free();
    return true;
}

// Recursively walks expr/stmt trees, calling try_mono_call on every generic
// call to queue monos and emit forward decls. Called as a pre-pass before
// emitting any fn body so forward decls don't interleave with code.
// For an EX_CALL `e`, return the declared type of the i-th formal parameter,
// or null when the callee isn't a known regular fn / impl method. Lets the
// prescan propagate `*Vector<int>` down into `take(Vector::new())` so the
// generic ctor monomorphizes from the surrounding context.
fn callee_param_ty(g: *CG, e: *Expr, i: i32) -> *Type {
    if e == null || e.lhs == null { return null; }
    let callee: *Expr = e.lhs;
    if callee.kind == EX_IDENT && callee.str_val != null && g.fns.contains(callee.str_val) {
        let sig: Stmt = g.fns.get(callee.str_val);
        if sig.fn_params != null && i < sig.fn_params.len() {
            let p: Param = sig.fn_params.get(i);
            return p.ty;
        }
    }
    // Method call: `recv.method(args)` — look up the impl method and skip
    // self at index 0, so user arg index `i` maps to method param `i + 1`.
    if callee.kind == EX_MEMBER && callee.lhs != null {
        let rt: *Type = infer_for_codegen(g, callee.lhs);
        let stripped: *Type = strip_ptr(rt);
        if stripped != null && (stripped.kind == TY_NAMED || stripped.kind == TY_GENERIC) {
            let mname: string = stripped.name.concat("_").concat(callee.field);
            if g.fns.contains(mname) {
                let sig: Stmt = g.fns.get(mname);
                if sig.fn_params != null && (i + 1) < sig.fn_params.len() {
                    let p: Param = sig.fn_params.get(i + 1);
                    return p.ty;
                }
            }
            if g.generic_fns.contains(mname) {
                let sig: Stmt = g.generic_fns.get(mname);
                if sig.fn_params != null && (i + 1) < sig.fn_params.len() {
                    let p: Param = sig.fn_params.get(i + 1);
                    return p.ty;
                }
            }
        }
    }
    return null;
}

fn prescan_expr(g: *CG, e: *Expr, ret_hint: *Type) {
    if e == null { return; }

    // Bidirectional inference for `inline_generic_ctor().method(args)`:
    // derive T from the chained method's args back to the receiver, so
    // `Vector::new().push(1)` queues the right Vector_new__int / Vector_push__int
    // monos. Must run before try_mono_call so the receiver hint is ready.
    let mut chain_recv_hint: *Type = null;
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER
        && e.lhs.lhs != null && e.lhs.lhs.kind == EX_CALL
        && e.lhs.lhs.lhs != null && e.lhs.lhs.lhs.kind == EX_PATH {
        let recv: *Expr = e.lhs.lhs;
        let method: string = e.lhs.field;
        // Resolve `mod::path::Vector::new()` → bare `Vector` family before
        // checking generic-struct registry.
        let mut family: string = recv.lhs.str_val;
        if !g.generic_structs.contains(family) {
            family = resolve_type_prefix(g, family);
        }
        if g.generic_structs.contains(family) {
            let struct_def: Stmt = g.generic_structs.get(family);
            let mname: string = family.concat("_").concat(method);
            if g.generic_fns.contains(mname) && struct_def.type_params != null {
                let mtmpl: Stmt = g.generic_fns.get(mname);
                let bindings: *HashMap<Type> = HashMap::new();
                // Static methods (`Json::wrap(v)`) have no `self`; instance
                // methods (`v.push(x)`) put `self` at fn_params[0]. Detect
                // by name to know whether call args start at param 0 or 1.
                let mut self_off: i32 = 0;
                if mtmpl.fn_params != null && mtmpl.fn_params.len() > 0 {
                    let first_p: Param = mtmpl.fn_params.get(0);
                    if first_p.name != null && first_p.name.eq("self") { self_off = 1; }
                }
                if e.args != null && mtmpl.fn_params != null
                   && mtmpl.fn_params.len() > self_off {
                    let n: i32 = mtmpl.fn_params.len() - self_off;
                    if e.args.len() < n { n = e.args.len(); }
                    for let i: i32 = 0; i < n; i++ {
                        let p: Param = mtmpl.fn_params.get(i + self_off);
                        let a: Expr = e.args.get(i);
                        let at: *Type = infer_for_codegen(g, &a);
                        if at != null && p.ty != null {
                            unify_for_inference(p.ty, at, mtmpl.type_params, bindings);
                        }
                    }
                }
                // Also unify against the inner static method's args (e.g.
                // `Json::wrap(v).into_response()` — the outer `.into_response()`
                // has no args of its own, but `wrap`'s arg `v` carries T).
                let inner_method: string = recv.lhs.field;
                let inner_mname: string = family.concat("_").concat(inner_method);
                if g.generic_fns.contains(inner_mname) {
                    let inner_tmpl: Stmt = g.generic_fns.get(inner_mname);
                    let mut inner_off: i32 = 0;
                    if inner_tmpl.fn_params != null && inner_tmpl.fn_params.len() > 0 {
                        let p0: Param = inner_tmpl.fn_params.get(0);
                        if p0.name != null && p0.name.eq("self") { inner_off = 1; }
                    }
                    if recv.args != null && inner_tmpl.fn_params != null
                       && inner_tmpl.fn_params.len() > inner_off {
                        let n2: i32 = inner_tmpl.fn_params.len() - inner_off;
                        if recv.args.len() < n2 { n2 = recv.args.len(); }
                        for let i: i32 = 0; i < n2; i++ {
                            let p: Param = inner_tmpl.fn_params.get(i + inner_off);
                            let a: Expr = recv.args.get(i);
                            let at: *Type = infer_for_codegen(g, &a);
                            if at != null && p.ty != null {
                                unify_for_inference(p.ty, at, struct_def.type_params, bindings);
                            }
                        }
                    }
                }
                let derived: *Vector<Type> = Vector::new();
                let mut all: bool = true;
                for let i: i32 = 0; i < struct_def.type_params.len(); i++ {
                    let tn: string = struct_def.type_params.get(i);
                    if bindings.contains(tn) { derived.push(bindings.get(tn)); }
                    else { all = false; }
                }
                if all && derived.len() > 0 {
                    chain_recv_hint = ty_pointer(ty_generic(family, derived));
                    // Queue the struct mono — chained inference is the only
                    // way Vector<int> reaches codegen here (no let_ty / no
                    // call-site signature mentions it). Emit the typedef +
                    // body inline so any fn forward-decl that follows in
                    // the same prescan window can name the mangled type.
                    let mangled_struct: string = mangle_generic(
                        chain_recv_hint.inner.name, chain_recv_hint.inner.args);
                    if !g.emitted_monos.contains(mangled_struct) {
                        g.emitted_monos.insert(mangled_struct, true);
                        println!("typedef struct ", mangled_struct, " ", mangled_struct, ";");
                        emit_struct_mono(g, chain_recv_hint.inner);
                    }
                    g.struct_mono_queue.push(*chain_recv_hint.inner);
                    prescan_expr(g, recv, chain_recv_hint);
                }
                bindings.free();
            }
        }
    }

    if e.kind == EX_CALL {
        let _ok: bool = try_mono_call(g, e, ret_hint);
    }
    // Method call on generic receiver: also queue.
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER {
        let recv: *Expr = e.lhs.lhs;
        let method: string = e.lhs.field;
        // Prefer the bidirectional hint when present — recv may have just
        // been rewritten to a mangled mono whose ret type isn't yet in g.fns.
        let mut stripped: *Type = null;
        if chain_recv_hint != null {
            stripped = chain_recv_hint.inner;
        } else {
            let rt: *Type = infer_for_codegen(g, recv);
            stripped = strip_ptr(rt);
        }
        if stripped != null && stripped.kind == TY_GENERIC {
            // Specialized impl already concrete — nothing to mono.
            let spec_prefix: string = mangle_generic(stripped.name, stripped.args);
            let spec_name: string = spec_prefix.concat("_").concat(method);
            if !g.fns.contains(spec_name) {
                let mname: string = stripped.name.concat("_").concat(method);
                if g.generic_fns.contains(mname) {
                    let template: Stmt = g.generic_fns.get(mname);
                    let full_args: *Vector<Type> = resolve_method_call_args(
                        g, e, &template, stripped.args);
                    if full_args != null {
                        let mangled: string = mangle_generic(mname, full_args);
                        register_fn_mono_signature(g, mangled, &template, full_args);
                        if !g.emitted_monos.contains(mangled) {
                            g.emitted_monos.insert(mangled, true);
                            let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: full_args };
                            g.fn_mono_queue.push(entry);
                        }
                    }
                }
            }
        }
    }
    if e.lhs != null {
        // EX_CAST stores its operand in `lhs`; pass the cast target as the
        // child's expected type so `(Vector::new() as *Vector<int>)` infers T.
        let mut child_hint: *Type = null;
        if e.kind == EX_CAST { child_hint = e.cast_to; }
        prescan_expr(g, e.lhs, child_hint);
    }
    let no_hint: *Type = null;
    if e.rhs != null { prescan_expr(g, e.rhs, no_hint); }
    if e.operand != null { prescan_expr(g, e.operand, no_hint); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            // Carry the formal param's declared type as the arg's expected
            // type so inline `Vector::new()` etc. monomorphize correctly.
            let mut arg_hint: *Type = null;
            if e.kind == EX_CALL { arg_hint = callee_param_ty(g, e, i); }
            // Same for struct-lit field values: pass the declared field type
            // so `Box { items: Vector::new() }` infers Vector<int> from the
            // `items: *Vector<int>` field.
            if e.kind == EX_STRUCT_LIT && e.str_val != null && e.field_names != null
                && i < e.field_names.len() {
                let fname: string = e.field_names.get(i);
                let mut sd: Stmt = Stmt { kind: 0 };
                let mut have: bool = false;
                if g.structs.contains(e.str_val) { sd = g.structs.get(e.str_val); have = true; }
                else if g.generic_structs.contains(e.str_val) { sd = g.generic_structs.get(e.str_val); have = true; }
                if have && sd.struct_fields != null {
                    for let j: i32 = 0; j < sd.struct_fields.len(); j++ {
                        let f: Field = sd.struct_fields.get(j);
                        if f.name.eq(fname) { arg_hint = f.ty; }
                    }
                }
            }
            prescan_expr(g, &a, arg_hint);
        }
    }
}

fn prescan_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    // `return X` carries the enclosing fn's return type as a hint so inline
    // generic ctors like `return Vector::new()` monomorphize correctly.
    if s.kind == ST_RETURN {
        if s.expr_value != null { prescan_expr(g, s.expr_value, g.current_ret_ty); }
        return;
    }
    if s.kind == ST_LET || s.kind == ST_CONST {
        // Declare in scope so receiver-type lookup works. When there's no
        // annotation, infer from the initializer (e.g. `let v = make()`
        // where `make` returns `*Vector<int>`).
        if s.let_ty != null { g.declare(s.name, s.let_ty); }
        else if s.let_value != null {
            let inferred: *Type = infer_for_codegen(g, s.let_value);
            if inferred != null { g.declare(s.name, inferred); }
        }
        if s.let_value != null { prescan_expr(g, s.let_value, s.let_ty); }
        // Auto-drop with `let v*` on a generic type: queue the free-method
        // mono so its forward decl is emitted before any user fn body.
        if s.kind == ST_LET && s.is_auto_owned && s.let_ty != null {
            let inner_ty: *Type = strip_ptr(s.let_ty);
            if inner_ty != null && inner_ty.kind == TY_GENERIC {
                let free_name: string = inner_ty.name.concat("_free");
                if g.generic_fns.contains(free_name) {
                    let mangled: string = mangle_generic(free_name, inner_ty.args);
                    if !g.emitted_monos.contains(mangled) {
                        g.emitted_monos.insert(mangled, true);
                        let template: Stmt = g.generic_fns.get(free_name);
                        let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: inner_ty.args };
                        g.fn_mono_queue.push(entry);
                    }
                }
            }
        }
        return;
    }
    let no_hint: *Type = null;
    if s.expr_value != null { prescan_expr(g, s.expr_value, no_hint); }
    if s.cond != null { prescan_expr(g, s.cond, no_hint); }
    if s.for_init != null { prescan_stmt(g, s.for_init); }
    if s.for_step != null { prescan_expr(g, s.for_step, no_hint); }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            prescan_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            prescan_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        g.scope.clear();
        if s.fn_params != null {
            for let i: i32 = 0; i < s.fn_params.len(); i++ {
                let p: Param = s.fn_params.get(i);
                g.declare(p.name, p.ty);
            }
        }
        let saved_ret: *Type = g.current_ret_ty;
        g.current_ret_ty = s.fn_ret_ty;
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            prescan_stmt(g, &b);
        }
        g.current_ret_ty = saved_ret;
    }
    if s.impl_methods != null {
        for let i: i32 = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            prescan_stmt(g, &m);
        }
    }
}

// Build a synthetic Stmt with substituted ret/params and register it under
// `mangled` in g.fns so infer_for_codegen can resolve calls to the mono'd
// function (e.g. an inline `Vector::new()` whose callee was just rewritten to
// `Vector_new__int`). Without this, chained `.method(arg)` after a freshly-
// mono'd ctor can't determine the receiver's type.
fn register_fn_mono_signature(g: *CG, mangled: string, template: *Stmt, args: *Vector<Type>) {
    if g.fns.contains(mangled) { return; }
    let synth: *Stmt = calloc(1, sizeof(Stmt)) as *Stmt;
    synth.kind = template.kind;
    synth.name = mangled;
    let mut sret: *Type = subst_type(template.fn_ret_ty, template.type_params, args);
    sret = resolve_assoc_recursive(g, sret);
    synth.fn_ret_ty = sret;
    // The mono may have introduced ?T / !T / ?!T inners that the up-front
    // collection pass never saw (it skipped the generic template body).
    // Register them now and emit runtime helpers inline so the forward decl
    // and body that follow can reference the typedef.
    collect_result_in_type(g, sret);
    if template.fn_params != null {
        let ps: *Vector<Param> = Vector::new();
        for let i: i32 = 0; i < template.fn_params.len(); i++ {
            let p: Param = template.fn_params.get(i);
            let pt: *Type = subst_type(p.ty, template.type_params, args);
            let resolved: *Type = resolve_assoc_recursive(g, pt);
            collect_result_in_type(g, resolved);
            let np: Param = Param { name: p.name, ty: resolved, name_line: p.name_line, name_col: p.name_col };
            ps.push(np);
        }
        synth.fn_params = ps;
    }
    g.fns.insert(mangled, *synth);
    // The mono may have introduced ?T / !T / ?!T inners that the up-front
    // collection pass never saw (it skipped the generic template body).
    // Collect them now and re-emit runtime helpers; the templates carry
    // header guards so re-emission of an existing inner is a no-op for cc.
    collect_result_in_type(g, sret);
    if synth.fn_params != null {
        for let i: i32 = 0; i < synth.fn_params.len(); i++ {
            let p: Param = synth.fn_params.get(i);
            collect_result_in_type(g, p.ty);
        }
    }
    emit_result_runtime(g);
    emit_option_runtime(g);
    emit_optres_runtime(g);
}

fn emit_mono_forward_decl(g: *CG, mangled: string, template: *Stmt, args: *Vector<Type>) {
    let mut new_ret: *Type = subst_type(template.fn_ret_ty, template.type_params, args);
    new_ret = resolve_assoc_recursive(g, new_ret);
    print!(type_to_c(new_ret), " ", mangled, "(");
    if template.fn_params == null || template.fn_params.len() == 0 {
        print!("void");
    } else {
        for let j: i32 = 0; j < template.fn_params.len(); j++ {
            if j > 0 { print!(", "); }
            let pp: Param = template.fn_params.get(j);
            let pt: *Type = subst_type(pp.ty, template.type_params, args);
            let resolved_pt: *Type = resolve_assoc_recursive(g, pt);
            print!(type_to_c(resolved_pt), " ", c_safe_ident(pp.name));
        }
    }
    println!(");");
}

// Unify a generic pattern type against a concrete type. Adds bindings for
// matching type vars listed in `params`. Returns false on mismatch (currently
// permissive: doesn't fail, just collects what it can).
fn unify_for_inference(pat: *Type, actual: *Type, params: *Vector<string>, bindings: *HashMap<Type>) {
    if pat == null { return; }
    if actual == null { return; }
    if pat.kind == TY_NAMED {
        // Type var?
        if params != null {
            for let i: i32 = 0; i < params.len(); i++ {
                if pat.name.eq(params.get(i)) {
                    if !bindings.contains(pat.name) {
                        bindings.insert(pat.name, *actual);
                    }
                    return;
                }
            }
        }
    }
    if pat.kind == TY_POINTER && actual.kind == TY_POINTER {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_BORROW && actual.kind == TY_BORROW {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_BORROW_MUT && actual.kind == TY_BORROW_MUT {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_SLICE && actual.kind == TY_SLICE {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_GENERIC && actual.kind == TY_GENERIC {
        if pat.name.eq(actual.name) && pat.args != null && actual.args != null
            && pat.args.len() == actual.args.len() {
            for let i: i32 = 0; i < pat.args.len(); i++ {
                let pa: Type = pat.args.get(i);
                let aa: Type = actual.args.get(i);
                unify_for_inference(&pa, &aa, params, bindings);
            }
        }
    }
    if pat.kind == TY_OPTION && actual.kind == TY_OPTION {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_RESULT && actual.kind == TY_RESULT {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_OPT_RESULT && actual.kind == TY_OPT_RESULT {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    // Fn-pointer types: `fn(T) -> U` against `fn(int) -> string` should
    // bind T=int, U=string. Without this case, generic fns like
    // `iter_map<T, U>(v: *Vector<T>, f: fn(T) -> U) -> *Vector<U>` couldn't
    // infer U from the fn-pointer arg's return type.
    if pat.kind == TY_FNPTR && actual.kind == TY_FNPTR {
        if pat.args != null && actual.args != null
           && pat.args.len() == actual.args.len() {
            for let i: i32 = 0; i < pat.args.len(); i++ {
                let pa: Type = pat.args.get(i);
                let aa: Type = actual.args.get(i);
                unify_for_inference(&pa, &aa, params, bindings);
            }
        }
        if pat.fnptr_ret != null && actual.fnptr_ret != null {
            unify_for_inference(pat.fnptr_ret, actual.fnptr_ret, params, bindings);
        }
    }
}

// Recursive type substitution: walk t, replacing Type::Named(n) with the
// matching arg from `params -> args` mapping.
fn subst_type(t: *Type, params: *Vector<string>, args: *Vector<Type>) -> *Type {
    if t == null { return null; }
    if t.kind == TY_NAMED {
        if params != null {
            for let i: i32 = 0; i < params.len(); i++ {
                if t.name.eq(params.get(i)) {
                    let a: Type = args.get(i);
                    let p: *Type = malloc(sizeof(Type)) as *Type;
                    *p = a;
                    return p;
                }
            }
        }
        return t;
    }
    if t.kind == TY_POINTER { return ty_pointer(subst_type(t.inner, params, args)); }
    if t.kind == TY_BORROW {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW; p.inner = subst_type(t.inner, params, args);
        return p;
    }
    if t.kind == TY_BORROW_MUT {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW_MUT; p.inner = subst_type(t.inner, params, args);
        return p;
    }
    if t.kind == TY_SLICE {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_SLICE; p.inner = subst_type(t.inner, params, args);
        return p;
    }
    if t.kind == TY_GENERIC {
        let new_args: *Vector<Type> = Vector::new();
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                let na: *Type = subst_type(&a, params, args);
                if na != null { new_args.push(*na); }
            }
        }
        return ty_generic(t.name, new_args);
    }
    if t.kind == TY_OPTION { return ty_option(subst_type(t.inner, params, args)); }
    if t.kind == TY_RESULT { return ty_result(subst_type(t.inner, params, args)); }
    if t.kind == TY_OPT_RESULT { return ty_optres(subst_type(t.inner, params, args)); }
    if t.kind == TY_TUPLE {
        let new_args: *Vector<Type> = Vector::new();
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                let na: *Type = subst_type(&a, params, args);
                if na != null { new_args.push(*na); }
            }
        }
        return ty_tuple(new_args);
    }
    if t.kind == TY_FNPTR {
        let new_args: *Vector<Type> = Vector::new();
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                let na: *Type = subst_type(&a, params, args);
                if na != null { new_args.push(*na); }
            }
        }
        let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
        p.kind = TY_FNPTR;
        p.args = new_args;
        p.fnptr_ret = subst_type(t.fnptr_ret, params, args);
        return p;
    }
    if t.kind == TY_ASSOC {
        // Substitute the owner; the assoc lookup itself happens later when
        // the owner is fully concrete (typer/codegen impl-table consult).
        let new_owner: *Type = subst_type(t.inner, params, args);
        return ty_assoc(new_owner, t.name);
    }
    return t;
}

// Substitute type params in an expression. Walks structurally and also
// rewrites EX_STRUCT_LIT for known generic structs (so `Box{}` inside a mono
// body becomes `Box__int{}`).
fn subst_expr(e: *Expr, params: *Vector<string>, args: *Vector<Type>, gs: *HashMap<Stmt>) -> *Expr {
    if e == null { return null; }
    let n: *Expr = calloc(1, sizeof(Expr)) as *Expr;
    *n = *e;
    if e.cast_to != null { n.cast_to = subst_type(e.cast_to, params, args); }
    if e.lhs != null { n.lhs = subst_expr(e.lhs, params, args, gs); }
    if e.rhs != null { n.rhs = subst_expr(e.rhs, params, args, gs); }
    if e.operand != null { n.operand = subst_expr(e.operand, params, args, gs); }
    if e.args != null {
        let new_args: *Vector<Expr> = Vector::new();
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            let nu: *Expr = subst_expr(&a, params, args, gs);
            if nu != null { new_args.push(*nu); }
        }
        n.args = new_args;
    }
    // Rewrite struct lit type_name when matches a known generic struct AND
    // the substitution provides as many args as the struct expects.
    if e.kind == EX_STRUCT_LIT && gs != null && gs.contains(e.str_val) {
        let template: Stmt = gs.get(e.str_val);
        if template.type_params != null && args != null
           && template.type_params.len() == args.len() {
            n.str_val = mangle_generic(e.str_val, args);
        }
    }
    // Rewrite `T::method` when T is one of this fn's type parameters.
    // At mono time T is concrete; emit the path with the substituted
    // type name (e.g. `T::from_json` -> `int::from_json` for T=int)
    // so the existing EX_PATH codegen lowers it to the right symbol.
    if e.kind == EX_PATH && params != null && args != null {
        for let i: i32 = 0; i < params.len(); i++ {
            if params.get(i).eq(e.str_val) && i < args.len() {
                let a: Type = args.get(i);
                n.str_val = mangle_type(&a);
                break;
            }
        }
    }
    return n;
}

fn subst_stmt(s: *Stmt, params: *Vector<string>, args: *Vector<Type>, gs: *HashMap<Stmt>) -> *Stmt {
    if s == null { return null; }
    let n: *Stmt = calloc(1, sizeof(Stmt)) as *Stmt;
    *n = *s;
    if s.let_ty != null { n.let_ty = subst_type(s.let_ty, params, args); }
    if s.let_value != null { n.let_value = subst_expr(s.let_value, params, args, gs); }
    if s.expr_value != null { n.expr_value = subst_expr(s.expr_value, params, args, gs); }
    if s.cond != null { n.cond = subst_expr(s.cond, params, args, gs); }
    if s.for_init != null { n.for_init = subst_stmt(s.for_init, params, args, gs); }
    if s.for_step != null { n.for_step = subst_expr(s.for_step, params, args, gs); }
    if s.fn_ret_ty != null { n.fn_ret_ty = subst_type(s.fn_ret_ty, params, args); }
    if s.then_body != null {
        let nb: *Vector<Stmt> = Vector::new();
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            let nu: *Stmt = subst_stmt(&b, params, args, gs);
            if nu != null { nb.push(*nu); }
        }
        n.then_body = nb;
    }
    if s.else_body != null {
        let nb: *Vector<Stmt> = Vector::new();
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            let nu: *Stmt = subst_stmt(&b, params, args, gs);
            if nu != null { nb.push(*nu); }
        }
        n.else_body = nb;
    }
    if s.fn_body != null {
        let nb: *Vector<Stmt> = Vector::new();
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            let nu: *Stmt = subst_stmt(&b, params, args, gs);
            if nu != null { nb.push(*nu); }
        }
        n.fn_body = nb;
    }
    return n;
}

fn op_to_c(op: i32) -> string {
    if op == OP_ADD { return "+"; }
    if op == OP_SUB { return "-"; }
    if op == OP_MUL { return "*"; }
    if op == OP_DIV { return "/"; }
    if op == OP_MOD { return "%"; }
    if op == OP_EQ  { return "=="; }
    if op == OP_NE  { return "!="; }
    if op == OP_LT  { return "<"; }
    if op == OP_LE  { return "<="; }
    if op == OP_GT  { return ">"; }
    if op == OP_GE  { return ">="; }
    if op == OP_AND { return "&&"; }
    if op == OP_OR  { return "||"; }
    if op == OP_BIT_AND { return "&"; }
    if op == OP_BIT_OR  { return "|"; }
    if op == OP_BIT_XOR { return "^"; }
    if op == OP_SHL { return "<<"; }
    if op == OP_SHR { return ">>"; }
    if op == OP_ASSIGN       { return "="; }
    if op == OP_PLUS_ASSIGN  { return "+="; }
    if op == OP_MINUS_ASSIGN { return "-="; }
    if op == OP_STAR_ASSIGN  { return "*="; }
    if op == OP_SLASH_ASSIGN { return "/="; }
    return "?";
}

fn unop_to_c(op: i32) -> string {
    if op == UN_NEG { return "-"; }
    if op == UN_NOT { return "!"; }
    if op == UN_BIT_NOT { return "~"; }
    if op == UN_DEREF { return "*"; }
    if op == UN_ADDR { return "&"; }
    if op == UN_ADDR_MUT { return "&"; }
    return "?";
}

// ---- printing helpers (just print! to stdout) ----------------------------

fn ind(n: i32) {
    for let i: i32 = 0; i < n; i++ { print!("    "); }
}

// `@cfg("windows")` / `@cfg("posix")` brackets a top-level decl with a cpp
// guard so per-platform fns (typically naked asm context switches) compile
// only on the right OS. No-op when cfg is empty.
fn emit_cfg_open(cfg: string) {
    if cfg.eq("windows") { println!("#ifdef _WIN32"); }
    else if cfg.eq("posix") { println!("#ifndef _WIN32"); }
}
fn emit_cfg_close(cfg: string) {
    if cfg.eq("windows") || cfg.eq("posix") { println!("#endif"); }
}

// Yield-expression of a match arm body: either a single ST_EXPR (the
// arm wrote `=> expr`) or a block whose trailing `return val;` is the
// value (the arm wrote `=> { stmts; return val; }`).
fn arm_value_expr(a: *MatchArm) -> *Expr {
    if a.body == null || a.body.len() == 0 { return null; }
    let last: Stmt = a.body.get(a.body.len() - 1);
    if last.kind == ST_RETURN { return last.expr_value; }
    if last.kind == ST_EXPR { return last.expr_value; }
    return null;
}

fn arm_value_type(g: *CG, a: *MatchArm) -> *Type {
    let v: *Expr = arm_value_expr(a);
    if v == null { return ty_named("i32"); }
    return infer_for_codegen(g, v);
}

fn emit_match_arm_value(g: *CG, a: *MatchArm) {
    if a.body == null { print!("__r = 0;"); return; }
    let last_idx: i32 = a.body.len() - 1;
    for let k: i32 = 0; k < last_idx; k++ {
        let b: Stmt = a.body.get(k);
        emit_stmt(g, &b, 0);
    }
    let v: *Expr = arm_value_expr(a);
    print!("__r = (");
    if v != null { emit_expr(g, v); } else { print!("0"); }
    print!(");");
}

// Probe expression GCC's `__typeof__` resolves to compute the EX_MATCH
// result type. Walks the first arm's value in a sibling stmt-expr that
// declares the same payload bindings — `__typeof__` evaluates the type
// at compile time without executing the body, so the payload reads
// give correct types even though no scrutinee value flows through.
fn emit_arm_typeof_probe(g: *CG, arms: *Vector<MatchArm>) {
    if arms == null || arms.len() == 0 { print!("(int)0"); return; }
    let a: MatchArm = arms.get(0);
    print!("({ ");
    if a.bindings != null && a.bindings.len() > 0 {
        if a.bindings.len() == 1 {
            let payload: string = "__m.data.v_".concat(a.variant);
            print!("__typeof__("); print!(payload); print!(") ");
            print!(c_safe_ident(a.bindings.get(0))); print!(" = "); print!(payload); print!("; ");
        } else {
            for let k: i32 = 0; k < a.bindings.len(); k++ {
                let payload: string = "__m.data.v_".concat(a.variant);
                print!("__typeof__("); print!(payload); print!(".f"); print!(k); print!(") ");
                print!(c_safe_ident(a.bindings.get(k))); print!(" = "); print!(payload); print!(".f"); print!(k); print!("; ");
            }
        }
    }
    let v: *Expr = arm_value_expr(&a);
    print!("(");
    if v != null { emit_expr(g, v); } else { print!("0"); }
    print!("); })");
}

// True iff `t` is `*dyn Trait` — i.e. a pointer to a dyn trait
// object. The C representation is the fat-pointer struct
// `__glide_dyn_<Trait>` (vtable + data), not a raw pointer, so any
// site that handles `null` against this type needs special-casing
// (struct-zero-init for assignment; .vtable field for compare).
fn _is_dyn_ptr(t: *Type) -> bool {
    if t == null { return false; }
    if t.kind != TY_POINTER { return false; }
    if t.inner == null { return false; }
    return t.inner.kind == TY_DYN;
}

// Emit a "null" appropriate for the expected type. For `*dyn Trait`
// the fat-pointer struct gets zero-initialised (vtable=NULL,
// data=NULL); for everything else, plain `NULL`.
fn _emit_null_for(t: *Type) {
    if _is_dyn_ptr(t) {
        print!("((", type_to_c(t), "){0})");
        return;
    }
    print!("NULL");
}

// Look up the type of `field_name` on `struct_name` via g.structs.
// Returns null when the struct or field isn't found (codegen falls
// back to plain NULL emit, which is the existing behaviour).
fn _field_ty_in_struct(g: *CG, struct_name: string, field_name: string) -> *Type {
    if g.structs == null || !g.structs.contains(struct_name) { return null; }
    let sd: Stmt = g.structs.get(struct_name);
    if sd.struct_fields == null { return null; }
    for let i: i32 = 0; i < sd.struct_fields.len(); i++ {
        let f: Field = sd.struct_fields.get(i);
        if f.name.eq(field_name) {
            let p: *Type = malloc(sizeof(Type)) as *Type;
            *p = *f.ty;
            return p;
        }
    }
    return null;
}

// ---- expressions ---------------------------------------------------------

pub fn emit_expr(g: *CG, e: *Expr) {
    if e == null { print!("/* null */"); return; }
    if e.kind == EX_INT { print!(e.int_val); return; }
    if e.kind == EX_FLOAT { print!(e.float_val); return; }
    if e.kind == EX_STRING { print!("\""); print!(e.str_val); print!("\""); return; }
    if e.kind == EX_CHAR {
        // Emit as `(char)NNN` decimal — C interprets `'\xNN'` as hex digits,
        // not decimal, so a decimal int_val would silently re-encode.
        print!("(char)"); print!(e.int_val); return;
    }
    if e.kind == EX_BOOL { if e.bool_val { print!("true"); } else { print!("false"); } return; }
    if e.kind == EX_NULL { print!("NULL"); return; }
    if e.kind == EX_IDENT { print!(c_safe_ident(e.str_val)); return; }
    if e.kind == EX_IF {
        // Lower expression-position if to a C ternary. Both branches
        // are guaranteed to be single expressions by the parser, so
        // they fit cleanly. Nested else-if chains nest naturally:
        // `(c1 ? a : (c2 ? b : c))`.
        print!("(");
        emit_expr(g, e.lhs);
        print!(" ? ");
        emit_expr(g, e.rhs);
        print!(" : ");
        if e.operand != null { emit_expr(g, e.operand); } else { print!("0"); }
        print!(")");
        return;
    }
    if e.kind == EX_BLOCK {
        // GCC statement-expression `({ stmts; value; })`. Stmts run for
        // side effects; trailing comma-expr yields the value.
        print!("({ ");
        if e.block_stmts != null {
            for let i: i32 = 0; i < e.block_stmts.len(); i++ {
                let b: Stmt = e.block_stmts.get(i);
                emit_stmt(g, &b, 0);
            }
        }
        print!("(");
        if e.operand != null { emit_expr(g, e.operand); } else { print!("0"); }
        print!("); })");
        return;
    }
    if e.kind == EX_MATCH {
        // GCC stmt-expr lowering. The result type is inferred via
        // `__typeof__` over the first arm's value evaluated in a sibling
        // stmt-expr — GCC computes the type at compile time without
        // running the body, so payload bindings resolve naturally.
        let scrut_ty: *Type = infer_for_codegen(g, e.lhs);
        let mut enum_name: string = "X";
        if scrut_ty != null && scrut_ty.kind == TY_NAMED { enum_name = scrut_ty.name; }
        print!("({ ");
        print!(enum_name); print!(" __m = ");
        emit_expr(g, e.lhs);
        print!("; ");
        print!("__typeof__(");
        emit_arm_typeof_probe(g, e.match_arms);
        print!(") __r; ");
        print!("switch (__m.tag) { ");
        if e.match_arms != null {
            for let i: i32 = 0; i < e.match_arms.len(); i++ {
                let a: MatchArm = e.match_arms.get(i);
                if a.variant.eq("_") { print!("default: "); }
                else { print!("case "); print!(enum_name); print!("_"); print!(a.variant); print!(": "); }
                print!("{ ");
                if a.bindings != null && a.bindings.len() > 0 {
                    if a.bindings.len() == 1 {
                        let payload: string = "__m.data.v_".concat(a.variant);
                        print!("__typeof__("); print!(payload); print!(") ");
                        print!(c_safe_ident(a.bindings.get(0))); print!(" = "); print!(payload); print!("; ");
                    } else {
                        for let k: i32 = 0; k < a.bindings.len(); k++ {
                            let payload: string = "__m.data.v_".concat(a.variant);
                            print!("__typeof__("); print!(payload); print!(".f"); print!(k); print!(") ");
                            print!(c_safe_ident(a.bindings.get(k))); print!(" = "); print!(payload); print!(".f"); print!(k); print!("; ");
                        }
                    }
                }
                emit_match_arm_value(g, &a);
                print!(" break; } ");
            }
        }
        print!("} __r; })");
        return;
    }
    if e.kind == EX_BINARY {
        if e.op_code == OP_COALESCE {
            // `??` fallback. LHS is ?T or !T. RHS is either a plain value
            // (yields T) or an `err(...)` call (yields !T, intended to be
            // chained with `?`). Detect the err() form by looking at the
            // RHS Expr shape — if it's a bare `err(s)` call we stay in
            // Result-shape; otherwise we extract the inner value.
            let lt: *Type = infer_for_codegen(g, e.lhs);
            let mut is_err_form: bool = false;
            if e.rhs != null && e.rhs.kind == EX_CALL && e.rhs.lhs != null
                && e.rhs.lhs.kind == EX_IDENT && e.rhs.lhs.str_val.eq("err") {
                is_err_form = true;
            }
            if lt != null && lt.kind == TY_OPTION {
                let m_in: string = mangle_type(lt.inner);
                if is_err_form {
                    // Substitute the None branch with an Err of the same inner
                    // type — caller will use `?` to propagate.
                    let m_out: string = m_in;
                    let arg: Expr = e.rhs.args.get(0);
                    print!("({ __glide_option_".concat(m_in).concat("_t __o = ("));
                    emit_expr(g, e.lhs);
                    print!("); __r_lift_t_".concat(m_out)
                        .concat("("));
                    // Fallback: emit ternary directly into __glide_err_<m>.
                    // Simpler form below avoids needing a per-T helper:
                    // (we re-emit the expression instead)
                }
                // Plain fallback: extract the inner.
                if !is_err_form {
                    print!("({ __glide_option_".concat(m_in).concat("_t __o = ("));
                    emit_expr(g, e.lhs);
                    print!("); __o.has ? __o.val : (");
                    emit_expr(g, e.rhs);
                    print!("); })");
                    return;
                }
                // is_err_form: substitute None → Err. Result is __glide_result_<T>_t.
                print!("({ __glide_option_".concat(m_in).concat("_t __o = ("));
                emit_expr(g, e.lhs);
                print!("); __o.has ? __glide_ok_".concat(m_in).concat("(__o.val) : __glide_err_").concat(m_in).concat("("));
                let arg: Expr = e.rhs.args.get(0);
                emit_expr(g, &arg);
                print!("); })");
                return;
            }
            if lt != null && lt.kind == TY_RESULT {
                let m_in: string = mangle_type(lt.inner);
                if !is_err_form {
                    print!("({ __glide_result_".concat(m_in).concat("_t __r = ("));
                    emit_expr(g, e.lhs);
                    print!("); __r.ok ? __r.val : (");
                    emit_expr(g, e.rhs);
                    print!("); })");
                    return;
                }
                // Replace existing Err msg with the new one.
                print!("({ __glide_result_".concat(m_in).concat("_t __r = ("));
                emit_expr(g, e.lhs);
                print!("); __r.ok ? __r : __glide_err_".concat(m_in).concat("("));
                let arg: Expr = e.rhs.args.get(0);
                emit_expr(g, &arg);
                print!("); })");
                return;
            }
            // Pointer nullable: `*T ?? default` → null check.
            if lt != null && lt.kind == TY_POINTER {
                let tc: string = type_to_c(lt);
                print!("({ ".concat(tc).concat(" __p = ("));
                emit_expr(g, e.lhs);
                print!("); __p ? __p : (");
                emit_expr(g, e.rhs);
                print!("); })");
                return;
            }
            // Fallback: simple ternary using a non-zero-ness of LHS.
            print!("(("); emit_expr(g, e.lhs); print!(") ? ("); emit_expr(g, e.lhs);
            print!(") : ("); emit_expr(g, e.rhs); print!("))");
            return;
        }
        // `*dyn Trait` compares to null: the C representation is a
        // fat-pointer struct, so `(x == NULL)` doesn't compile.
        // Translate to a check on the `vtable` slot (NULL when the
        // dyn was zero-initialised, set to a real vtable otherwise).
        if e.op_code == OP_EQ || e.op_code == OP_NE {
            let lt: *Type = infer_for_codegen(g, e.lhs);
            let rt: *Type = infer_for_codegen(g, e.rhs);
            let lhs_dyn: bool = _is_dyn_ptr(lt);
            let rhs_dyn: bool = _is_dyn_ptr(rt);
            let lhs_null: bool = e.lhs != null && e.lhs.kind == EX_NULL;
            let rhs_null: bool = e.rhs != null && e.rhs.kind == EX_NULL;
            if lhs_dyn && rhs_null {
                print!("(("); emit_expr(g, e.lhs); print!(").vtable ", op_to_c(e.op_code), " NULL)");
                return;
            }
            if rhs_dyn && lhs_null {
                print!("(NULL ", op_to_c(e.op_code), " (");
                emit_expr(g, e.rhs); print!(").vtable)");
                return;
            }
        }
        // 256-bit ints are software structs; C `+`/`<`/... don't apply, so
        // route every operator to its `__glide_<ty>_<op>` runtime helper.
        let mut bn256: string = _u256_ty(infer_for_codegen(g, e.lhs));
        if bn256.eq("") { bn256 = _u256_ty(infer_for_codegen(g, e.rhs)); }
        if !bn256.eq("") {
            if e.op_code == OP_EQ || e.op_code == OP_NE || e.op_code == OP_LT
               || e.op_code == OP_LE || e.op_code == OP_GT || e.op_code == OP_GE {
                print!("(__glide_".concat(bn256).concat("_cmp("));
                emit_expr(g, e.lhs); print!(", "); emit_expr(g, e.rhs);
                print!(") ", op_to_c(e.op_code), " 0)");
                return;
            }
            let afn: string = _u256_arith_fn(e.op_code);
            if !afn.eq("") {
                print!("__glide_".concat(bn256).concat("_").concat(afn).concat("("));
                emit_expr(g, e.lhs); print!(", "); emit_expr(g, e.rhs);
                print!(")");
                return;
            }
        }
        print!("(");
        emit_expr(g, e.lhs);
        print!(" ", op_to_c(e.op_code), " ");
        emit_expr(g, e.rhs);
        print!(")");
        return;
    }
    if e.kind == EX_UNARY {
        if e.op_code == UN_TRY {
            // Postfix `?`: GCC stmt-expr that unpacks the Result/Option/OptRes
            // in the current fn. The dispatch matrix:
            //   inner !T  in fn !U   -> propagate Err
            //   inner ?T  in fn ?U   -> propagate None
            //   inner ?T  in fn !U   -> coerce None -> Err{"none-coerced"}
            //   inner ?T  in fn ?!U  -> propagate None
            //   inner ?!T in fn ?!U  -> propagate Err and None
            //   inner ?!T in fn !U   -> propagate Err; None coerces
            // err-defer cleanups fire on every propagating arm.
            let inner_ty: *Type = infer_for_codegen(g, e.operand);
            let ret_ty: *Type = g.current_ret_ty;
            if inner_ty == null || ret_ty == null {
                print!("/* invalid `?` */ 0");
                return;
            }
            let inner_kind: i32 = inner_ty.kind;
            let ret_kind: i32 = ret_ty.kind;
            if inner_kind != TY_RESULT && inner_kind != TY_OPTION && inner_kind != TY_OPT_RESULT {
                print!("/* invalid `?` */ 0");
                return;
            }
            if ret_kind != TY_RESULT && ret_kind != TY_OPTION && ret_kind != TY_OPT_RESULT {
                print!("/* invalid `?` */ 0");
                return;
            }
            let m_in: string = mangle_type(inner_ty.inner);
            let m_out: string = mangle_type(ret_ty.inner);
            // Pick struct typedef + propagation snippets per (inner, ret) combo.
            let mut struct_pref: string = "__glide_result_";
            if inner_kind == TY_OPTION { struct_pref = "__glide_option_"; }
            if inner_kind == TY_OPT_RESULT { struct_pref = "__glide_optres_"; }
            print!("({ ".concat(struct_pref).concat(m_in).concat("_t __r = ("));
            emit_expr(g, e.operand);
            print!("); ");
            // Build the err/none-propagation block(s) for this combo.
            // Common err-defer prelude for any propagating arm.
            let nd: i32 = g.err_defer_stack.len();
            // Helper: write defer drains.
            // Inner = !T: check !__r.ok, propagate Err.
            if inner_kind == TY_RESULT {
                print!("if (!__r.ok) { ");
                for let i: i32 = nd - 1; i >= 0; i = i - 1 {
                    let ex: Expr = g.err_defer_stack.get(i);
                    emit_expr(g, &ex);
                    print!("; ");
                }
                if ret_kind == TY_RESULT {
                    print!("return __glide_err_".concat(m_out).concat("(__r.err); } __r.val; })"));
                } else if ret_kind == TY_OPT_RESULT {
                    print!("return __glide_optres_err_".concat(m_out).concat("(__r.err); } __r.val; })"));
                } else {
                    // ?U fn cannot represent Err — typer should have rejected.
                    print!("return __glide_none_".concat(m_out).concat("(); } __r.val; })"));
                }
                return;
            }
            // Inner = ?T: check !__r.has, propagate None (or coerce).
            if inner_kind == TY_OPTION {
                print!("if (!__r.has) { ");
                for let i: i32 = nd - 1; i >= 0; i = i - 1 {
                    let ex: Expr = g.err_defer_stack.get(i);
                    emit_expr(g, &ex);
                    print!("; ");
                }
                if ret_kind == TY_OPTION {
                    print!("return __glide_none_".concat(m_out).concat("(); } __r.val; })"));
                } else if ret_kind == TY_OPT_RESULT {
                    print!("return __glide_optres_none_".concat(m_out).concat("(); } __r.val; })"));
                } else {
                    // !U fn: coerce None → Err{"none-coerced"}.
                    print!("return __glide_err_".concat(m_out).concat("(\"none-coerced\"); } __r.val; })"));
                }
                return;
            }
            // Inner = ?!T: dispatch on tag. 0=Some, 1=None, 2=Err.
            print!("if (__r.tag != 0) { ");
            for let i: i32 = nd - 1; i >= 0; i = i - 1 {
                let ex: Expr = g.err_defer_stack.get(i);
                emit_expr(g, &ex);
                print!("; ");
            }
            if ret_kind == TY_OPT_RESULT {
                print!("__glide_optres_".concat(m_out)
                    .concat("_t __pr; __pr.tag = __r.tag; __pr.err = __r.err; return __pr; } __r.val; })"));
            } else if ret_kind == TY_RESULT {
                // None coerces to Err{"none-coerced"}; Err passes msg through.
                print!("if (__r.tag == 1) return __glide_err_".concat(m_out).concat("(\"none-coerced\"); ")
                    .concat("return __glide_err_").concat(m_out).concat("(__r.err); } __r.val; })"));
            } else {
                // ?U fn: drop Err msg, propagate None.
                print!("return __glide_none_".concat(m_out).concat("(); } __r.val; })"));
            }
            return;
        }
        print!("(".concat(unop_to_c(e.op_code)));
        emit_expr(g, e.operand);
        print!(")");
        return;
    }
    if e.kind == EX_ASSIGN {
        print!("(");
        emit_expr(g, e.lhs);
        print!(" ", op_to_c(e.op_code), " ");
        emit_expr(g, e.rhs);
        print!(")");
        return;
    }
    if e.kind == EX_CALL {
        // 256-bit constructors: `u256::from(n)` / `i256::from(n)` build the
        // software struct from an int (printf/`=` can't, since it's a struct).
        if e.lhs != null && e.lhs.kind == EX_PATH && e.lhs.field.eq("from")
           && (e.lhs.str_val.eq("u256") || e.lhs.str_val.eq("i256")) {
            print!("__glide_".concat(e.lhs.str_val).concat("_from_i64("));
            if e.args != null && e.args.len() > 0 {
                let a0: Expr = e.args.get(0);
                emit_expr(g, &a0);
            }
            print!(")");
            return;
        }
        // Enum ctor: `Shape::Circle(5)` → struct lit. Also accepts the
        // module-qualified form `mod::path::Shape::Circle(5)` by resolving
        // the prefix back to the bare enum name first. Only fires when the
        // trailing segment is actually a variant of the enum - otherwise
        // it's an `impl <Enum> { fn from_int(...) }` method call and the
        // normal call path handles it.
        let mut _is_enum_ctor: bool = false;
        let mut _ec_ename: string = "";
        if e.lhs != null && e.lhs.kind == EX_PATH {
            let mut probe: string = e.lhs.str_val;
            if !g.enums.contains(probe) { probe = resolve_type_prefix(g, probe); }
            if g.enums.contains(probe) {
                let edef: Stmt = g.enums.get(probe);
                if edef.enum_variants != null {
                    for let vi: i32 = 0; vi < edef.enum_variants.len(); vi++ {
                        let v: EnumVariant = edef.enum_variants.get(vi);
                        if v.name.eq(e.lhs.field) { _is_enum_ctor = true; break; }
                    }
                }
                if _is_enum_ctor { _ec_ename = probe; }
            }
        }
        if _is_enum_ctor {
            let mut ename: string = _ec_ename;
            let vname: string = e.lhs.field;
            print!("((");
            print!(ename);
            print!("){.tag = ");
            print!(ename.concat("_").concat(vname));
            if e.args != null && e.args.len() > 0 {
                if e.args.len() == 1 {
                    print!(", .data.v_");
                    print!(vname);
                    print!(" = ");
                    let a: Expr = e.args.get(0);
                    emit_expr(g, &a);
                } else {
                    print!(", .data.v_");
                    print!(vname);
                    print!(" = {");
                    for let i: i32 = 0; i < e.args.len(); i++ {
                        if i > 0 { print!(", "); }
                        let a: Expr = e.args.get(i);
                        emit_expr(g, &a);
                    }
                    print!("}");
                }
            }
            print!("})");
            return;
        }

        // ---- chan method-style: rewrite `c.send(x)` / `c.recv()` /
        // `c.close()` to the same lowering as `send(c, x)` etc.
        if e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.lhs != null {
            let mname: string = e.lhs.field;
            let recv_e: *Expr = e.lhs.lhs;
            let recv_ty: *Type = infer_for_codegen(g, recv_e);
            let stripped: *Type = strip_ptr(recv_ty);
            if stripped != null && stripped.kind == TY_GENERIC && stripped.name.eq("chan")
               && stripped.args != null && stripped.args.len() > 0 {
                let inner: Type = stripped.args.get(0);
                let m: string = mangle_type(&inner);
                let mut nargs: i32 = 0;
                if e.args != null { nargs = e.args.len(); }
                // `chan<T>` lowers to `__glide_chan_T_t*` on the C side
                // already, so the send/recv/close helpers want one level
                // of pointer. A Glide-side `*chan<T>` (or `**chan<T>`)
                // adds extra indirection — emit one deref per pointer
                // wrapper to drop back to the helper's expected shape.
                let mut deref_n: i32 = 0;
                let mut t: *Type = recv_ty;
                while t != null && (t.kind == TY_POINTER
                                || t.kind == TY_BORROW || t.kind == TY_BORROW_MUT) {
                    deref_n = deref_n + 1;
                    t = t.inner;
                }
                if mname.eq("send") && nargs == 1 {
                    print!("__glide_send_".concat(m).concat("("));
                    _emit_chan_recv(g, recv_e, deref_n);
                    print!(", ");
                    let v: Expr = e.args.get(0);
                    emit_expr(g, &v);
                    print!(")");
                    return;
                }
                if mname.eq("recv") && nargs == 0 {
                    print!("__glide_recv_".concat(m).concat("("));
                    _emit_chan_recv(g, recv_e, deref_n);
                    print!(")");
                    return;
                }
                if mname.eq("close") && nargs == 0 {
                    print!("__glide_close_".concat(m).concat("("));
                    _emit_chan_recv(g, recv_e, deref_n);
                    print!(")");
                    return;
                }
            }
        }

        // ---- chan builtins: make_chan / send / recv / close ----
        if e.lhs != null && e.lhs.kind == EX_IDENT && e.args != null {
            let cname: string = e.lhs.str_val;
            if cname.eq("unwrap") && e.args.len() == 1 {
                let r0: Expr = e.args.get(0);
                let rt: *Type = infer_for_codegen(g, &r0);
                if rt != null && rt.kind == TY_RESULT {
                    let m: string = mangle_type(rt.inner);
                    print!("__glide_unwrap_".concat(m).concat("("));
                    emit_expr(g, &r0);
                    print!(")");
                    return;
                }
            }
        }

        // Try generic monomorphization based on arg types (no ret-hint here).
        let no_mono_hint: *Type = null;
        let _mono_ok: bool = try_mono_call(g, e, no_mono_hint);

        // Method call: callee is a Member. Rewrite to Type_method(receiver, args).
        if e.lhs != null && e.lhs.kind == EX_MEMBER {
            let recv: *Expr = e.lhs.lhs;
            let method: string = e.lhs.field;
            let recv_ty: *Type = infer_for_codegen(g, recv);
            let stripped: *Type = strip_ptr(recv_ty);

            // Trait-object dispatch: receiver is `*dyn Trait` (fat pointer
            // struct). Look the method up in the vtable at runtime.
            if stripped != null && stripped.kind == TY_DYN {
                print!("((");
                emit_expr(g, recv);
                print!(").vtable->".concat(method).concat("(("));
                emit_expr(g, recv);
                print!(").data");
                if e.args != null {
                    for let i: i32 = 0; i < e.args.len(); i++ {
                        print!(", ");
                        let a: Expr = e.args.get(i);
                        emit_expr(g, &a);
                    }
                }
                print!("))");
                return;
            }

            // Specialized concrete impl (e.g. `impl Vector<int> { fn sum() }`).
            // The mangled prefix `Vector__int` already exists in g.fns as a
            // concrete fn — emit a direct call, no mono needed. Wins over the
            // generic family below when both define the same method name.
            if stripped != null && stripped.kind == TY_GENERIC {
                let spec_prefix: string = mangle_generic(stripped.name, stripped.args);
                let spec_name: string = spec_prefix.concat("_").concat(method);
                if g.fns.contains(spec_name) {
                    print!(spec_name);
                    print!("(");
                    let spec_needs_addr: bool = recv_ty != null
                        && recv_ty.kind != TY_POINTER
                        && recv_ty.kind != TY_BORROW
                        && recv_ty.kind != TY_BORROW_MUT;
                    if spec_needs_addr { print!("&"); }
                    emit_expr(g, recv);
                    if e.args != null {
                        for let i: i32 = 0; i < e.args.len(); i++ {
                            print!(", ");
                            let a: Expr = e.args.get(i);
                            emit_expr(g, &a);
                        }
                    }
                    print!(")");
                    return;
                }
            }

            // Generic method on a generic receiver (e.g. `v.push(x)` on
            // `*Vector<int>`). The receiver's type args bind the impl's
            // type params; mangle accordingly. If the method declares
            // additional `<U>`-style params, infer them from call args.
            if stripped != null && stripped.kind == TY_GENERIC {
                let base: string = stripped.name;
                let mname: string = base.concat("_").concat(method);
                if g.generic_fns.contains(mname) {
                    let template: Stmt = g.generic_fns.get(mname);
                    let full_args: *Vector<Type> = resolve_method_call_args(
                        g, e, &template, stripped.args);
                    if full_args == null { full_args = stripped.args; }
                    let mangled: string = mangle_generic(mname, full_args);
                    if !g.emitted_monos.contains(mangled) {
                        g.emitted_monos.insert(mangled, true);
                        let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: full_args };
                        g.fn_mono_queue.push(entry);
                    }
                    print!(mangled);
                    print!("(");
                    // Methods with `self: *T` (pointer receiver, the
                    // common case) want `&recv` when recv is a value;
                    // methods with `self: T` (by-value receiver) take
                    // recv directly. Inspect the template's first param
                    // to decide.
                    let mut p_is_ptr: bool = true;
                    if template.fn_params != null && template.fn_params.len() > 0 {
                        let first: Param = template.fn_params.get(0);
                        if first.ty != null
                           && first.ty.kind != TY_POINTER
                           && first.ty.kind != TY_BORROW
                           && first.ty.kind != TY_BORROW_MUT {
                            p_is_ptr = false;
                        }
                    }
                    let r_is_ptr: bool = recv_ty != null
                        && (recv_ty.kind == TY_POINTER
                            || recv_ty.kind == TY_BORROW
                            || recv_ty.kind == TY_BORROW_MUT);
                    let needs_addr: bool = p_is_ptr && !r_is_ptr;
                    let needs_deref: bool = !p_is_ptr && r_is_ptr;
                    if needs_addr { print!("&"); }
                    if needs_deref { print!("*"); }
                    emit_expr(g, recv);
                    if e.args != null {
                        for let i: i32 = 0; i < e.args.len(); i++ {
                            print!(", ");
                            let a: Expr = e.args.get(i);
                            emit_expr(g, &a);
                        }
                    }
                    print!(")");
                    return;
                }
            }

            if stripped != null && stripped.kind == TY_NAMED {
                let mut prefix: string = stripped.name;
                let mut fn_name: string = "";
                // Qualified call `s.NS::method(...)` — encoded as `NS::method` in `field`.
                // Skip the dispatch search and go straight to `NS_<type>_method`.
                let qpos: i32 = ns_split_pos(method);
                if qpos > 0 {
                    let ns: string = method.substring(0, qpos);
                    let real: string = method.substring(qpos + 2, method.len());
                    fn_name = ns.concat("_").concat(prefix).concat("_").concat(real);
                } else if is_stdlib_primitive(stripped.name) {
                    // Three-step dispatch for `s.method()` on a primitive:
                    //   1. Bareword `<type>_<method>` (impl with no namespace) — wins if it exists.
                    //   2. Namespaced `<*>_<type>_<method>` (impl in NS { ... }) — scan all fns
                    //      for keys ending in `_<type>_<method>`. Exactly one match → use it;
                    //      two or more → ambiguity error embedded in the C source so the build
                    //      fails with a clear message rather than picking arbitrarily.
                    //   3. `__glide_<type>_<method>` C runtime fallback (s.len, c.is_digit,
                    //      i.abs and the other primitive ops baked into stdlib.c).
                    let glide_name: string = prefix.concat("_").concat(method);
                    // Only sugar to `obj.method()` if the function came from
                    // an `impl T { ... }` block. A free fn coincidentally
                    // named `<Type>_<method>` is just a regular function and
                    // must be called positionally.
                    if g.fns.contains(glide_name) && g.method_fns.contains(glide_name) {
                        fn_name = glide_name;
                    } else {
                        // O(1) lookup via the method index. Multi-match values
                        // are `;`-joined; >1 segment means namespaced collision
                        // and we abort below with a build-time error.
                        let mut found: string = "";
                        let mut count: i32 = 0;
                        if g.method_index.contains(glide_name) {
                            let entry: string = g.method_index.get(glide_name);
                            let n: i32 = entry.len();
                            let mut start: i32 = 0;
                            let mut i: i32 = 0;
                            while i <= n {
                                if i == n || entry.at(i).to_int() == 59 {
                                    let part: string = entry.substring(start, i);
                                    if part.len() > 0 {
                                        found = part;
                                        count = count + 1;
                                    }
                                    start = i + 1;
                                }
                                i = i + 1;
                            }
                        }
                        if count == 1 {
                            fn_name = found;
                        } else if count >= 2 {
                            // #error in the emitted C aborts the compile with a clear message
                            // (codegen has no direct path to the parser's diagnostic stream, and
                            // we don't want to silently let printf("(null)") fall through).
                            println!("");
                            print!("#error \"ambiguous method `");
                            print!(method);
                            print!("` on `");
                            print!(prefix);
                            print!("`: multiple impl blocks register it; qualify the call as `value.NS::");
                            print!(method);
                            print!("()` or rename one impl\"");
                            println!("");
                            return;
                        } else {
                            // The <=64-bit int widths share the i64-wide
                            // `__glide_int_*` helpers; 128-bit ints have their
                            // own (printf can't format __int128). char/bool/
                            // string keep their own prefix.
                            let mut rt_prefix: string = prefix;
                            if prefix.eq("i128") { rt_prefix = "i128"; }
                            else if prefix.eq("u128") { rt_prefix = "u128"; }
                            else if _is_uint_family(prefix) { rt_prefix = "uint"; }
                            else if _is_int_family(prefix) { rt_prefix = "int"; }
                            fn_name = "__glide_".concat(rt_prefix).concat("_").concat(method);
                        }
                    }
                } else {
                    fn_name = prefix.concat("_").concat(method);
                }
                print!(fn_name);
                print!("(");
                // Whether to insert an auto-`&` on the receiver depends on
                // the resolved method's first param: pointer-ish param + value
                // receiver -> add `&`; everything else stays as-is. Default to
                // the legacy "non-primitive non-pointer => addr" rule when we
                // can't see the signature (extern fn, runtime fallback).
                let is_prim: bool = is_stdlib_primitive(stripped.name);
                let r_is_ptr: bool = recv_ty != null
                    && (recv_ty.kind == TY_POINTER
                        || recv_ty.kind == TY_BORROW
                        || recv_ty.kind == TY_BORROW_MUT);
                let mut needs_addr: bool = false;
                if g.fns.contains(fn_name) {
                    let sig: Stmt = g.fns.get(fn_name);
                    if sig.fn_params != null && sig.fn_params.len() > 0 {
                        let first: Param = sig.fn_params.get(0);
                        let p_is_ptr: bool = first.ty != null
                            && (first.ty.kind == TY_POINTER
                                || first.ty.kind == TY_BORROW
                                || first.ty.kind == TY_BORROW_MUT);
                        if p_is_ptr && !r_is_ptr { needs_addr = true; }
                    }
                } else {
                    // Unknown signature: fall back to the legacy heuristic.
                    needs_addr = !is_prim && !r_is_ptr;
                }
                if needs_addr { print!("&"); }
                emit_expr(g, recv);
                if e.args != null {
                    for let i: i32 = 0; i < e.args.len(); i++ {
                        print!(", ");
                        let a: Expr = e.args.get(i);
                        emit_expr(g, &a);
                    }
                }
                print!(")");
                return;
            }
            // Fallback: emit as plain member call.
        }
        // Indirect call through a fn-ptr (void*) — needs an inline cast in C.
        let callee_ty: *Type = infer_for_codegen(g, e.lhs);
        if callee_ty != null && callee_ty.kind == TY_FNPTR {
            print!("(("); print!(fnptr_cast_str(callee_ty)); print!(")");
            emit_expr(g, e.lhs);
            print!(")");
        } else {
            emit_expr(g, e.lhs);
        }
        print!("(");
        if e.args != null {
            for let i: i32 = 0; i < e.args.len(); i++ {
                if i > 0 { print!(", "); }
                let a: Expr = e.args.get(i);
                emit_expr(g, &a);
            }
        }
        print!(")");
        return;
    }
    if e.kind == EX_MEMBER {
        // Auto-deref for pointer receivers: `p.x` -> `p->x` for *T,
        // but C also allows `(*p).x`. Emit `->` when receiver is pointer.
        // Tuple index members (`t.0`) emit the `_0` struct field name.
        let mut fld: string = c_safe_ident(e.field);
        if tuple_field_is_index(e.field) { fld = "_".concat(e.field); }
        let recv_ty: *Type = infer_for_codegen(g, e.lhs);
        if recv_ty != null
            && (recv_ty.kind == TY_POINTER
                || recv_ty.kind == TY_BORROW
                || recv_ty.kind == TY_BORROW_MUT) {
            print!("(");
            emit_expr(g, e.lhs);
            print!("->", fld, ")");
            return;
        }
        print!("(");
        emit_expr(g, e.lhs);
        print!(".", fld, ")");
        return;
    }
    if e.kind == EX_INDEX {
        emit_expr(g, e.lhs);
        print!("[");
        emit_expr(g, e.rhs);
        print!("]");
        return;
    }
    if e.kind == EX_CAST {
        // `expr as *dyn Trait` produces a fat pointer literal. We need the
        // source's concrete type to pick the right vtable. infer_for_codegen
        // gives us back e.g. `*Cat`; we strip the pointer and use the inner
        // name to find the static `__glide_<Type>_as_<Trait>_vt`.
        let mut dyn_trait: string = "";
        if e.cast_to != null && e.cast_to.kind == TY_POINTER
            && e.cast_to.inner != null && e.cast_to.inner.kind == TY_DYN {
            dyn_trait = e.cast_to.inner.name;
        } else if e.cast_to != null && e.cast_to.kind == TY_DYN {
            dyn_trait = e.cast_to.name;
        }
        if !dyn_trait.eq("") {
            let src_ty: *Type = infer_for_codegen(g, e.lhs);
            let inner: *Type = strip_ptr(src_ty);
            let mut src_name: string = "?";
            if inner != null && inner.kind == TY_NAMED { src_name = inner.name; }
            print!("((__glide_dyn_".concat(dyn_trait).concat("){.data = (void*)"));
            emit_expr(g, e.lhs);
            print!(", .vtable = &__glide_".concat(src_name).concat("_as_").concat(dyn_trait).concat("_vt})"));
            return;
        }
        print!("((", type_to_c(e.cast_to), ")");
        emit_expr(g, e.lhs);
        print!(")");
        return;
    }
    if e.kind == EX_SIZEOF {
        print!("sizeof(", type_to_c(e.cast_to), ")");
        return;
    }
    if e.kind == EX_FNEXPR {
        // Lift to a uniquely-named top-level fn; expression evaluates to its
        // address (which decays to a fn pointer in C).
        let id: i32 = g.anon_count;
        g.anon_count = id + 1;
        let name: string = "__glide_anon_".concat(int_to_str(id));
        let af: AnonFn = AnonFn {
            name: name,
            params: e.fn_expr_params,
            ret_ty: e.cast_to,
            body: e.fn_expr_body,
        };
        g.anon_fns.push(af);
        print!(name);
        return;
    }
    if e.kind == EX_PATH {
        // Associated int constants: `i32::MAX` / `u64::MIN` / `u256::MAX` …
        if e.field.eq("MAX") || e.field.eq("MIN") {
            let lim: string = _int_limit_c(e.str_val, e.field.eq("MAX"));
            if !lim.eq("") { print!(lim); return; }
        }
        // First try the full qualified form `<prefix>::<field>` as a free
        // function alias (e.g. `stdlib::math::min_int`). Falls back to the
        // legacy `<Type>_<field>` form, with the `Type` prefix resolved
        // through the alias table so multi-segment module paths still hit
        // the existing flat C symbol.
        if g.module_aliases.contains(e.str_val.concat("::").concat(e.field)) {
            print!(g.module_aliases.get(e.str_val.concat("::").concat(e.field)));
            return;
        }
        let ty: string = resolve_type_prefix(g, e.str_val);
        // Payload-less enum variant in expression position. The `<Type>_<Var>`
        // #define is an int tag; wrap it as a struct literal so the value
        // is assignable to a `<Type>` binding. Match arms use a separate
        // emit path (`case <Type>_<Var>:`) and still see the int.
        if g.enums.contains(ty) {
            let edef: Stmt = g.enums.get(ty);
            if edef.enum_variants != null {
                for let i: i32 = 0; i < edef.enum_variants.len(); i++ {
                    let v: EnumVariant = edef.enum_variants.get(i);
                    if v.name.eq(e.field)
                       && (v.fields == null || v.fields.len() == 0) {
                        print!("((", ty, "){.tag = ", ty.concat("_").concat(e.field), "})");
                        return;
                    }
                }
            }
        }
        print!(ty.concat("_").concat(e.field));
        return;
    }
    if e.kind == EX_POSTINC { emit_expr(g, e.lhs); print!("++"); return; }
    if e.kind == EX_POSTDEC { emit_expr(g, e.lhs); print!("--"); return; }
    if e.kind == EX_MACRO {
        if e.str_val.eq("println") || e.str_val.eq("print") {
            print!("printf(\"");
            // Build a format string by walking args, joining with spaces.
            if e.args != null {
                for let i: i32 = 0; i < e.args.len(); i++ {
                    if i > 0 { print!(" "); }
                    let a: Expr = e.args.get(i);
                    let at: *Type = infer_for_codegen(g, &a);
                    print!(format_spec_for(at));
                }
            }
            if e.str_val.eq("println") { print!("\\n"); }
            print!("\"");
            // Then emit args (with bool→string conversion).
            if e.args != null {
                for let i: i32 = 0; i < e.args.len(); i++ {
                    print!(", ");
                    let a: Expr = e.args.get(i);
                    let at: *Type = infer_for_codegen(g, &a);
                    if at != null && at.kind == TY_NAMED && at.name.eq("bool") {
                        print!("__glide_bool_to_string(");
                        emit_expr(g, &a);
                        print!(")");
                    } else if at != null && at.kind == TY_NAMED
                              && (at.name.eq("i64") || at.name.eq("isize") || at.name.eq("long")) {
                        // Cast to (long long) so `%lld` works regardless of whether
                        // int64_t is `long long` (Windows) or `long` (Linux). Quiets
                        // -Wformat without forcing an inttypes.h dance.
                        print!("(long long)(");
                        emit_expr(g, &a);
                        print!(")");
                    } else if at != null && at.kind == TY_NAMED
                              && (at.name.eq("u64") || at.name.eq("usize") || at.name.eq("ulong")) {
                        print!("(unsigned long long)(");
                        emit_expr(g, &a);
                        print!(")");
                    } else if at != null && at.kind == TY_NAMED && at.name.eq("i128") {
                        print!("__glide_i128_to_string(");
                        emit_expr(g, &a);
                        print!(")");
                    } else if at != null && at.kind == TY_NAMED && at.name.eq("u128") {
                        print!("__glide_u128_to_string(");
                        emit_expr(g, &a);
                        print!(")");
                    } else if at != null && at.kind == TY_NAMED && at.name.eq("u256") {
                        print!("__glide_u256_to_string(");
                        emit_expr(g, &a);
                        print!(")");
                    } else if at != null && at.kind == TY_NAMED && at.name.eq("i256") {
                        print!("__glide_i256_to_string(");
                        emit_expr(g, &a);
                        print!(")");
                    } else {
                        emit_expr(g, &a);
                    }
                }
            }
            print!(")");
            return;
        }
        if e.str_val.eq("format") {
            print!("__glide_format(");
            // First arg: format string with {} converted to appropriate %fmt.
            if e.args != null && e.args.len() > 0 {
                let first: Expr = e.args.get(0);
                if first.kind == EX_STRING {
                    print!("\"");
                    let raw: string = first.str_val;
                    let mut arg_idx: i32 = 1;
                    let n: i32 = raw.len();
                    let mut i: i32 = 0;
                    while i < n {
                        let c: char = raw.at(i);
                        if c.to_int() == 123 && i + 1 < n && raw.at(i + 1).to_int() == 125 {
                            if e.args != null && arg_idx < e.args.len() {
                                let a: Expr = e.args.get(arg_idx);
                                let at: *Type = infer_for_codegen(g, &a);
                                print!(format_spec_for(at));
                            } else {
                                print!("%s");
                            }
                            arg_idx = arg_idx + 1;
                            i = i + 2;
                        } else {
                            // emit char literal-safe
                            if c.to_int() == 34 { print!("\\\""); }
                            else if c.to_int() == 92 { print!("\\\\"); }
                            else { print!(c); }
                            i = i + 1;
                        }
                    }
                    print!("\"");
                } else {
                    emit_expr(g, &first);
                }
                for let j: i32 = 1; j < e.args.len(); j++ {
                    print!(", ");
                    let a: Expr = e.args.get(j);
                    let at: *Type = infer_for_codegen(g, &a);
                    if at != null && at.kind == TY_NAMED
                       && (at.name.eq("i64") || at.name.eq("isize") || at.name.eq("long")) {
                        print!("(long long)(");
                        emit_expr(g, &a);
                        print!(")");
                    } else if at != null && at.kind == TY_NAMED
                              && (at.name.eq("u64") || at.name.eq("usize") || at.name.eq("ulong")) {
                        print!("(unsigned long long)(");
                        emit_expr(g, &a);
                        print!(")");
                    } else if at != null && at.kind == TY_NAMED && at.name.eq("i128") {
                        print!("__glide_i128_to_string(");
                        emit_expr(g, &a);
                        print!(")");
                    } else if at != null && at.kind == TY_NAMED && at.name.eq("u128") {
                        print!("__glide_u128_to_string(");
                        emit_expr(g, &a);
                        print!(")");
                    } else if at != null && at.kind == TY_NAMED && at.name.eq("u256") {
                        print!("__glide_u256_to_string(");
                        emit_expr(g, &a);
                        print!(")");
                    } else if at != null && at.kind == TY_NAMED && at.name.eq("i256") {
                        print!("__glide_i256_to_string(");
                        emit_expr(g, &a);
                        print!(")");
                    } else {
                        emit_expr(g, &a);
                    }
                }
            }
            print!(")");
            return;
        }
        print!("/* macro ", e.str_val, " */ 0");
        return;
    }
    if e.kind == EX_TUPLE {
        let tt: *Type = infer_for_codegen(g, e);
        if tt == null || tt.kind != TY_TUPLE {
            print!("/* tuple infer fail */ 0");
            return;
        }
        // Ensure the typedef exists even if the collection pass missed this
        // literal (e.g. it appears only in a context with no type annotation).
        register_tuple_type(g, tt);
        print!("((".concat(type_to_c(tt)).concat("){"));
        if e.args != null {
            for let i: i32 = 0; i < e.args.len(); i++ {
                if i > 0 { print!(", "); }
                print!("._".concat(int_to_str(i)).concat(" = "));
                let v: Expr = e.args.get(i);
                emit_expr(g, &v);
            }
        }
        print!("})");
        return;
    }
    if e.kind == EX_STRUCT_LIT {
        print!("((", e.str_val, "){");
        if e.field_names != null && e.args != null {
            for let i: i32 = 0; i < e.args.len(); i++ {
                if i > 0 { print!(", "); }
                let fname: string = e.field_names.get(i);
                print!(".", c_safe_ident(fname), " = ");
                let v: Expr = e.args.get(i);
                // `null` against a `*dyn Trait` field needs the
                // fat-pointer zero-init, not literal NULL.
                if v.kind == EX_NULL {
                    let fty: *Type = _field_ty_in_struct(g, e.str_val, fname);
                    if _is_dyn_ptr(fty) {
                        _emit_null_for(fty);
                        continue;
                    }
                }
                emit_expr(g, &v);
            }
        }
        print!("})");
        return;
    }
    print!("/* unknown expr ", e.kind, " */ 0");
}

// ---- statements ----------------------------------------------------------

// Emits a Glide `asm [volatile] { "instr" : outs : ins : clobbers }` block as
// a GCC-style `__asm__` statement. Each instruction line is wrapped in its
// own quoted string + "\n\t" so the generated C reads naturally and the
// assembler sees each line as a separate instruction. Constraints and clobbers
// pass through verbatim.
fn emit_asm_stmt(g: *CG, s: *Stmt, depth: i32) {
    ind(depth);
    print!("__asm__");
    if s.is_volatile { print!(" volatile"); }
    print!("(");
    if s.asm_strings == null || s.asm_strings.len() == 0 {
        print!("\"\"");
    } else {
        for let i: i32 = 0; i < s.asm_strings.len(); i++ {
            if i > 0 { println!(""); ind(depth + 1); }
            let line: string = s.asm_strings.get(i);
            print!("\"");
            // escape backslashes and quotes
            let n: i32 = line.len();
            let mut k: i32 = 0;
            while k < n {
                let c: char = line.at(k);
                if c.to_int() == 34 { print!("\\\""); }
                else if c.to_int() == 92 { print!("\\\\"); }
                else { print!(c); }
                k = k + 1;
            }
            print!("\\n\\t\"");
        }
    }
    // Outputs (always emit `:` so positional sections line up if anything follows).
    let has_out: bool = s.asm_out_constraints != null && s.asm_out_constraints.len() > 0;
    let has_in:  bool = s.asm_in_constraints  != null && s.asm_in_constraints.len()  > 0;
    let has_clb: bool = s.asm_clobbers        != null && s.asm_clobbers.len()        > 0;
    if has_out || has_in || has_clb {
        print!(" : ");
        if has_out {
            for let i: i32 = 0; i < s.asm_out_constraints.len(); i++ {
                if i > 0 { print!(", "); }
                let cstr: string = "\"".concat(s.asm_out_constraints.get(i)).concat("\"(");
                print!(cstr);
                let e: Expr = s.asm_out_exprs.get(i);
                emit_expr(g, &e);
                print!(")");
            }
        }
    }
    if has_in || has_clb {
        print!(" : ");
        if has_in {
            for let i: i32 = 0; i < s.asm_in_constraints.len(); i++ {
                if i > 0 { print!(", "); }
                let cstr: string = "\"".concat(s.asm_in_constraints.get(i)).concat("\"(");
                print!(cstr);
                let e: Expr = s.asm_in_exprs.get(i);
                emit_expr(g, &e);
                print!(")");
            }
        }
    }
    if has_clb {
        print!(" : ");
        for let i: i32 = 0; i < s.asm_clobbers.len(); i++ {
            if i > 0 { print!(", "); }
            let cstr: string = "\"".concat(s.asm_clobbers.get(i)).concat("\"");
            print!(cstr);
        }
    }
    println!(");");
}

pub fn emit_stmt(g: *CG, s: *Stmt, depth: i32) {
    if s == null { return; }
    g.emit_line_dir(s.line, s.origin);
    // Tuple destructuring: `let (a, b) = expr;`. Bind the value to a temp,
    // then declare each name as the corresponding tuple element.
    if s.kind == ST_LET && s.let_names != null && s.let_names.len() > 0 {
        let tup_ty: *Type = infer_for_codegen(g, s.let_value);
        let id: i32 = g.anon_count;
        g.anon_count = id + 1;
        let tmp: string = "__glide_dtup_".concat(int_to_str(id));
        ind(depth);
        print!("__typeof__(");
        emit_expr(g, s.let_value);
        print!(") ", tmp, " = ");
        emit_expr(g, s.let_value);
        println!(";");
        for let i: i32 = 0; i < s.let_names.len(); i++ {
            let nm: string = c_safe_ident(s.let_names.get(i));
            let field: string = tmp.concat("._").concat(int_to_str(i));
            ind(depth);
            print!("__typeof__(", field, ") ", nm, " = ", field, ";");
            println!("");
            // Declare the element type so later infer_for_codegen resolves it.
            if tup_ty != null && tup_ty.kind == TY_TUPLE && tup_ty.args != null
               && i < tup_ty.args.len() {
                let el: Type = tup_ty.args.get(i);
                let pp: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *pp = el;
                g.declare(s.let_names.get(i), pp);
            }
        }
        return;
    }
    if s.kind == ST_LET || s.kind == ST_CONST {
        // Auto-drop modes:
        //   struct_lit_auto: `let p: *T = T { ... }` rewrites RHS to malloc+init.
        //   explicit_auto: `let v* = expr` (explicit `*` after binding name).
        // Both push a cleanup expression onto the defer stack: a method call
        // `v.free()` if the type defines one, otherwise `free(v as *void)`.
        let mut struct_lit_auto: bool = false;
        if s.kind == ST_LET && s.let_ty != null && s.let_ty.kind == TY_POINTER
           && s.let_value != null && s.let_value.kind == EX_STRUCT_LIT {
            if s.let_ty.inner != null && s.let_ty.inner.kind == TY_NAMED {
                if s.let_ty.inner.name.eq(s.let_value.str_val) {
                    struct_lit_auto = true;
                }
            }
        }
        let auto_owned: bool = struct_lit_auto || s.is_auto_owned;
        // ---- pre-pass: detect generic fn call BEFORE we emit anything,
        //      since we may need to print a forward decl on its own line.

        // Generic struct literal hint: `let b: Box<int> = Box { ... }` →
        // rewrite the struct lit type_name to the mangled mono name.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_GENERIC {
            if s.let_value.kind == EX_STRUCT_LIT
                && s.let_value.str_val.eq(s.let_ty.name) {
                s.let_value.str_val = mangle_generic(s.let_ty.name, s.let_ty.args);
            }
        }
        // make_chan(cap) hint: rewrite to __glide_make_chan_<m>(cap) using let-annot.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_GENERIC
            && s.let_ty.name.eq("chan") && s.let_ty.args != null && s.let_ty.args.len() > 0
            && s.let_value.kind == EX_CALL && s.let_value.lhs != null
            && s.let_value.lhs.kind == EX_IDENT
            && s.let_value.lhs.str_val.eq("make_chan") {
            let inner: Type = s.let_ty.args.get(0);
            let m: string = mangle_type(&inner);
            s.let_value.lhs.str_val = "__glide_make_chan_".concat(m);
        }
        // ok(v)/err(s) hint: rewrite to __glide_ok_<m>/__glide_err_<m> using let-annot `!T`.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_RESULT
            && s.let_value.kind == EX_CALL && s.let_value.lhs != null
            && s.let_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(s.let_ty.inner);
            if s.let_value.lhs.str_val.eq("ok") {
                s.let_value.lhs.str_val = "__glide_ok_".concat(m);
            }
            if s.let_value.lhs.str_val.eq("err") {
                s.let_value.lhs.str_val = "__glide_err_".concat(m);
            }
        }
        // some(v)/none() hint: rewrite for ?T let-init.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_OPTION
            && s.let_value.kind == EX_CALL && s.let_value.lhs != null
            && s.let_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(s.let_ty.inner);
            if s.let_value.lhs.str_val.eq("some") {
                s.let_value.lhs.str_val = "__glide_some_".concat(m);
            }
            if s.let_value.lhs.str_val.eq("none") {
                s.let_value.lhs.str_val = "__glide_none_".concat(m);
            }
        }
        // some(v)/none()/err(s) hint: rewrite for ?!T let-init.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_OPT_RESULT
            && s.let_value.kind == EX_CALL && s.let_value.lhs != null
            && s.let_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(s.let_ty.inner);
            if s.let_value.lhs.str_val.eq("some") {
                s.let_value.lhs.str_val = "__glide_optres_some_".concat(m);
            }
            if s.let_value.lhs.str_val.eq("none") {
                s.let_value.lhs.str_val = "__glide_optres_none_".concat(m);
            }
            if s.let_value.lhs.str_val.eq("err") {
                s.let_value.lhs.str_val = "__glide_optres_err_".concat(m);
            }
        }
        // Generic fn call mono attempt — uses let-annot as ret-hint plus args.
        if s.let_value != null && s.let_value.kind == EX_CALL {
            let _ok: bool = try_mono_call(g, s.let_value, s.let_ty);
        }

        // ---- now emit the let stmt itself ----
        ind(depth);
        let cname: string = c_safe_ident(s.name);
        if s.let_ty != null {
            print!(type_to_c(s.let_ty), " ", cname);
            g.declare(s.name, s.let_ty);
        } else if s.let_value != null {
            // Try to infer from value. If the value is an Ident referencing
            // a lifted anon fn, use void* (fn-pointer slot).
            let mut handled: bool = false;
            if s.let_value.kind == EX_IDENT {
                for let k: i32 = 0; k < g.anon_fns.len(); k++ {
                    let af: AnonFn = g.anon_fns.get(k);
                    if af.name.eq(s.let_value.str_val) {
                        print!("void* ", cname);
                        let void_ptr: *Type = ty_pointer(ty_named("void"));
                        g.declare(s.name, void_ptr);
                        handled = true;
                        break;
                    }
                }
            }
            if !handled {
                let vt: *Type = infer_for_codegen(g, s.let_value);
                if vt != null {
                    print!(type_to_c(vt), " ", cname);
                    g.declare(s.name, vt);
                } else {
                    print!("/* infer */ int ", cname);
                }
            }
        } else {
            print!("/* infer */ int ", cname);
        }
        if struct_lit_auto {
            // T* p = malloc(sizeof(T)); *p = (T){...};
            print!(" = (");
            print!(type_to_c(s.let_ty));
            print!(")malloc(sizeof(");
            print!(type_to_c(s.let_ty.inner));
            print!("));");
            println!("");
            ind(depth);
            print!("*");
            print!(cname);
            print!(" = ");
            emit_expr(g, s.let_value);
            println!(";");
        } else {
            if s.let_value != null {
                print!(" = ");
                // `let p: *dyn Foo = null;` — fat-pointer struct
                // can't take literal NULL; emit zero-init.
                if s.let_value.kind == EX_NULL && _is_dyn_ptr(s.let_ty) {
                    _emit_null_for(s.let_ty);
                } else {
                    emit_expr(g, s.let_value);
                }
            }
            println!(";");
        }
        if auto_owned {
            // Decide cleanup: prefer `v.free()` method if type defines one
            // (e.g. Vector_free); otherwise libc `free(v as *void)`.
            let inner_ty: *Type = strip_ptr(s.let_ty);
            let mut method_name: string = "";
            let mut has_method: bool = false;
            if inner_ty != null && inner_ty.kind == TY_NAMED {
                method_name = inner_ty.name.concat("_free");
                if g.fns.contains(method_name) { has_method = true; }
            }
            if inner_ty != null && inner_ty.kind == TY_GENERIC {
                method_name = inner_ty.name.concat("_free");
                if g.generic_fns.contains(method_name) { has_method = true; }
            }
            if has_method {
                // Push `v.free()` (member call) onto defer; emit_expr will
                // dispatch through the existing method-on-receiver path,
                // including mono for generic receivers.
                let recv: *Expr = expr_ident(s.name, s.line, s.column);
                let mem: *Expr = expr_member(recv, "free");
                let no_args: *Vector<Expr> = Vector::new();
                let call: *Expr = expr_call(mem, no_args);
                g.auto_drop_stack.push(*call);
            } else {
                let free_call: *Expr = calloc(1, sizeof(Expr)) as *Expr;
                free_call.kind = EX_CALL;
                free_call.line = s.line;
                free_call.column = s.column;
                let callee: *Expr = expr_ident("free", s.line, s.column);
                free_call.lhs = callee;
                let args: *Vector<Expr> = Vector::new();
                let cast_arg: *Expr = expr_cast(expr_ident(s.name, s.line, s.column),
                                                 ty_pointer(ty_named("void")));
                args.push(*cast_arg);
                free_call.args = args;
                g.auto_drop_stack.push(*free_call);
            }
        }
        return;
    }
    if s.kind == ST_RETURN {
        // Detect `return err(...)` BEFORE rewriting `err` -> `__glide_err_X`
        // so `defer_err` cleanups can fire on this path only.
        let mut is_err_return: bool = false;
        if s.expr_value != null && s.expr_value.kind == EX_CALL && s.expr_value.lhs != null
            && s.expr_value.lhs.kind == EX_IDENT && s.expr_value.lhs.str_val.eq("err") {
            is_err_return = true;
        }
        // ok(v)/err(s) hint via current fn ret-type `!T`.
        if s.expr_value != null && g.current_ret_ty != null
            && g.current_ret_ty.kind == TY_RESULT
            && s.expr_value.kind == EX_CALL && s.expr_value.lhs != null
            && s.expr_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(g.current_ret_ty.inner);
            if s.expr_value.lhs.str_val.eq("ok") {
                s.expr_value.lhs.str_val = "__glide_ok_".concat(m);
            }
            if s.expr_value.lhs.str_val.eq("err") {
                s.expr_value.lhs.str_val = "__glide_err_".concat(m);
            }
        }
        // some(v)/none() hint via current fn ret-type `?T`.
        if s.expr_value != null && g.current_ret_ty != null
            && g.current_ret_ty.kind == TY_OPTION
            && s.expr_value.kind == EX_CALL && s.expr_value.lhs != null
            && s.expr_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(g.current_ret_ty.inner);
            if s.expr_value.lhs.str_val.eq("some") {
                s.expr_value.lhs.str_val = "__glide_some_".concat(m);
            }
            if s.expr_value.lhs.str_val.eq("none") {
                s.expr_value.lhs.str_val = "__glide_none_".concat(m);
            }
        }
        // some(v)/none()/err(s) hint via current fn ret-type `?!T`.
        if s.expr_value != null && g.current_ret_ty != null
            && g.current_ret_ty.kind == TY_OPT_RESULT
            && s.expr_value.kind == EX_CALL && s.expr_value.lhs != null
            && s.expr_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(g.current_ret_ty.inner);
            if s.expr_value.lhs.str_val.eq("some") {
                s.expr_value.lhs.str_val = "__glide_optres_some_".concat(m);
            }
            if s.expr_value.lhs.str_val.eq("none") {
                s.expr_value.lhs.str_val = "__glide_optres_none_".concat(m);
            }
            if s.expr_value.lhs.str_val.eq("err") {
                s.expr_value.lhs.str_val = "__glide_optres_err_".concat(m);
            }
        }
        // If there's a value AND there are pending cleanups (auto-drop or
        // explicit defer), capture the value in a temp BEFORE running cleanups
        // so e.g. `return v.get(0)` doesn't read freed memory after auto-drop
        // of v fires.
        let has_err_defers: bool = is_err_return && g.err_defer_stack.len() > 0;
        let has_cleanup: bool = g.defer_stack.len() > 0 || g.auto_drop_stack.len() > 0 || has_err_defers;
        if s.expr_value != null && has_cleanup {
            ind(depth);
            print!("__typeof__(");
            emit_expr(g, s.expr_value);
            print!(") __glide_ret = ");
            emit_expr(g, s.expr_value);
            println!(";");
            if has_err_defers { g.emit_err_defers_reverse(depth); }
            g.emit_deferred_reverse(depth);
            ind(depth); println!("return __glide_ret;");
        } else {
            if has_err_defers { g.emit_err_defers_reverse(depth); }
            g.emit_deferred_reverse(depth);
            ind(depth);
            print!("return");
            if s.expr_value != null {
                print!(" "); emit_expr(g, s.expr_value);
            } else if g.current_ret_ty != null && g.current_ret_ty.kind == TY_RESULT
                      && g.current_ret_ty.inner != null
                      && g.current_ret_ty.inner.kind == TY_NAMED
                      && g.current_ret_ty.inner.name.eq("void") {
                // `return;` inside a `fn -> !` body = explicit early success.
                print!(" __glide_ok_void()");
            }
            println!(";");
        }
        return;
    }
    if s.kind == ST_DEFER {
        if s.expr_value != null { g.defer_stack.push(*s.expr_value); }
        return;
    }
    if s.kind == ST_DEFER_ERR {
        if s.expr_value != null { g.err_defer_stack.push(*s.expr_value); }
        return;
    }
    if s.kind == ST_SPAWN {
        let id: i32 = g.spawn_count;
        g.spawn_count = id + 1;
        let ids: string = int_to_str(id);
        let call: *Expr = s.expr_value;
        let mut n_args: i32 = 0;
        if call != null && call.args != null { n_args = call.args.len(); }

        // Leaf detection: if the spawned function carries the `@leaf`
        // attribute, the runtime can dispatch it inline on the worker
        // thread without ever mmaping a coro stack — paying ~sizeof(task)
        // bytes of RSS instead of ~4 KB (Linux page floor). The function
        // is contractually leaf: no chan ops, no sleep, no I/O. If it
        // attempts to park anyway, __glide_park aborts with a clear
        // message (see sched.c).
        let mut is_leaf_call: bool = false;
        if call != null && call.lhs != null && call.lhs.kind == EX_IDENT
           && g.fns.contains(call.lhs.str_val) {
            let target: Stmt = g.fns.get(call.lhs.str_val);
            if target.attrs != null {
                for let ai: i32 = 0; ai < target.attrs.len(); ai++ {
                    let a: Attr = target.attrs.get(ai);
                    if a.name != null && a.name.eq("leaf") {
                        is_leaf_call = true;
                        break;
                    }
                }
            }
        }
        // spawn_thread (real OS pthread) is incompatible with leaf —
        // pthread_create needs a function-shaped entry that takes void*
        // and returns void*, and we don't want to pay pthread cost for
        // a "leaf" anyway.
        if s.is_spawn_thread { is_leaf_call = false; }
        let spawn_fn: string = if is_leaf_call { "__glide_spawn_leaf" } else { "__glide_spawn" };

        // Zero-arg fast path — skip the malloc/free of an empty struct.
        if n_args == 0 {
            ind(depth);
            if s.is_spawn_thread {
                println!("{ pthread_t __tid; pthread_create(&__tid, NULL, __glide_spawn_stub_".concat(ids).concat(", NULL); pthread_detach(__tid); }"));
            } else {
                println!(spawn_fn.concat("(__glide_spawn_stub_").concat(ids).concat(", NULL);"));
            }
            return;
        }

        let an: string = "__glide_spawn_args_".concat(ids);
        ind(depth); println!("{");
        ind(depth + 1);
        println!(an.concat("* __args = (").concat(an).concat("*)malloc(sizeof(").concat(an).concat("));"));
        for let i: i32 = 0; i < call.args.len(); i++ {
            ind(depth + 1);
            print!("__args->a".concat(int_to_str(i)).concat(" = "));
            let a: Expr = call.args.get(i);
            emit_expr(g, &a);
            println!(";");
        }
        if s.is_spawn_thread {
            ind(depth + 1); println!("pthread_t __tid;");
            ind(depth + 1); println!("pthread_create(&__tid, NULL, __glide_spawn_stub_".concat(ids).concat(", __args);"));
            ind(depth + 1); println!("pthread_detach(__tid);");
        } else {
            ind(depth + 1); println!(spawn_fn.concat("(__glide_spawn_stub_").concat(ids).concat(", __args);"));
        }
        ind(depth); println!("}");
        return;
    }
    if s.kind == ST_EXPR {
        // Field-assign generic mono hint: for `obj.field = Generic::new()`,
        // infer T from the field's declared type and rewrite the call to
        // `Generic_new__T()` before emitting. Lets users skip the let-init
        // dance — `c.args = Vector::new()` Just Works.
        if s.expr_value != null && s.expr_value.kind == EX_ASSIGN
           && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_MEMBER
           && s.expr_value.rhs != null && s.expr_value.rhs.kind == EX_CALL {
            let field_ty: *Type = infer_for_codegen(g, s.expr_value.lhs);
            if field_ty != null {
                let _ok: bool = try_mono_call(g, s.expr_value.rhs, field_ty);
            }
        }
        ind(depth);
        emit_expr(g, s.expr_value);
        println!(";");
        return;
    }
    if s.kind == ST_BREAK { ind(depth); println!("break;"); return; }
    if s.kind == ST_CONTINUE { ind(depth); println!("continue;"); return; }
    if s.kind == ST_ASM { emit_asm_stmt(g, s, depth); return; }
    // c_raw block: emit body verbatim, no escaping, no transformation. Trust the
    // user to produce valid C/asm.
    if s.kind == ST_CRAW { print!(s.name); return; }
    if s.kind == ST_IF {
        ind(depth); print!("if (");
        emit_expr(g, s.cond);
        println!(") {");
        if s.then_body != null {
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth);
        if s.else_body != null {
            println!("} else {");
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.else_body.len(); i++ {
                let b: Stmt = s.else_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
            ind(depth); println!("}");
        } else {
            println!("}");
        }
        return;
    }
    if s.kind == ST_WHILE_RECV {
        // `while let v [: T] = chan_expr.recv() { body }`
        // Lower to: { T v; while (__glide_recv_into_<m>(chan_expr, &v)) { body } }
        let recv: *Expr = s.let_value;
        let recv_target: *Expr = recv.lhs.lhs;
        let target_ty: *Type = infer_for_codegen(g, recv_target);
        let stripped: *Type = strip_ptr(target_ty);
        if stripped == null || stripped.kind != TY_GENERIC || !stripped.name.eq("chan")
           || stripped.args == null || stripped.args.len() == 0 {
            ind(depth); println!("/* while-let: receiver is not a chan<T> */");
            return;
        }
        let inner: Type = stripped.args.get(0);
        let m: string = mangle_type(&inner);
        let tc: string = type_to_c(&inner);
        let var: string = s.name;
        // Declare the binder. Use the user's annotation when present so the
        // C type matches their expectation; otherwise the chan inner type.
        let mut decl_ty: string = tc;
        if s.let_ty != null { decl_ty = type_to_c(s.let_ty); }
        ind(depth); println!("{");
        ind(depth + 1); println!(decl_ty.concat(" ").concat(var).concat(";"));
        ind(depth + 1); print!("while (__glide_recv_into_".concat(m).concat("("));
        emit_expr(g, recv_target);
        println!(", &".concat(var).concat(")) {"));
        g.declare(var, &inner);
        if s.then_body != null {
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 2);
            }
            g.emit_block_drops(saved, depth + 2);
        }
        ind(depth + 1); println!("}");
        ind(depth); println!("}");
        return;
    }
    if s.kind == ST_SELECT {
        // `select! { arm => { body } ... }` — race over chan ops.
        // v1 strategy: polling loop with adaptive backoff (yield_now → sleep_ms).
        // True parking on N chans is deferred (would need a wait-node refactor).
        let arms: *Vector<SelectArm> = s.select_arms;
        if arms == null || arms.len() == 0 {
            ind(depth); println!("/* empty select */");
            return;
        }
        let id_str: string = int_to_str(s.line * 1000 + s.column);
        let end_label: string = "__sel_end_".concat(id_str);

        let mut default_idx: i32 = -1;
        for let i: i32 = 0; i < arms.len(); i++ {
            let a: SelectArm = arms.get(i);
            if a.kind == SEL_DEFAULT { default_idx = i; }
        }

        ind(depth); println!("{");

        // Per-arm temp vars for value-binding recv arms.
        for let i: i32 = 0; i < arms.len(); i++ {
            let a: SelectArm = arms.get(i);
            if a.kind == SEL_RECV || a.kind == SEL_RECV_SOME {
                let chan_ty: *Type = infer_for_codegen(g, a.chan_expr);
                let stripped: *Type = strip_ptr(chan_ty);
                if stripped == null || stripped.kind != TY_GENERIC || !stripped.name.eq("chan")
                   || stripped.args == null || stripped.args.len() == 0 {
                    ind(depth + 1); println!("/* select: arm receiver is not a chan<T> */");
                    continue;
                }
                let inner: Type = stripped.args.get(0);
                let tc: string = type_to_c(&inner);
                ind(depth + 1); println!(tc.concat(" __sel_tmp_").concat(int_to_str(i)).concat(";"));
            }
        }

        ind(depth + 1); println!("int __sel_iters_".concat(id_str).concat(" = 0;"));
        ind(depth + 1); println!("while (1) {");

        for let i: i32 = 0; i < arms.len(); i++ {
            let a: SelectArm = arms.get(i);
            if a.kind == SEL_DEFAULT { continue; }

            if a.kind == SEL_RECV || a.kind == SEL_RECV_SOME {
                let chan_ty: *Type = infer_for_codegen(g, a.chan_expr);
                let stripped: *Type = strip_ptr(chan_ty);
                if stripped == null || stripped.kind != TY_GENERIC || !stripped.name.eq("chan")
                   || stripped.args == null || stripped.args.len() == 0 {
                    ind(depth + 2); println!("/* select arm: receiver is not a chan<T> */");
                    continue;
                }
                let inner: Type = stripped.args.get(0);
                let m: string = mangle_type(&inner);
                let tc: string = type_to_c(&inner);
                let tmp: string = "__sel_tmp_".concat(int_to_str(i));

                ind(depth + 2); print!("if (__glide_try_recv_".concat(m).concat("("));
                emit_expr(g, a.chan_expr);
                println!(", &".concat(tmp).concat(")) {"));

                ind(depth + 3); print!("__glide_wake_send_".concat(m).concat("("));
                emit_expr(g, a.chan_expr);
                println!(");");

                ind(depth + 3); println!("{");
                ind(depth + 4); println!(tc.concat(" ").concat(a.bind_name).concat(" = ").concat(tmp).concat(";"));
                g.declare(a.bind_name, &inner);
                if a.body != null {
                    let saved: i32 = g.auto_drop_stack.len();
                    for let j: i32 = 0; j < a.body.len(); j++ {
                        let bs: Stmt = a.body.get(j);
                        emit_stmt(g, &bs, depth + 4);
                    }
                    g.emit_block_drops(saved, depth + 4);
                }
                ind(depth + 4); println!("goto ".concat(end_label).concat(";"));
                ind(depth + 3); println!("}");
                ind(depth + 2); println!("}");
            }
            if a.kind == SEL_RECV_NONE {
                let chan_ty: *Type = infer_for_codegen(g, a.chan_expr);
                let stripped: *Type = strip_ptr(chan_ty);
                if stripped == null || stripped.kind != TY_GENERIC || !stripped.name.eq("chan") {
                    ind(depth + 2); println!("/* select arm: none receiver is not a chan<T> */");
                    continue;
                }
                ind(depth + 2); print!("if (atomic_load_explicit(&((");
                emit_expr(g, a.chan_expr);
                println!(")->closed), memory_order_acquire)) {");
                ind(depth + 3); println!("{");
                if a.body != null {
                    let saved: i32 = g.auto_drop_stack.len();
                    for let j: i32 = 0; j < a.body.len(); j++ {
                        let bs: Stmt = a.body.get(j);
                        emit_stmt(g, &bs, depth + 3);
                    }
                    g.emit_block_drops(saved, depth + 3);
                }
                ind(depth + 3); println!("goto ".concat(end_label).concat(";"));
                ind(depth + 2); println!("}");
                ind(depth + 2); println!("}");
            }
            if a.kind == SEL_SEND {
                let chan_ty: *Type = infer_for_codegen(g, a.chan_expr);
                let stripped: *Type = strip_ptr(chan_ty);
                if stripped == null || stripped.kind != TY_GENERIC || !stripped.name.eq("chan")
                   || stripped.args == null || stripped.args.len() == 0 {
                    ind(depth + 2); println!("/* select arm: send receiver is not a chan<T> */");
                    continue;
                }
                let inner: Type = stripped.args.get(0);
                let m: string = mangle_type(&inner);

                ind(depth + 2); print!("if (__glide_try_send_".concat(m).concat("("));
                emit_expr(g, a.chan_expr);
                print!(", ");
                emit_expr(g, a.send_value);
                println!(")) {");

                ind(depth + 3); print!("__glide_wake_recv_".concat(m).concat("("));
                emit_expr(g, a.chan_expr);
                println!(");");

                ind(depth + 3); println!("{");
                if a.body != null {
                    let saved: i32 = g.auto_drop_stack.len();
                    for let j: i32 = 0; j < a.body.len(); j++ {
                        let bs: Stmt = a.body.get(j);
                        emit_stmt(g, &bs, depth + 3);
                    }
                    g.emit_block_drops(saved, depth + 3);
                }
                ind(depth + 3); println!("goto ".concat(end_label).concat(";"));
                ind(depth + 2); println!("}");
                ind(depth + 2); println!("}");
            }
        }

        if default_idx >= 0 {
            let a: SelectArm = arms.get(default_idx);
            ind(depth + 2); println!("{");
            if a.body != null {
                let saved: i32 = g.auto_drop_stack.len();
                for let j: i32 = 0; j < a.body.len(); j++ {
                    let bs: Stmt = a.body.get(j);
                    emit_stmt(g, &bs, depth + 3);
                }
                g.emit_block_drops(saved, depth + 3);
            }
            ind(depth + 3); println!("goto ".concat(end_label).concat(";"));
            ind(depth + 2); println!("}");
        } else {
            ind(depth + 2); println!("if (__sel_iters_".concat(id_str).concat(" < 64) { yield_now(); } else { sleep_ms(1); }"));
            ind(depth + 2); println!("__sel_iters_".concat(id_str).concat("++;"));
        }

        ind(depth + 1); println!("}");
        ind(depth); println!(end_label.concat(":;"));
        ind(depth); println!("}");
        return;
    }
    if s.kind == ST_WHILE {
        ind(depth); print!("while (");
        emit_expr(g, s.cond);
        println!(") {");
        if s.then_body != null {
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth); println!("}");
        return;
    }
    if s.kind == ST_FOR {
        ind(depth); print!("for (");
        if s.for_init != null {
            if s.for_init.kind == ST_LET {
                let fname: string = c_safe_ident(s.for_init.name);
                if s.for_init.let_ty != null {
                    print!(type_to_c(s.for_init.let_ty), " ", fname);
                    g.declare(s.for_init.name, s.for_init.let_ty);
                } else {
                    // Untyped `for let i = 0; ...`: default to int and register
                    // it in scope so the body's `i` references type-resolve to
                    // int (otherwise printf-style macros emit `%p` → hex).
                    print!("int ", fname);
                    g.declare(s.for_init.name, ty_named("i32"));
                }
                if s.for_init.let_value != null {
                    print!(" = "); emit_expr(g, s.for_init.let_value);
                }
            } else {
                if s.for_init.expr_value != null { emit_expr(g, s.for_init.expr_value); }
            }
        }
        print!("; ");
        if s.cond != null { emit_expr(g, s.cond); }
        print!("; ");
        if s.for_step != null { emit_expr(g, s.for_step); }
        println!(") {");
        if s.then_body != null {
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth); println!("}");
        return;
    }
    if s.kind == ST_MATCH {
        // Compile to: { Type _m = scrut; switch (_m.tag) { case ENUM_VAR: ... } }
        ind(depth); println!("{");
        let scrut_ty: *Type = infer_for_codegen(g, s.scrutinee);
        let mut enum_name: string = "X";
        if scrut_ty != null && scrut_ty.kind == TY_NAMED { enum_name = scrut_ty.name; }
        ind(depth + 1); print!(enum_name, " __m = ");
        emit_expr(g, s.scrutinee);
        println!(";");
        ind(depth + 1); println!("switch (__m.tag) {");
        if s.arms != null {
            for let i: i32 = 0; i < s.arms.len(); i++ {
                let a: MatchArm = s.arms.get(i);
                ind(depth + 1);
                if a.variant.eq("_") { print!("default: "); }
                else {
                    print!("case ");
                    print!(enum_name.concat("_").concat(a.variant));
                    print!(": ");
                }
                println!("{");
                if a.bindings != null && a.bindings.len() > 0 {
                    if a.bindings.len() == 1 {
                        ind(depth + 2);
                        let payload: string = "__m.data.v_".concat(a.variant);
                        print!("__typeof__(");
                        print!(payload);
                        print!(") ");
                        print!(c_safe_ident(a.bindings.get(0)));
                        print!(" = ");
                        print!(payload);
                        println!(";");
                    } else {
                        for let k: i32 = 0; k < a.bindings.len(); k++ {
                            ind(depth + 2);
                            let payload: string = "__m.data.v_".concat(a.variant);
                            print!("__typeof__(");
                            print!(payload); print!(".f"); print!(k);
                            print!(") ");
                            print!(c_safe_ident(a.bindings.get(k)));
                            print!(" = ");
                            print!(payload); print!(".f"); print!(k);
                            println!(";");
                        }
                    }
                }
                if a.body != null {
                    for let k: i32 = 0; k < a.body.len(); k++ {
                        let bb: Stmt = a.body.get(k);
                        emit_stmt(g, &bb, depth + 2);
                    }
                }
                ind(depth + 1); println!("break; }");
            }
        }
        ind(depth + 1); println!("}");
        ind(depth); println!("}");
        return;
    }
    if s.kind == ST_BLOCK {
        ind(depth); println!("{");
        if s.then_body != null {
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth); println!("}");
        return;
    }
    ind(depth); println!("/* unknown stmt ", s.kind, " */");
}

// ---- top-level -----------------------------------------------------------

fn emit_fn_signature(s: *Stmt) {
    if s.name.eq("main") {
        print!("int main(int __glide_main_argc, char** __glide_main_argv)");
        return;
    }
    if s.is_naked { print!("__attribute__((naked)) "); }
    print!(type_to_c(s.fn_ret_ty), " ", c_safe_ident(s.name), "(");
    if s.fn_params == null || s.fn_params.len() == 0 {
        if s.is_variadic { print!("..."); }
        else             { print!("void"); }
    } else {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            if i > 0 { print!(", "); }
            let p: Param = s.fn_params.get(i);
            print!(type_to_c(p.ty), " ", c_safe_ident(p.name));
        }
        if s.is_variadic { print!(", ..."); }
    }
    print!(")");
}

// Walk an expr looking for `var.method(args)`. If found, try to resolve
// the impl-generic type params from the args. Returns the inferred
// concrete generic type (e.g. *Vector<int>) on success.
fn try_constrain_from_expr(g: *CG, e: *Expr, var: string, gen_name: string, tparams: *Vector<string>) -> *Type {
    if e == null { return null; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER
       && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT
       && e.lhs.lhs.str_val.eq(var) {
        let method: string = e.lhs.field;
        let mname: string = gen_name.concat("_").concat(method);
        if g.generic_fns.contains(mname) {
            let mtmpl: Stmt = g.generic_fns.get(mname);
            // For each tparam, find a method param (skipping self at index 0)
            // whose ty == Named(tparam). The corresponding user arg has the
            // concrete type. User args are e.args; method params after self
            // align 1:1 with them.
            if mtmpl.fn_params != null && e.args != null {
                let resolved: *Vector<Type> = Vector::new();
                let mut all: bool = true;
                for let pi: i32 = 0; pi < tparams.len(); pi++ {
                    let tp: string = tparams.get(pi);
                    let mut found: *Type = null;
                    for let j: i32 = 1; j < mtmpl.fn_params.len(); j++ {
                        let mp: Param = mtmpl.fn_params.get(j);
                        if mp.ty != null && mp.ty.kind == TY_NAMED && mp.ty.name.eq(tp) {
                            let arg_idx: i32 = j - 1;
                            if arg_idx < e.args.len() {
                                let a: Expr = e.args.get(arg_idx);
                                let at: *Type = infer_for_codegen(g, &a);
                                if at != null { found = at; break; }
                            }
                        }
                    }
                    if found == null { all = false; break; }
                    resolved.push(*found);
                }
                if all && resolved.len() > 0 {
                    return ty_pointer(ty_generic(gen_name, resolved));
                }
            }
        }
    }
    // Concrete free-fn call where `var` (possibly wrapped in &/&mut/*)
    // appears as an arg. Walk both the arg expr and the matching param
    // type in parallel, stripping wrappers on each side, until we hit
    // EX_IDENT(var) — the type at that point IS var's type. Resolves
    // bug #1: `let v* = Vector::new(); fill_jobs(&mut *v, n);` where
    // fill_jobs has a concrete `&mut Vector<int>` first param.
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT
       && e.args != null {
        let cname: string = e.lhs.str_val;
        if g.fns.contains(cname) {
            let fn_def: Stmt = g.fns.get(cname);
            if fn_def.fn_params != null {
                let nparams: i32 = fn_def.fn_params.len();
                let nargs: i32 = e.args.len();
                let mut limit: i32 = nargs;
                if nparams < limit { limit = nparams; }
                for let i: i32 = 0; i < limit; i++ {
                    let a: Expr = e.args.get(i);
                    let p: Param = fn_def.fn_params.get(i);
                    let resolved: *Type = constrain_walk(&a, p.ty, var);
                    if resolved != null
                       && resolved.kind == TY_POINTER
                       && resolved.inner != null
                       && resolved.inner.kind == TY_GENERIC
                       && resolved.inner.name.eq(gen_name) {
                        return resolved;
                    }
                }
            }
        }
    }
    // Recurse into children.
    if e.lhs != null {
        let r: *Type = try_constrain_from_expr(g, e.lhs, var, gen_name, tparams);
        if r != null { return r; }
    }
    if e.rhs != null {
        let r: *Type = try_constrain_from_expr(g, e.rhs, var, gen_name, tparams);
        if r != null { return r; }
    }
    if e.operand != null {
        let r: *Type = try_constrain_from_expr(g, e.operand, var, gen_name, tparams);
        if r != null { return r; }
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            let r: *Type = try_constrain_from_expr(g, &a, var, gen_name, tparams);
            if r != null { return r; }
        }
    }
    return null;
}

// Walk an arg-expr alongside its param-type, stripping unary wrappers in
// parallel. When we hit EX_IDENT matching `var`, return the type at that
// depth — that's `var`'s type. UN_DEREF/UN_ADDR/UN_ADDR_MUT each strip
// their corresponding type wrapper (or wrap, in the case of `*var` whose
// type is `ty_pointer(current)`). Returns null if shape diverges.
fn constrain_walk(arg: *Expr, ty: *Type, var: string) -> *Type {
    if arg == null || ty == null { return null; }
    if arg.kind == EX_IDENT && arg.str_val.eq(var) { return ty; }
    if arg.kind == EX_UNARY && arg.operand != null {
        if arg.op_code == UN_DEREF {
            return constrain_walk(arg.operand, ty_pointer(ty), var);
        }
        if arg.op_code == UN_ADDR {
            if ty.kind != TY_BORROW || ty.inner == null { return null; }
            return constrain_walk(arg.operand, ty.inner, var);
        }
        if arg.op_code == UN_ADDR_MUT {
            if ty.kind != TY_BORROW_MUT || ty.inner == null { return null; }
            return constrain_walk(arg.operand, ty.inner, var);
        }
    }
    return null;
}

fn try_constrain_from_stmt(g: *CG, s: *Stmt, var: string, gen_name: string, tparams: *Vector<string>) -> *Type {
    if s == null { return null; }
    if s.let_value != null {
        let r: *Type = try_constrain_from_expr(g, s.let_value, var, gen_name, tparams);
        if r != null { return r; }
    }
    if s.expr_value != null {
        let r: *Type = try_constrain_from_expr(g, s.expr_value, var, gen_name, tparams);
        if r != null { return r; }
    }
    if s.cond != null {
        let r: *Type = try_constrain_from_expr(g, s.cond, var, gen_name, tparams);
        if r != null { return r; }
    }
    if s.for_step != null {
        let r: *Type = try_constrain_from_expr(g, s.for_step, var, gen_name, tparams);
        if r != null { return r; }
    }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            let r: *Type = try_constrain_from_stmt(g, &b, var, gen_name, tparams);
            if r != null { return r; }
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            let r: *Type = try_constrain_from_stmt(g, &b, var, gen_name, tparams);
            if r != null { return r; }
        }
    }
    return null;
}

// Walk a stmt populating g.scope from any ST_LET it contains (recursively).
// Used so the type-inference pre-pass can resolve identifier references in
// nested blocks (e.g. `for let i: int = 0; ...; i++ { v.push(i * 10); }`).
fn populate_scope_from_stmt(g: *CG, s: *Stmt) {
    if s == null { return; }
    if s.kind == ST_LET || s.kind == ST_CONST {
        let mut ty: *Type = s.let_ty;
        // No annotation? Infer from the initializer so plain `let i = 0`
        // (typical in for-loops) registers `i: int` in the codegen scope —
        // otherwise printf-style macros default to `%p` and emit hex.
        if ty == null && s.let_value != null {
            ty = infer_for_codegen(g, s.let_value);
        }
        if ty != null { g.declare(s.name, ty); }
    }
    if s.for_init != null { populate_scope_from_stmt(g, s.for_init); }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            populate_scope_from_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            populate_scope_from_stmt(g, &b);
        }
    }
}

fn try_resolve_open_let(g: *CG, s: *Stmt, body: *Vector<Stmt>, start: i32) -> *Type {
    if s.let_ty != null { return null; }
    if s.let_value == null || s.let_value.kind != EX_CALL { return null; }
    let callee: *Expr = s.let_value.lhs;
    if callee == null { return null; }
    let mut gname: string = "";
    if callee.kind == EX_IDENT { gname = callee.str_val; }
    if callee.kind == EX_PATH {
        let qual: string = callee.str_val.concat("::").concat(callee.field);
        if g.module_aliases.contains(qual) {
            gname = g.module_aliases.get(qual);
        } else {
            gname = resolve_type_prefix(g, callee.str_val).concat("_").concat(callee.field);
        }
    }
    if gname.len() == 0 { return null; }
    if !g.generic_fns.contains(gname) { return null; }
    let template: Stmt = g.generic_fns.get(gname);
    if template.type_params == null || template.type_params.len() == 0 { return null; }
    if template.fn_ret_ty == null { return null; }
    let mut inner: *Type = template.fn_ret_ty;
    while inner != null && inner.kind == TY_POINTER {
        inner = inner.inner;
    }
    if inner == null || inner.kind != TY_GENERIC { return null; }
    let gen_base: string = inner.name;
    let n: i32 = body.len();
    for let j: i32 = start + 1; j < n; j++ {
        let s2: Stmt = body.get(j);
        let r: *Type = try_constrain_from_stmt(g, &s2, s.name, gen_base, template.type_params);
        if r != null { return r; }
    }
    return null;
}

// Pre-pass: for each `let v = Generic::new()` (no annot) anywhere in the fn,
// resolve T from the first subsequent use of v in the same body and backfill
// s.let_ty. Recurses into nested if/for/while bodies.
fn infer_let_types(g: *CG, body: *Vector<Stmt>) {
    if body == null { return; }
    // Pre-populate scope with all annotated lets (recursing) so identifier
    // inference works inside nested blocks.
    for let k: i32 = 0; k < body.len(); k++ {
        let sk: Stmt = body.get(k);
        populate_scope_from_stmt(g, &sk);
    }
    let n: i32 = body.len();
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET {
            let resolved: *Type = try_resolve_open_let(g, &s, body, i);
            if resolved != null {
                s.let_ty = resolved;
                body.set(i, s);
                g.declare(s.name, resolved);
            } else if s.let_ty == null && s.let_value != null
                      && s.let_names == null {
                // Backfill un-annotated tuple lets (`let p = (a, b);`) so the
                // program-wide tuple collection discovers the type even when
                // the elements are non-literal (idents resolved via scope).
                let vt: *Type = infer_for_codegen(g, s.let_value);
                if vt != null && vt.kind == TY_TUPLE {
                    s.let_ty = vt;
                    body.set(i, s);
                    g.declare(s.name, vt);
                }
            }
            // Declare destructured names so later tuple-literal inference in
            // the same body can see them.
            if s.let_names != null && s.let_names.len() > 0 && s.let_value != null {
                let dvt: *Type = infer_for_codegen(g, s.let_value);
                let dstr: *Type = strip_ptr(dvt);
                if dstr != null && dstr.kind == TY_TUPLE && dstr.args != null {
                    for let di: i32 = 0; di < s.let_names.len(); di++ {
                        if di < dstr.args.len() {
                            let el: Type = dstr.args.get(di);
                            let pp: *Type = __glide_palloc(sizeof(Type)) as *Type;
                            *pp = el;
                            g.declare(s.let_names.get(di), pp);
                        }
                    }
                }
            }
        }
        // Recurse into nested bodies for lets buried inside loops / branches.
        if s.then_body != null { infer_let_types(g, s.then_body); }
        if s.else_body != null { infer_let_types(g, s.else_body); }
    }
}

fn infer_let_types_in_program(g: *CG, program: *Vector<Stmt>) {
    let n: i32 = program.len();
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            // Set up a fresh scope with this fn's params so identifier
            // inference works during the pre-pass.
            g.scope.clear();
            if s.fn_params != null {
                for let k: i32 = 0; k < s.fn_params.len(); k++ {
                    let p: Param = s.fn_params.get(k);
                    g.declare(p.name, p.ty);
                }
            }
            infer_let_types(g, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null {
                    g.scope.clear();
                    if m.fn_params != null {
                        for let k: i32 = 0; k < m.fn_params.len(); k++ {
                            let p: Param = m.fn_params.get(k);
                            g.declare(p.name, p.ty);
                        }
                    }
                    infer_let_types(g, m.fn_body);
                }
            }
        }
    }
    // Restore empty scope for the regular emit pipeline.
    g.scope.clear();
}

// True iff `t` is the literal `void` named type, or a missing return type.
fn _main_ret_is_void(t: *Type) -> bool {
    if t == null { return true; }
    if t.kind == TY_NAMED && t.name.eq("void") { return true; }
    return false;
}

// C return type for the renamed __glide_user_main. Mirrors the user's
// declared return — the C `main` wrapper below converts whatever shape
// they picked into an exit code.
fn _main_user_c_ret(t: *Type) -> string {
    if _main_ret_is_void(t) { return "void"; }
    if t.kind == TY_NAMED && t.name.eq("int") { return "int"; }
    if t.kind == TY_RESULT && t.inner != null {
        let m: string = mangle_type(t.inner);
        return "__glide_result_".concat(m).concat("_t");
    }
    return type_to_c(t);
}

// User picked `fn main(argc: int, argv: **char) -> ...` — backward compat.
fn _main_takes_argv(s: *Stmt) -> bool {
    if s.fn_params == null { return false; }
    if s.fn_params.len() != 2 { return false; }
    return true;
}

// Emit the C `main(argc, argv)` wrapper that adapts the user's renamed
// main (whatever its signature) into a process exit code. Handles
// scheduler init/shutdown around the call.
fn _emit_main_wrapper(s: *Stmt) {
    let ret_ty: *Type = s.fn_ret_ty;
    let takes_argv: bool = _main_takes_argv(s);
    let call_args: string = "";
    if takes_argv { call_args = "argc, argv"; }
    println!("int main(int argc, char** argv) {");
    println!("    __glide_is_main_tls = 1;");
    println!("    __glide_args_init(argc, argv);");
    println!("    __glide_sched_init();");
    if _main_ret_is_void(ret_ty) {
        println!("    __glide_user_main(".concat(call_args).concat(");"));
        println!("    __glide_sched_shutdown();");
        println!("    return 0;");
    } else if ret_ty.kind == TY_NAMED && ret_ty.name.eq("int") {
        println!("    int __glide_rc = __glide_user_main(".concat(call_args).concat(");"));
        println!("    __glide_sched_shutdown();");
        println!("    return __glide_rc;");
    } else if ret_ty.kind == TY_RESULT && ret_ty.inner != null {
        let m: string = mangle_type(ret_ty.inner);
        let rt: string = "__glide_result_".concat(m).concat("_t");
        println!("    ".concat(rt).concat(" __glide_rc = __glide_user_main(").concat(call_args).concat(");"));
        println!("    __glide_sched_shutdown();");
        println!("    if (!__glide_rc.ok) {");
        println!("        fprintf(stderr, \"%s\\n\", __glide_rc.err ? __glide_rc.err : \"error\");");
        println!("        return 1;");
        println!("    }");
        let inner: *Type = ret_ty.inner;
        if inner != null && inner.kind == TY_NAMED && inner.name.eq("int") {
            println!("    return __glide_rc.val;");
        } else if inner != null && inner.kind == TY_NAMED && inner.name.eq("string") {
            println!("    if (__glide_rc.val) { fputs(__glide_rc.val, stdout); fputc('\\n', stdout); }");
            println!("    return 0;");
        } else {
            println!("    return 0;");
        }
    } else {
        println!("    (void)__glide_user_main(".concat(call_args).concat(");"));
        println!("    __glide_sched_shutdown();");
        println!("    return 0;");
    }
    println!("}");
}

fn emit_fn(g: *CG, s: *Stmt) {
    let is_main: bool = s.name.eq("main");
    // Track this fn's source origin so emit_stmt's `#line` directives
    // resolve against the right Glide file. The signature line itself
    // is emitted first (no directive yet) so a stack frame pointing
    // at the fn-entry shows the fn's declared line, not its caller.
    let saved_origin: string = g.current_origin;
    if s.origin != null && !s.origin.eq("") { g.current_origin = s.origin; }
    g.emit_line_dir(s.line, g.current_origin);
    if is_main {
        // User's main is renamed to __glide_user_main so the C wrapper
        // below owns the real `main` symbol. Signature mirrors the user's
        // declared return + params (`fn main()`, `fn main() -> !`, etc.);
        // the wrapper adapts it into a process exit code.
        let main_ret_c: string = _main_user_c_ret(s.fn_ret_ty);
        let main_params: string = "void";
        if _main_takes_argv(s) {
            main_params = "int __glide_main_argc, char** __glide_main_argv";
        }
        println!(main_ret_c.concat(" __glide_user_main(").concat(main_params).concat(") {"));
    } else {
        emit_fn_signature(s);
        println!(" {");
    }
    g.scope.clear();
    let saved_ret: *Type = g.current_ret_ty;
    g.current_ret_ty = s.fn_ret_ty;
    // Reset defer + auto-drop stacks for this fn.
    let saved_defer: *Vector<Expr> = g.defer_stack;
    let saved_err_defer: *Vector<Expr> = g.err_defer_stack;
    let saved_drop: *Vector<Expr> = g.auto_drop_stack;
    let new_defer: *Vector<Expr> = Vector::new();
    let new_err_defer: *Vector<Expr> = Vector::new();
    let new_drop: *Vector<Expr> = Vector::new();
    g.defer_stack = new_defer;
    g.err_defer_stack = new_err_defer;
    g.auto_drop_stack = new_drop;
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            g.declare(p.name, p.ty);
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            emit_stmt(g, &b, 1);
        }
    }
    // Flush any deferred exprs that didn't hit a return (e.g. fall-through fn end).
    g.emit_deferred_reverse(1);
    // Implicit `return __glide_ok_void();` at end of `fn -> !` so users can
    // write fns where success = falling off the end. Unreachable when every
    // path already returned, but harmless (no -Wreturn-type from gcc).
    if s.fn_ret_ty != null && s.fn_ret_ty.kind == TY_RESULT
       && s.fn_ret_ty.inner != null && s.fn_ret_ty.inner.kind == TY_NAMED
       && s.fn_ret_ty.inner.name.eq("void") {
        ind(1); println!("return __glide_ok_void();");
    }
    g.defer_stack = saved_defer;
    g.err_defer_stack = saved_err_defer;
    g.auto_drop_stack = saved_drop;
    g.current_ret_ty = saved_ret;
    g.current_origin = saved_origin;
    println!("}");

    // Real C `main` wrapper: runs scheduler init/shutdown around the user's
    // body and adapts whatever shape the user's main has into a process
    // exit code. Drains pending coroutines before exiting so `spawn worker();
    // main returns` waits for `worker` to finish (predictable for tests;
    // long-running servers stay in main's loop and never reach this point).
    if is_main {
        println!("");
        _emit_main_wrapper(s);
    }
}

fn emit_impl(g: *CG, s: *Stmt) {
    if s.impl_methods == null { return; }
    let saved_origin: string = g.current_origin;
    if s.origin != null && !s.origin.eq("") { g.current_origin = s.origin; }
    let mut prefix: string = "X";
    if s.impl_target != null && s.impl_target.kind == TY_NAMED {
        prefix = s.impl_target.name;
    }
    if s.impl_target != null && s.impl_target.kind == TY_GENERIC {
        prefix = mangle_generic(s.impl_target.name, s.impl_target.args);
    }
    // `impl T in NS { ... }` mangles to `NS_T_method` so two libs can each add
    // a `red()` method to `string` without colliding at link time. Bare
    // `impl T { ... }` keeps the unprefixed `T_method` name for back-compat.
    if s.import_path != null && !s.import_path.eq("") {
        prefix = s.import_path.concat("_").concat(prefix);
    }
    for let i: i32 = 0; i < s.impl_methods.len(); i++ {
        let m: Stmt = s.impl_methods.get(i);
        // Mangle method name: Type_method.
        let mangled: string = prefix.concat("_").concat(m.name);
        g.emit_line_dir(m.line, g.current_origin);
        // Emit a fn with mangled name.
        let mut saved_name: string = m.name;
        // We can't mutate the Stmt easily here; emit signature inline then body.
        print!(type_to_c(m.fn_ret_ty), " ", mangled, "(");
        if m.fn_params == null || m.fn_params.len() == 0 {
            print!("void");
        } else {
            for let j: i32 = 0; j < m.fn_params.len(); j++ {
                if j > 0 { print!(", "); }
                let p: Param = m.fn_params.get(j);
                print!(type_to_c(p.ty), " ", c_safe_ident(p.name));
            }
        }
        println!(") {");
        g.scope.clear();
        // Track the method's return type so `err(...)` / `ok(...)` lower to
        // the right `__glide_err_T` / `__glide_ok_T` helpers (same as
        // emit_fn does for top-level fns).
        let saved_ret: *Type = g.current_ret_ty;
        g.current_ret_ty = m.fn_ret_ty;
        let saved_defer: *Vector<Expr> = g.defer_stack;
        let saved_err_defer: *Vector<Expr> = g.err_defer_stack;
        let saved_drop: *Vector<Expr> = g.auto_drop_stack;
        let nd: *Vector<Expr> = Vector::new();
        let ned: *Vector<Expr> = Vector::new();
        let nadr: *Vector<Expr> = Vector::new();
        g.defer_stack = nd;
        g.err_defer_stack = ned;
        g.auto_drop_stack = nadr;
        if m.fn_params != null {
            for let j: i32 = 0; j < m.fn_params.len(); j++ {
                let p: Param = m.fn_params.get(j);
                g.declare(p.name, p.ty);
            }
        }
        if m.fn_body != null {
            for let j: i32 = 0; j < m.fn_body.len(); j++ {
                let b: Stmt = m.fn_body.get(j);
                emit_stmt(g, &b, 1);
            }
        }
        g.emit_deferred_reverse(1);
        g.defer_stack = saved_defer;
        g.err_defer_stack = saved_err_defer;
        g.auto_drop_stack = saved_drop;
        g.current_ret_ty = saved_ret;
        println!("}");
        println!("");
    }
    g.current_origin = saved_origin;
}

// Emit forward declarations for an `impl T { ... }` block's methods. Same
// mangling rule as emit_impl. Lets methods reference each other (and free
// fns reference impl methods) regardless of source order.
fn emit_impl_fwd_decls(g: *CG, s: *Stmt) {
    if s.impl_methods == null { return; }
    let mut prefix: string = "X";
    if s.impl_target != null && s.impl_target.kind == TY_NAMED {
        prefix = s.impl_target.name;
    }
    if s.impl_target != null && s.impl_target.kind == TY_GENERIC {
        prefix = mangle_generic(s.impl_target.name, s.impl_target.args);
    }
    if s.import_path != null && !s.import_path.eq("") {
        prefix = s.import_path.concat("_").concat(prefix);
    }
    for let i: i32 = 0; i < s.impl_methods.len(); i++ {
        let m: Stmt = s.impl_methods.get(i);
        let mangled: string = prefix.concat("_").concat(m.name);
        print!(type_to_c(m.fn_ret_ty), " ", mangled, "(");
        if m.fn_params == null || m.fn_params.len() == 0 {
            print!("void");
        } else {
            for let j: i32 = 0; j < m.fn_params.len(); j++ {
                if j > 0 { print!(", "); }
                let p: Param = m.fn_params.get(j);
                print!(type_to_c(p.ty), " ", c_safe_ident(p.name));
            }
        }
        println!(");");
    }
}

fn emit_struct(s: *Stmt) {
    let cname: string = c_safe_ident(s.name);
    println!("typedef struct ", cname, " {");
    if s.struct_fields != null {
        for let i: i32 = 0; i < s.struct_fields.len(); i++ {
            let f: Field = s.struct_fields.get(i);
            print!("    ", type_to_c(f.ty), " ", c_safe_ident(f.name)); println!(";");
        }
    }
    println!("} ", cname, ";");
    println!("");
}

fn emit_enum(s: *Stmt) {
    let mut has_payload: bool = false;
    if s.enum_variants != null {
        for let i: i32 = 0; i < s.enum_variants.len(); i++ {
            let v: EnumVariant = s.enum_variants.get(i);
            if v.fields != null && v.fields.len() > 0 { has_payload = true; }
        }
    }
    let ename: string = c_safe_ident(s.name);
    println!("typedef struct ", ename, " {");
    println!("    int tag;");
    if has_payload {
        println!("    union {");
        if s.enum_variants != null {
            for let i: i32 = 0; i < s.enum_variants.len(); i++ {
                let v: EnumVariant = s.enum_variants.get(i);
                if v.fields == null || v.fields.len() == 0 { continue; }
                if v.fields.len() == 1 {
                    let t: Type = v.fields.get(0);
                    print!("        ");
                    print!(type_to_c(&t));
                    print!(" v_");
                    print!(v.name);
                    println!(";");
                } else {
                    print!("        struct { ");
                    for let j: i32 = 0; j < v.fields.len(); j++ {
                        if j > 0 { print!(" "); }
                        let t: Type = v.fields.get(j);
                        print!(type_to_c(&t));
                        print!(" f");
                        print!(j);
                        print!(";");
                    }
                    print!(" } v_");
                    print!(v.name);
                    println!(";");
                }
            }
        }
        println!("    } data;");
    }
    println!("} ", ename, ";");
    if s.enum_variants != null {
        for let i: i32 = 0; i < s.enum_variants.len(); i++ {
            let v: EnumVariant = s.enum_variants.get(i);
            print!("#define ");
            print!(ename);
            print!("_");
            print!(v.name);
            print!(" ");
            print!(i);
            println!("");
        }
    }
    println!("");
}

// Register `<suffix>::<name>` -> `<name>` for every suffix of `mod_path`.
// For mod_path `stdlib::math` and name `min_int` this populates:
//   `stdlib::math::min_int` -> `min_int`   (full path)
//   `math::min_int`         -> `min_int`   (last-segment shorthand)
// so users can write either the full or partial qualified form. Single-
// segment paths only register the full form. Last write wins on collisions
// (Phase 2 territory).
fn register_alias_suffixes(g: *CG, mod_path: string, name: string) {
    if mod_path == null || mod_path.eq("") { return; }
    if name == null || name.eq("") { return; }
    let n: i32 = mod_path.len();
    let mut start: i32 = 0;
    while start < n {
        let suffix: string = mod_path.substring(start, n);
        g.module_aliases.insert(suffix.concat("::").concat(name), name);
        let mut next: i32 = -1;
        let mut i: i32 = start;
        while i + 1 < n {
            if mod_path.at(i).to_int() == 58 && mod_path.at(i + 1).to_int() == 58 {
                next = i + 2;
                break;
            }
            i = i + 1;
        }
        if next < 0 { break; }
        start = next;
    }
}

// Convert a source file path to a `::`-separated module path. Strips the
// `.glide` suffix and rewrites `/` and `\` to `::`. Used so user code can
// reach a pub item by `module::path::Item` instead of (or in addition to)
// the bare short name.
fn module_path_from_origin(origin: string) -> string {
    if origin == null || origin.eq("") { return ""; }
    let mut s: string = origin;
    let n: i32 = s.len();
    if n > 6 {
        let tail: string = s.substring(n - 6, n);
        if tail.eq(".glide") { s = s.substring(0, n - 6); }
    }
    // Strip the leading `src/` segment so user-facing module paths don't
    // expose the source-root layout. Files under `src/stdlib/foo.glide`
    // become `stdlib::foo`; files outside `src/` keep their full path.
    let len0: i32 = s.len();
    if len0 >= 4 {
        let first: i32 = s.at(0).to_int();
        let second: i32 = s.at(1).to_int();
        let third: i32 = s.at(2).to_int();
        let fourth: i32 = s.at(3).to_int();
        if first == 115 && second == 114 && third == 99
            && (fourth == 47 || fourth == 92) {
            s = s.substring(4, len0);
        }
    }
    let mut out: string = "";
    let mut i: i32 = 0;
    let len: i32 = s.len();
    while i < len {
        let c: i32 = s.at(i).to_int();
        if c == 47 || c == 92 {
            out = out.concat("::");
        } else {
            out = out.concat(s.substring(i, i + 1));
        }
        i = i + 1;
    }
    return out;
}

// Resolve a possibly-qualified path to its short C-symbol form. If `prefix`
// is empty the path is already bare; otherwise we look up `<prefix>::<name>`
// in the alias table and return the registered short name. Falls back to the
// last-segment of `prefix` (e.g. `Vector` from `stdlib::vector::Vector`)
// when no alias matches — that lets new user-written paths still resolve to
// the existing flat naming as long as the trailing type name is unique.
fn resolve_path_alias(g: *CG, prefix: string, name: string) -> string {
    if prefix == null || prefix.eq("") { return name; }
    let qual: string = prefix.concat("::").concat(name);
    if g.module_aliases.contains(qual) {
        return g.module_aliases.get(qual);
    }
    return name;
}

// Resolve the type-prefix of a multi-segment path (e.g. for
// `stdlib::vector::Vector::new`, `prefix` is `stdlib::vector::Vector` and we
// want `Vector` back). Used by EX_PATH normalisation in expression handlers.
fn resolve_type_prefix(g: *CG, prefix: string) -> string {
    if prefix == null || prefix.eq("")  { return prefix; }
    if g.module_aliases.contains(prefix) {
        return g.module_aliases.get(prefix);
    }
    // Fallback: trailing segment after the last `::`.
    let n: i32 = prefix.len();
    let mut i: i32 = n - 1;
    while i > 0 {
        if i + 1 < n && prefix.at(i).to_int() == 58 && prefix.at(i + 1).to_int() == 58 {
            // not how we scan — fix: look for the last `::` running backwards
            break;
        }
        i = i - 1;
    }
    // Simple forward scan for last `::` (cheap; module paths are short).
    let mut last: i32 = -1;
    let mut j: i32 = 0;
    while j + 1 < n {
        if prefix.at(j).to_int() == 58 && prefix.at(j + 1).to_int() == 58 {
            last = j;
            j = j + 2;
        } else {
            j = j + 1;
        }
    }
    if last < 0 { return prefix; }
    return prefix.substring(last + 2, n);
}

pub fn emit_program(program: *Vector<Stmt>) {
    print!(include_str!("bootstrap/runtime/prelude.c"));
    println!("");

    emit_stdlib_runtime();

    let g: *CG = CG::new();

    // Register generic struct templates up front so that runtime emitters
    // (chan, result) can synthesize struct monos for their inner types
    // (e.g. `chan<Vector<int>>` needs the `Vector__int` body before the
    // chan runtime references it). Also register concrete structs/enums so
    // chan<UserType> can emit the body before the chan storage references it.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_STRUCT {
            if s.type_params != null && s.type_params.len() > 0 {
                g.generic_structs.insert(s.name, s);
            } else {
                g.structs.insert(s.name, s);
            }
        }
        if s.kind == ST_ENUM {
            g.enums.insert(s.name, s);
        }
        if s.kind == ST_TRAIT && s.name != null && !s.name.eq("") {
            g.traits.insert(s.name, s);
        }
    }

    // ---- Concurrency pre-pass: collect chan inner types + emit pthread runtime
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        collect_chan_in_stmt(g, &s);
    }
    emit_scheduler_runtime();
    emit_socket_runtime();

    // Top-level `c_raw! { ... }` blocks: emit verbatim AFTER the runtime
    // so they can `#ifdef` against macros set by socket.c / reactor.c (e.g.
    // bootstrap fallbacks gated on __GLIDE_RUNTIME_HAS_REACTOR_ACTIVE).
    // Still before user code, so they remain visible to the rest of the
    // emit. Order matches source order so users can split raw payloads
    // across files predictably.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_CRAW {
            emit_cfg_open(s.cfg_target);
            print!(s.name);
            println!("");
            emit_cfg_close(s.cfg_target);
        }
    }

    // Forward typedef every concrete user struct/enum up front. Subsequent
    // pre-emit passes (chan-inner bodies, result-inner bodies, etc.) emit
    // FULL bodies that may reference *OtherStruct as field types — without
    // a forward decl already in scope, those references emit `unknown type`.
    // C99 accepts duplicate `typedef struct X X;` declarations, so the
    // later body-emit passes that re-issue the forward are harmless.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.name == null || s.name.eq("") { continue; }
        if s.kind == ST_STRUCT && (s.type_params == null || s.type_params.len() == 0) {
            println!("typedef struct ", c_safe_ident(s.name), " ", c_safe_ident(s.name), ";");
        }
        if s.kind == ST_ENUM {
            println!("typedef struct ", c_safe_ident(s.name), " ", c_safe_ident(s.name), ";");
        }
    }
    println!("");

    // Anonymous tuple structs — early pass. Collect tuple types reachable
    // from type annotations (struct fields, fn signatures, written `let`
    // annotations) and emit their typedefs now, before any struct body or
    // chan/result/option wrapper that stores a tuple by value. Generic
    // templates are skipped (their element type params aren't concrete yet);
    // a later pass picks up tuples inferred from literals + backfilled lets.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.type_params != null && s.type_params.len() > 0 { continue; }
        if s.kind == ST_STRUCT && s.type_params != null && s.type_params.len() > 0 { continue; }
        if s.kind == ST_IMPL && s.type_params != null && s.type_params.len() > 0 { continue; }
        collect_tuple_in_stmt(g, &s);
    }
    emit_tuple_runtime(g);

    // Pre-emit user struct/enum bodies that show up as chan<T> inners. The
    // chan template stores `T v;` by value so it needs the full definition,
    // not just a forward typedef. Walk the program directly (not g.structs)
    // because the registration pass is later in emit_program.
    for let i: i32 = 0; i < g.chan_types.len(); i++ {
        let t: Type = g.chan_types.get(i);
        if t.kind != TY_NAMED { continue; }
        if t.name == null || t.name.eq("") { continue; }
        if g.emitted_named.contains(t.name) { continue; }
        for let j: i32 = 0; j < program.len(); j++ {
            let s: Stmt = program.get(j);
            if s.name == null || s.name.eq("") { continue; }
            if !s.name.eq(t.name) { continue; }
            if s.kind == ST_STRUCT && (s.type_params == null || s.type_params.len() == 0) {
                println!("typedef struct ", s.name, " ", s.name, ";");
                emit_struct(&s);
                g.emitted_named.insert(t.name, true);
            } else if s.kind == ST_ENUM {
                println!("typedef struct ", s.name, " ", s.name, ";");
                emit_enum(&s);
                g.emitted_named.insert(t.name, true);
            }
        }
    }

    emit_chan_runtime(g);

    // ---- dyn Trait pre-pass + emission ----
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        collect_dyn_in_stmt(g, &s);
    }
    // Pre-emit struct bodies for every Type that appears as an `impl Trait
    // for Type` target where Trait is dyn-used. The thunks emitted by
    // emit_dyn_runtime do `*(Type*)self_p`, which needs the full definition.
    // Each struct's field types may reference generic mono structs
    // (Vector<T>, HashMap<V>, etc.); forward-decl those before emitting
    // the struct body so the field types are in scope.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_IMPL { continue; }
        if s.impl_trait_name == null || s.impl_trait_name.eq("") { continue; }
        if !g.dyn_traits.contains(s.impl_trait_name) { continue; }
        if s.impl_target == null || s.impl_target.kind != TY_NAMED { continue; }
        let tn: string = s.impl_target.name;
        if g.emitted_named.contains(tn) { continue; }
        for let j: i32 = 0; j < program.len(); j++ {
            let ts: Stmt = program.get(j);
            if ts.name == null || ts.name.eq("") { continue; }
            if !ts.name.eq(tn) { continue; }
            if ts.kind == ST_STRUCT && (ts.type_params == null || ts.type_params.len() == 0) {
                _forward_decl_field_monos(g, &ts);
                println!("typedef struct ".concat(ts.name).concat(" ").concat(ts.name).concat(";"));
                emit_struct(&ts);
                g.emitted_named.insert(tn, true);
            } else if ts.kind == ST_ENUM {
                println!("typedef struct ".concat(ts.name).concat(" ").concat(ts.name).concat(";"));
                emit_enum(&ts);
                g.emitted_named.insert(tn, true);
            }
        }
    }
    // emit_dyn_runtime is deferred until AFTER emit_result_runtime /
    // emit_option_runtime / emit_optres_runtime — the vtable struct's
    // method-pointer types (and the per-method thunk forward decls)
    // reference `__glide_option_<T>_t` / `__glide_result_<T>_t`, so
    // those typedefs must already be in scope. Emitting dyn runtime
    // here would make the C compiler treat the option/result type
    // names as implicit-int and silently mismatch the real
    // declarations later.

    // ---- Errors-as-values pre-pass: collect Result inner types + emit runtime
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        // Skip generic templates — their bodies reference type params and
        // assoc projections that will be resolved per-instantiation. Mono
        // entries are added to the queue and collected when emitted.
        if s.kind == ST_FN && s.type_params != null && s.type_params.len() > 0 { continue; }
        if s.kind == ST_STRUCT && s.type_params != null && s.type_params.len() > 0 { continue; }
        if s.kind == ST_IMPL && s.type_params != null && s.type_params.len() > 0 { continue; }
        // Trait body sigs reference `Self::Item` placeholders; never collect.
        // Concrete impls of the trait collect their own substituted types.
        if s.kind == ST_TRAIT { continue; }
        collect_result_in_stmt(g, &s);
    }
    // Same chan-userType story: result_<T> wraps T by value, so user
    // struct/enum bodies must be emitted before the result helpers.
    for let i: i32 = 0; i < g.result_types.len(); i++ {
        let t: Type = g.result_types.get(i);
        // Forward-declare any generic mono struct names referenced
        // anywhere in the result's wrapped type (T may be `*Vector<X>`
        // where TY_POINTER -> TY_GENERIC). Without this, the result
        // struct typedef references a yet-undeclared mangled tag.
        forward_decl_generic_monos(g, &t);
        if t.kind != TY_NAMED { continue; }
        if t.name == null || t.name.eq("") { continue; }
        if g.emitted_named.contains(t.name) { continue; }
        for let j: i32 = 0; j < program.len(); j++ {
            let s: Stmt = program.get(j);
            if s.name == null || s.name.eq("") { continue; }
            if !s.name.eq(t.name) { continue; }
            if s.kind == ST_STRUCT && (s.type_params == null || s.type_params.len() == 0) {
                _forward_decl_field_monos(g, &s);
                println!("typedef struct ", s.name, " ", s.name, ";");
                emit_struct(&s);
                g.emitted_named.insert(t.name, true);
            } else if s.kind == ST_ENUM {
                println!("typedef struct ", s.name, " ", s.name, ";");
                emit_enum(&s);
                g.emitted_named.insert(t.name, true);
            }
        }
    }
    emit_result_runtime(g);

    // Same up-front emission for option_<T> / optres_<T> wrappers.
    for let i: i32 = 0; i < g.option_types.len(); i++ {
        let t: Type = g.option_types.get(i);
        forward_decl_generic_monos(g, &t);
        if t.kind != TY_NAMED { continue; }
        if t.name == null || t.name.eq("") { continue; }
        if g.emitted_named.contains(t.name) { continue; }
        for let j: i32 = 0; j < program.len(); j++ {
            let s: Stmt = program.get(j);
            if s.name == null || s.name.eq("") { continue; }
            if !s.name.eq(t.name) { continue; }
            if s.kind == ST_STRUCT && (s.type_params == null || s.type_params.len() == 0) {
                _forward_decl_field_monos(g, &s);
                println!("typedef struct ", s.name, " ", s.name, ";");
                emit_struct(&s);
                g.emitted_named.insert(t.name, true);
            } else if s.kind == ST_ENUM {
                println!("typedef struct ", s.name, " ", s.name, ";");
                emit_enum(&s);
                g.emitted_named.insert(t.name, true);
            }
        }
    }
    emit_option_runtime(g);

    for let i: i32 = 0; i < g.optres_types.len(); i++ {
        let t: Type = g.optres_types.get(i);
        forward_decl_generic_monos(g, &t);
        if t.kind != TY_NAMED { continue; }
        if t.name == null || t.name.eq("") { continue; }
        if g.emitted_named.contains(t.name) { continue; }
        for let j: i32 = 0; j < program.len(); j++ {
            let s: Stmt = program.get(j);
            if s.name == null || s.name.eq("") { continue; }
            if !s.name.eq(t.name) { continue; }
            if s.kind == ST_STRUCT && (s.type_params == null || s.type_params.len() == 0) {
                _forward_decl_field_monos(g, &s);
                println!("typedef struct ", s.name, " ", s.name, ";");
                emit_struct(&s);
                g.emitted_named.insert(t.name, true);
            } else if s.kind == ST_ENUM {
                println!("typedef struct ", s.name, " ", s.name, ";");
                emit_enum(&s);
                g.emitted_named.insert(t.name, true);
            }
        }
    }
    emit_optres_runtime(g);

    // Now that every option/result/optres typedef is in scope, the
    // dyn-trait vtable struct + thunks can reference them safely.
    emit_dyn_runtime(g, program);

    // Populate codegen's assoc_table from every `impl Trait for T { type X = Y; }`.
    // Used by mangle_type / type_to_c to resolve TY_ASSOC owners that became
    // concrete after monomorphization.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_IMPL { continue; }
        if s.impl_trait_name == null || s.impl_trait_name.eq("") { continue; }
        if s.assoc_decls == null { continue; }
        if s.impl_target == null { continue; }
        let mut tname: string = "";
        if s.impl_target.kind == TY_NAMED   { tname = s.impl_target.name; }
        if s.impl_target.kind == TY_GENERIC { tname = s.impl_target.name; }
        if tname.eq("") { continue; }
        for let j: i32 = 0; j < s.assoc_decls.len(); j++ {
            let a: Param = s.assoc_decls.get(j);
            if a.ty == null { continue; }
            let key: string = s.impl_trait_name.concat("::").concat(tname)
                .concat("::").concat(a.name);
            g.assoc_table.insert(key, *a.ty);
        }
    }

    // Register generic struct + fn + impl-method templates.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        let mod_path: string = module_path_from_origin(s.origin);
        if s.kind == ST_STRUCT {
            if s.type_params != null && s.type_params.len() > 0 {
                g.generic_structs.insert(s.name, s);
            } else {
                g.structs.insert(s.name, s);
            }
            register_alias_suffixes(g, mod_path, s.name);
        }
        if s.kind == ST_FN {
            if s.type_params != null && s.type_params.len() > 0 {
                g.generic_fns.insert(s.name, s);
            } else {
                g.fns.insert(s.name, s);
            }
            register_alias_suffixes(g, mod_path, s.name);
        }
        if s.kind == ST_ENUM {
            g.enums.insert(s.name, s);
            register_alias_suffixes(g, mod_path, s.name);
        }
        if s.kind == ST_CONST && s.let_ty != null {
            g.consts.insert(s.name, *s.let_ty);
        }
        if s.kind == ST_IMPL && (s.type_params == null || s.type_params.len() == 0)
           && s.impl_target != null && s.impl_methods != null {
            let mut prefix: string = "X";
            if s.impl_target.kind == TY_NAMED { prefix = s.impl_target.name; }
            // `impl Vector<int> { ... }` — concrete specialization on a
            // generic type. Mangled prefix is `Vector__int` so it doesn't
            // collide with the generic `impl<T> Vector<T>` family.
            if s.impl_target.kind == TY_GENERIC {
                prefix = mangle_generic(s.impl_target.name, s.impl_target.args);
            }
            // `impl T in NS` registers as `NS_T_method` so two libs can both
            // add e.g. `red()` to string without colliding. Bare `impl T` keeps
            // the unprefixed `T_method` name for back-compat.
            let mut is_namespaced: bool = false;
            let mut bare_prefix: string = prefix;
            if s.import_path != null && !s.import_path.eq("") {
                prefix = s.import_path.concat("_").concat(prefix);
                is_namespaced = true;
            }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                let synth: *Stmt = calloc(1, sizeof(Stmt)) as *Stmt;
                *synth = m;
                synth.name = prefix.concat("_").concat(m.name);
                g.fns.insert(synth.name, *synth);
                // Mark as a real method so `obj.method()` dispatch finds it
                // - free fns named `<Type>_<method>` won't be sugared.
                g.method_fns.insert(synth.name, true);
                if is_namespaced {
                    let key: string = bare_prefix.concat("_").concat(m.name);
                    if g.method_index.contains(key) {
                        let prev: string = g.method_index.get(key);
                        g.method_index.insert(key, prev.concat(";").concat(synth.name));
                    } else {
                        g.method_index.insert(key, synth.name);
                    }
                }
            }
        }
        if s.kind == ST_IMPL && s.type_params != null && s.type_params.len() > 0
           && s.impl_target != null && s.impl_methods != null {
            // Build mangled prefix from target's name.
            let mut prefix: string = "X";
            if s.impl_target.kind == TY_NAMED { prefix = s.impl_target.name; }
            if s.impl_target.kind == TY_GENERIC { prefix = s.impl_target.name; }
            // Register each method as a generic fn under `Type_method` name.
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                let mname: string = prefix.concat("_").concat(m.name);
                // Synthesize a generic fn Stmt with the impl's type_params merged
                // into the method's type_params.
                let synth: *Stmt = calloc(1, sizeof(Stmt)) as *Stmt;
                *synth = m;
                synth.name = mname;
                let combined: *Vector<string> = Vector::new();
                for let k: i32 = 0; k < s.type_params.len(); k++ {
                    combined.push(s.type_params.get(k));
                }
                if m.type_params != null {
                    for let k: i32 = 0; k < m.type_params.len(); k++ {
                        combined.push(m.type_params.get(k));
                    }
                }
                synth.type_params = combined;
                g.generic_fns.insert(mname, *synth);
                g.method_fns.insert(mname, true);
            }
        }
    }

    // Pre-pass: backfill `let v = Generic::new()` (no annot) by inferring T
    // from the first subsequent use of v. Must run AFTER generic fn registry
    // is populated and BEFORE the generic-uses collection below.
    infer_let_types_in_program(g, program);

    // Walk the program collecting Type::Generic uses, emit specialized structs.
    let monos: *Vector<Type> = Vector::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        collect_generic_uses_in_stmt(&s, monos);
    }
    // Emit forward typedefs first (mono structs + concrete).
    for let i: i32 = 0; i < monos.len(); i++ {
        let t: Type = monos.get(i);
        let mangled: string = mangle_generic(t.name, t.args);
        if !g.emitted_monos.contains(mangled) {
            g.emitted_monos.insert(mangled, true);
            println!("typedef struct ", mangled, " ", mangled, ";");
        }
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_STRUCT && (s.type_params == null || s.type_params.len() == 0) {
            if s.name != null && !s.name.eq("") && g.emitted_named.contains(s.name) { continue; }
            println!("typedef struct ", s.name, " ", s.name, ";");
        }
    }
    println!("");

    // Emit specialized struct bodies.
    for let i: i32 = 0; i < monos.len(); i++ {
        let t: Type = monos.get(i);
        emit_struct_mono(g, &t);
    }

    // Concrete struct definitions. Skip anything the chan runtime already
    // forward-emitted (chan<UserType> needs the body up front).
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.name != null && !s.name.eq("") && g.emitted_named.contains(s.name) { continue; }
        if s.kind == ST_STRUCT && (s.type_params == null || s.type_params.len() == 0) {
            emit_struct(&s);
        }
        if s.kind == ST_ENUM { emit_enum(&s); }
    }

    // Anonymous tuple structs. Collected program-wide now that let types are
    // backfilled and every struct/mono body is in scope (tuple elements may
    // be user structs stored by value). Tuples wrapped in `!T` / `?T` were
    // already emitted by the result/option pre-pass; the dedup guard makes
    // this re-emission a no-op for those.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.type_params != null && s.type_params.len() > 0 { continue; }
        if s.kind == ST_STRUCT && s.type_params != null && s.type_params.len() > 0 { continue; }
        if s.kind == ST_IMPL && s.type_params != null && s.type_params.len() > 0 { continue; }
        collect_tuple_in_stmt(g, &s);
    }
    emit_tuple_runtime(g);

    // Top-level const definitions (#define for ints, static const for others).
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_CONST {
            emit_top_const(g, &s);
        }
    }
    println!("");

    // Forward fn declarations (concrete only). Includes impl-block methods
    // so they can call each other regardless of source order.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && (s.type_params == null || s.type_params.len() == 0) {
            emit_cfg_open(s.cfg_target);
            emit_fn_signature(&s); println!(";");
            emit_cfg_close(s.cfg_target);
        }
        if s.kind == ST_IMPL && (s.type_params == null || s.type_params.len() == 0) {
            emit_impl_fwd_decls(g, &s);
        }
    }

    // Pre-scan: walk every concrete fn / impl method to discover all generic
    // call sites. Emit forward declarations for each mono so their later
    // bodies can be called from anywhere.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && (s.type_params == null || s.type_params.len() == 0) {
            prescan_stmt(g, &s);
        }
        if s.kind == ST_IMPL && (s.type_params == null || s.type_params.len() == 0) {
            if s.impl_methods != null {
                for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                    let m: Stmt = s.impl_methods.get(j);
                    prescan_stmt(g, &m);
                }
            }
        }
    }
    // Walk the queued monos transitively (a mono body may call other generics).
    let mut idx: i32 = 0;
    while idx < g.fn_mono_queue.len() {
        let entry: FnMonoEntry = g.fn_mono_queue.get(idx);
        if g.generic_fns.contains(entry.name) {
            let template: Stmt = g.generic_fns.get(entry.name);
            // Set up scope with substituted param types so receiver-type lookup
            // works inside the substituted body.
            g.scope.clear();
            if template.fn_params != null {
                for let j: i32 = 0; j < template.fn_params.len(); j++ {
                    let p: Param = template.fn_params.get(j);
                    let pt: *Type = subst_type(p.ty, template.type_params, entry.args);
                    g.declare(p.name, pt);
                }
            }
            if template.fn_body != null {
                for let j: i32 = 0; j < template.fn_body.len(); j++ {
                    let b: Stmt = template.fn_body.get(j);
                    let nb: *Stmt = subst_stmt(&b, template.type_params, entry.args, g.generic_structs);
                    if nb != null { prescan_stmt(g, nb); }
                }
            }
        }
        idx = idx + 1;
    }
    // Drain dynamically-discovered struct monos (e.g. via chained ctor
    // inference). Emit typedef + body before any fn forward decl that may
    // reference the struct by name.
    for let i: i32 = 0; i < g.struct_mono_queue.len(); i++ {
        let t: Type = g.struct_mono_queue.get(i);
        let mangled: string = mangle_generic(t.name, t.args);
        if !g.emitted_monos.contains(mangled) {
            g.emitted_monos.insert(mangled, true);
            println!("typedef struct ", mangled, " ", mangled, ";");
            emit_struct_mono(g, &t);
        }
    }
    // Tuple typedefs reachable from monomorphized generic fns. The template's
    // `(T, ...)` types are skipped by the program-wide tuple passes (T isn't
    // concrete there); substitute each mono's args and collect the resulting
    // concrete tuples so the typedef precedes the mono's forward decl + body.
    for let i: i32 = 0; i < g.fn_mono_queue.len(); i++ {
        let entry: FnMonoEntry = g.fn_mono_queue.get(i);
        if !g.generic_fns.contains(entry.name) { continue; }
        let template: Stmt = g.generic_fns.get(entry.name);
        let rt: *Type = subst_type(template.fn_ret_ty, template.type_params, entry.args);
        collect_tuple_in_type(g, rt);
        g.scope.clear();
        if template.fn_params != null {
            for let j: i32 = 0; j < template.fn_params.len(); j++ {
                let p: Param = template.fn_params.get(j);
                let pt: *Type = subst_type(p.ty, template.type_params, entry.args);
                collect_tuple_in_type(g, pt);
                g.declare(p.name, pt);
            }
        }
        if template.fn_body != null {
            for let j: i32 = 0; j < template.fn_body.len(); j++ {
                let b: Stmt = template.fn_body.get(j);
                let nb: *Stmt = subst_stmt(&b, template.type_params, entry.args, g.generic_structs);
                if nb != null { collect_tuple_in_stmt(g, nb); }
            }
        }
    }
    g.scope.clear();
    emit_tuple_runtime(g);

    // Now emit forward declarations for every queued mono.
    for let i: i32 = 0; i < g.fn_mono_queue.len(); i++ {
        let entry: FnMonoEntry = g.fn_mono_queue.get(i);
        if g.generic_fns.contains(entry.name) {
            let template: Stmt = g.generic_fns.get(entry.name);
            let mangled: string = mangle_generic(entry.name, entry.args);
            emit_mono_forward_decl(g, mangled, &template, entry.args);
        }
    }
    println!("");

    // Pre-pass: walk all fn bodies to discover EX_FNEXPR uses. Lift each
    // into g.anon_fns and rewrite the expression in place to EX_IDENT
    // referring to the synthetic name. Output forward decls so the user
    // fns can reference them.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        lift_anons_in_stmt(g, &s);
    }
    for let i: i32 = 0; i < g.anon_fns.len(); i++ {
        let af: AnonFn = g.anon_fns.get(i);
        print!(type_to_c(af.ret_ty), " ", af.name, "(");
        if af.params == null || af.params.len() == 0 {
            print!("void");
        } else {
            for let j: i32 = 0; j < af.params.len(); j++ {
                if j > 0 { print!(", "); }
                let p: Param = af.params.get(j);
                print!(type_to_c(p.ty), " ", c_safe_ident(p.name));
            }
        }
        println!(");");
    }
    println!("");

    // Pre-emit spawn stubs (one per spawn site). The counter `g.spawn_count`
    // resets to 0 after this so the emit-pass walks the AST in the same order
    // and pulls the matching ID.
    g.spawn_count = 0;
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        pre_emit_spawn_stubs_in_stmt(g, &s);
    }
    g.spawn_count = 0;

    // Function + impl definitions (skip generic ones, and skip extern/bodyless).
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && (s.type_params == null || s.type_params.len() == 0)
           && s.fn_body != null {
            emit_cfg_open(s.cfg_target);
            emit_fn(g, &s); println!("");
            emit_cfg_close(s.cfg_target);
        }
        if s.kind == ST_IMPL && (s.type_params == null || s.type_params.len() == 0) {
            emit_cfg_open(s.cfg_target);
            emit_impl(g, &s);
            emit_cfg_close(s.cfg_target);
        }
    }

    // Drain generic fn mono queue. New monos may queue more; loop until empty.
    while g.fn_mono_queue.len() > 0 {
        let e: FnMonoEntry = g.fn_mono_queue.pop();
        if !g.generic_fns.contains(e.name) { continue; }
        let template: Stmt = g.generic_fns.get(e.name);
        let mangled: string = mangle_generic(e.name, e.args);
        // Substitute type params throughout the body / params / ret. After
        // subst_type makes owners concrete, resolve any TY_ASSOC via the
        // impl assoc_table.
        let new_params_v: *Vector<Param> = Vector::new();
        if template.fn_params != null {
            for let i: i32 = 0; i < template.fn_params.len(); i++ {
                let p: Param = template.fn_params.get(i);
                let pt: *Type = subst_type(p.ty, template.type_params, e.args);
                pt = resolve_assoc_recursive(g, pt);
                let np: Param = Param { name: p.name, ty: pt, name_line: p.name_line, name_col: p.name_col };
                new_params_v.push(np);
            }
        }
        let mut new_ret: *Type = subst_type(template.fn_ret_ty, template.type_params, e.args);
        new_ret = resolve_assoc_recursive(g, new_ret);
        let new_body: *Vector<Stmt> = Vector::new();
        if template.fn_body != null {
            for let i: i32 = 0; i < template.fn_body.len(); i++ {
                let b: Stmt = template.fn_body.get(i);
                let nb: *Stmt = subst_stmt(&b, template.type_params, e.args, g.generic_structs);
                if nb != null { new_body.push(*nb); }
            }
        }
        // Source mapping for the mono: inherits the template's origin
        // + signature line so crash traces point at the generic fn.
        let saved_origin: string = g.current_origin;
        if template.origin != null && !template.origin.eq("") {
            g.current_origin = template.origin;
        }
        g.emit_line_dir(template.line, g.current_origin);
        // Emit the specialized fn.
        print!(type_to_c(new_ret), " ", mangled, "(");
        if new_params_v.len() == 0 {
            print!("void");
        } else {
            for let j: i32 = 0; j < new_params_v.len(); j++ {
                if j > 0 { print!(", "); }
                let p: Param = new_params_v.get(j);
                print!(type_to_c(p.ty), " ", c_safe_ident(p.name));
            }
        }
        println!(") {");
        g.scope.clear();
        let saved_d: *Vector<Expr> = g.defer_stack;
        let saved_dr: *Vector<Expr> = g.auto_drop_stack;
        let nd_q: *Vector<Expr> = Vector::new();
        let nadr_q: *Vector<Expr> = Vector::new();
        g.defer_stack = nd_q;
        g.auto_drop_stack = nadr_q;
        for let j: i32 = 0; j < new_params_v.len(); j++ {
            let p: Param = new_params_v.get(j);
            g.declare(p.name, p.ty);
        }
        let saved_ret_mono: *Type = g.current_ret_ty;
        g.current_ret_ty = new_ret;
        for let j: i32 = 0; j < new_body.len(); j++ {
            let b: Stmt = new_body.get(j);
            emit_stmt(g, &b, 1);
        }
        g.emit_deferred_reverse(1);
        g.current_ret_ty = saved_ret_mono;
        g.defer_stack = saved_d;
        g.auto_drop_stack = saved_dr;
        g.current_origin = saved_origin;
        println!("}");
        println!("");
    }

    // Emit all collected anonymous fn lifts.
    for let i: i32 = 0; i < g.anon_fns.len(); i++ {
        let af: AnonFn = g.anon_fns.get(i);
        // Signature
        print!(type_to_c(af.ret_ty), " ", af.name, "(");
        if af.params == null || af.params.len() == 0 {
            print!("void");
        } else {
            for let j: i32 = 0; j < af.params.len(); j++ {
                if j > 0 { print!(", "); }
                let p: Param = af.params.get(j);
                print!(type_to_c(p.ty), " ", c_safe_ident(p.name));
            }
        }
        println!(") {");
        g.scope.clear();
        let saved_d: *Vector<Expr> = g.defer_stack;
        let saved_dr: *Vector<Expr> = g.auto_drop_stack;
        let nd: *Vector<Expr> = Vector::new();
        let nadr: *Vector<Expr> = Vector::new();
        g.defer_stack = nd;
        g.auto_drop_stack = nadr;
        if af.params != null {
            for let j: i32 = 0; j < af.params.len(); j++ {
                let p: Param = af.params.get(j);
                g.declare(p.name, p.ty);
            }
        }
        if af.body != null {
            for let j: i32 = 0; j < af.body.len(); j++ {
                let b: Stmt = af.body.get(j);
                emit_stmt(g, &b, 1);
            }
        }
        g.emit_deferred_reverse(1);
        g.defer_stack = saved_d;
        g.auto_drop_stack = saved_dr;
        println!("}");
        println!("");
    }

    g.free();
}

fn emit_top_const(g: *CG, s: *Stmt) {
    // `int` / `uint` / `i32` use `#define` so they can appear in `case`
    // labels and stay compatible with the existing tag-define machinery.
    // `i64` (and anything else) needs a typed `static const` so the
    // value carries its width through expressions - otherwise C macro
    // expansion treats `1000000000` as plain `int` and arithmetic like
    // `(SECS_PER_HOUR * NANOS_PER_SEC)` overflows int32 silently.
    if s.let_value == null { return; }
    let cname: string = c_safe_ident(s.name);
    if s.let_ty != null && s.let_ty.kind == TY_NAMED
       && (s.let_ty.name.eq("int") || s.let_ty.name.eq("uint")
           || s.let_ty.name.eq("i32")) {
        print!("#define ", cname, " ");
        emit_expr(g, s.let_value);
        println!("");
        return;
    }
    print!("static const ");
    if s.let_ty != null {
        print!(type_to_c(s.let_ty), " ", cname);
    } else {
        print!("int ", cname);
    }
    print!(" = ");
    if s.let_ty != null && s.let_ty.kind == TY_NAMED && s.let_ty.name.eq("i64") {
        // Cast the initializer so wider arithmetic stays 64-bit.
        print!("(int64_t)(");
        emit_expr(g, s.let_value);
        print!(")");
    } else {
        emit_expr(g, s.let_value);
    }
    println!(";");
}

fn emit_struct_mono(g: *CG, t: *Type) {
    if t == null || t.kind != TY_GENERIC { return; }
    if !g.generic_structs.contains(t.name) { return; }
    let template: Stmt = g.generic_structs.get(t.name);
    let mangled: string = mangle_generic(t.name, t.args);
    // Dedup: the same mono can appear many times in the collected uses; the
    // earlier typedef pass already inserted into emitted_monos, but here we
    // need our own marker for "body emitted".
    let body_key: string = mangled.concat("__body");
    if g.emitted_monos.contains(body_key) { return; }
    g.emitted_monos.insert(body_key, true);
    println!("struct ", mangled, " {");
    if template.struct_fields != null && template.type_params != null {
        for let i: i32 = 0; i < template.struct_fields.len(); i++ {
            let f: Field = template.struct_fields.get(i);
            let sub: *Type = subst_type(f.ty, template.type_params, t.args);
            print!("    ", type_to_c(sub), " ", f.name); println!(";");
        }
    }
    println!("};");
    println!("");
}

fn collect_generic_uses_in_type(t: *Type, out: *Vector<Type>) {
    if t == null { return; }
    if t.kind == TY_GENERIC {
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                collect_generic_uses_in_type(&a, out);
            }
        }
        out.push(*t);
    }
    if t.kind == TY_POINTER || t.kind == TY_BORROW
       || t.kind == TY_BORROW_MUT || t.kind == TY_SLICE {
        collect_generic_uses_in_type(t.inner, out);
    }
}

fn collect_generic_uses_in_stmt(s: *Stmt, out: *Vector<Type>) {
    if s == null { return; }
    // Skip generic fn signatures and bodies entirely — type vars (T, etc.) are
    // not concrete uses, and the substituted versions will be collected later.
    let is_generic: bool = s.type_params != null && s.type_params.len() > 0;
    if is_generic { return; }
    // Trait sigs are templates referencing Self / Self::Item; impls of the
    // trait walk normally and contribute their substituted uses there.
    if s.kind == ST_TRAIT { return; }
    // Skip impl method walks for generic impls (`impl<T> X for Foo<T>`) — the
    // method bodies reference T placeholders. Their substituted versions land
    // when each mono of Foo<Concrete> is processed. Concrete impls (no
    // type_params) walk normally below.

    if s.let_ty != null { collect_generic_uses_in_type(s.let_ty, out); }
    if s.fn_ret_ty != null { collect_generic_uses_in_type(s.fn_ret_ty, out); }
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            collect_generic_uses_in_type(p.ty, out);
        }
    }
    if s.struct_fields != null {
        for let i: i32 = 0; i < s.struct_fields.len(); i++ {
            let f: Field = s.struct_fields.get(i);
            collect_generic_uses_in_type(f.ty, out);
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            collect_generic_uses_in_stmt(&b, out);
        }
    }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            collect_generic_uses_in_stmt(&b, out);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            collect_generic_uses_in_stmt(&b, out);
        }
    }
    if s.impl_methods != null {
        for let i: i32 = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            collect_generic_uses_in_stmt(&m, out);
        }
    }
}
