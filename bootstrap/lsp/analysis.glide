// Custom analysis / lint passes for the LSP + `glide check`, extracted
// from lsp.glide for readability. run_extra_analyses (in lsp.glide)
// drives these; boundary helpers it shares live in lsp.glide (pub).
import stdlib::hashmap::*;
import bootstrap::syntax::ast;
import bootstrap::syntax::lexer;
import bootstrap::syntax::parser;
import bootstrap::sema::typer;
import bootstrap::cli::fmt;
import bootstrap::lsp::server;
import bootstrap::lsp::features; // extracted
import bootstrap::lsp::completion;

fn _is_int_type_name(n: string) -> bool {
    if n.eq("i8") || n.eq("i16") || n.eq("i32") || n.eq("i64") || n.eq("i128") || n.eq("i256") {
        return true;
    }
    if n.eq("u8") || n.eq("u16") || n.eq("u32") || n.eq("u64") || n.eq("u128") || n.eq("u256") {
        return true;
    }
    if n.eq("usize") || n.eq("isize") {
        return true;
    }
    return false;
}

// True when a literal of expr-kind `vk` clearly cannot fit field type `fty`.
// Fires for PRIMITIVE-typed fields (wrong literal kind) and for Option /
// Result-shaped fields (a bare literal must be wrapped in some()/ok()/etc).
// Generic / struct / pointer fields are never false-flagged.
fn _lit_field_mismatch(vk: i32, fty: *Type) -> bool {
    if fty == null {
        return false;
    }
    let is_lit: bool = vk == EX_INT || vk == EX_STRING || vk == EX_BOOL || vk == EX_FLOAT || vk == EX_CHAR;
    // `?T` / `!T` / `?!T` field: a raw literal silently mis-stores into the
    // wrapper, so it must go through a ctor. Any literal is a mismatch.
    if fty.kind == TY_OPTION || fty.kind == TY_RESULT || fty.kind == TY_OPT_RESULT {
        return is_lit;
    }
    if fty.kind != TY_NAMED {
        return false;
    }
    let tn: string = fty.name;
    let is_str: bool = tn.eq("string");
    let is_bool: bool = tn.eq("bool");
    let is_char: bool = tn.eq("char");
    let is_float: bool = tn.eq("f32") || tn.eq("f64");
    let is_int: bool = _is_int_type_name(tn);
    if !(is_str || is_bool || is_char || is_float || is_int) {
        return false;
    }
    if vk == EX_STRING {
        return !is_str;
    }
    if vk == EX_BOOL {
        return !is_bool;
    }
    if vk == EX_CHAR {
        return !is_char;
    }
    if vk == EX_FLOAT {
        return !is_float;
    }
    if vk == EX_INT {
        return !(is_int || is_float);
    }
    return false;
}

fn _lit_kind_name(vk: i32) -> string {
    if vk == EX_STRING {
        return "a string literal";
    }
    if vk == EX_BOOL {
        return "a bool literal";
    }
    if vk == EX_CHAR {
        return "a char literal";
    }
    if vk == EX_FLOAT {
        return "a float literal";
    }
    if vk == EX_INT {
        return "an integer literal";
    }
    return "a literal";
}

// Literal kind without a leading article, for "never a bare <kind>" phrasing.
fn _lit_kind_bare(vk: i32) -> string {
    if vk == EX_STRING {
        return "string literal";
    }
    if vk == EX_BOOL {
        return "bool literal";
    }
    if vk == EX_CHAR {
        return "char literal";
    }
    if vk == EX_FLOAT {
        return "float literal";
    }
    if vk == EX_INT {
        return "integer literal";
    }
    return "literal";
}

// Reconstruct a literal expression's source text, for quoting the exact
// value back to the user in a fix suggestion (e.g. `some(32)`).
fn _lit_text(e: *Expr) -> string {
    if e == null {
        return "value";
    }
    if e.kind == EX_INT {
        return int_to_str(e.int_val);
    }
    if e.kind == EX_STRING {
        return "\"".concat(e.str_val).concat("\"");
    }
    if e.kind == EX_BOOL {
        if e.bool_val {
            return "true";
        }
        return "false";
    }
    if e.kind == EX_FLOAT {
        if e.float_val != null && !e.float_val.eq("") {
            return e.float_val;
        }
        return "0.0";
    }
    return "value";
}

// Walk an expression; for every `Struct { field: value }` literal, flag
// unknown field names and literal values whose type can't match the field.
fn _struct_lit_check_expr(t: *Typer, stmts: *Vector<Stmt>, e: *Expr) {
    if e == null {
        return;
    }
    if e.kind == EX_STRUCT_LIT && e.str_val != null && e.field_names != null && e.args != null {
        // A qualified literal (`pkg::MyStruct { ... }`) arrives with the full
        // `pkg::MyStruct` name; strip the module prefix so the struct decl is
        // actually found and its fields get checked (else it was skipped silently).
        let sd: *Stmt = find_top_decl(stmts, t._strip_mod_prefix(e.str_val));
        if sd != null && sd.kind == ST_STRUCT && sd.struct_fields != null {
            let nf: i32 = e.field_names.len();
            for let i: i32 = 0; i < nf; i++ {
                if i >= e.args.len() {
                    break;
                }
                let fname: string = e.field_names.get(i);
                let val: Expr = e.args.get(i);
                let mut fty: *Type = null;
                let mut found: bool = false;
                for let j: i32 = 0; j < sd.struct_fields.len(); j++ {
                    let fd: Field = sd.struct_fields.get(j);
                    if fd.name != null && fd.name.eq(fname) {
                        fty = fd.ty;
                        found = true;
                        break;
                    }
                }
                if !found {
                    t.err_code_range(val.line, val.column, _lit_span(&val), "unknown-struct-field", "struct `".concat(e.str_val).concat("` has no field `").concat(fname).concat("`"));
                } else {
                    if _lit_field_mismatch(val.kind, fty) {
                        let fty_str: string = type_to_string(fty);
                        let vspan: i32 = _lit_span(&val);
                        let vend: i32 = val.column + vspan;
                        if fty.kind == TY_OPTION || fty.kind == TY_OPT_RESULT {
                            let lit: string = _lit_text(&val);
                            let repl: string = "some(".concat(lit).concat(")");
                            let msg: string = "field `".concat(fname).concat("` of `").concat(e.str_val).concat("` is optional (`").concat(fty_str).concat("`), so it holds either `some(value)` or `none()`, never a bare ").concat(_lit_kind_bare(val.kind)).concat(". Wrap the value: `").concat(fname).concat(": ").concat(repl).concat("` to store it, `").concat(fname).concat(": none()` for absent, or omit `").concat(fname).concat("` entirely (it defaults to none).");
                            t.err_code_range_fix(val.line, val.column, vspan, "struct-field-type", msg, val.line, val.column, val.line, vend, repl);
                        } else {
                            if fty.kind == TY_RESULT {
                                let lit: string = _lit_text(&val);
                                let repl: string = "ok(".concat(lit).concat(")");
                                let msg: string = "field `".concat(fname).concat("` of `").concat(e.str_val).concat("` is a result (`").concat(fty_str).concat("`), so it holds either `ok(value)` or `err(message)`, never a bare ").concat(_lit_kind_bare(val.kind)).concat(". Wrap the value: `").concat(fname).concat(": ").concat(repl).concat("` on success, or `").concat(fname).concat(": err(\"...\")` on error.");
                                t.err_code_range_fix(val.line, val.column, vspan, "struct-field-type", msg, val.line, val.column, val.line, vend, repl);
                            } else {
                                let msg: string = "field `".concat(fname).concat("` of `").concat(e.str_val).concat("` expects `").concat(fty_str).concat("`, but got ").concat(_lit_kind_name(val.kind)).concat(". Use a ").concat(fty_str).concat(" value here.");
                                t.err_code_range(val.line, val.column, vspan, "struct-field-type", msg);
                            }
                        }
                    }
                }
            }
            // Required fields: every field must be supplied EXCEPT `?T` /
            // `?!T` (Option-shaped), which default to `none()` when omitted.
            let present: *HashMap<bool> = HashMap::new();
            for let i: i32 = 0; i < nf; i++ {
                present.insert(e.field_names.get(i), true);
            }
            for let j: i32 = 0; j < sd.struct_fields.len(); j++ {
                let fd: Field = sd.struct_fields.get(j);
                if fd.name == null || fd.name.eq("") {
                    continue;
                }
                if present.contains(fd.name) {
                    continue;
                }
                if fd.ty != null && (fd.ty.kind == TY_OPTION || fd.ty.kind == TY_OPT_RESULT) {
                    continue;
                }
                // A private field can't be set from another file, so omitting
                // it there is correct — the struct's own file initializes it.
                // It is only "missing" (required) inside its own file.
                if !fd.is_pub && sd.origin != null && !sd.origin.eq(t.current_origin) {
                    continue;
                }
                t.err_code_range(e.line, e.column, e.str_val.len(), "missing-struct-field", "struct `".concat(e.str_val).concat("` literal is missing field `").concat(fd.name).concat("`"));
            }
            present.free();
        }
    }
    if e.lhs != null {
        _struct_lit_check_expr(t, stmts, e.lhs);
    }
    if e.rhs != null {
        _struct_lit_check_expr(t, stmts, e.rhs);
    }
    if e.operand != null {
        _struct_lit_check_expr(t, stmts, e.operand);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _struct_lit_check_expr(t, stmts, &a);
        }
    }
}

fn _struct_lit_check_body(t: *Typer, stmts: *Vector<Stmt>, body: *Vector<Stmt>) {
    if body == null {
        return;
    }
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.let_value != null {
            _struct_lit_check_expr(t, stmts, s.let_value);
        }
        if s.expr_value != null {
            _struct_lit_check_expr(t, stmts, s.expr_value);
        }
        if s.cond != null {
            _struct_lit_check_expr(t, stmts, s.cond);
        }
        if s.for_step != null {
            _struct_lit_check_expr(t, stmts, s.for_step);
        }
        if s.for_init != null && s.for_init.let_value != null {
            _struct_lit_check_expr(t, stmts, s.for_init.let_value);
        }
        if s.then_body != null {
            _struct_lit_check_body(t, stmts, s.then_body);
        }
        if s.else_body != null {
            _struct_lit_check_body(t, stmts, s.else_body);
        }
    }
}

// Validate struct-literal fields across every fn / impl method body. Catches
// the typo the typer misses (it tracks field NAMES but discards field TYPES),
// e.g. `Cfg { name: 42 }` where `name: string`.
pub fn analysis_struct_lit_fields(t: *Typer, stmts: *Vector<Stmt>) {
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            t.current_origin = s.origin;
            _struct_lit_check_body(t, stmts, s.fn_body);
        } else {
            if s.kind == ST_IMPL && s.impl_methods != null {
                for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                    let m: Stmt = s.impl_methods.get(j);
                    if m.kind == ST_FN && m.fn_body != null {
                        let mut org: string = m.origin;
                        if org == null || org.eq("") {
                            org = s.origin;
                        }
                        t.current_origin = org;
                        _struct_lit_check_body(t, stmts, m.fn_body);
                    }
                }
            }
        }
    }
}

pub fn analysis_trait_conformance(t: *Typer, stmts: *Vector<Stmt>) {
    // First pass: index trait definitions by name.
    let traits: *HashMap<Stmt> = HashMap::new();
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind == ST_TRAIT && s.name != null && !s.name.eq("") {
            traits.insert(s.name, s);
        }
    }
    // Build a `<trait>::<type>` set so we can check supertraits in O(1).
    let impl_set: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_IMPL {
            continue;
        }
        if s.impl_trait_name == null || s.impl_trait_name.eq("") {
            continue;
        }
        if s.impl_target == null || s.impl_target.kind != TY_NAMED {
            continue;
        }
        impl_set.insert(s.impl_trait_name.concat("::").concat(s.impl_target.name), true);
    }
    // Second pass: validate each `impl Trait for Type`.
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_IMPL {
            continue;
        }
        // Synthesized impls (proc-macro / @derive output, emitted at line 0)
        // are the compiler's job to validate. The LSP parses imported bodies
        // header-only, so a proc-derive's helper fns are empty here and the
        // generated impl comes out method-less — flagging it would be a false
        // positive. The real `glide build` expands and checks it for real.
        if s.line <= 0 {
            continue;
        }
        if s.impl_trait_name == null || s.impl_trait_name.eq("") {
            continue;
        }
        if !traits.contains(s.impl_trait_name) {
            t.current_origin = s.origin;
            t.err_code_range(s.line, s.column, 4, "unknown-trait", "trait `".concat(s.impl_trait_name).concat("` is not declared"));
            continue;
        }
        let trait_def: Stmt = traits.get(s.impl_trait_name);
        // Supertrait coverage: if `trait Bird: Animal`, then `impl Bird for T`
        // requires `impl Animal for T` to exist somewhere in the program.
        if trait_def.trait_supers != null && s.impl_target != null && s.impl_target.kind == TY_NAMED {
            for let k: i32 = 0; k < trait_def.trait_supers.len(); k++ {
                let sup: string = trait_def.trait_supers.get(k);
                let key: string = sup.concat("::").concat(s.impl_target.name);
                if !impl_set.contains(key) {
                    t.current_origin = s.origin;
                    t.err_code_range(s.line, s.column, 4, "missing-supertrait", "trait `".concat(s.impl_trait_name).concat("` requires `").concat(sup).concat("` but `").concat(s.impl_target.name).concat("` doesn't implement it"));
                    if traits.contains(sup) {
                        let sup_def: Stmt = traits.get(sup);
                        t.relate_last(sup_def.origin, sup_def.line, sup_def.column, sup_def.line, sup_def.column + 1, "supertrait `".concat(sup).concat("` declared here"));
                    }
                }
            }
        }
        if trait_def.impl_methods == null {
            continue;
        }
        // Build a name-indexed lookup of impl methods so we can match each
        // trait method to its implementation and compare signatures.
        let provided: *HashMap<Stmt> = HashMap::new();
        if s.impl_methods != null {
            for let k: i32 = 0; k < s.impl_methods.len(); k++ {
                let m: Stmt = s.impl_methods.get(k);
                if m.name != null {
                    provided.insert(m.name, m);
                }
            }
        }
        let mut target_name: string = "?";
        if s.impl_target != null && s.impl_target.kind == TY_NAMED {
            target_name = s.impl_target.name;
        }
        for let k: i32 = 0; k < trait_def.impl_methods.len(); k++ {
            let req: Stmt = trait_def.impl_methods.get(k);
            if req.name == null || req.name.eq("") {
                continue;
            }
            if !provided.contains(req.name) {
                t.current_origin = s.origin;
                t.err_code_range(s.line, s.column, 4, "missing-trait-method", "impl of trait `".concat(s.impl_trait_name).concat("` for `").concat(target_name).concat("` is missing method `").concat(req.name).concat("`"));
                t.relate_last(trait_def.origin, req.line, req.column, req.line, req.column + 1, "trait method `".concat(req.name).concat("` declared here"));
                continue;
            }
            // Signature matching: compare arity, each param's declared type,
            // and the return type. `Self` in the trait sig is the implementor
            // here; trait_def methods still have literal Self, so substitute
            // before comparing.
            let got: Stmt = provided.get(req.name);
            check_method_signature(t, s, req, got, target_name, trait_def.origin);
        }
    }
}

fn check_method_signature(t: *Typer, impl_stmt: Stmt, req: Stmt, got: Stmt, target_name: string, trait_origin: string) {
    let req_arity: i32 = if_param_count(req);
    let got_arity: i32 = if_param_count(got);
    if req_arity != got_arity {
        t.current_origin = impl_stmt.origin;
        t.err_code_range(got.name_line, got.name_col, got.name_len, "trait-method-mismatch", "method `".concat(req.name).concat("` has wrong arity for trait `").concat(impl_stmt.impl_trait_name).concat("`: expected ").concat(int_to_str(req_arity)).concat(" params, got ").concat(int_to_str(got_arity)));
        t.relate_last(trait_origin, req.line, req.column, req.line, req.column + 1, "trait requires `".concat(req.name).concat("` with ").concat(int_to_str(req_arity)).concat(" params"));
        return;
    }
    if req.fn_params != null && got.fn_params != null {
        for let i: i32 = 0; i < req_arity; i++ {
            let rp: Param = req.fn_params.get(i);
            let gp: Param = got.fn_params.get(i);
            let rty: *Type = subst_self(rp.ty, impl_stmt.impl_target);
            rty = subst_assoc(rty, impl_stmt.assoc_decls);
            if !types_compat(rty, gp.ty) {
                t.current_origin = impl_stmt.origin;
                t.err_code_range(got.name_line, got.name_col, got.name_len, "trait-method-mismatch", "method `".concat(req.name).concat("` param `").concat(rp.name).concat("`: expected `").concat(type_to_string(rty)).concat("`, got `").concat(type_to_string(gp.ty)).concat("`"));
                t.relate_last(trait_origin, req.line, req.column, req.line, req.column + 1, "trait signature for `".concat(req.name).concat("` declared here"));
                return;
            }
        }
    }
    let mut rret: *Type = subst_self(req.fn_ret_ty, impl_stmt.impl_target);
    rret = subst_assoc(rret, impl_stmt.assoc_decls);
    if !types_compat(rret, got.fn_ret_ty) {
        t.current_origin = impl_stmt.origin;
        t.err_code_range(got.name_line, got.name_col, got.name_len, "trait-method-mismatch", "method `".concat(req.name).concat("` return: expected `").concat(type_to_string(rret)).concat("`, got `").concat(type_to_string(got.fn_ret_ty)).concat("`"));
        t.relate_last(trait_origin, req.line, req.column, req.line, req.column + 1, "trait signature for `".concat(req.name).concat("` declared here"));
    }
}

// After Self substitution, an `Self::Item` becomes `<ImplTarget>::Item`. Resolve
// that against the impl's own `type Item = X;` declarations. Returns a fresh
// node — must NOT mutate the input (shared across impls).
fn subst_assoc(t: *Type, assocs: *Vector<Param>) -> *Type {
    if t == null {
        return null;
    }
    if assocs == null {
        return t;
    }
    if t.kind == TY_ASSOC {
        for let i: i32 = 0; i < assocs.len(); i++ {
            let a: Param = assocs.get(i);
            if a.name.eq(t.name) {
                return a.ty;
            }
        }
    }
    if t.inner == null && t.fnptr_ret == null {
        return t;
    }
    let copy: *Type = malloc(sizeof(Type)) as *Type;
    *copy = *t;
    if copy.inner != null {
        copy.inner = subst_assoc(copy.inner, assocs);
    }
    if copy.fnptr_ret != null {
        copy.fnptr_ret = subst_assoc(copy.fnptr_ret, assocs);
    }
    return copy;
}

fn if_param_count(s: Stmt) -> i32 {
    if s.fn_params == null {
        return 0;
    }
    return s.fn_params.len();
}

// Walk a Type and replace `Self` with `impl_target`, leaving everything
// else untouched. Returns a fresh node — must NOT mutate the input, since
// the trait sig is shared across every impl that names the trait.
fn subst_self(t: *Type, impl_target: *Type) -> *Type {
    if t == null {
        return null;
    }
    if impl_target == null {
        return t;
    }
    if t.kind == TY_NAMED && t.name.eq("Self") {
        return impl_target;
    }
    if t.inner == null && t.fnptr_ret == null {
        return t;
    }
    let copy: *Type = malloc(sizeof(Type)) as *Type;
    *copy = *t;
    if copy.inner != null {
        copy.inner = subst_self(copy.inner, impl_target);
    }
    if copy.fnptr_ret != null {
        copy.fnptr_ret = subst_self(copy.fnptr_ret, impl_target);
    }
    return copy;
    return t;
}

// Walk a fn body collecting let names, then walk again to find references.
// Anything declared but never referenced (and not prefixed with `_`) gets a
// warning. Skips fn params for v1.
pub fn analysis_unused_vars(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_FN || s.fn_body == null {
            continue;
        }
        t.current_origin = s.origin;
        check_unused_in_body(t, s.fn_body);
    }
}

fn check_unused_in_body(t: *Typer, body: *Vector<Stmt>) {
    let n: i32 = body.len();
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET {
            let name: string = s.name;
            // Tuple destructuring (`let (a, b) = ...`) has no single binder
            // name; element positions aren't tracked, so skip the lint.
            if s.let_names != null && s.let_names.len() > 0 {
                continue;
            }
            // Skip names beginning with `_` (intentional discard convention).
            if name.len() == 0 {
                continue;
            }
            if name.len() > 0 && name.at(0).to_int() == 95 {
                continue;
            }
            let mut used: bool = false;
            for let j: i32 = i + 1; j < n; j++ {
                let s2: Stmt = body.get(j);
                if stmt_uses_name(&s2, name) {
                    used = true;
                    break;
                }
            }
            if !used {
                t.warn_unused_range(s.name_line, s.name_col, s.name_len, "unused-var", "unused local `".concat(name).concat("` (prefix with `_` to silence)"));
            }
        }
        // Recurse into nested bodies.
        if s.then_body != null {
            check_unused_in_body(t, s.then_body);
        }
        if s.else_body != null {
            check_unused_in_body(t, s.else_body);
        }
        if s.kind == ST_SELECT && s.select_arms != null {
            for let k: i32 = 0; k < s.select_arms.len(); k++ {
                let arm: SelectArm = s.select_arms.get(k);
                if arm.body != null {
                    check_unused_in_body(t, arm.body);
                }
            }
        }
    }
}

// `let arena: *Arena = Arena::new(...)` without a paired `defer arena.free()`
// or `arena.free()` somewhere later in the scope is a leak. Same shape
// applies to raw `malloc(n)` (paired free) and `__glide_palloc_make()`
// (paired __glide_palloc_free). `let x* = Arena::new(...)` is fine —
// auto-drop handles it. `@allow("unfreed-alloc")` on the enclosing fn
// silences the warning for intentional escape-hatch patterns
// (e.g. ownership handed off to a caller through a raw pointer).
pub fn analysis_arena_not_freed(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_FN || s.fn_body == null {
            continue;
        }
        if _has_allow(&s, "unfreed-alloc") || _has_allow(&s, "arena-not-freed") {
            continue;
        }
        t.current_origin = s.origin;
        check_arena_in_body(t, s.fn_body, s.fn_body, false);
    }
}

fn check_arena_in_body(t: *Typer, body: *Vector<Stmt>, root: *Vector<Stmt>, suppress: bool) {
    let n: i32 = body.len();
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && !s.is_auto_owned {
            // Stmt-local opt-out: `@allow("unfreed-alloc")` on the `let`
            // itself silences the warning without polluting the
            // enclosing fn. Either alias is recognised. The `suppress`
            // flag propagates a parent block's `@allow`.
            if suppress {
                continue;
            }
            if _has_allow(&s, "unfreed-alloc") || _has_allow(&s, "arena-not-freed") {
                continue;
            }
            let kind: i32 = _alloc_kind(s.let_value);
            if kind != 0 {
                // Scan the entire fn body (not just the current block) so a
                // `defer foo.free()` registered in a nested if/while still counts.
                if alloc_is_freed_in_body(s.name, kind, root) {
                    continue;
                }
                // Heuristic ownership-escape suppression. If the
                // resource is stored in a struct field, pushed into a
                // container, or handed to any non-free fn, we assume
                // the receiver takes over the lifetime. The warning
                // only fires for true "let, never reference again,
                // never free" cases.
                if alloc_escapes_in_body(s.name, kind, root) {
                    continue;
                }
                t.warn_range(s.name_line, s.name_col, s.name.len(), _alloc_code(kind), _alloc_msg(kind, s.name));
            }
        }
        // Block-level `@allow("...")` on if/while/for/block/etc. — add
        // it to the active suppression set for the recursive walk.
        let sub_suppress: bool = suppress || _has_allow(&s, "unfreed-alloc") || _has_allow(&s, "arena-not-freed");
        if s.then_body != null {
            check_arena_in_body(t, s.then_body, root, sub_suppress);
        }
        if s.else_body != null {
            check_arena_in_body(t, s.else_body, root, sub_suppress);
        }
    }
}

fn _alloc_code(kind: i32) -> string {
    if kind == 1 {
        return "arena-not-freed";
    }
    return "unfreed-alloc";
}

fn _alloc_msg(kind: i32, name: string) -> string {
    if kind == 1 {
        return "arena `".concat(name).concat("` is never freed (use `let ").concat(name).concat("* = Arena::new(...)` or add `defer ").concat(name).concat(".free()`)");
    }
    if kind == 2 {
        return "allocation `".concat(name).concat("` is never freed (add `defer free(").concat(name).concat(")` after the malloc, or `@allow(\"unfreed-alloc\")` if the handle escapes the fn)");
    }
    return "palloc arena `".concat(name).concat("` is never freed (add `__glide_palloc_free(").concat(name).concat(")` or `@allow(\"unfreed-alloc\")` if the handle escapes the fn)");
}

fn alloc_is_freed_in_body(name: string, kind: i32, body: *Vector<Stmt>) -> bool {
    let n: i32 = body.len();
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if stmt_frees_resource(&s, name, kind) {
            return true;
        }
    }
    return false;
}

fn stmt_frees_resource(s: *Stmt, name: string, kind: i32) -> bool {
    if s == null {
        return false;
    }
    if kind == 1 {
        if stmt_calls_method(s, name, "free") {
            return true;
        }
    }
    if kind == 2 {
        if stmt_calls_fn_with(s, "free", name) {
            return true;
        }
    }
    if kind == 3 {
        if stmt_calls_fn_with(s, "__glide_palloc_free", name) {
            return true;
        }
    }
    // Returning the resource counts as ownership transfer.
    if s.expr_value != null && expr_returns_ident(s.expr_value, name) {
        return true;
    }
    return false;
}

fn stmt_calls_fn_with(s: *Stmt, fn_name: string, arg_name: string) -> bool {
    if s == null {
        return false;
    }
    if s.expr_value != null && expr_calls_fn_with(s.expr_value, fn_name, arg_name) {
        return true;
    }
    if s.let_value != null && expr_calls_fn_with(s.let_value, fn_name, arg_name) {
        return true;
    }
    if s.cond != null && expr_calls_fn_with(s.cond, fn_name, arg_name) {
        return true;
    }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            if stmt_calls_fn_with(&b, fn_name, arg_name) {
                return true;
            }
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            if stmt_calls_fn_with(&b, fn_name, arg_name) {
                return true;
            }
        }
    }
    return false;
}

fn expr_returns_ident(e: *Expr, name: string) -> bool {
    if e == null {
        return false;
    }
    if e.kind == EX_IDENT && e.str_val.eq(name) {
        return true;
    }
    return false;
}

fn stmt_calls_method(s: *Stmt, var: string, method: string) -> bool {
    if s == null {
        return false;
    }
    if s.expr_value != null && expr_calls_method(s.expr_value, var, method) {
        return true;
    }
    if s.let_value != null && expr_calls_method(s.let_value, var, method) {
        return true;
    }
    if s.cond != null && expr_calls_method(s.cond, var, method) {
        return true;
    }
    if s.for_step != null && expr_calls_method(s.for_step, var, method) {
        return true;
    }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            if stmt_calls_method(&b, var, method) {
                return true;
            }
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            if stmt_calls_method(&b, var, method) {
                return true;
            }
        }
    }
    return false;
}

// Returning the address of a temporary value is a dangling-pointer bug:
//   fn make() -> *Vec2 { return &Vec2 { x: 1, y: 2 }; }
// The temporary lives in `make`'s frame; its address is invalid the moment
// `make` returns. Code is `addr-of-temporary`.
pub fn analysis_addr_of_temporary(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            t.current_origin = s.origin;
            check_addr_temp_body(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            t.current_origin = s.origin;
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null {
                    check_addr_temp_body(t, m.fn_body);
                }
            }
        }
    }
}

fn check_addr_temp_body(t: *Typer, body: *Vector<Stmt>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_RETURN && s.expr_value != null {
            let e: *Expr = s.expr_value;
            if e.kind == EX_UNARY && (e.op_code == UN_ADDR || e.op_code == UN_ADDR_MUT) && e.operand != null && (e.operand.kind == EX_STRUCT_LIT || e.operand.kind == EX_NEW) {
                t.err_code_range(e.line, e.column, _expr_span(e), "addr-of-temporary", "cannot return address of a temporary value (would dangle); use `new T { ... }` to heap-allocate or return by value");
            }
        }
        if s.then_body != null {
            check_addr_temp_body(t, s.then_body);
        }
        if s.else_body != null {
            check_addr_temp_body(t, s.else_body);
        }
    }
}

// Statements after a terminator (return / break / continue) are unreachable.
// Only the first one is flagged.
pub fn analysis_dead_code(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            t.current_origin = s.origin;
            check_dead_code_body(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            t.current_origin = s.origin;
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null {
                    check_dead_code_body(t, m.fn_body);
                }
            }
        }
    }
}

fn check_dead_code_body(t: *Typer, body: *Vector<Stmt>) {
    let n: i32 = body.len();
    let mut terminated: bool = false;
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if terminated {
            t.warn_unused(s.line, s.column, "dead-code", "unreachable code after return / break / continue");
            return; // flag only the first dead stmt per block
        }
        if s.kind == ST_RETURN || s.kind == ST_BREAK || s.kind == ST_CONTINUE {
            terminated = true;
        }
        // Recurse into nested bodies regardless.
        if s.then_body != null {
            check_dead_code_body(t, s.then_body);
        }
        if s.else_body != null {
            check_dead_code_body(t, s.else_body);
        }
    }
}

// Top-level fn that's not pub, not `main`, never called from anywhere.
// Builds a call set from every reachable expression.
pub fn analysis_unused_fn(t: *Typer, program: *Vector<Stmt>) {
    let called: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            collect_calls_body(s.fn_body, called);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null {
                    collect_calls_body(m.fn_body, called);
                }
            }
        }
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_FN {
            continue;
        }
        if s.fn_body == null {
            continue;
        } // extern
        if s.is_pub {
            continue;
        } // public API
        if s.name.eq("main") {
            continue;
        }
        if s.type_params != null && s.type_params.len() > 0 {
            continue;
        } // generic, may be referenced indirectly
        if called.contains(s.name) {
            continue;
        }
        t.current_origin = s.origin;
        t.warn_unused_range(s.name_line, s.name_col, s.name_len, "unused-fn", "function `".concat(s.name).concat("` is never called"));
    }
    called.free();
}

fn collect_calls_body(body: *Vector<Stmt>, out: *HashMap<bool>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        collect_calls_stmt(&s, out);
    }
}

fn collect_calls_stmt(s: *Stmt, out: *HashMap<bool>) {
    if s == null {
        return;
    }
    if s.let_value != null {
        collect_calls_expr(s.let_value, out);
    }
    if s.expr_value != null {
        collect_calls_expr(s.expr_value, out);
    }
    if s.cond != null {
        collect_calls_expr(s.cond, out);
    }
    if s.for_step != null {
        collect_calls_expr(s.for_step, out);
    }
    if s.for_init != null {
        collect_calls_stmt(s.for_init, out);
    }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            collect_calls_stmt(&b, out);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            collect_calls_stmt(&b, out);
        }
    }
}

fn collect_calls_expr(e: *Expr, out: *HashMap<bool>) {
    if e == null {
        return;
    }
    if e.kind == EX_CALL && e.lhs != null {
        if e.lhs.kind == EX_IDENT {
            out.insert(e.lhs.str_val, true);
        }
        if e.lhs.kind == EX_PATH {
            out.insert(e.lhs.str_val.concat("_").concat(e.lhs.field), true);
            out.insert(e.lhs.field, true);
        }
        if e.lhs.kind == EX_MEMBER {
            out.insert(e.lhs.field, true);
        }
    }
    // Any free-standing identifier reference counts as a use too — covers
    // function pointers passed as args (`http_listen(8090, my_handler)`)
    // or stored in structs / vectors. False positives (a non-fn variable
    // happening to share a name) only suppress the warning, which is the
    // safer failure mode.
    if e.kind == EX_IDENT {
        out.insert(e.str_val, true);
    }
    if e.lhs != null {
        collect_calls_expr(e.lhs, out);
    }
    if e.rhs != null {
        collect_calls_expr(e.rhs, out);
    }
    if e.operand != null {
        collect_calls_expr(e.operand, out);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            collect_calls_expr(&a, out);
        }
    }
}

// `let mut x` where x is never reassigned. The `mut` is noise.
pub fn analysis_unnecessary_mut(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            t.current_origin = s.origin;
            check_mut_body(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            t.current_origin = s.origin;
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null {
                    check_mut_body(t, m.fn_body);
                }
            }
        }
    }
}

fn check_mut_body(t: *Typer, body: *Vector<Stmt>) {
    let n: i32 = body.len();
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.is_mut {
            let mut reassigned: bool = false;
            for let j: i32 = i + 1; j < n; j++ {
                let s2: Stmt = body.get(j);
                if stmt_reassigns(&s2, s.name) {
                    reassigned = true;
                    break;
                }
            }
            if !reassigned {
                // Quick fix: delete the `mut ` keyword (the 4 chars immediately
                // before the binding name in `let mut name`).
                t.warn_with_fix(s.name_line, s.name_col, s.name.len(), "unnecessary-mut", "`mut` on `".concat(s.name).concat("` is unnecessary; binding is never reassigned"), s.name_line, s.name_col - 4, s.name_line, s.name_col, "");
            }
        }
        if s.then_body != null {
            check_mut_body(t, s.then_body);
        }
        if s.else_body != null {
            check_mut_body(t, s.else_body);
        }
        if s.kind == ST_SELECT && s.select_arms != null {
            for let k: i32 = 0; k < s.select_arms.len(); k++ {
                let arm: SelectArm = s.select_arms.get(k);
                if arm.body != null {
                    check_mut_body(t, arm.body);
                }
            }
        }
    }
}

fn stmt_reassigns(s: *Stmt, name: string) -> bool {
    if s == null {
        return false;
    }
    if s.expr_value != null && expr_reassigns(s.expr_value, name) {
        return true;
    }
    if s.let_value != null && expr_reassigns(s.let_value, name) {
        return true;
    }
    if s.cond != null && expr_reassigns(s.cond, name) {
        return true;
    }
    if s.for_step != null && expr_reassigns(s.for_step, name) {
        return true;
    }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            if stmt_reassigns(&b, name) {
                return true;
            }
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            if stmt_reassigns(&b, name) {
                return true;
            }
        }
    }
    if s.kind == ST_SELECT && s.select_arms != null {
        for let i: i32 = 0; i < s.select_arms.len(); i++ {
            let arm: SelectArm = s.select_arms.get(i);
            if arm.send_value != null && expr_reassigns(arm.send_value, name) {
                return true;
            }
            if arm.body != null {
                for let j: i32 = 0; j < arm.body.len(); j++ {
                    let b: Stmt = arm.body.get(j);
                    if stmt_reassigns(&b, name) {
                        return true;
                    }
                }
            }
        }
    }
    return false;
}

fn expr_reassigns(e: *Expr, name: string) -> bool {
    if e == null {
        return false;
    }
    if e.kind == EX_ASSIGN && e.lhs != null && e.lhs.kind == EX_IDENT && e.lhs.str_val.eq(name) {
        return true;
    }
    if (e.kind == EX_POSTINC || e.kind == EX_POSTDEC) && e.lhs != null && e.lhs.kind == EX_IDENT && e.lhs.str_val.eq(name) {
        return true;
    }
    // `&name` / `&mut name`: address-of yields a mutable `*T` that a callee
    // can write through, so the `mut` is justified — not a redundant one.
    if e.kind == EX_UNARY && (e.op_code == UN_ADDR || e.op_code == UN_ADDR_MUT) && e.operand != null && e.operand.kind == EX_IDENT && e.operand.str_val.eq(name) {
        return true;
    }
    if e.lhs != null && expr_reassigns(e.lhs, name) {
        return true;
    }
    if e.rhs != null && expr_reassigns(e.rhs, name) {
        return true;
    }
    if e.operand != null && expr_reassigns(e.operand, name) {
        return true;
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if expr_reassigns(&a, name) {
                return true;
            }
        }
    }
    return false;
}

// Function declared `-> T` (non-void) where some path doesn't return.
// Conservative: walks the body, checks the LAST stmt of each branch.
fn _missing_return_check(t: *Typer, s: *Stmt, origin: string) {
    if s.fn_body == null {
        return;
    }
    if s.fn_ret_ty == null {
        return;
    } // void -> ok
    if s.is_naked {
        return;
    } // raw asm; `ret` lives in the asm
    // `-> !` (Result-without-value) returns Ok implicitly when the body
    // falls off the end. Codegen injects `return __glide_ok_void();` at
    // the function tail, so missing explicit return is not an error.
    if s.fn_ret_ty.kind == TY_RESULT && s.fn_ret_ty.inner != null && s.fn_ret_ty.inner.kind == TY_NAMED && s.fn_ret_ty.inner.name.eq("void") {
        return;
    }
    // Bool ret is okay-ish but still must return; same logic.
    if !body_always_returns(s.fn_body) {
        t.current_origin = origin;
        t.err_code_range(s.name_line, s.name_col, s.name.len(), "missing-return", "function `".concat(s.name).concat("` declared `-> ").concat(type_to_string(s.fn_ret_ty)).concat("` must return a value on every path, but can reach the end without returning"));
    }
}

pub fn analysis_missing_return(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        // Methods inside the user's own impl blocks are checked exactly like
        // top-level fns. Scoped to the focused file so an imported impl's
        // backlog doesn't surface, and so full builds (no user_origin) skip it.
        if s.kind == ST_IMPL && s.impl_methods != null {
            let own: bool = t.user_origin != null && !t.user_origin.eq("") && (s.origin == null || s.origin.eq(t.user_origin));
            if own {
                for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                    let m: Stmt = s.impl_methods.get(j);
                    if m.kind == ST_FN {
                        _missing_return_check(t, &m, s.origin);
                    }
                }
            }
            continue;
        }
        if s.kind != ST_FN {
            continue;
        }
        _missing_return_check(t, &s, s.origin);
    }
}

// Unused fn parameter (skip names starting with `_`). Reports at the fn
// declaration line since Param has no position info.
pub fn analysis_unused_params(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN {
            check_unused_params_fn(t, &s);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                check_unused_params_fn(t, &m);
            }
        }
    }
}

fn check_unused_params_fn(t: *Typer, fnstmt: *Stmt) {
    if fnstmt == null {
        return;
    }
    if fnstmt.fn_body == null {
        return;
    }
    // An empty body means either a genuine stub or, for the LSP, an imported
    // file parsed header-only (bodies brace-skipped). Either way every param
    // would look unused and the diagnostics don't belong on the active file
    // (imported impl methods carry no origin, so the publish filter can't drop
    // them). Skip.
    if fnstmt.fn_body.len() == 0 {
        return;
    }
    if fnstmt.fn_params == null {
        return;
    }
    if fnstmt.is_naked {
        return;
    } // params accessed via raw calling-conv regs
    // Synthesised fns (proc-macro outputs with line == 0) — the user
    // can't fix the `_` here, and the warning would anchor at line 1
    // of their file. Skip.
    if fnstmt.line <= 0 {
        return;
    }
    for let i: i32 = 0; i < fnstmt.fn_params.len(); i++ {
        let p: Param = fnstmt.fn_params.get(i);
        if p.name.eq("self") {
            continue;
        }
        if p.name.len() > 0 && p.name.at(0).to_int() == 95 {
            continue;
        }
        let mut used: bool = false;
        for let j: i32 = 0; j < fnstmt.fn_body.len(); j++ {
            let b: Stmt = fnstmt.fn_body.get(j);
            if stmt_uses_name(&b, p.name) {
                used = true;
                break;
            }
        }
        if !used {
            t.current_origin = fnstmt.origin;
            // Aim at the param identifier itself so the editor squiggle
            // and `glide fix` land on the right token. Falls back to
            // the fn name if the parser didn't fill in a position
            // (e.g. synthesized params).
            let mut pl: i32 = p.name_line;
            let mut pc: i32 = p.name_col;
            if pl == 0 {
                pl = fnstmt.name_line;
                pc = fnstmt.name_col;
            }
            t.warn_unused_range(pl, pc, p.name.len(), "unused-param", "parameter `".concat(p.name).concat("` of `").concat(fnstmt.name).concat("` is never used (prefix with `_` to silence)"));
        }
    }
}

// Estimate a type's size in bytes. Approximate (no alignment / padding) but
// good enough to spot "I'm returning a 2KB struct by value" anti-patterns.
fn type_size_bytes(t: *Type, structs: *HashMap<Stmt>) -> i32 {
    if t == null {
        return 0;
    }
    if t.kind == TY_POINTER || t.kind == TY_BORROW || t.kind == TY_BORROW_MUT {
        return 8;
    }
    if t.kind == TY_FNPTR {
        return 8;
    }
    if t.kind == TY_SLICE {
        return 16;
    } // {data, len}
    if t.kind == TY_RESULT {
        return type_size_bytes(t.inner, structs) + 16; // ok flag + val + err msg
    }
    if t.kind == TY_GENERIC {
        return 16;
    } // best-effort guess for unmonomorphized
    if t.kind == TY_NAMED {
        let n: string = t.name;
        if n.eq("char") || n.eq("bool") || n.eq("i8") || n.eq("u8") {
            return 1;
        }
        if n.eq("i16") || n.eq("u16") {
            return 2;
        }
        if n.eq("int") || n.eq("uint") || n.eq("i32") || n.eq("u32") || n.eq("f32") {
            return 4;
        }
        if n.eq("long") || n.eq("ulong") || n.eq("i64") || n.eq("u64") || n.eq("usize") || n.eq("isize") || n.eq("float") || n.eq("f64") {
            return 8;
        }
        if n.eq("i128") || n.eq("u128") {
            return 16;
        }
        if n.eq("i256") || n.eq("u256") {
            return 32;
        }
        if n.eq("string") {
            return 8;
        } // const char*
        if n.eq("void") {
            return 0;
        }
        if structs.contains(n) {
            let sd: Stmt = structs.get(n);
            let mut sz: i32 = 0;
            if sd.struct_fields != null {
                for let i: i32 = 0; i < sd.struct_fields.len(); i++ {
                    let f: Field = sd.struct_fields.get(i);
                    sz = sz + type_size_bytes(f.ty, structs);
                }
            }
            return sz;
        }
    }
    return 0;
}

// Hint: a function returns a large struct by value. The caller pays a copy on
// every call (or the ABI inserts a hidden out-pointer transparently). For hot
// paths, suggest taking an explicit `out: *T` parameter, or returning `*T` if
// ownership transfer makes sense.
pub fn analysis_large_return(t: *Typer, program: *Vector<Stmt>) {
    let structs: *HashMap<Stmt> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_STRUCT {
            structs.insert(s.name, s);
        }
    }
    let threshold: i32 = 64;
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_FN {
            continue;
        }
        if s.fn_body == null {
            continue;
        } // skip extern declarations
        let ret: *Type = s.fn_ret_ty;
        if ret == null {
            continue;
        }
        // Already a pointer / borrow — nothing to recommend.
        if ret.kind == TY_POINTER || ret.kind == TY_BORROW || ret.kind == TY_BORROW_MUT || ret.kind == TY_FNPTR {
            continue;
        }
        let sz: i32 = type_size_bytes(ret, structs);
        if sz >= threshold {
            t.current_origin = s.origin;
            t.push_diag(s.line, s.column, 3, "large-return", "fn `".concat(s.name).concat("` returns ").concat(int_to_str(sz)).concat(" bytes by value (").concat(type_to_string(ret)).concat("); for hot paths consider an out-param `out: *").concat(type_to_string(ret)).concat("` or returning `*").concat(type_to_string(ret)).concat("`"));
        }
    }
    structs.free();
}

// Emit a warning at every call site of a function (or path method)
// marked with the given attribute. Used by `@deprecated` /
// `@unstable` / any future attribute-driven lint. The reason string
// is interpolated into the message so the editor surfaces guidance
// inline. Suppression via `@allow("<lint-code>")` on the calling
// function or local stmt.
//
// `attr_name`: e.g. "deprecated" / "unstable"
// `lint_code`: warning code to emit, e.g. "deprecated-fn"
// `what`:      English noun used in the message ("deprecated"/"unstable")
pub fn analysis_deprecated_calls(t: *Typer, program: *Vector<Stmt>) {
    _run_attr_call_lint(t, program, "deprecated", "deprecated-fn", "deprecated");
}

pub fn analysis_unstable_calls(t: *Typer, program: *Vector<Stmt>) {
    _run_attr_call_lint(t, program, "unstable", "unstable-fn", "unstable");
}

// User-defined call-site lints declared via `@lint("<category>", "<reason>")`.
// First arg is the warning code (prefixed with `lint:` so it can't
// collide with the built-in codes); second arg is the message. The
// pass is otherwise identical to deprecated/unstable so suppression
// (`@allow("lint:<category>")`), block-level scoping, EX_PATH /
// EX_MEMBER resolution, and the impl-method qualified-key behaviour
// all come along for free.
//
// Example:
//   @lint("blocking_io", "blocks the coro scheduler — call from spawn_thread")
//   pub fn read_sync(path: string) -> string { … }
//
// Call sites then surface `lint:blocking_io: blocks the coro
// scheduler — call from spawn_thread` as a warning the user can
// silence with `@allow("lint:blocking_io")`.
pub fn analysis_custom_lints(t: *Typer, program: *Vector<Stmt>) {
    // First pass: collect every category that appears. Then run one
    // resolution pass per category. Two-pass keeps each per-category
    // HashMap local — Glide's generic monomorphization can't easily
    // express HashMap<*HashMap<string>>, so we re-walk the program
    // per category instead of nesting maps.
    let cats: *Vector<string> = _collect_lint_categories(program);
    for let i: i32 = 0; i < cats.len(); i++ {
        let cat: string = cats.get(i);
        let dep: *HashMap<string> = HashMap::new();
        _build_lint_index_for_cat(program, cat, dep);
        let code: string = "lint:".concat(cat);
        let what: string = "flagged by `".concat(code).concat("`");
        _run_call_lint_with_index(t, program, dep, code, what);
        dep.free();
    }
}

// Walk the program once and collect every category string that
// appears as the first arg of any `@lint(...)`. Deduplicated.
fn _collect_lint_categories(program: *Vector<Stmt>) -> *Vector<string> {
    let seen: *HashMap<bool> = HashMap::new();
    let out: *Vector<string> = Vector::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN {
            _gather_lint_cats(&s, seen, out);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                _gather_lint_cats(&m, seen, out);
            }
        }
    }
    seen.free();
    return out;
}

fn _gather_lint_cats(s: *Stmt, seen: *HashMap<bool>, out: *Vector<string>) {
    if s == null || s.attrs == null {
        return;
    }
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !a.name.eq("lint") {
            continue;
        }
        if a.args == null || a.args.len() == 0 {
            continue;
        }
        let cat_expr: Expr = a.args.get(0);
        if cat_expr.kind != EX_STRING {
            continue;
        }
        if seen.contains(cat_expr.str_val) {
            continue;
        }
        seen.insert(cat_expr.str_val, true);
        out.push(cat_expr.str_val);
    }
}

// For a single category, build the fn-name → reason index. Mirrors
// the structure of `_collect_attr_fns` so the existing call-site
// scanner can drive it.
fn _build_lint_index_for_cat(program: *Vector<Stmt>, cat: string, dep: *HashMap<string>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN {
            let r: ?string = _lint_reason_for_cat(&s, cat);
            if r.has {
                dep.insert(s.name, r.val);
            }
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            let mut owner: string = "";
            if s.impl_target != null && s.impl_target.name != null {
                owner = s.impl_target.name;
            }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                let r: ?string = _lint_reason_for_cat(&m, cat);
                if !r.has {
                    continue;
                }
                let rv: string = r.val;
                if !owner.eq("") {
                    dep.insert(owner.concat("::").concat(m.name), rv);
                }
                if !dep.contains(m.name) {
                    dep.insert(m.name, rv);
                }
            }
        }
    }
}

fn _lint_reason_for_cat(s: *Stmt, cat: string) -> ?string {
    if s == null || s.attrs == null {
        return none();
    }
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !a.name.eq("lint") {
            continue;
        }
        if a.args == null || a.args.len() == 0 {
            continue;
        }
        let cat_expr: Expr = a.args.get(0);
        if cat_expr.kind != EX_STRING {
            continue;
        }
        if !cat_expr.str_val.eq(cat) {
            continue;
        }
        if a.args.len() > 1 {
            let r_expr: Expr = a.args.get(1);
            if r_expr.kind == EX_STRING {
                return some(r_expr.str_val);
            }
        }
        return some("");
    }
    return none();
}

// Walk the diagnostic stream against every `@expect("<code>")`
// attribute in the program. Each `@expect` is either fulfilled (we
// remove the matching warning so it doesn't pollute the output) or
// unfulfilled (we emit a `unfulfilled-expectation` error pointing at
// the annotation). Useful for self-tests of the lint passes — you
// write the offending pattern, slap `@expect` on it, and the test
// only fails when the lint stops working.
pub fn analysis_expect_fulfillment(t: *Typer, program: *Vector<Stmt>) {
    let pending: *Vector<ExpectPending> = Vector::new();
    _collect_expectations(program, pending);
    if pending.len() == 0 {
        pending.free();
        return;
    }
    // Build two structures from `pending`:
    //   - stmt-local entries (pe_line == pe_end_line) get indexed by
    //     `origin|line|code` for O(1) lookup
    //   - fn-scope entries (pe_line < pe_end_line) stay in a flat list
    //     because each diagnostic has to range-check against them
    let index: *HashMap<string> = HashMap::new();
    let ranged: *Vector<i32> = Vector::new();
    for let i: i32 = 0; i < pending.len(); i++ {
        let pe: ExpectPending = pending.get(i);
        if pe.pe_line == pe.pe_end_line {
            let key: string = _expect_key(pe.pe_origin, pe.pe_line, pe.pe_code);
            let cur: string = if index.contains(key) { index.get(key) } else { "" };
            index.insert(key, cur.concat(" ").concat(int_to_str(i)));
        } else {
            ranged.push(i);
        }
    }
    // Single sweep over diagnostics — try the precise index first,
    // then fall back to range scan for fn-scope @expects.
    let consumed: *HashMap<bool> = HashMap::new();
    for let j: i32 = 0; j < t.diagnostics.len(); j++ {
        let d: DiagEntry = t.diagnostics.get(j);
        if d.severity != 2 {
            continue;
        }
        let mut matched: bool = false;
        let key: string = _expect_key(d.origin, d.line, d.code);
        if index.contains(key) {
            let bucket: string = index.get(key);
            let toks: *Vector<string> = bucket.trim().split(" ");
            for let k: i32 = 0; k < toks.len(); k++ {
                let t_tok: string = toks.get(k);
                if t_tok.eq("") {
                    continue;
                }
                let idx: i32 = _expect_str_to_int(t_tok);
                let pe: ExpectPending = pending.get(idx);
                if pe.pe_done {
                    continue;
                }
                let mut updated: ExpectPending = pe;
                updated.pe_done = true;
                pending.set(idx, updated);
                matched = true;
                break;
            }
        }
        if !matched {
            for let k: i32 = 0; k < ranged.len(); k++ {
                let idx: i32 = ranged.get(k);
                let pe: ExpectPending = pending.get(idx);
                if pe.pe_done {
                    continue;
                }
                if !pe.pe_origin.eq(d.origin) {
                    continue;
                }
                if !pe.pe_code.eq(d.code) {
                    continue;
                }
                if d.line < pe.pe_line || d.line > pe.pe_end_line {
                    continue;
                }
                let mut updated: ExpectPending = pe;
                updated.pe_done = true;
                pending.set(idx, updated);
                matched = true;
                break;
            }
        }
        if matched {
            consumed.insert(int_to_str(j), true);
        }
    }
    // Phase 2: rebuild diagnostics list without consumed entries. The
    // compaction shifts indices, so remap relatedInformation (keyed by
    // diagnostic index) in lockstep and drop entries whose diagnostic was
    // consumed.
    if consumed.len() > 0 {
        if t.related != null && t.related.len() > 0 {
            let remap: *Vector<i32> = Vector::new();
            let mut newidx: i32 = 0;
            for let i: i32 = 0; i < t.diagnostics.len(); i++ {
                if consumed.contains(int_to_str(i)) {
                    remap.push(-1);
                } else {
                    remap.push(newidx);
                    newidx = newidx + 1;
                }
            }
            let kept_rel: *Vector<DiagRelated> = Vector::new();
            for let r_i: i32 = 0; r_i < t.related.len(); r_i++ {
                let mut r: DiagRelated = t.related.get(r_i);
                if r.diag_index < 0 || r.diag_index >= remap.len() {
                    continue;
                }
                let ni: i32 = remap.get(r.diag_index);
                if ni < 0 {
                    continue;
                }
                r.diag_index = ni;
                kept_rel.push(r);
            }
            t.related = kept_rel;
        }
        let kept: *Vector<DiagEntry> = Vector::new();
        for let i: i32 = 0; i < t.diagnostics.len(); i++ {
            let key: string = int_to_str(i);
            if consumed.contains(key) {
                continue;
            }
            kept.push(t.diagnostics.get(i));
        }
        t.diagnostics = kept;
    }
    // Phase 3: emit `unfulfilled-expectation` errors for the
    // expectations no diagnostic satisfied.
    for let i: i32 = 0; i < pending.len(); i++ {
        let pe: ExpectPending = pending.get(i);
        if pe.pe_done {
            continue;
        }
        t.current_origin = pe.pe_origin;
        t.err_code(pe.pe_line, pe.pe_col, "unfulfilled-expectation", "@expect(\"".concat(pe.pe_code).concat("\") on this stmt did not match any emitted diagnostic"));
    }
    consumed.free();
    pending.free();
}

// Compact key for the @expect index. Three parts joined by `|` is
// fine because none of them can contain `|` in legal source
// (origins are file paths, codes are ident-like, lines are ints).
fn _expect_key(origin: string, line: i32, code: string) -> string {
    return origin.concat("|").concat(int_to_str(line)).concat("|").concat(code);
}

// Local ASCII int parser. The lsp module doesn't import stdlib helpers
// and parse_int_lexeme lives in the parser module — easier to inline a
// 10-line function than thread an import.
fn _expect_str_to_int(s: string) -> i32 {
    let mut acc: i32 = 0;
    for let i: i32 = 0; i < s.len(); i++ {
        let c: i32 = s.at(i).to_int();
        if c < 48 || c > 57 {
            return acc;
        }
        acc = acc * 10 + (c - 48);
    }
    return acc;
}

fn _collect_expectations(program: *Vector<Stmt>, out: *Vector<ExpectPending>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        // Fn-level `@expect("...")` covers the whole body — match
        // anywhere from the fn's first line through the last stmt's
        // line. Useful when the warning fires on a sub-expression
        // and the user just wants to assert "somewhere in here".
        if s.kind == ST_FN && s.fn_body != null {
            _gather_expects_in_fn(&s, s.fn_body, out);
            _gather_expects_in_body(s.fn_body, s.origin, out);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null {
                    continue;
                }
                _gather_expects_in_fn(&m, m.fn_body, out);
                _gather_expects_in_body(m.fn_body, m.origin, out);
            }
        }
    }
}

fn _gather_expects_in_fn(s: *Stmt, body: *Vector<Stmt>, out: *Vector<ExpectPending>) {
    if s == null || s.attrs == null {
        return;
    }
    let end_line: i32 = _max_line_in_body(body, s.line);
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !a.name.eq("expect") {
            continue;
        }
        if a.args == null || a.args.len() == 0 {
            continue;
        }
        let v: Expr = a.args.get(0);
        if v.kind != EX_STRING {
            continue;
        }
        let pe: ExpectPending = ExpectPending { pe_code: v.str_val, pe_line: s.line, pe_end_line: end_line, pe_col: s.column, pe_origin: s.origin, pe_done: false };
        out.push(pe);
    }
}

// Approximate the last line of a fn body — uses the highest `line`
// field seen across nested stmts. Good enough for matching @expect
// ranges; not source-precise but resilient to the parser not
// tracking explicit end positions.
fn _max_line_in_body(body: *Vector<Stmt>, fallback: i32) -> i32 {
    let mut best: i32 = fallback;
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.line > best {
            best = s.line;
        }
        if s.then_body != null {
            let sub: i32 = _max_line_in_body(s.then_body, best);
            if sub > best {
                best = sub;
            }
        }
        if s.else_body != null {
            let sub: i32 = _max_line_in_body(s.else_body, best);
            if sub > best {
                best = sub;
            }
        }
    }
    return best;
}

fn _gather_expects_in_body(body: *Vector<Stmt>, origin: string, out: *Vector<ExpectPending>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        _gather_expects_in_stmt(&s, origin, out);
        if s.then_body != null {
            _gather_expects_in_body(s.then_body, origin, out);
        }
        if s.else_body != null {
            _gather_expects_in_body(s.else_body, origin, out);
        }
    }
}

fn _gather_expects_in_stmt(s: *Stmt, origin: string, out: *Vector<ExpectPending>) {
    if s == null || s.attrs == null {
        return;
    }
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !a.name.eq("expect") {
            continue;
        }
        if a.args == null || a.args.len() == 0 {
            continue;
        }
        let v: Expr = a.args.get(0);
        if v.kind != EX_STRING {
            continue;
        }
        let pe: ExpectPending = ExpectPending { pe_code: v.str_val, pe_line: s.line, pe_end_line: s.line, pe_col: s.column, pe_origin: origin, pe_done: false };
        out.push(pe);
    }
}

// Variant of `_run_attr_call_lint` that takes a pre-built index +
// emits a custom code. Used by `analysis_custom_lints` to drive the
// shared scanner without rebuilding the dep map for each call.
fn _run_call_lint_with_index(t: *Typer, program: *Vector<Stmt>, dep: *HashMap<string>, lint_code: string, what: string) {
    if dep.len() == 0 {
        return;
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            if _has_allow(&s, lint_code) {
                continue;
            }
            t.current_origin = s.origin;
            let scope: *HashMap<string> = HashMap::new();
            _seed_scope_from_params(&s, scope, "");
            _scan_calls_in_body(t, s.fn_body, dep, lint_code, what, scope);
            scope.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            let mut owner: string = "";
            if s.impl_target != null && s.impl_target.name != null {
                owner = s.impl_target.name;
            }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null {
                    continue;
                }
                if _has_allow(&m, lint_code) {
                    continue;
                }
                t.current_origin = m.origin;
                let scope: *HashMap<string> = HashMap::new();
                _seed_scope_from_params(&m, scope, owner);
                _scan_calls_in_body(t, m.fn_body, dep, lint_code, what, scope);
                scope.free();
            }
        }
    }
}

fn _run_attr_call_lint(t: *Typer, program: *Vector<Stmt>, attr_name: string, lint_code: string, what: string) {
    let dep: *HashMap<string> = HashMap::new();
    _collect_attr_fns(program, dep, attr_name);
    if dep.len() == 0 {
        dep.free();
        return;
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            if _has_allow(&s, lint_code) {
                continue;
            }
            t.current_origin = s.origin;
            let scope: *HashMap<string> = HashMap::new();
            // Top-level fn: seed scope with the declared param types
            // so `obj.method()` inside the body can resolve receiver
            // types through `Type::method` lookups.
            _seed_scope_from_params(&s, scope, "");
            _scan_calls_in_body(t, s.fn_body, dep, lint_code, what, scope);
            scope.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            // Inside `impl Type { ... }`, `self` is bound to the
            // owner. Surface that to the receiver lookup so
            // `self.old()` resolves to `Type::old`.
            let mut owner: string = "";
            if s.impl_target != null && s.impl_target.name != null {
                owner = s.impl_target.name;
            }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null {
                    continue;
                }
                if _has_allow(&m, lint_code) {
                    continue;
                }
                t.current_origin = m.origin;
                let scope: *HashMap<string> = HashMap::new();
                _seed_scope_from_params(&m, scope, owner);
                _scan_calls_in_body(t, m.fn_body, dep, lint_code, what, scope);
                scope.free();
            }
        }
    }
    dep.free();
}

// Walk a fn's declared params, recording each `name: Type` binding so
// receiver lookups inside the body can resolve `name.method()` to
// `Type::method`. `self_owner` is the impl target name (used to
// auto-type the implicit `self` param).
fn _seed_scope_from_params(s: *Stmt, scope: *HashMap<string>, self_owner: string) {
    if s == null || s.fn_params == null {
        return;
    }
    for let i: i32 = 0; i < s.fn_params.len(); i++ {
        let p: Param = s.fn_params.get(i);
        if p.name.eq("self") && !self_owner.eq("") {
            scope.insert("self", self_owner);
            continue;
        }
        let n: string = _type_root_name(p.ty);
        if !n.eq("") {
            scope.insert(p.name, n);
        }
    }
}

fn _collect_attr_fns(program: *Vector<Stmt>, dep: *HashMap<string>, attr_name: string) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN {
            let reason: ?string = _attr_reason(&s, attr_name);
            if reason.has {
                dep.insert(s.name, reason.val);
            }
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            // Methods inside `impl Type { ... }` get keyed under
            // `Type::method` so `Type::method()` calls hit only that
            // entry; we also keep the bare name as a fallback for
            // `obj.method()` style calls where the call site can't tell
            // the receiver type without type info.
            let mut owner: string = "";
            if s.impl_target != null && s.impl_target.name != null {
                owner = s.impl_target.name;
            }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                let reason: ?string = _attr_reason(&m, attr_name);
                if !reason.has {
                    continue;
                }
                let rv: string = reason.val;
                if !owner.eq("") {
                    dep.insert(owner.concat("::").concat(m.name), rv);
                }
                // Only register the bare-name fallback if nothing's
                // there yet — preserves the older (and more specific)
                // entry when two impls share a method name.
                if !dep.contains(m.name) {
                    dep.insert(m.name, rv);
                }
            }
        }
    }
}

// Returns the attribute's reason string, or null if the item doesn't
// carry the attribute. Empty string means the attribute was present
// without an argument (e.g. `@deprecated`).
fn _attr_reason(s: *Stmt, attr_name: string) -> ?string {
    if s == null || s.attrs == null {
        return none();
    }
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !a.name.eq(attr_name) {
            continue;
        }
        if a.args == null || a.args.len() == 0 {
            return some("");
        }
        let v: Expr = a.args.get(0);
        if v.kind == EX_STRING {
            return some(v.str_val);
        }
        return some("");
    }
    return none();
}

// Flow-sensitive null-deref lint. For each fn body we walk stmts in
// source order keeping a small map `name → null?` derived from let
// inits and assignments. Whenever an expression dereferences (or
// member-accesses) an identifier we know to be currently null, we
// emit `null-deref` at the deref site. Reassigning the var to a
// non-null expression clears the flag; conditional branches reset
// the map for that scope since we can't track per-branch state
// without a full data-flow framework.
//
// What this catches:
//   let p: *T = null;
//   p.foo();              // null-deref
//   *p                    // null-deref
//
//   let p: *T = null;
//   if c { p = make(); }
//   p.foo();              // null-deref (branch may have skipped the init)
//
// What it doesn't (yet):
//   - flow through fn parameters (no annotation for "may be null")
//   - aliases (`let q = p;` doesn't propagate the null bit)
//   - mutable rebinding after early-return on null
pub fn analysis_null_deref(t: *Typer, program: *Vector<Stmt>) {
    // First pass: for every fn, identify which param indices are
    // dereferenced (or member-accessed) somewhere in the body
    // WITHOUT a preceding null-check. Those params are "non-null
    // required" — passing null literal to them at a call site is
    // an immediate crash.
    // Which params each fn null-GUARDS (validators like is_valid). Computed
    // first so the deref pass can treat `f(p)` as a guard of p when f guards
    // it — the "validate through a helper" pattern.
    let guards_params: *HashMap<string> = HashMap::new(); // fn name -> ","-joined guarded idxs
    _ndp_collect_param_guards(program, guards_params);
    let deref_params: *HashMap<string> = HashMap::new(); // fn name -> ","-joined indices
    _ndp_collect_param_derefs(program, deref_params, guards_params);
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            if _has_allow(&s, "null-deref") {
                continue;
            }
            t.current_origin = s.origin;
            let nulls: *HashMap<bool> = HashMap::new();
            _scan_null_body(t, s.fn_body, nulls);
            // Interprocedural pass: at each call site, look up
            // the callee's deref-param set and warn for null args.
            _ndp_check_calls_in_body(t, s.fn_body, deref_params);
            nulls.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null {
                    continue;
                }
                if _has_allow(&m, "null-deref") {
                    continue;
                }
                t.current_origin = m.origin;
                let nulls: *HashMap<bool> = HashMap::new();
                _scan_null_body(t, m.fn_body, nulls);
                _ndp_check_calls_in_body(t, m.fn_body, deref_params);
                nulls.free();
            }
        }
    }
    deref_params.free();
    guards_params.free();
}

// Compute which param indices are dereferenced unconditionally inside
// each fn body. "Unconditionally" = the body has no `if p == null`
// or `if p != null` guard ANYWHERE protecting the access. The result
// is conservative: if the body looks tricky, we don't include the
// index.
fn _ndp_collect_param_derefs(program: *Vector<Stmt>, deref_params: *HashMap<string>, guards_params: *HashMap<string>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && s.fn_params != null {
            _ndp_index_one_fn(&s, deref_params, guards_params);
        }
        if s.kind == ST_IMPL && s.impl_methods != null && s.impl_target != null {
            let tname: string = "";
            if s.impl_target.kind == TY_NAMED {
                tname = s.impl_target.name;
            } else {
                if s.impl_target.kind == TY_GENERIC {
                    tname = s.impl_target.name;
                }
            }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || m.fn_params == null {
                    continue;
                }
                _ndp_index_one_fn(&m, deref_params, guards_params);
                if !tname.eq("") {
                    // Also index under `<Type>::<method>` so callers
                    // doing `x.method(null)` can resolve.
                    let key: string = tname.concat("::").concat(m.name);
                    if deref_params.contains(m.name) {
                        deref_params.insert(key, deref_params.get(m.name));
                    }
                }
            }
        }
    }
}

fn _ndp_index_one_fn(m: *Stmt, deref_params: *HashMap<string>, guards_params: *HashMap<string>) {
    // Walk the body in source order. For each param, find the FIRST
    // event that mentions it: a guard (`if p == null` cond) or a
    // deref. A guard-first means the body handles null; a deref-first
    // means the body relies on caller-supplied non-null. Only the
    // latter set requires non-null args.
    let unprotected: *HashMap<bool> = HashMap::new(); // param -> first-seen-was-deref
    let seen_guard: *HashMap<bool> = HashMap::new();
    _ndp_walk_order(m.fn_body, unprotected, seen_guard, guards_params);
    let mut idxs: string = "";
    for let i: i32 = 0; i < m.fn_params.len(); i++ {
        let p: Param = m.fn_params.get(i);
        if p.ty == null || p.ty.kind != TY_POINTER {
            continue;
        }
        if !unprotected.contains(p.name) {
            continue;
        }
        if !unprotected.get(p.name) {
            continue;
        } // guarded first
        if idxs.eq("") {
            idxs = i.to_string();
        } else {
            idxs = idxs.concat(",").concat(i.to_string());
        }
    }
    unprotected.free();
    seen_guard.free();
    if !idxs.eq("") {
        deref_params.insert(m.name, idxs);
    }
}

// Walks body in source order. For each name, the first event wins:
// guard sets `unprotected[name] = false` (and never overwritten),
// deref sets `unprotected[name] = true` if no entry exists yet.
fn _ndp_walk_order(body: *Vector<Stmt>, unprotected: *HashMap<bool>, seen_guard: *HashMap<bool>, guards_params: *HashMap<string>) {
    if body == null {
        return;
    }
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        // Process cond before bodies — a guard registers before
        // the protected uses inside the branch.
        if s.cond != null {
            let gnames: *Vector<string> = Vector::new();
            _ndp_collect_guarded_names(s.cond, gnames);
            for let j: i32 = 0; j < gnames.len(); j++ {
                let n: string = gnames.get(j);
                if !unprotected.contains(n) {
                    unprotected.insert(n, false); // guard-first
                }
                seen_guard.insert(n, true);
            }
            // A param validated through a helper call (`is_valid(p)`) counts
            // as guarded — register before recording the cond's own derefs.
            _ndp_register_validated_args(s.cond, guards_params, unprotected);
            // Also check derefs in the cond expression itself.
            _ndp_record_derefs_in_expr_ordered(s.cond, unprotected, seen_guard);
            gnames.free();
        }
        if s.expr_value != null {
            _ndp_register_validated_args(s.expr_value, guards_params, unprotected);
            _ndp_record_derefs_in_expr_ordered(s.expr_value, unprotected, seen_guard);
        }
        if s.let_value != null {
            _ndp_register_validated_args(s.let_value, guards_params, unprotected);
            _ndp_record_derefs_in_expr_ordered(s.let_value, unprotected, seen_guard);
        }
        if s.then_body != null {
            _ndp_walk_order(s.then_body, unprotected, seen_guard, guards_params);
        }
        if s.else_body != null {
            _ndp_walk_order(s.else_body, unprotected, seen_guard, guards_params);
        }
    }
}

// For each call `f(args)` in `e`, if the callee `f` null-guards a param
// (per guards_params) and the matching argument is a bare identifier,
// register that identifier as guard-first. Models the "validate through a
// helper" pattern: passing p to a validator that null-checks it guards p.
// Only bare-ident args count — `f(p.val)` / `f(*p)` are real derefs handled
// elsewhere. First-event-wins is preserved (skip if already recorded).
fn _ndp_register_validated_args(e: *Expr, guards_params: *HashMap<string>, unprotected: *HashMap<bool>) {
    if e == null {
        return;
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT && e.args != null {
        let fname: string = e.lhs.str_val;
        if guards_params.contains(fname) {
            let idxs: string = guards_params.get(fname);
            let n: i32 = idxs.len();
            let mut buf: string = "";
            for let k: i32 = 0; k <= n; k++ {
                if k == n || idxs.at(k).to_int() == 44 {
                    if !buf.eq("") {
                        let idx: i32 = _ndp_atoi(buf);
                        if idx >= 0 && idx < e.args.len() {
                            let a: Expr = e.args.get(idx);
                            if a.kind == EX_IDENT && !unprotected.contains(a.str_val) {
                                unprotected.insert(a.str_val, false); // validated -> guard-first
                            }
                        }
                        buf = "";
                    }
                } else {
                    buf = buf.concat(idxs.substring(k, k + 1));
                }
            }
        }
    }
    if e.lhs != null {
        _ndp_register_validated_args(e.lhs, guards_params, unprotected);
    }
    if e.rhs != null {
        _ndp_register_validated_args(e.rhs, guards_params, unprotected);
    }
    if e.operand != null {
        _ndp_register_validated_args(e.operand, guards_params, unprotected);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _ndp_register_validated_args(&a, guards_params, unprotected);
        }
    }
}

// Compute, per fn, which pointer-param indices the fn null-GUARDS (the param
// appears in an `== null` / `!= null` test anywhere in the body). A call to
// such a fn validates that argument for the caller.
fn _ndp_collect_param_guards(program: *Vector<Stmt>, guards_params: *HashMap<string>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && s.fn_params != null {
            _ndp_index_guards_one_fn(&s, guards_params);
        }
        if s.kind == ST_IMPL && s.impl_methods != null && s.impl_target != null {
            let tname: string = "";
            if s.impl_target.kind == TY_NAMED {
                tname = s.impl_target.name;
            } else {
                if s.impl_target.kind == TY_GENERIC {
                    tname = s.impl_target.name;
                }
            }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || m.fn_params == null {
                    continue;
                }
                _ndp_index_guards_one_fn(&m, guards_params);
                if !tname.eq("") && guards_params.contains(m.name) {
                    guards_params.insert(tname.concat("::").concat(m.name), guards_params.get(m.name));
                }
            }
        }
    }
}

fn _ndp_index_guards_one_fn(m: *Stmt, guards_params: *HashMap<string>) {
    let guarded: *Vector<string> = Vector::new();
    _ndp_collect_all_guards(m.fn_body, guarded);
    let mut idxs: string = "";
    for let i: i32 = 0; i < m.fn_params.len(); i++ {
        let p: Param = m.fn_params.get(i);
        if p.ty == null || p.ty.kind != TY_POINTER {
            continue;
        }
        let mut is_guarded: bool = false;
        for let g: i32 = 0; g < guarded.len(); g++ {
            if guarded.get(g).eq(p.name) {
                is_guarded = true;
                break;
            }
        }
        if !is_guarded {
            continue;
        }
        if idxs.eq("") {
            idxs = i.to_string();
        } else {
            idxs = idxs.concat(",").concat(i.to_string());
        }
    }
    guarded.free();
    if !idxs.eq("") {
        guards_params.insert(m.name, idxs);
    }
}

// Collect every name that is null-tested in any cond throughout the body.
fn _ndp_collect_all_guards(body: *Vector<Stmt>, names: *Vector<string>) {
    if body == null {
        return;
    }
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.cond != null {
            _ndp_collect_guarded_names(s.cond, names);
        }
        if s.then_body != null {
            _ndp_collect_all_guards(s.then_body, names);
        }
        if s.else_body != null {
            _ndp_collect_all_guards(s.else_body, names);
        }
    }
}

fn _ndp_collect_guarded_names(e: *Expr, names: *Vector<string>) {
    if e == null {
        return;
    }
    if e.kind == EX_BINARY && (e.op_code == OP_EQ || e.op_code == OP_NE) && e.lhs != null && e.rhs != null {
        if e.lhs.kind == EX_IDENT && e.rhs.kind == EX_NULL {
            names.push(e.lhs.str_val);
        }
        if e.rhs.kind == EX_IDENT && e.lhs.kind == EX_NULL {
            names.push(e.rhs.str_val);
        }
    }
    if e.lhs != null {
        _ndp_collect_guarded_names(e.lhs, names);
    }
    if e.rhs != null {
        _ndp_collect_guarded_names(e.rhs, names);
    }
    if e.operand != null {
        _ndp_collect_guarded_names(e.operand, names);
    }
}

fn _ndp_record_derefs_in_expr_ordered(e: *Expr, unprotected: *HashMap<bool>, seen_guard: *HashMap<bool>) {
    if e == null {
        return;
    }
    let target: string = _ndp_deref_target(e);
    if !target.eq("") && !unprotected.contains(target) {
        // First event for this name is a deref → mark unprotected.
        unprotected.insert(target, true);
    }
    if e.lhs != null {
        _ndp_record_derefs_in_expr_ordered(e.lhs, unprotected, seen_guard);
    }
    if e.rhs != null {
        _ndp_record_derefs_in_expr_ordered(e.rhs, unprotected, seen_guard);
    }
    if e.operand != null {
        _ndp_record_derefs_in_expr_ordered(e.operand, unprotected, seen_guard);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _ndp_record_derefs_in_expr_ordered(&a, unprotected, seen_guard);
        }
    }
}

fn _ndp_deref_target(e: *Expr) -> string {
    if e == null {
        return "";
    }
    if e.kind == EX_UNARY && e.op_code == UN_DEREF && e.operand != null && e.operand.kind == EX_IDENT {
        return e.operand.str_val;
    }
    if e.kind == EX_MEMBER && e.lhs != null && e.lhs.kind == EX_IDENT {
        return e.lhs.str_val;
    }
    if e.kind == EX_INDEX && e.lhs != null && e.lhs.kind == EX_IDENT {
        return e.lhs.str_val;
    }
    return "";
}

// Walk a body and flag every call site where a null literal hits
// a known-non-null-required param of the callee.
fn _ndp_check_calls_in_body(t: *Typer, body: *Vector<Stmt>, deref_params: *HashMap<string>) {
    if body == null {
        return;
    }
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.expr_value != null {
            _ndp_check_calls_in_expr(t, s.expr_value, deref_params);
        }
        if s.let_value != null {
            _ndp_check_calls_in_expr(t, s.let_value, deref_params);
        }
        if s.cond != null {
            _ndp_check_calls_in_expr(t, s.cond, deref_params);
        }
        if s.then_body != null {
            _ndp_check_calls_in_body(t, s.then_body, deref_params);
        }
        if s.else_body != null {
            _ndp_check_calls_in_body(t, s.else_body, deref_params);
        }
    }
}

fn _ndp_check_calls_in_expr(t: *Typer, e: *Expr, deref_params: *HashMap<string>) {
    if e == null {
        return;
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT && e.args != null {
        let fname: string = e.lhs.str_val;
        if deref_params.contains(fname) {
            let idxs: string = deref_params.get(fname);
            // Parse comma-joined indices.
            let mut buf: string = "";
            let n: i32 = idxs.len();
            for let k: i32 = 0; k <= n; k++ {
                if k == n || idxs.at(k).to_int() == 44 {
                    if !buf.eq("") {
                        let idx: i32 = _ndp_atoi(buf);
                        if idx >= 0 && idx < e.args.len() {
                            let a: Expr = e.args.get(idx);
                            if a.kind == EX_NULL {
                                t.warn_range(a.line, a.column, _expr_span(&a), "null-deref", "passing `null` to `".concat(fname).concat("` — param at index ").concat(idx.to_string()).concat(" is dereferenced without a null-check; this call will segfault"));
                            }
                        }
                        buf = "";
                    }
                } else {
                    buf = buf.concat(idxs.substring(k, k + 1));
                }
            }
        }
    }
    if e.lhs != null {
        _ndp_check_calls_in_expr(t, e.lhs, deref_params);
    }
    if e.rhs != null {
        _ndp_check_calls_in_expr(t, e.rhs, deref_params);
    }
    if e.operand != null {
        _ndp_check_calls_in_expr(t, e.operand, deref_params);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _ndp_check_calls_in_expr(t, &a, deref_params);
        }
    }
}

fn _ndp_atoi(s: string) -> i32 {
    let mut n: i32 = 0;
    for let i: i32 = 0; i < s.len(); i++ {
        let c: i32 = s.at(i).to_int();
        if c < 48 || c > 57 {
            return -1;
        }
        n = n * 10 + (c - 48);
    }
    return n;
}

// Catches `free(x)` / `defer free(x)` where `x` is a Glide `string`.
// Strings in Glide are always allocated through the per-coro arena
// (palloc), so calling libc `free()` on one corrupts the heap and
// double-frees on the next arena drop. The arena handles cleanup
// automatically — the right fix is to delete the `free` call.
//
// Scope is intentionally narrow: only `let s: string = ...; free(s)`
// fires the warning. Vector / HashMap aren't included because their
// destructors (`p.free()` on a struct's `*Vector<…>` field) are
// legitimate uses; an interprocedural check would be needed to
// distinguish "this is the destructor releasing its own field" from
// "this is user code reaching into an arena-managed value".
pub fn analysis_bad_free(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            if _has_allow(&s, "bad-free") {
                continue;
            }
            t.current_origin = s.origin;
            let tys: *HashMap<string> = HashMap::new();
            _bf_scan_body(t, s.fn_body, tys, "");
            tys.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            // Detect a collection self-destructor: `impl Vector<T> {
            // fn free(self: *Vector<T>) { ... } }`. Only inside such
            // a method is `free(self as *void)` a legitimate pattern;
            // outside, calling libc free on a Vector / HashMap value
            // leaks its internal buffers.
            let impl_target: string = "";
            if s.impl_target != null {
                if s.impl_target.kind == TY_NAMED {
                    impl_target = s.impl_target.name;
                } else {
                    if s.impl_target.kind == TY_GENERIC {
                        impl_target = s.impl_target.name;
                    }
                }
            }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null {
                    continue;
                }
                if _has_allow(&m, "bad-free") {
                    continue;
                }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                let mut self_destructor_of: string = "";
                if m.name.eq("free") && (impl_target.eq("Vector") || impl_target.eq("HashMap")) {
                    self_destructor_of = impl_target;
                }
                let tys: *HashMap<string> = HashMap::new();
                _bf_scan_body(t, m.fn_body, tys, self_destructor_of);
                tys.free();
            }
        }
    }
}

// Reduce a Type to a short tag we can store in a HashMap<string>.
// Returns "" for types we don't care about.
fn _bf_ty_tag(ty: *Type) -> string {
    if ty == null {
        return "";
    }
    if ty.kind == TY_NAMED {
        return ty.name;
    }
    if ty.kind == TY_POINTER && ty.inner != null {
        // *Vector<T> / *HashMap<V> / *T — keep the inner head name.
        if ty.inner.kind == TY_NAMED {
            return ty.inner.name;
        }
        if ty.inner.kind == TY_GENERIC {
            return ty.inner.name;
        }
    }
    if ty.kind == TY_GENERIC {
        return ty.name;
    }
    return "";
}

// ---------- string-eq-with-== --------------------------------------------
// Glide strings are NUL-terminated `const char*`. The C `==` compares
// pointers, not content — `s == "foo"` is almost always wrong (returns
// true only when both sides reference the same interned literal).
// `.eq()` does the actual byte comparison.
pub fn analysis_string_eq_op(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            if _has_allow(&s, "string-eq-op") {
                continue;
            }
            t.current_origin = s.origin;
            let tys: *HashMap<string> = HashMap::new();
            _seq_scan_body(t, s.fn_body, tys);
            tys.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null {
                    continue;
                }
                if _has_allow(&m, "string-eq-op") {
                    continue;
                }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                let tys: *HashMap<string> = HashMap::new();
                _seq_scan_body(t, m.fn_body, tys);
                tys.free();
            }
        }
    }
}

fn _seq_scan_body(t: *Typer, body: *Vector<Stmt>, tys: *HashMap<string>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null && !s.name.eq("") && s.let_ty != null {
            tys.insert(s.name, _bf_ty_tag(s.let_ty));
        }
        if s.expr_value != null {
            _seq_check_expr(t, s.expr_value, tys);
        }
        if s.let_value != null {
            _seq_check_expr(t, s.let_value, tys);
        }
        if s.cond != null {
            _seq_check_expr(t, s.cond, tys);
        }
        if s.then_body != null {
            _seq_scan_body(t, s.then_body, tys);
        }
        if s.else_body != null {
            _seq_scan_body(t, s.else_body, tys);
        }
    }
}

fn _seq_check_expr(t: *Typer, e: *Expr, tys: *HashMap<string>) {
    if e == null {
        return;
    }
    if e.kind == EX_BINARY && (e.op_code == OP_EQ || e.op_code == OP_NE) && e.lhs != null && e.rhs != null {
        // `s == null` / `s != null` is a legitimate pointer-presence
        // check — strings ARE nullable in Glide. Skip those.
        if e.lhs.kind == EX_NULL || e.rhs.kind == EX_NULL {
        } else {
            let lhs_str: bool = _seq_is_string_expr(e.lhs, tys);
            let rhs_str: bool = _seq_is_string_expr(e.rhs, tys);
            if lhs_str || rhs_str {
                let op_name: string = "==";
                if e.op_code == OP_NE {
                    op_name = "!=";
                }
                let suggest: string = ".eq(…)";
                if e.op_code == OP_NE {
                    suggest = "!… .eq(…)";
                }
                t.warn_range(e.line, e.column, _expr_span(e.lhs), "string-eq-op", "`".concat(op_name).concat("` on strings compares pointers, not bytes — use `").concat(suggest).concat("` for the actual comparison"));
            }
        }
    }
    if e.lhs != null {
        _seq_check_expr(t, e.lhs, tys);
    }
    if e.rhs != null {
        _seq_check_expr(t, e.rhs, tys);
    }
    if e.operand != null {
        _seq_check_expr(t, e.operand, tys);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _seq_check_expr(t, &a, tys);
        }
    }
}

fn _seq_is_string_expr(e: *Expr, tys: *HashMap<string>) -> bool {
    if e == null {
        return false;
    }
    if e.kind == EX_STRING {
        return true;
    }
    if e.kind == EX_IDENT && tys.contains(e.str_val) {
        return tys.get(e.str_val).eq("string");
    }
    return false;
}

// ---------- unused-import ------------------------------------------------
// `import X::specific;` where no use of `specific` is found in the
// file. Wildcard / re-export forms aren't checked (impossible without
// dragging in module metadata). False-positive risk: a name might be
// referenced via macro expansion that we don't track here.
pub fn analysis_unused_import(t: *Typer, program: *Vector<Stmt>) {
    // Collect all identifiers referenced anywhere in the file. One
    // pass; we don't separate scopes because imports are top-level.
    let used: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_IMPORT {
            continue;
        }
        _ui_collect_stmt(&s, used);
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_IMPORT {
            continue;
        }
        if _has_allow(&s, "unused-import") {
            continue;
        }
        if s.import_wildcard {
            continue;
        }
        if s.imported_items == null || s.imported_items.len() == 0 {
            continue;
        }
        t.current_origin = s.origin;
        let mut any_used: bool = false;
        for let j: i32 = 0; j < s.imported_items.len(); j++ {
            let n: string = s.imported_items.get(j);
            if used.contains(n) {
                any_used = true;
                break;
            }
        }
        if !any_used {
            let first: string = s.imported_items.get(0);
            t.warn_range(s.line, s.column, 6, "unused-import", "import of `".concat(first).concat("` is never referenced in this file — remove it"));
        }
    }
    used.free();
}

// ---------- unused struct / enum -----------------------------------------
// A non-pub, non-generic struct or enum that is never referenced as a type,
// constructed, named in a path, or given an `impl` block is dead. Reuses the
// generous `_ui_collect_stmt` reference scan (the one analysis_unused_import
// uses): it marks every TY_NAMED in an annotation, every struct-literal name,
// every path head and every bare ident, so any plausible use suppresses the
// warning. A type with ANY impl block is treated as used (a strong intent
// signal that avoids flagging types referenced only through their methods).
pub fn analysis_unused_struct_enum(t: *Typer, program: *Vector<Stmt>) {
    let used: *HashMap<bool> = HashMap::new();
    let has_impl: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_IMPORT {
            continue;
        }
        if s.kind == ST_IMPL && s.impl_target != null && s.impl_target.name != null {
            has_impl.insert(s.impl_target.name, true);
        }
        _ui_collect_stmt(&s, used);
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_STRUCT && s.kind != ST_ENUM {
            continue;
        }
        if s.is_pub {
            continue;
        }
        if s.type_params != null && s.type_params.len() > 0 {
            continue;
        }
        if s.name == null || s.name.len() == 0 {
            continue;
        }
        if _has_allow(&s, "unused-struct") {
            continue;
        }
        if _has_allow(&s, "unused-enum") {
            continue;
        }
        if has_impl.contains(s.name) {
            continue;
        }
        if used.contains(s.name) {
            continue;
        }
        t.current_origin = s.origin;
        let mut nlen: i32 = s.name_len;
        if nlen == 0 {
            nlen = s.name.len();
        }
        if s.kind == ST_STRUCT {
            t.warn_unused_range(s.name_line, s.name_col, nlen, "unused-struct", "struct `".concat(s.name).concat("` is never used"));
        } else {
            t.warn_unused_range(s.name_line, s.name_col, nlen, "unused-enum", "enum `".concat(s.name).concat("` is never used"));
        }
    }
    used.free();
    has_impl.free();
}

// ---------- unused const -------------------------------------------------
// A non-pub top-level `const NAME = ..` whose NAME is never referenced
// anywhere in the file (idents, paths, annotations, other const values).
pub fn analysis_unused_const(t: *Typer, program: *Vector<Stmt>) {
    let used: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        _ui_collect_stmt(&s, used);
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_CONST {
            continue;
        }
        if s.is_pub {
            continue;
        }
        if s.name == null || s.name.len() == 0 {
            continue;
        }
        if _has_allow(&s, "unused-const") {
            continue;
        }
        if used.contains(s.name) {
            continue;
        }
        t.current_origin = s.origin;
        let mut nlen: i32 = s.name_len;
        if nlen == 0 {
            nlen = s.name.len();
        }
        t.warn_unused_range(s.name_line, s.name_col, nlen, "unused-const", "const `".concat(s.name).concat("` is never referenced"));
    }
    used.free();
}

// ---------- redundant import ---------------------------------------------
// Two import lines in the SAME file that resolve to the identical module
// file path: the second brings nothing the first didn't. Keyed on
// (origin, import_path) so two different files importing the same module
// never cross-trigger; only an in-file duplicate fires. Exact path equality
// also folds bare-vs-wildcard of the same module (both lower to the same
// `.glide` path). A selective item vs a wildcard of its parent carry
// different paths and are deliberately NOT matched (would risk false hits).
pub fn analysis_redundant_import(t: *Typer, program: *Vector<Stmt>) {
    let seen: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_IMPORT {
            continue;
        }
        if s.import_path == null || s.import_path.eq("") {
            continue;
        }
        if _has_allow(&s, "redundant-import") {
            continue;
        }
        let mut org: string = s.origin;
        if org == null {
            org = "";
        }
        let key: string = org.concat(" ").concat(s.import_path);
        if seen.contains(key) {
            t.current_origin = s.origin;
            t.warn_range(s.line, s.column, 6, "redundant-import", "duplicate import: this module is already imported above; remove this line");
        } else {
            seen.insert(key, true);
        }
    }
    seen.free();
}

// ---------- unused enum variant ------------------------------------------
// Within a non-pub enum that IS used somewhere, an individual variant never
// constructed (`E::V`) and never named in a match arm is dead. Keyed on the
// bare variant name (the parser strips `Mod::Type::` qualifiers, so a match
// arm and an `E::V` path both reduce to the bare variant). Skips pub/generic
// enums and any enum the type-ref scan never saw (a wholly-dead enum is
// owned by analysis_unused_struct_enum, no double report).
fn _uv_collect_expr(e: *Expr, out: *HashMap<bool>) {
    if e == null {
        return;
    }
    if e.kind == EX_PATH {
        out.insert(e.field, true);
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_PATH {
        out.insert(e.lhs.field, true);
    }
    if e.lhs != null {
        _uv_collect_expr(e.lhs, out);
    }
    if e.rhs != null {
        _uv_collect_expr(e.rhs, out);
    }
    if e.operand != null {
        _uv_collect_expr(e.operand, out);
    }
    if e.match_arms != null {
        for let i: i32 = 0; i < e.match_arms.len(); i++ {
            let arm: MatchArm = e.match_arms.get(i);
            out.insert(arm.variant, true);
        }
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _uv_collect_expr(&a, out);
        }
    }
}

fn _uv_collect_stmt(s: *Stmt, out: *HashMap<bool>) {
    if s == null {
        return;
    }
    if s.let_value != null {
        _uv_collect_expr(s.let_value, out);
    }
    if s.expr_value != null {
        _uv_collect_expr(s.expr_value, out);
    }
    if s.cond != null {
        _uv_collect_expr(s.cond, out);
    }
    if s.for_step != null {
        _uv_collect_expr(s.for_step, out);
    }
    if s.for_init != null {
        _uv_collect_stmt(s.for_init, out);
    }
    if s.arms != null {
        for let i: i32 = 0; i < s.arms.len(); i++ {
            let arm: MatchArm = s.arms.get(i);
            out.insert(arm.variant, true);
            if arm.body != null {
                for let j: i32 = 0; j < arm.body.len(); j++ {
                    let b: Stmt = arm.body.get(j);
                    _uv_collect_stmt(&b, out);
                }
            }
        }
    }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            _uv_collect_stmt(&b, out);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            _uv_collect_stmt(&b, out);
        }
    }
}

pub fn analysis_unused_variant(t: *Typer, program: *Vector<Stmt>) {
    let refs: *HashMap<bool> = HashMap::new();
    let used: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_IMPORT {
            _ui_collect_stmt(&s, refs);
        }
        if s.fn_body != null {
            for let j: i32 = 0; j < s.fn_body.len(); j++ {
                let b: Stmt = s.fn_body.get(j);
                _uv_collect_stmt(&b, used);
            }
        }
        if s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null {
                    for let k: i32 = 0; k < m.fn_body.len(); k++ {
                        let b: Stmt = m.fn_body.get(k);
                        _uv_collect_stmt(&b, used);
                    }
                }
            }
        }
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_ENUM {
            continue;
        }
        if s.is_pub {
            continue;
        }
        if s.type_params != null && s.type_params.len() > 0 {
            continue;
        }
        if s.name == null {
            continue;
        }
        if _has_allow(&s, "unused-variant") {
            continue;
        }
        if !refs.contains(s.name) {
            continue;
        }
        if s.enum_variants == null {
            continue;
        }
        let mut nlen: i32 = s.name_len;
        if nlen == 0 {
            nlen = s.name.len();
        }
        for let j: i32 = 0; j < s.enum_variants.len(); j++ {
            let v: EnumVariant = s.enum_variants.get(j);
            if used.contains(v.name) {
                continue;
            }
            t.current_origin = s.origin;
            t.warn_unused_range(s.name_line, s.name_col, nlen, "unused-variant", "enum variant `".concat(s.name).concat("::").concat(v.name).concat("` is never constructed or matched"));
        }
    }
    refs.free();
    used.free();
}

// ---------- arena-set-without-restore ------------------------------------
// `__glide_palloc_set(arena)` makes that arena the active one for all
// allocations until the next set. Without a paired `_set(prev)` (or a
// `defer __glide_palloc_set(prev)` registered immediately after), the
// arena leaks across return paths — the same bug that caused the LSP
// completion crash earlier.
pub fn analysis_arena_set_unbalanced(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "arena-set") {
            t.current_origin = s.origin;
            _asu_check_fn(t, s.fn_body, s.line, s.column);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "arena-set") {
                    continue;
                }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                _asu_check_fn(t, m.fn_body, m.line, m.column);
            }
        }
    }
}

fn _asu_check_fn(t: *Typer, body: *Vector<Stmt>, fn_line: i32, fn_col: i32) {
    let mut sets: i32 = 0;
    let mut defer_sets: i32 = 0;
    let mut first_set_line: i32 = 0;
    let mut first_set_col: i32 = 0;
    _asu_walk(body, &sets, &defer_sets, &first_set_line, &first_set_col, false);
    // Each non-defer set must be balanced by either another set (the
    // restore) or a defer set (the restore-via-defer).
    if sets > 0 && defer_sets + sets < sets * 2 {
        t.warn_range(first_set_line, first_set_col, 18, "arena-set", "`__glide_palloc_set(arena)` has no matching restore — add `defer __glide_palloc_set(prev);` immediately after the set");
    }
}

fn _asu_walk(body: *Vector<Stmt>, sets: *i32, defer_sets: *i32, fline: *i32, fcol: *i32, in_defer: bool) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_DEFER && s.expr_value != null {
            // Any palloc_set inside a defer counts as a restore —
            // even `_set(prev)` carries a non-null arg, and defers
            // fire on every exit so the restore is guaranteed.
            if _asu_is_palloc_set_any(s.expr_value) {
                *defer_sets = *defer_sets + 1;
            }
        } else {
            if s.expr_value != null && _asu_is_palloc_set_active(s.expr_value) {
                // Only `_set(<non-null>)` needs a balancing restore.
                // `_set(null)` IS a restore (drops the active arena).
                *sets = *sets + 1;
                if *fline == 0 {
                    *fline = s.line;
                    *fcol = s.column;
                }
            } else {
                if s.expr_value != null && _asu_is_palloc_set_any(s.expr_value) {
                    // Bare `_set(null)` or `_set(prev)` — count as restore.
                    *defer_sets = *defer_sets + 1;
                }
            }
        }
        if s.then_body != null {
            _asu_walk(s.then_body, sets, defer_sets, fline, fcol, in_defer);
        }
        if s.else_body != null {
            _asu_walk(s.else_body, sets, defer_sets, fline, fcol, in_defer);
        }
    }
}

fn _asu_is_palloc_set_any(e: *Expr) -> bool {
    if e == null {
        return false;
    }
    if e.kind != EX_CALL || e.lhs == null || e.lhs.kind != EX_IDENT {
        return false;
    }
    return e.lhs.str_val.eq("__glide_palloc_set");
}

fn _asu_is_palloc_set_active(e: *Expr) -> bool {
    if !_asu_is_palloc_set_any(e) {
        return false;
    }
    if e.args == null || e.args.len() != 1 {
        return false;
    }
    let arg: Expr = e.args.get(0);
    // Treat `_set(<arena-creating call>)` as the "active set" — that's
    // the form that actually starts a per-scope arena and needs a
    // restore. `_set(prev)` / `_set(null)` / `_set(saved_var)` are
    // restores, not new sets. Heuristic: look for a call to
    // `__glide_palloc_make` somewhere inside the arg.
    return _asu_arg_creates_arena(&arg);
}

fn _asu_arg_creates_arena(e: *Expr) -> bool {
    if e == null {
        return false;
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT && e.lhs.str_val.eq("__glide_palloc_make") {
        return true;
    }
    if e.lhs != null && _asu_arg_creates_arena(e.lhs) {
        return true;
    }
    if e.operand != null && _asu_arg_creates_arena(e.operand) {
        return true;
    }
    return false;
}

// ---------- coro-blocking ------------------------------------------------
// `spawn` submits a call to the M:N scheduler — if the called fn does
// sync IO (fs_read, sync TCP, blocking sleep) it stalls the worker
// thread, defeating the point. We resolve the spawn target's body and
// walk it looking for blocking helpers; for `spawn_thread` we don't
// warn (a pthread is supposed to block).
pub fn analysis_coro_blocking(t: *Typer, program: *Vector<Stmt>) {
    let blocking: *HashMap<bool> = HashMap::new();
    blocking.insert("fs_read", true);
    blocking.insert("fs_read_bytes", true);
    blocking.insert("fs_write", true);
    blocking.insert("fs_write_bytes", true);
    blocking.insert("fs_append", true);
    blocking.insert("fs_copy", true);
    blocking.insert("__glide_sleep_ms_blocking", true);
    blocking.insert("process_run", true);
    blocking.insert("http_get_sync", true);
    // Build name → body so spawn lookups can walk the target.
    let bodies: *HashMap<*Vector<Stmt>> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            bodies.insert(s.name, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null {
                    bodies.insert(m.name, m.fn_body);
                }
            }
        }
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "coro-blocking") {
            t.current_origin = s.origin;
            _cb_scan_for_spawn(t, s.fn_body, blocking, bodies);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "coro-blocking") {
                    continue;
                }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                _cb_scan_for_spawn(t, m.fn_body, blocking, bodies);
            }
        }
    }
    bodies.free();
    blocking.free();
}

fn _cb_scan_for_spawn(t: *Typer, body: *Vector<Stmt>, blocking: *HashMap<bool>, bodies: *HashMap<*Vector<Stmt>>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_SPAWN && !s.is_spawn_thread && s.expr_value != null && s.expr_value.kind == EX_CALL && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT {
            let tgt: string = s.expr_value.lhs.str_val;
            // Direct: spawn fs_read(...) — blocking name spawned.
            if blocking.contains(tgt) {
                t.warn_range(s.expr_value.line, s.expr_value.column, _expr_span(s.expr_value), "coro-blocking", "`".concat(tgt).concat("` blocks the worker thread — use `spawn_thread` instead of `spawn`"));
            } else {
                if bodies.contains(tgt) {
                    let target_body: *Vector<Stmt> = bodies.get(tgt);
                    _cb_walk_for_blocking(t, target_body, blocking, tgt, s.line);
                }
            }
        }
        if s.then_body != null {
            _cb_scan_for_spawn(t, s.then_body, blocking, bodies);
        }
        if s.else_body != null {
            _cb_scan_for_spawn(t, s.else_body, blocking, bodies);
        }
    }
}

fn _cb_walk_for_blocking(t: *Typer, body: *Vector<Stmt>, blocking: *HashMap<bool>, spawn_target: string, spawn_line: i32) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.expr_value != null {
            _cb_check_blocking_call(t, s.expr_value, blocking, spawn_target);
        }
        if s.let_value != null {
            _cb_check_blocking_call(t, s.let_value, blocking, spawn_target);
        }
        if s.then_body != null {
            _cb_walk_for_blocking(t, s.then_body, blocking, spawn_target, spawn_line);
        }
        if s.else_body != null {
            _cb_walk_for_blocking(t, s.else_body, blocking, spawn_target, spawn_line);
        }
    }
}

fn _cb_check_blocking_call(t: *Typer, e: *Expr, blocking: *HashMap<bool>, spawned: string) {
    if e == null {
        return;
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT && blocking.contains(e.lhs.str_val) {
        t.warn_range(e.line, e.column, _expr_span(e), "coro-blocking", "`".concat(e.lhs.str_val).concat("` blocks the worker thread — reached from `spawn ").concat(spawned).concat("()`. Use `spawn_thread` instead, or call the async variant"));
    }
    if e.lhs != null {
        _cb_check_blocking_call(t, e.lhs, blocking, spawned);
    }
    if e.rhs != null {
        _cb_check_blocking_call(t, e.rhs, blocking, spawned);
    }
    if e.operand != null {
        _cb_check_blocking_call(t, e.operand, blocking, spawned);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _cb_check_blocking_call(t, &a, blocking, spawned);
        }
    }
}

// ---------- unhandled-result ---------------------------------------------
// Calling a `fn -> !T` and discarding the value silently swallows the
// error. Accepted forms: `x?`, `let _ = …`, `let bound = …`, `match …`,
// or `return …`. Bare `ST_EXPR` with a `!T`-returning call is the bug.
//
// Method calls (`x.foo()`) are resolved by looking up the receiver's
// declared type from let bindings and consulting a per-type method
// table — so `Conn.write -> int` and `TcpStream.write -> !int` get
// distinguished even though they share a method name.
pub fn analysis_unhandled_result(t: *Typer, program: *Vector<Stmt>) {
    let ret_kinds: *HashMap<i32> = HashMap::new();
    let method_rets: *HashMap<i32> = HashMap::new();
    _ur_collect_sigs(program, ret_kinds, method_rets);
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "unhandled-result") {
            t.current_origin = s.origin;
            let tys: *HashMap<string> = HashMap::new();
            _ur_seed_params(s.fn_params, tys);
            _ur_walk(t, s.fn_body, ret_kinds, method_rets, tys);
            tys.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "unhandled-result") {
                    continue;
                }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                let tys: *HashMap<string> = HashMap::new();
                _ur_seed_params(m.fn_params, tys);
                _ur_walk(t, m.fn_body, ret_kinds, method_rets, tys);
                tys.free();
            }
        }
    }
    ret_kinds.free();
    method_rets.free();
}

fn _ur_seed_params(params: *Vector<Param>, tys: *HashMap<string>) {
    if params == null {
        return;
    }
    for let i: i32 = 0; i < params.len(); i++ {
        let p: Param = params.get(i);
        if p.ty != null && !p.name.eq("") {
            tys.insert(p.name, _bf_ty_tag(p.ty));
        }
    }
}

fn _ur_collect_sigs(program: *Vector<Stmt>, ret_kinds: *HashMap<i32>, method_rets: *HashMap<i32>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_ret_ty != null {
            ret_kinds.insert(s.name, s.fn_ret_ty.kind);
        }
        if s.kind == ST_IMPL && s.impl_methods != null && s.impl_target != null {
            let tname: string = "";
            if s.impl_target.kind == TY_NAMED {
                tname = s.impl_target.name;
            } else {
                if s.impl_target.kind == TY_GENERIC {
                    tname = s.impl_target.name;
                }
            }
            if tname.eq("") {
                continue;
            }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_ret_ty != null {
                    let key: string = tname.concat("::").concat(m.name);
                    method_rets.insert(key, m.fn_ret_ty.kind);
                }
            }
        }
    }
}

fn _ur_walk(t: *Typer, body: *Vector<Stmt>, ret_kinds: *HashMap<i32>, method_rets: *HashMap<i32>, tys: *HashMap<string>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null && !s.name.eq("") && s.let_ty != null {
            tys.insert(s.name, _bf_ty_tag(s.let_ty));
        }
        if s.kind == ST_EXPR && s.expr_value != null {
            _ur_check_call(t, s.expr_value, ret_kinds, method_rets, tys);
        }
        if s.then_body != null {
            _ur_walk(t, s.then_body, ret_kinds, method_rets, tys);
        }
        if s.else_body != null {
            _ur_walk(t, s.else_body, ret_kinds, method_rets, tys);
        }
        if s.fn_body != null {
            _ur_walk(t, s.fn_body, ret_kinds, method_rets, tys);
        }
    }
}

fn _ur_check_call(t: *Typer, e: *Expr, ret_kinds: *HashMap<i32>, method_rets: *HashMap<i32>, tys: *HashMap<string>) {
    if e == null {
        return;
    }
    // `?` is enough — already propagating.
    if e.kind == EX_UNARY && e.op_code == UN_TRY {
        return;
    }
    if e.kind != EX_CALL || e.lhs == null {
        return;
    }
    let fn_label: string = "";
    let mut k: i32 = -1;
    if e.lhs.kind == EX_IDENT {
        // Bare fn: `foo(…)`.
        let n: string = e.lhs.str_val;
        if !ret_kinds.contains(n) {
            return;
        }
        fn_label = n;
        k = ret_kinds.get(n);
    } else {
        if e.lhs.kind == EX_MEMBER && e.lhs.field != null && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT {
            // Method: `x.foo(…)`. Resolve x's declared type and look up
            // the per-type method table. Skip when receiver type isn't
            // tracked (param / let-without-annotation / chain receiver).
            let recv: string = e.lhs.lhs.str_val;
            if !tys.contains(recv) {
                return;
            }
            let tname: string = tys.get(recv);
            if tname.eq("") {
                return;
            }
            let key: string = tname.concat("::").concat(e.lhs.field);
            if !method_rets.contains(key) {
                return;
            }
            fn_label = recv.concat(".").concat(e.lhs.field);
            k = method_rets.get(key);
        } else {
            return;
        }
    }
    if k == TY_RESULT || k == TY_OPT_RESULT {
        t.warn_range(e.line, e.column, _expr_span(e), "unhandled-result", "`".concat(fn_label).concat("` returns a `!T` whose error is being discarded — propagate with `?` or bind with `let r = …`"));
    }
}

// ---------- ignored-option -----------------------------------------------
// `.val` on a `?T` reaches into the payload regardless of whether it's
// some or none — reading the none branch is UB. Accepted shape:
// `if x.is_some() { … x.val … }` or `let v = x?`. Anything else is a
// landmine. We detect only the simplest case: a `.val` access whose
// receiver is an EX_IDENT typed as `?T` (no `is_some` check above it
// in the same straight-line block).
pub fn analysis_ignored_option(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "ignored-option") {
            t.current_origin = s.origin;
            let opts: *HashMap<bool> = HashMap::new();
            let checked: *HashMap<bool> = HashMap::new();
            _io_scan(t, s.fn_body, opts, checked, program, s.origin);
            opts.free();
            checked.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "ignored-option") {
                    continue;
                }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                let opts: *HashMap<bool> = HashMap::new();
                let checked: *HashMap<bool> = HashMap::new();
                _io_scan(t, m.fn_body, opts, checked, program, s.origin);
                opts.free();
                checked.free();
            }
        }
    }
}

fn _io_scan(t: *Typer, body: *Vector<Stmt>, opts: *HashMap<bool>, checked: *HashMap<bool>, root: *Vector<Stmt>, path: string) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null {
            // Track `?T` locals, by annotation OR inferred from the value
            // (`let m = find(...)`), so the common unannotated form is covered.
            let mut lty: *Type = s.let_ty;
            if lty == null && s.let_value != null {
                lty = _let_node_type(&s, root, s.line - 1, path, 0);
            }
            if lty != null && (lty.kind == TY_OPTION || lty.kind == TY_OPT_RESULT) {
                opts.insert(s.name, true);
                // `let x = some(v)` is born present; `let x = find()` is not.
                checked.insert(s.name, _io_rhs_is_present(s.let_value));
            }
        }
        // Reassignment narrows: `x = some(v)` makes x present, `x = none()`
        // (or any non-present rhs) marks it unchecked again.
        if s.kind == ST_EXPR && s.expr_value != null && s.expr_value.kind == EX_ASSIGN && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT && opts.contains(s.expr_value.lhs.str_val) {
            checked.insert(s.expr_value.lhs.str_val, _io_rhs_is_present(s.expr_value.rhs));
        }
        if s.cond != null {
            // A `.val` read in the condition itself is unguarded unless a
            // `&&`-left guard protects it.
            _io_check_cond(t, s.cond, opts, checked);
        }
        // Positive guard: names a `&&`-chain of presence checks proves are
        // safe inside the then-body (`if x.is_some() && x.val > 0 { … }`).
        if s.then_body != null {
            let gnames: *Vector<string> = Vector::new();
            if s.cond != null {
                _io_collect_and_checks(s.cond, gnames);
            }
            let saved: *Vector<bool> = Vector::new();
            for let k: i32 = 0; k < gnames.len(); k++ {
                let nm: string = gnames.get(k);
                saved.push(checked.contains(nm) && checked.get(nm));
                checked.insert(nm, true);
            }
            _io_scan(t, s.then_body, opts, checked, root, path);
            for let k: i32 = 0; k < gnames.len(); k++ {
                checked.insert(gnames.get(k), saved.get(k));
            }
            saved.free();
            gnames.free();
        }
        if s.else_body != null {
            _io_scan(t, s.else_body, opts, checked, root, path);
        }
        if s.expr_value != null {
            _io_check_expr(t, s.expr_value, opts, checked);
        }
        if s.let_value != null {
            _io_check_expr(t, s.let_value, opts, checked);
        }
        // After an early-exit guard (`if !r.has { break/return/continue }`,
        // or a `||` chain of them), every subsequent sibling stmt is safe to
        // read the guarded option(s)' `.val`.
        if s.then_body != null && _io_body_is_early_exit(s.then_body) {
            let nms: *Vector<string> = Vector::new();
            _io_collect_orexit_checks(s.cond, nms);
            for let k: i32 = 0; k < nms.len(); k++ {
                checked.insert(nms.get(k), true);
            }
            nms.free();
        }
    }
}

fn _io_extract_check_unsigned(e: *Expr) -> string {
    // Like _io_extract_check but strips the outer `!`.
    if e == null {
        return "";
    }
    if e.kind == EX_UNARY && e.operand != null {
        return _io_extract_check_unsigned(e.operand);
    }
    return _io_extract_check(e);
}

fn _io_is_negated_check(e: *Expr) -> bool {
    if e == null {
        return false;
    }
    if e.kind == EX_UNARY {
        return true;
    }
    return false;
}

fn _io_is_none_check(e: *Expr) -> bool {
    if e == null {
        return false;
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.field != null && e.lhs.field.eq("is_none") {
        return true;
    }
    return false;
}

fn _io_body_is_early_exit(body: *Vector<Stmt>) -> bool {
    if body == null || body.len() == 0 {
        return false;
    }
    let last: Stmt = body.get(body.len() - 1);
    if last.kind == ST_RETURN || last.kind == ST_BREAK || last.kind == ST_CONTINUE {
        return true;
    }
    return false;
}

fn _io_extract_check(e: *Expr) -> string {
    if e == null {
        return "";
    }
    // `x.is_some()` — method form.
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.field != null && e.lhs.field.eq("is_some") && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT {
        return e.lhs.lhs.str_val;
    }
    // `x.has` — direct field access on the option struct (used in
    // tight loops where the method-call overhead matters).
    if e.kind == EX_MEMBER && e.field != null && e.field.eq("has") && e.lhs != null && e.lhs.kind == EX_IDENT {
        return e.lhs.str_val;
    }
    // `!x.is_some()` / `!x.has` — recurse through the unary !.
    if e.kind == EX_UNARY && e.operand != null {
        return _io_extract_check(e.operand);
    }
    return "";
}

// True when `e` is a definitely-present ctor — `some(...)` / `ok(...)`.
// A local initialised or reassigned to one of these is safe to `.val`.
fn _io_rhs_is_present(e: *Expr) -> bool {
    if e == null {
        return false;
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT && e.lhs.str_val != null && (e.lhs.str_val.eq("some") || e.lhs.str_val.eq("ok")) {
        return true;
    }
    return false;
}

// Names made present by an early-exit guard. For `if !a.has || !b.has
// { return }` control only falls through when EVERY disjunct is false, so
// each negated-check receiver (`!x.has` / `!x.is_some()` / `x.is_none()`)
// is guaranteed present afterwards. Also covers the single-check form.
fn _io_collect_orexit_checks(e: *Expr, out: *Vector<string>) {
    if e == null {
        return;
    }
    if e.kind == EX_BINARY && e.op_code == OP_OR {
        _io_collect_orexit_checks(e.lhs, out);
        _io_collect_orexit_checks(e.rhs, out);
        return;
    }
    if e.kind == EX_UNARY && e.operand != null {
        let nm: string = _io_extract_check(e.operand);
        if !nm.eq("") {
            out.push(nm);
        }
        return;
    }
    if _io_is_none_check(e) && e.lhs != null && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT {
        out.push(e.lhs.lhs.str_val);
    }
}

// Names a positive guard proves present in the then-body. `if a.has &&
// b.is_some() { … }` makes both a and b safe inside. Each `&&`-operand
// that is a positive check (`x.has` / `x.is_some()`, not negated/is_none)
// contributes its receiver.
fn _io_collect_and_checks(e: *Expr, out: *Vector<string>) {
    if e == null {
        return;
    }
    if e.kind == EX_BINARY && e.op_code == OP_AND {
        _io_collect_and_checks(e.lhs, out);
        _io_collect_and_checks(e.rhs, out);
        return;
    }
    if _io_is_negated_check(e) || _io_is_none_check(e) {
        return;
    }
    let nm: string = _io_extract_check(e);
    if !nm.eq("") {
        out.push(nm);
    }
}

// Check a condition for unguarded `.val`, honouring `&&` short-circuit:
// in `x.has && x.val`, the left guard protects the right operand, so the
// `.val` there is safe — but a bare `if x.val` still flags.
fn _io_check_cond(t: *Typer, e: *Expr, opts: *HashMap<bool>, checked: *HashMap<bool>) {
    if e == null {
        return;
    }
    if e.kind == EX_BINARY && e.op_code == OP_AND && e.lhs != null && e.rhs != null {
        _io_check_cond(t, e.lhs, opts, checked);
        let g: string = _io_extract_check_unsigned(e.lhs);
        let neg: bool = _io_is_negated_check(e.lhs) || _io_is_none_check(e.lhs);
        if !g.eq("") && !neg {
            let was: bool = checked.contains(g) && checked.get(g);
            checked.insert(g, true);
            _io_check_cond(t, e.rhs, opts, checked);
            checked.insert(g, was);
        } else {
            _io_check_cond(t, e.rhs, opts, checked);
        }
        return;
    }
    _io_check_expr(t, e, opts, checked);
}

fn _io_check_expr(t: *Typer, e: *Expr, opts: *HashMap<bool>, checked: *HashMap<bool>) {
    if e == null {
        return;
    }
    if e.kind == EX_MEMBER && e.field != null && e.field.eq("val") && e.lhs != null && e.lhs.kind == EX_IDENT && opts.contains(e.lhs.str_val) {
        let nm: string = e.lhs.str_val;
        if !(checked.contains(nm) && checked.get(nm)) {
            let mut span: i32 = 1;
            if e.field_col > 0 {
                span = e.field_col - e.column + e.field.len();
            }
            t.warn_range(e.line, e.column, span, "ignored-option", "`".concat(nm).concat(".val` reads the payload without checking `").concat(nm).concat(".is_some()`. Guard with `if ").concat(nm).concat(".is_some() { ... }` or unwrap via `let v = ").concat(nm).concat("?;`."));
        }
    }
    if e.lhs != null {
        _io_check_expr(t, e.lhs, opts, checked);
    }
    if e.rhs != null {
        _io_check_expr(t, e.rhs, opts, checked);
    }
    if e.operand != null {
        _io_check_expr(t, e.operand, opts, checked);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _io_check_expr(t, &a, opts, checked);
        }
    }
}

// ---------- unchecked-result ---------------------------------------------
// The Result counterpart to ignored-option: reading `r.val` on a `!T`
// reaches the success slot regardless of whether the call actually
// succeeded; on the error path it's a zeroed value. Safe shapes:
//   `if r.ok { … r.val … }`   (positive guard, then-body)
//   `if !r.ok { return; } … r.val`   (early-exit guard, rest of body)
//   `let v = r?;`             (consumes the result; v isn't r.val)
// Tracks `!T`-annotated locals only (matches ignored-option), straight-line.
pub fn analysis_unchecked_result(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "unchecked-result") {
            t.current_origin = s.origin;
            let res: *HashMap<bool> = HashMap::new();
            let checked: *HashMap<bool> = HashMap::new();
            _ur_scan(t, s.fn_body, res, checked, program, s.origin);
            res.free();
            checked.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "unchecked-result") {
                    continue;
                }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                let res: *HashMap<bool> = HashMap::new();
                let checked: *HashMap<bool> = HashMap::new();
                _ur_scan(t, m.fn_body, res, checked, program, s.origin);
                res.free();
                checked.free();
            }
        }
    }
}

fn _ur_scan(t: *Typer, body: *Vector<Stmt>, res: *HashMap<bool>, checked: *HashMap<bool>, root: *Vector<Stmt>, path: string) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null {
            // Track `!T` locals, by annotation OR inferred from the value
            // (`let r = mk()` where mk returns `!T`) so the common, unannotated
            // form is covered, not just `let r: !i32 = ...`.
            let mut lty: *Type = s.let_ty;
            if lty == null && s.let_value != null {
                lty = _let_node_type(&s, root, s.line - 1, path, 0);
            }
            if lty != null && (lty.kind == TY_RESULT || lty.kind == TY_OPT_RESULT) {
                res.insert(s.name, true);
                checked.insert(s.name, _io_rhs_is_present(s.let_value));
            }
        }
        if s.kind == ST_EXPR && s.expr_value != null && s.expr_value.kind == EX_ASSIGN && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT && res.contains(s.expr_value.lhs.str_val) {
            checked.insert(s.expr_value.lhs.str_val, _io_rhs_is_present(s.expr_value.rhs));
        }
        if s.cond != null {
            _ur_check_cond(t, s.cond, res, checked);
        }
        if s.then_body != null {
            let gnames: *Vector<string> = Vector::new();
            if s.cond != null {
                _ur_collect_and_checks(s.cond, gnames);
            }
            let saved: *Vector<bool> = Vector::new();
            for let k: i32 = 0; k < gnames.len(); k++ {
                let nm: string = gnames.get(k);
                saved.push(checked.contains(nm) && checked.get(nm));
                checked.insert(nm, true);
            }
            _ur_scan(t, s.then_body, res, checked, root, path);
            for let k: i32 = 0; k < gnames.len(); k++ {
                checked.insert(gnames.get(k), saved.get(k));
            }
            saved.free();
            gnames.free();
        }
        if s.else_body != null {
            _ur_scan(t, s.else_body, res, checked, root, path);
        }
        if s.expr_value != null {
            _ur_check_expr(t, s.expr_value, res, checked);
        }
        if s.let_value != null {
            _ur_check_expr(t, s.let_value, res, checked);
        }
        if s.then_body != null && _io_body_is_early_exit(s.then_body) {
            let nms: *Vector<string> = Vector::new();
            _ur_collect_orexit_checks(s.cond, nms);
            for let k: i32 = 0; k < nms.len(); k++ {
                checked.insert(nms.get(k), true);
            }
            nms.free();
        }
    }
}

// Receiver name of an `r.ok` guard (strips a leading `!`); "" otherwise.
fn _ur_extract_check(e: *Expr) -> string {
    if e == null {
        return "";
    }
    if e.kind == EX_UNARY && e.operand != null {
        return _ur_extract_check(e.operand);
    }
    if e.kind == EX_MEMBER && e.field != null && e.field.eq("ok") && e.lhs != null && e.lhs.kind == EX_IDENT {
        return e.lhs.str_val;
    }
    return "";
}

// Result counterpart of `_io_collect_orexit_checks`: receivers of `!x.ok`
// disjuncts in an early-exit guard are ok afterwards.
fn _ur_collect_orexit_checks(e: *Expr, out: *Vector<string>) {
    if e == null {
        return;
    }
    if e.kind == EX_BINARY && e.op_code == OP_OR {
        _ur_collect_orexit_checks(e.lhs, out);
        _ur_collect_orexit_checks(e.rhs, out);
        return;
    }
    if e.kind == EX_UNARY && e.operand != null {
        let nm: string = _ur_extract_check(e.operand);
        if !nm.eq("") {
            out.push(nm);
        }
    }
}

// Result counterpart of `_io_collect_and_checks`: positive `x.ok` checks in
// an `&&`-chain prove their receivers ok inside the then-body.
fn _ur_collect_and_checks(e: *Expr, out: *Vector<string>) {
    if e == null {
        return;
    }
    if e.kind == EX_BINARY && e.op_code == OP_AND {
        _ur_collect_and_checks(e.lhs, out);
        _ur_collect_and_checks(e.rhs, out);
        return;
    }
    if _io_is_negated_check(e) {
        return;
    }
    let nm: string = _ur_extract_check(e);
    if !nm.eq("") {
        out.push(nm);
    }
}

// Result counterpart of `_io_check_cond`: `r.ok && r.val` is guarded.
fn _ur_check_cond(t: *Typer, e: *Expr, res: *HashMap<bool>, checked: *HashMap<bool>) {
    if e == null {
        return;
    }
    if e.kind == EX_BINARY && e.op_code == OP_AND && e.lhs != null && e.rhs != null {
        _ur_check_cond(t, e.lhs, res, checked);
        let g: string = _ur_extract_check(e.lhs);
        let neg: bool = _io_is_negated_check(e.lhs);
        if !g.eq("") && !neg {
            let was: bool = checked.contains(g) && checked.get(g);
            checked.insert(g, true);
            _ur_check_cond(t, e.rhs, res, checked);
            checked.insert(g, was);
        } else {
            _ur_check_cond(t, e.rhs, res, checked);
        }
        return;
    }
    _ur_check_expr(t, e, res, checked);
}

fn _ur_check_expr(t: *Typer, e: *Expr, res: *HashMap<bool>, checked: *HashMap<bool>) {
    if e == null {
        return;
    }
    if e.kind == EX_MEMBER && e.field != null && e.field.eq("val") && e.lhs != null && e.lhs.kind == EX_IDENT && res.contains(e.lhs.str_val) {
        let nm: string = e.lhs.str_val;
        if !(checked.contains(nm) && checked.get(nm)) {
            let mut span: i32 = 1;
            if e.field_col > 0 {
                span = e.field_col - e.column + e.field.len();
            }
            t.warn_range(e.line, e.column, span, "unchecked-result", "`".concat(nm).concat(".val` reads the value without checking `").concat(nm).concat(".ok`. On the error path it is a zeroed value. Guard with `if ").concat(nm).concat(".ok { ... }`, or unwrap with `let v = ").concat(nm).concat("?;`."));
        }
    }
    if e.lhs != null {
        _ur_check_expr(t, e.lhs, res, checked);
    }
    if e.rhs != null {
        _ur_check_expr(t, e.rhs, res, checked);
    }
    if e.operand != null {
        _ur_check_expr(t, e.operand, res, checked);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _ur_check_expr(t, &a, res, checked);
        }
    }
}

// ---------- use-after-free -----------------------------------------------
// `x.free()` invalidates `x`. Any subsequent use in the same block is a
// dangling-pointer access — exactly the shape of the LSP completion
// crash. `defer x.free()` is fine (fires at scope exit, value is still
// valid throughout the block).
pub fn analysis_use_after_free(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "use-after-free") {
            t.current_origin = s.origin;
            let freed: *HashMap<bool> = HashMap::new();
            _uaf_scan(t, s.fn_body, freed);
            freed.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "use-after-free") {
                    continue;
                }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                let freed: *HashMap<bool> = HashMap::new();
                _uaf_scan(t, m.fn_body, freed);
                freed.free();
            }
        }
    }
}

fn _uaf_scan(t: *Typer, body: *Vector<Stmt>, freed: *HashMap<bool>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        // Defer doesn't mark freed — fires at scope exit only.
        if s.kind == ST_DEFER {
            continue;
        }
        // A return / propagation marks the end of this control-flow
        // path. Any siblings after a return are reached via a different
        // path (else-branch fall-through up the chain) where the freed
        // state shouldn't carry. Clearing avoids the common pattern
        // `if c { x.free(); return; } x.free();` warning on the second
        // free.
        if s.kind == ST_RETURN {
            freed.clear();
            continue;
        }
        // Reassignment clears the freed bit.
        if s.kind == ST_LET && s.name != null && freed.contains(s.name) {
            freed.insert(s.name, false);
        }
        if s.expr_value != null && s.expr_value.kind == EX_ASSIGN && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT && freed.contains(s.expr_value.lhs.str_val) {
            freed.insert(s.expr_value.lhs.str_val, false);
        }
        // The free call itself is allowed even though `x` appears in
        // it. Detect the free target up-front and skip its receiver
        // when we walk the expression.
        let mut free_target: string = "";
        if s.expr_value != null {
            free_target = _uaf_free_target(s.expr_value);
        }
        if s.expr_value != null {
            _uaf_check_expr(t, s.expr_value, freed, free_target);
        }
        if s.let_value != null {
            _uaf_check_expr(t, s.let_value, freed, "");
        }
        if s.cond != null {
            _uaf_check_expr(t, s.cond, freed, "");
        }
        if !free_target.eq("") {
            freed.insert(free_target, true);
        }
        // if/else branches are mutually exclusive paths: a free on the
        // `then` path must NOT poison reads on the `else` path. Scan each
        // branch with its own copy of `freed`, then merge the union of
        // names still freed in EITHER branch back in — so a name freed on
        // any path (without realloc) is still flagged after the if, which
        // keeps real dangling-read detection intact.
        if s.then_body != null || s.else_body != null {
            let then_freed: *HashMap<bool> = _uaf_clone_bool(freed);
            let else_freed: *HashMap<bool> = _uaf_clone_bool(freed);
            if s.then_body != null {
                _uaf_scan(t, s.then_body, then_freed);
            }
            if s.else_body != null {
                _uaf_scan(t, s.else_body, else_freed);
            }
            _uaf_merge_freed(then_freed, freed);
            _uaf_merge_freed(else_freed, freed);
            then_freed.free();
            else_freed.free();
        }
    }
}

fn _uaf_clone_bool(src: *HashMap<bool>) -> *HashMap<bool> {
    let out: *HashMap<bool> = HashMap::new();
    let ks: *Vector<string> = src.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        out.insert(k, src.get(k));
    }
    return out;
}

fn _uaf_merge_freed(src: *HashMap<bool>, dst: *HashMap<bool>) {
    let ks: *Vector<string> = src.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        // Union of TRUE-freed names: if either branch left it freed,
        // it stays freed after the if. A branch that reallocated it
        // (freed=false) does not clear a free recorded by the sibling.
        if src.get(k) {
            dst.insert(k, true);
        }
    }
}

fn _uaf_free_target(e: *Expr) -> string {
    if e == null {
        return "";
    }
    if e.kind != EX_CALL || e.lhs == null || e.lhs.kind != EX_MEMBER {
        return "";
    }
    if e.lhs.field == null || !e.lhs.field.eq("free") {
        return "";
    }
    if e.lhs.lhs == null || e.lhs.lhs.kind != EX_IDENT {
        return "";
    }
    return e.lhs.lhs.str_val;
}

fn _uaf_check_expr(t: *Typer, e: *Expr, freed: *HashMap<bool>, skip: string) {
    if e == null {
        return;
    }
    if e.kind == EX_IDENT && freed.contains(e.str_val) && freed.get(e.str_val) && !e.str_val.eq(skip) {
        t.warn_range(e.line, e.column, _expr_span(e), "use-after-free", "`".concat(e.str_val).concat("` was freed earlier in this scope — accessing it is a dangling-pointer read"));
        return;
    }
    if e.lhs != null {
        _uaf_check_expr(t, e.lhs, freed, skip);
    }
    if e.rhs != null {
        _uaf_check_expr(t, e.rhs, freed, skip);
    }
    if e.operand != null {
        _uaf_check_expr(t, e.operand, freed, skip);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _uaf_check_expr(t, &a, freed, skip);
        }
    }
}

// ---------- mutex-not-unlocked -------------------------------------------
// Every `m.lock()` needs an `m.unlock()` in the same block / fn. The
// check is balance-based (count locks vs unlocks per name); deeper
// control-flow checking would require building a CFG, but unbalanced
// counts already catch the common shapes.
pub fn analysis_mutex_unbalanced(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "mutex-unbalanced") {
            t.current_origin = s.origin;
            _mu_check_fn(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "mutex-unbalanced") {
                    continue;
                }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                _mu_check_fn(t, m.fn_body);
            }
        }
    }
}

fn _mu_check_fn(t: *Typer, body: *Vector<Stmt>) {
    // Path-aware: walk stmts in order with `held` = the set of names
    // currently locked. Every exit path (return / ?-propagation /
    // break / continue / fall-off-the-end) must clear `held`. We
    // detect `?` operators inside expressions because each is a
    // potential early return.
    let held: *HashMap<i32> = HashMap::new(); // name -> line of lock
    let held_col: *HashMap<i32> = HashMap::new();
    let warned: *HashMap<bool> = HashMap::new();
    _mu_walk_path(t, body, held, held_col, warned);
    // Names still held at fall-through end of fn are bugs too.
    let names: *Vector<string> = held.keys();
    for let i: i32 = 0; i < names.len(); i++ {
        let nm: string = names.get(i);
        if warned.contains(nm) {
            continue;
        }
        t.warn_range(held.get(nm), held_col.get(nm), nm.len(), "mutex-unbalanced", "`".concat(nm).concat(".lock()` falls off the end of the fn without `.unlock()` — release it on every exit (a `defer ").concat(nm).concat(".unlock();` right after the lock covers all returns)"));
        warned.insert(nm, true);
    }
    held.free();
    held_col.free();
    warned.free();
}

fn _mu_walk_path(t: *Typer, body: *Vector<Stmt>, held: *HashMap<i32>, held_col: *HashMap<i32>, warned: *HashMap<bool>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.expr_value != null && _ler_expr_has_try(s.expr_value) {
            _mu_flag_held(t, held, held_col, warned, s.line, "?-propagation");
        }
        if s.let_value != null && _ler_expr_has_try(s.let_value) {
            _mu_flag_held(t, held, held_col, warned, s.line, "?-propagation");
        }
        if s.expr_value != null {
            _mu_update_state(s.expr_value, held, held_col);
        }
        if s.let_value != null {
            _mu_update_state(s.let_value, held, held_col);
        }
        if s.kind == ST_RETURN || s.kind == ST_BREAK || s.kind == ST_CONTINUE {
            let exit_label: string = "return";
            if s.kind == ST_BREAK {
                exit_label = "break";
            }
            if s.kind == ST_CONTINUE {
                exit_label = "continue";
            }
            _mu_flag_held(t, held, held_col, warned, s.line, exit_label);
            return;
        }
        if s.kind == ST_DEFER && s.expr_value != null {
            let nm: string = _mu_unlock_target(s.expr_value);
            if !nm.eq("") && held.contains(nm) {
                held.remove(nm);
                held_col.remove(nm);
            }
        }
        // For if/else, walk each branch with its own copy of the
        // held state so a lock acquired only in one branch doesn't
        // leak into the other. After both branches, merge: a name
        // is "held after" iff held in EITHER branch (worst case for
        // leak detection — drives a warning if any path leaves it
        // held at a later exit).
        if s.then_body != null || s.else_body != null {
            let snap: *HashMap<i32> = _mu_clone_int(held);
            let snap_col: *HashMap<i32> = _mu_clone_int(held_col);
            let then_held: *HashMap<i32> = _mu_clone_int(held);
            let then_col: *HashMap<i32> = _mu_clone_int(held_col);
            if s.then_body != null {
                _mu_walk_path(t, s.then_body, then_held, then_col, warned);
            }
            let else_held: *HashMap<i32> = _mu_clone_int(snap);
            let else_col: *HashMap<i32> = _mu_clone_int(snap_col);
            if s.else_body != null {
                _mu_walk_path(t, s.else_body, else_held, else_col, warned);
            }
            // Merge: union of both branches' remaining held names.
            held.clear();
            held_col.clear();
            _mu_merge_into(then_held, then_col, held, held_col);
            _mu_merge_into(else_held, else_col, held, held_col);
            then_held.free();
            then_col.free();
            else_held.free();
            else_col.free();
            snap.free();
            snap_col.free();
        }
        // match arm bodies live in s.arms[].body, not then/else_body. Walk
        // each arm with its own clone of the held set and merge the union,
        // so an unlock() inside an arm is seen (no false "never released"),
        // while an arm that forgets to unlock still leaves the name held.
        if s.kind == ST_MATCH && s.arms != null {
            let m_snap: *HashMap<i32> = _mu_clone_int(held);
            let m_snap_col: *HashMap<i32> = _mu_clone_int(held_col);
            let m_acc: *HashMap<i32> = HashMap::new();
            let m_acc_col: *HashMap<i32> = HashMap::new();
            for let j: i32 = 0; j < s.arms.len(); j++ {
                let arm: MatchArm = s.arms.get(j);
                if arm.body == null {
                    continue;
                }
                let a_held: *HashMap<i32> = _mu_clone_int(m_snap);
                let a_col: *HashMap<i32> = _mu_clone_int(m_snap_col);
                _mu_walk_path(t, arm.body, a_held, a_col, warned);
                _mu_merge_into(a_held, a_col, m_acc, m_acc_col);
                a_held.free();
                a_col.free();
            }
            held.clear();
            held_col.clear();
            _mu_merge_into(m_acc, m_acc_col, held, held_col);
            m_acc.free();
            m_acc_col.free();
            m_snap.free();
            m_snap_col.free();
        }
    }
}

fn _mu_clone_int(src: *HashMap<i32>) -> *HashMap<i32> {
    let out: *HashMap<i32> = HashMap::new();
    let ks: *Vector<string> = src.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        out.insert(k, src.get(k));
    }
    return out;
}

fn _mu_merge_into(src: *HashMap<i32>, src_col: *HashMap<i32>, dst: *HashMap<i32>, dst_col: *HashMap<i32>) {
    let ks: *Vector<string> = src.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if !dst.contains(k) {
            dst.insert(k, src.get(k));
            if src_col.contains(k) {
                dst_col.insert(k, src_col.get(k));
            }
        }
    }
}

fn _mu_flag_held(t: *Typer, held: *HashMap<i32>, held_col: *HashMap<i32>, warned: *HashMap<bool>, exit_line: i32, exit_kind: string) {
    let names: *Vector<string> = held.keys();
    for let i: i32 = 0; i < names.len(); i++ {
        let nm: string = names.get(i);
        if warned.contains(nm) {
            continue;
        }
        t.warn_range(held.get(nm), held_col.get(nm), nm.len(), "mutex-unbalanced", "`".concat(nm).concat(".lock()` is still held at the ").concat(exit_kind).concat(" — wrap it with `defer ").concat(nm).concat(".unlock();` so every exit path releases the lock"));
        warned.insert(nm, true);
    }
}

fn _mu_update_state(e: *Expr, held: *HashMap<i32>, held_col: *HashMap<i32>) {
    if e == null {
        return;
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.field != null && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT {
        let recv: string = e.lhs.lhs.str_val;
        if e.lhs.field.eq("lock") && !held.contains(recv) {
            held.insert(recv, e.line);
            held_col.insert(recv, e.column);
        }
        if e.lhs.field.eq("unlock") && held.contains(recv) {
            held.remove(recv);
            held_col.remove(recv);
        }
    }
    if e.lhs != null {
        _mu_update_state(e.lhs, held, held_col);
    }
    if e.rhs != null {
        _mu_update_state(e.rhs, held, held_col);
    }
    if e.operand != null {
        _mu_update_state(e.operand, held, held_col);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _mu_update_state(&a, held, held_col);
        }
    }
}

fn _mu_unlock_target(e: *Expr) -> string {
    if e == null {
        return "";
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.field != null && e.lhs.field.eq("unlock") && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT {
        return e.lhs.lhs.str_val;
    }
    return "";
}

// ---------- chan-leak ----------------------------------------------------
// A chan with receivers in a `while let v = c.recv()` (or similar)
// needs SOMEONE to call `c.close()` — otherwise the receivers block
// forever and the program never terminates. We approximate by
// flagging any chan declared in a fn that has no `close()` anywhere
// in that fn.
pub fn analysis_chan_leak(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "chan-leak") {
            t.current_origin = s.origin;
            _cl_check_fn(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "chan-leak") {
                    continue;
                }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                _cl_check_fn(t, m.fn_body);
            }
        }
    }
}

fn _cl_check_fn(t: *Typer, body: *Vector<Stmt>) {
    // Two-step: collect every chan; then walk paths reporting at
    // every exit point that leaves the chan open. An exit is
    // return/break/continue at any depth, OR fall-off-the-end of
    // the top-level body.
    let chans: *HashMap<i32> = HashMap::new();
    let chans_col: *HashMap<i32> = HashMap::new();
    _cl_collect_chans(body, chans, chans_col);
    let names: *Vector<string> = chans.keys();
    for let i: i32 = 0; i < names.len(); i++ {
        let nm: string = names.get(i);
        let mut warned: bool = false;
        let r: i32 = _cl_walk(t, body, nm, false, chans.get(nm), chans_col.get(nm), &warned);
        // r encodes: 0 = falls through with closed=false (top-level
        // leak), 1 = closed at end, 2 = always exits before fall-through
        if r == 0 && !warned {
            t.warn_range(chans.get(nm), chans_col.get(nm), nm.len(), "chan-leak", "channel `".concat(nm).concat("` reaches the end of the fn without `close()` on the fall-through path — every exit must close before receivers can stop waiting"));
        }
    }
    chans.free();
    chans_col.free();
}

fn _cl_collect_chans(body: *Vector<Stmt>, chans: *HashMap<i32>, chans_col: *HashMap<i32>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null && s.let_ty != null && s.let_ty.kind == TY_GENERIC && s.let_ty.name.eq("chan") {
            chans.insert(s.name, s.line);
            chans_col.insert(s.name, s.column);
        }
        if s.then_body != null {
            _cl_collect_chans(s.then_body, chans, chans_col);
        }
        if s.else_body != null {
            _cl_collect_chans(s.else_body, chans, chans_col);
        }
    }
}

// Walk `body`. Side-effect: warns once (via `*warned`) at the first
// return/break/continue where chan `nm` is still open. Return value:
//   0 = body falls through with closed=false
//   1 = body falls through with closed=true
//   2 = body never falls through (every path returned/break'd)
// The caller composes these for if/else merging.
fn _cl_walk(t: *Typer, body: *Vector<Stmt>, nm: string, closed_in: bool, chan_line: i32, chan_col: i32, warned: *bool) -> i32 {
    let mut closed: bool = closed_in;
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.expr_value != null && _cl_expr_closes(s.expr_value, nm) {
            closed = true;
        }
        if s.let_value != null && _cl_expr_closes(s.let_value, nm) {
            closed = true;
        }
        if s.kind == ST_RETURN || s.kind == ST_BREAK || s.kind == ST_CONTINUE {
            if !closed && !*warned {
                let exit_label: string = "return";
                if s.kind == ST_BREAK {
                    exit_label = "break";
                }
                if s.kind == ST_CONTINUE {
                    exit_label = "continue";
                }
                t.warn_range(chan_line, chan_col, nm.len(), "chan-leak", "channel `".concat(nm).concat("` is still open at this ").concat(exit_label).concat(" — `close()` it before exiting so receivers can stop"));
                *warned = true;
            }
            return 2;
        }
        if s.kind == ST_IF {
            let mut fall_state: i32 = 0;
            if closed {
                fall_state = 1;
            }
            let mut then_r: i32 = fall_state;
            if s.then_body != null {
                then_r = _cl_walk(t, s.then_body, nm, closed, chan_line, chan_col, warned);
            }
            let mut else_r: i32 = fall_state;
            if s.else_body != null {
                else_r = _cl_walk(t, s.else_body, nm, closed, chan_line, chan_col, warned);
            }
            // Merge: if both never fall through, outer doesn't either.
            // Otherwise take the AND of fall-through closed states
            // (a branch that exited contributes nothing to the merge).
            if then_r == 2 && else_r == 2 {
                return 2;
            }
            let mut new_closed: bool = true;
            let mut any_fall: bool = false;
            if then_r != 2 {
                any_fall = true;
                if then_r == 0 {
                    new_closed = false;
                }
            }
            if else_r != 2 {
                any_fall = true;
                if else_r == 0 {
                    new_closed = false;
                }
            }
            if !any_fall {
                return 2;
            }
            closed = new_closed;
        }
    }
    if closed {
        return 1;
    }
    return 0;
}

fn _cl_expr_closes(e: *Expr, nm: string) -> bool {
    if e == null {
        return false;
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.field != null && e.lhs.field.eq("close") && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT && e.lhs.lhs.str_val.eq(nm) {
        return true;
    }
    if e.lhs != null && _cl_expr_closes(e.lhs, nm) {
        return true;
    }
    if e.rhs != null && _cl_expr_closes(e.rhs, nm) {
        return true;
    }
    if e.operand != null && _cl_expr_closes(e.operand, nm) {
        return true;
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if _cl_expr_closes(&a, nm) {
                return true;
            }
        }
    }
    return false;
}

// ---------- leak-on-early-return -----------------------------------------
// `let x = make(); … x?; defer x.free();` — the `?` propagation fires
// before the defer registers, leaking x on the error path. The fix is
// to register the defer *immediately* after the binding.
pub fn analysis_leak_on_early_return(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "leak-on-early-return") {
            t.current_origin = s.origin;
            _ler_check_fn(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "leak-on-early-return") {
                    continue;
                }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                _ler_check_fn(t, m.fn_body);
            }
        }
    }
}

fn _ler_check_fn(t: *Typer, body: *Vector<Stmt>) {
    // First pass: find every defer x.free() and remember the stmt index.
    let defer_idx: *HashMap<i32> = HashMap::new(); // name -> idx of defer
    let alloc_idx: *HashMap<i32> = HashMap::new(); // name -> idx of let
    let alloc_line: *HashMap<i32> = HashMap::new(); // name -> source line of defer
    let alloc_col: *HashMap<i32> = HashMap::new();
    let returning: *Vector<i32> = Vector::new(); // idx of ?/return stmts
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null && s.let_value != null && _ler_is_allocating_call(s.let_value) {
            alloc_idx.insert(s.name, i);
        }
        if s.kind == ST_DEFER && s.expr_value != null {
            // Three shapes count as "this defer releases x":
            //   defer x.free()              — method call
            //   defer free(x as *void)      — raw free of a pointer
            //   defer __glide_palloc_free(x)
            let nm: string = _ler_defer_target(s.expr_value);
            if !nm.eq("") {
                defer_idx.insert(nm, i);
                alloc_line.insert(nm, s.line);
                alloc_col.insert(nm, s.column);
            }
        }
        if _ler_has_early_exit(&s) {
            returning.push(i);
        }
    }
    let names: *Vector<string> = defer_idx.keys();
    for let i: i32 = 0; i < names.len(); i++ {
        let nm: string = names.get(i);
        if !alloc_idx.contains(nm) {
            continue;
        }
        let a: i32 = alloc_idx.get(nm);
        let d: i32 = defer_idx.get(nm);
        if d <= a + 1 {
            continue;
        } // defer placed right after alloc — safe
        for let k: i32 = 0; k < returning.len(); k++ {
            let r: i32 = returning.get(k);
            if r > a && r < d {
                // If `nm` is freed inline (not via defer) on a top-level
                // statement before the early exit, that exit path already
                // releases it — no leak. Covers free-then-rebind and
                // explicit free-before-`?` patterns.
                if _ler_freed_inline_before(body, nm, a, r) {
                    continue;
                }
                t.warn_range(alloc_line.get(nm), alloc_col.get(nm), nm.len(), "leak-on-early-return", "`defer ".concat(nm).concat(".free()` is registered after an early exit on line — move it right after `let ").concat(nm).concat(" = …;` so the cleanup also fires on the error path"));
                break;
            }
        }
    }
    defer_idx.free();
    alloc_idx.free();
    alloc_line.free();
    alloc_col.free();
}

// True when `nm` is released by an inline free (a plain expression
// statement, NOT a `defer`) at some top-level index strictly between the
// alloc at `a` and the early exit at `r`. Such a free already covers the
// early-exit path, so the deferred free is not a leak there.
fn _ler_freed_inline_before(body: *Vector<Stmt>, nm: string, a: i32, r: i32) -> bool {
    for let k: i32 = a + 1; k < r; k++ {
        let s: Stmt = body.get(k);
        if s.kind == ST_DEFER {
            continue;
        }
        if s.expr_value != null && _ler_defer_target(s.expr_value).eq(nm) {
            return true;
        }
    }
    return false;
}

fn _ler_defer_target(e: *Expr) -> string {
    if e == null {
        return "";
    }
    // x.free()
    let mc: string = _uaf_free_target(e);
    if !mc.eq("") {
        return mc;
    }
    // free(x as *void) / __glide_palloc_free(x)
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT && (e.lhs.str_val.eq("free") || e.lhs.str_val.eq("__glide_palloc_free")) && e.args != null && e.args.len() == 1 {
        let arg: Expr = e.args.get(0);
        let mut probe: *Expr = &arg;
        while probe != null && probe.kind == EX_CAST {
            probe = probe.lhs;
        }
        if probe != null && probe.kind == EX_IDENT {
            return probe.str_val;
        }
    }
    return "";
}

fn _ler_is_allocating_call(e: *Expr) -> bool {
    if e == null {
        return false;
    }
    // Peel cast wrappers: `malloc(n) as *T`, common at every alloc site.
    let mut p: *Expr = e;
    while p != null && p.kind == EX_CAST {
        p = p.lhs;
    }
    if p == null {
        return false;
    }
    if p.kind == EX_CALL && p.lhs != null && p.lhs.kind == EX_IDENT {
        let n: string = p.lhs.str_val;
        if n.eq("malloc") || n.eq("__glide_palloc_make") {
            return true;
        }
    }
    if p.kind == EX_CALL && p.lhs != null && p.lhs.kind == EX_MEMBER && p.lhs.field != null && p.lhs.field.eq("new") {
        return true;
    }
    return false;
}

fn _ler_has_early_exit(s: *Stmt) -> bool {
    if s == null {
        return false;
    }
    if s.kind == ST_RETURN {
        return true;
    }
    if s.expr_value != null && _ler_expr_has_try(s.expr_value) {
        return true;
    }
    if s.let_value != null && _ler_expr_has_try(s.let_value) {
        return true;
    }
    return false;
}

fn _ler_expr_has_try(e: *Expr) -> bool {
    if e == null {
        return false;
    }
    if e.kind == EX_UNARY && e.op_code == UN_TRY {
        return true;
    }
    if e.lhs != null && _ler_expr_has_try(e.lhs) {
        return true;
    }
    if e.rhs != null && _ler_expr_has_try(e.rhs) {
        return true;
    }
    if e.operand != null && _ler_expr_has_try(e.operand) {
        return true;
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if _ler_expr_has_try(&a) {
                return true;
            }
        }
    }
    return false;
}
