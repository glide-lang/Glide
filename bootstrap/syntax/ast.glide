// `impl <trait_name> for <target> { methods... }`. Used by proc-derive
// macros — the parser sets `impl_trait_name` on a regular stmt_impl,
// but macro emitters need a single-call constructor since the
// interpreter has no field setters.
pub fn stmt_impl_trait(target: *Type, trait_name: string, methods: *Vector<Stmt>, line: i32, col: i32) -> *Stmt {
    let s: *Stmt = stmt_impl(target, methods, line, col);
    s.impl_trait_name = trait_name;
    return s;
}

