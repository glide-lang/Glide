    let e: *Expr = __glide_palloc(sizeof(Expr)) as *Expr;
    e.kind = EX_IDENT;
    e.line = line;
    e.column = col;
    e.str_val = name;
    return e;
}

pub fn expr_bool(b: bool, line: i32, col: i32) -> *Expr {
    let e: *Expr = __glide_palloc(sizeof(Expr)) as *Expr;
    e.kind = EX_BOOL;
    e.line = line;
    e.column = col;
    e.bool_val = b;
    return e;
}

pub fn expr_binary(op: i32, lhs: *Expr, rhs: *Expr) -> *Expr {
    let e: *Expr = __glide_palloc(sizeof(Expr)) as *Expr;
    e.kind = EX_BINARY;
    e.line = lhs.line;
    e.column = lhs.column;
    e.op_code = op;
    e.lhs = lhs;
    e.rhs = rhs;
    e.lead = "";
    return e;
}

pub fn expr_call(callee: *Expr, args: *Vector<Expr>) -> *Expr {
    let e: *Expr = __glide_palloc(sizeof(Expr)) as *Expr;
    e.kind = EX_CALL;
    e.line = callee.line;
    e.column = callee.column;
    e.lhs = callee;
    e.args = args;
    return e;
}

pub fn stmt_let(name: string, ty: *Type, value: *Expr, is_mut: bool, line: i32, col: i32) -> *Stmt {
    let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
    s.kind = ST_LET;
    s.line = line;
    s.column = col;
    s.name = name;
    s.let_ty = ty;
    s.let_value = value;
    s.is_mut = is_mut;
    return s;
}

// ---- shared formatting helpers ------------------------------------------
// Live in ast so any module that depends on the AST (parser, expander,
// typer, codegen) can format integer literals into source-strings without
// pulling in codegen.glide.
// Strip the lexer's \x02 ///-marker prefixes from a doc block for DISPLAY
// (hover, completion, glide doc). fmt is the only consumer that keeps them.
pub fn doc_clean(raw: string) -> string {
    if raw == null || raw.eq("") { return raw; }
    let mut out: string = "";
    let n: i32 = raw.len();
    let mut i: i32 = 0;
    let mut at_line_start: bool = true;
    while i < n {
        let c: i32 = raw.at(i).to_int();
        if at_line_start && c == 2 {
            i = i + 1;
            at_line_start = false;
            continue;
        }
        out = out.concat(raw.substring(i, i + 1));
        at_line_start = c == 10;
        i = i + 1;
    }
    return out;
}

pub fn int_to_str(n: i64) -> string {
    if n == 0 { return "0"; }
    let mut x: i64 = n;
    let mut neg: bool = false;
    if x < 0 {
        neg = true;
        x = -x;
    }
    let mut s: string = "";
    while x > 0 {
        let d: i32 = (x % 10) as i32;
        let ch: string = digit_str(d);
        s = ch.concat(s);
        x = x / 10;
    }
    if neg { s = "-".concat(s); }
    return s;
}

pub fn digit_str(d: i32) -> string {
    if d == 0 { return "0"; }
    if d == 1 { return "1"; }
    if d == 2 { return "2"; }
    if d == 3 { return "3"; }
    if d == 4 { return "4"; }
    if d == 5 { return "5"; }
    if d == 6 { return "6"; }
    if d == 7 { return "7"; }
    if d == 8 { return "8"; }
    return "9";
}

// True if `s` is a non-empty run of ASCII digits. Used to recognise a
// tuple-index member (`t.0`, `t.12`) where the field name is numeric.
pub fn tuple_field_is_index(s: string) -> bool {
    if s == null { return false; }
    let n: i32 = s.len();
    if n == 0 { return false; }
    for let i: i32 = 0; i < n; i++ {
        let c: i32 = s.at(i).to_int();
        if c < 48 || c > 57 { return false; }
    }
    return true;
}

// Parse an all-digit tuple-index string into its i32 value. Assumes the
// caller already validated with `tuple_field_is_index`.
pub fn tuple_index_value(s: string) -> i32 {
    let mut v: i32 = 0;
    let n: i32 = s.len();
    for let i: i32 = 0; i < n; i++ {
        v = v * 10 + (s.at(i).to_int() - 48);
    }
    return v;
}

// Strip pointer / borrow wrappers from a type. Used by the typer +
// codegen + LSP whenever they need the bare element type.
pub fn strip_ptr(t: *Type) -> *Type {
    if t == null { return null; }
    if t.kind == TY_POINTER || t.kind == TY_BORROW || t.kind == TY_BORROW_MUT {
        return strip_ptr(t.inner);
    }
    return t;
}

pub fn stmt_return(v: *Expr, line: i32, col: i32) -> *Stmt {
    let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
    s.kind = ST_RETURN;
    s.line = line;
    s.column = col;
    s.expr_value = v;
    return s;
}

pub fn stmt_expr(e: *Expr) -> *Stmt {
    let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
    s.kind = ST_EXPR;
    if e != null {
        s.line = e.line;
        s.column = e.column;
    }
    s.expr_value = e;
    return s;
}

pub fn stmt_fn(name: string, params: *Vector<Param>, ret_ty: *Type, body: *Vector<Stmt>, line: i32, col: i32) -> *Stmt {
