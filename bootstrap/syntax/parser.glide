// Parser — tokens to AST. Recursive descent for statements and top-level
// declarations, Pratt parsing for expressions (precedence climbing keeps
// operator handling table-driven).
//
// Output shape: `(stmts: *Vector<Stmt>, diagnostics: *Vector<ParseDiag>)`.
// Diagnostics are accumulated rather than fatal; the parser keeps going so
// the LSP and `glide check` can show multiple errors at once.
//
// Lookahead is one token most of the time, two or three for ambiguous heads
// (`fn(...) -> T` as expression vs as type, struct-literal vs block, etc).
// Unknown stmts get a synth `ST_ERROR` so later passes still receive a
// well-formed tree.
import stdlib::hashmap::*;
import bootstrap::syntax::lexer::*;
import bootstrap::syntax::ast::*;

// Runtime IO helper used while resolving qualified imports. Declared
// here so 'glide check bootstrap/parser.glide' resolves it standalone;
// the symbol itself is provided by the codegen runtime prelude.
extern fn read_file(path: string) -> string;

pub struct ParseDiag {
    pub origin: string,
    pub line: i32,
    pub col: i32,
    pub msg: string,
    // Diagnostic code (empty -> defaults to "parse" in merge_parse_diags) and
    // the underline width (0 -> 1). Optional mechanical fix: splice
    // `fix_replacement` over (fix_line,fix_col)..(fix_end_line,fix_end_col).
    pub code: string,
    pub span: i32,
    pub fix_line: i32,
    pub fix_col: i32,
    pub fix_end_line: i32,
    pub fix_end_col: i32,
    pub fix_replacement: string,
}

pub struct Parser {
    pub lex: *Lexer,
    pub current: Token,
    pub peek: Token,
    pub error_count: i32,
    pub no_struct_lit: bool,
    // When set, skip parse-time `Self`-substitution in impl bodies so `fmt`
    // can reproduce `Self` as written instead of the concrete target type.
    pub fmt_mode: bool,
    pub diags: *Vector<ParseDiag>,
    // Position of the most recently consumed token (advanced past). Used to
    // anchor "expected ';'" errors at the END of the previous token rather
    // than the start of the next stmt — much friendlier IDE underlines.
    pub prev_line: i32,
    pub prev_col: i32,
    pub prev_len: i32,
    // When set, parse only declaration HEADERS: function / method bodies are
    // brace-skipped instead of parsed into an AST. Used by the LSP to load
    // imported files as signatures only (no body allocation). Macro defs and
    // proc-macro fns keep their bodies (the expander needs them).
    pub header_only: bool,
    // Per-fn latch set by the caller (which holds the attrs) right before
    // parse_fn, telling it to brace-skip this body. Reset inside parse_fn.
    pub skip_fn_body: bool,
}

impl Parser {
    pub fn new(lex: *Lexer) -> *Parser {
        let p: *Parser = __glide_palloc(sizeof(Parser)) as *Parser;
        p.lex = lex;
        p.current = lex.next_token();
        p.peek = lex.next_token();
        p.error_count = 0;
        p.no_struct_lit = false;
        p.fmt_mode = false;
        p.header_only = false;
        p.skip_fn_body = false;
        let dv: *Vector<ParseDiag> = Vector::new();
        p.diags = dv;
        return p;
    }

    pub fn free(self: *Parser) {
        if self.diags != null {
            self.diags.free();
        }
        __glide_pfree(self as *void);
    }

    fn advance(self: *Parser) -> Token {
        let prev: Token = self.current;
        self.prev_line = prev.line;
        self.prev_col = prev.column;
        self.prev_len = prev.lexeme.len();
        self.current = self.peek;
        self.peek = self.lex.next_token();
        return prev;
    }

    fn at_eof(self: *Parser) -> bool {
        return self.current.kind == TOK_EOF;
    }

    fn at_kw(self: *Parser, lexeme: string) -> bool {
        if self.current.kind != TOK_KEYWORD {
            return false;
        }
        return self.current.lexeme.eq(lexeme);
    }

    fn at_op(self: *Parser, lexeme: string) -> bool {
        if self.current.kind != TOK_OP {
            return false;
        }
        return self.current.lexeme.eq(lexeme);
    }

    fn peek_op(self: *Parser, lexeme: string) -> bool {
        if self.peek.kind != TOK_OP {
            return false;
        }
        return self.peek.lexeme.eq(lexeme);
    }

    fn eat_kw(self: *Parser, lexeme: string) -> bool {
        if self.at_kw(lexeme) {
            self.advance();
            return true;
        }
        return false;
    }

    fn eat_op(self: *Parser, lexeme: string) -> bool {
        if self.at_op(lexeme) {
            self.advance();
            return true;
        }
        return false;
    }

    // Lowest-level diagnostic push: full control over code, span, and an
    // optional mechanical fix (zero-width range + replacement = insertion).
    fn push_pdiag(self: *Parser, line: i32, col: i32, span: i32, code: string, msg: string, fl: i32, fc: i32, fel: i32, fec: i32, repl: string) {
        let d: ParseDiag = ParseDiag { origin: "", line: line, col: col, msg: msg, code: code, span: span, fix_line: fl, fix_col: fc, fix_end_line: fel, fix_end_col: fec, fix_replacement: repl };
        self.diags.push(d);
        self.error_count = self.error_count + 1;
    }

    fn err(self: *Parser, msg: string) {
        self.err_code("parse", msg);
    }

    // Like `err` but with an explicit diagnostic code. The underline spans the
    // offending token so editors highlight the whole token, not one char.
    fn err_code(self: *Parser, code: string, msg: string) {
        let full: string = msg.concat(" near '").concat(self.current.lexeme).concat("'");
        let mut span: i32 = self.current.lexeme.len();
        if span < 1 {
            span = 1;
        }
        self.push_pdiag(self.current.line, self.current.column, span, code, full, 0, 0, 0, 0, "");
    }

    // Same as `err` but anchors at the end of the most-recently-consumed
    // token. Used for "expected ';'" so the underline lands at the end of
    // the prior stmt instead of the start of the next one.
    fn err_after_prev(self: *Parser, msg: string) {
        let full: string = msg.concat(" near '").concat(self.current.lexeme).concat("'");
        let mut line: i32 = self.prev_line;
        let mut col: i32 = self.prev_col + self.prev_len;
        if line == 0 {
            line = self.current.line;
            col = self.current.column;
        }
        self.push_pdiag(line, col, 1, "parse", full, 0, 0, 0, 0, "");
    }

    fn expect_op(self: *Parser, lexeme: string) -> bool {
        if self.at_op(lexeme) {
            self.advance();
            return true;
        }
        if lexeme.eq(";") {
            // Insert the missing `;` at the end of the previous token. Carries a
            // quick fix so `glide fix` / the editor can splice it in one click.
            let mut line: i32 = self.prev_line;
            let mut col: i32 = self.prev_col + self.prev_len;
            if line == 0 {
                line = self.current.line;
                col = self.current.column;
            }
            let full: string = "expected ';'".concat(" near '").concat(self.current.lexeme).concat("'");
            self.push_pdiag(line, col, 1, "expected-semicolon", full, line, col, line, col, ";");
        } else {
            self.err_code("expected-token", "expected '".concat(lexeme).concat("'"));
        }
        return false;
    }

    // True at either `>` or the start of a `>>` token. Handles the nested-
    // generics case (`Vector<Foo<T>>`) where the lexer hands back `>>` as
    // a single shift-right token.
    fn at_close_angle(self: *Parser) -> bool {
        if self.current.kind != TOK_OP {
            return false;
        }
        return self.current.lexeme.eq(">") || self.current.lexeme.eq(">>");
    }

    // Consume a single closing `>`. If the current token is `>>`, splits it
    // so the outer generic still sees the second `>`.
    fn consume_close_angle(self: *Parser) -> bool {
        if self.at_op(">") {
            self.advance();
            return true;
        }
        if self.at_op(">>") {
            self.current.lexeme = ">";
            self.current.column = self.current.column + 1;
            return true;
        }
        self.err("expected '>'");
        return false;
    }

    fn expect_ident(self: *Parser) -> string {
        if self.current.kind == TOK_IDENT || self.current.kind == TOK_KEYWORD {
            let name: string = self.current.lexeme;
            self.advance();
            return name;
        }
        self.err("expected identifier");
        return "";
    }

    // Binder-position identifier (`let` names, params, tuple-destructure
    // slots): keywords are rejected here. `expect_ident` stays lenient for
    // expression/path positions, but accepting `let volatile = 1` created a
    // binding that either emitted invalid C (`int32_t volatile = 1;`) or —
    // for `let true` — could never be read back (the use site resolves to
    // the literal). The keyword token is consumed so parsing recovers at
    // the `:`/`=` that follows instead of cascading.
    fn expect_binder_ident(self: *Parser) -> string {
        if self.current.kind == TOK_KEYWORD {
            let mut span: i32 = self.current.lexeme.len();
            if span < 1 {
                span = 1;
            }
            self.push_pdiag(self.current.line, self.current.column, span, "reserved-word", "`".concat(self.current.lexeme).concat("` is a reserved word, not a binding name"), 0, 0, 0, 0, "");
            self.advance();
            return "";
        }
        return self.expect_ident();
    }
}

// ---- top-level ------------------------------------------------------------
pub fn parse_program(p: *Parser) -> *Vector<Stmt> {
    let stmts: *Vector<Stmt> = Vector::new();
    while !p.at_eof() {
        // Doc comment travels on the token (the lexer LL(2) pre-load means
        // `lex.pending_doc` belongs to `peek`, not `current`, by the time
        // the parser looks at it).
        let doc: string = p.current.doc;
        let lead: string = p.current.lead;
        let s: *Stmt = parse_top_stmt(p);
        if s == null {
            p.advance();
            continue;
        }
        s.doc_comment = doc;
        s.leading_comments = lead;
        // After the decl, `current` is the next token; a comment on the same
        // line as the decl's end rode along as that token's `trail`.
        s.trailing_comment = p.current.trail;
        stmts.push(*s);
    }
    // Trailing comments at end of file (the EOF token's lead).
    if p.fmt_mode && p.current.lead != null && !p.current.lead.eq("") {
        stmts.push(*stmt_comment(p.current.lead));
    }
    return stmts;
}

pub fn parse_top_stmt(p: *Parser) -> *Stmt {
    // Collect a sequence of `@<name>(args)` (or `@<name>`) attributes.
    // `@cfg("windows")` / `@cfg("posix")` is recognised inline (sets
    // `cfg_target` directly so the existing #ifdef guard logic works
    // unchanged); every other attribute lands in `attrs` for the
    // expander to interpret.
    let mut cfg: string = "";
    let mut cfg_line: i32 = 0;
    let mut cfg_col: i32 = 0;
    let attrs_collected: *Vector<Attr> = Vector::new();
    while p.at_op("@") {
        let at_line: i32 = p.current.line;
        let at_col: i32 = p.current.column;
        p.advance();
        let attr_name: string = p.expect_ident();
        let arg_exprs: *Vector<Expr> = Vector::new();
        if p.eat_op("(") {
            while !p.at_op(")") && !p.at_eof() {
                let e: *Expr = parse_expr(p, 0);
                if e != null {
                    arg_exprs.push(*e);
                }
                if !p.eat_op(",") {
                    break;
                }
            }
            p.expect_op(")");
        }
        if attr_name.eq("cfg") {
            // Special-case: keep cfg as a string field for codegen's #ifdef
            // emission. Expects exactly one string-literal arg.
            cfg_line = at_line;
            cfg_col = at_col;
            if arg_exprs.len() == 1 {
                let a0: Expr = arg_exprs.get(0);
                if a0.kind == EX_STRING {
                    cfg = a0.str_val;
                } else {
                    p.err("@cfg expects a string literal: \"windows\" or \"posix\"");
                }
            } else {
                p.err("@cfg expects exactly one argument");
            }
            if !cfg.eq("windows") && !cfg.eq("posix") {
                p.err("unknown cfg target — expected `windows` or `posix`");
            }
        } else {
            attrs_collected.push(Attr { name: attr_name, args: arg_exprs, line: at_line, column: at_col });
        }
    }
    let mut is_pub: bool = false;
    if p.eat_kw("pub") {
        is_pub = true;
    }
    // @cfg is only ENFORCED (#ifdef-wrapped) on `fn` / `impl` / `c_raw!`
    // declarations. On every other kind codegen ignores it — a
    // `@cfg("windows") enum` existed (and ran) on linux. Reject the inert
    // spellings instead of silently compiling the decl on every platform.
    if !cfg.eq("") {
        let cfg_ok: bool = p.at_kw("fn") || p.at_kw("naked") || p.at_kw("impl") || p.at_kw("extern") || p.current.kind == TOK_RAW_BLOCK;
        if !cfg_ok {
            p.push_pdiag(cfg_line, cfg_col, 4, "cfg-unsupported-decl", "@cfg only gates `fn`, `impl`, and `c_raw!` declarations — on `".concat(p.current.lexeme).concat("` it is ignored (not supported yet); gate the uses with `if cfg!(\"").concat(cfg).concat("\")` instead"), 0, 0, 0, 0, "");
        }
    }
    // `extern fn name(args) -> ret;` — declares a foreign C function. We
    // parse the signature like a regular fn but expect `;` instead of a body
    // and mark fn_body as null. Codegen skips emitting these (the runtime
    // / linked C provides the body).
    if p.eat_kw("extern") {
        if p.at_kw("fn") {
            let s: *Stmt = parse_fn(p);
            if s != null {
                s.is_pub = is_pub;
                s.is_extern = true;
                s.fn_body = null;
                s.cfg_target = cfg;
                s.attrs = attrs_collected;
            }
            return s;
        }
        // `extern type Foo;` — an opaque C type (FFI handle). Registered as
        // a fieldless extern struct: `*Foo` resolves everywhere, codegen
        // emits only a forward `typedef struct Foo Foo;` (the C side owns
        // the definition), and the typer rejects by-value/constructed uses
        // (an opaque type has no known size).
        if p.at_kw("type") {
            p.advance(); // 'type'
            let et_line: i32 = p.current.line;
            let et_col: i32 = p.current.column;
            let et_len: i32 = p.current.lexeme.len();
            let et_name: string = p.expect_ident();
            p.expect_op(";");
            let et_fields: *Vector<Field> = Vector::new();
            let s: *Stmt = stmt_struct(et_name, et_fields, et_line, et_col);
            if s != null {
                s.is_pub = is_pub;
                s.is_extern = true;
                s.cfg_target = cfg;
                s.attrs = attrs_collected;
                s.name_line = et_line;
                s.name_col = et_col;
                s.name_len = et_len;
            }
            return s;
        }
        // Any other `extern <thing>;` — skip the line. The `;` is left in
        // place: parse_program's advance-on-null consumes one token after a
        // null return.
        p.err("expected `fn` or `type` after `extern`");
        while !p.at_op(";") && !p.at_eof() {
            p.advance();
        }
        return null;
    }
    // `naked fn ...` — function emitted with __attribute__((naked)). Body
    // must contain only `asm! { ... }` blocks; calling convention is raw.
    let mut is_naked_fn: bool = false;
    if p.eat_kw("naked") {
        is_naked_fn = true;
    }
    if p.at_kw("fn") {
        p.skip_fn_body = p.header_only && !_attrs_keep_body(attrs_collected);
        let s: *Stmt = parse_fn(p);
        if s != null {
            s.is_pub = is_pub;
            s.is_naked = is_naked_fn;
            s.cfg_target = cfg;
            s.attrs = attrs_collected;
        }
        return s;
    }
    if is_naked_fn {
        p.err("`naked` only applies to `fn`");
    }
    if p.at_kw("let") {
        let s: *Stmt = parse_let(p);
        if s != null {
            s.is_pub = is_pub;
            s.cfg_target = cfg;
            s.attrs = attrs_collected;
        }
        return s;
    }
    if p.at_kw("const") {
        let s: *Stmt = parse_const(p);
        if s != null {
            s.is_pub = is_pub;
            s.cfg_target = cfg;
            s.attrs = attrs_collected;
        }
        return s;
    }
    if p.at_kw("struct") {
        let s: *Stmt = parse_struct(p);
        if s != null {
            s.is_pub = is_pub;
            s.cfg_target = cfg;
            s.attrs = attrs_collected;
        }
        return s;
    }
    if p.at_kw("enum") {
        let s: *Stmt = parse_enum(p);
        if s != null {
            s.is_pub = is_pub;
            s.cfg_target = cfg;
            s.attrs = attrs_collected;
        }
        return s;
    }
    if p.at_kw("impl") {
        let s: *Stmt = parse_impl(p);
        if s != null {
            s.cfg_target = cfg;
            s.attrs = attrs_collected;
        }
        return s;
    }
    if p.at_kw("trait") {
        let s: *Stmt = parse_trait(p);
        if s != null {
            s.is_pub = is_pub;
            s.cfg_target = cfg;
            s.attrs = attrs_collected;
        }
        return s;
    }
    if p.at_kw("import") {
        // `pub import …;` re-exports the imported symbols: any file that
        // imports THIS module then sees them too (barrel/prelude pattern).
        let s: *Stmt = parse_import(p);
        if s != null {
            s.is_pub = is_pub;
        }
        return s;
    }
    // `c_raw! { ... }` at top level — emitted at the top of the generated .c.
    if p.current.kind == TOK_RAW_BLOCK {
        let line: i32 = p.current.line;
        let col: i32 = p.current.column;
        let body: string = p.current.lexeme;
        p.advance();
        let s: *Stmt = stmt_craw(body, line, col);
        s.cfg_target = cfg;
        s.attrs = attrs_collected;
        return s;
    }
    if p.at_kw("macro") {
        let s: *Stmt = parse_macro_def(p);
        if s != null {
            s.is_pub = is_pub;
            s.cfg_target = cfg;
            s.attrs = attrs_collected;
        }
        return s;
    }
    // `type X = i32;` at top level — the alias form doesn't exist. Consume
    // the whole decl so it yields ONE targeted error instead of a cascade of
    // "unexpected token" + phantom-type follow-ups.
    if p.at_kw("type") {
        p.err_code("type-alias-unsupported", "top-level type aliases are not supported; `type` only declares associated types inside trait/impl blocks");
        while !p.at_op(";") && !p.at_eof() {
            p.advance();
        }
        // Leave the `;` for parse_program's advance-on-null, which always
        // consumes one token after a null return.
        return null;
    }
    p.err("unexpected token at top level");
    return null;
}

// `macro name!($x:expr, $($y:expr),*) { body }`
// or, for builtins / docs-only stubs: `macro name!(matchers);` (no body — the
// expander leaves the call alone so codegen's native handling can run).
fn parse_macro_def(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'macro'
    let nline: i32 = p.current.line;
    let ncol: i32 = p.current.column;
    let nlen: i32 = p.current.lexeme.len();
    let name: string = p.expect_ident();
    p.expect_op("!");
    p.expect_op("(");
    let params: *Vector<MacroParam> = parse_macro_matchers(p);
    p.expect_op(")");
    let mut body: *Vector<Stmt> = null;
    if p.eat_op(";") {
        // Body-less stub.
    } else {
        body = parse_block(p);
    }
    let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
    s.kind = ST_MACRO_DEF;
    s.line = line;
    s.column = col;
    s.name = name;
    s.name_line = nline;
    s.name_col = ncol;
    s.name_len = nlen;
    s.macro_params = params;
    s.then_body = body;
    return s;
}

// Matcher kind after `$name:`. Only `expr` is implemented — the expander
// substitutes bound EXPRESSIONS and never read the recorded kind, so a
// declared `:ty` / `:ident` exploded downstream as expr-parse errors at
// every call site (`mk!(i64)` → "unknown name i64"). Reject at the
// definition site instead.
fn _expect_matcher_kind(p: *Parser) {
    let k_line: i32 = p.current.line;
    let k_col: i32 = p.current.column;
    let kind: string = p.expect_ident();
    if kind.eq("expr") {
        return;
    }
    if kind.eq("ty") || kind.eq("ident") {
        p.push_pdiag(k_line, k_col, kind.len(), "unsupported-matcher-kind", "macro matcher kind `:".concat(kind).concat("` is not supported yet — only `:expr` works"), 0, 0, 0, 0, "");
        return;
    }
    p.push_pdiag(k_line, k_col, kind.len(), "unsupported-matcher-kind", "matcher kind must be `expr` (`:ty` / `:ident` are not supported yet)", 0, 0, 0, 0, "");
}

// Matcher list: `$x:expr`, `$($x:expr),*`, etc, comma-separated.
fn parse_macro_matchers(p: *Parser) -> *Vector<MacroParam> {
    let out: *Vector<MacroParam> = Vector::new();
    while !p.at_op(")") && !p.at_eof() {
        // Variadic: `$( $name:expr ) sep *` (sep = ',' or ';')
        if p.at_op("$") && p.peek_op("(") {
            p.advance(); // '$'
            p.advance(); // '('
            p.expect_op("$");
            let bname: string = p.expect_ident();
            p.expect_op(":");
            _expect_matcher_kind(p);
            p.expect_op(")");
            let mut sep: string = "";
            if p.at_op(",") || p.at_op(";") {
                sep = p.current.lexeme;
                // The expander never reads the separator: calls always use
                // `,` regardless of what's declared here, and a `;`-separated
                // call is a hard parse error. Reject the fiction at the
                // definition instead of exploding at every call site.
                if sep.eq(";") {
                    p.err_code("unsupported-matcher-separator", "`;` separators are not supported in macro matchers; use `,`");
                }
                p.advance();
            }
            p.expect_op("*");
            let mp: MacroParam = MacroParam { name: bname, is_variadic: true, separator: sep, kind: "expr" };
            out.push(mp);
        } else {
            if p.at_op("$") {
                p.advance(); // '$'
                let bname: string = p.expect_ident();
                p.expect_op(":");
                _expect_matcher_kind(p);
                let mp: MacroParam = MacroParam { name: bname, is_variadic: false, separator: "", kind: "expr" };
                out.push(mp);
            } else {
                p.err("expected `$name:<kind>` or `$($name:<kind>),*` in macro matcher list");
                p.advance();
            }
        }
        if !p.eat_op(",") {
            break;
        }
    }
    return out;
}

// True if a fn carrying these attrs must keep its body even in header-only
// mode: proc-macro functions are executed by the expander, so their bodies are
// part of the public contract, not just an implementation detail.
fn _attrs_keep_body(attrs: *Vector<Attr>) -> bool {
    if attrs == null {
        return false;
    }
    for let i: i32 = 0; i < attrs.len(); i++ {
        let a: Attr = attrs.get(i);
        if a.name.eq("proc_macro") || a.name.eq("proc_macro_expr") || a.name.eq("proc_macro_str")
           || a.name.eq("proc_derive") || a.name.eq("proc_attr") || a.name.eq("proc_pass") {
            return true;
        }
    }
    return false;
}

// Consume a `{ ... }` block at the token level without building an AST. The
// lexer collapses strings, char literals and c_raw! { } into single tokens, so
// counting `{` / `}` operator tokens is enough to find the matching brace.
fn skip_block(p: *Parser) -> *Vector<Stmt> {
    let empty: *Vector<Stmt> = Vector::new();
    if !p.expect_op("{") {
        return empty;
    }
    let mut depth: i32 = 1;
    while depth > 0 && !p.at_eof() {
        if p.at_op("{") {
            depth = depth + 1;
        } else if p.at_op("}") {
            depth = depth - 1;
        }
        p.advance();
    }
    return empty;
}

fn parse_fn(p: *Parser) -> *Stmt {
    let skip_body: bool = p.skip_fn_body;
    p.skip_fn_body = false;
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'fn'
    let nline: i32 = p.current.line;
    let ncol: i32 = p.current.column;
    let nlen: i32 = p.current.lexeme.len();
    let name: string = p.expect_ident();
    // Optional generic params <T, U: Bound + Bound>
    let tps_bounds: *Vector<string> = Vector::new();
    let tps: *Vector<string> = parse_type_params_with_bounds(p, tps_bounds);
    p.expect_op("(");
    let params: *Vector<Param> = Vector::new();
    let mut variadic: bool = false;
    let mut dots_line: i32 = 0;
    let mut dots_col: i32 = 0;
    while !p.at_op(")") && !p.at_eof() {
        if p.at_op("...") {
            // C-style variadic — must be the last position. Consumed without
            // adding a regular param. Only meaningful on `extern fn` decls;
            // a bodied fn is rejected below (once we know a body follows).
            dots_line = p.current.line;
            dots_col = p.current.column;
            p.advance();
            variadic = true;
            break;
        }
        // Rust-style borrowed receivers: `&self` -> `self: &Self` and
        // `&mut self` -> `self: &mut Self`; the impl post-pass substitutes
        // the target type. Only the receiver gets this sugar.
        if p.at_op("&") {
            p.advance();
            let br_mut: bool = p.eat_kw("mut");
            // Anchor the receiver at the `self` token (not the leading `&`), so
            // highlight/rename cover `self`, not `&sel`.
            let br_line: i32 = p.current.line;
            let br_col: i32 = p.current.column;
            let br_name: string = p.expect_ident();
            if !br_name.eq("self") {
                p.err("expected `self` after `&` in a parameter list (borrowed params are written `name: &T`)");
            }
            let bty: *Type = __glide_palloc(sizeof(Type)) as *Type;
            if br_mut {
                bty.kind = TY_BORROW_MUT;
            } else {
                bty.kind = TY_BORROW;
            }
            bty.inner = ty_named("Self");
            let bprm: Param = Param { name: br_name, ty: bty, name_line: br_line, name_col: br_col, is_mut: false };
            params.push(bprm);
            if !p.eat_op(",") {
                break;
            }
            continue;
        }
        // `mut` before the name binds the param as reassignable in the body;
        // without it the param is immutable (`assign-immutable` on writes).
        let mkw_line: i32 = p.current.line;
        let mkw_col: i32 = p.current.column;
        let pn_mut: bool = p.eat_kw("mut");
        let pn_line: i32 = p.current.line;
        let pn_col: i32 = p.current.column;
        let pname: string = p.expect_binder_ident();
        // Rust-style bare receiver: `fn m(self, …)` inside an impl means
        // `self: *Self`; the impl post-pass substitutes the target type.
        // An annotated `self: *T` keeps working unchanged.
        if pname.eq("self") && !p.at_op(":") {
            // `fn m(mut self)` used to parse with the `mut` silently dropped.
            // Rejecting beats recording: the receiver is a `*T` pointer, so
            // there is nothing for `mut` to grant — writes go through it
            // already, and rebinding the pointer needs the annotated form.
            if pn_mut {
                p.push_pdiag(mkw_line, mkw_col, 3, "mut-self-receiver", "`mut` on a bare `self` receiver has no effect — the receiver is already a `*T` pointer; write through it, or declare `mut self: *Self` to rebind the pointer locally", 0, 0, 0, 0, "");
            }
            let sprm: Param = Param { name: pname, ty: ty_pointer(ty_named("Self")), name_line: pn_line, name_col: pn_col, is_mut: false };
            params.push(sprm);
            if !p.eat_op(",") {
                break;
            }
            continue;
        }
        p.expect_op(":");
        // Rust-style `impl Trait` argument: `ao: impl Alelo2` desugars to a
        // hidden generic — `fn a<__impl_ao: Alelo2>(ao: *__impl_ao)` — static
        // dispatch, exactly as if the bound were written by hand. `+` chains
        // bounds (`impl Read + Write`). fmt prints the sugar back.
        if p.at_kw("impl") {
            p.advance();
            let mut bound: string = p.expect_ident();
            while p.eat_op("+") {
                bound = bound.concat("+").concat(p.expect_ident());
            }
            let gname: string = "__impl_".concat(pname);
            tps.push(gname);
            tps_bounds.push(bound);
            let iprm: Param = Param { name: pname, ty: ty_pointer(ty_named(gname)), name_line: pn_line, name_col: pn_col, is_mut: pn_mut };
            params.push(iprm);
            if !p.eat_op(",") {
                break;
            }
            continue;
        }
        let pty: *Type = parse_type(p);
        let prm: Param = Param { name: pname, ty: pty, name_line: pn_line, name_col: pn_col, is_mut: pn_mut };
        params.push(prm);
        if !p.eat_op(",") {
            break;
        }
    }
    p.expect_op(")");
    let mut ret_ty: *Type = null;
    if p.eat_op("->") {
        ret_ty = parse_type(p);
    }
    // A return type written without the `->` is the most common slip:
    // `fn f(x) T { ... }` instead of `fn f(x) -> T { ... }`. Without this guard
    // the stray type tokens derail block parsing into a confusing cascade (or,
    // when the fn is called across a file boundary, an ICE in codegen because the
    // return type was silently dropped to void). Flag it clearly and recover by
    // consuming the type so the rest of the file still parses.
    if ret_ty == null && !p.at_op("{") && !p.at_op(";") {
        p.err_code("missing-arrow", "missing `->` before the return type (write `fn name(args) -> Type`)");
        ret_ty = parse_type(p);
    }
    // Bodyless form: `fn name(args) -> ret;` (used after `extern`).
    if p.eat_op(";") {
        let no_body: *Vector<Stmt> = null;
        let s: *Stmt = stmt_fn(name, params, ret_ty, no_body, line, col);
        if s != null {
            s.type_params = tps;
            s.type_param_bounds = tps_bounds;
            s.name_line = nline;
            s.name_col = ncol;
            s.name_len = nlen;
            s.is_variadic = variadic;
        }
        return s;
    }
    // A body follows, so this is NOT an extern decl: `...` is a lie here —
    // the body has no way to access the extra arguments (no va_list surface),
    // and codegen silently dropped the flag.
    if variadic {
        p.push_pdiag(dots_line, dots_col, 3, "variadic-non-extern", "`...` is only supported on `extern fn` declarations — a Glide fn body cannot access variadic arguments", 0, 0, 0, 0, "");
    }
    let mut body: *Vector<Stmt> = null;
    if skip_body {
        body = skip_block(p);
    } else {
        body = parse_block(p);
    }
    let s: *Stmt = stmt_fn(name, params, ret_ty, body, line, col);
    if s != null {
        s.type_params = tps;
        s.type_param_bounds = tps_bounds;
        s.name_line = nline;
        s.name_col = ncol;
        s.name_len = nlen;
        s.is_variadic = variadic;
    }
    return s;
}

fn parse_type_params(p: *Parser) -> *Vector<string> {
    let tps: *Vector<string> = Vector::new();
    if !p.eat_op("<") {
        return tps;
    }
    while !p.at_op(">") && !p.at_eof() {
        let name: string = p.expect_ident();
        tps.push(name);
        // Optional bounds: `T: Trait1 + Trait2`. Discarded here; the caller
        // version `parse_type_params_with_bounds` is what records them.
        if p.eat_op(":") {
            let _b: string = p.expect_ident();
            while p.eat_op("+") {
                let _nb: string = p.expect_ident();
            }
        }
        if !p.eat_op(",") {
            break;
        }
    }
    p.expect_op(">");
    return tps;
}

// Same as parse_type_params, but also fills `bounds_out` in lockstep with
// the returned name list. Each slot is a `+`-joined string of trait names
// (or `""` for an unbounded slot). Use this in the parse paths that record
// type params on the resulting Stmt.
fn parse_type_params_with_bounds(p: *Parser, bounds_out: *Vector<string>) -> *Vector<string> {
    let tps: *Vector<string> = Vector::new();
    if !p.eat_op("<") {
        return tps;
    }
    while !p.at_op(">") && !p.at_eof() {
        let name: string = p.expect_ident();
        tps.push(name);
        let mut bound: string = "";
        if p.eat_op(":") {
            let b0: string = p.expect_ident();
            bound = b0;
            while p.eat_op("+") {
                let nb: string = p.expect_ident();
                bound = bound.concat("+").concat(nb);
            }
        }
        bounds_out.push(bound);
        if !p.eat_op(",") {
            break;
        }
    }
    p.expect_op(">");
    return tps;
}

fn skip_type_params(p: *Parser) {
    p.advance(); // '<'
    while !p.at_op(">") && !p.at_eof() {
        p.advance();
    }
    p.eat_op(">");
}

fn parse_struct(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'struct'
    let nline: i32 = p.current.line;
    let ncol: i32 = p.current.column;
    let nlen: i32 = p.current.lexeme.len();
    let name: string = p.expect_ident();
    let tps_bounds: *Vector<string> = Vector::new();
    let tps: *Vector<string> = parse_type_params_with_bounds(p, tps_bounds);
    // Two field-list shapes:
    //   struct Name { pub a: T, pub b: U }       full form
    //   struct Name(a: T, b: U)                  compact form: implicit
    //                                            pub on every field, no
    //                                            doc-comment slots
    // The compact form is sugar — same Stmt produced as the full form
    // with `is_pub = true` on every field. Useful for value-types like
    // ApiKey, Token, Wrapper where the boilerplate noise dominates.
    let mut is_tuple: bool = false;
    let mut open: string = "{";
    let mut close: string = "}";
    if p.at_op("(") {
        is_tuple = true;
        open = "(";
        close = ")";
    }
    p.expect_op(open);
    let fields: *Vector<Field> = Vector::new();
    while !p.at_op(close) && !p.at_eof() {
        let fdoc: string = p.current.doc;
        // Three equivalent ways to mark a field exported across files:
        //   pub field: T,    // long form
        //   !field: T,       // short prefix sigil (field-only shortcut)
        // Bare `field: T,` stays private (default) in the brace form.
        // In the tuple form every field is implicitly pub.
        let mut fpub: bool = is_tuple;
        let mut fbang: bool = false;
        if p.eat_kw("pub") {
            fpub = true;
        } else {
            if p.eat_op("!") {
                fpub = true;
                fbang = true;
            }
        }
        let fname: string = p.expect_ident();
        p.expect_op(":");
        // `own *T` field: the struct owns this pointer and frees it (recursively)
        // when it drops. Bare `*T` is a non-owning reference, left untouched.
        let mut fown: bool = false;
        if p.current.kind == TOK_IDENT && p.current.lexeme.eq("own") {
            fown = true;
            p.advance();
        }
        let mut fty: *Type = parse_type(p);
        if fown && fty != null && fty.kind != TY_POINTER {
            // `own T` (no *) is sugar for `own *T`: an owned heap pointer with the
            // `*` left implicit. Stored as *T everywhere downstream, so you write
            // `own Conn` and assign a pointer-returning ctor; the drop frees it.
            fty = ty_pointer(fty);
        }
        let mut f: Field = Field { name: fname, ty: fty, doc: fdoc, is_pub: fpub, bang_pub: fbang, trail: "", is_own: fown };
        let had_comma: bool = p.eat_op(",");
        if p.current.trail != null && !p.current.trail.eq("") {
            f.trail = p.current.trail;
        }
        fields.push(f);
        if !had_comma {
            break;
        }
    }
    p.expect_op(close);
    let s: *Stmt = stmt_struct(name, fields, line, col);
    if s != null {
        s.type_params = tps;
        s.type_param_bounds = tps_bounds;
        s.name_line = nline;
        s.name_col = ncol;
        s.name_len = nlen;
    }
    return s;
}

fn parse_enum(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'enum'
    let nline: i32 = p.current.line;
    let ncol: i32 = p.current.column;
    let nlen: i32 = p.current.lexeme.len();
    let name: string = p.expect_ident();
    if p.at_op("<") {
        // `enum E<T>` used to be silently brace-skipped: the decl passed
        // check and codegen emitted a literal `T` field into the C (cc ICE).
        // Generic enums are unimplemented — say so, then skip the param list
        // so the variant block still parses (recovery, no cascade).
        p.push_pdiag(p.current.line, p.current.column, 1, "generic-enum-unsupported", "generic enums are not supported yet — `enum ".concat(name).concat("<T>` cannot be monomorphized; use a concrete payload type"), 0, 0, 0, 0, "");
        skip_type_params(p);
    }
    p.expect_op("{");
    let variants: *Vector<EnumVariant> = Vector::new();
    while !p.at_op("}") && !p.at_eof() {
        let vdoc: string = p.current.doc;
        let vname: string = p.expect_ident();
        let fields: *Vector<Type> = Vector::new();
        if p.eat_op("(") {
            while !p.at_op(")") && !p.at_eof() {
                let t: *Type = parse_type(p);
                if t != null {
                    fields.push(*t);
                }
                if !p.eat_op(",") {
                    break;
                }
            }
            p.expect_op(")");
        }
        let mut v: EnumVariant = EnumVariant { name: vname, fields: fields, doc: vdoc, trail: "" };
        let had_comma: bool = p.eat_op(",");
        if p.current.trail != null && !p.current.trail.eq("") {
            v.trail = p.current.trail;
        }
        variants.push(v);
        if !had_comma {
            break;
        }
    }
    p.expect_op("}");
    let s: *Stmt = stmt_enum(name, variants, line, col);
    if s != null {
        s.name_line = nline;
        s.name_col = ncol;
        s.name_len = nlen;
    }
    return s;
}

// `trait Name { fn method(args) -> ret; ... }` — a contract. Methods
// have signatures only (no body); a corresponding `impl Trait for Type`
// supplies the implementations. `Self` is allowed as a stand-in for the
// implementor and gets substituted when the impl is parsed.
fn parse_trait(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'trait'
    let nline: i32 = p.current.line;
    let ncol: i32 = p.current.column;
    let name: string = p.expect_ident();
    let nlen: i32 = name.len();
    // Optional supertrait list: `trait Bird: Animal, Mover { ... }`.
    let supers: *Vector<string> = Vector::new();
    if p.eat_op(":") {
        supers.push(p.expect_ident());
        while p.eat_op(",") {
            supers.push(p.expect_ident());
        }
    }
    p.expect_op("{");
    let methods: *Vector<Stmt> = Vector::new();
    let assocs: *Vector<Param> = Vector::new();
    while !p.at_op("}") && !p.at_eof() {
        let doc: string = p.current.doc;
        let mut is_pub: bool = false;
        if p.eat_kw("pub") {
            is_pub = true;
        }
        // Associated type declaration: `type Item;`
        if p.at_kw("type") {
            p.advance();
            let aname: string = p.expect_ident();
            p.expect_op(";");
            let no_ty: *Type = null;
            assocs.push(Param { name: aname, ty: no_ty, name_line: 0, name_col: 0, is_mut: false });
            continue;
        }
        if p.at_kw("fn") {
            // Trait methods can be bodyless (signature only — implementor must
            // provide) OR have a body (default implementation that the impl
            // can override). parse_fn handles both shapes natively.
            let m: *Stmt = parse_fn(p);
            if m != null {
                m.is_pub = is_pub;
                if doc != null && !doc.eq("") {
                    m.doc_comment = doc;
                }
                methods.push(*m);
            }
        } else {
            p.err("expected `fn` or `type` inside trait body");
            p.advance();
        }
    }
    p.expect_op("}");
    let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
    s.kind = ST_TRAIT;
    s.line = line;
    s.column = col;
    s.name = name;
    s.name_line = nline;
    s.name_col = ncol;
    s.name_len = nlen;
    s.impl_methods = methods;
    s.trait_supers = supers;
    s.assoc_decls = assocs;
    return s;
}

fn parse_impl(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'impl'
    let tps_bounds: *Vector<string> = Vector::new();
    let tps: *Vector<string> = parse_type_params_with_bounds(p, tps_bounds);
    let mut target: *Type = parse_type(p);
    // `impl TraitName for Type { ... }` — the first type was the trait
    // name; consume `for` and parse the real implementor.
    let mut trait_name: string = "";
    if p.at_kw("for") {
        if target != null && target.kind == TY_NAMED {
            trait_name = target.name;
        }
        // A module-qualified trait (`impl alelo::Pinto for T`) parses as an
        // assoc type (`Owner::Name`); the trait leaf is its `name`.
        if target != null && target.kind == TY_ASSOC {
            trait_name = target.name;
        }
        p.advance();
        target = parse_type(p);
    }
    // Optional namespace tag: `impl string in cores { ... }`. Lets two libs both
    // add e.g. `red()` to string without their generated symbols colliding —
    // each gets `cores_string_red` / `style_string_red` instead of both stamping
    // out `string_red`. Method-call dispatch later picks the unambiguous match.
    let mut ns: string = "";
    if p.at_kw("in") {
        p.advance();
        ns = p.expect_ident();
    }
    p.expect_op("{");
    let methods: *Vector<Stmt> = Vector::new();
    let assocs: *Vector<Param> = Vector::new();
    while !p.at_op("}") && !p.at_eof() {
        // Capture the contiguous `///` (or `//`) doc block above the method
        // so hover can render it. The lexer attaches doc to the next non-doc
        // token, which is `pub` (if present) or `fn`/`macro` otherwise.
        let doc: string = p.current.doc;
        // Member-level attributes: `@deprecated(...)`, `@allow(...)`, etc.
        // Collected in source order so the lint passes can read them
        // off `Stmt.attrs`.
        let mem_attrs: *Vector<Attr> = Vector::new();
        while p.at_op("@") {
            let at_line: i32 = p.current.line;
            let at_col: i32 = p.current.column;
            p.advance();
            let nm: string = p.expect_ident();
            let arg_exprs: *Vector<Expr> = Vector::new();
            if p.eat_op("(") {
                while !p.at_op(")") && !p.at_eof() {
                    let e: *Expr = parse_expr(p, 0);
                    if e != null {
                        arg_exprs.push(*e);
                    }
                    if !p.eat_op(",") {
                        break;
                    }
                }
                p.expect_op(")");
            }
            mem_attrs.push(Attr { name: nm, args: arg_exprs, line: at_line, column: at_col });
        }
        let mut is_pub: bool = false;
        if p.eat_kw("pub") {
            is_pub = true;
        }
        // Associated type definition: `type Item = ConcreteType;`
        if p.at_kw("type") {
            p.advance();
            let aname: string = p.expect_ident();
            p.expect_op("=");
            let aty: *Type = parse_type(p);
            p.expect_op(";");
            assocs.push(Param { name: aname, ty: aty, name_line: 0, name_col: 0, is_mut: false });
            continue;
        }
        if p.at_kw("fn") {
            p.skip_fn_body = p.header_only && !_attrs_keep_body(mem_attrs);
            let m: *Stmt = parse_fn(p);
            if m != null {
                m.is_pub = is_pub;
                if doc != null && !doc.eq("") {
                    m.doc_comment = doc;
                }
                if mem_attrs.len() > 0 {
                    m.attrs = mem_attrs;
                }
                methods.push(*m);
            }
        } else {
            if p.at_kw("macro") {
                let m: *Stmt = parse_macro_def(p);
                if m != null {
                    m.is_pub = is_pub;
                    if doc != null && !doc.eq("") {
                        m.doc_comment = doc;
                    }
                    if mem_attrs.len() > 0 {
                        m.attrs = mem_attrs;
                    }
                    methods.push(*m);
                }
            } else {
                p.err("expected fn, macro, or type inside impl");
                p.advance();
            }
        }
    }
    p.expect_op("}");
    let s: *Stmt = stmt_impl(target, methods, line, col);
    if s != null {
        s.type_params = tps;
        s.type_param_bounds = tps_bounds;
        s.assoc_decls = assocs;
        if !ns.eq("") {
            s.import_path = ns;
        }
        // `fmt` wants the source verbatim, so it skips this lowering and keeps
        // `Self` as written. Every other caller substitutes eagerly.
        if p.fmt_mode {
            if !trait_name.eq("") {
                s.impl_trait_name = trait_name;
            }
        } else {
            if !trait_name.eq("") {
                s.impl_trait_name = trait_name;
                // Inside `impl Trait for T { ... }`, `Self` in method signatures
                // refers to T. Substitute now so later passes don't have to know
                // about the trait-context. Also resolve `Self::Assoc` against
                // this impl's assoc definitions.
                substitute_self_in_methods(methods, target);
                substitute_self_assoc_in_methods(methods, assocs);
            } else {
                // Plain `impl T { ... }` — Self in method sigs also refers to T.
                substitute_self_in_methods(methods, target);
            }
        }
    }
    return s;
}

// Replace any TY_NAMED("Self") in the param/return types of `methods`
// with the concrete `target` type. Vector.get returns by value, so we
// must `.set()` the rewritten Param/Stmt back in place.
pub fn substitute_self_in_methods(methods: *Vector<Stmt>, target: *Type) {
    if methods == null || target == null {
        return;
    }
    // The implementor's bare name, used to rewrite `Self` in value position
    // (struct literals `Self { }`, path qualifiers `Self::new()`). For a
    // generic target (`impl<T> Box<T>`) this is the base name `Box`, which is
    // what a hand-written literal / mono lookup expects.
    let mut tname: string = "";
    if target.kind == TY_NAMED {
        tname = target.name;
    } else {
        if target.kind == TY_GENERIC {
            tname = target.name;
        }
    }
    for let i: i32 = 0; i < methods.len(); i++ {
        let mut m: Stmt = methods.get(i);
        if m.fn_params != null {
            for let j: i32 = 0; j < m.fn_params.len(); j++ {
                let mut p: Param = m.fn_params.get(j);
                if p.ty != null {
                    p.ty = substitute_self_in_type(p.ty, target);
                }
                m.fn_params.set(j, p);
            }
        }
        if m.fn_ret_ty != null {
            m.fn_ret_ty = substitute_self_in_type(m.fn_ret_ty, target);
        }
        // Rewrite `Self` inside the method body too — `Self { }` literals,
        // `Self::method()` calls, `as Self` casts, and `let x: Self` types.
        // CLONES the body (returns a fresh tree); the trait-default expansion
        // in lower.glide shares method-body pointers across every impl of the
        // same trait, so an in-place mutation would pollute siblings.
        if m.fn_body != null && !tname.eq("") {
            m.fn_body = _subst_self_clone_stmts(m.fn_body, target, tname);
        }
        methods.set(i, m);
    }
}

// ---- `Self` substitution in method bodies --------------------------------
// These clone the AST while replacing `Self`: in types via
// `substitute_self_in_type`, and in value position (struct-literal / path
// names) via the implementor's bare `name`. Cloning (rather than mutating)
// keeps shared trait-default bodies intact across impls.
fn _subst_self_clone_expr(e: *Expr, target: *Type, name: string) -> *Expr {
    if e == null {
        return null;
    }
    let c: *Expr = __glide_palloc(sizeof(Expr)) as *Expr;
    *c = *e;
    if c.kind == EX_STRUCT_LIT && c.str_val != null && c.str_val.eq("Self") {
        c.str_val = name;
    }
    if c.kind == EX_PATH && c.str_val != null && c.str_val.eq("Self") {
        c.str_val = name;
    }
    if c.macro_owner != null && c.macro_owner.eq("Self") {
        c.macro_owner = name;
    }
    if c.cast_to != null {
        c.cast_to = substitute_self_in_type(c.cast_to, target);
    }
    c.lhs = _subst_self_clone_expr(e.lhs, target, name);
    c.rhs = _subst_self_clone_expr(e.rhs, target, name);
    c.operand = _subst_self_clone_expr(e.operand, target, name);
    c.macro_recv = _subst_self_clone_expr(e.macro_recv, target, name);
    if e.args != null {
        let na: *Vector<Expr> = Vector::new();
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            let sa: *Expr = _subst_self_clone_expr(&a, target, name);
            na.push(*sa);
        }
        c.args = na;
    }
    if e.block_stmts != null {
        c.block_stmts = _subst_self_clone_stmts(e.block_stmts, target, name);
    }
    if e.fn_expr_body != null {
        c.fn_expr_body = _subst_self_clone_stmts(e.fn_expr_body, target, name);
    }
    if e.match_arms != null {
        let nm: *Vector<MatchArm> = Vector::new();
        for let i: i32 = 0; i < e.match_arms.len(); i++ {
            let mut arm: MatchArm = e.match_arms.get(i);
            if arm.body != null {
                arm.body = _subst_self_clone_stmts(arm.body, target, name);
            }
            // `Self::variant` patterns: the qualifier refers to the implementor.
            if arm.qualifier != null && arm.qualifier.eq("Self") {
                arm.qualifier = name;
            }
            nm.push(arm);
        }
        c.match_arms = nm;
    }
    return c;
}

fn _subst_self_clone_stmts(body: *Vector<Stmt>, target: *Type, name: string) -> *Vector<Stmt> {
    if body == null {
        return null;
    }
    let out: *Vector<Stmt> = Vector::new();
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        let cs: *Stmt = _subst_self_clone_stmt(&s, target, name);
        out.push(*cs);
    }
    return out;
}

fn _subst_self_clone_stmt(s: *Stmt, target: *Type, name: string) -> *Stmt {
    if s == null {
        return null;
    }
    let c: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
    *c = *s;
    if c.let_ty != null {
        c.let_ty = substitute_self_in_type(c.let_ty, target);
    }
    c.let_value = _subst_self_clone_expr(s.let_value, target, name);
    c.expr_value = _subst_self_clone_expr(s.expr_value, target, name);
    c.cond = _subst_self_clone_expr(s.cond, target, name);
    c.for_step = _subst_self_clone_expr(s.for_step, target, name);
    c.scrutinee = _subst_self_clone_expr(s.scrutinee, target, name);
    if s.for_init != null {
        c.for_init = _subst_self_clone_stmt(s.for_init, target, name);
    }
    if s.then_body != null {
        c.then_body = _subst_self_clone_stmts(s.then_body, target, name);
    }
    if s.else_body != null {
        c.else_body = _subst_self_clone_stmts(s.else_body, target, name);
    }
    if s.arms != null {
        let na: *Vector<MatchArm> = Vector::new();
        for let i: i32 = 0; i < s.arms.len(); i++ {
            let mut arm: MatchArm = s.arms.get(i);
            if arm.body != null {
                arm.body = _subst_self_clone_stmts(arm.body, target, name);
            }
            // `Self::variant` patterns: the qualifier refers to the implementor.
            if arm.qualifier != null && arm.qualifier.eq("Self") {
                arm.qualifier = name;
            }
            na.push(arm);
        }
        c.arms = na;
    }
    // Nested fn / closure declared in the body: substitute its signature and
    // body too.
    if c.fn_ret_ty != null {
        c.fn_ret_ty = substitute_self_in_type(c.fn_ret_ty, target);
    }
    if s.fn_params != null {
        let np: *Vector<Param> = Vector::new();
        for let j: i32 = 0; j < s.fn_params.len(); j++ {
            let mut p: Param = s.fn_params.get(j);
            if p.ty != null {
                p.ty = substitute_self_in_type(p.ty, target);
            }
            np.push(p);
        }
        c.fn_params = np;
    }
    if s.fn_body != null {
        c.fn_body = _subst_self_clone_stmts(s.fn_body, target, name);
    }
    return c;
}

fn substitute_self_in_type(t: *Type, target: *Type) -> *Type {
    if t == null {
        return null;
    }
    if t.kind == TY_NAMED && t.name.eq("Self") {
        return target;
    }
    if t.inner == null && t.fnptr_ret == null {
        return t;
    }
    let copy: *Type = __glide_palloc(sizeof(Type)) as *Type;
    *copy = *t;
    if copy.inner != null {
        copy.inner = substitute_self_in_type(copy.inner, target);
    }
    if copy.fnptr_ret != null {
        copy.fnptr_ret = substitute_self_in_type(copy.fnptr_ret, target);
    }
    return copy;
}

// Replace any `Self::Name` in method sigs with the impl's `type Name = X`
// definition. Runs after `substitute_self_in_methods` so the target type
// already replaced bare `Self`. Lookup the assoc by name; leave unchanged
// if the impl doesn't define it (typer will diagnose).
pub fn substitute_self_assoc_in_methods(methods: *Vector<Stmt>, assocs: *Vector<Param>) {
    if methods == null || assocs == null {
        return;
    }
    for let i: i32 = 0; i < methods.len(); i++ {
        let mut m: Stmt = methods.get(i);
        if m.fn_params != null {
            for let j: i32 = 0; j < m.fn_params.len(); j++ {
                let mut p: Param = m.fn_params.get(j);
                if p.ty != null {
                    p.ty = substitute_self_assoc_in_type(p.ty, assocs);
                }
                m.fn_params.set(j, p);
            }
        }
        if m.fn_ret_ty != null {
            m.fn_ret_ty = substitute_self_assoc_in_type(m.fn_ret_ty, assocs);
        }
        methods.set(i, m);
    }
}

fn substitute_self_assoc_in_type(t: *Type, assocs: *Vector<Param>) -> *Type {
    if t == null {
        return null;
    }
    if t.kind == TY_ASSOC && t.inner != null && t.inner.kind == TY_NAMED && t.inner.name.eq("Self") {
        for let i: i32 = 0; i < assocs.len(); i++ {
            let a: Param = assocs.get(i);
            if a.name.eq(t.name) {
                return a.ty;
            }
        }
    }
    if t.inner == null && t.fnptr_ret == null {
        return t;
    }
    let copy: *Type = __glide_palloc(sizeof(Type)) as *Type;
    *copy = *t;
    if copy.inner != null {
        copy.inner = substitute_self_assoc_in_type(copy.inner, assocs);
    }
    if copy.fnptr_ret != null {
        copy.fnptr_ret = substitute_self_assoc_in_type(copy.fnptr_ret, assocs);
    }
    return copy;
}

fn parse_import(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'import'
    // Only path-based imports are supported. The path segments map straight
    // to the filesystem (`a::b::c` -> `a/b/c.glide`); there's no
    // `mod.glide` indirection. Forms accepted:
    //   import a;                    -> load `a.glide`, all pub visible
    //   import a::b::c::Item;        -> just `Item` from `a/b/c.glide`
    //   import a::b::c::{X, Y};      -> selective list
    //   import a::b::c::*;           -> all pub from `a/b/c.glide`
    if p.current.kind == TOK_STRING {
        p.err("string-literal imports were removed; use `import a::b::Item;` instead");
        // skip to ';' so the rest of the file still parses
        while !p.at_op(";") && !p.at_eof() {
            p.advance();
        }
        p.eat_op(";");
        return null;
    }
    let mut path: string = "";
    let mut items: *Vector<string> = null;
    let segs: *Vector<string> = Vector::new();
    let collected: *Vector<string> = Vector::new();
    let mut wildcard: bool = false;
    let mut mod_line: i32 = p.current.line;
    let mut mod_col: i32 = p.current.column;
    segs.push(p.expect_ident());
    while p.at_op("::") {
        p.advance();
        if p.at_op("{") {
            p.advance();
            while !p.at_op("}") && !p.at_eof() {
                // A brace entry is an ident, optionally continuing as a nested
                // path (`cookies::CookieJar`) or nested group
                // (`cookies::{CookieJar, Cookie}`) — flattened to
                // `cookies::CookieJar` entries; the loader splits them into
                // the child-module load + the selective symbol.
                let mut entry: string = p.expect_ident();
                while p.at_op("::") {
                    p.advance();
                    if p.at_op("{") {
                        p.advance();
                        while !p.at_op("}") && !p.at_eof() {
                            collected.push(entry.concat("::").concat(p.expect_ident()));
                            if !p.eat_op(",") {
                                break;
                            }
                        }
                        p.expect_op("}");
                        entry = "";
                        break;
                    }
                    entry = entry.concat("::").concat(p.expect_ident());
                }
                if !entry.eq("") {
                    collected.push(entry);
                }
                if !p.eat_op(",") {
                    break;
                }
            }
            p.expect_op("}");
            break;
        }
        if p.at_op("*") {
            p.advance();
            wildcard = true;
            break;
        }
        mod_line = p.current.line;
        mod_col = p.current.column;
        segs.push(p.expect_ident());
    }
    if collected.len() > 0 {
        items = collected;
    }
    // Build "/"-joined file path from ALL segments. The loader probes the
    // filesystem to decide whether the trailing segment names a file (module
    // import) or an item from the parent file. Wildcards / brace-lists
    // already specify items, so they always target the full path as a file.
    for let i: i32 = 0; i < segs.len(); i++ {
        if i > 0 {
            path = path.concat("/");
        }
        path = path.concat(segs.get(i));
    }
    path = path.concat(".glide");
    p.expect_op(";");
    let s: *Stmt = stmt_import(path, line, col);
    s.imported_items = items;
    s.import_wildcard = wildcard;
    s.import_mod_line = mod_line;
    s.import_mod_col = mod_col;
    if segs.len() > 0 {
        s.import_mod_name = segs.get(segs.len() - 1);
    }
    return s;
}

fn parse_block(p: *Parser) -> *Vector<Stmt> {
    let stmts: *Vector<Stmt> = Vector::new();
    if !p.expect_op("{") {
        return stmts;
    }
    while !p.at_op("}") && !p.at_eof() {
        // Pick up any `//` comment chain that lives above this stmt so the
        // formatter can re-emit it. Same pattern as parse_program.
        let doc: string = p.current.doc;
        let lead: string = p.current.lead;
        let s: *Stmt = parse_stmt(p);
        if s != null {
            if doc != null && !doc.eq("") {
                s.doc_comment = doc;
            }
            if lead != null && !lead.eq("") {
                s.leading_comments = lead;
            }
            if p.current.trail != null && !p.current.trail.eq("") {
                s.trailing_comment = p.current.trail;
            }
            stmts.push(*s);
        }
    }
    // Comments after the last stmt (the `}` token's lead) would otherwise be
    // dropped; keep them as a fmt-only placeholder stmt.
    if p.fmt_mode && p.current.lead != null && !p.current.lead.eq("") {
        stmts.push(*stmt_comment(p.current.lead));
    }
    p.expect_op("}");
    return stmts;
}

// `asm! [volatile] { "instr" "instr" [: "=c"(out), ...] [: "c"(in), ...] [: "clob", ...] }`
//
// Maps directly to GCC's `__asm__ [volatile] ("..." : outs : ins : clobbers)`.
// Each section after the strings is optional but they are positional — to skip
// outputs while providing inputs you write `: : "r"(x)`. Trailing `;` after the
// closing `}` is optional (eaten below when present).
fn parse_asm_block(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'asm'
    p.expect_op("!");
    let mut is_volatile: bool = false;
    if p.eat_kw("volatile") {
        is_volatile = true;
    }
    p.expect_op("{");
    let s: *Stmt = stmt_asm(line, col);
    s.is_volatile = is_volatile;
    // Instruction strings: contiguous run of TOK_STRING tokens.
    while p.current.kind == TOK_STRING {
        let lex: string = p.current.lexeme;
        let inner: string = lex.substring(1, lex.len() - 1);
        s.asm_strings.push(inner);
        p.advance();
    }
    // Optional sections: `: outs`, `: ins`, `: clobbers`. Each colon
    // unconditionally moves to the next slot, so `: : "r"(x)` skips outputs.
    let mut slot: i32 = 0; // 0=outs, 1=ins, 2=clobbers
    while p.eat_op(":") && slot < 3 {
        // Empty section is fine — just advance the slot.
        if p.at_op("}") || p.at_op(":") {
            slot = slot + 1;
            continue;
        }
        if slot == 2 {
            // Clobber list: just strings.
            while p.current.kind == TOK_STRING {
                let lex: string = p.current.lexeme;
                let inner: string = lex.substring(1, lex.len() - 1);
                s.asm_clobbers.push(inner);
                p.advance();
                if !p.eat_op(",") {
                    break;
                }
            }
        } else {
            // Operand list: `"constraint"(expr), ...`
            while p.current.kind == TOK_STRING {
                let lex: string = p.current.lexeme;
                let cstr: string = lex.substring(1, lex.len() - 1);
                p.advance();
                p.expect_op("(");
                let e: *Expr = parse_expr(p, 0);
                p.expect_op(")");
                if slot == 0 {
                    s.asm_out_constraints.push(cstr);
                    if e != null {
                        s.asm_out_exprs.push(*e);
                    }
                } else {
                    s.asm_in_constraints.push(cstr);
                    if e != null {
                        s.asm_in_exprs.push(*e);
                    }
                }
                if !p.eat_op(",") {
                    break;
                }
            }
        }
        slot = slot + 1;
    }
    p.expect_op("}");
    p.eat_op(";"); // optional trailing `;` — common style
    return s;
}

fn parse_stmt(p: *Parser) -> *Stmt {
    // Macro body repetition: `$( inner_stmts ) sep *` (sep = ';' or ',').
    // Only meaningful inside a macro def's body — outside, the expander will
    // surface an error if the rep escapes.
    if p.at_op("$") && p.peek_op("(") {
        let line: i32 = p.current.line;
        let col: i32 = p.current.column;
        p.advance(); // '$'
        p.advance(); // '('
        let inner: *Vector<Stmt> = Vector::new();
        while !p.at_op(")") && !p.at_eof() {
            let s2: *Stmt = parse_stmt(p);
            if s2 != null {
                inner.push(*s2);
            }
        }
        p.expect_op(")");
        let mut sep: string = "";
        if p.at_op(",") || p.at_op(";") {
            sep = p.current.lexeme;
            p.advance();
        }
        p.expect_op("*");
        let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
        s.kind = ST_MACRO_REP;
        s.line = line;
        s.column = col;
        s.then_body = inner;
        s.macro_rep_sep = sep;
        return s;
    }
    if p.at_kw("asm") && p.peek_op("!") {
        return parse_asm_block(p);
    }
    // `c_raw! { ... }` raw payload — captured by the lexer as TOK_RAW_BLOCK.
    if p.current.kind == TOK_RAW_BLOCK {
        let line: i32 = p.current.line;
        let col: i32 = p.current.column;
        let body: string = p.current.lexeme;
        p.advance();
        return stmt_craw(body, line, col);
    }
    // `select! { arm => { stmt; } ... }` builtin — race over chan ops.
    if p.current.kind == TOK_IDENT && p.current.lexeme.eq("select") && p.peek_op("!") {
        return parse_select_macro(p);
    }
    // Stmt-local attributes: `@allow(...) let x = …;` or
    // `@allow(...) { ... }`. Mirrors the top-level form so lints can
    // be suppressed at the precise binding (or block scope) the user
    // means without polluting the whole enclosing fn. Attached to
    // whichever Stmt parse_stmt returns; the helper `_apply_attrs`
    // covers every dispatch arm below.
    let body_attrs: *Vector<Attr> = Vector::new();
    let mut cfg: string = "";
    while p.at_op("@") {
        let at_line: i32 = p.current.line;
        let at_col: i32 = p.current.column;
        p.advance();
        let nm: string = p.expect_ident();
        let arg_exprs: *Vector<Expr> = Vector::new();
        if p.eat_op("(") {
            while !p.at_op(")") && !p.at_eof() {
                let e: *Expr = parse_expr(p, 0);
                if e != null {
                    arg_exprs.push(*e);
                }
                if !p.eat_op(",") {
                    break;
                }
            }
            p.expect_op(")");
        }
        if nm.eq("cfg") {
            // Statement-level `@cfg`: gates a single stmt (or `{ ... }` block)
            // behind the same #ifdef the top-level decl form uses, so
            // codegen's emit_cfg_open/close apply per-statement.
            if arg_exprs.len() == 1 {
                let a0: Expr = arg_exprs.get(0);
                if a0.kind == EX_STRING {
                    cfg = a0.str_val;
                } else {
                    p.err("@cfg expects a string literal: \"windows\" or \"posix\"");
                }
            } else {
                p.err("@cfg expects exactly one argument");
            }
            if !cfg.eq("windows") && !cfg.eq("posix") {
                p.err("unknown cfg target — expected `windows` or `posix`");
            }
        } else {
            body_attrs.push(Attr { name: nm, args: arg_exprs, line: at_line, column: at_col });
        }
    }
    if p.at_kw("asm") && p.peek_op("!") {
        return _apply_attrs(parse_asm_block(p), body_attrs, cfg);
    }
    if p.at_kw("let") {
        return _apply_attrs(parse_let(p), body_attrs, cfg);
    }
    if p.at_kw("const") {
        return _apply_attrs(parse_const(p), body_attrs, cfg);
    }
    if p.at_kw("return") {
        return _apply_attrs(parse_return(p), body_attrs, cfg);
    }
    if p.at_kw("if") {
        return _apply_attrs(parse_if(p), body_attrs, cfg);
    }
    if p.at_kw("while") {
        return _apply_attrs(parse_while(p), body_attrs, cfg);
    }
    if p.at_kw("for") {
        return _apply_attrs(parse_for(p), body_attrs, cfg);
    }
    if p.at_kw("match") {
        return _apply_attrs(parse_match(p), body_attrs, cfg);
    }
    if p.at_kw("defer") {
        let line: i32 = p.current.line;
        let col: i32 = p.current.column;
        p.advance();
        let e: *Expr = parse_expr(p, 0);
        p.expect_op(";");
        let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
        s.kind = ST_DEFER;
        s.line = line;
        s.column = col;
        s.expr_value = e;
        return _apply_attrs(s, body_attrs, cfg);
    }
    if p.at_kw("defer_err") {
        let line: i32 = p.current.line;
        let col: i32 = p.current.column;
        p.advance();
        let e: *Expr = parse_expr(p, 0);
        p.expect_op(";");
        let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
        s.kind = ST_DEFER_ERR;
        s.line = line;
        s.column = col;
        s.expr_value = e;
        return _apply_attrs(s, body_attrs, cfg);
    }
    if p.at_kw("spawn") {
        let line: i32 = p.current.line;
        let col: i32 = p.current.column;
        p.advance();
        let e: *Expr = parse_expr(p, 0);
        p.expect_op(";");
        return _apply_attrs(stmt_spawn(e, line, col), body_attrs, cfg);
    }
    if p.at_kw("spawn_thread") {
        let line: i32 = p.current.line;
        let col: i32 = p.current.column;
        p.advance();
        let e: *Expr = parse_expr(p, 0);
        p.expect_op(";");
        let s: *Stmt = stmt_spawn(e, line, col);
        if s != null {
            s.is_spawn_thread = true;
        }
        return _apply_attrs(s, body_attrs, cfg);
    }
    if p.at_kw("break") {
        let line: i32 = p.current.line;
        let col: i32 = p.current.column;
        p.advance();
        p.expect_op(";");
        return _apply_attrs(stmt_break(line, col), body_attrs, cfg);
    }
    if p.at_kw("continue") {
        let line: i32 = p.current.line;
        let col: i32 = p.current.column;
        p.advance();
        p.expect_op(";");
        return _apply_attrs(stmt_continue(line, col), body_attrs, cfg);
    }
    if p.at_op("{") {
        let body: *Vector<Stmt> = parse_block(p);
        let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
        s.kind = ST_BLOCK;
        s.then_body = body;
        return _apply_attrs(s, body_attrs, cfg);
    }
    // expression statement (with possible assign)
    let e: *Expr = parse_expr(p, 0);
    if e == null {
        return null;
    }
    let assigned: *Expr = parse_maybe_assign(p, e);
    p.expect_op(";");
    return _apply_attrs(stmt_expr(assigned), body_attrs, cfg);
}

// Attach a collected attribute list (and optional `@cfg` target) to the
// statement parse_stmt is about to return. Empty list is a no-op (no
// allocation either, since `body_attrs` is reused as the slot when
// non-empty); empty cfg leaves cfg_target untouched.
fn _apply_attrs(s: *Stmt, attrs: *Vector<Attr>, cfg: string) -> *Stmt {
    if s != null {
        if attrs != null && attrs.len() > 0 {
            s.attrs = attrs;
        }
        if cfg != null && !cfg.eq("") {
            s.cfg_target = cfg;
        }
    }
    return s;
}

fn parse_maybe_assign(p: *Parser, lhs: *Expr) -> *Expr {
    let mut op: i32 = 0;
    if p.at_op("=") {
        op = OP_ASSIGN;
    } else {
        if p.at_op("+=") {
            op = OP_PLUS_ASSIGN;
        } else {
            if p.at_op("-=") {
                op = OP_MINUS_ASSIGN;
            } else {
                if p.at_op("*=") {
                    op = OP_STAR_ASSIGN;
                } else {
                    if p.at_op("/=") {
                        op = OP_SLASH_ASSIGN;
                    } else {
                        if p.at_op("%=") {
                            op = OP_PERCENT_ASSIGN;
                        } else {
                            if p.at_op("&=") {
                                op = OP_BITAND_ASSIGN;
                            } else {
                                if p.at_op("|=") {
                                    op = OP_BITOR_ASSIGN;
                                } else {
                                    if p.at_op("^=") {
                                        op = OP_BITXOR_ASSIGN;
                                    } else {
                                        if p.at_op("<<=") {
                                            op = OP_SHL_ASSIGN;
                                        } else {
                                            if p.at_op(">>=") {
                                                op = OP_SHR_ASSIGN;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    if op == 0 {
        return lhs;
    }
    // Anchor the node at the assignment operator so an assignment-type-mismatch
    // diagnostic underlines the `=` (or `+=`, …), not the target variable.
    let op_line: i32 = p.current.line;
    let op_col: i32 = p.current.column;
    p.advance();
    let rhs_raw: *Expr = parse_expr(p, 0);
    let rhs: *Expr = parse_maybe_assign(p, rhs_raw);
    let a: *Expr = expr_assign(op, lhs, rhs);
    a.line = op_line;
    a.column = op_col;
    return a;
}

fn parse_let(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'let'
    let mut is_mut: bool = false;
    if p.eat_kw("mut") {
        is_mut = true;
    }
    // Tuple destructuring: `let (a, b, c) = expr;`. Binds each name to the
    // corresponding tuple element. The element types come from the value's
    // tuple type, so no per-name annotation is accepted in this form.
    if p.at_op("(") {
        p.advance();
        let names: *Vector<string> = Vector::new();
        let nlines: *Vector<i32> = Vector::new();
        let ncols: *Vector<i32> = Vector::new();
        let nmuts: *Vector<bool> = Vector::new();
        while !p.at_op(")") && !p.at_eof() {
            // Per-binding `mut` (`let (mut x, y) = …`); a statement-level
            // `let mut (…)` marks every binding.
            let bind_mut: bool = p.eat_kw("mut");
            nmuts.push(bind_mut || is_mut);
            nlines.push(p.current.line);
            ncols.push(p.current.column);
            names.push(p.expect_binder_ident());
            if !p.eat_op(",") {
                break;
            }
        }
        p.expect_op(")");
        let mut dval: *Expr = null;
        if p.eat_op("=") {
            dval = parse_expr(p, 0);
        }
        p.expect_op(";");
        let ds: *Stmt = stmt_let("", null, dval, is_mut, line, col);
        ds.let_names = names;
        ds.let_name_lines = nlines;
        ds.let_name_cols = ncols;
        ds.let_muts = nmuts;
        return ds;
    }
    let nline: i32 = p.current.line;
    let ncol: i32 = p.current.column;
    let nlen: i32 = p.current.lexeme.len();
    let name: string = p.expect_binder_ident();
    // Postfix `*` on the binding: explicit auto-drop ownership marker.
    let mut is_auto_owned: bool = false;
    if p.eat_op("*") {
        is_auto_owned = true;
    }
    let mut ty: *Type = null;
    if p.eat_op(":") {
        ty = parse_type(p);
    }
    let mut value: *Expr = null;
    if p.eat_op("=") {
        value = parse_expr(p, 0);
    }
    p.expect_op(";");
    let s: *Stmt = stmt_let(name, ty, value, is_mut, line, col);
    s.is_auto_owned = is_auto_owned;
    s.name_line = nline;
    s.name_col = ncol;
    s.name_len = nlen;
    return s;
}

fn parse_const(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'const'
    let nline: i32 = p.current.line;
    let ncol: i32 = p.current.column;
    let nlen: i32 = p.current.lexeme.len();
    let name: string = p.expect_binder_ident();
    let mut ty: *Type = null;
    if p.eat_op(":") {
        ty = parse_type(p);
    }
    p.expect_op("=");
    let value: *Expr = parse_expr(p, 0);
    p.expect_op(";");
    let s: *Stmt = stmt_const(name, ty, value, line, col);
    if s != null {
        s.name_line = nline;
        s.name_col = ncol;
        s.name_len = nlen;
    }
    return s;
}

fn parse_return(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'return'
    let mut value: *Expr = null;
    if !p.at_op(";") {
        value = parse_expr(p, 0);
    }
    p.expect_op(";");
    return stmt_return(value, line, col);
}

fn parse_match(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'match'
    let saved: bool = p.no_struct_lit;
    p.no_struct_lit = true;
    let scrut: *Expr = parse_expr(p, 0);
    p.no_struct_lit = saved;
    p.expect_op("{");
    let arms: *Vector<MatchArm> = Vector::new();
    while !p.at_op("}") && !p.at_eof() {
        let arm_lead: string = p.current.lead;
        let mut variant: string = "_";
        let mut qual: string = "";
        let bindings: *Vector<string> = Vector::new();
        // Literal pattern: `0 =>`, `-3 =>`, `"s" =>`, `'c' =>`. The arm
        // dispatches on value equality (codegen lowers to an if/else chain),
        // so the typer requires a `_` arm alongside. `variant` keeps the
        // literal's source text for the formatter round-trip.
        let mut lit: *Expr = null;
        let lit_line: i32 = p.current.line;
        let lit_col: i32 = p.current.column;
        let mut lit_neg: bool = false;
        if p.at_op("-") {
            // In pattern position a `-` can only start a numeric literal.
            p.advance();
            lit_neg = true;
        }
        if p.current.kind == TOK_INT {
            let lit_lex: string = p.current.lexeme;
            p.advance();
            let mut lit_v: i64 = parse_int_lexeme(lit_lex);
            variant = lit_lex;
            if lit_neg {
                lit_v = 0 - lit_v;
                variant = "-".concat(lit_lex);
            }
            lit = expr_int(lit_v, lit_line, lit_col);
        } else if p.current.kind == TOK_STRING && !lit_neg {
            let lit_lex: string = p.current.lexeme;
            p.advance();
            let lit_inner: string = lit_lex.substring(1, lit_lex.len() - 1);
            lit = build_string_or_interp(p, lit_inner, lit_line, lit_col);
            variant = lit_lex;
        } else if p.current.kind == TOK_CHAR && !lit_neg {
            let lit_lex: string = p.current.lexeme;
            p.advance();
            let lit_inner: string = lit_lex.substring(1, lit_lex.len() - 1);
            lit = expr_char(decode_char_inner(lit_inner), lit_line, lit_col);
            variant = lit_lex;
        } else if lit_neg {
            p.err("expected a numeric literal after `-` in a match pattern");
        }
        if p.current.kind == TOK_IDENT {
            let first: string = p.current.lexeme;
            p.advance();
            variant = first;
            // The LAST `::` segment is the variant; the segments before it
            // (`foo::Color` in `foo::Color::Red`) ride along as `qual` so the
            // typer can require them to name the scrutinee's enum — a dropped
            // qualifier let `WrongEnum::Red` match any enum with a `Red`.
            while p.eat_op("::") {
                if qual.eq("") {
                    qual = variant;
                } else {
                    qual = qual.concat("::").concat(variant);
                }
                variant = p.expect_ident();
            }
            if p.eat_op("(") {
                while !p.at_op(")") && !p.at_eof() {
                    bindings.push(p.expect_ident());
                    if !p.eat_op(",") {
                        break;
                    }
                }
                p.expect_op(")");
            }
        }
        p.expect_op("=>");
        let body: *Vector<Stmt> = Vector::new();
        if p.at_op("{") {
            let blk: *Vector<Stmt> = parse_block(p);
            for let i: i32 = 0; i < blk.len(); i++ {
                body.push(blk.get(i));
            }
        } else {
            let e: *Expr = parse_expr(p, 0);
            let ass: *Expr = parse_maybe_assign(p, e);
            body.push(*stmt_expr(ass));
        }
        let mut arm: MatchArm = MatchArm { variant: variant, qualifier: qual, bindings: bindings, body: body, line: lit_line, col: lit_col, lead: arm_lead, trail: "", lit: lit };
        p.eat_op(",");
        if p.current.trail != null && !p.current.trail.eq("") {
            arm.trail = p.current.trail;
        }
        arms.push(arm);
    }
    p.expect_op("}");
    return stmt_match(scrut, arms, line, col);
}

// Expression-position `match`. Each arm body is either:
//   - a single expression (e.g. `A => 1`), which is the arm's VALUE;
//   - a block, whose trailing expression statement (if any) is the value.
// A user-written `return` inside an arm exits the ENCLOSING FUNCTION (like
// Rust); it never yields the arm. The codegen lowers the whole match to a
// GCC stmt-expression.
fn parse_match_expr(p: *Parser) -> *Expr {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'match'
    let saved: bool = p.no_struct_lit;
    p.no_struct_lit = true;
    let scrut: *Expr = parse_expr(p, 0);
    p.no_struct_lit = saved;
    p.expect_op("{");
    let arms: *Vector<MatchArm> = Vector::new();
    while !p.at_op("}") && !p.at_eof() {
        let arm_lead: string = p.current.lead;
        let mut variant: string = "_";
        let mut qual: string = "";
        let bindings: *Vector<string> = Vector::new();
        // Literal pattern: `0 =>`, `-3 =>`, `"s" =>`, `'c' =>`. The arm
        // dispatches on value equality (codegen lowers to an if/else chain),
        // so the typer requires a `_` arm alongside. `variant` keeps the
        // literal's source text for the formatter round-trip.
        let mut lit: *Expr = null;
        let lit_line: i32 = p.current.line;
        let lit_col: i32 = p.current.column;
        let mut lit_neg: bool = false;
        if p.at_op("-") {
            // In pattern position a `-` can only start a numeric literal.
            p.advance();
            lit_neg = true;
        }
        if p.current.kind == TOK_INT {
            let lit_lex: string = p.current.lexeme;
            p.advance();
            let mut lit_v: i64 = parse_int_lexeme(lit_lex);
            variant = lit_lex;
            if lit_neg {
                lit_v = 0 - lit_v;
                variant = "-".concat(lit_lex);
            }
            lit = expr_int(lit_v, lit_line, lit_col);
        } else if p.current.kind == TOK_STRING && !lit_neg {
            let lit_lex: string = p.current.lexeme;
            p.advance();
            let lit_inner: string = lit_lex.substring(1, lit_lex.len() - 1);
            lit = build_string_or_interp(p, lit_inner, lit_line, lit_col);
            variant = lit_lex;
        } else if p.current.kind == TOK_CHAR && !lit_neg {
            let lit_lex: string = p.current.lexeme;
            p.advance();
            let lit_inner: string = lit_lex.substring(1, lit_lex.len() - 1);
            lit = expr_char(decode_char_inner(lit_inner), lit_line, lit_col);
            variant = lit_lex;
        } else if lit_neg {
            p.err("expected a numeric literal after `-` in a match pattern");
        }
        if p.current.kind == TOK_IDENT {
            let first: string = p.current.lexeme;
            p.advance();
            variant = first;
            // The LAST `::` segment is the variant; the segments before it
            // (`foo::Color` in `foo::Color::Red`) ride along as `qual` so the
            // typer can require them to name the scrutinee's enum — a dropped
            // qualifier let `WrongEnum::Red` match any enum with a `Red`.
            while p.eat_op("::") {
                if qual.eq("") {
                    qual = variant;
                } else {
                    qual = qual.concat("::").concat(variant);
                }
                variant = p.expect_ident();
            }
            if p.eat_op("(") {
                while !p.at_op(")") && !p.at_eof() {
                    bindings.push(p.expect_ident());
                    if !p.eat_op(",") {
                        break;
                    }
                }
                p.expect_op(")");
            }
        }
        p.expect_op("=>");
        let body: *Vector<Stmt> = Vector::new();
        if p.at_op("{") {
            let blk: *Vector<Stmt> = parse_block(p);
            for let i: i32 = 0; i < blk.len(); i++ {
                body.push(blk.get(i));
            }
        } else {
            // Bare `=> expr` arm: the expression is the arm's VALUE. It rides
            // in a synthesized return marked `is_arm_yield` so a user-written
            // `return` (which exits the enclosing fn, like Rust) stays distinct.
            let e: *Expr = parse_expr(p, 0);
            let yr: *Stmt = stmt_return(e, line, col);
            yr.is_arm_yield = true;
            body.push(*yr);
        }
        let mut arm: MatchArm = MatchArm { variant: variant, qualifier: qual, bindings: bindings, body: body, line: lit_line, col: lit_col, lead: arm_lead, trail: "", lit: lit };
        p.eat_op(",");
        if p.current.trail != null && !p.current.trail.eq("") {
            arm.trail = p.current.trail;
        }
        arms.push(arm);
    }
    p.expect_op("}");
    return expr_match(scrut, arms, line, col);
}

// `select! { arm => { stmt } ... }` — race over chan ops.
//
// Arm forms:
//   var = c.recv() => { ... }     // bind T value (close ignored)
//   some(v) = c.recv() => { ... } // fires only on value, binds payload
//   none = c.recv() => { ... }    // fires only on chan closed + drained
//   c.send(v) => { ... }          // fires when send completes
//   default => { ... }            // non-blocking fallback
fn parse_select_macro(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'select'
    p.expect_op("!");
    p.expect_op("{");
    let arms: *Vector<SelectArm> = Vector::new();
    while !p.at_op("}") && !p.at_eof() {
        let arm: *SelectArm = parse_select_arm(p);
        if arm != null {
            arms.push(*arm);
        }
        // Optional separator between arms (unnecessary since bodies are blocks,
        // but accepted for visual rhythm).
        p.eat_op(",");
        p.eat_op(";");
    }
    p.expect_op("}");
    let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
    s.kind = ST_SELECT;
    s.line = line;
    s.column = col;
    s.select_arms = arms;
    return s;
}

fn select_extract_recv_chan(p: *Parser, e: *Expr) -> *Expr {
    if e == null || e.kind != EX_CALL || e.lhs == null || e.lhs.kind != EX_MEMBER || !e.lhs.field.eq("recv") {
        p.err("select arm RHS must be `chan.recv()`");
        return null;
    }
    if e.args != null && e.args.len() != 0 {
        p.err("`chan.recv()` takes no args");
        return null;
    }
    return e.lhs.lhs;
}

fn parse_select_arm(p: *Parser) -> *SelectArm {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    let lhs: *Expr = parse_expr(p, 0);
    if lhs == null {
        return null;
    }
    if p.at_op("=") {
        p.advance(); // '='
        let rhs: *Expr = parse_expr(p, 0);
        if rhs == null {
            return null;
        }
        p.expect_op("=>");
        let body: *Vector<Stmt> = parse_block(p);
        // Dispatch on LHS shape.
        if lhs.kind == EX_IDENT {
            let name: string = lhs.str_val;
            if name.eq("none") || name.eq("None") {
                let ch: *Expr = select_extract_recv_chan(p, rhs);
                let arm: *SelectArm = __glide_palloc(sizeof(SelectArm)) as *SelectArm;
                arm.kind = SEL_RECV_NONE;
                arm.chan_expr = ch;
                arm.body = body;
                arm.line = line;
                arm.column = col;
                return arm;
            }
            // var = chan.recv() => body
            let ch: *Expr = select_extract_recv_chan(p, rhs);
            let arm: *SelectArm = __glide_palloc(sizeof(SelectArm)) as *SelectArm;
            arm.kind = SEL_RECV;
            arm.chan_expr = ch;
            arm.bind_name = name;
            arm.body = body;
            arm.line = line;
            arm.column = col;
            return arm;
        }
        if lhs.kind == EX_CALL && lhs.lhs != null && lhs.lhs.kind == EX_IDENT {
            let cname: string = lhs.lhs.str_val;
            if (cname.eq("some") || cname.eq("Some")) && lhs.args != null && lhs.args.len() == 1 {
                let arg0: Expr = lhs.args.get(0);
                if arg0.kind == EX_IDENT {
                    let ch: *Expr = select_extract_recv_chan(p, rhs);
                    let arm: *SelectArm = __glide_palloc(sizeof(SelectArm)) as *SelectArm;
                    arm.kind = SEL_RECV_SOME;
                    arm.chan_expr = ch;
                    arm.bind_name = arg0.str_val;
                    arm.body = body;
                    arm.line = line;
                    arm.column = col;
                    return arm;
                }
            }
        }
        p.err("invalid recv-arm pattern (use `var = chan.recv()`, `some(v) = chan.recv()`, or `none = chan.recv()`)");
        return null;
    }
    if p.at_op("=>") {
        p.advance(); // '=>'
        let body: *Vector<Stmt> = parse_block(p);
        if lhs.kind == EX_IDENT && lhs.str_val.eq("default") {
            let arm: *SelectArm = __glide_palloc(sizeof(SelectArm)) as *SelectArm;
            arm.kind = SEL_DEFAULT;
            arm.body = body;
            arm.line = line;
            arm.column = col;
            return arm;
        }
        if lhs.kind == EX_CALL && lhs.lhs != null && lhs.lhs.kind == EX_MEMBER && lhs.lhs.field.eq("send") && lhs.args != null && lhs.args.len() == 1 {
            let arg0: Expr = lhs.args.get(0);
            let arg_ptr: *Expr = __glide_palloc(sizeof(Expr)) as *Expr;
            *arg_ptr = arg0;
            let arm: *SelectArm = __glide_palloc(sizeof(SelectArm)) as *SelectArm;
            arm.kind = SEL_SEND;
            arm.chan_expr = lhs.lhs.lhs;
            arm.send_value = arg_ptr;
            arm.body = body;
            arm.line = line;
            arm.column = col;
            return arm;
        }
        p.err("invalid select arm (expected `chan.send(v) =>` or `default =>`)");
        return null;
    }
    p.err("expected '=' or '=>' in select arm");
    return null;
}

// Expression-position block. `{ stmt; stmt; return val; }` produces
// `val`. The trailing `return val;` MUST be the last stmt; everything
// before it runs for side effects, and `val` is the block's value.
fn parse_block_expr(p: *Parser) -> *Expr {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.expect_op("{");
    let stmts: *Vector<Stmt> = Vector::new();
    while !p.at_op("}") && !p.at_eof() {
        let doc: string = p.current.doc;
        let lead: string = p.current.lead;
        let s: *Stmt = parse_stmt(p);
        if s != null {
            if doc != null && !doc.eq("") {
                s.doc_comment = doc;
            }
            if lead != null && !lead.eq("") {
                s.leading_comments = lead;
            }
            if p.current.trail != null && !p.current.trail.eq("") {
                s.trailing_comment = p.current.trail;
            }
            stmts.push(*s);
        }
    }
    p.expect_op("}");
    let mut value: *Expr = null;
    if stmts.len() > 0 {
        let last: Stmt = stmts.get(stmts.len() - 1);
        if last.kind == ST_RETURN && last.expr_value != null {
            value = last.expr_value;
            stmts.pop();
        }
    }
    if value == null {
        p.push_pdiag(line, col, 1, "parse", "block expression must end with `return <expr>;`", 0, 0, 0, 0, "");
        value = expr_int(0, line, col);
    }
    return expr_block(stmts, value, line, col);
}

// Expression-position `if`. Both branches must be a single expression
// (`if c { e } else { e }`); the codegen lowers it to a C ternary.
// Statement-position `if cond { stmts; }` keeps its existing
// stmt-level parser (parse_if).
fn parse_if_expr(p: *Parser) -> *Expr {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'if'
    let saved: bool = p.no_struct_lit;
    p.no_struct_lit = true;
    let cond: *Expr = parse_expr(p, 0);
    p.no_struct_lit = saved;
    p.expect_op("{");
    let then_e: *Expr = parse_expr(p, 0);
    p.expect_op("}");
    if !p.eat_kw("else") {
        // Without else, no value to produce — fall back to the stmt
        // form by synthesising a null else branch. The typer rejects
        // expression-position if without else.
        return expr_if(cond, then_e, null, line, col);
    }
    let else_e: *Expr;
    if p.at_kw("if") {
        else_e = parse_if_expr(p);
    } else {
        p.expect_op("{");
        else_e = parse_expr(p, 0);
        p.expect_op("}");
    }
    return expr_if(cond, then_e, else_e, line, col);
}

// `if let <ctor>(<bind>?) = <expr> { then } [else { else }]`, where `ctor` is
// one of some / none / ok / err. Produces a surface ST_IF_LET node so `glide
// fmt` round-trips it; lower.glide desugars it to a scoped temp + `.has`/`.ok`
// test before the typer/codegen (mirrors ST_FOR_IN / ST_WHILE_RECV).
fn parse_if_let(p: *Parser, line: i32, col: i32) -> *Stmt {
    p.advance(); // 'let'
    let ctor: string = p.expect_ident();
    let binds: *Vector<string> = Vector::new();
    if p.eat_op("(") {
        if !p.at_op(")") {
            binds.push(p.expect_ident());
        }
        p.expect_op(")");
    }
    if !ctor.eq("some") && !ctor.eq("none") && !ctor.eq("ok") && !ctor.eq("err") {
        p.err("`if let` pattern must be some / none / ok / err");
    }
    p.expect_op("=");
    let saved: bool = p.no_struct_lit;
    p.no_struct_lit = true;
    let scrut: *Expr = parse_expr(p, 0);
    p.no_struct_lit = saved;
    let then_body: *Vector<Stmt> = parse_block(p);
    let mut else_body: *Vector<Stmt> = null;
    if p.eat_kw("else") {
        if p.at_kw("if") {
            let inner: *Stmt = parse_if(p);
            let one: *Vector<Stmt> = Vector::new();
            if inner != null {
                one.push(*inner);
            }
            else_body = one;
        } else {
            else_body = parse_block(p);
        }
    }
    let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
    ast_fill_defaults(s);
    s.kind = ST_IF_LET;
    s.line = line;
    s.column = col;
    s.name = ctor;
    s.let_names = binds;
    s.let_value = scrut;
    s.then_body = then_body;
    s.else_body = else_body;
    return s;
}

fn parse_if(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'if'
    if p.at_kw("let") {
        return parse_if_let(p, line, col);
    }
    let saved: bool = p.no_struct_lit;
    p.no_struct_lit = true;
    let cond: *Expr = parse_expr(p, 0);
    p.no_struct_lit = saved;
    let then_body: *Vector<Stmt> = parse_block(p);
    let mut else_body: *Vector<Stmt> = null;
    if p.eat_kw("else") {
        if p.at_kw("if") {
            let inner: *Stmt = parse_if(p);
            let one: *Vector<Stmt> = Vector::new();
            if inner != null {
                one.push(*inner);
            }
            else_body = one;
        } else {
            else_body = parse_block(p);
        }
    }
    return stmt_if(cond, then_body, else_body, line, col);
}

fn parse_while(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'while'
    // chan-aware while-let: `while let v [: T] = recv_expr { body }`.
    // Lowered at codegen to a __glide_recv_into_<m>(c, &v) loop. Detects
    // EOF without the zero-value sentinel.
    if p.at_kw("let") {
        let nline: i32 = p.peek.line;
        let ncol: i32 = p.peek.column;
        let nlen: i32 = p.peek.lexeme.len();
        p.advance(); // 'let'
        let var_name: string = p.expect_binder_ident();
        let mut ty: *Type = null;
        if p.eat_op(":") {
            ty = parse_type(p);
        }
        p.expect_op("=");
        let saved: bool = p.no_struct_lit;
        p.no_struct_lit = true;
        let recv: *Expr = parse_expr(p, 0);
        p.no_struct_lit = saved;
        let body: *Vector<Stmt> = parse_block(p);
        let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
        s.kind = ST_WHILE_RECV;
        s.line = line;
        s.column = col;
        s.name = var_name;
        s.name_line = nline;
        s.name_col = ncol;
        s.name_len = nlen;
        s.let_ty = ty;
        s.let_value = recv;
        s.then_body = body;
        return s;
    }
    let saved: bool = p.no_struct_lit;
    p.no_struct_lit = true;
    let cond: *Expr = parse_expr(p, 0);
    p.no_struct_lit = saved;
    let body: *Vector<Stmt> = parse_block(p);
    return stmt_while(cond, body, line, col);
}

fn parse_for(p: *Parser) -> *Stmt {
    let line: i32 = p.current.line;
    let col: i32 = p.current.column;
    p.advance(); // 'for'
    // for-in form: `for IDENT in EXPR { body }`. Distinguishes from the
    // C-style by checking that current is a bare identifier AND the next
    // token is the `in` keyword.
    if p.current.kind == TOK_IDENT && p.peek.kind == TOK_KEYWORD && p.peek.lexeme.eq("in") {
        return parse_for_in(p, line, col);
    }
    let saved: bool = p.no_struct_lit;
    p.no_struct_lit = true;
    let mut init: *Stmt = null;
    if !p.at_op(";") {
        if p.at_kw("let") {
            // parse let WITHOUT the trailing semicolon
            let l_line: i32 = p.current.line;
            let l_col: i32 = p.current.column;
            p.advance(); // 'let'
            let mut is_mut: bool = false;
            if p.eat_kw("mut") {
                is_mut = true;
            }
            let lname: string = p.expect_binder_ident();
            let mut lty: *Type = null;
            if p.eat_op(":") {
                lty = parse_type(p);
            }
            let mut lval: *Expr = null;
            if p.eat_op("=") {
                lval = parse_expr(p, 0);
            }
            init = stmt_let(lname, lty, lval, is_mut, l_line, l_col);
        } else {
            let e: *Expr = parse_expr(p, 0);
            let assigned: *Expr = parse_maybe_assign(p, e);
            init = stmt_expr(assigned);
        }
    }
    p.expect_op(";");
    let mut cond: *Expr = null;
    if !p.at_op(";") {
        cond = parse_expr(p, 0);
    }
    p.expect_op(";");
    let mut step: *Expr = null;
    if !p.at_op("{") {
        let e: *Expr = parse_expr(p, 0);
        step = parse_maybe_assign(p, e);
    }
    p.no_struct_lit = saved;
    let body: *Vector<Stmt> = parse_block(p);
    return stmt_for(init, cond, step, body, line, col);
}

// `for IDENT in EXPR [..[=] EXPR] { body }` — kept as ST_FOR_IN in the AST so
// the formatter can re-emit the original sugar. A lowering pass run between
// parse and typer rewrites it into the existing ST_FOR / ST_BLOCK shape.
//
//   ST_FOR_IN encoding:
//     name        = binder
//     let_value   = `lo` (range) OR the iter expr (collection)
//     cond        = `hi` (range) OR null (collection)
//     is_mut      = true means inclusive range (`..=`)
//     then_body   = body
fn parse_for_in(p: *Parser, line: i32, col: i32) -> *Stmt {
    let nline: i32 = p.current.line;
    let ncol: i32 = p.current.column;
    let nlen: i32 = p.current.lexeme.len();
    let var_name: string = p.expect_ident();
    p.advance(); // 'in'
    let saved: bool = p.no_struct_lit;
    p.no_struct_lit = true;
    let lo: *Expr = parse_expr(p, 0);
    let mut hi: *Expr = null;
    let mut inclusive: bool = false;
    if p.at_op("..") || p.at_op("..=") {
        if p.at_op("..=") {
            inclusive = true;
        }
        p.advance();
        hi = parse_expr(p, 0);
    }
    p.no_struct_lit = saved;
    let body: *Vector<Stmt> = parse_block(p);
    let s: *Stmt = __glide_palloc(sizeof(Stmt)) as *Stmt;
    s.kind = ST_FOR_IN;
    s.line = line;
    s.column = col;
    s.name = var_name;
    s.name_line = nline;
    s.name_col = ncol;
    s.name_len = nlen;
    s.let_value = lo;
    s.cond = hi;
    s.is_mut = inclusive;
    s.then_body = body;
    return s;
}

// ---- types ---------------------------------------------------------------

// True when the current token can start a type. Used to disambiguate the
// `!` shorthand for Result-without-value (`-> !`) from `!T` (Result-of-T).
fn at_type_start(p: *Parser) -> bool {
    let k: i32 = p.current.kind;
    if k == TOK_IDENT {
        return true;
    }
    if k == TOK_KEYWORD {
        let lex: string = p.current.lexeme;
        if lex.eq("chan") {
            return true;
        }
        if lex.eq("dyn") {
            return true;
        }
        if lex.eq("fn") {
            return true;
        }
        return false;
    }
    if k == TOK_OP {
        let lex: string = p.current.lexeme;
        if lex.eq("*") {
            return true;
        }
        if lex.eq("&") {
            return true;
        }
        if lex.eq("[") {
            return true;
        }
        if lex.eq("?") {
            return true;
        }
        if lex.eq("!") {
            return true;
        }
        if lex.eq("(") {
            return true;
        } // tuple type `(A, B, ...)`
        return false;
    }
    return false;
}

fn parse_type(p: *Parser) -> *Type {
    if p.eat_op("!") {
        // `!` solo (no inner type) = Result-without-value. Used for fns that
        // either succeed or fail with no payload: `fn os_chdir(...) -> !`.
        // If a token that can start a type follows, parse normally as `!T`.
        if !at_type_start(p) {
            return ty_result(ty_named("void"));
        }
        let inner: *Type = parse_type(p);
        return ty_result(inner);
    }
    // `?T` (Option) and `?!T` (Option-or-Err, 3 variants Some|None|Err).
    if p.eat_op("?") {
        if p.eat_op("!") {
            let inner: *Type = parse_type(p);
            return ty_optres(inner);
        }
        let inner: *Type = parse_type(p);
        return ty_option(inner);
    }
    if p.eat_op("*") {
        let inner: *Type = parse_type(p);
        return ty_pointer(inner);
    }
    // `dyn TraitName` - trait object. Must appear behind a pointer
    // (`*dyn Trait`) since the size depends on the runtime type.
    if p.at_kw("dyn") {
        p.advance();
        // Accept a module-qualified trait (`dyn alelo::Pinto`): keep the last
        // segment as the trait name (codegen builds identifiers from it) and
        // remember the qualifier in `inner` so an unused-import scan still sees
        // the module reference.
        let mut name: string = p.expect_ident();
        let mut qualifier: string = "";
        while p.at_op("::") {
            p.advance();
            qualifier = name;
            name = p.expect_ident();
        }
        let t: *Type = __glide_palloc(sizeof(Type)) as *Type;
        t.kind = TY_DYN;
        t.name = name;
        if !qualifier.eq("") {
            t.inner = ty_named(qualifier);
        }
        return t;
    }
    if p.eat_op("&") {
        if p.eat_kw("mut") {
            let inner: *Type = parse_type(p);
            let t: *Type = __glide_palloc(sizeof(Type)) as *Type;
            t.kind = TY_BORROW_MUT;
            t.inner = inner;
            return t;
        }
        let inner: *Type = parse_type(p);
        let t: *Type = __glide_palloc(sizeof(Type)) as *Type;
        t.kind = TY_BORROW;
        t.inner = inner;
        return t;
    }
    if p.at_op("[") && p.peek_op("]") {
        p.advance();
        p.advance();
        let inner: *Type = parse_type(p);
        let t: *Type = __glide_palloc(sizeof(Type)) as *Type;
        t.kind = TY_SLICE;
        t.inner = inner;
        return t;
    }
    if p.at_kw("fn") {
        p.advance();
        p.expect_op("(");
        let params: *Vector<Type> = Vector::new();
        while !p.at_op(")") && !p.at_eof() {
            if p.current.kind == TOK_IDENT && p.peek_op(":") {
                p.advance();
                p.advance();
            }
            let t: *Type = parse_type(p);
            if t != null {
                params.push(*t);
            }
            if !p.eat_op(",") {
                break;
            }
        }
        p.expect_op(")");
        let mut ret: *Type = null;
        if p.eat_op("->") {
            ret = parse_type(p);
        }
        return ty_fnptr(params, ret);
    }
    // Tuple type `(A, B, ...)`. `()` is the unit tuple; `(T)` with no comma is
    // just a parenthesized `T`; a trailing comma (`(T,)`) forces a 1-tuple.
    if p.at_op("(") {
        p.advance();
        let elems: *Vector<Type> = Vector::new();
        let mut saw_comma: bool = false;
        while !p.at_op(")") && !p.at_eof() {
            let et: *Type = parse_type(p);
            if et != null {
                elems.push(*et);
            }
            if p.eat_op(",") {
                saw_comma = true;
            } else {
                break;
            }
        }
        p.expect_op(")");
        if elems.len() == 1 && !saw_comma {
            let only: Type = elems.get(0);
            let p0: *Type = __glide_palloc(sizeof(Type)) as *Type;
            *p0 = only;
            return p0;
        }
        return ty_tuple(elems);
    }
    if p.current.kind == TOK_IDENT || p.current.kind == TOK_KEYWORD {
        let nl: i32 = p.current.line;
        let nc: i32 = p.current.column;
        let name: string = p.current.lexeme;
        p.advance();
        // Generic instantiation: Foo<T1, T2>. Handles nested forms like
        // `chan<Vector<int>>` by splitting a trailing `>>` token.
        if p.at_op("<") {
            p.advance();
            let args: *Vector<Type> = Vector::new();
            while !p.at_close_angle() && !p.at_eof() {
                let inner: *Type = parse_type(p);
                if inner != null {
                    args.push(*inner);
                }
                if !p.eat_op(",") {
                    break;
                }
            }
            p.consume_close_angle();
            let gt: *Type = ty_generic(name, args);
            gt.line = nl;
            gt.col = nc;
            return gt;
        }
        // Associated type projection: `Owner::Name` (e.g. `Self::Item`,
        // `T::Item`). Owner is the bare ident parsed above.
        if p.at_op("::") {
            p.advance();
            let assoc_name: string = p.expect_ident();
            // `module::Type<G, ...>` — a module-qualified generic type.
            // The module is just a namespace qualifier, so strip it and
            // build the generic type on the bare name (matching how the
            // typer resolves `module::Type::method` expressions).
            if p.at_op("<") {
                p.advance();
                let gargs: *Vector<Type> = Vector::new();
                while !p.at_close_angle() && !p.at_eof() {
                    let ginner: *Type = parse_type(p);
                    if ginner != null {
                        gargs.push(*ginner);
                    }
                    if !p.eat_op(",") {
                        break;
                    }
                }
                p.consume_close_angle();
                let qgt: *Type = ty_generic(assoc_name, gargs);
                qgt.line = nl;
                qgt.col = nc;
                return qgt;
            }
            return ty_assoc(ty_named(name), assoc_name);
        }
        let nt: *Type = ty_named(name);
        nt.line = nl;
        nt.col = nc;
        return nt;
    }
    p.err("expected type");
    return ty_named("__error__");
}

// ---- expressions (Pratt) -------------------------------------------------
fn parse_expr(p: *Parser, min_bp: i32) -> *Expr {
    let mut left: *Expr = parse_prefix(p);
    if left == null {
        return null;
    }
    while true {
        // postfix call ()
        if p.at_op("(") {
            p.advance();
            let args: *Vector<Expr> = Vector::new();
            while !p.at_op(")") && !p.at_eof() {
                let a: *Expr = parse_expr(p, 0);
                if a != null {
                    args.push(*a);
                }
                if !p.eat_op(",") {
                    break;
                }
            }
            p.expect_op(")");
            left = expr_call(left, args);
            continue;
        }
        // index []  — plain `[i]` or range slice `[lo..hi]` / `[lo..=hi]`
        if p.at_op("[") {
            let bline: i32 = p.current.line;
            let bcol: i32 = p.current.column;
            p.advance();
            let idx: *Expr = parse_expr(p, 0);
            if p.at_op("..") || p.at_op("..=") {
                let inclusive: bool = p.at_op("..=");
                p.advance();
                let hi: *Expr = parse_expr(p, 0);
                p.expect_op("]");
                left = expr_index(left, expr_range(idx, hi, inclusive, bline, bcol));
                continue;
            }
            p.expect_op("]");
            left = expr_index(left, idx);
            continue;
        }
        // member .  (with macro-call form `.name!(args)`)
        if p.at_op(".") {
            p.advance();
            let fname_line: i32 = p.current.line;
            let fname_col: i32 = p.current.column;
            // Tuple index: `t.0`, `t.1`. The field name is the integer lexeme.
            if p.current.kind == TOK_INT {
                let idx: string = p.current.lexeme;
                p.advance();
                left = expr_member(left, idx);
                left.field_line = fname_line;
                left.field_col = fname_col;
                continue;
            }
            // Nested tuple index `t.0.1`: the lexer greedily reads `0.1` as a
            // single float token, so split it back into two index accesses.
            if p.current.kind == TOK_FLOAT {
                let lex: string = p.current.lexeme;
                p.advance();
                let mut dot: i32 = 0;
                let ln: i32 = lex.len();
                while dot < ln && lex.at(dot).to_int() != 46 {
                    dot = dot + 1;
                }
                let a_idx: string = lex.substring(0, dot);
                let b_idx: string = lex.substring(dot + 1, ln);
                left = expr_member(left, a_idx);
                left.field_line = fname_line;
                left.field_col = fname_col;
                left = expr_member(left, b_idx);
                left.field_line = fname_line;
                left.field_col = fname_col;
                continue;
            }
            let mut mname: string = p.expect_ident();
            // Qualified method call `expr.NS::method(...)` — disambiguates when
            // multiple `impl T in NS { ... }` blocks register the same method
            // name. We encode the namespace into the member field as
            // `NS::method` (a single string with `::` inside) so codegen can
            // split it later and emit `NS_T_method(receiver, args)` directly.
            if p.at_op("::") {
                p.advance();
                let real: string = p.expect_ident();
                mname = mname.concat("::").concat(real);
            }
            if p.at_op("!") && p.peek_op("(") {
                p.advance(); // '!'
                p.advance(); // '('
                let margs: *Vector<Expr> = Vector::new();
                while !p.at_op(")") && !p.at_eof() {
                    let a: *Expr = parse_expr(p, 0);
                    if a != null {
                        margs.push(*a);
                    }
                    if !p.eat_op(",") {
                        break;
                    }
                }
                p.expect_op(")");
                let me: *Expr = expr_macro(mname, margs, left.line, left.column);
                me.macro_recv = left;
                left = me;
                continue;
            }
            left = expr_member(left, mname);
            left.field_line = fname_line;
            left.field_col = fname_col;
            continue;
        }
        // postfix ++ / --
        if p.at_op("++") {
            p.advance();
            left = expr_postinc(left);
            continue;
        }
        if p.at_op("--") {
            p.advance();
            left = expr_postdec(left);
            continue;
        }
        // postfix ?  (Result error propagation). Anchor the node at the `?`
        // token itself, not the operand's start, so diagnostics (e.g. the
        // "can only propagate in a fn returning !T" error) point at the `?`.
        if p.at_op("?") {
            let ql: i32 = p.current.line;
            let qc: i32 = p.current.column;
            p.advance();
            left = expr_unary(UN_TRY, left, ql, qc);
            continue;
        }
        // cast: as Type
        if p.at_kw("as") {
            p.advance();
            let target: *Type = parse_type(p);
            left = expr_cast(left, target);
            continue;
        }
        // binary infix
        let info: i32 = peek_binop_bp(p);
        let lbp: i32 = info / 100;
        let op: i32 = info - lbp * 100;
        if lbp == 0 {
            break;
        }
        if lbp < min_bp {
            break;
        }
        // A comment sitting just before the operator (e.g. on its own line in a
        // wrapped `||` chain) rides on the operator token's lead; keep it so fmt
        // can re-emit the chain multi-line.
        let op_lead: string = p.current.lead;
        // Anchor the node at the operator token so type-mismatch / string-eq /
        // tuple-eq diagnostics underline the operator, not the left operand.
        let op_line: i32 = p.current.line;
        let op_col: i32 = p.current.column;
        p.advance();
        let rbp: i32 = lbp + 1;
        let right: *Expr = parse_expr(p, rbp);
        if right == null {
            break;
        }
        left = expr_binary(op, left, right);
        left.line = op_line;
        left.column = op_col;
        if op_lead != null && !op_lead.eq("") {
            left.lead = op_lead;
        }
    }
    return left;
}

// Returns lbp*100 + op_code, or 0 if not a binary operator.
fn peek_binop_bp(p: *Parser) -> i32 {
    if p.current.kind != TOK_OP {
        return 0;
    }
    let lex: string = p.current.lexeme;
    if lex.eq("??") {
        return 100 * 1 + OP_COALESCE;
    }
    if lex.eq("||") {
        return 100 * 2 + OP_OR;
    }
    if lex.eq("&&") {
        return 100 * 3 + OP_AND;
    }
    if lex.eq("|") {
        return 100 * 4 + OP_BIT_OR;
    }
    if lex.eq("^") {
        return 100 * 5 + OP_BIT_XOR;
    }
    if lex.eq("&") {
        return 100 * 6 + OP_BIT_AND;
    }
    if lex.eq("==") {
        return 100 * 7 + OP_EQ;
    }
    if lex.eq("!=") {
        return 100 * 7 + OP_NE;
    }
    if lex.eq("<") {
        return 100 * 8 + OP_LT;
    }
    if lex.eq("<=") {
        return 100 * 8 + OP_LE;
    }
    if lex.eq(">") {
        return 100 * 8 + OP_GT;
    }
    if lex.eq(">=") {
        return 100 * 8 + OP_GE;
    }
    if lex.eq("<<") {
        return 100 * 9 + OP_SHL;
    }
    if lex.eq(">>") {
        return 100 * 9 + OP_SHR;
    }
    if lex.eq("+") {
        return 100 * 10 + OP_ADD;
    }
    if lex.eq("-") {
        return 100 * 10 + OP_SUB;
    }
    if lex.eq("*") {
        return 100 * 11 + OP_MUL;
    }
    if lex.eq("/") {
        return 100 * 11 + OP_DIV;
    }
    if lex.eq("%") {
        return 100 * 11 + OP_MOD;
    }
    return 0;
}

// String interpolation: when the literal contains `${expr}` segments, lower
// to `format!(fmt, args...)` where each `${...}` becomes a `{}` placeholder
// and the inner source is parsed as a Glide expression. Plain strings (no
// `${`) are returned as a normal EX_STRING and skip the rewrite.
//
// `\${` is the escape: it produces a literal `${` in the output and is NOT
// treated as the start of an interpolation segment. Use this when the
// string itself needs to mention `${...}` (error messages, docs, …).
fn build_string_or_interp(p: *Parser, raw: string, line: i32, col: i32) -> *Expr {
    let n: i32 = raw.len();
    let mut has_interp: bool = false;
    let mut probe: i32 = 0;
    while probe + 1 < n {
        if raw.at(probe).to_int() == 36 && raw.at(probe + 1).to_int() == 123 {
            // `\${` is an escape — skip past it.
            if probe > 0 && raw.at(probe - 1).to_int() == 92 {
                probe = probe + 2;
                continue;
            }
            has_interp = true;
            break;
        }
        probe = probe + 1;
    }
    if !has_interp {
        return expr_string(raw, line, col);
    }
    let mut fmt: string = "";
    let inner_args: *Vector<Expr> = Vector::new();
    let mut j: i32 = 0;
    while j < n {
        let c0: char = raw.at(j);
        // Escaped `\${` — emit a literal `${` and skip all three chars (drop
        // the backslash so the rendered string doesn't keep it). The output
        // is built one byte at a time to avoid the literal `${` in source.
        if c0.to_int() == 92 && j + 2 < n && raw.at(j + 1).to_int() == 36 && raw.at(j + 2).to_int() == 123 {
            fmt = fmt.concat(raw.substring(j + 1, j + 3));
            j = j + 3;
            continue;
        }
        if c0.to_int() == 36 && j + 1 < n && raw.at(j + 1).to_int() == 123 {
            let start_expr: i32 = j + 2;
            let mut k: i32 = start_expr;
            while k < n && raw.at(k).to_int() != 125 {
                k = k + 1;
            }
            if k >= n {
                p.err("unterminated \\${...} in string literal");
                return expr_string(raw, line, col);
            }
            let expr_src: string = raw.substring(start_expr, k);
            let sub_lex: *Lexer = Lexer::new(expr_src);
            // Anchor the sub-lexer at the interpolation site (col is the
            // opening quote; +1 steps past it) so every node of the parsed
            // sub-expression carries real source positions — parser AND
            // typer diagnostics inside `${...}` (e.g. use-after-move) then
            // point into the string instead of 1:1.
            sub_lex.line = line;
            sub_lex.column = col + 1 + start_expr;
            let sub_par: *Parser = Parser::new(sub_lex);
            let e: *Expr = parse_expr(sub_par, 0);
            for let di: i32 = 0; di < sub_par.diags.len(); di++ {
                let d: ParseDiag = sub_par.diags.get(di);
                // Positions are already host-anchored (see above); drop any
                // inner fix (its offsets assume the sub-expression source).
                p.push_pdiag(d.line, d.col, d.span, d.code, "in interpolation: ".concat(d.msg), 0, 0, 0, 0, "");
            }
            if e == null {
                return expr_string(raw, line, col);
            }
            inner_args.push(*e);
            fmt = fmt.concat("{}");
            j = k + 1;
        } else {
            fmt = fmt.concat(raw.substring(j, j + 1));
            j = j + 1;
        }
    }
    let final_args: *Vector<Expr> = Vector::new();
    final_args.push(*expr_string(fmt, line, col));
    for let i2: i32 = 0; i2 < inner_args.len(); i2++ {
        final_args.push(inner_args.get(i2));
    }
    let m: *Expr = expr_macro("format", final_args, line, col);
    // Stash the original `${...}` source so fmt can round-trip back to the
    // interpolation form instead of `format!("...", x, y, z)`.
    m.field = raw;
    return m;
}

fn parse_prefix(p: *Parser) -> *Expr {
    let tok: Token = p.current;
    let line: i32 = tok.line;
    let col: i32 = tok.column;
    // Macro placeholder `$ident` — only meaningful inside a macro body. We
    // parse it permissively at any expr position; the expander surfaces an
    // error if a stray placeholder escapes.
    if tok.kind == TOK_OP && tok.lexeme.eq("$") {
        // Avoid stealing `$(` — that's a stmt-level repetition.
        if !p.peek_op("(") {
            p.advance();
            let nm: string = p.expect_ident();
            return expr_macro_var(nm, line, col);
        }
    }
    // Block-as-expression: `{ stmts; return val; }`. Stmt-position `{`
    // is consumed by parse_stmt before reaching here, so any `{` we see
    // is an expression context.
    if tok.kind == TOK_OP && tok.lexeme.eq("{") {
        return parse_block_expr(p);
    }
    if tok.kind == TOK_INT {
        p.advance();
        let ie: *Expr = expr_int(parse_int_lexeme(tok.lexeme), line, col);
        ie.cast_to = _num_suffix_type(tok.lexeme);
        return ie;
    }
    if tok.kind == TOK_FLOAT {
        p.advance();
        return expr_float(tok.lexeme, line, col);
    }
    if tok.kind == TOK_STRING {
        p.advance();
        // strip quotes
        let len: i32 = tok.lexeme.len();
        let inner: string = tok.lexeme.substring(1, len - 1);
        return build_string_or_interp(p, inner, line, col);
    }
    if tok.kind == TOK_CHAR {
        p.advance();
        // 'x' or '\x'
        let len: i32 = tok.lexeme.len();
        let inner: string = tok.lexeme.substring(1, len - 1);
        let c: char = decode_char_inner(inner);
        return expr_char(c, line, col);
    }
    if tok.kind == TOK_KEYWORD {
        if tok.lexeme.eq("true") {
            p.advance();
            return expr_bool(true, line, col);
        }
        if tok.lexeme.eq("false") {
            p.advance();
            return expr_bool(false, line, col);
        }
        if tok.lexeme.eq("null") {
            p.advance();
            return expr_null(line, col);
        }
        if tok.lexeme.eq("if") {
            return parse_if_expr(p);
        }
        if tok.lexeme.eq("match") {
            return parse_match_expr(p);
        }
        if tok.lexeme.eq("fn") {
            p.advance();
            p.expect_op("(");
            let params: *Vector<Param> = Vector::new();
            while !p.at_op(")") && !p.at_eof() {
                // `mut` rides on the Param, same as named-fn params, so the
                // typer can hold closure params to the same immutability rule.
                let pn_mut: bool = p.eat_kw("mut");
                let pn_line: i32 = p.current.line;
                let pn_col: i32 = p.current.column;
                let pname: string = p.expect_binder_ident();
                p.expect_op(":");
                let pty: *Type = parse_type(p);
                params.push(Param { name: pname, ty: pty, name_line: pn_line, name_col: pn_col, is_mut: pn_mut });
                if !p.eat_op(",") {
                    break;
                }
            }
            p.expect_op(")");
            let mut ret: *Type = null;
            if p.eat_op("->") {
                ret = parse_type(p);
            }
            let body: *Vector<Stmt> = parse_block(p);
            return expr_fnexpr(params, ret, body, line, col);
        }
        if tok.lexeme.eq("move") {
            // move fn(...) — same as fn for our minimal closure (no captures yet).
            p.advance();
            // Continue into the fn case directly.
            if p.at_kw("fn") {
                p.advance();
                p.expect_op("(");
                let params: *Vector<Param> = Vector::new();
                while !p.at_op(")") && !p.at_eof() {
                    // Same param shape as the plain `fn(...)` arm: `mut` is
                    // recorded, keywords are rejected as binder names.
                    let pn_mut: bool = p.eat_kw("mut");
                    let pn_line: i32 = p.current.line;
                    let pn_col: i32 = p.current.column;
                    let pname: string = p.expect_binder_ident();
                    p.expect_op(":");
                    let pty: *Type = parse_type(p);
                    params.push(Param { name: pname, ty: pty, name_line: pn_line, name_col: pn_col, is_mut: pn_mut });
                    if !p.eat_op(",") {
                        break;
                    }
                }
                p.expect_op(")");
                let mut ret: *Type = null;
                if p.eat_op("->") {
                    ret = parse_type(p);
                }
                let body: *Vector<Stmt> = parse_block(p);
                return expr_fnexpr(params, ret, body, line, col);
            }
        }
        if tok.lexeme.eq("sizeof") {
            p.advance();
            p.expect_op("(");
            let t: *Type = parse_type(p);
            p.expect_op(")");
            let e: *Expr = __glide_palloc(sizeof(Expr)) as *Expr;
            e.kind = EX_SIZEOF;
            e.line = line;
            e.column = col;
            e.cast_to = t;
            return e;
        }
        if tok.lexeme.eq("new") {
            // `new T { ... }` (the raw-heap literal) was never implemented: it
            // desugared to an unknown `T__new!` macro with the field NAMES
            // silently discarded (unknown-macro at check; a null-pointer init
            // under unchecked emit). Until it exists, reject it up front and
            // point at the form that works. The literal is still parsed and
            // returned as a plain struct literal so downstream checks see the
            // fields instead of cascading.
            p.advance();
            let tn: string = p.expect_ident();
            p.push_pdiag(line, col, 3, "new-unsupported", "`new ".concat(tn).concat(" { ... }` heap literals are not supported yet; write `let p: *").concat(tn).concat(" = ").concat(tn).concat(" { ... };` instead — a struct literal bound to a `*T` heap-allocates (and is auto-dropped)"), 0, 0, 0, 0, "");
            if p.at_op("<") {
                skip_type_params(p);
            }
            p.expect_op("{");
            let names: *Vector<string> = Vector::new();
            let args: *Vector<Expr> = Vector::new();
            while !p.at_op("}") && !p.at_eof() {
                let fname: string = p.expect_ident();
                p.expect_op(":");
                let v: *Expr = parse_expr(p, 0);
                if v != null {
                    names.push(fname);
                    args.push(*v);
                }
                if !p.eat_op(",") {
                    break;
                }
            }
            p.expect_op("}");
            return expr_struct_lit(tn, names, args, line, col);
        }
    }
    // Keywords that are also valid identifier-position references fall here.
    // Binder positions reject keywords (`expect_binder_ident`), but PATH
    // heads like `type::of(...)` from older code still reach this arm, so
    // expression position stays lenient rather than silently emitting a
    // null Expr (which produced malformed C).
    if tok.kind == TOK_IDENT || tok.kind == TOK_KEYWORD {
        p.advance();
        // Multi-segment path `a::b::c::Item[::method]`. The full prefix lives
        // in `str_val` and the trailing segment goes to `field`; codegen looks
        // the joined `prefix::field` up in the alias table (modules) and
        // falls back to the legacy 2-segment `Type_method` resolver.
        if p.at_op("::") {
            p.advance();
            let mut prefix: string = tok.lexeme;
            // Track the position of the FINAL segment (the `field`), so
            // references/rename on `Type::method` anchor at `method`, not at
            // the qualifier — otherwise a rename overwrites the qualifier.
            let mut last_line: i32 = p.current.line;
            let mut last_col: i32 = p.current.column;
            let mut last: string = p.expect_ident();
            while p.at_op("::") {
                p.advance();
                prefix = prefix.concat("::").concat(last);
                last_line = p.current.line;
                last_col = p.current.column;
                last = p.expect_ident();
            }
            if p.at_op("!") && p.peek_op("(") {
                p.advance(); // '!'
                p.advance(); // '('
                let margs: *Vector<Expr> = Vector::new();
                while !p.at_op(")") && !p.at_eof() {
                    let a: *Expr = parse_expr(p, 0);
                    if a != null {
                        margs.push(*a);
                    }
                    if !p.eat_op(",") {
                        break;
                    }
                }
                p.expect_op(")");
                let me: *Expr = expr_macro(last, margs, line, col);
                me.macro_owner = prefix;
                return me;
            }
            // Module-qualified struct literal `mod::Struct { field: v, ... }`.
            // The trailing segment is the struct name; the qualifier resolves
            // like any imported reference. Mirrors the bare struct-literal path
            // below so `al2::Alelo2 { ... }` parses (needs `al2` imported).
            if p.at_op("{") && starts_uppercase(last) && !p.no_struct_lit {
                p.advance();
                let qnames: *Vector<string> = Vector::new();
                let qvalues: *Vector<Expr> = Vector::new();
                while !p.at_op("}") && !p.at_eof() {
                    let qf: string = p.expect_ident();
                    p.expect_op(":");
                    let qv: *Expr = parse_expr(p, 0);
                    if qv != null {
                        qnames.push(qf);
                        qvalues.push(*qv);
                    }
                    if !p.eat_op(",") {
                        break;
                    }
                }
                p.expect_op("}");
                let sl: *Expr = expr_struct_lit(last, qnames, qvalues, line, col);
                // Keep the module qualifier so the loader auto-loads it (the
                // C struct type is only emitted when its module is compiled);
                // codegen still uses the bare `last` as the type name.
                sl.field = prefix;
                // Remember where the struct NAME sits (after `mod::`) so a
                // "unknown struct" diagnostic underlines `Penis`, not `mod`.
                sl.field_line = last_line;
                sl.field_col = last_col;
                return sl;
            }
            let pe: *Expr = expr_path(prefix, last, line, col);
            pe.field_line = last_line;
            pe.field_col = last_col;
            return pe;
        }
        // `name!(...)` macro call?
        if p.at_op("!") && p.peek_op("(") {
            p.advance(); // '!'
            p.advance(); // '('
            let args: *Vector<Expr> = Vector::new();
            while !p.at_op(")") && !p.at_eof() {
                let a: *Expr = parse_expr(p, 0);
                if a != null {
                    args.push(*a);
                }
                if !p.eat_op(",") {
                    break;
                }
            }
            p.expect_op(")");
            // Compile-time builtin: include_str!("path") → reads the file at parse
            // time and replaces the call with a string literal of its contents.
            // The file's raw bytes get pre-escaped into Glide-source form (raw `"`
            // becomes `\"`, raw newline becomes `\n`-text, etc) so the codegen's
            // verbatim string-literal emission produces valid C.
            if tok.lexeme.eq("include_str") && args.len() == 1 {
                let arg: Expr = args.get(0);
                if arg.kind == EX_STRING {
                    let raw: string = read_file(arg.str_val);
                    let mut esc: string = "";
                    let n: i32 = raw.len();
                    let mut k: i32 = 0;
                    while k < n {
                        let c: char = raw.at(k);
                        let v: i32 = c.to_int();
                        if v == 34 {
                            esc = esc.concat("\\\"");
                        } else {
                            if v == 92 {
                                esc = esc.concat("\\\\");
                            } else {
                                if v == 10 {
                                    esc = esc.concat("\\n");
                                } else {
                                    if v == 13 {
                                        esc = esc.concat("\\r");
                                    } else {
                                        if v == 9 {
                                            esc = esc.concat("\\t");
                                        } else {
                                            esc = esc.concat(raw.substring(k, k + 1));
                                        }
                                    }
                                }
                            }
                        }
                        k = k + 1;
                    }
                    return expr_string(esc, line, col);
                }
            }
            return expr_macro(tok.lexeme, args, line, col);
        }
        // Struct literal: `TypeName { name: value, ... }`. Heuristic: only when
        // the identifier starts with a capital letter (convention for types).
        if p.at_op("{") && starts_uppercase(tok.lexeme) && !p.no_struct_lit {
            p.advance();
            let names: *Vector<string> = Vector::new();
            let values: *Vector<Expr> = Vector::new();
            while !p.at_op("}") && !p.at_eof() {
                let fline: i32 = p.current.line;
                let fcol: i32 = p.current.column;
                let fname: string = p.expect_ident();
                let mut v: *Expr = null;
                if p.eat_op(":") {
                    v = parse_expr(p, 0);
                } else {
                    // Field shorthand: `T { x }` is sugar for `T { x: x }`.
                    v = expr_ident(fname, fline, fcol);
                }
                if v != null {
                    names.push(fname);
                    values.push(*v);
                }
                if !p.eat_op(",") {
                    break;
                }
            }
            p.expect_op("}");
            return expr_struct_lit(tok.lexeme, names, values, line, col);
        }
        return expr_ident(tok.lexeme, line, col);
    }
    if p.at_op("(") {
        p.advance();
        // `()` — unit tuple literal.
        if p.at_op(")") {
            p.advance();
            let empty: *Vector<Expr> = Vector::new();
            return expr_tuple(empty, line, col);
        }
        let first: *Expr = parse_expr(p, 0);
        // `(e)` — parenthesized expression (no comma). `(e, ...)` — tuple.
        if !p.at_op(",") {
            p.expect_op(")");
            return first;
        }
        let elems: *Vector<Expr> = Vector::new();
        if first != null {
            elems.push(*first);
        }
        while p.eat_op(",") {
            if p.at_op(")") {
                break;
            } // allow trailing comma
            let e: *Expr = parse_expr(p, 0);
            if e != null {
                elems.push(*e);
            }
        }
        p.expect_op(")");
        return expr_tuple(elems, line, col);
    }
    // unary ops
    if p.at_op("-") {
        p.advance();
        let r: *Expr = parse_expr(p, 13);
        return expr_unary(UN_NEG, r, line, col);
    }
    if p.at_op("!") {
        p.advance();
        let r: *Expr = parse_expr(p, 13);
        return expr_unary(UN_NOT, r, line, col);
    }
    if p.at_op("~") {
        p.advance();
        let r: *Expr = parse_expr(p, 13);
        return expr_unary(UN_BIT_NOT, r, line, col);
    }
    if p.at_op("*") {
        p.advance();
        let r: *Expr = parse_expr(p, 13);
        return expr_unary(UN_DEREF, r, line, col);
    }
    if p.at_op("&") {
        p.advance();
        if p.eat_kw("mut") {
            let r: *Expr = parse_expr(p, 13);
            return expr_unary(UN_ADDR_MUT, r, line, col);
        }
        let r: *Expr = parse_expr(p, 13);
        return expr_unary(UN_ADDR, r, line, col);
    }
    p.err("unexpected token at start of expression");
    p.advance();
    return null;
}

// ---- helpers -------------------------------------------------------------
fn parse_int_lexeme(s0: string) -> i64 {
    // Drop a trailing type suffix (`100i32`, `3u8`) before decoding the value;
    // `_num_strip_suffix` leaves hex/binary lexemes untouched.
    let s: string = _num_strip_suffix(s0);
    let n: i32 = s.len();
    let mut v: i64 = 0;
    // Hex (0x/0X) and binary (0b/0B) literals. The lexer captures the whole
    // lexeme verbatim; decode its value here so codegen emits the right
    // decimal number.
    if n >= 2 && s.at(0).to_int() == 48 {
        let p: i32 = s.at(1).to_int();
        if p == 120 || p == 88 {
            for let i: i32 = 2; i < n; i++ {
                let ci: i32 = s.at(i).to_int();
                if ci == 95 {
                    continue;
                }
                let mut d: i32 = 0;
                if ci >= 48 && ci <= 57 {
                    d = ci - 48;
                } else {
                    if ci >= 97 && ci <= 102 {
                        d = ci - 97 + 10;
                    } else {
                        if ci >= 65 && ci <= 70 {
                            d = ci - 65 + 10;
                        }
                    }
                }
                v = v * 16 + d as i64;
            }
            return v;
        }
        if p == 98 || p == 66 {
            for let i: i32 = 2; i < n; i++ {
                let ci: i32 = s.at(i).to_int();
                if ci == 95 {
                    continue;
                }
                v = v * 2 + (ci - 48) as i64;
            }
            return v;
        }
    }
    for let i: i32 = 0; i < n; i++ {
        let c: char = s.at(i);
        let ci: i32 = c.to_int();
        if ci == 95 {
            continue;
        } // skip _
        v = v * 10 + (ci - 48) as i64;
    }
    return v;
}

fn starts_uppercase(s: string) -> bool {
    if s.len() == 0 {
        return false;
    }
    let c: char = s.at(0);
    let ci: i32 = c.to_int();
    return ci >= 65 && ci <= 90;
}

fn decode_char_inner(s: string) -> char {
    if s.len() == 0 {
        return '\0';
    }
    let first: char = s.at(0);
    if first.to_int() != 92 {
        return first;
    } // not '\'
    if s.len() < 2 {
        return '\0';
    }
    let esc: char = s.at(1);
    let ei: i32 = esc.to_int();
    if ei == 110 {
        return '\n';
    }
    if ei == 116 {
        return '\t';
    }
    if ei == 114 {
        return '\r';
    }
    if ei == 48 {
        return '\0';
    }
    if ei == 92 {
        return '\\';
    }
    if ei == 39 {
        return '\'';
    }
    if ei == 34 {
        return '"';
    }
    return esc;
}
