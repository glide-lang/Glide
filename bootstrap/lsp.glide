// LSP server — Language Server Protocol over JSON-RPC on stdio.
//
// Started by `glide lsp`. The transport reads `Content-Length`-framed
// messages, decodes them via json.glide, and dispatches by method name.
//
// Lifecycle:
//   initialize / initialized / shutdown / exit
//   textDocument/didOpen, didChange, didClose
//
// Lookups:
//   textDocument/hover               — keyword + builtin docs, doc-comment
//                                       extraction for user fns/structs.
//   textDocument/definition          — jump to fn / struct / impl method.
//                                       Resolves Vector::new, c.send, chained
//                                       inline ctors, qualified paths.
//   textDocument/references          — every read/write of the symbol.
//   textDocument/documentHighlight   — same as references, kind-tagged.
//   textDocument/documentSymbol      — outline tree.
//   textDocument/completion          — keywords, builtins, locals, fields,
//                                       chan ops on `c.`, type::method.
//
// Edits:
//   textDocument/rename              — workspace edit across collected uses.
//   textDocument/prepareRename       — validates the cursor target.
//   textDocument/formatting          — round-trip through fmt.glide.
//
// Diagnostics:
//   publishDiagnostics               — typer errors + warnings: null safety,
//                                       unused-var, arena-not-freed, missing
//                                       trait method, unsatisfied bound,
//                                       type mismatch, trait-method-mismatch.

import stdlib::hashmap::*;
import ast;
import lexer;
import parser;
import expander;     // for body_references_self / expand_macros
import lower;        // for lower_program
import typer;        // for types_compat / merge_parse_diags
import json;
import fmt;
import manifest;     // for project-aware completion (Manifest, dep_cache_dir, …)

// LSP diagnostic log. Opens (truncate) on lsp_main entry and redirects
// stderr there so SIGSEGV traps from the runtime land in the same
// stream — gives the user one file (`~/.glide/lsp.log`) to share when
// the editor's server-output panel is empty after a crash.
extern fn __glide_lsp_log_open(path: string);
extern fn __glide_lsp_log(msg: string);

c_raw! {
    #include <stdio.h>
    #include <time.h>
    static FILE* __glide_lsp_log_fp = NULL;
    void __glide_lsp_log_open(const char* path) {
        if (path == NULL || !*path) return;
        __glide_lsp_log_fp = fopen(path, "w");
        if (!__glide_lsp_log_fp) return;
        setvbuf(__glide_lsp_log_fp, NULL, _IONBF, 0);   /* unbuffered: crash-time data survives */
        /* Redirect stderr into the log so SIGSEGV handlers (and any
           rogue fprintf(stderr, ...)) end up in the same place. */
        int fd = fileno(__glide_lsp_log_fp);
        if (fd >= 0) {
            fflush(stderr);
            dup2(fd, fileno(stderr));
        }
    }
    void __glide_lsp_log(const char* msg) {
        if (__glide_lsp_log_fp == NULL || msg == NULL) return;
        time_t t = time(NULL);
        struct tm* lt = localtime(&t);
        if (lt) {
            fprintf(__glide_lsp_log_fp, "[%02d:%02d:%02d] %s\n",
                lt->tm_hour, lt->tm_min, lt->tm_sec, msg);
        } else {
            fprintf(__glide_lsp_log_fp, "%s\n", msg);
        }
    }
}

fn _lsp_log(msg: string) { __glide_lsp_log(msg); }

// `~/.glide/lsp.log` on POSIX, `%USERPROFILE%\.glide\lsp.log` on Windows.
// Falls back to TMP if the home dir lookup fails.
fn _lsp_log_path() -> string {
    let up: string = __glide_getenv("USERPROFILE");
    if !up.eq("") { return up.concat("/.glide/lsp.log"); }
    let h: string = __glide_getenv("HOME");
    if !h.eq("") { return h.concat("/.glide/lsp.log"); }
    let tmp: string = __glide_getenv("TMP");
    if !tmp.eq("") { return tmp.concat("/glide-lsp.log"); }
    return "glide-lsp.log";
}

extern fn __glide_getenv(name: string) -> string;

// FFI to runtime helpers (defined in codegen runtime emit / stdlib::os c_raw).
extern fn read_file(path: string) -> string;
extern fn __glide_read_line() -> string;
extern fn __glide_read_bytes(n: i32) -> string;
pub extern fn __glide_write_str(s: string);
pub extern fn __glide_flush_stdout();
extern fn __glide_log(s: string);
extern fn __glide_set_binary_io();
extern fn __glide_exe_dir() -> string;
extern fn __glide_cwd() -> string;

// Forward declarations for symbols defined in main.glide. The driver
// is the canonical owner; declaring them here lets the LSP file
// type-check standalone without forming a circular import (main.glide
// itself imports lsp).
extern fn load_into_str(stmts: *Vector<Stmt>, src: string, origin: string,
                        loaded: *HashMap<bool>, pdiags: *Vector<ParseDiag>);
extern fn load_builtins_dir(stmts: *Vector<Stmt>, dir: string,
                            loaded: *HashMap<bool>, pdiags: *Vector<ParseDiag>);
// Cached LSP variants. Skip lex+parse on paths already in `cache`,
// populate it on miss. Backed by main.glide.
extern fn load_into_str_with_cache(stmts: *Vector<Stmt>, src: string, origin: string,
                                   loaded: *HashMap<bool>, pdiags: *Vector<ParseDiag>,
                                   cache: *HashMap<*Vector<Stmt>>);
extern fn load_into_with_cache(stmts: *Vector<Stmt>, path: string,
                               loaded: *HashMap<bool>, pdiags: *Vector<ParseDiag>,
                               cache: *HashMap<*Vector<Stmt>>);
extern fn load_builtins_dir_with_cache(stmts: *Vector<Stmt>, dir: string,
                                       loaded: *HashMap<bool>, pdiags: *Vector<ParseDiag>,
                                       cache: *HashMap<*Vector<Stmt>>);

// ---- Document store ----------------------------------------------------

pub struct LspDoc {
    pub uri: string,
    pub text: string,
    pub version: i32,
    pub stmts: *Vector<Stmt>,
    // Pre-`expand_macros` snapshot. Lets documentSymbol / glide/routeList
    // / any future per-attribute query read the user's source-level fns
    // with their original @get/@post/@route attrs intact, before
    // expansion replaces them with `_user_*` + `_route_register_*`
    // companions.
    pub pre_expand_stmts: *Vector<Stmt>,
    // Macro-def shapes harvested BEFORE `expand_macros` consumes them.
    // Used by completion (free macros surface as `name!`, proc-attrs as
    // `@name`, proc-derives inside `@derive(...)`). The post-expansion
    // `stmts` has none of these, so without the pre-pass copy the
    // completion list misses every macro the user can actually call.
    pub macro_defs: *Vector<Stmt>,
    pub impl_macro_defs: *Vector<Stmt>,
    pub proc_attrs: *Vector<string>,
    pub proc_derives: *Vector<string>,
    pub proc_macros: *Vector<string>,
}

// Marker kind for the synthetic "module" entries produced per stdlib
// file. Out-of-band of the AST's ST_* kind range so it can't collide.
pub const SYMKIND_MODULE: i32 = -1;
pub const SYMKIND_PROC_ATTR: i32 = -2;     // fn carrying `@proc_attr(Name)`
pub const SYMKIND_PROC_DERIVE: i32 = -3;   // fn carrying `@proc_derive(Name)`
pub const SYMKIND_PROC_MACRO: i32 = -4;    // fn carrying `@proc_macro(Name)` / `@proc_macro_str(Name)`

// One importable symbol from src/stdlib/. Built once at server startup
// and reused by completion to surface auto-import suggestions. Mirrors
// the data gopls keeps per-symbol so the LSP can fill out the full
// CompletionItem (signature + labelDetails + documentation + snippet).
pub struct ImportableSym {
    pub name: string,         // `HashMap`, `Time`, `min_int`, …
    pub kind: i32,            // ST_FN / ST_STRUCT / ST_ENUM / ST_CONST / ST_TRAIT
    pub module: string,       // `stdlib::hashmap`, `stdlib::time`, …
    pub signature: string,    // full one-line signature, used in `detail`
    pub label_extra: string,  // shown next to the label (param list for fns)
    pub doc: string,          // doc-comment, rendered in `documentation`
    pub snippet: string,      // gopls-style snippet for `insertText`
    pub has_snippet: bool,    // true → insertTextFormat=2; false → plain
}

pub struct LspState {
    pub docs: *HashMap<LspDoc>,
    pub shutdown_requested: bool,
    pub stdlib_index: *Vector<ImportableSym>,
    /// Project-local importable symbols: the user's own modules under
    /// the project's `src/` tree plus every dep (path or git) declared
    /// in `glide.glide`. Built once when the first doc opens from a
    /// project that has a manifest; cached after.
    pub project_index: *Vector<ImportableSym>,
    /// Manifest root we built `project_index` for. Used to detect when
    /// the user opened a doc in a different project and the index
    /// needs to be rebuilt.
    pub project_root: string,
    // Path -> parse_program output. Populated lazily on first parse of
    // each transitive import (builtins + stdlib + user-imported files);
    // hits skip the lex/parse work on every keystroke. The user's
    // currently-edited buffer is never cached — its content changes
    // between calls, so it always parses fresh.
    pub parse_cache: *HashMap<*Vector<Stmt>>,
    // Latest parse arena. Held here (rather than via __glide_palloc_get
    // at the start of each run) because we deactivate the arena
    // between requests so hover / completion scratch goes to libc heap;
    // palloc_get would then return null and we'd never free the
    // arena's many MB of pipeline allocations.
    pub last_arena: *void,
    // Last manifest root we applied lint config from. Cached so we
    // don't reparse the manifest + reset the global deny/allow on
    // every keystroke (the lists also live on libc heap, so
    // re-applying would leak the previous instance).
    pub lint_applied_root: string,
}

pub fn lsp_state_new() -> *LspState {
    let s: *LspState = malloc(sizeof(LspState)) as *LspState;
    let m: *HashMap<LspDoc> = HashMap::new();
    s.docs = m;
    s.shutdown_requested = false;
    let idx: *Vector<ImportableSym> = Vector::new();
    s.stdlib_index = idx;
    let pidx: *Vector<ImportableSym> = Vector::new();
    s.project_index = pidx;
    s.project_root = "";
    let pc: *HashMap<*Vector<Stmt>> = HashMap::new();
    s.parse_cache = pc;
    s.last_arena = null;
    s.lint_applied_root = "";
    populate_stdlib_index(s);
    return s;
}

// ---- Wire protocol -----------------------------------------------------

// Read a single LSP message: parse `Content-Length: N` header, blank line,
// then read N bytes of payload. Returns "" on EOF.
fn lsp_read_message() -> string {
    let mut content_length: i32 = 0;
    while true {
        let line: string = __glide_read_line();
        if line.eq("") { return ""; }
        let n: i32 = line.len();
        // Strip trailing \r\n / \n
        let mut end: i32 = n;
        while end > 0 {
            let c: i32 = line.at(end - 1).to_int();
            if c == 10 || c == 13 { end = end - 1; }
            else { break; }
        }
        if end == 0 { break; }   // blank line ends header
        // Look for "Content-Length: N"
        let trimmed: string = line.substring(0, end);
        if trimmed.len() > 16 {
            let prefix: string = trimmed.substring(0, 16);
            if prefix.eq("Content-Length: ") {
                content_length = parse_int_str(trimmed.substring(16, trimmed.len()));
            }
        }
    }
    if content_length <= 0 { return ""; }
    return __glide_read_bytes(content_length);
}

fn parse_int_str(s: string) -> i32 {
    let mut n: i32 = 0;
    let len: i32 = s.len();
    for let i: i32 = 0; i < len; i++ {
        let c: i32 = s.at(i).to_int();
        if c < 48 || c > 57 { break; }
        n = n * 10 + (c - 48);
    }
    return n;
}

fn lsp_send(payload: string) {
    let header: string = "Content-Length: ".concat(int_to_str(payload.len())).concat("\r\n\r\n");
    __glide_write_str(header);
    __glide_write_str(payload);
    __glide_flush_stdout();
}

fn lsp_send_response(id: *JsonValue, result: *JsonValue) {
    let resp: *JsonValue = json_object();
    json_obj_set(resp, "jsonrpc", json_string("2.0"));
    if id != null { json_obj_set(resp, "id", id); }
    json_obj_set(resp, "result", result);
    lsp_send(json_emit(resp));
    json_free(resp);
}

fn lsp_send_notification(method: string, params: *JsonValue) {
    let n: *JsonValue = json_object();
    json_obj_set(n, "jsonrpc", json_string("2.0"));
    json_obj_set(n, "method", json_string(method));
    json_obj_set(n, "params", params);
    lsp_send(json_emit(n));
    json_free(n);
}

// ---- Method handlers ---------------------------------------------------

fn handle_initialize(req: *JsonValue) {
    let id: *JsonValue = json_get(req, "id");
    let result: *JsonValue = json_object();
    let caps: *JsonValue = json_object();
    // textDocumentSync: 1 = Full sync. We re-parse on every change.
    json_obj_set(caps, "textDocumentSync", json_int(1));
    json_obj_set(caps, "hoverProvider", json_bool(true));
    json_obj_set(caps, "documentSymbolProvider", json_bool(true));
    json_obj_set(caps, "definitionProvider", json_bool(true));
    json_obj_set(caps, "referencesProvider", json_bool(true));
    json_obj_set(caps, "documentHighlightProvider", json_bool(true));
    let rename_caps: *JsonValue = json_object();
    json_obj_set(rename_caps, "prepareProvider", json_bool(true));
    json_obj_set(caps, "renameProvider", rename_caps);
    json_obj_set(caps, "documentFormattingProvider", json_bool(true));
    // Quick-fix code actions. Server reads `context.diagnostics` for
    // entries carrying a `data.fix` from us and returns CodeAction[]
    // with WorkspaceEdit.
    let cap_ca: *JsonValue = json_object();
    let kinds: *JsonValue = json_array();
    json_arr_push(kinds, json_string("quickfix"));
    json_obj_set(cap_ca, "codeActionKinds", kinds);
    json_obj_set(caps, "codeActionProvider", cap_ca);
    let comp: *JsonValue = json_object();
    let trig: *JsonValue = json_array();
    json_arr_push(trig, json_string("."));
    json_arr_push(trig, json_string(":"));
    json_obj_set(comp, "triggerCharacters", trig);
    json_obj_set(caps, "completionProvider", comp);
    json_obj_set(result, "capabilities", caps);
    let info: *JsonValue = json_object();
    json_obj_set(info, "name", json_string("glide-lsp"));
    json_obj_set(info, "version", json_string("0.1.1"));
    json_obj_set(result, "serverInfo", info);
    lsp_send_response(id, result);
}

fn handle_shutdown(req: *JsonValue, state: *LspState) {
    state.shutdown_requested = true;
    let id: *JsonValue = json_get(req, "id");
    lsp_send_response(id, json_null());
}

// Convert one DiagEntry into the LSP Diagnostic JSON shape.
fn diag_to_json(d: *DiagEntry) -> *JsonValue {
    let dj: *JsonValue = json_object();
    let range: *JsonValue = json_object();
    let start: *JsonValue = json_object();
    let endp: *JsonValue = json_object();
    // LSP positions are 0-indexed; the typer reports 1-indexed lines/cols.
    let mut line0: i32 = d.line - 1;  if line0 < 0 { line0 = 0; }
    let mut col0:  i32 = d.col  - 1;  if col0  < 0 { col0 = 0; }
    let mut endl: i32 = d.end_line - 1; if endl < 0 { endl = 0; }
    let mut endc: i32 = d.end_col  - 1; if endc < 0 { endc = 0; }
    json_obj_set(start, "line", json_int(line0));
    json_obj_set(start, "character", json_int(col0));
    json_obj_set(endp,  "line", json_int(endl));
    json_obj_set(endp,  "character", json_int(endc));
    json_obj_set(range, "start", start);
    json_obj_set(range, "end", endp);
    json_obj_set(dj, "range", range);
    json_obj_set(dj, "severity", json_int(d.severity));
    if !d.code.eq("") { json_obj_set(dj, "code", json_string(d.code)); }
    json_obj_set(dj, "source", json_string("glide"));
    json_obj_set(dj, "message", json_string(d.message));
    if d.tag != 0 {
        // LSP DiagnosticTag: 1 = Unnecessary (rendered faded by editors),
        //                    2 = Deprecated (struck-through).
        let tags: *JsonValue = json_array();
        json_arr_push(tags, json_int(d.tag));
        json_obj_set(dj, "tags", tags);
    }
    // When the analysis attached a mechanical fix, stash it in the
    // `data` field. Editors hand `context.diagnostics` back on
    // `textDocument/codeAction`, so the code-action handler reads
    // these fields without re-running the analysis.
    //
    // Two paths:
    //   - explicit fix via `warn_with_fix` (fix_line > 0)
    //   - implicit fix derived from the code: `unused-{var,param}`
    //     get an "insert `_` at the diag range start" fix. Mirrors
    //     what `glide fix` does so the editor's quick-fix and the
    //     CLI fixer agree.
    let mut has_fix: bool = false;
    let mut fr_sl: i32 = 0; let mut fr_sc: i32 = 0;
    let mut fr_el: i32 = 0; let mut fr_ec: i32 = 0;
    let mut new_text: string = "";
    if !d.fix_replacement.eq("") || d.fix_line > 0 {
        has_fix = true;
        fr_sl = d.fix_line - 1;  if fr_sl < 0 { fr_sl = 0; }
        fr_sc = d.fix_col - 1;   if fr_sc < 0 { fr_sc = 0; }
        fr_el = d.fix_end_line - 1; if fr_el < 0 { fr_el = 0; }
        fr_ec = d.fix_end_col - 1; if fr_ec < 0 { fr_ec = 0; }
        new_text = d.fix_replacement;
    } else if d.code.eq("unused-var") || d.code.eq("unused-param") {
        has_fix = true;
        fr_sl = line0; fr_sc = col0; fr_el = line0; fr_ec = col0;
        new_text = "_";
    }
    if has_fix {
        let data: *JsonValue = json_object();
        let fix: *JsonValue = json_object();
        let fr: *JsonValue = json_object();
        let fs: *JsonValue = json_object();
        let fe: *JsonValue = json_object();
        json_obj_set(fs, "line", json_int(fr_sl));
        json_obj_set(fs, "character", json_int(fr_sc));
        json_obj_set(fe, "line", json_int(fr_el));
        json_obj_set(fe, "character", json_int(fr_ec));
        json_obj_set(fr, "start", fs);
        json_obj_set(fr, "end", fe);
        json_obj_set(fix, "range", fr);
        json_obj_set(fix, "newText", json_string(new_text));
        json_obj_set(data, "fix", fix);
        json_obj_set(dj, "data", data);
    }
    return dj;
}

// Convert `file:///C:/path` (Windows) or `file:///path` (POSIX) into a plain
// filesystem path the rest of the loader can use. URL-decoding is intentionally
// not done — Glide identifiers and most paths are ASCII.
fn uri_to_path(uri: string) -> string {
    let n: i32 = uri.len();
    if n < 7 { return uri; }
    if !uri.substring(0, 7).eq("file://") { return uri; }
    let rest: string = uri.substring(7, n);
    let rn: i32 = rest.len();
    // Windows: file:///C:/... -> "/C:/..." -> drop leading '/'
    if rn > 2 && rest.at(0).to_int() == 47 && rest.at(2).to_int() == 58 {
        return rest.substring(1, rn);
    }
    return rest;
}

// Locate `src/builtins/`. Prefer the exe-relative install layout so the
// origin paths the LSP stamps on Stmt nodes are absolute (used for goto-def
// URIs). Falls back to a cwd-relative path for in-repo development.
fn find_builtins_dir() -> string {
    let exe_dir: string = __glide_exe_dir();
    if !exe_dir.eq("") {
        let probe: string = exe_dir.concat("/src/builtins/builtins.glide");
        if !read_file(probe).eq("") { return exe_dir.concat("/src/builtins"); }
    }
    if !read_file("src/builtins/builtins.glide").eq("") { return "src/builtins"; }
    return "";
}

// Locate `src/stdlib/`. Same fallback chain as find_builtins_dir — prefer
// the install layout next to the binary, fall back to in-repo dev.
fn find_stdlib_dir() -> string {
    let exe_dir: string = __glide_exe_dir();
    if !exe_dir.eq("") {
        let probe: string = exe_dir.concat("/src/stdlib/hashmap.glide");
        if !read_file(probe).eq("") { return exe_dir.concat("/src/stdlib"); }
    }
    if !read_file("src/stdlib/hashmap.glide").eq("") { return "src/stdlib"; }
    return "";
}

// Strip a trailing ".glide" so "math.glide" -> "math".
fn drop_glide_ext(name: string) -> string {
    let n: i32 = name.len();
    if n > 6 && name.substring(n - 6, n).eq(".glide") {
        return name.substring(0, n - 6);
    }
    return name;
}

// Walk every src/stdlib/*.glide and collect all `pub` top-level decls into
// state.stdlib_index. Called once at startup; the LSP doesn't reparse on
// every completion request.
//
// Each module also gets a single ImportableSym entry of its own (kind =
// SYMKIND_MODULE) so the completion UI can suggest the module by short
// name — typing `hash` lists both the `HashMap` struct AND the
// `hashmap` module, just like gopls lists packages alongside symbols.
fn populate_stdlib_index(state: *LspState) {
    let dir: string = find_stdlib_dir();
    if dir.eq("") { return; }
    _index_stdlib_subtree(state, dir, "stdlib");
}

// Walk `dir` recursively. Each `.glide` file becomes an importable
// module under `module_prefix::<filename-without-extension>`; each
// subdirectory recurses with the prefix extended. So `src/stdlib/http`
// becomes `stdlib::http`, `src/stdlib/http/client.glide` becomes
// `stdlib::http::client`, and so on.
fn _index_stdlib_subtree(state: *LspState, dir: string, module_prefix: string) {
    let files: *Vector<string> = fs_list_dir(dir, ".glide");
    if files != null {
        for let i: i32 = 0; i < files.len(); i++ {
            let fname: string = files.get(i);
            if fname.eq("") { continue; }
            let path: string = dir.concat("/").concat(fname);
            let mod_name: string = drop_glide_ext(fname);
            let module: string = module_prefix.concat("::").concat(mod_name);
            _index_one_module(state, path, mod_name, module);
        }
    }
    let subs_raw: string = __glide_fs_list_dirs(dir);
    if subs_raw.eq("") { return; }
    let subs: *Vector<string> = subs_raw.split("\n");
    for let i: i32 = 0; i < subs.len(); i++ {
        let sub: string = subs.get(i);
        if sub.eq("") { continue; }
        let child_dir: string = dir.concat("/").concat(sub);
        let child_pref: string = module_prefix.concat("::").concat(sub);
        _index_stdlib_subtree(state, child_dir, child_pref);
    }
}

// Rebuild `state.project_index` if the doc at `uri` belongs to a Glide
// project we haven't indexed yet. No-op when there's no `glide.glide`
// above the file, or when we already indexed this project.
//
// Critical: the index OUTLIVES the request that triggered its build,
// so we switch the active arena to null before the build and all
// allocations (Vector, strings, ImportableSym entries) land on libc
// heap. Otherwise the request-scoped arena gets freed at end of
// dispatch and `state.project_index` dangles until the next access
// crashes the LSP.
fn _refresh_project_index(state: *LspState, uri: string) {
    let path: string = uri_to_path(uri);
    if path.eq("") { return; }
    let dir: string = parent_dir(path);
    let root: string = find_manifest_root(dir);
    if root.eq("") { return; }
    if state.project_root.eq(root) { return; }

    let prev_arena: *void = __glide_palloc_get();
    __glide_palloc_set(null);

    state.project_root = root.concat("");   // libc-heap copy
    let fresh: *Vector<ImportableSym> = Vector::new();
    state.project_index = fresh;
    let src_dir: string = root.concat("/src");
    if __glide_file_exists(src_dir) {
        let proj_name: string = _project_namespace(root);
        _index_stdlib_subtree(state, src_dir, proj_name);
    }
    // Each declared dep — path deps point at a sibling dir, git deps at
    // the cache slot. Indexing covers both because dep_cache_dir picks
    // the right one already.
    let m: *Manifest = read_manifest(root);
    if m != null {
        for let i: i32 = 0; i < m.deps.len(); i++ {
            let d: ManifestDep = m.deps.get(i);
            let dep_root: string = dep_cache_dir(m, d);
            if dep_root.eq("") || !__glide_file_exists(dep_root) { continue; }
            let dep_src: string = dep_root.concat("/src");
            if __glide_file_exists(dep_src) {
                _index_stdlib_subtree(state, dep_src, d.name);
            } else {
                _index_stdlib_subtree(state, dep_root, d.name);
            }
        }
    }

    __glide_palloc_set(prev_arena);
}

// Read the `name` field from `<root>/glide.glide` so the project's
// own modules live under the user-chosen namespace (e.g. `my_app`).
// Falls back to the directory's basename for malformed manifests.
fn _project_namespace(root: string) -> string {
    let m: *Manifest = read_manifest(root);
    if m != null && !m.name.eq("") { return m.name; }
    // basename(root) fallback.
    let mut cut: i32 = -1;
    for let i: i32 = 0; i < root.len(); i++ {
        let c: i32 = root.at(i).to_int();
        if c == 47 || c == 92 { cut = i; }
    }
    if cut < 0 || cut + 1 >= root.len() { return "project"; }
    return root.substring(cut + 1, root.len());
}

// Parse one source file and append every pub item to the index, plus
// a SYMKIND_MODULE entry for the module itself.
fn _index_one_module(state: *LspState, path: string, mod_name: string, module: string) {
    let src: string = read_file(path);
    if src.eq("") { return; }
    let lex: *Lexer = Lexer::new(src);
    let par: *Parser = Parser::new(lex);
    let stmts: *Vector<Stmt> = parse_program(par);
    if stmts == null { return; }
    // Track exported symbol names so the module entry can list them
    // in its hover-doc summary.
    let mut summary: string = "";
    let mut count: i32 = 0;
    for let j: i32 = 0; j < stmts.len(); j++ {
        let s: Stmt = stmts.get(j);
        // Proc-macro fns register globally via their `@proc_<kind>(Name)`
        // attribute; they don't need to be `pub` (stdlib convention keeps
        // the impl helper private). Other stmts still require pub for
        // cross-file visibility.
        let mut is_proc_fn: bool = false;
        if s.kind == ST_FN && s.attrs != null {
            for let kk: i32 = 0; kk < s.attrs.len(); kk++ {
                let aa: Attr = s.attrs.get(kk);
                if aa.name == null { continue; }
                if aa.name.eq("proc_attr") || aa.name.eq("proc_derive")
                   || aa.name.eq("proc_macro") || aa.name.eq("proc_macro_str") {
                    is_proc_fn = true;
                    break;
                }
            }
        }
        if !s.is_pub && !is_proc_fn { continue; }
        if s.kind != ST_FN && s.kind != ST_STRUCT && s.kind != ST_ENUM
           && s.kind != ST_CONST && s.kind != ST_TRAIT && s.kind != ST_MACRO_DEF { continue; }
        let mut sig: string = "";
        let mut label_extra: string = "";
        let mut snip: string = s.name;
        let mut has_snip: bool = false;
        // Default: kind matches the AST kind. Overridden below for fns
        // wearing a `@proc_<kind>(Name)` attribute so they show up under
        // `@<name>` / `@derive(Name)` completion instead of the bare-ident
        // list.
        let mut sym_kind: i32 = s.kind;
        let mut sym_name: string = s.name;
        if s.kind == ST_FN {
            sig = fn_signature(&s);
            label_extra = fn_label_extra(&s);
            snip = fn_snippet(&s);
            has_snip = true;
            // Proc-macro registration: `@proc_<kind>(Name)`. The user-
            // facing name is the attr arg, not the impl fn name.
            if s.attrs != null {
                for let k: i32 = 0; k < s.attrs.len(); k++ {
                    let a: Attr = s.attrs.get(k);
                    if a.name == null { continue; }
                    if a.args == null || a.args.len() == 0 { continue; }
                    let ne: Expr = a.args.get(0);
                    if ne.kind != EX_IDENT { continue; }
                    if a.name.eq("proc_attr") {
                        sym_kind = SYMKIND_PROC_ATTR;
                        sym_name = ne.str_val;
                        sig = "proc-attr ".concat(ne.str_val);
                        label_extra = "";
                        snip = ne.str_val;
                        has_snip = false;
                        break;
                    }
                    if a.name.eq("proc_derive") {
                        sym_kind = SYMKIND_PROC_DERIVE;
                        sym_name = ne.str_val;
                        sig = "proc-derive ".concat(ne.str_val);
                        label_extra = "";
                        snip = ne.str_val;
                        has_snip = false;
                        break;
                    }
                    if a.name.eq("proc_macro") || a.name.eq("proc_macro_str") {
                        sym_kind = SYMKIND_PROC_MACRO;
                        sym_name = ne.str_val;
                        sig = "proc-macro ".concat(ne.str_val);
                        label_extra = "";
                        snip = ne.str_val.concat("!");
                        has_snip = false;
                        break;
                    }
                }
            }
        }
        else if s.kind == ST_STRUCT { sig = "struct ".concat(s.name); }
        else if s.kind == ST_ENUM { sig = "enum ".concat(s.name); }
        else if s.kind == ST_TRAIT { sig = "trait ".concat(s.name); }
        else if s.kind == ST_CONST { sig = "const ".concat(s.name); }
        else if s.kind == ST_MACRO_DEF {
            sig = macro_signature(&s);
            sym_name = s.name;   // user calls it as `name!`
        }
        let sym: ImportableSym = ImportableSym {
            name: sym_name,
            kind: sym_kind,
            module: module,
            signature: sig,
            label_extra: label_extra,
            doc: s.doc_comment,
            snippet: snip,
            has_snippet: has_snip,
        };
        state.stdlib_index.push(sym);
        if count < 12 {
            if !summary.eq("") { summary = summary.concat(", "); }
            summary = summary.concat("`").concat(s.name).concat("`");
        } else if count == 12 {
            summary = summary.concat(", …");
        }
        count = count + 1;
    }
    // Module entry — the header reads "Glide stdlib module" and the
    // exported names follow on the next line.
    let mut mdoc: string = "Glide stdlib module.";
    if !summary.eq("") {
        mdoc = mdoc.concat("\n\nExports: ").concat(summary).concat(".");
    }
    let mod_sym: ImportableSym = ImportableSym {
        name: mod_name,
        kind: SYMKIND_MODULE,
        module: module,
        signature: "module ".concat(mod_name),
        label_extra: "",
        doc: mdoc,
        snippet: mod_name.concat("::"),
        has_snippet: true,
    };
    state.stdlib_index.push(mod_sym);
}

// Compact label suffix for fn items, gopls-style: `(a: int, b: int) -> int`.
// Goes in `labelDetails.detail`, shown next to the function name.
fn fn_label_extra(s: *Stmt) -> string {
    let mut out: string = "(";
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            if i > 0 { out = out.concat(", "); }
            let p: Param = s.fn_params.get(i);
            out = out.concat(p.name).concat(": ").concat(type_to_string_pretty(p.ty));
        }
    }
    out = out.concat(")");
    if s.fn_ret_ty != null {
        out = out.concat(" -> ").concat(type_to_string_pretty(s.fn_ret_ty));
    }
    return out;
}

// gopls-style snippet for a fn call: `name(${1:p1}, ${2:p2})`. Each tab
// stop is the parameter name, so the user can Tab through and overwrite.
fn fn_snippet(s: *Stmt) -> string {
    let mut out: string = s.name.concat("(");
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            if i > 0 { out = out.concat(", "); }
            let p: Param = s.fn_params.get(i);
            out = out.concat("$").concat("{").concat(int_to_str((i + 1) as i64))
                     .concat(":").concat(p.name).concat("}");
        }
    }
    out = out.concat(")");
    return out;
}

// Helper: directory listing with a suffix filter. Mirrors fs_list from
// stdlib::fs but stays inside the LSP module to avoid the import dep.
extern fn __glide_list_dir(path: string, suffix: string) -> string;
extern fn __glide_fs_list_dirs(path: string) -> string;
extern fn __glide_file_exists(path: string) -> bool;
extern fn parent_dir(path: string) -> string;
fn fs_list_dir(dir: string, suffix: string) -> *Vector<string> {
    let raw: string = __glide_list_dir(dir, suffix);
    if raw.eq("") { return Vector::new(); }
    return raw.split("\n");
}

// Walk a Vector<Stmt> and free its parse-owned descendant containers
// (fn_body / then_body / else_body / impl_methods) recursively, then
// free the Vector itself. lower_block builds a fresh Vector for each
// of these on every reparse, so they always belong to the per-keystroke
// parse cycle regardless of the host Stmt's origin.
//
// Deliberately stops short of Expr / Type / for_init / Param fields:
// when the host Stmt came from a cached import those pointers refer
// into the cache's own AST graph, and lower_program never replaces
// them. Touching them would corrupt the cache. The user-buffer's own
// Expr / Type leaks are paid for once per keystroke and dwarfed by
// the Vector-of-Stmt accumulation this walker plugs.
fn stmt_vec_lower_free(v: *Vector<Stmt>) {
    if v == null { return; }
    for let i: i32 = 0; i < v.len(); i++ {
        let s: Stmt = v.get(i);
        stmt_lower_free_children(&s);
    }
    v.free();
}

fn stmt_lower_free_children(s: *Stmt) {
    if s == null { return; }
    if s.fn_body != null { stmt_vec_lower_free(s.fn_body); }
    if s.then_body != null { stmt_vec_lower_free(s.then_body); }
    if s.else_body != null { stmt_vec_lower_free(s.else_body); }
    if s.impl_methods != null { stmt_vec_lower_free(s.impl_methods); }
}

fn run_analysis_and_publish(uri: string, text: string, state: *LspState) {
    _lsp_log("  analyze enter: ".concat(uri));
    // Save the request-scoped arena (set by lsp_main for the duration
    // of this dispatch); we restore it at the end so any post-pipeline
    // handler scratch keeps flowing into the request arena and gets
    // reclaimed when the request returns.
    let prev_active: *void = __glide_palloc_get();
    // Doc-scoped arena lifecycle: free whatever the previous reanalysis
    // left in state.last_arena, then make a fresh one. Cached imports
    // and request scratch live in their own arenas, so the doc arena
    // exclusively holds the parse / lower / type pipeline output.
    //
    // Freeing the doc arena invalidates *every* open doc's stmts
    // pointer (they all alias into the same chunk chain in the current
    // single-doc-arena model). Null them out before the free so a
    // later hover / highlight on a stale doc returns empty results
    // instead of crashing on dangling memory.
    if state.last_arena != null {
        let keys: *Vector<string> = state.docs.keys();
        for let i: i32 = 0; i < keys.len(); i++ {
            let k: string = keys.get(i);
            let d: LspDoc = state.docs.get(k);
            d.stmts = null;
            state.docs.insert(k, d);
        }
        keys.free();
        __glide_palloc_free(state.last_arena);
    }
    let cur_arena: *void = __glide_palloc_make();
    state.last_arena = cur_arena;
    __glide_palloc_set(cur_arena);

    let path: string = uri_to_path(uri);
    // Pick up the project's lint config (`lint.deny` / `lint.allow` /
    // preset) so the editor surfaces the same warnings + promotions
    // the CLI does. Cached by manifest root: applied once per project,
    // then short-circuited on subsequent calls. Restart the LSP after
    // editing the manifest for changes to take effect — avoids
    // leaking a fresh copy of the deny/allow lists per keystroke.
    let mroot: string = find_manifest_root(_lsp_parent_dir(path));
    if !mroot.eq("") && !mroot.eq(state.lint_applied_root) {
        _lsp_log("    manifest lint apply: ".concat(mroot));
        _lsp_apply_manifest_lint(mroot);
        // Save the root on libc heap so the next-doc-arena reset
        // doesn't invalidate the cache key.
        let prev: *void = __glide_palloc_get();
        __glide_palloc_set(null);
        state.lint_applied_root = _strdup_libc(mroot);
        __glide_palloc_set(prev);
        _lsp_log("    manifest lint applied");
    }
    let stmts: *Vector<Stmt> = Vector::new();
    let loaded: *HashMap<bool> = HashMap::new();

    // Auto-inject src/builtins/ so hover/goto/completion see the same set
    // of primitives `glide build` does. src/stdlib/ modules have to be
    // pulled in via the user file's own `import` statements.
    let bdir: string = find_builtins_dir();
    let pdiags: *Vector<ParseDiag> = Vector::new();
    if !bdir.eq("") {
        load_builtins_dir_with_cache(stmts, bdir, loaded, pdiags, state.parse_cache);
    }

    // Parse the user's text and follow its `import "..."` directives so that
    // cross-file symbols (Stmt, Expr, Lexer, etc. when editing the bootstrap
    // codebase) resolve. Imports are resolved relative to the user file's dir.
    // Transitive imports go through state.parse_cache so stdlib + builtins
    // aren't relexed/reparsed on every keystroke.
    load_into_str_with_cache(stmts, text, path, loaded, pdiags, state.parse_cache);

    // Harvest macro definitions (free `macro foo!()`, `impl T { macro x!() }`,
    // proc-macro fns) BEFORE expand_macros runs — it consumes the defs into
    // a private registry and drops them from the output. Completion needs
    // the names to surface `name!`, `@attr`, `@derive(Name)`.
    let macro_defs: *Vector<Stmt> = Vector::new();
    let impl_macro_defs: *Vector<Stmt> = Vector::new();
    let proc_attrs: *Vector<string> = Vector::new();
    let proc_derives: *Vector<string> = Vector::new();
    let proc_macros: *Vector<string> = Vector::new();
    _harvest_macro_defs(stmts, macro_defs, impl_macro_defs, proc_attrs, proc_derives, proc_macros);

    // Snapshot the source-level stmts so documentSymbol / routeList can
    // read attrs that expand_macros will consume. Stmts are pushed by
    // value but their inner Vec pointers (attrs / fn_body / ...) still
    // alias the originals — that's fine: expand_macros builds a new
    // result Vector rather than mutating these structs in place.
    let pre_expand_stmts: *Vector<Stmt> = Vector::new();
    for let i: i32 = 0; i < stmts.len(); i++ { pre_expand_stmts.push(stmts.get(i)); }

    // Expand macros and lower surface-syntax sugar (for-in -> for) so the
    // typer sees the same shapes the build pipeline does. Without this,
    // anything inside a `for x in expr { ... }` body never gets type-checked
    // by the LSP.
    let expanded: *Vector<Stmt> = expand_macros(stmts);
    // user-only: cached imports came back from cache already lowered
    // at populate time, so we pass them through and only run the heavy
    // lower_block walk on the user buffer's stmts. Cuts the dominant
    // per-keystroke arena cost (was ~800 MB for bootstrap edits).
    let lowered: *Vector<Stmt> = lower_program_user_only(expanded, path);
    stmts.clear();
    for let i: i32 = 0; i < lowered.len(); i++ {
        let s: Stmt = lowered.get(i);
        stmts.push(s);
    }

    let t: *Typer = Typer::new();
    merge_parse_diags(t, pdiags);
    // The manifest (`glide.glide`) is config, not a program: the CLI only
    // parses it for literal fields and never type-checks it. Its `Package` /
    // `Dep` / `vec_of` identifiers are intentionally undeclared, so run only
    // the parse pass here — semantic checks would flag them as unknown.
    let is_manifest: bool = path_is_manifest(path);
    if !is_manifest {
        // Match the build / `glide check` pipeline: register the import-derived
        // visibility table and enforce it, so the editor flags unknown
        // functions / missing imports / out-of-scope names — not just the
        // null-safety + arity checks that run unconditionally. The doc's
        // builtins + transitive imports are already loaded into `stmts` above,
        // so every legit cross-file symbol is registered and won't false-flag.
        build_visibility(t, stmts);
        t.enforce_visibility = true;
        check_program(t, stmts);
        run_extra_analyses(t, stmts);
    }

    // Save the parsed stmts on the doc. The arena stays alive (in the
    // global g_palloc_active) until the next reanalysis, so this doc's
    // stmts remain valid for hover / completion / goto on the same
    // doc. Other docs' stmts are now dangling.
    if state.docs.contains(uri) {
        let d: LspDoc = state.docs.get(uri);
        d.stmts = stmts;
        d.pre_expand_stmts = pre_expand_stmts;
        d.macro_defs = macro_defs;
        d.impl_macro_defs = impl_macro_defs;
        d.proc_attrs = proc_attrs;
        d.proc_derives = proc_derives;
        d.proc_macros = proc_macros;
        state.docs.insert(uri, d);
    }

    // Only publish diagnostics whose origin matches the user's file path.
    // Errors from imported files (stdlib, ast.glide, etc.) are dropped here
    // — they'd appear at the wrong line/file in the editor.
    let arr: *JsonValue = json_array();
    for let i: i32 = 0; i < t.diagnostics.len(); i++ {
        let de: DiagEntry = t.diagnostics.get(i);
        if de.origin.eq(path) || de.origin.eq("") {
            json_arr_push(arr, diag_to_json(&de));
        }
    }

    let params: *JsonValue = json_object();
    json_obj_set(params, "uri", json_string(uri));
    json_obj_set(params, "diagnostics", arr);
    lsp_send_notification("textDocument/publishDiagnostics", params);

    t.free();
    expanded.free();
    lowered.free();
    pdiags.free();
    loaded.free();

    state.last_arena = __glide_palloc_get();
    // Restore the request arena so any handler-side scratch after this
    // reanalysis (e.g. publishDiagnostics tree) lands there and gets
    // reclaimed at end of dispatch.
    __glide_palloc_set(prev_active);
}

fn handle_did_open(req: *JsonValue, state: *LspState) {
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    let text: string = json_as_string(json_get(td, "text"));
    let version: i32 = json_as_int(json_get(td, "version"));
    // The leaf strings come straight out of the request tree
    // (jp_string_value's substring or jp_unescape's heap buffer).
    // json_free at end of lsp_main only frees tree wrappers, not leaf
    // strings, so retaining the pointer on doc keeps it alive.
    let prev_text: string = "";
    if state.docs.contains(uri) {
        let prev: LspDoc = state.docs.get(uri);
        prev_text = prev.text;
    }
    let no_macro_v: *Vector<Stmt> = null;
    let no_str_v: *Vector<string> = null;
    let doc: LspDoc = LspDoc {
        uri: uri, text: text, version: version, stmts: null,
        pre_expand_stmts: no_macro_v,
        macro_defs: no_macro_v, impl_macro_defs: no_macro_v,
        proc_attrs: no_str_v, proc_derives: no_str_v, proc_macros: no_str_v,
    };
    state.docs.insert(uri, doc);
    if !prev_text.eq("") { c_raw! { free((char*)(prev_text )); } }
    // Refresh project_index when the user opens a doc from a different
    // Glide project. Walks up from the file's directory looking for a
    // `glide.glide` manifest; populates symbols from the project's own
    // src/ tree plus every declared dep (path + git cache dir).
    _refresh_project_index(state, uri);
    run_analysis_and_publish(uri, text, state);
}

fn handle_did_change(req: *JsonValue, state: *LspState) {
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    let version: i32 = json_as_int(json_get(td, "version"));
    // Full-sync mode: contentChanges[0].text is the full new content.
    let changes: *JsonValue = json_get(params, "contentChanges");
    let first: *JsonValue = json_at(changes, 0);
    let text: string = json_as_string(json_get(first, "text"));
    if text.eq("") {
        // didChange w/ empty diff in incremental mode would land here; ignore.
        return;
    }
    let prev_stmts: *Vector<Stmt> = null;
    let prev_text: string = "";
    if state.docs.contains(uri) {
        let prev: LspDoc = state.docs.get(uri);
        prev_stmts = prev.stmts;
        prev_text = prev.text;
    }
    let no_macro_v2: *Vector<Stmt> = null;
    let no_str_v2: *Vector<string> = null;
    let doc: LspDoc = LspDoc {
        uri: uri, text: text, version: version, stmts: prev_stmts,
        pre_expand_stmts: no_macro_v2,
        macro_defs: no_macro_v2, impl_macro_defs: no_macro_v2,
        proc_attrs: no_str_v2, proc_derives: no_str_v2, proc_macros: no_str_v2,
    };
    state.docs.insert(uri, doc);
    if !prev_text.eq("") { c_raw! { free((char*)(prev_text )); } }
    run_analysis_and_publish(uri, text, state);
}

fn handle_did_close(req: *JsonValue, state: *LspState) {
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    let prev_text: string = "";
    if state.docs.contains(uri) {
        let prev: LspDoc = state.docs.get(uri);
        prev_text = prev.text;
    }
    state.docs.remove(uri);
    if !prev_text.eq("") { c_raw! { free((char*)(prev_text )); } }
    // Clear diagnostics for this URI.
    let p: *JsonValue = json_object();
    json_obj_set(p, "uri", json_string(uri));
    json_obj_set(p, "diagnostics", json_array());
    lsp_send_notification("textDocument/publishDiagnostics", p);
}

// Bundle of all extra-pass analyses. Both LSP and `glide check` call this.
pub fn run_extra_analyses(t: *Typer, stmts: *Vector<Stmt>) {
    analysis_unused_vars(t, stmts);
    analysis_unused_params(t, stmts);
    analysis_unused_fn(t, stmts);
    analysis_unnecessary_mut(t, stmts);
    analysis_arena_not_freed(t, stmts);
    analysis_addr_of_temporary(t, stmts);
    analysis_dead_code(t, stmts);
    analysis_missing_return(t, stmts);
    analysis_large_return(t, stmts);
    analysis_trait_conformance(t, stmts);
    analysis_deprecated_calls(t, stmts);
    analysis_unstable_calls(t, stmts);
    analysis_custom_lints(t, stmts);
    analysis_null_deref(t, stmts);
    analysis_bad_free(t, stmts);
    analysis_string_eq_op(t, stmts);
    analysis_unused_import(t, stmts);
    analysis_arena_set_unbalanced(t, stmts);
    analysis_coro_blocking(t, stmts);
    analysis_unhandled_result(t, stmts);
    analysis_ignored_option(t, stmts);
    analysis_use_after_free(t, stmts);
    analysis_mutex_unbalanced(t, stmts);
    analysis_chan_leak(t, stmts);
    analysis_leak_on_early_return(t, stmts);
    // Must run last — consumes diagnostics emitted by every other pass
    // to decide whether each @expect was fulfilled.
    analysis_expect_fulfillment(t, stmts);
}

// For each `impl Trait for Type { ... }` walk the trait's method names
// and verify the impl declares each one. Catches typos and forgotten
// methods at compile time, so the user gets a friendly Glide-level
// diagnostic instead of an opaque `undefined symbol` from the linker.
fn analysis_trait_conformance(t: *Typer, stmts: *Vector<Stmt>) {
    // First pass: index trait definitions by name.
    let traits: *HashMap<Stmt> = HashMap::new();
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind == ST_TRAIT && s.name != null && !s.name.eq("") {
            traits.insert(s.name, s);
        }
    }
    // Build a `<trait>::<type>` set so we can check supertraits in O(1).
    let impl_set: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_IMPL { continue; }
        if s.impl_trait_name == null || s.impl_trait_name.eq("") { continue; }
        if s.impl_target == null || s.impl_target.kind != TY_NAMED { continue; }
        impl_set.insert(s.impl_trait_name.concat("::").concat(s.impl_target.name), true);
    }

    // Second pass: validate each `impl Trait for Type`.
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_IMPL { continue; }
        if s.impl_trait_name == null || s.impl_trait_name.eq("") { continue; }

        if !traits.contains(s.impl_trait_name) {
            t.current_origin = s.origin;
            t.err_code(s.line, s.column, "unknown-trait",
                "trait `".concat(s.impl_trait_name).concat("` is not declared"));
            continue;
        }

        let trait_def: Stmt = traits.get(s.impl_trait_name);

        // Supertrait coverage: if `trait Bird: Animal`, then `impl Bird for T`
        // requires `impl Animal for T` to exist somewhere in the program.
        if trait_def.trait_supers != null && s.impl_target != null
           && s.impl_target.kind == TY_NAMED {
            for let k: i32 = 0; k < trait_def.trait_supers.len(); k++ {
                let sup: string = trait_def.trait_supers.get(k);
                let key: string = sup.concat("::").concat(s.impl_target.name);
                if !impl_set.contains(key) {
                    t.current_origin = s.origin;
                    t.err_code(s.line, s.column, "missing-supertrait",
                        "trait `".concat(s.impl_trait_name)
                            .concat("` requires `").concat(sup)
                            .concat("` but `").concat(s.impl_target.name)
                            .concat("` doesn't implement it"));
                }
            }
        }

        if trait_def.impl_methods == null { continue; }

        // Build a name-indexed lookup of impl methods so we can match each
        // trait method to its implementation and compare signatures.
        let provided: *HashMap<Stmt> = HashMap::new();
        if s.impl_methods != null {
            for let k: i32 = 0; k < s.impl_methods.len(); k++ {
                let m: Stmt = s.impl_methods.get(k);
                if m.name != null { provided.insert(m.name, m); }
            }
        }

        let mut target_name: string = "?";
        if s.impl_target != null && s.impl_target.kind == TY_NAMED {
            target_name = s.impl_target.name;
        }
        for let k: i32 = 0; k < trait_def.impl_methods.len(); k++ {
            let req: Stmt = trait_def.impl_methods.get(k);
            if req.name == null || req.name.eq("") { continue; }
            if !provided.contains(req.name) {
                t.current_origin = s.origin;
                t.err_code(s.line, s.column, "missing-trait-method",
                    "impl of trait `".concat(s.impl_trait_name)
                        .concat("` for `").concat(target_name)
                        .concat("` is missing method `").concat(req.name).concat("`"));
                continue;
            }
            // Signature matching: compare arity, each param's declared type,
            // and the return type. `Self` in the trait sig is the implementor
            // here; trait_def methods still have literal Self, so substitute
            // before comparing.
            let got: Stmt = provided.get(req.name);
            check_method_signature(t, s, req, got, target_name);
        }
    }
}

fn check_method_signature(t: *Typer, impl_stmt: Stmt, req: Stmt, got: Stmt, target_name: string) {
    let req_arity: i32 = if_param_count(req);
    let got_arity: i32 = if_param_count(got);
    if req_arity != got_arity {
        t.current_origin = impl_stmt.origin;
        t.err_code(got.line, got.column, "trait-method-mismatch",
            "method `".concat(req.name).concat("` has wrong arity for trait `")
                .concat(impl_stmt.impl_trait_name).concat("`: expected ")
                .concat(int_to_str(req_arity)).concat(" params, got ")
                .concat(int_to_str(got_arity)));
        return;
    }
    if req.fn_params != null && got.fn_params != null {
        for let i: i32 = 0; i < req_arity; i++ {
            let rp: Param = req.fn_params.get(i);
            let gp: Param = got.fn_params.get(i);
            let rty: *Type = subst_self(rp.ty, impl_stmt.impl_target);
            rty = subst_assoc(rty, impl_stmt.assoc_decls);
            if !types_compat(rty, gp.ty) {
                t.current_origin = impl_stmt.origin;
                t.err_code(got.line, got.column, "trait-method-mismatch",
                    "method `".concat(req.name).concat("` param `").concat(rp.name)
                        .concat("`: expected `").concat(type_to_string(rty))
                        .concat("`, got `").concat(type_to_string(gp.ty)).concat("`"));
                return;
            }
        }
    }
    let mut rret: *Type = subst_self(req.fn_ret_ty, impl_stmt.impl_target);
    rret = subst_assoc(rret, impl_stmt.assoc_decls);
    if !types_compat(rret, got.fn_ret_ty) {
        t.current_origin = impl_stmt.origin;
        t.err_code(got.line, got.column, "trait-method-mismatch",
            "method `".concat(req.name).concat("` return: expected `")
                .concat(type_to_string(rret)).concat("`, got `")
                .concat(type_to_string(got.fn_ret_ty)).concat("`"));
    }
}

// After Self substitution, an `Self::Item` becomes `<ImplTarget>::Item`. Resolve
// that against the impl's own `type Item = X;` declarations. Returns a fresh
// node — must NOT mutate the input (shared across impls).
fn subst_assoc(t: *Type, assocs: *Vector<Param>) -> *Type {
    if t == null { return null; }
    if assocs == null { return t; }
    if t.kind == TY_ASSOC {
        for let i: i32 = 0; i < assocs.len(); i++ {
            let a: Param = assocs.get(i);
            if a.name.eq(t.name) { return a.ty; }
        }
    }
    if t.inner == null && t.fnptr_ret == null { return t; }
    let copy: *Type = malloc(sizeof(Type)) as *Type;
    *copy = *t;
    if copy.inner != null { copy.inner = subst_assoc(copy.inner, assocs); }
    if copy.fnptr_ret != null { copy.fnptr_ret = subst_assoc(copy.fnptr_ret, assocs); }
    return copy;
}

fn if_param_count(s: Stmt) -> i32 {
    if s.fn_params == null { return 0; }
    return s.fn_params.len();
}

// Walk a Type and replace `Self` with `impl_target`, leaving everything
// else untouched. Returns a fresh node — must NOT mutate the input, since
// the trait sig is shared across every impl that names the trait.
fn subst_self(t: *Type, impl_target: *Type) -> *Type {
    if t == null { return null; }
    if impl_target == null { return t; }
    if t.kind == TY_NAMED && t.name.eq("Self") { return impl_target; }
    if t.inner == null && t.fnptr_ret == null { return t; }
    let copy: *Type = malloc(sizeof(Type)) as *Type;
    *copy = *t;
    if copy.inner != null { copy.inner = subst_self(copy.inner, impl_target); }
    if copy.fnptr_ret != null { copy.fnptr_ret = subst_self(copy.fnptr_ret, impl_target); }
    return copy;
    return t;
}

// ---- Position-based features: hover / symbols / goto ------------------

fn type_to_string_pretty(t: *Type) -> string {
    if t == null { return ""; }
    return type_to_string(t);
}

fn fn_signature(s: *Stmt) -> string {
    let mut sig: string = "fn ".concat(s.name).concat("(");
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            if i > 0 { sig = sig.concat(", "); }
            let p: Param = s.fn_params.get(i);
            sig = sig.concat(p.name).concat(": ").concat(type_to_string_pretty(p.ty));
        }
    }
    sig = sig.concat(")");
    if s.fn_ret_ty != null { sig = sig.concat(" -> ").concat(type_to_string_pretty(s.fn_ret_ty)); }
    return sig;
}

// Render a `macro name!($x:expr, $($y:expr),*)` signature for hover/completion.
fn macro_signature(s: *Stmt) -> string {
    let mut sig: string = "macro ".concat(s.name).concat("!(");
    if s.macro_params != null {
        for let i: i32 = 0; i < s.macro_params.len(); i++ {
            if i > 0 { sig = sig.concat(", "); }
            let mp: MacroParam = s.macro_params.get(i);
            if mp.is_variadic {
                let mut sep: string = ",";
                if !mp.separator.eq("") { sep = mp.separator; }
                sig = sig.concat("$(").concat("$").concat(mp.name).concat(":expr)").concat(sep).concat("*");
            } else {
                sig = sig.concat("$").concat(mp.name).concat(":expr");
            }
        }
    }
    sig = sig.concat(")");
    return sig;
}

// Walk top-level looking for a name match. Returns the declaring stmt or null.
fn find_top_decl(stmts: *Vector<Stmt>, name: string) -> *Stmt {
    if stmts == null { return null; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if (s.kind == ST_FN || s.kind == ST_STRUCT || s.kind == ST_ENUM
            || s.kind == ST_CONST || s.kind == ST_MACRO_DEF
            || s.kind == ST_TRAIT)
           && s.name.eq(name) {
            let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            *p = s;
            return p;
        }
    }
    return null;
}

// Find a local binding (let / param) named `name` inside `host` that's
// in scope at `before_line` (0-indexed). Walks the fn body recursively,
// drilling into nested blocks; returns the lexically-closest match so
// shadowing-by-block works the way users expect.
fn find_local_decl(host: *Stmt, name: string, before_line: i32) -> *Stmt {
    if host == null { return null; }
    // Params first — they're "above" every line of the body.
    if host.fn_params != null {
        for let i: i32 = 0; i < host.fn_params.len(); i++ {
            let p: Param = host.fn_params.get(i);
            if !p.name.eq(name) { continue; }
            // Synthesise a Stmt at the fn's name position so callers
            // can reuse range_for_decl_name + path_to_uri.
            let s: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            s.kind = ST_LET;
            s.name = p.name;
            s.let_ty = p.ty;
            s.let_value = null;
            s.is_mut = false;
            s.line = host.name_line;
            s.column = host.name_col;
            s.name_line = host.name_line;
            s.name_col = host.name_col;
            s.name_len = p.name.len();
            s.origin = host.origin;
            return s;
        }
    }
    return _find_let_in_block(host.fn_body, name, before_line);
}

fn _find_let_in_block(body: *Vector<Stmt>, name: string, before_line: i32) -> *Stmt {
    if body == null { return null; }
    let mut best: *Stmt = null;
    let mut best_line: i32 = -1;
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        // Lets visible at `before_line` if their decl line is at or
        // before it. Track the closest (max line ≤ before_line).
        if s.kind == ST_LET && s.name.eq(name) && (s.line - 1) <= before_line {
            if s.line > best_line {
                best_line = s.line;
                let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
                *p = s;
                best = p;
            }
        }
        // for-init's own let (`for let i = 0; ...`).
        if s.kind == ST_FOR && s.for_init != null && s.for_init.kind == ST_LET
           && s.for_init.name != null && s.for_init.name.eq(name)
           && (s.for_init.line - 1) <= before_line {
            if s.for_init.line > best_line {
                best_line = s.for_init.line;
                let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
                *p = *s.for_init;
                best = p;
            }
        }
        // Recurse into nested scopes — shadowing wins over outer lets.
        if s.then_body != null {
            let inner: *Stmt = _find_let_in_block(s.then_body, name, before_line);
            if inner != null && inner.line > best_line {
                best_line = inner.line;
                best = inner;
            }
        }
        if s.else_body != null {
            let inner: *Stmt = _find_let_in_block(s.else_body, name, before_line);
            if inner != null && inner.line > best_line {
                best_line = inner.line;
                best = inner;
            }
        }
        if s.fn_body != null && s.kind != ST_FN {
            let inner: *Stmt = _find_let_in_block(s.fn_body, name, before_line);
            if inner != null && inner.line > best_line {
                best_line = inner.line;
                best = inner;
            }
        }
        if s.for_init != null && s.for_init.then_body != null {
            let inner: *Stmt = _find_let_in_block(s.for_init.then_body, name, before_line);
            if inner != null && inner.line > best_line {
                best_line = inner.line;
                best = inner;
            }
        }
        // Match arm bodies.
        if s.kind == ST_MATCH && s.arms != null {
            for let j: i32 = 0; j < s.arms.len(); j++ {
                let arm: MatchArm = s.arms.get(j);
                let inner: *Stmt = _find_let_in_block(arm.body, name, before_line);
                if inner != null && inner.line > best_line {
                    best_line = inner.line;
                    best = inner;
                }
            }
        }
        // Closures embedded in this stmt's expressions.
        let ce1: *Stmt = _find_let_in_expr(s.let_value, name, before_line);
        if ce1 != null && ce1.line > best_line { best_line = ce1.line; best = ce1; }
        let ce2: *Stmt = _find_let_in_expr(s.expr_value, name, before_line);
        if ce2 != null && ce2.line > best_line { best_line = ce2.line; best = ce2; }
        let ce3: *Stmt = _find_let_in_expr(s.cond, name, before_line);
        if ce3 != null && ce3.line > best_line { best_line = ce3.line; best = ce3; }
        let ce4: *Stmt = _find_let_in_expr(s.for_step, name, before_line);
        if ce4 != null && ce4.line > best_line { best_line = ce4.line; best = ce4; }
    }
    return best;
}

// Walk an expression looking for an EX_FNEXPR that binds `name` as a param
// or contains a matching let in its body. Mirrors `_expr_var_type` but
// returns the synthesised / found Stmt so hover & goto-def can resolve to
// closure params, not just user-written let statements.
fn _find_let_in_expr(e: *Expr, name: string, before_line: i32) -> *Stmt {
    if e == null { return null; }
    if e.kind == EX_FNEXPR {
        if e.fn_expr_params != null {
            for let i: i32 = 0; i < e.fn_expr_params.len(); i++ {
                let p: Param = e.fn_expr_params.get(i);
                if p.name != null && p.name.eq(name) {
                    let st: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
                    st.kind = ST_LET;
                    st.name = p.name;
                    st.let_ty = p.ty;
                    st.let_value = null;
                    st.is_mut = false;
                    st.line = e.line;
                    st.column = e.column;
                    st.name_line = e.line;
                    st.name_col = e.column;
                    st.name_len = p.name.len();
                    return st;
                }
            }
        }
        if e.fn_expr_body != null && e.line - 1 <= before_line {
            let r: *Stmt = _find_let_in_block(e.fn_expr_body, name, before_line);
            if r != null { return r; }
        }
    }
    let r1: *Stmt = _find_let_in_expr(e.lhs, name, before_line);
    if r1 != null { return r1; }
    let r2: *Stmt = _find_let_in_expr(e.rhs, name, before_line);
    if r2 != null { return r2; }
    let r3: *Stmt = _find_let_in_expr(e.operand, name, before_line);
    if r3 != null { return r3; }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            let ra: *Stmt = _find_let_in_expr(&a, name, before_line);
            if ra != null { return ra; }
        }
    }
    return null;
}

// Macros are looked up by their unqualified name (without the trailing
// `!`). Walks top-level `macro` defs first, then any `impl T { macro
// ... }` blocks. Returns the first hit.
fn find_macro_def(stmts: *Vector<Stmt>, name: string) -> *Stmt {
    if stmts == null { return null; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind == ST_MACRO_DEF && s.name.eq(name) {
            let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            *p = s;
            return p;
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.kind == ST_MACRO_DEF && m.name.eq(name) {
                    let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
                    *p = m;
                    return p;
                }
            }
        }
    }
    return null;
}

// Proc macros live on a fn declaration tagged with `@proc_derive(Name)`,
// `@proc_attr(Name)`, `@proc_macro(Name)`, or `@proc_macro_str(Name)`.
// Clicking on `Name` inside `@derive(Name)` / `@Name` should jump to
// that fn. Walks every fn looking for a matching attr+arg pair.
fn find_proc_macro_fn(stmts: *Vector<Stmt>, name: string) -> *Stmt {
    if stmts == null { return null; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_FN || s.attrs == null { continue; }
        for let j: i32 = 0; j < s.attrs.len(); j++ {
            let a: Attr = s.attrs.get(j);
            let n: string = a.name;
            let is_proc: bool = n.eq("proc_derive") || n.eq("proc_attr")
                             || n.eq("proc_macro") || n.eq("proc_macro_str");
            if !is_proc { continue; }
            if a.args == null || a.args.len() == 0 { continue; }
            let arg0: Expr = a.args.get(0);
            if arg0.kind != EX_IDENT { continue; }
            if !arg0.str_val.eq(name) { continue; }
            let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            *p = s;
            return p;
        }
    }
    return null;
}

// Find a struct field decl. Field nodes don't carry their own line
// info, so we jump to the struct's name instead — close enough that
// the user lands on the right declaration to scan visually.
fn find_struct_field(stmts: *Vector<Stmt>, type_name: string, field: string) -> *Stmt {
    if stmts == null { return null; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_STRUCT || !s.name.eq(type_name) { continue; }
        if s.struct_fields == null { continue; }
        for let j: i32 = 0; j < s.struct_fields.len(); j++ {
            let f: Field = s.struct_fields.get(j);
            if !f.name.eq(field) { continue; }
            let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            *p = s;
            return p;
        }
    }
    return null;
}

// Find any impl-scoped macro by name. Mirrors `find_method_anywhere` for fns.
fn find_macro_in_impl_anywhere(stmts: *Vector<Stmt>, name: string) -> ImplMethodHit {
    let miss: ImplMethodHit = ImplMethodHit { method: null, owner: "" };
    if stmts == null { return miss; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_IMPL || s.impl_methods == null { continue; }
        let mut tname: string = "";
        if s.impl_target != null {
            if s.impl_target.kind == TY_NAMED { tname = s.impl_target.name; }
            if s.impl_target.kind == TY_GENERIC { tname = s.impl_target.name; }
        }
        for let j: i32 = 0; j < s.impl_methods.len(); j++ {
            let m: Stmt = s.impl_methods.get(j);
            if m.kind != ST_MACRO_DEF { continue; }
            if !m.name.eq(name) { continue; }
            let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            *p = m;
            if (p.origin == null || p.origin.eq("")) && s.origin != null {
                p.origin = s.origin;
            }
            let hit: ImplMethodHit = ImplMethodHit { method: p, owner: tname };
            return hit;
        }
    }
    return miss;
}

// Description for the language-builtin macros. Returns "" for unknown names.
fn builtin_macro_doc(name: string) -> string {
    if name.eq("println") {
        return "```glide\nmacro println!(...)\n```\n\n---\n\nPrint the args separated by spaces, terminated with a newline. Format spec is inferred per arg type.";
    }
    if name.eq("print") {
        return "```glide\nmacro print!(...)\n```\n\n---\n\nLike `println!` but without a trailing newline.";
    }
    if name.eq("format") {
        return "```glide\nmacro format!(\"fmt\", args...)\n```\n\n---\n\nReturn a formatted string. `{}` placeholders take the corresponding arg.";
    }
    return "";
}

// Hover docs for reserved keywords. Each returns markdown with a one-line
// summary plus a small worked example. Empty string = not a keyword we
// document (caller falls back to other lookups).
fn keyword_doc(name: string) -> string {
    // Bindings.
    if name.eq("let") {
        return "```glide\nlet name [: T] = expr;\n```\n\n---\n\nDeclares an immutable local binding. Add `mut` to allow reassignment, drop the type annotation when it can be inferred from the initializer.\n\n```glide\nlet x: i32 = 42;\nlet v = Vector::new();          // type inferred\nlet mut count: i32 = 0;\n```";
    }
    if name.eq("mut") {
        return "```glide\nlet mut name = expr;\n```\n\n---\n\nMarks a `let` binding as reassignable. Without `mut`, the binding is immutable.\n\n```glide\nlet mut n: i32 = 0;\nn = n + 1;                       // ok\n```";
    }
    if name.eq("const") {
        return "```glide\nconst NAME [: T] = expr;\n```\n\n---\n\nFile-scope constant. Lowered to a `#define` in C. The initializer must be a compile-time literal.\n\n```glide\nconst MAX: i32 = 1024;\nconst NAME: string = \"glide\";\n```";
    }

    // Types and items.
    if name.eq("fn") {
        return "```glide\nfn name(params) [-> T] { body }\n```\n\n---\n\nDeclare a function. Params are `name: type`. Omit `-> T` for void.\n\n```glide\nfn add(a: i32, b: i32) -> i32 {\n    return a + b;\n}\n```";
    }
    if name.eq("struct") {
        return "```glide\nstruct Name { field: T, ... }\n```\n\n---\n\nDeclare a value-type record. Fields are `name: type`, comma-separated.\n\n```glide\nstruct Point { x: i32, y: i32 }\nlet p: Point = Point { x: 1, y: 2 };\n```";
    }
    if name.eq("enum") {
        return "```glide\nenum Name { Variant, Variant(T1, T2), ... }\n```\n\n---\n\nTagged union. Each variant can carry zero or more positional payloads.\n\n```glide\nenum Shape { Circle(f64), Square(i32) }\nlet s: Shape = Shape::Circle(3.14);\n```";
    }
    if name.eq("impl") {
        return "```glide\nimpl T { fn method(self: *T, ...) { ... } }\n```\n\n---\n\nAttach methods (and macros) to a type. The first param `self: *T` makes the method instance-callable as `value.method(args)`.\n\n```glide\nimpl Counter {\n    fn bump(self: *Counter) { self.n = self.n + 1; }\n}\n```";
    }
    if name.eq("interface") {
        return "```glide\ninterface Name { fn method(self: *Self, ...) -> T; }\n```\n\n---\n\nDeclare a set of method signatures that types can implement.";
    }
    if name.eq("type") {
        return "```glide\ntype Alias = ExistingType;\n```\n\n---\n\nDefine a type alias. Resolved transparently — the alias and the original are interchangeable.\n\n```glide\ntype Bytes = []u8;\n```";
    }
    if name.eq("macro") {
        return "```glide\nmacro name!(matchers) { body }\n```\n\n---\n\nDeclare a `macro_rules`-style macro. Matchers use `$x:expr` and the variadic form `$($x:expr),*`. Inside an `impl`, body referring to `self` makes it instance-style.\n\n```glide\nmacro vec_of!($($x:expr),*) {\n    let v: *Vector<i32> = Vector::new();\n    $( v.push($x); )*\n}\n```";
    }

    // Control flow.
    if name.eq("if") {
        return "```glide\nif cond { ... } else if cond { ... } else { ... }\n```\n\n---\n\nBranch on a `bool`. Braces are required; the trailing `else` is optional.";
    }
    if name.eq("else") {
        return "```glide\nif cond { ... } else { ... }\n```\n\n---\n\nFalse-branch of an `if`. Can chain via `else if`.";
    }
    if name.eq("while") {
        return "```glide\nwhile cond { ... }\n```\n\n---\n\nLoop while `cond` evaluates to `true`. Use `break` / `continue` to control flow.\n\n```glide\nwhile !done { step(); }\n```";
    }
    if name.eq("for") {
        return "```glide\nfor IDENT in lo..hi { ... }      // exclusive range\nfor IDENT in lo..=hi { ... }     // inclusive range\nfor IDENT in collection { ... }  // any value with .len() / .get(i)\nfor let i = 0; i < n; i++ { ... } // C-style\n```\n\n---\n\nThree shapes share the keyword: range loops, collection iteration, and C-style.\n\n```glide\nfor i in 0..10 { println!(i); }\nfor x in v { println!(x); }\n```";
    }
    if name.eq("in") {
        return "```glide\nfor IDENT in EXPR { ... }\n```\n\n---\n\nBinder keyword used by the `for` shape. Has no other meaning outside `for`.";
    }
    if name.eq("return") {
        return "```glide\nreturn expr;     // value\nreturn;          // void\n```\n\n---\n\nLeave the enclosing function. The expression must match the declared return type.";
    }
    if name.eq("break") {
        return "```glide\nbreak;\n```\n\n---\n\nLeave the innermost loop (`for` or `while`).";
    }
    if name.eq("continue") {
        return "```glide\ncontinue;\n```\n\n---\n\nSkip to the next iteration of the innermost loop.";
    }
    if name.eq("match") {
        return "```glide\nmatch expr {\n    Variant1(payload) => { ... }\n    Variant2          => { ... }\n    _                 => { ... }\n}\n```\n\n---\n\nPattern-match an enum value. Each arm receives the variant's payload as bindings. `_` is the wildcard.";
    }

    // Memory & runtime.
    if name.eq("defer") {
        return "```glide\ndefer expr;\n```\n\n---\n\nRun `expr` at function exit (LIFO with other defers, before any `return`). Used for cleanup.\n\n```glide\nlet v: *Vector<i32> = Vector::new();\ndefer v.free();\n```";
    }
    if name.eq("defer_err") {
        return "```glide\ndefer_err expr;\n```\n\n---\n\nLike `defer`, but only fires when the function returns an `Err` / `!T` failure value. Lets you tear down half-built state without running the same code on the happy path.\n\n```glide\nlet conn: *Conn = open();\ndefer_err conn.close();          // only closes on error\nlet r: !i32 = conn.do_thing()?;\n// success → conn lives on\n```";
    }
    if name.eq("spawn") {
        return "```glide\nspawn fn_call(args);\n```\n\n---\n\nRun the call on a new pthread. Detached — no join handle.\n\n```glide\nspawn worker(c);\n```";
    }
    if name.eq("chan") {
        return "```glide\nlet c: chan<T> = make_chan(cap);\n```\n\n---\n\nTyped concurrent channel. Pair with `send(c, x)`, `recv(c)`, `close(c)`.";
    }
    if name.eq("select") {
        return "```glide\nselect! {\n    case x = recv(c1) => { ... }\n    case Some(v) = recv(c2) => { ... }   // close-aware\n    case send(c3, x) => { ... }\n    default => { ... }\n}\n```\n\n---\n\nMultiplex over chan operations. The first arm whose op completes wins; with a `default` arm the macro is non-blocking. `Some(v)`-bound receive returns `None` when the channel closes.";
    }
    if name.eq("dyn") {
        return "```glide\n*dyn Trait\n```\n\n---\n\nA pointer to an erased-type value that implements `Trait`. Dispatch is dynamic (vtable lookup) instead of monomorphised — useful for heterogeneous containers and runtime polymorphism.\n\n```glide\nlet w: *dyn Writer = &my_struct;\nw.write(\"hi\");\n```";
    }
    if name.eq("trait") {
        return "```glide\ntrait Name {\n    fn method(self: *Self, ...) -> T;\n    fn defaulted(self: *Self) -> i32 { return 0; }   // default impl\n}\n```\n\n---\n\nA set of method signatures (with optional default bodies) that types can implement via `impl Trait for T`. Used as bound `T: Trait` for generic constraints and via `*dyn Trait` for dynamic dispatch.";
    }
    if name.eq("interface") {
        return "```glide\ninterface Name { fn method(self: *Self, ...) -> T; }\n```\n\n---\n\nLegacy alias for `trait`. New code should prefer `trait`.";
    }
    if name.eq("Self") {
        return "```glide\nfn method(self: *Self) -> Self { ... }\n```\n\n---\n\nInside a `trait` / `impl` declaration, refers to the implementing type. Resolved to the concrete type at instantiation time.";
    }
    if name.eq("naked") {
        return "```glide\nnaked fn name(args) -> T { asm! { ... } }\n```\n\n---\n\nFunction emitted with `__attribute__((naked))` — no prologue / epilogue. Body must contain only `asm!` blocks; calling convention is raw, so you assemble the entire stack frame yourself.";
    }
    if name.eq("asm") {
        return "```glide\nasm! [volatile] {\n    \"instr\"\n    \"instr\"\n    : \"=c\"(out), ...      // outputs\n    : \"c\"(in), ...        // inputs\n    : \"clobber\", ...      // clobbers\n}\n```\n\n---\n\nInline assembly. Maps to GCC's extended-asm form. Sections are positional — leave a blank `:` to skip a slot.";
    }
    if name.eq("volatile") {
        return "```glide\nasm! volatile { ... }\n```\n\n---\n\nMarker on an `asm!` block that tells the compiler not to reorder or eliminate it even if its outputs aren't observed.";
    }
    if name.eq("move") {
        return "```glide\nmove fn(args) -> ret { body }\n```\n\n---\n\nClosure prefix that captures referenced locals by move (one-shot, releases the source). Without `move`, an `fn` expression with captures isn't allowed.";
    }
    if name.eq("new") {
        return "```glide\nlet p: *T = new T { field: value, ... };\n```\n\n---\n\nHeap-allocate a struct (raw — no auto-drop). Pair with `free` later.\n\nFor auto-dropped allocation use `let p: *T = T { ... };` (no `new`) instead.";
    }
    if name.eq("as") {
        return "```glide\nexpr as T\n```\n\n---\n\nExplicit cast between numeric types or pointer types. Compiles to a C cast.\n\n```glide\nlet n: i32 = some_long as i32;\nlet p: *void = buf as *void;\n```";
    }
    if name.eq("sizeof") {
        return "```glide\nsizeof(T)\n```\n\n---\n\nByte size of a type, like C's `sizeof`. Returns `usize`.";
    }

    // Modules / FFI.
    if name.eq("pub") {
        return "```glide\npub fn ...     pub struct ...     pub const ...\n```\n\n---\n\nMakes a top-level item visible across files. Default visibility is file-local.";
    }
    if name.eq("import") {
        return "```glide\nimport \"path/to/file.glide\";\n```\n\n---\n\nLoad another `.glide` source file into this compilation. Resolved relative to the current file. Cycle-safe.";
    }
    if name.eq("extern") {
        return "```glide\nextern fn name(args) -> T;\nextern type Name;\nextern type Name = \"struct foo\";\n```\n\n---\n\nDeclare a foreign C symbol that codegen will reference but not define. Pair with `c_link` to add the library at link time.";
    }
    if name.eq("c_include") {
        return "```glide\nc_include \"<header.h>\";\nc_include \"local.h\";\n```\n\n---\n\nInject a literal `#include` into the generated C. Use to expose types and prototypes for `extern` declarations.";
    }
    if name.eq("c_link") {
        return "```glide\nc_link \"name\";\n```\n\n---\n\nAdd `-lname` to the linker command. Use to pull in a library that backs `extern fn` declarations.";
    }

    // Literals.
    if name.eq("true")  { return "```glide\ntrue\n```\n\n---\n\nThe `true` boolean literal. `bool` in Glide maps to C's `_Bool`."; }
    if name.eq("false") { return "```glide\nfalse\n```\n\n---\n\nThe `false` boolean literal."; }
    if name.eq("null")  { return "```glide\nnull\n```\n\n---\n\nNull pointer. Compatible with any `*T` / `&T` / `&mut T`."; }
    if name.eq("self")  { return "```glide\nself: *T\n```\n\n---\n\nReceiver parameter inside an `impl` method. Convention: declare as `self: *T`, callers use `value.method(args)`."; }

    return "";
}

// Scan every `impl Type { ... }` block for a method whose name matches; return
// the first hit. Used by hover when the user points at an impl-method name and
// we don't have a receiver type to disambiguate.
pub struct ImplMethodHit {
    pub method: *Stmt,
    pub owner: string,
}

fn find_method_anywhere(stmts: *Vector<Stmt>, method_name: string) -> ImplMethodHit {
    let miss: ImplMethodHit = ImplMethodHit { method: null, owner: "" };
    if stmts == null { return miss; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_IMPL || s.impl_methods == null { continue; }
        let mut tname: string = "";
        if s.impl_target != null {
            if s.impl_target.kind == TY_NAMED { tname = s.impl_target.name; }
            if s.impl_target.kind == TY_GENERIC { tname = s.impl_target.name; }
        }
        for let j: i32 = 0; j < s.impl_methods.len(); j++ {
            let m: Stmt = s.impl_methods.get(j);
            if m.kind != ST_FN { continue; }
            if !m.name.eq(method_name) { continue; }
            let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            *p = m;
            if (p.origin == null || p.origin.eq("")) && s.origin != null {
                p.origin = s.origin;
            }
            let hit: ImplMethodHit = ImplMethodHit { method: p, owner: tname };
            return hit;
        }
    }
    return miss;
}

// Result of `find_field_anywhere`: the parent struct's name + the field def.
pub struct FieldHit {
    pub owner: string,
    pub name: string,
    pub ty: *Type,
    pub doc: string,
}

fn find_field_anywhere(stmts: *Vector<Stmt>, field_name: string) -> FieldHit {
    let miss: FieldHit = FieldHit { owner: "", name: "", ty: null, doc: "" };
    if stmts == null { return miss; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_STRUCT || s.struct_fields == null { continue; }
        for let j: i32 = 0; j < s.struct_fields.len(); j++ {
            let f: Field = s.struct_fields.get(j);
            if !f.name.eq(field_name) { continue; }
            let hit: FieldHit = FieldHit { owner: s.name, name: f.name, ty: f.ty, doc: f.doc };
            return hit;
        }
    }
    return miss;
}

// Search inside `impl Type { ... }` blocks for a method by name. The returned
// Stmt's `origin` is taken from the parent impl, since impl_methods stmts are
// populated by parse_fn before load_into_str stamps origin on the impl.
fn find_method_in_impl(stmts: *Vector<Stmt>, type_name: string, method_name: string) -> *Stmt {
    if stmts == null { return null; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_IMPL { continue; }
        if s.impl_target == null { continue; }
        let mut tname: string = "";
        if s.impl_target.kind == TY_NAMED { tname = s.impl_target.name; }
        if s.impl_target.kind == TY_GENERIC { tname = s.impl_target.name; }
        if !tname.eq(type_name) { continue; }
        if s.impl_methods == null { continue; }
        for let j: i32 = 0; j < s.impl_methods.len(); j++ {
            let m: Stmt = s.impl_methods.get(j);
            if (m.kind == ST_FN || m.kind == ST_MACRO_DEF) && m.name.eq(method_name) {
                let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
                *p = m;
                if (p.origin == null || p.origin.eq("")) && s.origin != null {
                    p.origin = s.origin;
                }
                return p;
            }
        }
    }
    return null;
}

// Crude "word at position": lex once, find the token whose range contains the
// (line0, col0) — both 0-indexed from the LSP. Returns the token's lexeme or "".
fn word_at(text: string, line0: i32, col0: i32) -> string {
    let lex: *Lexer = Lexer::new(text);
    while true {
        let tok: Token = lex.next_token();
        if tok.kind == TOK_EOF { return ""; }
        if tok.kind != TOK_IDENT && tok.kind != TOK_KEYWORD { continue; }
        // Lexer line/col is 1-indexed.
        let tline: i32 = tok.line - 1;
        let tcol: i32 = tok.column - 1;
        let len: i32 = tok.lexeme.len();
        if tline == line0 && col0 >= tcol && col0 <= tcol + len {
            return tok.lexeme;
        }
    }
    return "";
}

// Best-effort type inference for hover. Mirrors what the codegen does in
// `try_resolve_open_let`: when a variable is declared as `Generic::new()`
// without an annotation, walk subsequent uses in the same body looking for
// a method call that constrains the type parameter. Single-T case only.
fn lsp_infer_expr(stmts: *Vector<Stmt>, host: *Stmt, e: *Expr) -> *Type {
    if e == null { return null; }
    if e.kind == EX_INT { return ty_named("i32"); }
    if e.kind == EX_FLOAT { return ty_named("f64"); }
    if e.kind == EX_STRING { return ty_named("string"); }
    if e.kind == EX_BOOL { return ty_named("bool"); }
    if e.kind == EX_CHAR { return ty_named("char"); }
    if e.kind == EX_IDENT && e.str_val != null && host != null {
        if host.fn_params != null {
            for let i: i32 = 0; i < host.fn_params.len(); i++ {
                let p: Param = host.fn_params.get(i);
                if p.name.eq(e.str_val) { return p.ty; }
            }
        }
        let lst: *Stmt = find_local_let_in_body(host.fn_body, e.str_val);
        if lst != null {
            if lst.let_ty != null { return lst.let_ty; }
            if lst.let_value != null { return lsp_infer_expr(stmts, host, lst.let_value); }
        }
    }
    return null;
}

// Look up the impl block whose target name matches `gen_name`, returning its
// type-param names and method list so the caller can probe constraints.
fn find_generic_impl(stmts: *Vector<Stmt>, gen_name: string) -> *Stmt {
    if stmts == null { return null; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_IMPL { continue; }
        if s.impl_target == null { continue; }
        let mut tname: string = "";
        if s.impl_target.kind == TY_NAMED { tname = s.impl_target.name; }
        if s.impl_target.kind == TY_GENERIC { tname = s.impl_target.name; }
        if tname.eq(gen_name) {
            let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            *p = s;
            return p;
        }
    }
    return null;
}

fn name_in_tparams(name: string, tparams: *Vector<string>) -> bool {
    if tparams == null { return false; }
    for let i: i32 = 0; i < tparams.len(); i++ {
        if tparams.get(i).eq(name) { return true; }
    }
    return false;
}

// If `e` is `var.method(args)`, find the impl method's first parameter (after
// `self`) whose declared type is a type-param, and return the inferred type
// of the corresponding user arg. Returns null when no constraint exists.
fn try_constrain_call(stmts: *Vector<Stmt>, host: *Stmt, e: *Expr, var: string,
                       impl_methods: *Vector<Stmt>, tparams: *Vector<string>) -> *Type {
    if e == null || e.kind != EX_CALL || e.lhs == null || e.lhs.kind != EX_MEMBER { return null; }
    if e.lhs.lhs == null || e.lhs.lhs.kind != EX_IDENT { return null; }
    if e.lhs.lhs.str_val == null || !e.lhs.lhs.str_val.eq(var) { return null; }
    let method: string = e.lhs.field;
    if impl_methods == null { return null; }
    for let i: i32 = 0; i < impl_methods.len(); i++ {
        let m: Stmt = impl_methods.get(i);
        if m.kind != ST_FN || !m.name.eq(method) { continue; }
        if m.fn_params == null || e.args == null { return null; }
        for let j: i32 = 1; j < m.fn_params.len(); j++ {
            let mp: Param = m.fn_params.get(j);
            if mp.ty == null || mp.ty.kind != TY_NAMED { continue; }
            if !name_in_tparams(mp.ty.name, tparams) { continue; }
            let arg_idx: i32 = j - 1;
            if arg_idx >= e.args.len() { continue; }
            let a: Expr = e.args.get(arg_idx);
            let at: *Type = lsp_infer_expr(stmts, host, &a);
            if at != null { return at; }
        }
    }
    return null;
}

fn walk_constraint_in_expr(stmts: *Vector<Stmt>, host: *Stmt, e: *Expr, var: string,
                            impl_methods: *Vector<Stmt>, tparams: *Vector<string>) -> *Type {
    if e == null { return null; }
    let r: *Type = try_constrain_call(stmts, host, e, var, impl_methods, tparams);
    if r != null { return r; }
    if e.lhs != null {
        let r2: *Type = walk_constraint_in_expr(stmts, host, e.lhs, var, impl_methods, tparams);
        if r2 != null { return r2; }
    }
    if e.rhs != null {
        let r2: *Type = walk_constraint_in_expr(stmts, host, e.rhs, var, impl_methods, tparams);
        if r2 != null { return r2; }
    }
    if e.operand != null {
        let r2: *Type = walk_constraint_in_expr(stmts, host, e.operand, var, impl_methods, tparams);
        if r2 != null { return r2; }
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            let r2: *Type = walk_constraint_in_expr(stmts, host, &a, var, impl_methods, tparams);
            if r2 != null { return r2; }
        }
    }
    return null;
}

fn walk_constraint_in_body(stmts: *Vector<Stmt>, host: *Stmt, body: *Vector<Stmt>, var: string,
                            impl_methods: *Vector<Stmt>, tparams: *Vector<string>) -> *Type {
    if body == null { return null; }
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.expr_value != null {
            let r: *Type = walk_constraint_in_expr(stmts, host, s.expr_value, var, impl_methods, tparams);
            if r != null { return r; }
        }
        if s.let_value != null {
            let r: *Type = walk_constraint_in_expr(stmts, host, s.let_value, var, impl_methods, tparams);
            if r != null { return r; }
        }
        if s.cond != null {
            let r: *Type = walk_constraint_in_expr(stmts, host, s.cond, var, impl_methods, tparams);
            if r != null { return r; }
        }
        if s.for_step != null {
            let r: *Type = walk_constraint_in_expr(stmts, host, s.for_step, var, impl_methods, tparams);
            if r != null { return r; }
        }
        if s.then_body != null {
            let r: *Type = walk_constraint_in_body(stmts, host, s.then_body, var, impl_methods, tparams);
            if r != null { return r; }
        }
        if s.else_body != null {
            let r: *Type = walk_constraint_in_body(stmts, host, s.else_body, var, impl_methods, tparams);
            if r != null { return r; }
        }
    }
    return null;
}

// Walk the fn body recursively, return the first ST_LET (or for-loop's let
// init) matching `name`. Heap-copies so the caller has stable pointer.
fn find_local_let_in_body(body: *Vector<Stmt>, name: string) -> *Stmt {
    if body == null { return null; }
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null && s.name.eq(name) {
            let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            *p = s;
            return p;
        }
        if s.kind == ST_FOR && s.for_init != null && s.for_init.kind == ST_LET
           && s.for_init.name != null && s.for_init.name.eq(name) {
            let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            *p = *s.for_init;
            return p;
        }
        if s.then_body != null {
            let r: *Stmt = find_local_let_in_body(s.then_body, name);
            if r != null { return r; }
        }
        if s.else_body != null {
            let r: *Stmt = find_local_let_in_body(s.else_body, name);
            if r != null { return r; }
        }
    }
    return null;
}

// Render a hover string for a local `let`. Prefers the explicit annotation;
// otherwise infers from the initializer (literals, or `Generic::new()` plus
// a constraint from later usage like `var.push(x)` to resolve T).
fn render_hover_for_let(stmts: *Vector<Stmt>, host: *Stmt, s: *Stmt) -> string {
    let mut header: string = "let ";
    if s.is_mut { header = header.concat("mut "); }
    header = header.concat(s.name);
    let mut inferred: bool = false;
    if s.let_ty != null {
        header = header.concat(": ").concat(type_to_string_pretty(s.let_ty));
    } else if s.let_value != null {
        let e: *Expr = s.let_value;
        if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_PATH {
            // `Generic::new()` form. Try to resolve the type-param by walking
            // subsequent uses of `s.name` in the host fn's body.
            let gen_name: string = e.lhs.str_val;
            let mut t_str: string = "?";
            let imp: *Stmt = find_generic_impl(stmts, gen_name);
            if imp != null && host != null && host.fn_body != null {
                let r: *Type = walk_constraint_in_body(stmts, host, host.fn_body, s.name,
                                                       imp.impl_methods, imp.type_params);
                if r != null { t_str = type_to_string_pretty(r); }
            }
            header = header.concat(": *").concat(gen_name).concat("<").concat(t_str).concat(">");
            inferred = true;
        } else if e.kind == EX_INT    { header = header.concat(": i32"); inferred = true; }
        else if e.kind == EX_FLOAT  { header = header.concat(": f64"); inferred = true; }
        else if e.kind == EX_STRING { header = header.concat(": string"); inferred = true; }
        else if e.kind == EX_BOOL   { header = header.concat(": bool"); inferred = true; }
        else if e.kind == EX_CHAR   { header = header.concat(": char"); inferred = true; }
    }
    let mut block: string = "```glide\n".concat(header).concat("\n```");
    if inferred {
        block = block.concat("\n\n*type inferred*");
    }
    return block;
}

// Hover card for a manifest (`glide.glide`) schema symbol — the `Package`
// fields, the literal itself, `vec_of`, and the `Dep` constructors. Returns
// markdown content, or "" when `word` isn't part of the manifest schema (the
// caller then falls back to generic hover so keywords like `let` still work).
fn _manifest_hover_doc(word: string) -> string {
    let mut sig: string = "";
    let mut desc: string = "";
    if word.eq("name") { sig = "name: string"; desc = "Package name. **Required.**"; }
    else if word.eq("version") { sig = "version: string"; desc = "Semver version, e.g. `\"0.1.0\"`. **Required.**"; }
    else if word.eq("bin") { sig = "bin: string"; desc = "Entry-point source file. Defaults to `src/main.glide`."; }
    else if word.eq("deps") { sig = "deps: vec_of(...)"; desc = "Dependency list. Each entry is a `Dep::path(...)` or `Dep::git(...)`."; }
    else if word.eq("description") { sig = "description: string"; desc = "Short summary. Optional, informational."; }
    else if word.eq("author") { sig = "author: string"; desc = "Author, e.g. `\"Ada <ada@example.com>\"`. Optional."; }
    else if word.eq("license") { sig = "license: string"; desc = "SPDX identifier, e.g. `\"MIT\"`. Optional."; }
    else if word.eq("repository") { sig = "repository: string"; desc = "Source URL. Optional."; }
    else if word.eq("target") { sig = "target: string"; desc = "Default cross-compile triple, e.g. `\"x86_64-linux-musl\"`. Optional."; }
    else if word.eq("Package") {
        sig = "Package { ... }";
        desc = "Project manifest. The CLI reads its literal fields; it is never compiled. Required fields `name` / `version`; common `bin` / `deps`; optional `description` / `author` / `license` / `repository` / `target`.";
    }
    else if word.eq("vec_of") { sig = "vec_of(...)"; desc = "Builds the `deps` list. Each argument is a `Dep::path` or `Dep::git`."; }
    else if word.eq("Dep") { sig = "Dep::path | Dep::git"; desc = "Dependency constructors: `Dep::path(name, rel_path)` (local) or `Dep::git(name, url, rev)`."; }
    else if word.eq("path") { sig = "Dep::path(name, rel_path)"; desc = "Depend on a package at a local filesystem path."; }
    else if word.eq("git") { sig = "Dep::git(name, url, rev)"; desc = "Depend on a package from a git repository at a tag or commit."; }
    if sig.eq("") { return ""; }
    return "```glide\n".concat(sig).concat("\n```\n\n---\n\n").concat(desc);
}

fn handle_hover(req: *JsonValue, state: *LspState) {
    let id: *JsonValue = json_get(req, "id");
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    let pos: *JsonValue = json_get(params, "position");
    let line0: i32 = json_as_int(json_get(pos, "line"));
    let col0: i32 = json_as_int(json_get(pos, "character"));

    if !state.docs.contains(uri) { lsp_send_response(id, json_null()); return; }
    let doc: LspDoc = state.docs.get(uri);

    let word: string = word_at(doc.text, line0, col0);
    if word.eq("") { lsp_send_response(id, json_null()); return; }

    // Manifest (`glide.glide`) schema hover. On a hit we respond directly;
    // otherwise fall through so keywords (`let`) still get their generic card.
    if path_is_manifest(uri_to_path(uri)) {
        let mdoc: string = _manifest_hover_doc(word);
        if !mdoc.eq("") {
            let mres: *JsonValue = json_object();
            let mc: *JsonValue = json_object();
            json_obj_set(mc, "kind", json_string("markdown"));
            json_obj_set(mc, "value", json_string(mdoc));
            json_obj_set(mres, "contents", mc);
            lsp_send_response(id, mres);
            return;
        }
    }

    let mut decl: *Stmt = null;
    let mut content: string = "";

    // Proc-macro name inside `@derive(Name)` / `@Name(...)` / `@Name`:
    // resolve via the registry of fns wearing `@proc_<kind>(Name)`. Has
    // to run before `find_top_decl(word)` because the registered name
    // (e.g. JsonBind) usually doesn't match any top-level decl — the
    // impl fn is private and named differently (`derive_json_bind`).
    if _inside_proc_attr_arg(doc.text, line0, col0)
       || _on_bare_attribute_name(doc.text, line0, col0) {
        let pm: *Stmt = find_proc_macro_fn(doc.stmts, word);
        if pm != null {
            decl = pm;
            // Render as `@proc_<kind>(Name)` instead of the impl fn's
            // signature — that's what the user actually wrote, and it
            // tells them what shape of macro they're invoking.
            let mut kind_label: string = "proc-macro";
            if pm.attrs != null {
                for let i: i32 = 0; i < pm.attrs.len(); i++ {
                    let a: Attr = pm.attrs.get(i);
                    if a.name == null { continue; }
                    if a.name.eq("proc_derive") { kind_label = "proc-derive"; break; }
                    if a.name.eq("proc_attr")   { kind_label = "proc-attr"; break; }
                    if a.name.eq("proc_macro")  { kind_label = "proc-macro"; break; }
                    if a.name.eq("proc_macro_str") { kind_label = "proc-macro (str)"; break; }
                }
            }
            content = "```glide\n".concat(kind_label).concat(" ").concat(word).concat("\n```");
            if pm.doc_comment != null && !pm.doc_comment.eq("") {
                content = content.concat("\n\n---\n\n").concat(pm.doc_comment);
            }
        } else {
            // Builtin attribute (`@cfg`, `@derive`, `@expect`, `@allow`,
            // `@deprecated`, `@lint`, `@proc_*`). Show a one-line
            // description so hovering the attr name itself produces a
            // card instead of null.
            let bi: string = _builtin_attr_doc(word);
            if !bi.eq("") {
                content = "```glide\n@".concat(word).concat("\n```\n\n---\n\n").concat(bi);
            }
        }
    }

    if decl == null && content.eq("") { decl = find_top_decl(doc.stmts, word); }
    if decl != null && content.eq("") {
        if decl.kind == ST_FN { content = "```glide\n".concat(fn_signature(decl)).concat("\n```"); }
        else if decl.kind == ST_STRUCT {
            content = "```glide\nstruct ".concat(decl.name).concat("\n```");
        }
        else if decl.kind == ST_ENUM {
            content = "```glide\nenum ".concat(decl.name).concat("\n```");
        }
        else if decl.kind == ST_CONST {
            content = "```glide\nconst ".concat(decl.name);
            if decl.let_ty != null { content = content.concat(": ").concat(type_to_string_pretty(decl.let_ty)); }
            content = content.concat("\n```");
        }
        else if decl.kind == ST_MACRO_DEF {
            content = "```glide\n".concat(macro_signature(decl)).concat("\n```");
        }
        // Append the decl's doc comment (the contiguous `//` block above it).
        if !content.eq("") && decl.doc_comment != null && !decl.doc_comment.eq("") {
            content = content.concat("\n\n---\n\n").concat(decl.doc_comment);
        }
    }

    // Local: search the fn body for a `let` (or `for let`) by name, and the
    // fn's params, so hover on a variable shows its type.
    if content.eq("") {
        let host: *Stmt = fn_containing(doc.stmts, line0, uri_to_path(uri));
        if host != null {
            if host.fn_params != null {
                for let i: i32 = 0; i < host.fn_params.len(); i++ {
                    let pp: Param = host.fn_params.get(i);
                    if pp.name.eq(word) {
                        let mut h: string = "param ".concat(pp.name);
                        if pp.ty != null { h = h.concat(": ").concat(type_to_string_pretty(pp.ty)); }
                        content = "```glide\n".concat(h).concat("\n```");
                        break;
                    }
                }
            }
            if content.eq("") {
                let lst: *Stmt = find_local_let_in_body(host.fn_body, word);
                if lst != null {
                    content = render_hover_for_let(doc.stmts, host, lst);
                }
            }
        }
    }

    // Impl method: hover on a method name in either the decl site or a call
    // (`v.push(x)` or `Type::push(...)`). First match across all impl blocks.
    if content.eq("") {
        let mhit: ImplMethodHit = find_method_anywhere(doc.stmts, word);
        if mhit.method != null {
            let m: *Stmt = mhit.method;
            let mut sig: string = fn_signature(m);
            if !mhit.owner.eq("") {
                sig = "impl ".concat(mhit.owner).concat("\n").concat(sig);
            }
            content = "```glide\n".concat(sig).concat("\n```");
            if m.doc_comment != null && !m.doc_comment.eq("") {
                content = content.concat("\n\n---\n\n").concat(m.doc_comment);
            }
        }
    }

    // Struct field: hover on a field name (decl site or `obj.field` access).
    // Linear scan; first matching field wins. With named-collision across
    // structs the user may need to point at the receiver instead.
    if content.eq("") {
        let fhit: FieldHit = find_field_anywhere(doc.stmts, word);
        if !fhit.name.eq("") {
            let mut sig: string = fhit.owner.concat(".").concat(fhit.name);
            if fhit.ty != null {
                sig = sig.concat(": ").concat(type_to_string_pretty(fhit.ty));
            }
            content = "```glide\n".concat(sig).concat("\n```");
            if fhit.doc != null && !fhit.doc.eq("") {
                content = content.concat("\n\n---\n\n").concat(fhit.doc);
            }
        }
    }

    // Type-attached macro: hover on a macro name in `impl T { macro foo!... }`
    // decl or at a `v.foo!(...)` / `Type::foo!(...)` / `T::foo!()` call site.
    if content.eq("") {
        let mhit2: ImplMethodHit = find_macro_in_impl_anywhere(doc.stmts, word);
        if mhit2.method != null {
            let m: *Stmt = mhit2.method;
            let mut sig: string = macro_signature(m);
            if !mhit2.owner.eq("") {
                sig = "impl ".concat(mhit2.owner).concat("\n").concat(sig);
            }
            content = "```glide\n".concat(sig).concat("\n```");
            if m.doc_comment != null && !m.doc_comment.eq("") {
                content = content.concat("\n\n---\n\n").concat(m.doc_comment);
            }
        }
    }

    // Builtin macros (`println`, `print`, `format`).
    if content.eq("") {
        let bd: string = builtin_macro_doc(word);
        if !bd.eq("") { content = bd; }
    }

    // Reserved-word docs (`fn`, `let`, `for`, etc).
    if content.eq("") {
        let kd: string = keyword_doc(word);
        if !kd.eq("") { content = kd; }
    }

    if content.eq("") {
        // Built-in keywords / types fallback.
        if word.eq("int") || word.eq("uint") || word.eq("long") || word.eq("ulong")
           || word.eq("float") || word.eq("bool") || word.eq("string") || word.eq("char")
           || word.eq("usize") || word.eq("isize")
           || word.eq("i8") || word.eq("i16") || word.eq("i32") || word.eq("i64")
           || word.eq("u8") || word.eq("u16") || word.eq("u32") || word.eq("u64")
           || word.eq("f32") || word.eq("f64") {
            content = "```glide\n// built-in type: ".concat(word).concat("\n```");
        }
    }

    if content.eq("") { lsp_send_response(id, json_null()); return; }

    let result: *JsonValue = json_object();
    let contents: *JsonValue = json_object();
    json_obj_set(contents, "kind", json_string("markdown"));
    json_obj_set(contents, "value", json_string(content));
    json_obj_set(result, "contents", contents);
    lsp_send_response(id, result);
}

// LSP SymbolKind values:
//   12 = Function, 13 = Variable, 14 = Constant, 22 = Struct, 10 = Enum, 9 = Constructor
fn symbol_kind_for(s: *Stmt) -> i32 {
    if s.kind == ST_FN { return 12; }
    if s.kind == ST_STRUCT { return 22; }
    if s.kind == ST_ENUM { return 10; }
    if s.kind == ST_CONST { return 14; }
    return 13;
}

fn position_to_json(line1: i32, col1: i32) -> *JsonValue {
    let p: *JsonValue = json_object();
    let mut l: i32 = line1 - 1; if l < 0 { l = 0; }
    let mut c: i32 = col1 - 1; if c < 0 { c = 0; }
    json_obj_set(p, "line", json_int(l));
    json_obj_set(p, "character", json_int(c));
    return p;
}

// Range covering the declaration's name (the bit a user actually wants to
// jump to / highlight). Falls back to the whole stmt's start if the parser
// didn't capture a name position.
fn range_for_decl_name(s: *Stmt) -> *JsonValue {
    let mut nl: i32 = s.name_line;
    let mut nc: i32 = s.name_col;
    let mut nlen: i32 = s.name_len;
    if nl == 0 { nl = s.line; nc = s.column; nlen = 1; }
    if nlen < 1 { nlen = 1; }
    let r: *JsonValue = json_object();
    json_obj_set(r, "start", position_to_json(nl, nc));
    json_obj_set(r, "end",   position_to_json(nl, nc + nlen));
    return r;
}

// Replace backslashes with forward slashes so Windows paths like
// `C:\Users\...\stdlib\vector.glide` produce a clean `file:///C:/...` URI.
fn normalize_path(path: string) -> string {
    if path == null || path.len() == 0 { return ""; }
    let n: i32 = path.len();
    let mut out: string = "";
    let mut i: i32 = 0;
    while i < n {
        let c: i32 = path.at(i).to_int();
        if c == 92 { out = out.concat("/"); }
        else { out = out.concat(path.substring(i, i + 1)); }
        i = i + 1;
    }
    return out;
}

// `true` when `p` looks absolute on the host platform: leading `/` on
// POSIX, or `<letter>:/` / `<letter>:\` on Windows. The path should
// already be normalized (forward-slashed).
fn is_absolute_path(p: string) -> bool {
    let n: i32 = p.len();
    if n == 0 { return false; }
    if p.at(0).to_int() == 47 { return true; }
    if n >= 3 {
        let c2: i32 = p.at(1).to_int();
        let c3: i32 = p.at(2).to_int();
        if c2 == 58 && (c3 == 47 || c3 == 92) { return true; }
    }
    return false;
}

// Convert a filesystem path to a `file://` URI. Handles both POSIX
// (`/path/to/x`) and Windows (`C:/path/to/x`). Relative paths get
// prefixed with the LSP's working directory so import origins like
// `src/stdlib/hashmap.glide` produce a clickable URI for goto-def.
fn path_to_uri(path: string) -> string {
    if path == null || path.len() == 0 { return ""; }
    let mut p: string = normalize_path(path);
    if !is_absolute_path(p) {
        let cwd: string = normalize_path(__glide_cwd());
        if !cwd.eq("") {
            if cwd.at(cwd.len() - 1).to_int() == 47 {
                p = cwd.concat(p);
            } else {
                p = cwd.concat("/").concat(p);
            }
        }
    }
    if p.at(0).to_int() == 47 { return "file://".concat(p); }
    return "file:///".concat(p);
}

fn handle_document_symbol(req: *JsonValue, state: *LspState) {
    let id: *JsonValue = json_get(req, "id");
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    if !state.docs.contains(uri) { lsp_send_response(id, json_array()); return; }
    let doc: LspDoc = state.docs.get(uri);
    let path: string = uri_to_path(uri);
    let arr: *JsonValue = json_array();
    // Walk the pre-expansion snapshot so route attrs survive — also
    // keeps the outline showing the user's source-level fns instead of
    // the synth `_user_*` / `_route_register_*` companions the macro
    // injects.
    let src_stmts: *Vector<Stmt> = doc.pre_expand_stmts;
    if src_stmts == null { src_stmts = doc.stmts; }
    if src_stmts != null {
        for let i: i32 = 0; i < src_stmts.len(); i++ {
            let s: Stmt = src_stmts.get(i);
            if s.kind != ST_FN && s.kind != ST_STRUCT && s.kind != ST_ENUM && s.kind != ST_CONST {
                continue;
            }
            // Skip stmts from other files (stdlib + imports).
            if !s.origin.eq("") && !s.origin.eq(path) { continue; }
            let sym: *JsonValue = json_object();
            let route_tag: string = route_tag_for(&s);
            let mut display: string = s.name;
            if !route_tag.eq("") {
                display = route_tag.concat(" ").concat(s.name);
            }
            json_obj_set(sym, "name", json_string(display));
            let mut detail: string = "";
            if s.kind == ST_FN { detail = fn_signature(&s); }
            json_obj_set(sym, "detail", json_string(detail));
            json_obj_set(sym, "kind", json_int(symbol_kind_for(&s)));
            json_obj_set(sym, "range", range_for_decl_name(&s));
            json_obj_set(sym, "selectionRange", range_for_decl_name(&s));
            json_arr_push(arr, sym);
        }
    }
    lsp_send_response(id, arr);
}

// "[GET /health]" tag for a stmt carrying @get/@post/etc, "" otherwise.
// Mirrors the @route attribute decode in src/stdlib/http/route.glide so
// the LSP outline shows the same routing surface the macro will register.
fn route_tag_for(s: *Stmt) -> string {
    if s == null || s.kind != ST_FN || s.attrs == null { return ""; }
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !_is_lsp_route_attr(a.name) { continue; }
        let mut method: string = "";
        let mut path: string = "";
        if a.name.eq("route") {
            if a.args == null || a.args.len() < 2 { continue; }
            let m_arg: Expr = a.args.get(0);
            let p_arg: Expr = a.args.get(1);
            if m_arg.kind == EX_IDENT { method = m_arg.str_val; }
            if p_arg.kind == EX_STRING { path = p_arg.str_val; }
        } else {
            method = a.name;
            if a.args == null || a.args.len() < 1 { continue; }
            let p_arg: Expr = a.args.get(0);
            if p_arg.kind == EX_STRING { path = p_arg.str_val; }
        }
        if method.eq("") || path.eq("") { continue; }
        return "[".concat(method.to_upper()).concat(" ").concat(path).concat("]");
    }
    return "";
}

fn _is_lsp_route_attr(n: string) -> bool {
    if n.eq("route") { return true; }
    if n.eq("get") { return true; }
    if n.eq("post") { return true; }
    if n.eq("put") { return true; }
    if n.eq("delete") { return true; }
    if n.eq("patch") { return true; }
    if n.eq("head") { return true; }
    if n.eq("options") { return true; }
    if n.eq("any") { return true; }
    return false;
}

// Custom LSP method `glide/routeList`. Walks every open document for
// fns carrying a @route/@get/@post/etc attribute and returns:
//
//   [{ "method": "GET", "path": "/users/:id", "handler": "show",
//      "uri": "file:///...users.glide", "line": 12, "column": 3 }, ...]
//
// Foundation for editor route sidebars (Zed extension, VS Code panel,
// etc). Clients can render the list, group by method or file, and
// jump to each handler via the line/column.
fn handle_route_list(req: *JsonValue, state: *LspState) {
    let id: *JsonValue = json_get(req, "id");
    let arr: *JsonValue = json_array();
    let uris: *Vector<string> = state.docs.keys();
    for let i: i32 = 0; i < uris.len(); i++ {
        let uri: string = uris.get(i);
        let doc: LspDoc = state.docs.get(uri);
        let path: string = uri_to_path(uri);
        let src_stmts: *Vector<Stmt> = doc.pre_expand_stmts;
        if src_stmts == null { src_stmts = doc.stmts; }
        if src_stmts == null { continue; }
        for let j: i32 = 0; j < src_stmts.len(); j++ {
            let s: Stmt = src_stmts.get(j);
            if s.kind != ST_FN || s.attrs == null { continue; }
            if !s.origin.eq("") && !s.origin.eq(path) { continue; }
            for let k: i32 = 0; k < s.attrs.len(); k++ {
                let a: Attr = s.attrs.get(k);
                if !_is_lsp_route_attr(a.name) { continue; }
                let mut method: string = "";
                let mut route_path: string = "";
                if a.name.eq("route") {
                    if a.args == null || a.args.len() < 2 { continue; }
                    let m_arg: Expr = a.args.get(0);
                    let p_arg: Expr = a.args.get(1);
                    if m_arg.kind == EX_IDENT { method = m_arg.str_val; }
                    if p_arg.kind == EX_STRING { route_path = p_arg.str_val; }
                } else {
                    method = a.name;
                    if a.args == null || a.args.len() < 1 { continue; }
                    let p_arg: Expr = a.args.get(0);
                    if p_arg.kind == EX_STRING { route_path = p_arg.str_val; }
                }
                if method.eq("") || route_path.eq("") { continue; }
                let entry: *JsonValue = json_object();
                json_obj_set(entry, "method", json_string(method.to_upper()));
                json_obj_set(entry, "path", json_string(route_path));
                json_obj_set(entry, "handler", json_string(s.name));
                json_obj_set(entry, "uri", json_string(uri));
                let mut nl: i32 = s.name_line;
                let mut nc: i32 = s.name_col;
                if nl == 0 { nl = s.line; nc = s.column; }
                if nl < 1 { nl = 1; }
                if nc < 1 { nc = 1; }
                json_obj_set(entry, "line", json_int(nl - 1));
                json_obj_set(entry, "column", json_int(nc - 1));
                json_arr_push(arr, entry);
                break;
            }
        }
    }
    let result: *JsonValue = json_object();
    json_obj_set(result, "routes", arr);
    lsp_send_response(id, result);
}

fn handle_definition(req: *JsonValue, state: *LspState) {
    let id: *JsonValue = json_get(req, "id");
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    let pos: *JsonValue = json_get(params, "position");
    let line0: i32 = json_as_int(json_get(pos, "line"));
    let col0: i32 = json_as_int(json_get(pos, "character"));

    if !state.docs.contains(uri) { lsp_send_response(id, json_null()); return; }
    let doc: LspDoc = state.docs.get(uri);
    let word: string = word_at(doc.text, line0, col0);
    if word.eq("") { lsp_send_response(id, json_null()); return; }

    let mut decl: *Stmt = null;

    // 0) Cursor on a segment of an `import a::b::c;` line — jump to the
    //    resolved .glide file. Walks doc.stmts for the ST_IMPORT whose
    //    line matches the cursor; its `import_path` already holds the
    //    fully-resolved on-disk path. We only jump when the path
    //    actually exists; otherwise we'd hand Zed a bogus URI (the
    //    resolver's "first attempt" fallback for unfound imports), it'd
    //    try to canonicalize it and log a worktree error.
    let imp: *Stmt = _find_import_on_line(doc.stmts, line0, uri);
    if imp != null && imp.import_path != null && !imp.import_path.eq("")
       && __glide_file_exists(imp.import_path) {
        let target: string = path_to_uri(imp.import_path);
        let loc: *JsonValue = json_object();
        json_obj_set(loc, "uri", json_string(target));
        let zero: *JsonValue = json_object();
        let zero_start: *JsonValue = json_object();
        json_obj_set(zero_start, "line", json_int(0));
        json_obj_set(zero_start, "character", json_int(0));
        let zero_end: *JsonValue = json_object();
        json_obj_set(zero_end, "line", json_int(0));
        json_obj_set(zero_end, "character", json_int(0));
        json_obj_set(zero, "start", zero_start);
        json_obj_set(zero, "end", zero_end);
        json_obj_set(loc, "range", zero);
        lsp_send_response(id, loc);
        return;
    }

    // 1) Cursor on `name` in `name!(...)` — jump to the macro def. Tries
    //    free / type-attached `macro` defs first, then function-like
    //    proc-macros (`@proc_macro(name)` fns, e.g. `info!`). Without the
    //    proc-macro fallback, `info!` would slip to the same-named `info`
    //    fn further down.
    if decl == null && _ident_followed_by_bang(doc.text, line0, col0, word.len()) {
        decl = find_macro_def(doc.stmts, word);
        if decl == null { decl = find_proc_macro_fn(doc.stmts, word); }
    }

    // 2) Cursor on `Name` inside `@derive(Name)` / `@Name(...)` / `@Name`
    //    — jump to the fn decorated with `@proc_<kind>(Name)`.
    if decl == null && (_inside_proc_attr_arg(doc.text, line0, col0)
                        || _on_bare_attribute_name(doc.text, line0, col0)) {
        decl = find_proc_macro_fn(doc.stmts, word);
    }

    // 3) `Vector::new` (or `Vector::with_cap`, etc) — impl method.
    if decl == null {
        let path_q: string = path_qualifier_before(doc.text, line0, col0);
        if !path_q.eq("") {
            decl = find_method_in_impl(doc.stmts, path_q, word);
        }
    }

    // 4) `var.method` and `var.field` — resolve the receiver's type, then
    //    look up the method first, falling back to a struct field decl.
    if decl == null {
        let mem_var: string = member_qualifier_before(doc.text, line0, col0);
        if !mem_var.eq("") {
            let var_type: string = lookup_local_type(doc.stmts, line0, mem_var, uri_to_path(uri));
            if !var_type.eq("") {
                decl = find_method_in_impl(doc.stmts, var_type, word);
                if decl == null {
                    decl = find_struct_field(doc.stmts, var_type, word);
                }
            }
        }
    }

    // 5) Chained inline ctor: `Vector::new().push_all` — derive the
    //    receiver type from the `Type::ctor()` paren-balanced lookback
    //    used by completion.
    if decl == null {
        let chain_ty: string = chained_ctor_qualifier_before(doc.text, line0, col0);
        if !chain_ty.eq("") {
            decl = find_method_in_impl(doc.stmts, chain_ty, word);
            if decl == null {
                decl = find_struct_field(doc.stmts, chain_ty, word);
            }
        }
    }

    // 6) Local binding (let / param) above the cursor in the containing
    //    fn. Shadowing-aware via the inner-most match.
    if decl == null {
        let host: *Stmt = fn_containing(doc.stmts, line0, uri_to_path(uri));
        if host != null {
            decl = find_local_decl(host, word, line0);
        }
    }

    // 7) Last resort: any top-level decl with the right name (fn, struct,
    //    enum, const, trait, macro).
    if decl == null { decl = find_top_decl(doc.stmts, word); }
    if decl == null { lsp_send_response(id, json_null()); return; }

    // Build the URI from the decl's origin so jumps to stdlib (Vector,
    // HashMap, ...) actually open the right file. Verify the origin
    // exists on disk — origins of stmts pulled from a failed transitive
    // import (file not found) get set to the resolver's "first attempt"
    // path. Returning that to Zed makes it log a worktree canonicalize
    // error. Fall back to the current doc when the path doesn't resolve.
    let mut target_uri: string = uri;
    if decl.origin != null && !decl.origin.eq("") && __glide_file_exists(decl.origin) {
        target_uri = path_to_uri(decl.origin);
    } else if decl.origin != null && !decl.origin.eq("") {
        lsp_send_response(id, json_null());
        return;
    }
    let loc: *JsonValue = json_object();
    json_obj_set(loc, "uri", json_string(target_uri));
    json_obj_set(loc, "range", range_for_decl_name(decl));
    lsp_send_response(id, loc);
}

// True when the character immediately after `<word>` at (line0, col0)
// is `!`, marking a macro call site.
fn _ident_followed_by_bang(text: string, line0: i32, col0: i32, _word_len: i32) -> bool {
    let off: i32 = _line_col_offset(text, line0, col0);
    if off < 0 { return false; }
    // Walk forward past any remaining ident chars in case col0 sits
    // mid-word, then check the next byte.
    let n: i32 = text.len();
    let mut i: i32 = off;
    while i < n {
        let c: i32 = text.at(i).to_int();
        let is_id: bool = (c >= 97 && c <= 122) || (c >= 65 && c <= 90)
                       || (c >= 48 && c <= 57) || c == 95;
        if !is_id { break; }
        i = i + 1;
    }
    return i < n && text.at(i).to_int() == 33;
}

// True when (line0, col0) sits on an ident that's the first arg of a
// proc-macro attribute call: `@<attr>(<ident>, …)`. Walks back from the
// word start past whitespace + `(` + `<ident>` looking for an `@`.
fn _inside_proc_attr_arg(text: string, line0: i32, col0: i32) -> bool {
    let off: i32 = _line_col_offset(text, line0, col0);
    if off < 0 { return false; }
    // Skip back over the current word.
    let mut i: i32 = off;
    while i > 0 {
        let c: i32 = text.at(i - 1).to_int();
        let is_id: bool = (c >= 97 && c <= 122) || (c >= 65 && c <= 90)
                       || (c >= 48 && c <= 57) || c == 95;
        if !is_id { break; }
        i = i - 1;
    }
    // Optional whitespace + `(`.
    while i > 0 && text.at(i - 1).to_int() == 32 { i = i - 1; }
    if i == 0 || text.at(i - 1).to_int() != 40 { return false; }
    i = i - 1;
    // Walk back over the attribute name.
    while i > 0 {
        let c: i32 = text.at(i - 1).to_int();
        let is_id: bool = (c >= 97 && c <= 122) || (c >= 65 && c <= 90)
                       || (c >= 48 && c <= 57) || c == 95;
        if !is_id { break; }
        i = i - 1;
    }
    return i > 0 && text.at(i - 1).to_int() == 64;
}

// One-line descriptions for compiler-recognised attribute names. Returns
// "" for anything that isn't a builtin so the caller can fall back to
// the proc-macro registry / top-level decl lookup.
fn _builtin_attr_doc(name: string) -> string {
    if name == null { return ""; }
    if name.eq("cfg") {
        return "Per-platform guard: `@cfg(\"windows\")` wraps the decl in `#ifdef _WIN32`, `@cfg(\"posix\")` in `#ifndef _WIN32`. Applied to fn / struct / impl / const.";
    }
    if name.eq("derive") {
        return "Apply one or more proc-derive macros to the next struct: `@derive(JsonBind, Debug)`. Each arg names a fn registered via `@proc_derive(Name)`.";
    }
    if name.eq("expect") {
        return "Test-only: assert that the next decl raises a diagnostic with the given code. `@expect(\"unused-var\")`. The diag is swallowed when the expectation matches.";
    }
    if name.eq("allow") {
        return "Silence a specific lint on the next decl. `@allow(\"unused-var\")` / `@allow(\"deprecated-fn\")`.";
    }
    if name.eq("deprecated") {
        return "Mark a decl as deprecated. Optional reason: `@deprecated(\"use Foo::new instead\")`. Calls surface a `deprecated-fn` warning.";
    }
    if name.eq("lint") {
        return "Per-decl lint promotion: `@lint(\"unused-var\", \"error\")` makes the named lint hard-fail on this decl only.";
    }
    if name.eq("proc_attr") {
        return "Register the annotated fn as the implementation of an attribute proc-macro. `@proc_attr(handler)` lets user code write `@handler` on fns / structs.";
    }
    if name.eq("proc_derive") {
        return "Register the annotated fn as a derive proc-macro. `@proc_derive(JsonBind)` lets user code write `@derive(JsonBind)` on structs.";
    }
    if name.eq("proc_macro") {
        return "Register the annotated fn as a function-style proc-macro that takes a typed AST and returns a Vector<Stmt>. `@proc_macro(name)` lets user code write `name!(...)`.";
    }
    if name.eq("proc_macro_str") {
        return "Register the annotated fn as a function-style proc-macro that takes its body as a raw string. `@proc_macro_str(name)` for templating / lit-style use.";
    }
    return "";
}

// True when the cursor sits on the identifier of a bare attribute like
// `@handler` (no args / no parens). Used by hover + goto so clicking on
// the attribute name itself resolves to the registered proc-fn.
fn _on_bare_attribute_name(text: string, line0: i32, col0: i32) -> bool {
    let off: i32 = _line_col_offset(text, line0, col0);
    if off < 0 { return false; }
    let mut i: i32 = off;
    while i > 0 {
        let c: i32 = text.at(i - 1).to_int();
        let is_id: bool = (c >= 97 && c <= 122) || (c >= 65 && c <= 90)
                       || (c >= 48 && c <= 57) || c == 95;
        if !is_id { break; }
        i = i - 1;
    }
    return i > 0 && text.at(i - 1).to_int() == 64;
}

// Pick the ST_IMPORT stmt whose source line matches the cursor line
// (1-indexed in Stmt.line, 0-indexed in LSP), constrained to the
// document the user is editing so a stdlib file's imports don't
// match. Returns null when the cursor isn't on an import line.
fn _find_import_on_line(stmts: *Vector<Stmt>, line0: i32, doc_uri: string) -> *Stmt {
    if stmts == null { return null; }
    let want_path: string = uri_to_path(doc_uri);
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_IMPORT { continue; }
        if !s.origin.eq(want_path) { continue; }
        if (s.line - 1) == line0 {
            let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            *p = s;
            return p;
        }
    }
    return null;
}

// Convert an LSP (line, character) to a flat byte offset into `text`.
// Returns -1 when the position is outside the document.
fn _line_col_offset(text: string, line0: i32, col0: i32) -> i32 {
    let n: i32 = text.len();
    let mut line: i32 = 0;
    let mut col: i32 = 0;
    for let i: i32 = 0; i < n; i++ {
        if line == line0 && col == col0 { return i; }
        let c: i32 = text.at(i).to_int();
        if c == 10 {
            if line == line0 { return i; }
            line = line + 1;
            col = 0;
        } else {
            col = col + 1;
        }
    }
    if line == line0 && col == col0 { return n; }
    return -1;
}

// LSP CompletionItemKind:
//   3 = Function, 6 = Variable, 5 = Field, 8 = Class (struct), 13 = Enum,
//   14 = Keyword, 21 = Constant, 25 = TypeParameter
fn ci_kind_for(s: *Stmt) -> i32 {
    if s.kind == ST_FN { return 3; }
    if s.kind == ST_STRUCT { return 8; }
    if s.kind == ST_ENUM { return 13; }
    if s.kind == ST_CONST { return 21; }
    if s.kind == ST_MACRO_DEF { return 2; }   // 2 = Method (closest LSP kind for macros)
    return 6;
}

// Walk the doc, find the fn that contains the cursor (line0 0-indexed).
// Used for scope-local completion.
// `path` filters by `s.origin` so fns from imported files don't shadow the
// user's own fn — without it a fn at line N in any stdlib/builtin file
// would beat a user fn at an earlier line, breaking hover / completion /
// goto on locals.
fn fn_containing(stmts: *Vector<Stmt>, line0: i32, path: string) -> *Stmt {
    if stmts == null { return null; }
    let mut best: *Stmt = null;
    let mut best_line: i32 = -1;
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_FN || s.fn_body == null { continue; }
        if !path.eq("") && s.origin != null && !s.origin.eq(path) { continue; }
        let start: i32 = s.line - 1;
        if start <= line0 && start > best_line {
            best_line = start;
            let p: *Stmt = malloc(sizeof(Stmt)) as *Stmt;
            *p = s;
            best = p;
        }
    }
    return best;
}

// Recursively collect names declared in body up to `before_line` (0-indexed).
// Descends through nested blocks, match arms and closures embedded in
// expressions so identifiers bound inside `r.get("/", fn(req) { let x = ... })`
// still show up in the completion list when the cursor sits in the closure body.
fn collect_locals(body: *Vector<Stmt>, before_line: i32, out: *Vector<Stmt>) {
    if body == null { return; }
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && (s.line - 1) < before_line {
            out.push(s);
        }
        if s.kind == ST_FOR && s.for_init != null {
            collect_locals_stmt(s.for_init, before_line, out);
        }
        if s.then_body != null { collect_locals(s.then_body, before_line, out); }
        if s.else_body != null { collect_locals(s.else_body, before_line, out); }
        if s.kind == ST_MATCH && s.arms != null {
            for let j: i32 = 0; j < s.arms.len(); j++ {
                let arm: MatchArm = s.arms.get(j);
                collect_locals(arm.body, before_line, out);
            }
        }
        _collect_locals_in_expr(s.let_value, before_line, out);
        _collect_locals_in_expr(s.expr_value, before_line, out);
        _collect_locals_in_expr(s.cond, before_line, out);
        _collect_locals_in_expr(s.for_step, before_line, out);
    }
}

fn collect_locals_stmt(s: *Stmt, before_line: i32, out: *Vector<Stmt>) {
    if s == null { return; }
    if s.kind == ST_LET && (s.line - 1) < before_line { out.push(*s); }
}

fn _collect_locals_in_expr(e: *Expr, before_line: i32, out: *Vector<Stmt>) {
    if e == null { return; }
    if e.kind == EX_FNEXPR && e.fn_expr_body != null && e.line - 1 <= before_line {
        collect_locals(e.fn_expr_body, before_line, out);
    }
    _collect_locals_in_expr(e.lhs, before_line, out);
    _collect_locals_in_expr(e.rhs, before_line, out);
    _collect_locals_in_expr(e.operand, before_line, out);
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _collect_locals_in_expr(&a, before_line, out);
        }
    }
}

// Collect every closure param whose enclosing closure body covers the
// cursor line. Recursive so nested closures stack: `fn(a) { fn(b) { <c> } }`
// surfaces both `a` and `b` at cursor `<c>`. Used by the completion handler
// to advertise closure params alongside the host fn's regular params.
fn collect_active_closure_params(body: *Vector<Stmt>, line0: i32, out: *Vector<Param>) {
    if body == null { return; }
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.then_body != null { collect_active_closure_params(s.then_body, line0, out); }
        if s.else_body != null { collect_active_closure_params(s.else_body, line0, out); }
        if s.kind == ST_MATCH && s.arms != null {
            for let j: i32 = 0; j < s.arms.len(); j++ {
                let arm: MatchArm = s.arms.get(j);
                collect_active_closure_params(arm.body, line0, out);
            }
        }
        _collect_closure_params_in_expr(s.let_value, line0, out);
        _collect_closure_params_in_expr(s.expr_value, line0, out);
        _collect_closure_params_in_expr(s.cond, line0, out);
        _collect_closure_params_in_expr(s.for_step, line0, out);
    }
}

fn _collect_closure_params_in_expr(e: *Expr, line0: i32, out: *Vector<Param>) {
    if e == null { return; }
    if e.kind == EX_FNEXPR && e.fn_expr_body != null && e.line - 1 <= line0 {
        if e.fn_expr_params != null {
            for let i: i32 = 0; i < e.fn_expr_params.len(); i++ {
                let p: Param = e.fn_expr_params.get(i);
                out.push(p);
            }
        }
        collect_active_closure_params(e.fn_expr_body, line0, out);
    }
    _collect_closure_params_in_expr(e.lhs, line0, out);
    _collect_closure_params_in_expr(e.rhs, line0, out);
    _collect_closure_params_in_expr(e.operand, line0, out);
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _collect_closure_params_in_expr(&a, line0, out);
        }
    }
}

fn completion_item(label: string, kind: i32, detail: string) -> *JsonValue {
    let it: *JsonValue = json_object();
    json_obj_set(it, "label", json_string(label));
    json_obj_set(it, "kind", json_int(kind));
    if !detail.eq("") { json_obj_set(it, "detail", json_string(detail)); }
    return it;
}

// Import statement form, mirrored from the parser so the LSP can decide
// whether an auto-import edit would be redundant (wildcard / bare /
// already-listed in a selective import).
pub const IMP_BARE: i32 = 0;       // `import stdlib::hashmap;`
pub const IMP_WILDCARD: i32 = 1;   // `import stdlib::hashmap::*;`
pub const IMP_SELECTIVE: i32 = 2;  // `import stdlib::hashmap::{X, Y};`

pub struct ImportInfo {
    pub module: string,         // canonical "stdlib::hashmap"
    pub line: i32,              // 0-indexed line of the import statement
    pub kind: i32,              // IMP_BARE / IMP_WILDCARD / IMP_SELECTIVE
    pub items: *HashMap<bool>,  // names listed in `{...}` (selective only)
    pub close_pos: i32,         // 0-indexed col of `}` (selective only, else -1)
}

// Walk the doc text once and parse every `import …;` line into an
// ImportInfo. Driven off the source text rather than the AST so we can
// emit precise text edits (insert before `}`) when adding to a
// selective import that already exists.
fn analyze_imports(text: string) -> *Vector<ImportInfo> {
    let out: *Vector<ImportInfo> = Vector::new();
    if text == null { return out; }
    let n: i32 = text.len();
    let mut line: i32 = 0;
    let mut line_start: i32 = 0;
    let mut i: i32 = 0;
    while i <= n {
        let at_eol: bool = (i == n) || (text.at(i).to_int() == 10);
        if at_eol {
            let raw: string = text.substring(line_start, i);
            let trimmed: string = raw.trim();
            if trimmed.len() > 7 && trimmed.substring(0, 7).eq("import ") {
                let info: ImportInfo = parse_import_line(raw, line);
                if !info.module.eq("") { out.push(info); }
            }
            line = line + 1;
            line_start = i + 1;
        }
        i = i + 1;
    }
    return out;
}

// Find first occurrence of byte `c` in `s` starting from `from`. Returns
// -1 when missing.
fn find_byte(s: string, c: i32, from: i32) -> i32 {
    let n: i32 = s.len();
    let mut i: i32 = from;
    while i < n {
        if s.at(i).to_int() == c { return i; }
        i = i + 1;
    }
    return -1;
}

fn parse_import_line(raw: string, line: i32) -> ImportInfo {
    let none_items: *HashMap<bool> = HashMap::new();
    let miss: ImportInfo = ImportInfo {
        module: "", line: line, kind: IMP_BARE,
        items: none_items, close_pos: -1,
    };
    let trimmed: string = raw.trim();
    if trimmed.len() < 8 { return miss; }
    let mut body: string = trimmed.substring(7, trimmed.len()).trim();
    let bn0: i32 = body.len();
    if bn0 > 0 && body.at(bn0 - 1).to_int() == 59 {
        body = body.substring(0, bn0 - 1).trim();
    }
    if body.eq("") { return miss; }

    // Selective: `module::{X, Y, …}`
    let brace_open_in_body: i32 = find_substr(body, "::{");
    if brace_open_in_body >= 0 {
        let module: string = body.substring(0, brace_open_in_body);
        let inner_start: i32 = brace_open_in_body + 3;
        let brace_close: i32 = find_byte(body, 125, inner_start);
        let items: *HashMap<bool> = HashMap::new();
        if brace_close > 0 {
            let inner: string = body.substring(inner_start, brace_close);
            let parts: *Vector<string> = inner.split(",");
            for let i: i32 = 0; i < parts.len(); i++ {
                let nm: string = parts.get(i).trim();
                if !nm.eq("") { items.insert(nm, true); }
            }
        }
        // Find `}` column in the original (un-trimmed) raw line so the
        // text edit can splice `, NewName` directly before it.
        let close_in_raw: i32 = find_byte(raw, 125, 0);
        return ImportInfo {
            module: module, line: line, kind: IMP_SELECTIVE,
            items: items, close_pos: close_in_raw,
        };
    }

    // Wildcard: `module::*`
    let bn: i32 = body.len();
    if bn >= 3 && body.substring(bn - 3, bn).eq("::*") {
        return ImportInfo {
            module: body.substring(0, bn - 3),
            line: line, kind: IMP_WILDCARD,
            items: none_items, close_pos: -1,
        };
    }

    // Bare module: `module` (single or multi-segment, no items).
    return ImportInfo {
        module: body, line: line, kind: IMP_BARE,
        items: none_items, close_pos: -1,
    };
}

// Build a `*HashMap<ImportInfo>` keyed by canonical module path so the
// completion code can look up "is stdlib::hashmap already imported?" in
// O(1). Stores both the original and the pretty form for compatibility.
fn current_imports(text: string) -> *HashMap<ImportInfo> {
    let h: *HashMap<ImportInfo> = HashMap::new();
    let infos: *Vector<ImportInfo> = analyze_imports(text);
    for let i: i32 = 0; i < infos.len(); i++ {
        let info: ImportInfo = infos.get(i);
        h.insert(info.module, info);
    }
    return h;
}

// Build an `additionalTextEdits` JSON entry for the auto-import action,
// or return null when no edit is needed.
//
// Strategy:
//   * existing wildcard / bare / matching selective entry → no edit
//   * existing selective without the name → splice `, name` before `}`
//   * no existing import → insert `import module::{name};\n` at the
//     fallback line. For Module items (is_module = true), insert the
//     bare form `import module;` instead so `module::Foo` paths work.
fn build_import_edit(name: string, module: string,
                     existing: *ImportInfo, fallback_line: i32,
                     is_module: bool) -> *JsonValue {
    if existing != null {
        if existing.kind == IMP_WILDCARD { return null; }
        if existing.kind == IMP_BARE { return null; }
        if existing.kind == IMP_SELECTIVE {
            if existing.items.contains(name) { return null; }
            let edit: *JsonValue = json_object();
            let range: *JsonValue = json_object();
            let start: *JsonValue = json_object();
            let endp: *JsonValue = json_object();
            json_obj_set(start, "line", json_int(existing.line));
            json_obj_set(start, "character", json_int(existing.close_pos));
            json_obj_set(endp,  "line", json_int(existing.line));
            json_obj_set(endp,  "character", json_int(existing.close_pos));
            json_obj_set(range, "start", start);
            json_obj_set(range, "end", endp);
            json_obj_set(edit, "range", range);
            json_obj_set(edit, "newText", json_string(", ".concat(name)));
            return edit;
        }
    }
    // No existing import — fresh insertion.
    let edit: *JsonValue = json_object();
    let range: *JsonValue = json_object();
    let start: *JsonValue = json_object();
    let endp: *JsonValue = json_object();
    json_obj_set(start, "line", json_int(fallback_line));
    json_obj_set(start, "character", json_int(0));
    json_obj_set(endp,  "line", json_int(fallback_line));
    json_obj_set(endp,  "character", json_int(0));
    json_obj_set(range, "start", start);
    json_obj_set(range, "end", endp);
    json_obj_set(edit, "range", range);
    let mut new_text: string = "";
    if is_module {
        new_text = "import ".concat(module).concat(";\n");
    } else {
        new_text = "import ".concat(module).concat("::{").concat(name).concat("};\n");
    }
    json_obj_set(edit, "newText", json_string(new_text));
    return edit;
}

fn lsp_strip_quotes(s: string) -> string {
    let n: i32 = s.len();
    if n >= 2 && s.at(0).to_int() == 34 && s.at(n - 1).to_int() == 34 {
        return s.substring(1, n - 1);
    }
    return s;
}

// Import-context detector results. The cursor either sits in the
// path part of an `import …;` line, in the `{X, Y}` selective list
// of one, or somewhere unrelated.
pub const IMPCTX_NONE: i32 = 0;
pub const IMPCTX_PATH: i32 = 1;
pub const IMPCTX_BRACE: i32 = 2;

// Pull the substring of `text` from the start of `line0` up to `col0`.
fn line_prefix_to_cursor(text: string, line0: i32, col0: i32) -> string {
    let n: i32 = text.len();
    let mut line: i32 = 0;
    let mut start: i32 = 0;
    let mut i: i32 = 0;
    while i < n && line < line0 {
        if text.at(i).to_int() == 10 { line = line + 1; start = i + 1; }
        i = i + 1;
    }
    let mut end: i32 = start + col0;
    if end > n { end = n; }
    return text.substring(start, end);
}

// Classify the cursor position with respect to the surrounding `import`
// statement. Returns IMPCTX_NONE when not in an import.
fn import_context_kind(text: string, line0: i32, col0: i32) -> i32 {
    let prefix: string = line_prefix_to_cursor(text, line0, col0);
    let trimmed: string = prefix.trim();
    let tlen: i32 = trimmed.len();
    if tlen < 7 { return IMPCTX_NONE; }
    if !trimmed.substring(0, 7).eq("import ") { return IMPCTX_NONE; }
    // Ignore lines that already terminated.
    if find_byte(prefix, 59, 0) >= 0 { return IMPCTX_NONE; }
    // Inside `{...}` if there's an unclosed `{` after `import `.
    let brace_pos: i32 = find_byte(trimmed, 123, 7);
    if brace_pos >= 0 {
        let close_after: i32 = find_byte(trimmed, 125, brace_pos);
        if close_after < 0 { return IMPCTX_BRACE; }
    }
    return IMPCTX_PATH;
}

// Path the user has typed after `import ` up to the cursor, with any
// trailing partial identifier dropped. So `import stdlib::ha|shmap`
// returns "stdlib::"; `import stdlib::|` returns "stdlib::"; `import |`
// returns "".
fn import_path_prefix(text: string, line0: i32, col0: i32) -> string {
    let prefix: string = line_prefix_to_cursor(text, line0, col0);
    let trimmed: string = prefix.trim();
    if trimmed.len() < 7 { return ""; }
    let body: string = trimmed.substring(7, trimmed.len());
    // Drop any trailing partial identifier.
    let n: i32 = body.len();
    let mut end: i32 = n;
    while end > 0 {
        let c: i32 = body.at(end - 1).to_int();
        if (c >= 65 && c <= 90) || (c >= 97 && c <= 122)
           || (c >= 48 && c <= 57) || c == 95 {
            end = end - 1;
        } else { break; }
    }
    return body.substring(0, end);
}

// Module path being filled inside `{ ... }` of a selective import.
// `import stdlib::hashmap::{Has|}` → "stdlib::hashmap".
fn import_brace_module(text: string, line0: i32, col0: i32) -> string {
    let prefix: string = line_prefix_to_cursor(text, line0, col0);
    let trimmed: string = prefix.trim();
    if trimmed.len() < 7 { return ""; }
    let body: string = trimmed.substring(7, trimmed.len());
    let bopen: i32 = find_byte(body, 123, 0);
    if bopen <= 1 { return ""; }
    // Body before `::{`
    if bopen >= 2 && body.at(bopen - 1).to_int() == 58
                  && body.at(bopen - 2).to_int() == 58 {
        return body.substring(0, bopen - 2);
    }
    return "";
}

// Push completion items for the children of an import path prefix.
//   ""               → top-level namespaces (stdlib)
//   "stdlib::"       → 9 stdlib submodules
//   "stdlib::math::" → uncommon, falls through (modules don't nest yet)
fn list_import_path_children(state: *LspState, prefix: string,
                             items: *JsonValue, seen: *HashMap<bool>) {
    if prefix.eq("") {
        // Top-level namespaces. `stdlib` always, plus project deps
        // registered through the manifest at didOpen time.
        if !seen.contains("stdlib") {
            seen.insert("stdlib", true);
            let no_edit_n: *JsonValue = null;
            json_arr_push(items, rich_completion_item(
                "stdlib", "", 9, "namespace stdlib",
                "Glide standard library root.", "", "stdlib::", false,
                no_edit_n));
        }
        if state.project_index != null {
            _list_project_top_namespaces(state, items, seen);
        }
        return;
    }
    if state.stdlib_index != null {
        _list_index_children(state.stdlib_index, prefix, items, seen);
    }
    if state.project_index != null {
        _list_index_children(state.project_index, prefix, items, seen);
    }
}

// Walk an index, filter modules whose `module` field starts with
// `prefix`, and emit the next segment. So `prefix = "stdlib::"`
// yields each top-level stdlib module; `prefix = "stdlib::http::"`
// yields `client`, `cookies`, `form`, etc.
fn _list_index_children(idx: *Vector<ImportableSym>, prefix: string,
                        items: *JsonValue, seen: *HashMap<bool>) {
    let n: i32 = idx.len();
    for let i: i32 = 0; i < n; i++ {
        let sym: ImportableSym = idx.get(i);
        if sym.kind != SYMKIND_MODULE { continue; }
        if !sym.module.starts_with(prefix) { continue; }
        // The remainder after `prefix` should be exactly one segment
        // (no further `::`). That gives the IMMEDIATE child only —
        // otherwise `stdlib::` would list `stdlib::http::client` too.
        let rest: string = sym.module.substring(prefix.len(), sym.module.len());
        if rest.eq("") { continue; }
        if rest.contains("::") { continue; }
        if seen.contains(rest) { continue; }
        seen.insert(rest, true);
        let no_edit: *JsonValue = null;
        json_arr_push(items, rich_completion_item(
            rest, "", 9, sym.signature, sym.doc, "", rest, false, no_edit));
    }
}

// Project-side namespaces (dep aliases from `glide.glide` + the
// project's own top-level modules). Each becomes a first-segment
// suggestion at `import `.
fn _list_project_top_namespaces(state: *LspState, items: *JsonValue, seen: *HashMap<bool>) {
    let idx: *Vector<ImportableSym> = state.project_index;
    let n: i32 = idx.len();
    for let i: i32 = 0; i < n; i++ {
        let sym: ImportableSym = idx.get(i);
        if sym.kind != SYMKIND_MODULE { continue; }
        // Top-level alias is whatever comes before the first `::`.
        let mod: string = sym.module;
        let mut first: string = mod;
        let p: i32 = mod.index_of("::");
        if p > 0 { first = mod.substring(0, p); }
        if seen.contains(first) { continue; }
        seen.insert(first, true);
        let no_edit: *JsonValue = null;
        json_arr_push(items, rich_completion_item(
            first, "", 9, "namespace ".concat(first),
            "Project / dep namespace.", "", first.concat("::"), false, no_edit));
    }
}

// Find the line + col where a new `import` statement should be inserted.
// Strategy: place it after the last existing `import` line at the top of
// the file, or at the very start if the file has none. Returns 0-indexed
// line + character (LSP coordinates).
fn find_import_insertion_pos(text: string) -> i32 {
    let n: i32 = text.len();
    let mut line: i32 = 0;
    let mut last_import_line: i32 = -1;
    let mut line_start: i32 = 0;
    let mut i: i32 = 0;
    while i <= n {
        let at_eol: bool = (i == n) || (text.at(i).to_int() == 10);
        if at_eol {
            let cur: string = text.substring(line_start, i);
            let trimmed: string = cur.trim();
            if trimmed.len() >= 7 && trimmed.substring(0, 7).eq("import ") {
                last_import_line = line;
            }
            line = line + 1;
            line_start = i + 1;
        }
        i = i + 1;
    }
    if last_import_line < 0 { return 0; }
    return last_import_line + 1;
}

// Build a rich completion item, gopls-style. Includes:
//   - labelDetails { detail, description }   compact signature + module
//   - detail                                  full signature line
//   - documentation (markdown)                signature fence + doc-comment
//   - insertText + insertTextFormat=2          snippet with tab stops (fns)
//   - additionalTextEdits                     auto-import edit (caller-built)
//
// The caller is responsible for constructing the import edit (or passing
// null when none is needed); see build_import_edit() upstream.
fn rich_completion_item(label: string, label_extra: string, kind: i32,
                        signature: string, doc: string, module: string,
                        snippet: string, has_snippet: bool,
                        import_edit: *JsonValue) -> *JsonValue {
    let it: *JsonValue = json_object();
    json_obj_set(it, "label", json_string(label));
    json_obj_set(it, "kind", json_int(kind));

    // labelDetails: shows `(a: int, b: int) -> int   stdlib::math` next to
    // the label, gopls-compatible with LSP 3.17 clients.
    if !label_extra.eq("") || !module.eq("") {
        let ld: *JsonValue = json_object();
        if !label_extra.eq("") { json_obj_set(ld, "detail", json_string(label_extra)); }
        if !module.eq("") { json_obj_set(ld, "description", json_string(module)); }
        json_obj_set(it, "labelDetails", ld);
    }

    // detail: `[<module>]  <signature>`. Module *leads* the line so
    // long signatures truncate on the right without hiding the source
    // package — Zed and similar editors can't paint slices of a
    // string in different colors, so we wrap the module in brackets
    // as the universal "this is a metadata tag" cue. LSP 3.17 clients
    // ALSO get the module via labelDetails.description above for the
    // rust-analyzer / gopls right-aligned layout.
    let mut det: string = "";
    if !module.eq("") { det = "[".concat(module).concat("]"); }
    if !signature.eq("") {
        if det.eq("") { det = signature; }
        else { det = det.concat("  ").concat(signature); }
    }
    if !det.eq("") { json_obj_set(it, "detail", json_string(det)); }

    // filterText: makes the item discoverable from a wider range of
    // queries. Several editors (Zed, VS Code at lower setting) use a
    // prefix or fuzzy match against filterText, so we order it
    // lower-first to give `hashmap` the best chance of matching
    // `HashMap`. The user can also find the symbol via the original
    // label or the module path:
    //   `hashmap`, `hash`, `HashMap`, `stdlib::hashmap`
    // gopls and rust-analyzer use the same trick.
    let lower: string = ascii_to_lower(label);
    let mut filter: string = lower;
    if !lower.eq(label) { filter = filter.concat(" ").concat(label); }
    if !module.eq("") {
        filter = filter.concat(" ").concat(module);
        let mlower: string = ascii_to_lower(module);
        if !mlower.eq(module) { filter = filter.concat(" ").concat(mlower); }
    }
    json_obj_set(it, "filterText", json_string(filter));

    // documentation: markdown — fenced signature + horizontal rule + doc.
    let mut md: string = "";
    if !signature.eq("") {
        md = "```glide\n".concat(signature).concat("\n```");
    }
    if !doc.eq("") {
        if !md.eq("") { md = md.concat("\n\n---\n\n"); }
        md = md.concat(doc);
    }
    if !module.eq("") {
        if !md.eq("") { md = md.concat("\n\n"); }
        md = md.concat("From ").concat("`").concat(module).concat("`");
    }
    if !md.eq("") {
        let docobj: *JsonValue = json_object();
        json_obj_set(docobj, "kind", json_string("markdown"));
        json_obj_set(docobj, "value", json_string(md));
        json_obj_set(it, "documentation", docobj);
    }

    // Snippet body: only when the symbol is a callable and the editor
    // supports snippets. Falls back to plain insert.
    if has_snippet && !snippet.eq("") {
        json_obj_set(it, "insertText", json_string(snippet));
        json_obj_set(it, "insertTextFormat", json_int(2));   // 2 = Snippet
    } else {
        json_obj_set(it, "insertText", json_string(label));
        json_obj_set(it, "insertTextFormat", json_int(1));   // 1 = PlainText
    }

    // Auto-import edit (caller-supplied; null = no edit).
    if import_edit != null {
        let edits: *JsonValue = json_array();
        json_arr_push(edits, import_edit);
        json_obj_set(it, "additionalTextEdits", edits);
    }

    return it;
}

// ASCII-lowercase a string. Bytes 0x41..0x5A get +0x20; everything else
// passes through.
fn ascii_to_lower(s: string) -> string {
    let n: i32 = s.len();
    let mut out: string = "";
    for let i: i32 = 0; i < n; i++ {
        let c: i32 = s.at(i).to_int();
        if c >= 65 && c <= 90 {
            out = out.concat(((c + 32) as char).to_string());
        } else {
            out = out.concat(s.substring(i, i + 1));
        }
    }
    return out;
}

// Map an origin path back to a short module label, gopls-style:
//   .../src/stdlib/math.glide   -> "stdlib::math"
//   .../src/builtins/vector.glide -> "builtins::vector"
//   anything else (the user's own file) -> ""
// Convert an absolute source path into a Glide module path so the
// editor can show "stdlib::http" / "stdlib::http::router" /
// "builtins::vector" next to each completion item.
//
// Strategy:
//   1. Normalise separators so the rest of the logic works on either
//      `/` or `\` paths (Windows file:// URIs come with backslashes).
//   2. Split into segments.
//   3. Find the first "stdlib" or "builtins" segment from the right.
//      Everything after it (joined by `::`, with `.glide` stripped
//      from the last segment) is the module path.
//   4. Fall back to "" for paths that aren't under either tree —
//      the user's own files don't get a synthetic label (callers can
//      decide whether to label them by project name separately).
fn pretty_module(origin: string) -> string {
    if origin == null || origin.eq("") { return ""; }
    let parts: *Vector<string> = _split_path(origin);
    if parts.len() < 2 { return ""; }
    // Walk back to the last "stdlib" or "builtins" segment.
    let mut anchor: i32 = -1;
    let mut prefix: string = "";
    for let i: i32 = parts.len() - 1; i >= 0; i-- {
        let seg: string = parts.get(i);
        if seg.eq("stdlib") { anchor = i; prefix = "stdlib"; break; }
        if seg.eq("builtins") { anchor = i; prefix = "builtins"; break; }
    }
    if anchor < 0 { return ""; }
    let mut out: string = prefix;
    for let i: i32 = anchor + 1; i < parts.len(); i++ {
        let mut seg: string = parts.get(i);
        if i == parts.len() - 1 { seg = drop_glide_ext(seg); }
        // Collapse `builtins::builtins` / `stdlib::stdlib` to the
        // single root — the file at the root of the namespace
        // shouldn't read like it lives in its own sub-module.
        if i == parts.len() - 1 && seg.eq(prefix) { continue; }
        out = out.concat("::").concat(seg);
    }
    return out;
}

// Path split that accepts both `/` and `\`. Empty segments (leading
// slash, doubled separator) are dropped.
fn _split_path(p: string) -> *Vector<string> {
    let out: *Vector<string> = Vector::new();
    if p == null { return out; }
    let n: i32 = p.len();
    let mut start: i32 = 0;
    for let i: i32 = 0; i < n; i++ {
        let c: i32 = p.at(i).to_int();
        if c == 47 || c == 92 {
            if i > start { out.push(p.substring(start, i)); }
            start = i + 1;
        }
    }
    if start < n { out.push(p.substring(start, n)); }
    return out;
}

// Push completion items for every `pub` symbol whose module path matches
// `path`. Accepts both fully-qualified ("stdlib::math") and short
// ("math") forms. The single-segment "stdlib" path is special-cased to
// list the available submodules instead of symbols.
fn list_module_members(state: *LspState, path: string,
                       items: *JsonValue, seen: *HashMap<bool>) {
    if state.stdlib_index != null {
        _list_module_members_from(state.stdlib_index, path, items, seen);
    }
    if state.project_index != null {
        _list_module_members_from(state.project_index, path, items, seen);
    }
}

fn _list_module_members_from(idx: *Vector<ImportableSym>, path: string,
                             items: *JsonValue, seen: *HashMap<bool>) {
    let n: i32 = idx.len();

    // Pass 1: list immediate child modules. `path = "stdlib"` yields
    // every top-level stdlib module; `path = "stdlib::http"` yields
    // client/cookies/h2/etc. Same shape works for project namespaces.
    let prefix: string = path.concat("::");
    let mods: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < n; i++ {
        let sym: ImportableSym = idx.get(i);
        if sym.kind != SYMKIND_MODULE { continue; }
        if !sym.module.starts_with(prefix) { continue; }
        let rest: string = sym.module.substring(prefix.len(), sym.module.len());
        if rest.eq("") || rest.contains("::") { continue; }
        if mods.contains(rest) { continue; }
        mods.insert(rest, true);
        if seen.contains(rest) { continue; }
        seen.insert(rest, true);
        let no_edit: *JsonValue = null;
        json_arr_push(items, rich_completion_item(
            rest, "", 9, "module ".concat(rest),
            "submodule of `".concat(path).concat("`"), "", rest, false, no_edit));
    }
    mods.free();

    // Pass 2: members of the module whose path equals `path`. Accept
    // the short leaf too so the user can type either form. Also fold in
    // the function-like proc-macros from the module's `_macros` sibling
    // (e.g. `stdlib::log_macros` for `stdlib::log`) as `name!` — they're
    // re-exported by the base module and `log::info!(...)` is a valid
    // qualified macro call, so `log::inf` should offer `info!`.
    let pm_mod: string = path.concat("_macros");
    for let i: i32 = 0; i < n; i++ {
        let sym: ImportableSym = idx.get(i);
        if sym.kind == SYMKIND_MODULE { continue; }
        let m: string = sym.module;
        let cut: i32 = find_substr(m, "::");
        let mut leaf: string = m;
        if cut >= 0 { leaf = m.substring(cut + 2, m.len()); }
        let own: bool = m.eq(path) || leaf.eq(path);
        let pm_reexport: bool = sym.kind == SYMKIND_PROC_MACRO
                                && (m.eq(pm_mod) || leaf.eq(pm_mod));
        if !own && !pm_reexport { continue; }
        // proc-attrs / proc-derives aren't callable as `mod::name`.
        if sym.kind == SYMKIND_PROC_ATTR || sym.kind == SYMKIND_PROC_DERIVE { continue; }
        let mut label: string = sym.name;
        if sym.kind == SYMKIND_PROC_MACRO || sym.kind == ST_MACRO_DEF {
            label = sym.name.concat("!");
        }
        if seen.contains(label) { continue; }
        seen.insert(label, true);
        let no_edit2: *JsonValue = null;
        let item: *JsonValue = rich_completion_item(
            label, sym.label_extra, ci_kind_for_stmt_kind(sym.kind),
            sym.signature, sym.doc, sym.module,
            sym.snippet, sym.has_snippet, no_edit2);
        json_arr_push(items, item);
    }
}

// Find the first occurrence of `needle` in `haystack`. Returns -1 if
// missing. Works on bytes; fine for ASCII module names.
fn find_substr(haystack: string, needle: string) -> i32 {
    let hn: i32 = haystack.len();
    let nn: i32 = needle.len();
    if nn == 0 { return 0; }
    if nn > hn { return -1; }
    let limit: i32 = hn - nn;
    let mut i: i32 = 0;
    while i <= limit {
        let mut k: i32 = 0;
        while k < nn && haystack.at(i + k).to_int() == needle.at(k).to_int() {
            k = k + 1;
        }
        if k == nn { return i; }
        i = i + 1;
    }
    return -1;
}

// LSP CompletionItemKind for a Stmt kind. Mirrors ci_kind_for, kept here
// so populate_stdlib_index doesn't need the rest of the file in scope.
fn ci_kind_for_stmt_kind(k: i32) -> i32 {
    if k == SYMKIND_MODULE { return 9; }  // Module
    if k == ST_FN { return 3; }           // Function
    if k == ST_STRUCT { return 22; }      // Struct
    if k == ST_ENUM { return 13; }        // Enum
    if k == ST_CONST { return 21; }       // Constant
    if k == ST_TRAIT { return 8; }        // Interface
    return 1;                              // Text fallback
}

// Walk back from (line0, col0) and skip any partial identifier the user is
// typing. Returns the cursor position just before that partial.
fn cursor_before_partial(text: string, line0: i32, col0: i32) -> i32 {
    let mut pos: i32 = 0;
    let mut line: i32 = 0;
    let n: i32 = text.len();
    while pos < n && line < line0 {
        if text.at(pos).to_int() == 10 { line = line + 1; }
        pos = pos + 1;
    }
    pos = pos + col0;
    if pos > n { pos = n; }
    let mut p: i32 = pos;
    while p > 0 {
        let c: i32 = text.at(p - 1).to_int();
        if (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || (c >= 48 && c <= 57) || c == 95 {
            p = p - 1;
        } else { break; }
    }
    return p;
}

// If the cursor sits right after `Type::[partial]`, return the type name.
// Otherwise return "". Type vs module is decided by the first character:
// upper-case → type (`Vector::`, `HashMap::`), lower-case → module
// (handled by module_path_before instead).
// A canonical fixed-width primitive type name. These are lowercase (unlike
// struct/enum names), so the `::` qualifier walker has to recognise them
// explicitly to tell `u256::` (a type) from `hashmap::` (a module path).
fn _is_canon_prim(n: string) -> bool {
    if n.eq("i8") || n.eq("i16") || n.eq("i32") || n.eq("i64")
       || n.eq("i128") || n.eq("i256") { return true; }
    if n.eq("u8") || n.eq("u16") || n.eq("u32") || n.eq("u64")
       || n.eq("u128") || n.eq("u256") { return true; }
    if n.eq("usize") || n.eq("isize") || n.eq("f32") || n.eq("f64") { return true; }
    return false;
}

fn path_qualifier_before(text: string, line0: i32, col0: i32) -> string {
    let p: i32 = cursor_before_partial(text, line0, col0);
    if p < 2 { return ""; }
    if text.at(p - 1).to_int() != 58 || text.at(p - 2).to_int() != 58 { return ""; }
    let mut start: i32 = p - 2;
    while start > 0 {
        let c: i32 = text.at(start - 1).to_int();
        if (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || (c >= 48 && c <= 57) || c == 95 {
            start = start - 1;
        } else { break; }
    }
    let raw: string = text.substring(start, p - 2);
    if raw.eq("") { return ""; }
    let first: i32 = raw.at(0).to_int();
    // Lower-case ⇒ module path, not a type qualifier — EXCEPT the lowercase
    // primitive type names (i32, u256, …), which are real type qualifiers.
    if first >= 97 && first <= 122 {
        if _is_canon_prim(raw) { return raw; }
        return "";
    }
    return raw;
}

// If the cursor sits right after `mod::` or `a::b::…::` (where every
// segment starts with a lower-case letter), return the joined path. Used
// by completion to list the symbols inside a stdlib module the user is
// drilling into. Returns "" when no module-style path precedes the cursor.
//
// Examples accepted:
//   `hashmap::|`            -> "hashmap"
//   `stdlib::hashmap::|`    -> "stdlib::hashmap"
//   `stdlib::|`             -> "stdlib"      (caller may list submodules)
// Examples rejected:
//   `HashMap::|`            -> "" (type qualifier; path_qualifier_before)
//   `stdlib::Hashmap::|`    -> "" (mixed-case; ambiguous, skipped)
fn module_path_before(text: string, line0: i32, col0: i32) -> string {
    let p: i32 = cursor_before_partial(text, line0, col0);
    if p < 2 { return ""; }
    if text.at(p - 1).to_int() != 58 || text.at(p - 2).to_int() != 58 { return ""; }
    let mut end: i32 = p - 2;
    let segments: *Vector<string> = Vector::new();
    while true {
        let mut start: i32 = end;
        while start > 0 {
            let c: i32 = text.at(start - 1).to_int();
            if (c >= 65 && c <= 90) || (c >= 97 && c <= 122)
               || (c >= 48 && c <= 57) || c == 95 {
                start = start - 1;
            } else { break; }
        }
        if start >= end { break; }
        let seg: string = text.substring(start, end);
        // Modules are lower-case; bail as soon as a segment isn't.
        let f: i32 = seg.at(0).to_int();
        if f < 97 || f > 122 { return ""; }
        segments.push(seg);
        if start >= 2 && text.at(start - 1).to_int() == 58
                      && text.at(start - 2).to_int() == 58 {
            end = start - 2;
            continue;
        }
        break;
    }
    let n: i32 = segments.len();
    if n == 0 { return ""; }
    // A lone lowercase primitive (`u256::`, `i32::`) is a TYPE qualifier, not
    // a module path — hand it to path_qualifier_before instead.
    if n == 1 && _is_canon_prim(segments.get(0)) { return ""; }
    let mut out: string = segments.get(n - 1);
    for let i: i32 = n - 2; i >= 0; i = i - 1 {
        out = out.concat("::").concat(segments.get(i));
    }
    return out;
}

// If the cursor sits right after `var.[partial]`, return the var name.
// Otherwise return "".
fn member_qualifier_before(text: string, line0: i32, col0: i32) -> string {
    let p: i32 = cursor_before_partial(text, line0, col0);
    if p < 1 { return ""; }
    if text.at(p - 1).to_int() != 46 { return ""; }
    let mut start: i32 = p - 1;
    while start > 0 {
        let c: i32 = text.at(start - 1).to_int();
        if (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || (c >= 48 && c <= 57) || c == 95 {
            start = start - 1;
        } else { break; }
    }
    return text.substring(start, p - 1);
}

// Member completion fallback for `Type::ctor().` where the receiver is an
// inline call expression. Walks back past a paren-balanced `(...)`, then
// looks for `Type::ident` and returns `Type` so the caller can list its
// instance methods. Returns "" if the pattern doesn't match.
fn chained_ctor_qualifier_before(text: string, line0: i32, col0: i32) -> string {
    let p: i32 = cursor_before_partial(text, line0, col0);
    if p < 1 { return ""; }
    if text.at(p - 1).to_int() != 46 { return ""; }
    // Just before the dot we expect a `)`.
    let mut i: i32 = p - 2;
    if i < 0 { return ""; }
    if text.at(i).to_int() != 41 { return ""; }
    // Walk back to the matching `(`.
    let mut depth: i32 = 1;
    i = i - 1;
    while i >= 0 && depth > 0 {
        let c: i32 = text.at(i).to_int();
        if c == 41 { depth = depth + 1; }
        if c == 40 { depth = depth - 1; }
        if depth == 0 { break; }
        i = i - 1;
    }
    if i < 0 || depth != 0 { return ""; }
    // i now sits at the matching `(`. The chars immediately before should
    // form an identifier (the method name). Skip them.
    let mut j: i32 = i - 1;
    while j >= 0 {
        let c: i32 = text.at(j).to_int();
        if (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || (c >= 48 && c <= 57) || c == 95 {
            j = j - 1;
        } else { break; }
    }
    // Expect `::` immediately before the method name.
    if j < 1 { return ""; }
    if text.at(j).to_int() != 58 || text.at(j - 1).to_int() != 58 { return ""; }
    let mut k: i32 = j - 2;
    while k >= 0 {
        let c: i32 = text.at(k).to_int();
        if (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || (c >= 48 && c <= 57) || c == 95 {
            k = k - 1;
        } else { break; }
    }
    return text.substring(k + 1, j - 1);
}

// Strip pointer/borrow wrappers and return the underlying type's simple
// name (`*Vector<int>` -> "Vector"). Empty string when the type isn't a
// named / generic carrier we can match against impls.
fn _type_simple_name(t: *Type) -> string {
    let mut x: *Type = t;
    while x != null && (x.kind == TY_POINTER || x.kind == TY_BORROW || x.kind == TY_BORROW_MUT) {
        x = x.inner;
    }
    if x == null { return ""; }
    if x.kind == TY_NAMED { return x.name; }
    if x.kind == TY_GENERIC { return x.name; }
    return "";
}

// Resolve a `let` to its receiver type name. Honors the explicit annotation
// first; falls back to recognising `Type::ctor()` on the RHS so
// `let r = Router::new();` yields "Router".
fn _let_simple_type(s: *Stmt) -> string {
    if s == null { return ""; }
    if s.let_ty != null {
        let n: string = _type_simple_name(s.let_ty);
        if !n.eq("") { return n; }
    }
    if s.let_value != null && s.let_value.kind == EX_CALL && s.let_value.lhs != null
       && s.let_value.lhs.kind == EX_PATH {
        return s.let_value.lhs.str_val;
    }
    return "";
}

// Recursively walks `body` looking for the type of `var` visible at `line0`.
// Descends through nested blocks (if/while/for/match) AND through closures
// (EX_FNEXPR) embedded in expressions, so `req` inside `r.get("/", fn(req: *X) {
// req.<cursor> })` correctly resolves to `X`. Innermost binding wins —
// shadowing across closure boundaries is honoured.
fn _scope_var_type(body: *Vector<Stmt>, line0: i32, var: string) -> string {
    if body == null { return ""; }
    let mut found: string = "";
    let mut container_idx: i32 = -1;
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.line - 1 > line0 { break; }
        if s.kind == ST_LET && s.name != null && s.name.eq(var) && s.line - 1 < line0 {
            let n: string = _let_simple_type(&s);
            if !n.eq("") { found = n; }
        }
        if s.kind == ST_FOR && s.for_init != null && s.for_init.kind == ST_LET
           && s.for_init.name != null && s.for_init.name.eq(var)
           && s.for_init.line - 1 <= line0 {
            let n: string = _let_simple_type(s.for_init);
            if !n.eq("") { found = n; }
        }
        container_idx = i;
    }
    if container_idx >= 0 {
        let s: Stmt = body.get(container_idx);
        let r1: string = _scope_var_type(s.then_body, line0, var);
        if !r1.eq("") { return r1; }
        let r2: string = _scope_var_type(s.else_body, line0, var);
        if !r2.eq("") { return r2; }
        if s.kind == ST_MATCH && s.arms != null {
            for let j: i32 = 0; j < s.arms.len(); j++ {
                let arm: MatchArm = s.arms.get(j);
                let ra: string = _scope_var_type(arm.body, line0, var);
                if !ra.eq("") { return ra; }
            }
        }
        let re1: string = _expr_var_type(s.let_value, line0, var);
        if !re1.eq("") { return re1; }
        let re2: string = _expr_var_type(s.expr_value, line0, var);
        if !re2.eq("") { return re2; }
        let re3: string = _expr_var_type(s.cond, line0, var);
        if !re3.eq("") { return re3; }
        let re4: string = _expr_var_type(s.for_step, line0, var);
        if !re4.eq("") { return re4; }
    }
    return found;
}

// Walks an expression tree for an EX_FNEXPR whose params/body bind `var`
// at the cursor line. Used by `_scope_var_type` to look through closures
// passed as call args, struct-lit field values, etc.
fn _expr_var_type(e: *Expr, line0: i32, var: string) -> string {
    if e == null { return ""; }
    if e.kind == EX_FNEXPR {
        if e.fn_expr_params != null {
            for let i: i32 = 0; i < e.fn_expr_params.len(); i++ {
                let p: Param = e.fn_expr_params.get(i);
                if p.name != null && p.name.eq(var) {
                    return _type_simple_name(p.ty);
                }
            }
        }
        if e.fn_expr_body != null && e.line - 1 <= line0 {
            let rb: string = _scope_var_type(e.fn_expr_body, line0, var);
            if !rb.eq("") { return rb; }
        }
    }
    let r1: string = _expr_var_type(e.lhs, line0, var);
    if !r1.eq("") { return r1; }
    let r2: string = _expr_var_type(e.rhs, line0, var);
    if !r2.eq("") { return r2; }
    let r3: string = _expr_var_type(e.operand, line0, var);
    if !r3.eq("") { return r3; }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            let ra: string = _expr_var_type(&a, line0, var);
            if !ra.eq("") { return ra; }
        }
    }
    return "";
}

// Best-effort lookup of the type a local was declared with. Walks the fn
// containing the cursor, descends into nested blocks and closures, finds
// the matching let / param, and returns the underlying generic / named
// type name we can match against impl targets.
fn lookup_local_type(stmts: *Vector<Stmt>, line0: i32, var: string, path: string) -> string {
    let host: *Stmt = fn_containing(stmts, line0, path);
    if host == null || host.fn_body == null { return ""; }
    // Inner scopes win over the host's own params (shadowing).
    let inner: string = _scope_var_type(host.fn_body, line0, var);
    if !inner.eq("") { return inner; }
    if host.fn_params != null {
        for let i: i32 = 0; i < host.fn_params.len(); i++ {
            let pp: Param = host.fn_params.get(i);
            if pp.name.eq(var) { return _type_simple_name(pp.ty); }
        }
    }
    return "";
}

// ---- AST-typed chain resolution -----------------------------------------
//
// Below: a text-walking resolver that returns the receiver's *Type
// (not just a name) for arbitrary chains like `r.listen(8080).`,
// `Type::new().method().`, `v[0].`, `req.headers.`. Plus a member-listing
// helper that handles `!T`, `?T`, `?!T`, named structs and chan types.
// Lets the completion handler suppress the 500+-item "every visible
// symbol" fallback any time the cursor sits after a `.` we can't resolve.

// Detect attribute-style completion contexts.
//   0 = not in an attribute
//   1 = right after `@` (bare attr name, e.g. `@h|`, `@derive`)
//   2 = inside `@derive(...)` arg list
fn _attribute_context(text: string, end_pos: i32) -> i32 {
    // Walk back over any partial ident already typed after `@` / `(` / `,`.
    let mut i: i32 = end_pos - 1;
    while i >= 0 {
        let c: i32 = text.at(i).to_int();
        if (c >= 65 && c <= 90) || (c >= 97 && c <= 122)
           || (c >= 48 && c <= 57) || c == 95 { i = i - 1; } else { break; }
    }
    if i < 0 { return 0; }
    let here: i32 = text.at(i).to_int();
    if here == 64 { return 1; }  // `@`
    // Inside `@derive(<...>)` — walk further left looking for an unmatched
    // `(` preceded by `derive` preceded by `@`.
    if here == 40 || here == 44 || here == 32 {
        let mut j: i32 = i;
        while j > 0 {
            let c2: i32 = text.at(j).to_int();
            if c2 == 10 { return 0; }
            if c2 == 40 {
                let name_end: i32 = j;
                let mut k: i32 = name_end - 1;
                while k >= 0 {
                    let cc: i32 = text.at(k).to_int();
                    if (cc >= 65 && cc <= 90) || (cc >= 97 && cc <= 122)
                       || (cc >= 48 && cc <= 57) || cc == 95 { k = k - 1; }
                    else { break; }
                }
                if k < 0 { return 0; }
                let attr_name: string = text.substring(k + 1, name_end);
                if k >= 0 && text.at(k).to_int() == 64 && attr_name.eq("derive") {
                    return 2;
                }
                return 0;
            }
            j = j - 1;
        }
    }
    return 0;
}

fn _push_attr_completions(doc: LspDoc, state: *LspState, items: *JsonValue, seen: *HashMap<bool>) {
    // Built-in attributes recognised by the compiler.
    let builtins: *Vector<string> = Vector::new();
    builtins.push("cfg"); builtins.push("derive"); builtins.push("expect");
    builtins.push("allow"); builtins.push("deprecated"); builtins.push("lint");
    builtins.push("proc_attr"); builtins.push("proc_derive");
    builtins.push("proc_macro"); builtins.push("proc_macro_str");
    for let i: i32 = 0; i < builtins.len(); i++ {
        let nm: string = builtins.get(i);
        if seen.contains(nm) { continue; }
        seen.insert(nm, true);
        json_arr_push(items, completion_item(nm, 2, "attribute"));
    }
    // Locally registered proc-attrs (already imported).
    if doc.proc_attrs != null {
        for let i: i32 = 0; i < doc.proc_attrs.len(); i++ {
            let nm: string = doc.proc_attrs.get(i);
            if seen.contains(nm) { continue; }
            seen.insert(nm, true);
            json_arr_push(items, completion_item(nm, 2, "proc-attr"));
        }
    }
    // Non-imported proc-attrs from stdlib / project index — surface with
    // an auto-import edit so the user can pick `@handler` without first
    // typing `import stdlib::http::handler;`.
    _push_proc_index_items(state.stdlib_index, doc, SYMKIND_PROC_ATTR, "proc-attr", 2, items, seen);
    _push_proc_index_items(state.project_index, doc, SYMKIND_PROC_ATTR, "proc-attr", 2, items, seen);
}

fn _push_derive_completions(doc: LspDoc, state: *LspState, items: *JsonValue, seen: *HashMap<bool>) {
    if doc.proc_derives != null {
        for let i: i32 = 0; i < doc.proc_derives.len(); i++ {
            let nm: string = doc.proc_derives.get(i);
            if seen.contains(nm) { continue; }
            seen.insert(nm, true);
            json_arr_push(items, completion_item(nm, 7, "derive"));  // 7 = Class
        }
    }
    _push_proc_index_items(state.stdlib_index, doc, SYMKIND_PROC_DERIVE, "derive", 7, items, seen);
    _push_proc_index_items(state.project_index, doc, SYMKIND_PROC_DERIVE, "derive", 7, items, seen);
}

// Walk an importable-symbol index for entries of `want_kind` and push a
// completion item with the auto-import edit, so the user can pick a
// proc-derive / proc-attr without having to know which stdlib submodule
// it lives in.
fn _push_proc_index_items(idx: *Vector<ImportableSym>, doc: LspDoc,
                           want_kind: i32, detail: string, ci_kind: i32,
                           items: *JsonValue, seen: *HashMap<bool>) {
    if idx == null { return; }
    let imps: *HashMap<ImportInfo> = current_imports(doc.text);
    let insert_line: i32 = find_import_insertion_pos(doc.text);
    for let i: i32 = 0; i < idx.len(); i++ {
        let sym: ImportableSym = idx.get(i);
        if sym.kind != want_kind { continue; }
        if sym.name == null || seen.contains(sym.name) { continue; }
        seen.insert(sym.name, true);
        let mut existing: *ImportInfo = null;
        if imps.contains(sym.module) {
            let info_val: ImportInfo = imps.get(sym.module);
            existing = malloc(sizeof(ImportInfo)) as *ImportInfo;
            *existing = info_val;
        }
        let edit: *JsonValue = build_import_edit(
            sym.name, sym.module, existing, insert_line, false);
        let item: *JsonValue = rich_completion_item(
            sym.name, "", ci_kind,
            detail.concat(" ").concat(sym.name), sym.doc, sym.module,
            sym.name, false, edit);
        json_arr_push(items, item);
    }
    imps.free();
}

// Walk every loaded stmt (user file + builtins + transitively-imported
// stdlib modules) collecting macro definitions and proc-macro
// registrations. Run before `expand_macros` consumes them so the
// completion handler still has the names.
fn _harvest_macro_defs(
    stmts: *Vector<Stmt>,
    out_macros: *Vector<Stmt>,
    out_impl_macros: *Vector<Stmt>,
    out_attrs: *Vector<string>,
    out_derives: *Vector<string>,
    out_fns: *Vector<string>,
) {
    if stmts == null { return; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind == ST_MACRO_DEF && s.name != null { out_macros.push(s); continue; }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.kind == ST_MACRO_DEF && m.name != null { out_impl_macros.push(m); }
            }
        }
        if s.kind == ST_FN && s.attrs != null {
            for let j: i32 = 0; j < s.attrs.len(); j++ {
                let a: Attr = s.attrs.get(j);
                if a.name == null { continue; }
                if a.args == null || a.args.len() == 0 { continue; }
                let ne: Expr = a.args.get(0);
                if ne.kind != EX_IDENT { continue; }
                if a.name.eq("proc_attr")        { out_attrs.push(ne.str_val); }
                else if a.name.eq("proc_derive") { out_derives.push(ne.str_val); }
                else if a.name.eq("proc_macro")     { out_fns.push(ne.str_val); }
                else if a.name.eq("proc_macro_str") { out_fns.push(ne.str_val); }
            }
        }
    }
}

// True if the cursor at (`line0`, `col0`) sits inside a string literal,
// char literal, or `//` line comment. Walks from start-of-file tracking
// state so multi-line strings (rare but legal — the lexer keeps reading
// until the closing `"`) are handled correctly. Block-comment style
// `/* ... */` isn't lexed by Glide so it's left out.
fn _cursor_in_string_or_comment(text: string, line0: i32, col0: i32) -> bool {
    let n: i32 = text.len();
    let mut pos: i32 = 0;
    let mut line: i32 = 0;
    while pos < n && line < line0 {
        if text.at(pos).to_int() == 10 { line = line + 1; }
        pos = pos + 1;
    }
    let mut target: i32 = pos + col0;
    if target > n { target = n; }
    let mut in_str: bool = false;
    let mut in_chr: bool = false;
    let mut in_lc: bool = false;
    let mut i: i32 = 0;
    while i < target {
        let c: i32 = text.at(i).to_int();
        // Line comment: lasts until newline. Reset at newline.
        if in_lc {
            if c == 10 { in_lc = false; }
            i = i + 1;
            continue;
        }
        if in_str {
            if c == 92 && i + 1 < target { i = i + 2; continue; }  // \X
            if c == 34 { in_str = false; }
            i = i + 1;
            continue;
        }
        if in_chr {
            if c == 92 && i + 1 < target { i = i + 2; continue; }
            if c == 39 { in_chr = false; }
            i = i + 1;
            continue;
        }
        if c == 34 { in_str = true; i = i + 1; continue; }
        if c == 39 { in_chr = true; i = i + 1; continue; }
        if c == 47 && i + 1 < target && text.at(i + 1).to_int() == 47 {
            in_lc = true;
            i = i + 2;
            continue;
        }
        i = i + 1;
    }
    return in_str || in_chr || in_lc;
}

fn _match_paren_back(text: string, close_pos: i32) -> i32 {
    if close_pos < 0 { return -1; }
    if text.at(close_pos).to_int() != 41 { return -1; }
    let mut depth: i32 = 1;
    let mut i: i32 = close_pos - 1;
    while i >= 0 {
        let c: i32 = text.at(i).to_int();
        if c == 41 { depth = depth + 1; }
        else if c == 40 { depth = depth - 1; if depth == 0 { return i; } }
        i = i - 1;
    }
    return -1;
}

fn _match_brack_back(text: string, close_pos: i32) -> i32 {
    if close_pos < 0 { return -1; }
    if text.at(close_pos).to_int() != 93 { return -1; }
    let mut depth: i32 = 1;
    let mut i: i32 = close_pos - 1;
    while i >= 0 {
        let c: i32 = text.at(i).to_int();
        if c == 93 { depth = depth + 1; }
        else if c == 91 { depth = depth - 1; if depth == 0 { return i; } }
        i = i - 1;
    }
    return -1;
}

fn _ident_start_back(text: string, end_i: i32) -> i32 {
    let mut i: i32 = end_i;
    while i >= 0 {
        let c: i32 = text.at(i).to_int();
        if (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || (c >= 48 && c <= 57) || c == 95 {
            i = i - 1;
        } else { break; }
    }
    return i + 1;
}

// Strip pointer/borrow wrappers and return the resulting node. null on null.
fn _strip_ptr_borrow(t: *Type) -> *Type {
    let mut x: *Type = t;
    while x != null && (x.kind == TY_POINTER || x.kind == TY_BORROW || x.kind == TY_BORROW_MUT) {
        x = x.inner;
    }
    return x;
}

// Find an impl method named `method_name` on `type_name`, return its
// declared return type. null if not found.
fn _impl_method_ret(stmts: *Vector<Stmt>, type_name: string, method_name: string) -> *Type {
    if stmts == null { return null; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_IMPL { continue; }
        if s.impl_target == null || s.impl_target.name == null
           || !s.impl_target.name.eq(type_name) { continue; }
        if s.impl_methods == null { continue; }
        for let j: i32 = 0; j < s.impl_methods.len(); j++ {
            let m: Stmt = s.impl_methods.get(j);
            if m.kind != ST_FN || m.name == null || !m.name.eq(method_name) { continue; }
            return m.fn_ret_ty;
        }
    }
    return null;
}

// Resolve a method call on a receiver type to its return type.
fn _method_ret_type(stmts: *Vector<Stmt>, recv: *Type, method_name: string) -> *Type {
    let x: *Type = _strip_ptr_borrow(recv);
    if x == null { return null; }
    if x.kind != TY_NAMED && x.kind != TY_GENERIC { return null; }
    return _impl_method_ret(stmts, x.name, method_name);
}

// Look up a struct field type by struct + field name.
fn _struct_field_type(stmts: *Vector<Stmt>, recv: *Type, field_name: string) -> *Type {
    let x: *Type = _strip_ptr_borrow(recv);
    if x == null { return null; }
    if x.kind != TY_NAMED && x.kind != TY_GENERIC { return null; }
    if stmts == null { return null; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_STRUCT || !s.name.eq(x.name) { continue; }
        if s.struct_fields == null { continue; }
        for let j: i32 = 0; j < s.struct_fields.len(); j++ {
            let f: Field = s.struct_fields.get(j);
            if f.name.eq(field_name) { return f.ty; }
        }
    }
    return null;
}

// Look up a top-level fn's return type by name.
fn _fn_ret_type(stmts: *Vector<Stmt>, fn_name: string) -> *Type {
    if stmts == null { return null; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind == ST_FN && s.name != null && s.name.eq(fn_name) {
            return s.fn_ret_ty;
        }
    }
    return null;
}

// Look up a local (let / param / closure-param / for-init / etc.) by name
// at the cursor line and return its AST type — strips nothing so callers
// can see `*HttpRequest`, `!int`, `?string` etc. as-is.
fn _local_type_node(stmts: *Vector<Stmt>, line0: i32, var: string, path: string) -> *Type {
    let host: *Stmt = fn_containing(stmts, line0, path);
    if host == null { return null; }
    if host.fn_params != null {
        for let i: i32 = 0; i < host.fn_params.len(); i++ {
            let p: Param = host.fn_params.get(i);
            if p.name.eq(var) { return p.ty; }
        }
    }
    return _scope_var_node(host.fn_body, line0, var, stmts);
}

fn _scope_var_node(body: *Vector<Stmt>, line0: i32, var: string, root: *Vector<Stmt>) -> *Type {
    if body == null { return null; }
    let mut found: *Type = null;
    let mut container_idx: i32 = -1;
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.line - 1 > line0 { break; }
        if s.kind == ST_LET && s.name != null && s.name.eq(var) && s.line - 1 < line0 {
            let n: *Type = _let_node_type(&s, root);
            if n != null { found = n; }
        }
        if s.kind == ST_FOR && s.for_init != null && s.for_init.kind == ST_LET
           && s.for_init.name != null && s.for_init.name.eq(var)
           && s.for_init.line - 1 <= line0 {
            let n: *Type = _let_node_type(s.for_init, root);
            if n != null { found = n; }
        }
        container_idx = i;
    }
    if container_idx >= 0 {
        let s: Stmt = body.get(container_idx);
        let r1: *Type = _scope_var_node(s.then_body, line0, var, root);
        if r1 != null { return r1; }
        let r2: *Type = _scope_var_node(s.else_body, line0, var, root);
        if r2 != null { return r2; }
        if s.kind == ST_MATCH && s.arms != null {
            for let j: i32 = 0; j < s.arms.len(); j++ {
                let arm: MatchArm = s.arms.get(j);
                let ra: *Type = _scope_var_node(arm.body, line0, var, root);
                if ra != null { return ra; }
            }
        }
        let re1: *Type = _expr_var_node(s.let_value, line0, var, root);
        if re1 != null { return re1; }
        let re2: *Type = _expr_var_node(s.expr_value, line0, var, root);
        if re2 != null { return re2; }
        let re3: *Type = _expr_var_node(s.cond, line0, var, root);
        if re3 != null { return re3; }
        let re4: *Type = _expr_var_node(s.for_step, line0, var, root);
        if re4 != null { return re4; }
    }
    return found;
}

fn _expr_var_node(e: *Expr, line0: i32, var: string, root: *Vector<Stmt>) -> *Type {
    if e == null { return null; }
    if e.kind == EX_FNEXPR {
        if e.fn_expr_params != null {
            for let i: i32 = 0; i < e.fn_expr_params.len(); i++ {
                let p: Param = e.fn_expr_params.get(i);
                if p.name != null && p.name.eq(var) { return p.ty; }
            }
        }
        if e.fn_expr_body != null && e.line - 1 <= line0 {
            let rb: *Type = _scope_var_node(e.fn_expr_body, line0, var, root);
            if rb != null { return rb; }
        }
    }
    let r1: *Type = _expr_var_node(e.lhs, line0, var, root);
    if r1 != null { return r1; }
    let r2: *Type = _expr_var_node(e.rhs, line0, var, root);
    if r2 != null { return r2; }
    let r3: *Type = _expr_var_node(e.operand, line0, var, root);
    if r3 != null { return r3; }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            let ra: *Type = _expr_var_node(&a, line0, var, root);
            if ra != null { return ra; }
        }
    }
    return null;
}

// Type of a let's binding: explicit annotation first, then `Type::ctor()`
// RHS lookup (Router::new() -> *Router, Vector::new() -> *Vector<T>).
fn _let_node_type(s: *Stmt, root: *Vector<Stmt>) -> *Type {
    if s == null { return null; }
    if s.let_ty != null { return s.let_ty; }
    if s.let_value != null && s.let_value.kind == EX_CALL && s.let_value.lhs != null
       && s.let_value.lhs.kind == EX_PATH {
        let t_name: string = s.let_value.lhs.str_val;
        let m_name: string = s.let_value.lhs.field;
        return _impl_method_ret(root, t_name, m_name);
    }
    // `let v = ret();` — infer from a plain function call's return type, so
    // `v.` completes even without a type annotation.
    if s.let_value != null && s.let_value.kind == EX_CALL && s.let_value.lhs != null
       && s.let_value.lhs.kind == EX_IDENT {
        return _fn_ret_type(root, s.let_value.lhs.str_val);
    }
    // `let s = "x"; / let n = 5;` — infer the primitive type from a literal
    // initializer, so `s.` completes string methods without an annotation.
    if s.let_value != null {
        let lv: i32 = s.let_value.kind;
        if lv == EX_STRING { return ty_named("string"); }
        if lv == EX_INT    { return ty_named("i32"); }
        if lv == EX_FLOAT  { return ty_named("f64"); }
        if lv == EX_BOOL   { return ty_named("bool"); }
        if lv == EX_CHAR   { return ty_named("char"); }
    }
    return null;
}

// Resolve the type of the expression text ending at `end_pos` (exclusive)
// in `text`. Recursive walker: handles ident, `x.field`, `x.method(args)`,
// `Type::method(args)`, chained variants, and `v[i]` indexing. Returns
// null when we can't resolve. Robust to expressions that don't end with
// a parseable token (lets us answer completion at `expr.|`).
// True if `s` is one or more ASCII digits and nothing else (a bare integer
// literal token). Drives member completion on a literal receiver (`43.`).
fn _all_digits(s: string) -> bool {
    if s == null || s.len() == 0 { return false; }
    for let i: i32 = 0; i < s.len(); i++ {
        let c: i32 = s.at(i).to_int();
        if c < 48 || c > 57 { return false; }
    }
    return true;
}

fn _chain_resolve_type(text: string, end_pos: i32, stmts: *Vector<Stmt>, line0: i32, path: string) -> *Type {
    if end_pos <= 0 || stmts == null { return null; }
    let last_i: i32 = end_pos - 1;
    let c: i32 = text.at(last_i).to_int();

    // Call: `…(args)`
    if c == 41 {
        let open_i: i32 = _match_paren_back(text, last_i);
        if open_i < 0 { return null; }
        let m_start: i32 = _ident_start_back(text, open_i - 1);
        let m_end: i32 = open_i;
        if m_start >= m_end { return null; }
        let method_name: string = text.substring(m_start, m_end);
        let pre_i: i32 = m_start - 1;
        if pre_i < 0 {
            return _fn_ret_type(stmts, method_name);
        }
        let pc: i32 = text.at(pre_i).to_int();
        if pc == 46 {
            let recv: *Type = _chain_resolve_type(text, pre_i, stmts, line0, path);
            return _method_ret_type(stmts, recv, method_name);
        }
        if pre_i >= 1 && pc == 58 && text.at(pre_i - 1).to_int() == 58 {
            let t_end: i32 = pre_i - 1;
            let t_start: i32 = _ident_start_back(text, t_end - 1);
            if t_start >= t_end { return null; }
            let type_name: string = text.substring(t_start, t_end);
            return _impl_method_ret(stmts, type_name, method_name);
        }
        return _fn_ret_type(stmts, method_name);
    }

    // Literal receiver: `"".` → string, `'x'.` → char. A quote/apostrophe
    // immediately before the `.` is the close of a literal, so member
    // completion works directly on literals (`"".len()`).
    if c == 34 { return ty_named("string"); }
    if c == 39 { return ty_named("char"); }

    // Indexing: `…[idx]` — for Vector<T>[i] return T.
    if c == 93 {
        let open_i: i32 = _match_brack_back(text, last_i);
        if open_i < 0 { return null; }
        let recv: *Type = _chain_resolve_type(text, open_i, stmts, line0, path);
        let x: *Type = _strip_ptr_borrow(recv);
        if x != null && x.kind == TY_GENERIC && x.args != null && x.args.len() > 0 {
            let a: Type = x.args.get(0);
            let p: *Type = malloc(sizeof(Type)) as *Type;
            *p = a;
            return p;
        }
        return null;
    }

    // Ident or member field
    if (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || (c >= 48 && c <= 57) || c == 95 {
        let i_start: i32 = _ident_start_back(text, last_i);
        let ident: string = text.substring(i_start, end_pos);
        // Bare integer literal receiver: `43.` → i32, so member completion
        // offers the int methods directly on a literal.
        if _all_digits(ident) { return ty_named("i32"); }
        let pre_i: i32 = i_start - 1;
        if pre_i < 0 {
            return _local_type_node(stmts, line0, ident, path);
        }
        let pc: i32 = text.at(pre_i).to_int();
        if pc == 46 {
            let recv: *Type = _chain_resolve_type(text, pre_i, stmts, line0, path);
            return _struct_field_type(stmts, recv, ident);
        }
        return _local_type_node(stmts, line0, ident, path);
    }

    return null;
}

// Push members of the receiver type into `items`. Handles `!T` (ok/val/err),
// `?T` (has/val), `?!T` (has/ok/val/err), and named/generic types via the
// existing list_fields/list_methods/list_chan helpers.
// Push one primitive-type method completion with a doc + example. `ret` is
// the return type shown in the signature.
fn _prim_method(items: *JsonValue, seen: *HashMap<bool>, name: string, ret: string, doc: string) {
    if seen.contains(name) { return; }
    seen.insert(name, true);
    let no_edit: *JsonValue = null;
    json_arr_push(items, rich_completion_item(
        name, "", 2, name.concat("(self) -> ").concat(ret), doc, "", "", false, no_edit));
}

// Methods on the primitive types. These are lowered by codegen, not written
// in Glide source, so member completion (`c.` / `n.` / `b.`) would otherwise
// show nothing for them — surface them here with a summary + a fenced
// `glide` example, the same shape the documented stdlib uses.
fn _list_primitive_methods(type_name: string, items: *JsonValue, seen: *HashMap<bool>) {
    if type_name.eq("char") {
        _prim_method(items, seen, "to_int", "int",
            "The character's numeric code point.\n\n```glide\nlet c: char = 'A';\nc.to_int();   // 65\n```");
        _prim_method(items, seen, "to_string", "string",
            "A one-character `string` holding this char.\n\n```glide\n'x'.to_string();   // \"x\"\n```");
        _prim_method(items, seen, "is_digit", "bool",
            "True for `'0'` through `'9'`.\n\n```glide\n'7'.is_digit();   // true\n'a'.is_digit();   // false\n```");
        _prim_method(items, seen, "is_alpha", "bool",
            "True for an ASCII letter (`a`-`z` / `A`-`Z`).\n\n```glide\n'a'.is_alpha();   // true\n```");
        return;
    }
    if type_name.eq("int") || type_name.eq("i8") || type_name.eq("i16")
       || type_name.eq("i32") || type_name.eq("i64")
       || type_name.eq("u8") || type_name.eq("u16") || type_name.eq("u32")
       || type_name.eq("u64") || type_name.eq("i128") || type_name.eq("u128")
       || type_name.eq("i256") || type_name.eq("u256")
       || type_name.eq("usize") || type_name.eq("isize") {
        _prim_method(items, seen, "abs", type_name,
            "Absolute value.\n\n```glide\nlet n: i32 = -5;\nn.abs();   // 5\n```");
        _prim_method(items, seen, "to_string", "string",
            "Decimal text for this integer.\n\n```glide\nlet n: i32 = 42;\nn.to_string();   // \"42\"\n```");
        return;
    }
    if type_name.eq("bool") {
        _prim_method(items, seen, "to_string", "string",
            "`\"true\"` or `\"false\"`.\n\n```glide\nlet ok: bool = true;\nok.to_string();   // \"true\"\n```");
        return;
    }
}

fn _list_members_for_type_node(ty: *Type, stmts: *Vector<Stmt>, items: *JsonValue, seen: *HashMap<bool>) {
    if ty == null { return; }
    let x: *Type = _strip_ptr_borrow(ty);
    if x == null { return; }
    if x.kind == TY_RESULT {
        let inner_pretty: string = type_to_string_pretty(x.inner);
        if !seen.contains("ok")  { seen.insert("ok",  true); json_arr_push(items, completion_item("ok",  5, "bool")); }
        if !seen.contains("val") { seen.insert("val", true); json_arr_push(items, completion_item("val", 5, inner_pretty)); }
        if !seen.contains("err") { seen.insert("err", true); json_arr_push(items, completion_item("err", 5, "string")); }
        return;
    }
    if x.kind == TY_OPTION {
        let inner_pretty: string = type_to_string_pretty(x.inner);
        if !seen.contains("has") { seen.insert("has", true); json_arr_push(items, completion_item("has", 5, "bool")); }
        if !seen.contains("val") { seen.insert("val", true); json_arr_push(items, completion_item("val", 5, inner_pretty)); }
        return;
    }
    if x.kind == TY_OPT_RESULT {
        let inner_pretty: string = type_to_string_pretty(x.inner);
        if !seen.contains("has") { seen.insert("has", true); json_arr_push(items, completion_item("has", 5, "bool")); }
        if !seen.contains("ok")  { seen.insert("ok",  true); json_arr_push(items, completion_item("ok",  5, "bool")); }
        if !seen.contains("val") { seen.insert("val", true); json_arr_push(items, completion_item("val", 5, inner_pretty)); }
        if !seen.contains("err") { seen.insert("err", true); json_arr_push(items, completion_item("err", 5, "string")); }
        return;
    }
    if x.kind == TY_NAMED || x.kind == TY_GENERIC {
        list_fields_for_type(stmts, x.name, items, seen);
        list_methods_for_type(stmts, x.name, items, seen, true);
        _list_primitive_methods(x.name, items, seen);
        list_chan_methods_for_type(x.name, items, seen);
        return;
    }
}

fn list_fields_for_type(stmts: *Vector<Stmt>, type_name: string, items: *JsonValue, seen: *HashMap<bool>) {
    if stmts == null { return; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_STRUCT || !s.name.eq(type_name) { continue; }
        if s.struct_fields == null { continue; }
        for let j: i32 = 0; j < s.struct_fields.len(); j++ {
            let f: Field = s.struct_fields.get(j);
            if seen.contains(f.name) { continue; }
            seen.insert(f.name, true);
            json_arr_push(items, completion_item(f.name, 5, type_to_string_pretty(f.ty)));  // 5 = Field
        }
    }
}

// Surface the chan API (`send` / `recv` / `close`) on member completion when
// the receiver is a `chan<T>`. Channels have no impl block to scan so the
// methods are hardcoded here, matching the typer's special-case lowering.
fn list_chan_methods_for_type(type_name: string, items: *JsonValue, seen: *HashMap<bool>) {
    if !type_name.eq("chan") { return; }
    if !seen.contains("send") {
        seen.insert("send", true);
        json_arr_push(items, completion_item("send", 2, "fn send(self: chan<T>, x: T)"));
    }
    if !seen.contains("recv") {
        seen.insert("recv", true);
        json_arr_push(items, completion_item("recv", 2, "fn recv(self: chan<T>) -> T"));
    }
    if !seen.contains("close") {
        seen.insert("close", true);
        json_arr_push(items, completion_item("close", 2, "fn close(self: chan<T>)"));
    }
}

// `want_self`: true → list instance methods (first param is `self`).
//              false → list static methods (no `self`).
fn list_methods_for_type(stmts: *Vector<Stmt>, type_name: string,
                          items: *JsonValue, seen: *HashMap<bool>,
                          want_self: bool) {
    if stmts == null { return; }
    for let i: i32 = 0; i < stmts.len(); i++ {
        let s: Stmt = stmts.get(i);
        if s.kind != ST_IMPL { continue; }
        if s.impl_target == null { continue; }
        let mut tname: string = "";
        if s.impl_target.kind == TY_NAMED { tname = s.impl_target.name; }
        if s.impl_target.kind == TY_GENERIC { tname = s.impl_target.name; }
        if !tname.eq(type_name) { continue; }
        if s.impl_methods == null { continue; }
        for let j: i32 = 0; j < s.impl_methods.len(); j++ {
            let m: Stmt = s.impl_methods.get(j);
            if m.kind == ST_FN {
                let mut has_self: bool = false;
                if m.fn_params != null && m.fn_params.len() > 0 {
                    let p0: Param = m.fn_params.get(0);
                    if p0.name.eq("self") { has_self = true; }
                }
                if want_self && !has_self { continue; }
                if !want_self && has_self { continue; }
                if seen.contains(m.name) { continue; }
                seen.insert(m.name, true);
                // Carry the `///` doc comment so method completion shows the
                // summary + example on hover, not just the signature.
                let mut mdoc: string = "";
                if m.doc_comment != null { mdoc = m.doc_comment; }
                let no_edit_m: *JsonValue = null;
                json_arr_push(items, rich_completion_item(
                    m.name, "", 2, fn_signature(&m), mdoc, "", "", false, no_edit_m));
            } else if m.kind == ST_MACRO_DEF {
                // Mirror the fn filter: instance macros (body uses `self`)
                // belong to `v.` completion; static-in-impl macros (no self)
                // belong to `Type::` completion. Calling the wrong shape
                // works but produces awkward sites, so we hide them.
                let uses_self: bool = body_references_self(m.then_body);
                if want_self && !uses_self { continue; }
                if !want_self && uses_self { continue; }
                let label: string = m.name.concat("!");
                if seen.contains(label) { continue; }
                seen.insert(label, true);
                json_arr_push(items, completion_item(label, 2, macro_signature(&m)));
            }
        }
    }
}

// True when the cursor (partial-word start at `p`) sits in a type-annotation
// position: right after `:` (but not `::`), after `->`, or after `<` (generic
// arg). Used to offer primitive type names there. Generous on purpose — a
// false positive (e.g. a struct-literal `field:`) only adds a few type names
// to the list, which the prefix filter hides.
fn _in_type_position(text: string, p: i32) -> bool {
    let mut i: i32 = p - 1;
    while i >= 0 {
        let c: i32 = text.at(i).to_int();
        if c == 32 || c == 9 { i = i - 1; continue; }   // skip spaces/tabs
        break;
    }
    if i < 0 { return false; }
    let c: i32 = text.at(i).to_int();
    if c == 58 {                                          // ':'
        if i >= 1 && text.at(i - 1).to_int() == 58 { return false; }   // '::' — module path
        return true;
    }
    if c == 62 && i >= 1 && text.at(i - 1).to_int() == 45 { return true; }   // '->' return type
    if c == 60 { return true; }                           // '<' generic arg
    return false;
}

// Offer the primitive type names (mirrors the typer's `_is_known_type_name`
// list) as completions. Kind 22 = Struct, so they render as types.
fn _push_primitive_types(items: *JsonValue, seen: *HashMap<bool>) {
    // Canonical fixed-width family only — the legacy `int`/`uint`/`long`/
    // `ulong`/`float` spellings are retired (they now error with a hint), so
    // new code standardises on `iN` / `uN` / `fN`.
    let prims: *Vector<string> = Vector::new();
    prims.push("i8");   prims.push("i16");  prims.push("i32");  prims.push("i64");
    prims.push("u8");   prims.push("u16");  prims.push("u32");  prims.push("u64");
    prims.push("i128"); prims.push("u128");
    prims.push("i256"); prims.push("u256");
    prims.push("usize"); prims.push("isize");
    prims.push("f32");  prims.push("f64");
    prims.push("bool"); prims.push("char"); prims.push("string"); prims.push("void");
    for let i: i32 = 0; i < prims.len(); i++ {
        let p: string = prims.get(i);
        if seen.contains(p) { continue; }
        seen.insert(p, true);
        json_arr_push(items, completion_item(p, 22, "primitive type"));
    }
}

// Byte offset of the cursor (line0/col0) into `text`.
fn _manifest_cursor_offset(text: string, line0: i32, col0: i32) -> i32 {
    let n: i32 = text.len();
    let mut pos: i32 = 0;
    let mut line: i32 = 0;
    while pos < n && line < line0 {
        if text.at(pos).to_int() == 10 { line = line + 1; }
        pos = pos + 1;
    }
    pos = pos + col0;
    if pos > n { pos = n; }
    return pos;
}

// Offset of the innermost unclosed `{` / `(` strictly before the cursor, or
// -1 if the cursor is at top level. `text.at(offset)` tells the caller which
// delimiter it is. Skips string + `//`-comment contents.
fn _manifest_open_offset(text: string, line0: i32, col0: i32) -> i32 {
    let pos: i32 = _manifest_cursor_offset(text, line0, col0);
    let stack: *Vector<i32> = Vector::new();
    let mut i: i32 = 0;
    while i < pos {
        let c: i32 = text.at(i).to_int();
        if c == 34 {                       // string literal — skip to its end
            i = i + 1;
            while i < pos {
                let d: i32 = text.at(i).to_int();
                if d == 92 { i = i + 2; continue; }
                if d == 34 { i = i + 1; break; }
                i = i + 1;
            }
            continue;
        }
        if c == 47 && i + 1 < pos && text.at(i + 1).to_int() == 47 {   // // comment
            while i < pos && text.at(i).to_int() != 10 { i = i + 1; }
            continue;
        }
        if c == 123 || c == 40 { stack.push(i); }
        else if c == 125 || c == 41 { if stack.len() > 0 { stack.pop(); } }
        i = i + 1;
    }
    if stack.len() == 0 { return -1; }
    return stack.get(stack.len() - 1);
}

// Collect the field names already written at the top level of the `{ }` block
// that opens at `open_off`, into `present`. Lets completion drop fields the
// user has already filled in. Idents are matched only when followed by a
// single `:` (so `Dep::path` inside a nested `vec_of(...)` is excluded both by
// the `::` check and by sitting at a deeper delimiter level).
fn _manifest_collect_fields(text: string, open_off: i32, present: *HashMap<bool>) {
    if open_off < 0 { return; }
    let n: i32 = text.len();
    let mut depth: i32 = 0;
    let mut i: i32 = open_off + 1;
    while i < n {
        let c: i32 = text.at(i).to_int();
        if c == 34 {
            i = i + 1;
            while i < n {
                let d: i32 = text.at(i).to_int();
                if d == 92 { i = i + 2; continue; }
                if d == 34 { i = i + 1; break; }
                i = i + 1;
            }
            continue;
        }
        if c == 47 && i + 1 < n && text.at(i + 1).to_int() == 47 {
            while i < n && text.at(i).to_int() != 10 { i = i + 1; }
            continue;
        }
        if c == 123 || c == 40 { depth = depth + 1; i = i + 1; continue; }
        if c == 125 || c == 41 {
            if depth == 0 { break; }       // closes the block we started in
            depth = depth - 1; i = i + 1; continue;
        }
        if depth == 0 && ((c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95) {
            let start: i32 = i;
            while i < n {
                let cc: i32 = text.at(i).to_int();
                if (cc >= 65 && cc <= 90) || (cc >= 97 && cc <= 122)
                   || (cc >= 48 && cc <= 57) || cc == 95 { i = i + 1; } else { break; }
            }
            let ident: string = text.substring(start, i);
            let mut j: i32 = i;
            while j < n {
                let w: i32 = text.at(j).to_int();
                if w == 32 || w == 9 || w == 10 || w == 13 { j = j + 1; } else { break; }
            }
            if j < n && text.at(j).to_int() == 58
               && (j + 1 >= n || text.at(j + 1).to_int() != 58) {
                present.insert(ident, true);
            }
            continue;
        }
        i = i + 1;
    }
}

// True if the current line already has a `:` before the cursor — i.e. the
// cursor sits in a field's VALUE slot, not at a field-name position.
fn _manifest_in_value_slot(text: string, line0: i32, col0: i32) -> bool {
    let cur: i32 = _manifest_cursor_offset(text, line0, col0);
    let mut s: i32 = cur;
    while s > 0 && text.at(s - 1).to_int() != 10 { s = s - 1; }
    let mut i: i32 = s;
    while i < cur {
        if text.at(i).to_int() == 58 { return true; }
        i = i + 1;
    }
    return false;
}

// Push every `Package` field not already present, so completion is
// progressive: filled-in fields drop off the list. Kind 5 = Field.
fn _push_manifest_fields(items: *JsonValue, present: *HashMap<bool>) {
    if !present.contains("name") { json_arr_push(items, completion_item("name", 5, "string — package name (required)")); }
    if !present.contains("version") { json_arr_push(items, completion_item("version", 5, "string — semver, e.g. \"0.1.0\" (required)")); }
    if !present.contains("bin") { json_arr_push(items, completion_item("bin", 5, "string — entry point (default src/main.glide)")); }
    if !present.contains("deps") { json_arr_push(items, completion_item("deps", 5, "vec_of(...) — dependency list")); }
    if !present.contains("description") { json_arr_push(items, completion_item("description", 5, "string — short summary (optional)")); }
    if !present.contains("author") { json_arr_push(items, completion_item("author", 5, "string — name <email> (optional)")); }
    if !present.contains("license") { json_arr_push(items, completion_item("license", 5, "string — SPDX id, e.g. \"MIT\" (optional)")); }
    if !present.contains("repository") { json_arr_push(items, completion_item("repository", 5, "string — source URL (optional)")); }
    if !present.contains("target") { json_arr_push(items, completion_item("target", 5, "string — default cross-compile triple (optional)")); }
}

// The field name of the current line (`<ident>:` at its start), or "".
// Lets completion offer value suggestions keyed to the field being filled.
fn _manifest_line_field(text: string, line0: i32, col0: i32) -> string {
    let cur: i32 = _manifest_cursor_offset(text, line0, col0);
    let n: i32 = text.len();
    let mut s: i32 = cur;
    while s > 0 && text.at(s - 1).to_int() != 10 { s = s - 1; }
    let mut i: i32 = s;
    while i < cur {
        let w: i32 = text.at(i).to_int();
        if w == 32 || w == 9 { i = i + 1; } else { break; }
    }
    let start: i32 = i;
    while i < n {
        let c: i32 = text.at(i).to_int();
        if (c >= 65 && c <= 90) || (c >= 97 && c <= 122)
           || (c >= 48 && c <= 57) || c == 95 { i = i + 1; } else { break; }
    }
    if i == start { return ""; }
    let ident: string = text.substring(start, i);
    let mut j: i32 = i;
    while j < n {
        let w: i32 = text.at(j).to_int();
        if w == 32 || w == 9 { j = j + 1; } else { break; }
    }
    if j < n && text.at(j).to_int() == 58 { return ident; }
    return "";
}

// Cross-compile triples offered as `target:` values. The musl pair has
// auto-fetched sysroots (`glide target list`); the rest cross-compile via the
// bundled zig backend (a program touching openssl/etc. needs a manual sysroot).
fn _push_target_triples(items: *JsonValue) {
    json_arr_push(items, completion_item("x86_64-linux-musl", 12, "Linux x86_64 (sysroot auto-fetched)"));
    json_arr_push(items, completion_item("aarch64-linux-musl", 12, "Linux ARM64 (sysroot auto-fetched)"));
    json_arr_push(items, completion_item("x86_64-linux-gnu", 12, "Linux x86_64 (glibc)"));
    json_arr_push(items, completion_item("aarch64-linux-gnu", 12, "Linux ARM64 (glibc)"));
    json_arr_push(items, completion_item("x86_64-macos", 12, "macOS Intel"));
    json_arr_push(items, completion_item("aarch64-macos", 12, "macOS Apple Silicon"));
    json_arr_push(items, completion_item("x86_64-windows-gnu", 12, "Windows x86_64 (MinGW)"));
}

// Manifest-aware completion for `glide.glide`. The manifest is never compiled,
// so symbol-based completion has nothing to offer; instead we surface the
// fixed schema (`Package` + its fields, `vec_of`, `Dep::path` / `Dep::git`)
// keyed off the cursor's delimiter context. Text-driven so it works even
// while the buffer is half-typed (no AST required).
fn handle_manifest_completion(id: *JsonValue, doc: LspDoc, line0: i32, col0: i32) {
    // `target:` value — offer cross-compile triples, even inside the string
    // (the value is always a quoted triple, so completion is wanted there).
    if _manifest_line_field(doc.text, line0, col0).eq("target")
       && _manifest_in_value_slot(doc.text, line0, col0) {
        let titems: *JsonValue = json_array();
        _push_target_triples(titems);
        lsp_send_response(id, titems);
        return;
    }
    if _cursor_in_string_or_comment(doc.text, line0, col0) {
        lsp_send_response(id, json_array());
        return;
    }
    let items: *JsonValue = json_array();
    // After `Dep::` → the two dependency constructors.
    let q: string = path_qualifier_before(doc.text, line0, col0);
    if q.eq("Dep") {
        json_arr_push(items, completion_item("path", 3, "Dep::path(name, rel_path) — local path dependency"));
        json_arr_push(items, completion_item("git", 3, "Dep::git(name, url, rev) — git dependency"));
        lsp_send_response(id, items);
        return;
    }
    let ob: i32 = _manifest_open_offset(doc.text, line0, col0);
    let mut ctx: i32 = 0;
    if ob >= 0 {
        let oc: i32 = doc.text.at(ob).to_int();
        if oc == 123 { ctx = 1; } else if oc == 40 { ctx = 2; }
    }
    if ctx == 1 {
        // Inside `Package { }`. A value slot (after `field:`) only takes
        // `vec_of` for the deps list; everything else is a string literal.
        // Otherwise it's a field-name slot — offer only the fields that
        // aren't already written (progressive).
        if _manifest_in_value_slot(doc.text, line0, col0) {
            // Only `deps` takes a non-string value (`vec_of(...)`); the other
            // fields are string literals, so suggest nothing there.
            if _manifest_line_field(doc.text, line0, col0).eq("deps") {
                json_arr_push(items, completion_item("vec_of", 3, "vec_of(Dep::..., ...) — dependency list"));
            }
        } else {
            let present: *HashMap<bool> = HashMap::new();
            _manifest_collect_fields(doc.text, ob, present);
            _push_manifest_fields(items, present);
            present.free();
        }
    } else if ctx == 2 {
        // Inside `vec_of( )` — dependency entries.
        json_arr_push(items, completion_item("Dep::path", 3, "Dep::path(name, rel_path) — local path dependency"));
        json_arr_push(items, completion_item("Dep::git", 3, "Dep::git(name, url, rev) — git dependency"));
    } else {
        // Top level — the manifest literal + the dep-list helper.
        json_arr_push(items, completion_item("Package", 22, "package manifest — Package { name, version, ... }"));
        json_arr_push(items, completion_item("vec_of", 3, "vec_of(...) — dependency list"));
    }
    lsp_send_response(id, items);
}

fn handle_completion(req: *JsonValue, state: *LspState) {
    let id: *JsonValue = json_get(req, "id");
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    let pos: *JsonValue = json_get(params, "position");
    let line0: i32 = json_as_int(json_get(pos, "line"));
    let col0: i32 = json_as_int(json_get(pos, "character"));
    if !state.docs.contains(uri) { lsp_send_response(id, json_array()); return; }
    let doc: LspDoc = state.docs.get(uri);
    // The manifest (`glide.glide`) isn't a program — offer its fixed schema
    // (Package fields, vec_of, Dep::path/git) instead of generic symbols.
    if path_is_manifest(uri_to_path(uri)) {
        handle_manifest_completion(id, doc, line0, col0);
        return;
    }
    if doc.stmts == null {
        // The buffer doesn't parse into an AST yet — typically a half-typed
        // `let x: ` whose empty type trips the parser. The symbol-based
        // completion can't run, but if the cursor is in a type slot we can
        // still offer the primitive type names off the raw text, so type
        // completion works mid-edit instead of going silent.
        let it0: *JsonValue = json_array();
        let p0: i32 = cursor_before_partial(doc.text, line0, col0);
        if !_cursor_in_string_or_comment(doc.text, line0, col0) && _in_type_position(doc.text, p0) {
            let seen0: *HashMap<bool> = HashMap::new();
            _push_primitive_types(it0, seen0);
            seen0.free();
        }
        lsp_send_response(id, it0);
        return;
    }
    // Editors trigger completion on `.` / `:` even inside string and char
    // literals (Zed/VSCode don't know about Glide's lexer). Bail out before
    // we list anything — typing `"x.y"` should never offer field names.
    if _cursor_in_string_or_comment(doc.text, line0, col0) {
        lsp_send_response(id, json_array());
        return;
    }
    let items: *JsonValue = json_array();
    let seen: *HashMap<bool> = HashMap::new();

    // Type-annotation position (`: T`, `-> T`, `<T>`): seed the list with the
    // primitive type names + the enclosing fn/impl type params up front, so
    // they survive whichever branch handles (or early-returns) this request.
    // `_in_type_position` excludes `.` and `::`, so this never fires in member
    // or module-path context.
    let _tp_p: i32 = cursor_before_partial(doc.text, line0, col0);
    if _in_type_position(doc.text, _tp_p) {
        _push_primitive_types(items, seen);
        let tphost: *Stmt = fn_containing(doc.stmts, line0, uri_to_path(uri));
        if tphost != null && tphost.type_params != null {
            for let i: i32 = 0; i < tphost.type_params.len(); i++ {
                let tp: string = tphost.type_params.get(i);
                if tp == null || seen.contains(tp) { continue; }
                seen.insert(tp, true);
                json_arr_push(items, completion_item(tp, 25, "type parameter"));
            }
        }
    }

    // Import-path completion: cursor sits inside `import …;`. The
    // helper returns the module path the user has typed so far
    // ("", "stdlib", "stdlib::hashmap"); we list the matching child.
    let imp_kind: i32 = import_context_kind(doc.text, line0, col0);
    if imp_kind == IMPCTX_PATH {
        let prefix: string = import_path_prefix(doc.text, line0, col0);
        list_import_path_children(state, prefix, items, seen);
        seen.free();
        lsp_send_response(id, items);
        return;
    }
    if imp_kind == IMPCTX_BRACE {
        let mod_in_brace: string = import_brace_module(doc.text, line0, col0);
        if !mod_in_brace.eq("") {
            list_module_members(state, mod_in_brace, items, seen);
            seen.free();
            lsp_send_response(id, items);
            return;
        }
    }

    // Module-path completion: cursor right after `module::` or
    // `stdlib::module::`. Lists every `pub` symbol from that module.
    // Single-segment `stdlib::` lists the submodules instead.
    let mod_path: string = module_path_before(doc.text, line0, col0);
    if !mod_path.eq("") && state.stdlib_index != null {
        list_module_members(state, mod_path, items, seen);
        seen.free();
        lsp_send_response(id, items);
        return;
    }

    // Path completion: cursor is right after `Type::` (or `Type::partial`).
    let qualifier: string = path_qualifier_before(doc.text, line0, col0);
    if !qualifier.eq("") {
        // After `Type::` only static methods (no `self`) make sense.
        list_methods_for_type(doc.stmts, qualifier, items, seen, false);
        // 256-bit ints construct via `u256::from(n)` / `i256::from(n)`, which
        // are compiler builtins (no impl block), so surface them here.
        if (qualifier.eq("u256") || qualifier.eq("i256")) && !seen.contains("from") {
            seen.insert("from", true);
            json_arr_push(items, completion_item("from",
                3, qualifier.concat("::from(n) — build from an integer")));
        }
        // Every integer primitive exposes the `MAX` / `MIN` associated
        // constants (e.g. `i32::MAX`). Floats are excluded.
        if _is_canon_prim(qualifier) && !qualifier.eq("f32") && !qualifier.eq("f64") {
            if !seen.contains("MAX") {
                seen.insert("MAX", true);
                json_arr_push(items, completion_item("MAX", 21,
                    "largest value of ".concat(qualifier)));
            }
            if !seen.contains("MIN") {
                seen.insert("MIN", true);
                json_arr_push(items, completion_item("MIN", 21,
                    "smallest value of ".concat(qualifier)));
            }
        }
        seen.free();
        lsp_send_response(id, items);
        return;
    }

    // Member completion: cursor sits right after a `.`. Unified resolver
    // handles `var.`, `var.method(args).`, `Type::new().`, `expr.field.`,
    // `v[i].`, and arbitrary chains. The text-walker returns the receiver's
    // AST type so we can surface `!T`/`?T` virtual fields (ok/val/err,
    // has/val) the same way as struct fields. Always early-returns once
    // we know the cursor is in member position — never falls through to
    // bare-ident completion, which would dump every visible symbol.
    let _cursor_p: i32 = cursor_before_partial(doc.text, line0, col0);
    if _cursor_p >= 1 && doc.text.at(_cursor_p - 1).to_int() == 46 {
        let recv_ty: *Type = _chain_resolve_type(doc.text, _cursor_p - 1, doc.stmts, line0, uri_to_path(uri));
        if recv_ty != null {
            // List members off the PRE-expansion snapshot: expand_macros
            // consumes type-attached `macro` defs out of doc.stmts, so the
            // post-expansion set has the fns but not the macros. pre_expand
            // still carries them, so `v.push_a` can offer `push_all!`.
            let mut mstmts: *Vector<Stmt> = doc.stmts;
            if doc.pre_expand_stmts != null { mstmts = doc.pre_expand_stmts; }
            _list_members_for_type_node(recv_ty, mstmts, items, seen);
        }
        seen.free();
        lsp_send_response(id, items);
        return;
    }
    // Stray `::` with no resolvable type before it: empty list, never the
    // dump-every-global fallback. `path_qualifier_before` already handles
    // the happy path; this is the safety net.
    if _cursor_p >= 2 && doc.text.at(_cursor_p - 1).to_int() == 58
       && doc.text.at(_cursor_p - 2).to_int() == 58 {
        seen.free();
        lsp_send_response(id, items);
        return;
    }

    // Attribute context. Cursor sits inside `@<partial>` (declaration-side
    // proc-attr) or inside `@derive(<partial>)` (derive list). Surface
    // proc-attrs / proc-derives + the handful of built-in attribute names
    // the compiler recognises (`cfg`, `expect`, `allow`, `deprecated`,
    // `lint`, `proc_attr`, `proc_derive`, `proc_macro`, `proc_macro_str`).
    let _attr_ctx: i32 = _attribute_context(doc.text, _cursor_p);
    if _attr_ctx != 0 {
        if _attr_ctx == 1 {
            // After `@` — bare attribute name.
            _push_attr_completions(doc, state, items, seen);
        } else {
            // Inside `@derive(...)` — derive list.
            _push_derive_completions(doc, state, items, seen);
        }
        seen.free();
        lsp_send_response(id, items);
        return;
    }

    // 1. Locals in scope (params + lets above the cursor in the containing fn).
    let host: *Stmt = fn_containing(doc.stmts, line0, uri_to_path(uri));
    if host != null {
        if host.fn_params != null {
            for let i: i32 = 0; i < host.fn_params.len(); i++ {
                let p: Param = host.fn_params.get(i);
                if !seen.contains(p.name) {
                    seen.insert(p.name, true);
                    let sig: string = "param ".concat(p.name).concat(": ").concat(type_to_string_pretty(p.ty));
                    let no_edit_p: *JsonValue = null;
                    let item: *JsonValue = rich_completion_item(
                        p.name, "", 6, sig, "", "", "", false, no_edit_p);
                    json_arr_push(items, item);
                }
            }
        }
        // Closure params from any enclosing closure whose body covers the cursor.
        let cps: *Vector<Param> = Vector::new();
        collect_active_closure_params(host.fn_body, line0, cps);
        for let i: i32 = 0; i < cps.len(); i++ {
            let p: Param = cps.get(i);
            if p.name == null || seen.contains(p.name) { continue; }
            seen.insert(p.name, true);
            let sig: string = "param ".concat(p.name).concat(": ").concat(type_to_string_pretty(p.ty));
            let no_edit_cp: *JsonValue = null;
            let item: *JsonValue = rich_completion_item(
                p.name, "", 6, sig, "", "", "", false, no_edit_cp);
            json_arr_push(items, item);
        }
        let locals: *Vector<Stmt> = Vector::new();
        collect_locals(host.fn_body, line0, locals);
        for let i: i32 = 0; i < locals.len(); i++ {
            let s: Stmt = locals.get(i);
            if seen.contains(s.name) { continue; }
            seen.insert(s.name, true);
            let mut sig: string = "local ".concat(s.name);
            if s.let_ty != null {
                sig = "let ".concat(s.name).concat(": ").concat(type_to_string_pretty(s.let_ty));
            } else if s.let_value != null {
                // No annotation — infer the type for the hint, same as
                // member completion: `Type::ctor()` / plain fn-call returns
                // (_let_node_type), falling back to literals/idents
                // (lsp_infer_expr). So `let v = ret()` shows `*Vector<int>`.
                let mut inferred: *Type = _let_node_type(&s, doc.stmts);
                if inferred == null { inferred = lsp_infer_expr(doc.stmts, host, s.let_value); }
                if inferred != null {
                    sig = "let ".concat(s.name).concat(": ").concat(type_to_string_pretty(inferred));
                }
            }
            let no_edit_l: *JsonValue = null;
            let item: *JsonValue = rich_completion_item(
                s.name, "", 6, sig, "", "", "", false, no_edit_l);
            json_arr_push(items, item);
        }
    }

    // Primitive type names (i32, u256, …) are valid in both type and
    // expression position (annotations, `u256::from(n)`, casts), and the
    // type-position branch above only seeds them when the cursor is clearly
    // in a type slot. Offer them here too so a bare prefix completes (`i3`
    // → `i32`); the editor filters by what's typed. Idempotent via `seen`.
    _push_primitive_types(items, seen);

    // 2. Top-level decls (incl. static macros). Decls from stdlib that
    // were transitively loaded by an existing import still get a
    // build_import_edit pass so that selective imports are merged
    // (`{PI}` → `{PI, min_int}`) when the user picks a name that's
    // not yet listed.
    let imps2: *HashMap<ImportInfo> = current_imports(doc.text);
    let insert_line2: i32 = find_import_insertion_pos(doc.text);
    if doc.stmts != null {
        for let i: i32 = 0; i < doc.stmts.len(); i++ {
            let s: Stmt = doc.stmts.get(i);
            if s.kind != ST_FN && s.kind != ST_STRUCT && s.kind != ST_ENUM
               && s.kind != ST_CONST && s.kind != ST_MACRO_DEF { continue; }
            if s.name == null { continue; }
            // Hide compiler-internal symbols (`__glide_*`, `__rt_*`, leading
            // `_` privates). Users never call these directly; surfacing them
            // bloats the completion list with C-runtime plumbing.
            if s.name.len() >= 2 && s.name.at(0).to_int() == 95 { continue; }
            // Static macros are inserted as `name!` to get the bang for free.
            let mut label: string = s.name;
            if s.kind == ST_MACRO_DEF { label = s.name.concat("!"); }
            if seen.contains(label) { continue; }
            seen.insert(label, true);
            let mut sig: string = "";
            let mut label_extra: string = "";
            let mut snip: string = label;
            let mut has_snip: bool = false;
            if s.kind == ST_FN {
                sig = fn_signature(&s);
                label_extra = fn_label_extra(&s);
                snip = fn_snippet(&s);
                has_snip = true;
            }
            else if s.kind == ST_STRUCT { sig = "struct ".concat(s.name); }
            else if s.kind == ST_ENUM { sig = "enum ".concat(s.name); }
            else if s.kind == ST_CONST {
                sig = "const ".concat(s.name);
                if s.let_ty != null { sig = sig.concat(": ").concat(type_to_string_pretty(s.let_ty)); }
            }
            else if s.kind == ST_MACRO_DEF { sig = macro_signature(&s); }
            let mut module: string = "";
            if s.origin != null { module = pretty_module(s.origin); }
            let mut docc: string = "";
            if s.doc_comment != null { docc = s.doc_comment; }
            // For stdlib items reached via an existing import, ask
            // build_import_edit whether a selective merge is needed.
            // Builtins / own-doc decls always pass null.
            let mut decl_edit: *JsonValue = null;
            if module.len() >= 8 && module.substring(0, 8).eq("stdlib::") {
                let mut existing: *ImportInfo = null;
                if imps2.contains(module) {
                    let info_val: ImportInfo = imps2.get(module);
                    existing = malloc(sizeof(ImportInfo)) as *ImportInfo;
                    *existing = info_val;
                }
                decl_edit = build_import_edit(label, module, existing, insert_line2, false);
            }
            let item: *JsonValue = rich_completion_item(
                label, label_extra, ci_kind_for(&s),
                sig, docc, module, snip, has_snip,
                decl_edit);
            json_arr_push(items, item);
        }
    }

    // 2b. Builtin macros.
    let builtins: *Vector<string> = Vector::new();
    builtins.push("println!"); builtins.push("print!"); builtins.push("format!");
    for let i: i32 = 0; i < builtins.len(); i++ {
        let bn: string = builtins.get(i);
        if seen.contains(bn) { continue; }
        seen.insert(bn, true);
        let mut bdetail: string = "builtin macro";
        if bn.eq("println!") { bdetail = "println!(args...) — print + newline"; }
        else if bn.eq("print!") { bdetail = "print!(args...) — print, no newline"; }
        else if bn.eq("format!") { bdetail = "format!(\"fmt\", args...) — formatted string"; }
        json_arr_push(items, completion_item(bn, 2, bdetail));
    }

    // 2c. User + stdlib macros harvested before expand_macros consumed
    // them. Surface as `name!`. Doc.macro_defs covers free macros
    // (`assert!`, `bail!`, etc); proc_macros covers `@proc_macro(foo)`
    // fns invoked as `foo!(...)`.
    if doc.macro_defs != null {
        for let i: i32 = 0; i < doc.macro_defs.len(); i++ {
            let md: Stmt = doc.macro_defs.get(i);
            if md.name == null { continue; }
            if md.name.len() >= 1 && md.name.at(0).to_int() == 95 { continue; }
            let mlabel: string = md.name.concat("!");
            if seen.contains(mlabel) { continue; }
            seen.insert(mlabel, true);
            json_arr_push(items, completion_item(mlabel, 2, macro_signature(&md)));
        }
    }
    if doc.proc_macros != null {
        for let i: i32 = 0; i < doc.proc_macros.len(); i++ {
            let pn: string = doc.proc_macros.get(i);
            let plabel: string = pn.concat("!");
            if seen.contains(plabel) { continue; }
            seen.insert(plabel, true);
            json_arr_push(items, completion_item(plabel, 2, "proc-macro"));
        }
    }

    // 3. Auto-import suggestions: surface every `pub` symbol from
    // src/stdlib/ that the user hasn't imported yet. Each item carries
    // labelDetails + documentation (markdown) + a snippet (for fns) +
    // a precise additionalTextEdit:
    //   - existing wildcard / bare / matching selective → no edit
    //   - existing selective without the name → splice `, name` before `}`
    //   - no existing import → insert
    //       `import stdlib::X::{name};\n` (selective)
    //       or `import stdlib::X;\n` for Module entries
    if state.stdlib_index != null && state.stdlib_index.len() > 0 {
        let imps: *HashMap<ImportInfo> = current_imports(doc.text);
        let insert_line: i32 = find_import_insertion_pos(doc.text);
        _emit_index_items(state.stdlib_index, imps, insert_line, items, seen);
        if state.project_index != null {
            _emit_index_items(state.project_index, imps, insert_line, items, seen);
        }
        imps.free();
    }

    // 4. Glide keywords.
    // (helper for the bare-ident loop above lives below `handle_completion`)
    let kws: *Vector<string> = Vector::new();
    kws.push("let"); kws.push("const"); kws.push("mut"); kws.push("fn");
    kws.push("struct"); kws.push("enum"); kws.push("impl"); kws.push("interface");
    kws.push("trait"); kws.push("dyn"); kws.push("Self"); kws.push("in");
    kws.push("if"); kws.push("else"); kws.push("while"); kws.push("for");
    kws.push("return"); kws.push("break"); kws.push("continue");
    kws.push("match"); kws.push("defer"); kws.push("defer_err");
    kws.push("spawn"); kws.push("import");
    kws.push("pub"); kws.push("extern"); kws.push("true"); kws.push("false"); kws.push("null");
    kws.push("as"); kws.push("sizeof"); kws.push("type"); kws.push("move"); kws.push("chan");
    kws.push("naked"); kws.push("asm"); kws.push("volatile");
    kws.push("c_raw"); kws.push("macro"); kws.push("select");
    for let i: i32 = 0; i < kws.len(); i++ {
        let k: string = kws.get(i);
        if seen.contains(k) { continue; }
        seen.insert(k, true);
        json_arr_push(items, completion_item(k, 14, ""));
    }

    seen.free();
    lsp_send_response(id, items);
}

// Push completion items for every symbol in `idx` that isn't already
// in `seen`. Reused for the bare-ident path across both stdlib and
// project indexes.
fn _emit_index_items(idx: *Vector<ImportableSym>, imps: *HashMap<ImportInfo>,
                     insert_line: i32, items: *JsonValue,
                     seen: *HashMap<bool>) {
    let n: i32 = idx.len();
    for let i: i32 = 0; i < n; i++ {
        let sym: ImportableSym = idx.get(i);
        if sym.name == null { continue; }
        // Proc-attrs / proc-derives surface only under `@<...>` /
        // `@derive(...)` contexts, not in the bare-ident suggestion bag.
        // Free macros appear here as `name!` (so `assert` typed at top
        // level offers `assert!` with auto-import).
        // Proc-attrs / proc-derives surface only under `@<...>` /
        // `@derive(...)` contexts, not in the bare-ident bag. Function-like
        // proc-macros (`info!`, `routes!`) DO belong here — surfaced as
        // `name!` so typing `info` offers `info!` with an auto-import.
        if sym.kind == SYMKIND_PROC_ATTR || sym.kind == SYMKIND_PROC_DERIVE { continue; }
        let mut label: string = sym.name;
        let mut imp_module: string = sym.module;
        if sym.kind == ST_MACRO_DEF { label = sym.name.concat("!"); }
        if sym.kind == SYMKIND_PROC_MACRO {
            label = sym.name.concat("!");
            // The defining file is conventionally `X_macros`, re-exported by
            // the base module `X` (which also carries the fns the macro
            // expands to). Steer the auto-import at `X`, not the macro lib.
            let ml: i32 = imp_module.len();
            if ml > 7 && imp_module.substring(ml - 7, ml).eq("_macros") {
                imp_module = imp_module.substring(0, ml - 7);
            }
        }
        if seen.contains(label) { continue; }
        seen.insert(label, true);
        let mut existing: *ImportInfo = null;
        if imps.contains(imp_module) {
            let info_val: ImportInfo = imps.get(imp_module);
            existing = malloc(sizeof(ImportInfo)) as *ImportInfo;
            *existing = info_val;
        }
        let is_module: bool = (sym.kind == SYMKIND_MODULE);
        let edit: *JsonValue = build_import_edit(
            sym.name, imp_module, existing, insert_line, is_module);
        let item: *JsonValue = rich_completion_item(
            label, sym.label_extra, ci_kind_for_stmt_kind(sym.kind),
            sym.signature, sym.doc, imp_module,
            sym.snippet, sym.has_snippet, edit);
        json_arr_push(items, item);
    }
}

// Walks the program collecting every usage of `name` as an identifier.
// Returns a list of (line, col) pairs, 1-indexed.
struct UseSite { line: i32, col: i32 }

fn collect_uses_in_expr(e: *Expr, name: string, out: *Vector<UseSite>) {
    if e == null { return; }
    // Synthesised exprs (line == 0) don't map to a position in the user's
    // file — surfacing them as highlights anchored at (0, 0) makes the
    // editor light up column 0 of line 1 on every hover. Recurse into
    // children but never emit a hit ourselves.
    let has_pos: bool = e.line > 0;
    if has_pos && e.kind == EX_IDENT && e.str_val.eq(name) {
        let u: UseSite = UseSite { line: e.line, col: e.column };
        out.push(u);
    }
    if has_pos && e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_PATH
       && e.lhs.str_val.eq(name) {
        let u: UseSite = UseSite { line: e.line, col: e.column };
        out.push(u);
    }
    // `Type::method` outside an EX_CALL (function-pointer slot, enum
    // variant ctor, ...). Without this `Router::new` typed standalone
    // doesn't highlight.
    if has_pos && e.kind == EX_PATH {
        if e.str_val != null && e.str_val.eq(name) {
            let u: UseSite = UseSite { line: e.line, col: e.column };
            out.push(u);
        }
        if e.field != null && e.field.eq(name) {
            let u: UseSite = UseSite { line: e.line, col: e.column };
            out.push(u);
        }
    }
    // `recv.field` / `recv.method(...)` — member name itself.
    if has_pos && e.kind == EX_MEMBER && e.field != null && e.field.eq(name) {
        let u: UseSite = UseSite { line: e.line, col: e.column };
        out.push(u);
    }
    // `Foo { a: ..., b: ... }` — struct literal type + field names.
    if has_pos && e.kind == EX_STRUCT_LIT && e.str_val != null && e.str_val.eq(name) {
        let u: UseSite = UseSite { line: e.line, col: e.column };
        out.push(u);
    }
    // `expr as *Foo` / `sizeof(Foo)` — type names in cast / sizeof slots.
    if (e.kind == EX_CAST || e.kind == EX_SIZEOF) && e.cast_to != null {
        _collect_type_uses(e.cast_to, name, out, e.line, e.column);
    }
    // Closure params + their annotations + body.
    if e.kind == EX_FNEXPR {
        if e.fn_expr_params != null {
            for let i: i32 = 0; i < e.fn_expr_params.len(); i++ {
                let p: Param = e.fn_expr_params.get(i);
                if p.name != null && p.name.eq(name) {
                    let u: UseSite = UseSite { line: e.line, col: e.column };
                    out.push(u);
                }
                _collect_type_uses(p.ty, name, out, e.line, e.column);
            }
        }
        _collect_type_uses(e.cast_to, name, out, e.line, e.column);
        if e.fn_expr_body != null {
            for let i: i32 = 0; i < e.fn_expr_body.len(); i++ {
                let bs: Stmt = e.fn_expr_body.get(i);
                collect_uses_in_stmt(&bs, name, out);
            }
        }
    }
    if e.lhs != null { collect_uses_in_expr(e.lhs, name, out); }
    if e.rhs != null { collect_uses_in_expr(e.rhs, name, out); }
    if e.operand != null { collect_uses_in_expr(e.operand, name, out); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            collect_uses_in_expr(&a, name, out);
        }
    }
}

// Walk a type tree, recording an occurrence of `name` at the carrier
// position (`carrier_line`/`carrier_col`) for every TY_NAMED /
// TY_GENERIC whose name matches. We don't have per-segment positions
// inside type nodes, so highlights anchor at the enclosing
// declaration's position — close enough to be useful and never
// wrong-file. Skip when the carrier has no position (line == 0):
// those come from synthesised stmts (proc-macro outputs, etc.) and
// would dump bogus (0,0) highlights all over the file.
fn _collect_type_uses(t: *Type, name: string, out: *Vector<UseSite>, carrier_line: i32, carrier_col: i32) {
    if t == null { return; }
    if carrier_line == 0 { return; }
    if t.kind == TY_NAMED && t.name != null && t.name.eq(name) {
        let u: UseSite = UseSite { line: carrier_line, col: carrier_col };
        out.push(u);
    }
    if t.kind == TY_GENERIC && t.name != null && t.name.eq(name) {
        let u: UseSite = UseSite { line: carrier_line, col: carrier_col };
        out.push(u);
    }
    if t.inner != null { _collect_type_uses(t.inner, name, out, carrier_line, carrier_col); }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            _collect_type_uses(&a, name, out, carrier_line, carrier_col);
        }
    }
    if t.fnptr_ret != null { _collect_type_uses(t.fnptr_ret, name, out, carrier_line, carrier_col); }
}

fn collect_uses_in_stmt(s: *Stmt, name: string, out: *Vector<UseSite>) {
    if s == null { return; }
    // Declaration site of fn / struct / enum / const / let / trait / macro
    // — anchor at the name position so highlight / find-refs land on the
    // identifier itself, not the leading `let` / `fn` / `struct` keyword.
    if (s.kind == ST_FN || s.kind == ST_STRUCT || s.kind == ST_ENUM
        || s.kind == ST_CONST || s.kind == ST_TRAIT || s.kind == ST_MACRO_DEF)
       && s.name != null && s.name.eq(name) {
        let mut nl: i32 = s.name_line; let mut nc: i32 = s.name_col;
        if nl == 0 { nl = s.line; nc = s.column; }
        let u: UseSite = UseSite { line: nl, col: nc };
        out.push(u);
    }
    if s.kind == ST_LET && s.name != null && s.name.eq(name) {
        let mut nl: i32 = s.name_line; let mut nc: i32 = s.name_col;
        if nl == 0 { nl = s.line; nc = s.column; }
        let u: UseSite = UseSite { line: nl, col: nc };
        out.push(u);
    }
    // Type annotations: `let r: *Router`, `fn(req: *HttpRequest) -> Json<Res>`,
    // `struct Foo { f: T }`, `impl Foo`. Anchor at the stmt's own line/col
    // since fields/params/types don't carry their own positions.
    _collect_type_uses(s.let_ty, name, out, s.line, s.column);
    _collect_type_uses(s.fn_ret_ty, name, out, s.line, s.column);
    _collect_type_uses(s.impl_target, name, out, s.line, s.column);
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            if p.name != null && p.name.eq(name) {
                let mut nl: i32 = p.name_line; let mut nc: i32 = p.name_col;
                if nl == 0 { nl = s.line; nc = s.column; }
                if nl > 0 {
                    let u: UseSite = UseSite { line: nl, col: nc };
                    out.push(u);
                }
            }
            // Prefer the param's own position (closer to where the type
            // is written) over the fn-stmt's. Falls back to the stmt if
            // the param has no position info.
            let mut tl: i32 = p.name_line; let mut tc: i32 = p.name_col;
            if tl == 0 { tl = s.line; tc = s.column; }
            _collect_type_uses(p.ty, name, out, tl, tc);
        }
    }
    if s.struct_fields != null {
        for let i: i32 = 0; i < s.struct_fields.len(); i++ {
            let f: Field = s.struct_fields.get(i);
            if f.name != null && f.name.eq(name) {
                let u: UseSite = UseSite { line: s.line, col: s.column };
                out.push(u);
            }
            _collect_type_uses(f.ty, name, out, s.line, s.column);
        }
    }
    // `@derive(Name)`, `@expect("code")`, `@Name`, etc — pick up the
    // attribute args. Without this `@derive(JsonBind)` doesn't highlight
    // JsonBind.
    if s.attrs != null {
        for let i: i32 = 0; i < s.attrs.len(); i++ {
            let a: Attr = s.attrs.get(i);
            if a.args == null { continue; }
            for let j: i32 = 0; j < a.args.len(); j++ {
                let ae: Expr = a.args.get(j);
                collect_uses_in_expr(&ae, name, out);
            }
        }
    }
    if s.let_value != null { collect_uses_in_expr(s.let_value, name, out); }
    if s.expr_value != null { collect_uses_in_expr(s.expr_value, name, out); }
    if s.cond != null { collect_uses_in_expr(s.cond, name, out); }
    if s.for_step != null { collect_uses_in_expr(s.for_step, name, out); }
    if s.scrutinee != null { collect_uses_in_expr(s.scrutinee, name, out); }
    if s.for_init != null { collect_uses_in_stmt(s.for_init, name, out); }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            collect_uses_in_stmt(&b, name, out);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            collect_uses_in_stmt(&b, name, out);
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            collect_uses_in_stmt(&b, name, out);
        }
    }
    if s.impl_methods != null {
        for let i: i32 = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            collect_uses_in_stmt(&m, name, out);
        }
    }
    if s.arms != null {
        for let i: i32 = 0; i < s.arms.len(); i++ {
            let a: MatchArm = s.arms.get(i);
            if a.body != null {
                for let j: i32 = 0; j < a.body.len(); j++ {
                    let b: Stmt = a.body.get(j);
                    collect_uses_in_stmt(&b, name, out);
                }
            }
        }
    }
}

fn use_to_range(u: *UseSite, name_len: i32) -> *JsonValue {
    let r: *JsonValue = json_object();
    let mut l: i32 = u.line - 1; if l < 0 { l = 0; }
    let mut c: i32 = u.col - 1; if c < 0 { c = 0; }
    let s: *JsonValue = json_object();
    json_obj_set(s, "line", json_int(l));
    json_obj_set(s, "character", json_int(c));
    let e: *JsonValue = json_object();
    json_obj_set(e, "line", json_int(l));
    json_obj_set(e, "character", json_int(c + name_len));
    json_obj_set(r, "start", s);
    json_obj_set(r, "end", e);
    return r;
}

fn handle_references(req: *JsonValue, state: *LspState) {
    let id: *JsonValue = json_get(req, "id");
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    let pos: *JsonValue = json_get(params, "position");
    let line0: i32 = json_as_int(json_get(pos, "line"));
    let col0: i32 = json_as_int(json_get(pos, "character"));
    if !state.docs.contains(uri) { lsp_send_response(id, json_array()); return; }
    let doc: LspDoc = state.docs.get(uri);
    let path: string = uri_to_path(uri);
    let word: string = word_at(doc.text, line0, col0);
    if word.eq("") { lsp_send_response(id, json_array()); return; }
    let uses: *Vector<UseSite> = Vector::new();
    if doc.stmts != null {
        for let i: i32 = 0; i < doc.stmts.len(); i++ {
            let s: Stmt = doc.stmts.get(i);
            if !s.origin.eq("") && !s.origin.eq(path) { continue; }
            collect_uses_in_stmt(&s, word, uses);
        }
    }
    let arr: *JsonValue = json_array();
    for let i: i32 = 0; i < uses.len(); i++ {
        let u: UseSite = uses.get(i);
        if u.line <= 0 { continue; }
        let loc: *JsonValue = json_object();
        json_obj_set(loc, "uri", json_string(uri));
        json_obj_set(loc, "range", use_to_range(&u, word.len()));
        json_arr_push(arr, loc);
    }
    lsp_send_response(id, arr);
}

fn handle_document_highlight(req: *JsonValue, state: *LspState) {
    let id: *JsonValue = json_get(req, "id");
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    let pos: *JsonValue = json_get(params, "position");
    let line0: i32 = json_as_int(json_get(pos, "line"));
    let col0: i32 = json_as_int(json_get(pos, "character"));
    if !state.docs.contains(uri) { lsp_send_response(id, json_array()); return; }
    let doc: LspDoc = state.docs.get(uri);
    let path: string = uri_to_path(uri);
    let word: string = word_at(doc.text, line0, col0);
    if word.eq("") { lsp_send_response(id, json_array()); return; }
    let uses: *Vector<UseSite> = Vector::new();
    if doc.stmts != null {
        for let i: i32 = 0; i < doc.stmts.len(); i++ {
            let s: Stmt = doc.stmts.get(i);
            if !s.origin.eq("") && !s.origin.eq(path) { continue; }
            collect_uses_in_stmt(&s, word, uses);
        }
    }
    let arr: *JsonValue = json_array();
    for let i: i32 = 0; i < uses.len(); i++ {
        let u: UseSite = uses.get(i);
        // Drop synthesised hits (line == 0). They come from proc-macro
        // outputs or other compiler-injected stmts and would highlight
        // column 0 of line 1 with no real text underneath.
        if u.line <= 0 { continue; }
        let h: *JsonValue = json_object();
        json_obj_set(h, "range", use_to_range(&u, word.len()));
        json_obj_set(h, "kind", json_int(1));     // 1 = Text (read), 2 = Read, 3 = Write
        json_arr_push(arr, h);
    }
    lsp_send_response(id, arr);
}

fn handle_rename(req: *JsonValue, state: *LspState) {
    let id: *JsonValue = json_get(req, "id");
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    let pos: *JsonValue = json_get(params, "position");
    let line0: i32 = json_as_int(json_get(pos, "line"));
    let col0: i32 = json_as_int(json_get(pos, "character"));
    let new_name: string = json_as_string(json_get(params, "newName"));
    if !state.docs.contains(uri) || new_name.eq("") {
        lsp_send_response(id, json_null()); return;
    }
    let doc: LspDoc = state.docs.get(uri);
    let path: string = uri_to_path(uri);
    let word: string = word_at(doc.text, line0, col0);
    if word.eq("") { lsp_send_response(id, json_null()); return; }
    let uses: *Vector<UseSite> = Vector::new();
    if doc.stmts != null {
        for let i: i32 = 0; i < doc.stmts.len(); i++ {
            let s: Stmt = doc.stmts.get(i);
            if !s.origin.eq("") && !s.origin.eq(path) { continue; }
            collect_uses_in_stmt(&s, word, uses);
        }
    }
    let edits: *JsonValue = json_array();
    for let i: i32 = 0; i < uses.len(); i++ {
        let u: UseSite = uses.get(i);
        // Skip synthesised hits — renaming would otherwise insert at
        // (0,0), which the editor applies as an actual file edit.
        if u.line <= 0 { continue; }
        let edit: *JsonValue = json_object();
        json_obj_set(edit, "range", use_to_range(&u, word.len()));
        json_obj_set(edit, "newText", json_string(new_name));
        json_arr_push(edits, edit);
    }
    let changes: *JsonValue = json_object();
    json_obj_set(changes, uri, edits);
    let result: *JsonValue = json_object();
    json_obj_set(result, "changes", changes);
    lsp_send_response(id, result);
}

// `prepareRename` — validates that the cursor sits on something renameable.
// Returns `{ range, placeholder }` so the editor knows what range to
// highlight while the user types the new name. Refuses keywords, literals,
// and empty selections.
fn handle_prepare_rename(req: *JsonValue, state: *LspState) {
    let id: *JsonValue = json_get(req, "id");
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    let pos: *JsonValue = json_get(params, "position");
    let line0: i32 = json_as_int(json_get(pos, "line"));
    let col0: i32 = json_as_int(json_get(pos, "character"));
    if !state.docs.contains(uri) { lsp_send_response(id, json_null()); return; }
    let doc: LspDoc = state.docs.get(uri);
    let word: string = word_at(doc.text, line0, col0);
    if word.eq("") { lsp_send_response(id, json_null()); return; }
    if is_glide_keyword(word) { lsp_send_response(id, json_null()); return; }

    // Build the exact range covering the word at the cursor.
    let lex: *Lexer = Lexer::new(doc.text);
    while true {
        let tok: Token = lex.next_token();
        if tok.kind == TOK_EOF { break; }
        if tok.kind != TOK_IDENT { continue; }
        let tline: i32 = tok.line - 1;
        let tcol: i32 = tok.column - 1;
        let len: i32 = tok.lexeme.len();
        if tline == line0 && col0 >= tcol && col0 <= tcol + len {
            let range: *JsonValue = json_object();
            let start: *JsonValue = json_object();
            let endp: *JsonValue = json_object();
            json_obj_set(start, "line", json_int(tline));
            json_obj_set(start, "character", json_int(tcol));
            json_obj_set(endp,  "line", json_int(tline));
            json_obj_set(endp,  "character", json_int(tcol + len));
            json_obj_set(range, "start", start);
            json_obj_set(range, "end", endp);
            let result: *JsonValue = json_object();
            json_obj_set(result, "range", range);
            json_obj_set(result, "placeholder", json_string(word));
            lsp_send_response(id, result);
            return;
        }
    }
    lsp_send_response(id, json_null());
}

// Reject rename of language keywords. Mirrors the lexer's reserved set.
fn is_glide_keyword(w: string) -> bool {
    if w.eq("fn") { return true; } if w.eq("let") { return true; }
    if w.eq("mut") { return true; } if w.eq("const") { return true; }
    if w.eq("struct") { return true; } if w.eq("enum") { return true; }
    if w.eq("trait") { return true; } if w.eq("impl") { return true; }
    if w.eq("import") { return true; } if w.eq("pub") { return true; }
    if w.eq("if") { return true; } if w.eq("else") { return true; }
    if w.eq("while") { return true; } if w.eq("for") { return true; }
    if w.eq("return") { return true; } if w.eq("spawn") { return true; }
    if w.eq("defer") { return true; } if w.eq("match") { return true; }
    if w.eq("break") { return true; } if w.eq("continue") { return true; }
    if w.eq("as") { return true; } if w.eq("sizeof") { return true; }
    if w.eq("new") { return true; } if w.eq("move") { return true; }
    if w.eq("type") { return true; } if w.eq("extern") { return true; }
    if w.eq("c_include") { return true; } if w.eq("c_link") { return true; }
    if w.eq("c_raw") { return true; } if w.eq("macro") { return true; }
    if w.eq("naked") { return true; } if w.eq("asm") { return true; }
    if w.eq("volatile") { return true; } if w.eq("dyn") { return true; }
    if w.eq("Self") { return true; } if w.eq("in") { return true; }
    if w.eq("chan") { return true; } if w.eq("true") { return true; }
    if w.eq("false") { return true; } if w.eq("null") { return true; }
    if w.eq("defer_err") { return true; } if w.eq("select") { return true; }
    if w.eq("trait") { return true; } if w.eq("interface") { return true; }
    return false;
}

fn count_lines(s: string) -> i32 {
    let mut n: i32 = 0;
    let len: i32 = s.len();
    for let i: i32 = 0; i < len; i++ {
        if s.at(i).to_int() == 10 { n = n + 1; }
    }
    return n;
}

fn handle_formatting(req: *JsonValue, state: *LspState) {
    let id: *JsonValue = json_get(req, "id");
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    if !state.docs.contains(uri) { lsp_send_response(id, json_array()); return; }
    let doc: LspDoc = state.docs.get(uri);
    // Re-parse from text in case stmts is stale.
    let lex: *Lexer = Lexer::new(doc.text);
    let p: *Parser = Parser::new(lex);
    let parsed: *Vector<Stmt> = parse_program(p);
    let formatted: string = fmt_program(parsed);
    // Return a single TextEdit replacing the whole document.
    let lines: i32 = count_lines(doc.text) + 2;
    let edit: *JsonValue = json_object();
    let range: *JsonValue = json_object();
    let start: *JsonValue = json_object();
    let endp: *JsonValue = json_object();
    json_obj_set(start, "line", json_int(0));
    json_obj_set(start, "character", json_int(0));
    json_obj_set(endp, "line", json_int(lines));
    json_obj_set(endp, "character", json_int(0));
    json_obj_set(range, "start", start);
    json_obj_set(range, "end", endp);
    json_obj_set(edit, "range", range);
    json_obj_set(edit, "newText", json_string(formatted));
    let arr: *JsonValue = json_array();
    json_arr_push(arr, edit);
    lsp_send_response(id, arr);
}

// `textDocument/codeAction` — read `context.diagnostics` from the
// request, look at each entry's `data.fix` field (set by us in
// `diag_to_json`), and synthesize a CodeAction with a WorkspaceEdit
// that applies the replacement. No re-analysis needed: the editor
// hands back the diagnostic objects we published, including the
// `data` blob.
fn handle_code_action(req: *JsonValue, state: *LspState) {
    let id: *JsonValue = json_get(req, "id");
    let params: *JsonValue = json_get(req, "params");
    let td: *JsonValue = json_get(params, "textDocument");
    let uri: string = json_as_string(json_get(td, "uri"));
    let ctx: *JsonValue = json_get(params, "context");
    let diags: *JsonValue = json_get(ctx, "diagnostics");

    let out: *JsonValue = json_array();
    let n: i32 = _json_arr_len(diags);
    _lsp_log("  codeAction: ".concat(int_to_str(n)).concat(" diags"));
    if n == 0 {
        lsp_send_response(id, out);
        return;
    }
    for let i: i32 = 0; i < n; i++ {
        let d: *JsonValue = json_at(diags, i);
        let data: *JsonValue = json_get(d, "data");
        if data == null { continue; }
        let fix: *JsonValue = json_get(data, "fix");
        if fix == null { continue; }
        let new_text: string = json_as_string(json_get(fix, "newText"));
        let fr: *JsonValue = json_get(fix, "range");
        if fr == null { continue; }

        // Pull positions out as ints + rebuild fresh JsonValue trees
        // for the response. We can't share JsonValue subtrees with
        // the incoming request: lsp_send_response calls json_free on
        // the whole reply, which would walk into the shared Vector
        // pointers and clobber memory the request handler still
        // tries to free on dispatch teardown.
        let fr_start: *JsonValue = json_get(fr, "start");
        let fr_end:   *JsonValue = json_get(fr, "end");
        let sl: i32 = json_as_int(json_get(fr_start, "line"));
        let sc: i32 = json_as_int(json_get(fr_start, "character"));
        let el: i32 = json_as_int(json_get(fr_end,   "line"));
        let ec: i32 = json_as_int(json_get(fr_end,   "character"));

        let code: string = json_as_string(json_get(d, "code"));

        let action: *JsonValue = json_object();
        let title: string = _code_action_title(code, new_text);
        json_obj_set(action, "title", json_string(title));
        json_obj_set(action, "kind", json_string("quickfix"));

        // Build the WorkspaceEdit { changes: { uri: [TextEdit] } }
        // with a freshly-allocated range so we don't alias the
        // request's JsonValues.
        let edit: *JsonValue = json_object();
        let changes: *JsonValue = json_object();
        let edits: *JsonValue = json_array();
        let te: *JsonValue = json_object();
        let r: *JsonValue = json_object();
        let s_obj: *JsonValue = json_object();
        let e_obj: *JsonValue = json_object();
        json_obj_set(s_obj, "line", json_int(sl));
        json_obj_set(s_obj, "character", json_int(sc));
        json_obj_set(e_obj, "line", json_int(el));
        json_obj_set(e_obj, "character", json_int(ec));
        json_obj_set(r, "start", s_obj);
        json_obj_set(r, "end", e_obj);
        json_obj_set(te, "range", r);
        json_obj_set(te, "newText", json_string(new_text));
        json_arr_push(edits, te);
        json_obj_set(changes, uri, edits);
        json_obj_set(edit, "changes", changes);
        json_obj_set(action, "edit", edit);
        json_arr_push(out, action);

        // Free the wrappers we allocated via json_get / json_at for
        // the incoming data; their inner Vectors are owned by the
        // request and stay alive until lsp_main's outer free.
        free(d as *void);
        free(data as *void);
        free(fix as *void);
        free(fr as *void);
        if fr_start != null { free(fr_start as *void); }
        if fr_end != null { free(fr_end as *void); }
    }
    lsp_send_response(id, out);
}

// json_array doesn't expose a length helper; reach into the field
// directly. Returns 0 when the value isn't an array (or is null).
fn _json_arr_len(v: *JsonValue) -> i32 {
    if v == null { return 0; }
    if v.kind != JSON_ARRAY { return 0; }
    if v.arr == null { return 0; }
    return v.arr.len();
}

fn _code_action_title(code: string, new_text: string) -> string {
    if code.eq("unused-var")  { return "Prefix with `_`"; }
    if code.eq("unused-param"){ return "Prefix with `_`"; }
    if code.eq("unused-fn")   { return "Prefix with `_`"; }
    if code.eq("unnecessary-mut") { return "Remove `mut`"; }
    if new_text.eq("") { return "Apply fix (delete)"; }
    return "Apply fix";
}

// ---- Custom analysis passes --------------------------------------------

// Walk a fn body collecting let names, then walk again to find references.
// Anything declared but never referenced (and not prefixed with `_`) gets a
// warning. Skips fn params for v1.
fn analysis_unused_vars(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_FN || s.fn_body == null { continue; }
        t.current_origin = s.origin;
        check_unused_in_body(t, s.fn_body);
    }
}

fn check_unused_in_body(t: *Typer, body: *Vector<Stmt>) {
    let n: i32 = body.len();
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET {
            let name: string = s.name;
            // Tuple destructuring (`let (a, b) = ...`) has no single binder
            // name; element positions aren't tracked, so skip the lint.
            if s.let_names != null && s.let_names.len() > 0 {
                continue;
            }
            // Skip names beginning with `_` (intentional discard convention).
            if name.len() == 0 { continue; }
            if name.len() > 0 && name.at(0).to_int() == 95 { continue; }
            let mut used: bool = false;
            for let j: i32 = i + 1; j < n; j++ {
                let s2: Stmt = body.get(j);
                if stmt_uses_name(&s2, name) { used = true; break; }
            }
            if !used {
                t.warn_unused_range(s.name_line, s.name_col, s.name_len, "unused-var",
                    "unused local `".concat(name).concat("` (prefix with `_` to silence)"));
            }
        }
        // Recurse into nested bodies.
        if s.then_body != null { check_unused_in_body(t, s.then_body); }
        if s.else_body != null { check_unused_in_body(t, s.else_body); }
        if s.kind == ST_SELECT && s.select_arms != null {
            for let k: i32 = 0; k < s.select_arms.len(); k++ {
                let arm: SelectArm = s.select_arms.get(k);
                if arm.body != null { check_unused_in_body(t, arm.body); }
            }
        }
    }
}

fn stmt_uses_name(s: *Stmt, name: string) -> bool {
    if s == null { return false; }
    if s.let_value != null && expr_uses_name(s.let_value, name) { return true; }
    if s.expr_value != null && expr_uses_name(s.expr_value, name) { return true; }
    if s.cond != null && expr_uses_name(s.cond, name) { return true; }
    if s.for_step != null && expr_uses_name(s.for_step, name) { return true; }
    if s.for_init != null && stmt_uses_name(s.for_init, name) { return true; }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            if stmt_uses_name(&b, name) { return true; }
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            if stmt_uses_name(&b, name) { return true; }
        }
    }
    if s.kind == ST_ASM {
        if s.asm_out_exprs != null {
            for let i: i32 = 0; i < s.asm_out_exprs.len(); i++ {
                let e: Expr = s.asm_out_exprs.get(i);
                if expr_uses_name(&e, name) { return true; }
            }
        }
        if s.asm_in_exprs != null {
            for let i: i32 = 0; i < s.asm_in_exprs.len(); i++ {
                let e: Expr = s.asm_in_exprs.get(i);
                if expr_uses_name(&e, name) { return true; }
            }
        }
    }
    if s.kind == ST_SELECT && s.select_arms != null {
        for let i: i32 = 0; i < s.select_arms.len(); i++ {
            let arm: SelectArm = s.select_arms.get(i);
            if arm.chan_expr != null && expr_uses_name(arm.chan_expr, name) { return true; }
            if arm.send_value != null && expr_uses_name(arm.send_value, name) { return true; }
            if arm.body != null {
                for let j: i32 = 0; j < arm.body.len(); j++ {
                    let b: Stmt = arm.body.get(j);
                    if stmt_uses_name(&b, name) { return true; }
                }
            }
        }
    }
    return false;
}

fn expr_uses_name(e: *Expr, name: string) -> bool {
    if e == null { return false; }
    if e.kind == EX_IDENT && e.str_val.eq(name) { return true; }
    if e.lhs != null && expr_uses_name(e.lhs, name) { return true; }
    if e.rhs != null && expr_uses_name(e.rhs, name) { return true; }
    if e.operand != null && expr_uses_name(e.operand, name) { return true; }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if expr_uses_name(&a, name) { return true; }
        }
    }
    if e.match_arms != null {
        for let i: i32 = 0; i < e.match_arms.len(); i++ {
            let a: MatchArm = e.match_arms.get(i);
            if a.body != null {
                for let k: i32 = 0; k < a.body.len(); k++ {
                    let b: Stmt = a.body.get(k);
                    if stmt_uses_name(&b, name) { return true; }
                }
            }
        }
    }
    if e.block_stmts != null {
        for let i: i32 = 0; i < e.block_stmts.len(); i++ {
            let b: Stmt = e.block_stmts.get(i);
            if stmt_uses_name(&b, name) { return true; }
        }
    }
    return false;
}

// Lint-code grouping: `@allow("alloc")` is shorthand for both
// `unfreed-alloc` and `arena-not-freed`; `@allow("unused")` covers
// every `unused-*`; `@allow("experimental")` covers the
// stability codes; `@allow("lint")` (or `@allow("lint:*")`) silences
// every user-defined `lint:<category>` warning. Anything starting
// with `lint:` matches the corresponding custom-lint code verbatim.
fn _code_in_group(allow_token: string, code: string) -> bool {
    if allow_token.eq(code) { return true; }
    if allow_token.eq("all") || allow_token.eq("*") { return true; }
    if allow_token.eq("alloc") {
        if code.eq("unfreed-alloc") || code.eq("arena-not-freed") { return true; }
    }
    if allow_token.eq("unused") {
        if code.eq("unused-var") || code.eq("unused-param")
           || code.eq("unused-fn") || code.eq("unnecessary-mut") { return true; }
    }
    if allow_token.eq("experimental") {
        if code.eq("unstable-fn") || code.eq("deprecated-fn") { return true; }
    }
    if allow_token.eq("lint") || allow_token.eq("lint:*") {
        if code.starts_with("lint:") { return true; }
    }
    // Glob-style prefix: `@allow("lint:io_*")` matches every custom
    // category that begins with `io_`. Plain trailing `*` only.
    if allow_token.len() > 1 {
        let last: i32 = allow_token.at(allow_token.len() - 1).to_int();
        if last == 42 {
            let prefix: string = allow_token.substring(0, allow_token.len() - 1);
            if code.starts_with(prefix) { return true; }
        }
    }
    return false;
}

// Project-wide allow list (`lint.allow` from the manifest). Same
// c_raw global as main.glide; we just need the getter here.
extern fn __glide_proj_allow_get() -> *void;
extern fn __glide_proj_allow_set(p: *void);
extern fn __glide_deny_set(p: *void);
extern fn __glide_deny_get() -> *void;

// Compact `parent_dir(path)` — `main.glide`'s is not `pub`, so we
// keep a local copy here. Same behaviour: strip trailing `/seg` or
// `\seg`, return "" when there's no separator.
fn _lsp_parent_dir(path: string) -> string {
    let n: i32 = path.len();
    let mut last: i32 = -1;
    for let i: i32 = 0; i < n; i++ {
        let c: i32 = path.at(i).to_int();
        if c == 47 || c == 92 { last = i; }
    }
    if last < 0 { return ""; }
    return path.substring(0, last);
}

// Wire the project's `lint.deny` / `lint.allow` from the nearest
// `glide.glide` into the process-wide globals. Idempotent.
//
// Critical: the Vector / string entries we stash in the deny / allow
// globals OUTLIVE the doc arena. If we let them allocate in the
// active arena (set just before this fn runs), the very next
// reanalysis frees the doc arena and the global pointers turn into
// dangling references, crashing on the next read. Switch the active
// arena to null (libc heap) around the construction so the data
// survives across reanalyses. Per-invocation strings inside the
// manifest parse still land in the doc arena and are freed cleanly.
fn _lsp_apply_manifest_lint(start_dir: string) {
    let root: string = find_manifest_root(start_dir);
    if root.eq("") { return; }
    let m: *Manifest = read_manifest(root);
    if m == null { return; }

    let prev_arena: *void = __glide_palloc_get();
    __glide_palloc_set(null);

    if m.lint_deny != null && m.lint_deny.len() > 0 {
        let p: *void = __glide_deny_get();
        let merged: *Vector<string> = Vector::new();
        if p != null {
            let existing: *Vector<string> = p as *Vector<string>;
            for let i: i32 = 0; i < existing.len(); i++ {
                let s: string = existing.get(i);
                merged.push(_strdup_libc(s));
            }
        }
        for let i: i32 = 0; i < m.lint_deny.len(); i++ {
            merged.push(_strdup_libc(m.lint_deny.get(i)));
        }
        __glide_deny_set(merged as *void);
    }
    if m.lint_allow != null && m.lint_allow.len() > 0 {
        let copy: *Vector<string> = Vector::new();
        for let i: i32 = 0; i < m.lint_allow.len(); i++ {
            copy.push(_strdup_libc(m.lint_allow.get(i)));
        }
        __glide_proj_allow_set(copy as *void);
    }

    __glide_palloc_set(prev_arena);
}

// Copy `s` onto whatever arena is currently active. Used by
// _lsp_apply_manifest_lint with active=null so the resulting string
// lands on libc heap and outlives every doc-arena reset.
fn _strdup_libc(s: string) -> string {
    // `.substring(0, len)` allocates a fresh buffer rather than
    // sharing the source pointer, which is what we want — `.concat("")`
    // may short-circuit when the rhs is empty.
    return s.substring(0, s.len());
}

fn _project_allow_matches(code: string) -> bool {
    let p: *void = __glide_proj_allow_get();
    if p == null { return false; }
    let v: *Vector<string> = p as *Vector<string>;
    for let i: i32 = 0; i < v.len(); i++ {
        if _code_in_group(v.get(i), code) { return true; }
    }
    return false;
}

// Returns true when either the enclosing item carries
// `@allow("<code>")`, or the project's `lint.allow = [...]` covers it.
// Matched either verbatim or via the group / prefix logic above.
fn _has_allow(s: *Stmt, code: string) -> bool {
    if _project_allow_matches(code) { return true; }
    if s == null || s.attrs == null { return false; }
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !a.name.eq("allow") { continue; }
        if a.args == null { continue; }
        for let j: i32 = 0; j < a.args.len(); j++ {
            let v: Expr = a.args.get(j);
            if v.kind == EX_STRING && _code_in_group(v.str_val, code) { return true; }
        }
    }
    return false;
}

// `let arena: *Arena = Arena::new(...)` without a paired `defer arena.free()`
// or `arena.free()` somewhere later in the scope is a leak. Same shape
// applies to raw `malloc(n)` (paired free) and `__glide_palloc_make()`
// (paired __glide_palloc_free). `let x* = Arena::new(...)` is fine —
// auto-drop handles it. `@allow("unfreed-alloc")` on the enclosing fn
// silences the warning for intentional escape-hatch patterns
// (e.g. ownership handed off to a caller through a raw pointer).
fn analysis_arena_not_freed(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_FN || s.fn_body == null { continue; }
        if _has_allow(&s, "unfreed-alloc") || _has_allow(&s, "arena-not-freed") { continue; }
        t.current_origin = s.origin;
        check_arena_in_body(t, s.fn_body, s.fn_body, false);
    }
}

// Tag for the kind of resource a `let` is binding. Drives which paired
// cleanup we look for downstream.
//   0 = not a tracked resource
//   1 = Arena::new(...)         → arena.free()
//   2 = malloc(...)              → free(arena)
//   3 = __glide_palloc_make()    → __glide_palloc_free(arena)
fn _alloc_kind(v: *Expr) -> i32 {
    if v == null { return 0; }
    // `malloc(n) as *u8` — peel the cast.
    if v.kind == EX_CAST && v.lhs != null { return _alloc_kind(v.lhs); }
    if v.kind != EX_CALL || v.lhs == null { return 0; }
    let head: *Expr = v.lhs;
    if head.kind == EX_PATH && head.str_val.eq("Arena") && head.field.eq("new") { return 1; }
    if head.kind == EX_IDENT && head.str_val.eq("malloc") { return 2; }
    if head.kind == EX_IDENT && head.str_val.eq("__glide_palloc_make") { return 3; }
    return 0;
}

fn check_arena_in_body(t: *Typer, body: *Vector<Stmt>, root: *Vector<Stmt>, suppress: bool) {
    let n: i32 = body.len();
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && !s.is_auto_owned {
            // Stmt-local opt-out: `@allow("unfreed-alloc")` on the `let`
            // itself silences the warning without polluting the
            // enclosing fn. Either alias is recognised. The `suppress`
            // flag propagates a parent block's `@allow`.
            if suppress { continue; }
            if _has_allow(&s, "unfreed-alloc") || _has_allow(&s, "arena-not-freed") { continue; }
            let kind: i32 = _alloc_kind(s.let_value);
            if kind != 0 {
                // Scan the entire fn body (not just the current block) so a
                // `defer foo.free()` registered in a nested if/while still counts.
                if alloc_is_freed_in_body(s.name, kind, root) { continue; }
                // Heuristic ownership-escape suppression. If the
                // resource is stored in a struct field, pushed into a
                // container, or handed to any non-free fn, we assume
                // the receiver takes over the lifetime. The warning
                // only fires for true "let, never reference again,
                // never free" cases.
                if alloc_escapes_in_body(s.name, kind, root) { continue; }
                t.warn(s.line, s.column, _alloc_code(kind), _alloc_msg(kind, s.name));
            }
        }
        // Block-level `@allow("...")` on if/while/for/block/etc. — add
        // it to the active suppression set for the recursive walk.
        let sub_suppress: bool = suppress
            || _has_allow(&s, "unfreed-alloc")
            || _has_allow(&s, "arena-not-freed");
        if s.then_body != null { check_arena_in_body(t, s.then_body, root, sub_suppress); }
        if s.else_body != null { check_arena_in_body(t, s.else_body, root, sub_suppress); }
    }
}

// Conservative escape detection: returns true when `name` is observed
// in any of these contexts anywhere in the fn body.
//   - assigned to a struct field      (obj.f = name)
//   - subscript-stored                 (arr[i] = name)
//   - returned                         (return name; / return ok(name); etc.)
//   - passed as arg to any call where the callee is NOT a known free fn
//     (so `vec.push(name)`, `process(name)`, `Box::wrap(name)` all
//     count as ownership transfer)
//
// Heuristic — won't catch every pattern, but eliminates the
// false-positive cases where the analyzer can't see the cleanup is
// happening elsewhere. The user can still annotate `@allow(...)` for
// the cases this misses.
fn alloc_escapes_in_body(name: string, kind: i32, body: *Vector<Stmt>) -> bool {
    let n: i32 = body.len();
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if stmt_lets_name_escape(&s, name, kind) { return true; }
    }
    return false;
}

fn stmt_lets_name_escape(s: *Stmt, name: string, kind: i32) -> bool {
    if s == null { return false; }
    // `return name;` (and `return ok(name)`, etc.)
    if s.kind == ST_RETURN && s.expr_value != null
       && expr_mentions_ident(s.expr_value, name) { return true; }
    if s.let_value != null && expr_passes_to_non_free(s.let_value, name, kind) { return true; }
    if s.expr_value != null && expr_passes_to_non_free(s.expr_value, name, kind) { return true; }
    if s.cond != null && expr_passes_to_non_free(s.cond, name, kind) { return true; }
    if s.for_step != null && expr_passes_to_non_free(s.for_step, name, kind) { return true; }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            if stmt_lets_name_escape(&b, name, kind) { return true; }
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            if stmt_lets_name_escape(&b, name, kind) { return true; }
        }
    }
    return false;
}

fn _is_free_call_for(callee_name: string, kind: i32) -> bool {
    if kind == 1 { return callee_name.eq("free"); }  // arena uses method form, but be permissive
    if kind == 2 { return callee_name.eq("free"); }
    if kind == 3 { return callee_name.eq("__glide_palloc_free"); }
    return false;
}

fn expr_passes_to_non_free(e: *Expr, name: string, kind: i32) -> bool {
    if e == null { return false; }
    // Assignment to anything except `name` itself counts as escape:
    //   self.field = name
    //   arr[i] = name
    //   x = name              (alias — still escapes our local scope)
    if e.kind == EX_ASSIGN && e.rhs != null && expr_mentions_ident(e.rhs, name) {
        return true;
    }
    // Function / method call passing `name` as an arg, where the
    // callee isn't the matching free fn.
    if e.kind == EX_CALL && e.lhs != null && e.args != null {
        let mut callee: string = "";
        if e.lhs.kind == EX_IDENT { callee = e.lhs.str_val; }
        else if e.lhs.kind == EX_PATH { callee = e.lhs.field; }
        else if e.lhs.kind == EX_MEMBER { callee = e.lhs.field; }
        let mut name_in_args: bool = false;
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if expr_strips_to_ident(&a, name) { name_in_args = true; break; }
        }
        if name_in_args && !_is_free_call_for(callee, kind) { return true; }
    }
    if e.lhs != null && expr_passes_to_non_free(e.lhs, name, kind) { return true; }
    if e.rhs != null && expr_passes_to_non_free(e.rhs, name, kind) { return true; }
    if e.operand != null && expr_passes_to_non_free(e.operand, name, kind) { return true; }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if expr_passes_to_non_free(&a, name, kind) { return true; }
        }
    }
    return false;
}

fn expr_mentions_ident(e: *Expr, name: string) -> bool {
    if e == null { return false; }
    if e.kind == EX_IDENT && e.str_val.eq(name) { return true; }
    if e.lhs != null && expr_mentions_ident(e.lhs, name) { return true; }
    if e.rhs != null && expr_mentions_ident(e.rhs, name) { return true; }
    if e.operand != null && expr_mentions_ident(e.operand, name) { return true; }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if expr_mentions_ident(&a, name) { return true; }
        }
    }
    return false;
}

fn _alloc_code(kind: i32) -> string {
    if kind == 1 { return "arena-not-freed"; }
    return "unfreed-alloc";
}

fn _alloc_msg(kind: i32, name: string) -> string {
    if kind == 1 {
        return "arena `".concat(name).concat("` is never freed (use `let ")
            .concat(name).concat("* = Arena::new(...)` or add `defer ")
            .concat(name).concat(".free()`)");
    }
    if kind == 2 {
        return "allocation `".concat(name).concat("` is never freed (add `defer free(")
            .concat(name).concat(")` after the malloc, or `@allow(\"unfreed-alloc\")` if the handle escapes the fn)");
    }
    return "palloc arena `".concat(name).concat("` is never freed (add `__glide_palloc_free(")
        .concat(name).concat(")` or `@allow(\"unfreed-alloc\")` if the handle escapes the fn)");
}

fn alloc_is_freed_in_body(name: string, kind: i32, body: *Vector<Stmt>) -> bool {
    let n: i32 = body.len();
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if stmt_frees_resource(&s, name, kind) { return true; }
    }
    return false;
}

fn stmt_frees_resource(s: *Stmt, name: string, kind: i32) -> bool {
    if s == null { return false; }
    if kind == 1 {
        if stmt_calls_method(s, name, "free") { return true; }
    }
    if kind == 2 {
        if stmt_calls_fn_with(s, "free", name) { return true; }
    }
    if kind == 3 {
        if stmt_calls_fn_with(s, "__glide_palloc_free", name) { return true; }
    }
    // Returning the resource counts as ownership transfer.
    if s.expr_value != null && expr_returns_ident(s.expr_value, name) { return true; }
    return false;
}

fn stmt_calls_fn_with(s: *Stmt, fn_name: string, arg_name: string) -> bool {
    if s == null { return false; }
    if s.expr_value != null && expr_calls_fn_with(s.expr_value, fn_name, arg_name) { return true; }
    if s.let_value  != null && expr_calls_fn_with(s.let_value,  fn_name, arg_name) { return true; }
    if s.cond       != null && expr_calls_fn_with(s.cond,       fn_name, arg_name) { return true; }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            if stmt_calls_fn_with(&b, fn_name, arg_name) { return true; }
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            if stmt_calls_fn_with(&b, fn_name, arg_name) { return true; }
        }
    }
    return false;
}

fn expr_calls_fn_with(e: *Expr, fn_name: string, arg_name: string) -> bool {
    if e == null { return false; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT
       && e.lhs.str_val.eq(fn_name) && e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if expr_strips_to_ident(&a, arg_name) { return true; }
        }
    }
    if e.lhs != null && expr_calls_fn_with(e.lhs, fn_name, arg_name) { return true; }
    if e.rhs != null && expr_calls_fn_with(e.rhs, fn_name, arg_name) { return true; }
    if e.operand != null && expr_calls_fn_with(e.operand, fn_name, arg_name) { return true; }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if expr_calls_fn_with(&a, fn_name, arg_name) { return true; }
        }
    }
    return false;
}

// Match `name` or `name as T` — strip the cast and check the inner
// identifier so `free(x as *void)` still counts as freeing `x`.
fn expr_strips_to_ident(e: *Expr, name: string) -> bool {
    if e == null { return false; }
    if e.kind == EX_IDENT && e.str_val.eq(name) { return true; }
    if e.kind == EX_CAST && e.lhs != null { return expr_strips_to_ident(e.lhs, name); }
    return false;
}

fn expr_returns_ident(e: *Expr, name: string) -> bool {
    if e == null { return false; }
    if e.kind == EX_IDENT && e.str_val.eq(name) { return true; }
    return false;
}

fn stmt_calls_method(s: *Stmt, var: string, method: string) -> bool {
    if s == null { return false; }
    if s.expr_value != null && expr_calls_method(s.expr_value, var, method) { return true; }
    if s.let_value != null && expr_calls_method(s.let_value, var, method) { return true; }
    if s.cond != null && expr_calls_method(s.cond, var, method) { return true; }
    if s.for_step != null && expr_calls_method(s.for_step, var, method) { return true; }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            if stmt_calls_method(&b, var, method) { return true; }
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            if stmt_calls_method(&b, var, method) { return true; }
        }
    }
    return false;
}

fn expr_calls_method(e: *Expr, var: string, method: string) -> bool {
    if e == null { return false; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER
       && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT
       && e.lhs.lhs.str_val.eq(var) && e.lhs.field.eq(method) {
        return true;
    }
    if e.lhs != null && expr_calls_method(e.lhs, var, method) { return true; }
    if e.rhs != null && expr_calls_method(e.rhs, var, method) { return true; }
    if e.operand != null && expr_calls_method(e.operand, var, method) { return true; }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if expr_calls_method(&a, var, method) { return true; }
        }
    }
    return false;
}

// Returning the address of a temporary value is a dangling-pointer bug:
//   fn make() -> *Vec2 { return &Vec2 { x: 1, y: 2 }; }
// The temporary lives in `make`'s frame; its address is invalid the moment
// `make` returns. Code is `addr-of-temporary`.
pub fn analysis_addr_of_temporary(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            t.current_origin = s.origin;
            check_addr_temp_body(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            t.current_origin = s.origin;
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null { check_addr_temp_body(t, m.fn_body); }
            }
        }
    }
}

fn check_addr_temp_body(t: *Typer, body: *Vector<Stmt>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_RETURN && s.expr_value != null {
            let e: *Expr = s.expr_value;
            if e.kind == EX_UNARY && (e.op_code == UN_ADDR || e.op_code == UN_ADDR_MUT)
               && e.operand != null
               && (e.operand.kind == EX_STRUCT_LIT || e.operand.kind == EX_NEW) {
                t.err_code(s.line, s.column, "addr-of-temporary",
                    "cannot return address of a temporary value (would dangle); use `new T { ... }` to heap-allocate or return by value");
            }
        }
        if s.then_body != null { check_addr_temp_body(t, s.then_body); }
        if s.else_body != null { check_addr_temp_body(t, s.else_body); }
    }
}

// Statements after a terminator (return / break / continue) are unreachable.
// Only the first one is flagged.
pub fn analysis_dead_code(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            t.current_origin = s.origin;
            check_dead_code_body(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            t.current_origin = s.origin;
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null { check_dead_code_body(t, m.fn_body); }
            }
        }
    }
}

fn check_dead_code_body(t: *Typer, body: *Vector<Stmt>) {
    let n: i32 = body.len();
    let mut terminated: bool = false;
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if terminated {
            t.warn_unused(s.line, s.column, "dead-code",
                "unreachable code after return / break / continue");
            return;     // flag only the first dead stmt per block
        }
        if s.kind == ST_RETURN || s.kind == ST_BREAK || s.kind == ST_CONTINUE {
            terminated = true;
        }
        // Recurse into nested bodies regardless.
        if s.then_body != null { check_dead_code_body(t, s.then_body); }
        if s.else_body != null { check_dead_code_body(t, s.else_body); }
    }
}

// Top-level fn that's not pub, not `main`, never called from anywhere.
// Builds a call set from every reachable expression.
pub fn analysis_unused_fn(t: *Typer, program: *Vector<Stmt>) {
    let called: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null { collect_calls_body(s.fn_body, called); }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null { collect_calls_body(m.fn_body, called); }
            }
        }
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_FN { continue; }
        if s.fn_body == null { continue; }                      // extern
        if s.is_pub { continue; }                                // public API
        if s.name.eq("main") { continue; }
        if s.type_params != null && s.type_params.len() > 0 { continue; }   // generic, may be referenced indirectly
        if called.contains(s.name) { continue; }
        t.current_origin = s.origin;
        t.warn_unused_range(s.name_line, s.name_col, s.name_len, "unused-fn",
            "function `".concat(s.name).concat("` is never called"));
    }
    called.free();
}

fn collect_calls_body(body: *Vector<Stmt>, out: *HashMap<bool>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        collect_calls_stmt(&s, out);
    }
}

fn collect_calls_stmt(s: *Stmt, out: *HashMap<bool>) {
    if s == null { return; }
    if s.let_value != null { collect_calls_expr(s.let_value, out); }
    if s.expr_value != null { collect_calls_expr(s.expr_value, out); }
    if s.cond != null { collect_calls_expr(s.cond, out); }
    if s.for_step != null { collect_calls_expr(s.for_step, out); }
    if s.for_init != null { collect_calls_stmt(s.for_init, out); }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            collect_calls_stmt(&b, out);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            collect_calls_stmt(&b, out);
        }
    }
}

fn collect_calls_expr(e: *Expr, out: *HashMap<bool>) {
    if e == null { return; }
    if e.kind == EX_CALL && e.lhs != null {
        if e.lhs.kind == EX_IDENT { out.insert(e.lhs.str_val, true); }
        if e.lhs.kind == EX_PATH {
            out.insert(e.lhs.str_val.concat("_").concat(e.lhs.field), true);
            out.insert(e.lhs.field, true);
        }
        if e.lhs.kind == EX_MEMBER { out.insert(e.lhs.field, true); }
    }
    // Any free-standing identifier reference counts as a use too — covers
    // function pointers passed as args (`http_listen(8090, my_handler)`)
    // or stored in structs / vectors. False positives (a non-fn variable
    // happening to share a name) only suppress the warning, which is the
    // safer failure mode.
    if e.kind == EX_IDENT { out.insert(e.str_val, true); }
    if e.lhs != null { collect_calls_expr(e.lhs, out); }
    if e.rhs != null { collect_calls_expr(e.rhs, out); }
    if e.operand != null { collect_calls_expr(e.operand, out); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            collect_calls_expr(&a, out);
        }
    }
}

// `let mut x` where x is never reassigned. The `mut` is noise.
pub fn analysis_unnecessary_mut(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            t.current_origin = s.origin;
            check_mut_body(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            t.current_origin = s.origin;
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null { check_mut_body(t, m.fn_body); }
            }
        }
    }
}

fn check_mut_body(t: *Typer, body: *Vector<Stmt>) {
    let n: i32 = body.len();
    for let i: i32 = 0; i < n; i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.is_mut {
            let mut reassigned: bool = false;
            for let j: i32 = i + 1; j < n; j++ {
                let s2: Stmt = body.get(j);
                if stmt_reassigns(&s2, s.name) { reassigned = true; break; }
            }
            if !reassigned {
                t.warn(s.name_line, s.name_col, "unnecessary-mut",
                    "`mut` on `".concat(s.name).concat("` is unnecessary; binding is never reassigned"));
            }
        }
        if s.then_body != null { check_mut_body(t, s.then_body); }
        if s.else_body != null { check_mut_body(t, s.else_body); }
        if s.kind == ST_SELECT && s.select_arms != null {
            for let k: i32 = 0; k < s.select_arms.len(); k++ {
                let arm: SelectArm = s.select_arms.get(k);
                if arm.body != null { check_mut_body(t, arm.body); }
            }
        }
    }
}

fn stmt_reassigns(s: *Stmt, name: string) -> bool {
    if s == null { return false; }
    if s.expr_value != null && expr_reassigns(s.expr_value, name) { return true; }
    if s.let_value != null && expr_reassigns(s.let_value, name) { return true; }
    if s.cond != null && expr_reassigns(s.cond, name) { return true; }
    if s.for_step != null && expr_reassigns(s.for_step, name) { return true; }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            if stmt_reassigns(&b, name) { return true; }
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            if stmt_reassigns(&b, name) { return true; }
        }
    }
    if s.kind == ST_SELECT && s.select_arms != null {
        for let i: i32 = 0; i < s.select_arms.len(); i++ {
            let arm: SelectArm = s.select_arms.get(i);
            if arm.send_value != null && expr_reassigns(arm.send_value, name) { return true; }
            if arm.body != null {
                for let j: i32 = 0; j < arm.body.len(); j++ {
                    let b: Stmt = arm.body.get(j);
                    if stmt_reassigns(&b, name) { return true; }
                }
            }
        }
    }
    return false;
}

fn expr_reassigns(e: *Expr, name: string) -> bool {
    if e == null { return false; }
    if e.kind == EX_ASSIGN && e.lhs != null && e.lhs.kind == EX_IDENT
       && e.lhs.str_val.eq(name) {
        return true;
    }
    if (e.kind == EX_POSTINC || e.kind == EX_POSTDEC)
       && e.lhs != null && e.lhs.kind == EX_IDENT
       && e.lhs.str_val.eq(name) {
        return true;
    }
    if e.lhs != null && expr_reassigns(e.lhs, name) { return true; }
    if e.rhs != null && expr_reassigns(e.rhs, name) { return true; }
    if e.operand != null && expr_reassigns(e.operand, name) { return true; }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if expr_reassigns(&a, name) { return true; }
        }
    }
    return false;
}

// Function declared `-> T` (non-void) where some path doesn't return.
// Conservative: walks the body, checks the LAST stmt of each branch.
pub fn analysis_missing_return(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_FN { continue; }
        if s.fn_body == null { continue; }
        if s.fn_ret_ty == null { continue; }                 // void -> ok
        if s.is_naked { continue; }                          // raw asm; `ret` lives in the asm
        // `-> !` (Result-without-value) returns Ok implicitly when the body
        // falls off the end. Codegen injects `return __glide_ok_void();` at
        // the function tail, so missing explicit return is not an error.
        if s.fn_ret_ty.kind == TY_RESULT && s.fn_ret_ty.inner != null
           && s.fn_ret_ty.inner.kind == TY_NAMED
           && s.fn_ret_ty.inner.name.eq("void") {
            continue;
        }
        // Bool ret is okay-ish but still must return; same logic.
        if !body_always_returns(s.fn_body) {
            t.current_origin = s.origin;
            t.warn(s.line, s.column, "missing-return",
                "function `".concat(s.name)
                .concat("` declared `-> ").concat(type_to_string(s.fn_ret_ty))
                .concat("` may exit without returning a value"));
        }
    }
}

fn body_always_returns(body: *Vector<Stmt>) -> bool {
    let n: i32 = body.len();
    if n == 0 { return false; }
    let last: Stmt = body.get(n - 1);
    return stmt_terminates(&last);
}

fn stmt_terminates(s: *Stmt) -> bool {
    if s == null { return false; }
    if s.kind == ST_RETURN { return true; }
    if s.kind == ST_BREAK || s.kind == ST_CONTINUE { return true; }
    if s.kind == ST_BLOCK {
        if s.then_body != null { return body_always_returns(s.then_body); }
        return false;
    }
    if s.kind == ST_IF {
        if s.then_body != null && s.else_body != null {
            return body_always_returns(s.then_body) && body_always_returns(s.else_body);
        }
        return false;
    }
    if s.kind == ST_MATCH {
        if s.arms == null { return false; }
        let mut all: bool = true;
        let mut has_default: bool = false;
        for let i: i32 = 0; i < s.arms.len(); i++ {
            let a: MatchArm = s.arms.get(i);
            if a.variant.eq("_") { has_default = true; }
            if a.body == null || !body_always_returns(a.body) { all = false; break; }
        }
        return all && has_default;
    }
    return false;
}

// Unused fn parameter (skip names starting with `_`). Reports at the fn
// declaration line since Param has no position info.
pub fn analysis_unused_params(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN { check_unused_params_fn(t, &s); }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                check_unused_params_fn(t, &m);
            }
        }
    }
}

fn check_unused_params_fn(t: *Typer, fnstmt: *Stmt) {
    if fnstmt == null { return; }
    if fnstmt.fn_body == null { return; }
    if fnstmt.fn_params == null { return; }
    if fnstmt.is_naked { return; }                          // params accessed via raw calling-conv regs
    // Synthesised fns (proc-macro outputs with line == 0) — the user
    // can't fix the `_` here, and the warning would anchor at line 1
    // of their file. Skip.
    if fnstmt.line <= 0 { return; }
    for let i: i32 = 0; i < fnstmt.fn_params.len(); i++ {
        let p: Param = fnstmt.fn_params.get(i);
        if p.name.eq("self") { continue; }
        if p.name.len() > 0 && p.name.at(0).to_int() == 95 { continue; }
        let mut used: bool = false;
        for let j: i32 = 0; j < fnstmt.fn_body.len(); j++ {
            let b: Stmt = fnstmt.fn_body.get(j);
            if stmt_uses_name(&b, p.name) { used = true; break; }
        }
        if !used {
            t.current_origin = fnstmt.origin;
            // Aim at the param identifier itself so the editor squiggle
            // and `glide fix` land on the right token. Falls back to
            // the fn name if the parser didn't fill in a position
            // (e.g. synthesized params).
            let mut pl: i32 = p.name_line;
            let mut pc: i32 = p.name_col;
            if pl == 0 { pl = fnstmt.name_line; pc = fnstmt.name_col; }
            t.warn_unused_range(pl, pc, p.name.len(), "unused-param",
                "parameter `".concat(p.name).concat("` of `")
                .concat(fnstmt.name).concat("` is never used (prefix with `_` to silence)"));
        }
    }
}

// Estimate a type's size in bytes. Approximate (no alignment / padding) but
// good enough to spot "I'm returning a 2KB struct by value" anti-patterns.
fn type_size_bytes(t: *Type, structs: *HashMap<Stmt>) -> i32 {
    if t == null { return 0; }
    if t.kind == TY_POINTER || t.kind == TY_BORROW || t.kind == TY_BORROW_MUT { return 8; }
    if t.kind == TY_FNPTR { return 8; }
    if t.kind == TY_SLICE { return 16; }            // {data, len}
    if t.kind == TY_RESULT {
        return type_size_bytes(t.inner, structs) + 16;   // ok flag + val + err msg
    }
    if t.kind == TY_GENERIC { return 16; }          // best-effort guess for unmonomorphized
    if t.kind == TY_NAMED {
        let n: string = t.name;
        if n.eq("char") || n.eq("bool") || n.eq("i8") || n.eq("u8") { return 1; }
        if n.eq("i16") || n.eq("u16") { return 2; }
        if n.eq("int") || n.eq("uint") || n.eq("i32") || n.eq("u32") || n.eq("f32") { return 4; }
        if n.eq("long") || n.eq("ulong") || n.eq("i64") || n.eq("u64")
           || n.eq("usize") || n.eq("isize") || n.eq("float") || n.eq("f64") { return 8; }
        if n.eq("i128") || n.eq("u128") { return 16; }
        if n.eq("i256") || n.eq("u256") { return 32; }
        if n.eq("string") { return 8; }             // const char*
        if n.eq("void") { return 0; }
        if structs.contains(n) {
            let sd: Stmt = structs.get(n);
            let mut sz: i32 = 0;
            if sd.struct_fields != null {
                for let i: i32 = 0; i < sd.struct_fields.len(); i++ {
                    let f: Field = sd.struct_fields.get(i);
                    sz = sz + type_size_bytes(f.ty, structs);
                }
            }
            return sz;
        }
    }
    return 0;
}

// Hint: a function returns a large struct by value. The caller pays a copy on
// every call (or the ABI inserts a hidden out-pointer transparently). For hot
// paths, suggest taking an explicit `out: *T` parameter, or returning `*T` if
// ownership transfer makes sense.
fn analysis_large_return(t: *Typer, program: *Vector<Stmt>) {
    let structs: *HashMap<Stmt> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_STRUCT { structs.insert(s.name, s); }
    }
    let threshold: i32 = 64;
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_FN { continue; }
        if s.fn_body == null { continue; }      // skip extern declarations
        let ret: *Type = s.fn_ret_ty;
        if ret == null { continue; }
        // Already a pointer / borrow — nothing to recommend.
        if ret.kind == TY_POINTER || ret.kind == TY_BORROW
           || ret.kind == TY_BORROW_MUT || ret.kind == TY_FNPTR { continue; }
        let sz: i32 = type_size_bytes(ret, structs);
        if sz >= threshold {
            t.current_origin = s.origin;
            t.push_diag(s.line, s.column, 3, "large-return",
                "fn `".concat(s.name).concat("` returns ")
                .concat(int_to_str(sz)).concat(" bytes by value (")
                .concat(type_to_string(ret))
                .concat("); for hot paths consider an out-param `out: *")
                .concat(type_to_string(ret)).concat("` or returning `*")
                .concat(type_to_string(ret)).concat("`"));
        }
    }
    structs.free();
}

// Emit a warning at every call site of a function (or path method)
// marked with the given attribute. Used by `@deprecated` /
// `@unstable` / any future attribute-driven lint. The reason string
// is interpolated into the message so the editor surfaces guidance
// inline. Suppression via `@allow("<lint-code>")` on the calling
// function or local stmt.
//
// `attr_name`: e.g. "deprecated" / "unstable"
// `lint_code`: warning code to emit, e.g. "deprecated-fn"
// `what`:      English noun used in the message ("deprecated"/"unstable")
pub fn analysis_deprecated_calls(t: *Typer, program: *Vector<Stmt>) {
    _run_attr_call_lint(t, program, "deprecated", "deprecated-fn", "deprecated");
}

pub fn analysis_unstable_calls(t: *Typer, program: *Vector<Stmt>) {
    _run_attr_call_lint(t, program, "unstable", "unstable-fn", "unstable");
}

// User-defined call-site lints declared via `@lint("<category>", "<reason>")`.
// First arg is the warning code (prefixed with `lint:` so it can't
// collide with the built-in codes); second arg is the message. The
// pass is otherwise identical to deprecated/unstable so suppression
// (`@allow("lint:<category>")`), block-level scoping, EX_PATH /
// EX_MEMBER resolution, and the impl-method qualified-key behaviour
// all come along for free.
//
// Example:
//   @lint("blocking_io", "blocks the coro scheduler — call from spawn_thread")
//   pub fn read_sync(path: string) -> string { … }
//
// Call sites then surface `lint:blocking_io: blocks the coro
// scheduler — call from spawn_thread` as a warning the user can
// silence with `@allow("lint:blocking_io")`.
pub fn analysis_custom_lints(t: *Typer, program: *Vector<Stmt>) {
    // First pass: collect every category that appears. Then run one
    // resolution pass per category. Two-pass keeps each per-category
    // HashMap local — Glide's generic monomorphization can't easily
    // express HashMap<*HashMap<string>>, so we re-walk the program
    // per category instead of nesting maps.
    let cats: *Vector<string> = _collect_lint_categories(program);
    for let i: i32 = 0; i < cats.len(); i++ {
        let cat: string = cats.get(i);
        let dep: *HashMap<string> = HashMap::new();
        _build_lint_index_for_cat(program, cat, dep);
        let code: string = "lint:".concat(cat);
        let what: string = "flagged by `".concat(code).concat("`");
        _run_call_lint_with_index(t, program, dep, code, what);
        dep.free();
    }
}

// Walk the program once and collect every category string that
// appears as the first arg of any `@lint(...)`. Deduplicated.
fn _collect_lint_categories(program: *Vector<Stmt>) -> *Vector<string> {
    let seen: *HashMap<bool> = HashMap::new();
    let out: *Vector<string> = Vector::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN { _gather_lint_cats(&s, seen, out); }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                _gather_lint_cats(&m, seen, out);
            }
        }
    }
    seen.free();
    return out;
}

fn _gather_lint_cats(s: *Stmt, seen: *HashMap<bool>, out: *Vector<string>) {
    if s == null || s.attrs == null { return; }
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !a.name.eq("lint") { continue; }
        if a.args == null || a.args.len() == 0 { continue; }
        let cat_expr: Expr = a.args.get(0);
        if cat_expr.kind != EX_STRING { continue; }
        if seen.contains(cat_expr.str_val) { continue; }
        seen.insert(cat_expr.str_val, true);
        out.push(cat_expr.str_val);
    }
}

// For a single category, build the fn-name → reason index. Mirrors
// the structure of `_collect_attr_fns` so the existing call-site
// scanner can drive it.
fn _build_lint_index_for_cat(program: *Vector<Stmt>, cat: string, dep: *HashMap<string>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN {
            let r: ?string = _lint_reason_for_cat(&s, cat);
            if r.has { dep.insert(s.name, r.val); }
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            let mut owner: string = "";
            if s.impl_target != null && s.impl_target.name != null { owner = s.impl_target.name; }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                let r: ?string = _lint_reason_for_cat(&m, cat);
                if !r.has { continue; }
                let rv: string = r.val;
                if !owner.eq("") { dep.insert(owner.concat("::").concat(m.name), rv); }
                if !dep.contains(m.name) { dep.insert(m.name, rv); }
            }
        }
    }
}

fn _lint_reason_for_cat(s: *Stmt, cat: string) -> ?string {
    if s == null || s.attrs == null { return none(); }
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !a.name.eq("lint") { continue; }
        if a.args == null || a.args.len() == 0 { continue; }
        let cat_expr: Expr = a.args.get(0);
        if cat_expr.kind != EX_STRING { continue; }
        if !cat_expr.str_val.eq(cat) { continue; }
        if a.args.len() > 1 {
            let r_expr: Expr = a.args.get(1);
            if r_expr.kind == EX_STRING { return some(r_expr.str_val); }
        }
        return some("");
    }
    return none();
}

// Walk the diagnostic stream against every `@expect("<code>")`
// attribute in the program. Each `@expect` is either fulfilled (we
// remove the matching warning so it doesn't pollute the output) or
// unfulfilled (we emit a `unfulfilled-expectation` error pointing at
// the annotation). Useful for self-tests of the lint passes — you
// write the offending pattern, slap `@expect` on it, and the test
// only fails when the lint stops working.
pub fn analysis_expect_fulfillment(t: *Typer, program: *Vector<Stmt>) {
    let pending: *Vector<ExpectPending> = Vector::new();
    _collect_expectations(program, pending);
    if pending.len() == 0 { pending.free(); return; }

    // Build two structures from `pending`:
    //   - stmt-local entries (pe_line == pe_end_line) get indexed by
    //     `origin|line|code` for O(1) lookup
    //   - fn-scope entries (pe_line < pe_end_line) stay in a flat list
    //     because each diagnostic has to range-check against them
    let index: *HashMap<string> = HashMap::new();
    let ranged: *Vector<i32> = Vector::new();
    for let i: i32 = 0; i < pending.len(); i++ {
        let pe: ExpectPending = pending.get(i);
        if pe.pe_line == pe.pe_end_line {
            let key: string = _expect_key(pe.pe_origin, pe.pe_line, pe.pe_code);
            let cur: string = if index.contains(key) { index.get(key) } else { "" };
            index.insert(key, cur.concat(" ").concat(int_to_str(i)));
        } else {
            ranged.push(i);
        }
    }

    // Single sweep over diagnostics — try the precise index first,
    // then fall back to range scan for fn-scope @expects.
    let consumed: *HashMap<bool> = HashMap::new();
    for let j: i32 = 0; j < t.diagnostics.len(); j++ {
        let d: DiagEntry = t.diagnostics.get(j);
        if d.severity != 2 { continue; }
        let mut matched: bool = false;

        let key: string = _expect_key(d.origin, d.line, d.code);
        if index.contains(key) {
            let bucket: string = index.get(key);
            let toks: *Vector<string> = bucket.trim().split(" ");
            for let k: i32 = 0; k < toks.len(); k++ {
                let t_tok: string = toks.get(k);
                if t_tok.eq("") { continue; }
                let idx: i32 = _expect_str_to_int(t_tok);
                let pe: ExpectPending = pending.get(idx);
                if pe.pe_done { continue; }
                let mut updated: ExpectPending = pe;
                updated.pe_done = true;
                pending.set(idx, updated);
                matched = true;
                break;
            }
        }
        if !matched {
            for let k: i32 = 0; k < ranged.len(); k++ {
                let idx: i32 = ranged.get(k);
                let pe: ExpectPending = pending.get(idx);
                if pe.pe_done { continue; }
                if !pe.pe_origin.eq(d.origin) { continue; }
                if !pe.pe_code.eq(d.code) { continue; }
                if d.line < pe.pe_line || d.line > pe.pe_end_line { continue; }
                let mut updated: ExpectPending = pe;
                updated.pe_done = true;
                pending.set(idx, updated);
                matched = true;
                break;
            }
        }
        if matched { consumed.insert(int_to_str(j), true); }
    }

    // Phase 2: rebuild diagnostics list without consumed entries.
    if consumed.len() > 0 {
        let kept: *Vector<DiagEntry> = Vector::new();
        for let i: i32 = 0; i < t.diagnostics.len(); i++ {
            let key: string = int_to_str(i);
            if consumed.contains(key) { continue; }
            kept.push(t.diagnostics.get(i));
        }
        t.diagnostics = kept;
    }

    // Phase 3: emit `unfulfilled-expectation` errors for the
    // expectations no diagnostic satisfied.
    for let i: i32 = 0; i < pending.len(); i++ {
        let pe: ExpectPending = pending.get(i);
        if pe.pe_done { continue; }
        t.current_origin = pe.pe_origin;
        t.err_code(pe.pe_line, pe.pe_col, "unfulfilled-expectation",
            "@expect(\"".concat(pe.pe_code).concat("\") on this stmt did not match any emitted diagnostic"));
    }

    consumed.free();
    pending.free();
}

// Compact key for the @expect index. Three parts joined by `|` is
// fine because none of them can contain `|` in legal source
// (origins are file paths, codes are ident-like, lines are ints).
fn _expect_key(origin: string, line: i32, code: string) -> string {
    return origin.concat("|").concat(int_to_str(line)).concat("|").concat(code);
}

// Local ASCII int parser. The lsp module doesn't import stdlib helpers
// and parse_int_lexeme lives in the parser module — easier to inline a
// 10-line function than thread an import.
fn _expect_str_to_int(s: string) -> i32 {
    let mut acc: i32 = 0;
    for let i: i32 = 0; i < s.len(); i++ {
        let c: i32 = s.at(i).to_int();
        if c < 48 || c > 57 { return acc; }
        acc = acc * 10 + (c - 48);
    }
    return acc;
}

struct ExpectPending {
    pe_code: string,
    pe_line: i32,        // start of the matching range (inclusive)
    pe_end_line: i32,    // end of the matching range (inclusive); == pe_line for stmt-local
    pe_col: i32,
    pe_origin: string,
    pe_done: bool,
}

fn _collect_expectations(program: *Vector<Stmt>, out: *Vector<ExpectPending>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        // Fn-level `@expect("...")` covers the whole body — match
        // anywhere from the fn's first line through the last stmt's
        // line. Useful when the warning fires on a sub-expression
        // and the user just wants to assert "somewhere in here".
        if s.kind == ST_FN && s.fn_body != null {
            _gather_expects_in_fn(&s, s.fn_body, out);
            _gather_expects_in_body(s.fn_body, s.origin, out);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null { continue; }
                _gather_expects_in_fn(&m, m.fn_body, out);
                _gather_expects_in_body(m.fn_body, m.origin, out);
            }
        }
    }
}

fn _gather_expects_in_fn(s: *Stmt, body: *Vector<Stmt>, out: *Vector<ExpectPending>) {
    if s == null || s.attrs == null { return; }
    let end_line: i32 = _max_line_in_body(body, s.line);
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !a.name.eq("expect") { continue; }
        if a.args == null || a.args.len() == 0 { continue; }
        let v: Expr = a.args.get(0);
        if v.kind != EX_STRING { continue; }
        let pe: ExpectPending = ExpectPending {
            pe_code: v.str_val,
            pe_line: s.line,
            pe_end_line: end_line,
            pe_col: s.column,
            pe_origin: s.origin,
            pe_done: false,
        };
        out.push(pe);
    }
}

// Approximate the last line of a fn body — uses the highest `line`
// field seen across nested stmts. Good enough for matching @expect
// ranges; not source-precise but resilient to the parser not
// tracking explicit end positions.
fn _max_line_in_body(body: *Vector<Stmt>, fallback: i32) -> i32 {
    let mut best: i32 = fallback;
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.line > best { best = s.line; }
        if s.then_body != null {
            let sub: i32 = _max_line_in_body(s.then_body, best);
            if sub > best { best = sub; }
        }
        if s.else_body != null {
            let sub: i32 = _max_line_in_body(s.else_body, best);
            if sub > best { best = sub; }
        }
    }
    return best;
}

fn _gather_expects_in_body(body: *Vector<Stmt>, origin: string, out: *Vector<ExpectPending>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        _gather_expects_in_stmt(&s, origin, out);
        if s.then_body != null { _gather_expects_in_body(s.then_body, origin, out); }
        if s.else_body != null { _gather_expects_in_body(s.else_body, origin, out); }
    }
}

fn _gather_expects_in_stmt(s: *Stmt, origin: string, out: *Vector<ExpectPending>) {
    if s == null || s.attrs == null { return; }
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !a.name.eq("expect") { continue; }
        if a.args == null || a.args.len() == 0 { continue; }
        let v: Expr = a.args.get(0);
        if v.kind != EX_STRING { continue; }
        let pe: ExpectPending = ExpectPending {
            pe_code: v.str_val,
            pe_line: s.line,
            pe_end_line: s.line,    // stmt-local: single line
            pe_col: s.column,
            pe_origin: origin,
            pe_done: false,
        };
        out.push(pe);
    }
}

// Variant of `_run_attr_call_lint` that takes a pre-built index +
// emits a custom code. Used by `analysis_custom_lints` to drive the
// shared scanner without rebuilding the dep map for each call.
fn _run_call_lint_with_index(t: *Typer, program: *Vector<Stmt>, dep: *HashMap<string>, lint_code: string, what: string) {
    if dep.len() == 0 { return; }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            if _has_allow(&s, lint_code) { continue; }
            t.current_origin = s.origin;
            let scope: *HashMap<string> = HashMap::new();
            _seed_scope_from_params(&s, scope, "");
            _scan_calls_in_body(t, s.fn_body, dep, lint_code, what, scope);
            scope.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            let mut owner: string = "";
            if s.impl_target != null && s.impl_target.name != null { owner = s.impl_target.name; }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null { continue; }
                if _has_allow(&m, lint_code) { continue; }
                t.current_origin = m.origin;
                let scope: *HashMap<string> = HashMap::new();
                _seed_scope_from_params(&m, scope, owner);
                _scan_calls_in_body(t, m.fn_body, dep, lint_code, what, scope);
                scope.free();
            }
        }
    }
}

fn _run_attr_call_lint(t: *Typer, program: *Vector<Stmt>, attr_name: string, lint_code: string, what: string) {
    let dep: *HashMap<string> = HashMap::new();
    _collect_attr_fns(program, dep, attr_name);
    if dep.len() == 0 { dep.free(); return; }

    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            if _has_allow(&s, lint_code) { continue; }
            t.current_origin = s.origin;
            let scope: *HashMap<string> = HashMap::new();
            // Top-level fn: seed scope with the declared param types
            // so `obj.method()` inside the body can resolve receiver
            // types through `Type::method` lookups.
            _seed_scope_from_params(&s, scope, "");
            _scan_calls_in_body(t, s.fn_body, dep, lint_code, what, scope);
            scope.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            // Inside `impl Type { ... }`, `self` is bound to the
            // owner. Surface that to the receiver lookup so
            // `self.old()` resolves to `Type::old`.
            let mut owner: string = "";
            if s.impl_target != null && s.impl_target.name != null { owner = s.impl_target.name; }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null { continue; }
                if _has_allow(&m, lint_code) { continue; }
                t.current_origin = m.origin;
                let scope: *HashMap<string> = HashMap::new();
                _seed_scope_from_params(&m, scope, owner);
                _scan_calls_in_body(t, m.fn_body, dep, lint_code, what, scope);
                scope.free();
            }
        }
    }
    dep.free();
}

// Walk a fn's declared params, recording each `name: Type` binding so
// receiver lookups inside the body can resolve `name.method()` to
// `Type::method`. `self_owner` is the impl target name (used to
// auto-type the implicit `self` param).
fn _seed_scope_from_params(s: *Stmt, scope: *HashMap<string>, self_owner: string) {
    if s == null || s.fn_params == null { return; }
    for let i: i32 = 0; i < s.fn_params.len(); i++ {
        let p: Param = s.fn_params.get(i);
        if p.name.eq("self") && !self_owner.eq("") {
            scope.insert("self", self_owner);
            continue;
        }
        let n: string = _type_root_name(p.ty);
        if !n.eq("") { scope.insert(p.name, n); }
    }
}

// Strip pointers / borrows down to the underlying TY_NAMED and return
// its `name`. Returns "" when the type isn't a plain named ref —
// generics, function pointers, etc. fall through and the receiver
// lookup uses the bare-name fallback at the call site.
fn _type_root_name(ty: *Type) -> string {
    if ty == null { return ""; }
    if ty.kind == TY_NAMED { return ty.name; }
    if ty.kind == TY_POINTER || ty.kind == TY_BORROW || ty.kind == TY_BORROW_MUT {
        return _type_root_name(ty.inner);
    }
    if ty.kind == TY_GENERIC { return ty.name; }   // e.g. `Vector<int>` → "Vector"
    return "";
}

fn _collect_attr_fns(program: *Vector<Stmt>, dep: *HashMap<string>, attr_name: string) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN {
            let reason: ?string = _attr_reason(&s, attr_name);
            if reason.has { dep.insert(s.name, reason.val); }
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            // Methods inside `impl Type { ... }` get keyed under
            // `Type::method` so `Type::method()` calls hit only that
            // entry; we also keep the bare name as a fallback for
            // `obj.method()` style calls where the call site can't tell
            // the receiver type without type info.
            let mut owner: string = "";
            if s.impl_target != null && s.impl_target.name != null { owner = s.impl_target.name; }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                let reason: ?string = _attr_reason(&m, attr_name);
                if !reason.has { continue; }
                let rv: string = reason.val;
                if !owner.eq("") { dep.insert(owner.concat("::").concat(m.name), rv); }
                // Only register the bare-name fallback if nothing's
                // there yet — preserves the older (and more specific)
                // entry when two impls share a method name.
                if !dep.contains(m.name) { dep.insert(m.name, rv); }
            }
        }
    }
}

// Returns the attribute's reason string, or null if the item doesn't
// carry the attribute. Empty string means the attribute was present
// without an argument (e.g. `@deprecated`).
fn _attr_reason(s: *Stmt, attr_name: string) -> ?string {
    if s == null || s.attrs == null { return none(); }
    for let i: i32 = 0; i < s.attrs.len(); i++ {
        let a: Attr = s.attrs.get(i);
        if !a.name.eq(attr_name) { continue; }
        if a.args == null || a.args.len() == 0 { return some(""); }
        let v: Expr = a.args.get(0);
        if v.kind == EX_STRING { return some(v.str_val); }
        return some("");
    }
    return none();
}

fn _scan_calls_in_body(t: *Typer, body: *Vector<Stmt>, dep: *HashMap<string>, lint_code: string, what: string, scope: *HashMap<string>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        _scan_calls_in_stmt(t, &s, dep, lint_code, what, scope);
    }
}

fn _scan_calls_in_stmt(t: *Typer, s: *Stmt, dep: *HashMap<string>, lint_code: string, what: string, scope: *HashMap<string>) {
    if s == null { return; }
    // Stmt / block-level opt-out — `@allow("deprecated-fn")` on the
    // let, defer, block, if, while, etc. mutes the warning for every
    // call inside this stmt's subtree. Bubbling stops here so a
    // narrower scope below won't accidentally re-enable.
    if _has_allow(s, lint_code) { return; }
    if s.let_value != null { _scan_calls_in_expr(t, s.let_value, dep, lint_code, what, scope); }
    if s.expr_value != null { _scan_calls_in_expr(t, s.expr_value, dep, lint_code, what, scope); }
    if s.cond != null { _scan_calls_in_expr(t, s.cond, dep, lint_code, what, scope); }
    if s.for_step != null { _scan_calls_in_expr(t, s.for_step, dep, lint_code, what, scope); }
    // Record `let name: Type = ...` into the receiver-resolution
    // scope so `name.method()` farther down resolves to
    // `Type::method` instead of falling back to the bare name. Only
    // annotated lets contribute — untyped bindings stay invisible to
    // the heuristic.
    if s.kind == ST_LET && s.let_ty != null {
        let n: string = _type_root_name(s.let_ty);
        if !n.eq("") { scope.insert(s.name, n); }
    }
    if s.then_body != null { _scan_calls_in_body(t, s.then_body, dep, lint_code, what, scope); }
    if s.else_body != null { _scan_calls_in_body(t, s.else_body, dep, lint_code, what, scope); }
}

fn _scan_calls_in_expr(t: *Typer, e: *Expr, dep: *HashMap<string>, lint_code: string, what: string, scope: *HashMap<string>) {
    if e == null { return; }
    if e.kind == EX_CALL && e.lhs != null {
        let head: *Expr = e.lhs;
        let mut key: string = "";
        let mut display: string = "";
        if head.kind == EX_PATH {
            // `Type::method` — qualified key, strict (no bare fallback).
            key = head.str_val.concat("::").concat(head.field);
            display = key;
        } else if head.kind == EX_IDENT {
            key = head.str_val; display = head.str_val;
        } else if head.kind == EX_MEMBER {
            // `obj.method()` — try to resolve `obj` to its declared
            // type via the local scope. When the receiver type IS
            // known, only the qualified `Type::method` key is
            // consulted (no bare-name fallback) so an annotated
            // method in one impl doesn't bleed into unrelated impls
            // that share the method name. When the receiver type
            // can't be resolved (chained expressions, untyped let,
            // etc.) we still fall back to the bare method name.
            let method: string = head.field;
            let mut receiver_known: bool = false;
            let mut qualified: string = "";
            if head.lhs != null && head.lhs.kind == EX_IDENT {
                let recv: string = head.lhs.str_val;
                if scope.contains(recv) {
                    receiver_known = true;
                    let ty_name: string = scope.get(recv);
                    qualified = ty_name.concat("::").concat(method);
                }
            }
            if receiver_known {
                key = qualified; display = qualified;
            } else {
                key = method; display = method;
            }
        }
        if !key.eq("") && dep.contains(key) {
            let reason: string = dep.get(key);
            let mut msg: string = "function `".concat(display).concat("` is ").concat(what);
            if !reason.eq("") { msg = msg.concat(": ").concat(reason); }
            t.warn(e.line, e.column, lint_code, msg);
        }
    }
    if e.lhs != null { _scan_calls_in_expr(t, e.lhs, dep, lint_code, what, scope); }
    if e.rhs != null { _scan_calls_in_expr(t, e.rhs, dep, lint_code, what, scope); }
    if e.operand != null { _scan_calls_in_expr(t, e.operand, dep, lint_code, what, scope); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _scan_calls_in_expr(t, &a, dep, lint_code, what, scope);
        }
    }
}

// Flow-sensitive null-deref lint. For each fn body we walk stmts in
// source order keeping a small map `name → null?` derived from let
// inits and assignments. Whenever an expression dereferences (or
// member-accesses) an identifier we know to be currently null, we
// emit `null-deref` at the deref site. Reassigning the var to a
// non-null expression clears the flag; conditional branches reset
// the map for that scope since we can't track per-branch state
// without a full data-flow framework.
//
// What this catches:
//   let p: *T = null;
//   p.foo();              // null-deref
//   *p                    // null-deref
//
//   let p: *T = null;
//   if c { p = make(); }
//   p.foo();              // null-deref (branch may have skipped the init)
//
// What it doesn't (yet):
//   - flow through fn parameters (no annotation for "may be null")
//   - aliases (`let q = p;` doesn't propagate the null bit)
//   - mutable rebinding after early-return on null
pub fn analysis_null_deref(t: *Typer, program: *Vector<Stmt>) {
    // First pass: for every fn, identify which param indices are
    // dereferenced (or member-accessed) somewhere in the body
    // WITHOUT a preceding null-check. Those params are "non-null
    // required" — passing null literal to them at a call site is
    // an immediate crash.
    let deref_params: *HashMap<string> = HashMap::new();   // fn name -> ","-joined indices
    _ndp_collect_param_derefs(program, deref_params);

    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            if _has_allow(&s, "null-deref") { continue; }
            t.current_origin = s.origin;
            let nulls: *HashMap<bool> = HashMap::new();
            _scan_null_body(t, s.fn_body, nulls);
            // Interprocedural pass: at each call site, look up
            // the callee's deref-param set and warn for null args.
            _ndp_check_calls_in_body(t, s.fn_body, deref_params);
            nulls.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null { continue; }
                if _has_allow(&m, "null-deref") { continue; }
                t.current_origin = m.origin;
                let nulls: *HashMap<bool> = HashMap::new();
                _scan_null_body(t, m.fn_body, nulls);
                _ndp_check_calls_in_body(t, m.fn_body, deref_params);
                nulls.free();
            }
        }
    }
    deref_params.free();
}

// Compute which param indices are dereferenced unconditionally inside
// each fn body. "Unconditionally" = the body has no `if p == null`
// or `if p != null` guard ANYWHERE protecting the access. The result
// is conservative: if the body looks tricky, we don't include the
// index.
fn _ndp_collect_param_derefs(program: *Vector<Stmt>, deref_params: *HashMap<string>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && s.fn_params != null {
            _ndp_index_one_fn(&s, deref_params);
        }
        if s.kind == ST_IMPL && s.impl_methods != null && s.impl_target != null {
            let tname: string = "";
            if s.impl_target.kind == TY_NAMED { tname = s.impl_target.name; }
            else if s.impl_target.kind == TY_GENERIC { tname = s.impl_target.name; }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || m.fn_params == null { continue; }
                _ndp_index_one_fn(&m, deref_params);
                if !tname.eq("") {
                    // Also index under `<Type>::<method>` so callers
                    // doing `x.method(null)` can resolve.
                    let key: string = tname.concat("::").concat(m.name);
                    if deref_params.contains(m.name) {
                        deref_params.insert(key, deref_params.get(m.name));
                    }
                }
            }
        }
    }
}
fn _ndp_index_one_fn(m: *Stmt, deref_params: *HashMap<string>) {
    // Walk the body in source order. For each param, find the FIRST
    // event that mentions it: a guard (`if p == null` cond) or a
    // deref. A guard-first means the body handles null; a deref-first
    // means the body relies on caller-supplied non-null. Only the
    // latter set requires non-null args.
    let unprotected: *HashMap<bool> = HashMap::new();   // param -> first-seen-was-deref
    let seen_guard: *HashMap<bool> = HashMap::new();
    _ndp_walk_order(m.fn_body, unprotected, seen_guard);
    let mut idxs: string = "";
    for let i: i32 = 0; i < m.fn_params.len(); i++ {
        let p: Param = m.fn_params.get(i);
        if p.ty == null || p.ty.kind != TY_POINTER { continue; }
        if !unprotected.contains(p.name) { continue; }
        if !unprotected.get(p.name) { continue; }   // guarded first
        if idxs.eq("") { idxs = i.to_string(); }
        else { idxs = idxs.concat(",").concat(i.to_string()); }
    }
    unprotected.free(); seen_guard.free();
    if !idxs.eq("") {
        deref_params.insert(m.name, idxs);
    }
}
// Walks body in source order. For each name, the first event wins:
// guard sets `unprotected[name] = false` (and never overwritten),
// deref sets `unprotected[name] = true` if no entry exists yet.
fn _ndp_walk_order(body: *Vector<Stmt>, unprotected: *HashMap<bool>, seen_guard: *HashMap<bool>) {
    if body == null { return; }
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        // Process cond before bodies — a guard registers before
        // the protected uses inside the branch.
        if s.cond != null {
            let gnames: *Vector<string> = Vector::new();
            _ndp_collect_guarded_names(s.cond, gnames);
            for let j: i32 = 0; j < gnames.len(); j++ {
                let n: string = gnames.get(j);
                if !unprotected.contains(n) {
                    unprotected.insert(n, false);   // guard-first
                }
                seen_guard.insert(n, true);
            }
            // Also check derefs in the cond expression itself.
            _ndp_record_derefs_in_expr_ordered(s.cond, unprotected, seen_guard);
            gnames.free();
        }
        if s.expr_value != null { _ndp_record_derefs_in_expr_ordered(s.expr_value, unprotected, seen_guard); }
        if s.let_value != null { _ndp_record_derefs_in_expr_ordered(s.let_value, unprotected, seen_guard); }
        if s.then_body != null { _ndp_walk_order(s.then_body, unprotected, seen_guard); }
        if s.else_body != null { _ndp_walk_order(s.else_body, unprotected, seen_guard); }
    }
}
fn _ndp_collect_guarded_names(e: *Expr, names: *Vector<string>) {
    if e == null { return; }
    if e.kind == EX_BINARY && (e.op_code == OP_EQ || e.op_code == OP_NE)
       && e.lhs != null && e.rhs != null {
        if e.lhs.kind == EX_IDENT && e.rhs.kind == EX_NULL { names.push(e.lhs.str_val); }
        if e.rhs.kind == EX_IDENT && e.lhs.kind == EX_NULL { names.push(e.rhs.str_val); }
    }
    if e.lhs != null { _ndp_collect_guarded_names(e.lhs, names); }
    if e.rhs != null { _ndp_collect_guarded_names(e.rhs, names); }
    if e.operand != null { _ndp_collect_guarded_names(e.operand, names); }
}
fn _ndp_record_derefs_in_expr_ordered(e: *Expr, unprotected: *HashMap<bool>,
                                     seen_guard: *HashMap<bool>) {
    if e == null { return; }
    let target: string = _ndp_deref_target(e);
    if !target.eq("") && !unprotected.contains(target) {
        // First event for this name is a deref → mark unprotected.
        unprotected.insert(target, true);
    }
    if e.lhs != null { _ndp_record_derefs_in_expr_ordered(e.lhs, unprotected, seen_guard); }
    if e.rhs != null { _ndp_record_derefs_in_expr_ordered(e.rhs, unprotected, seen_guard); }
    if e.operand != null { _ndp_record_derefs_in_expr_ordered(e.operand, unprotected, seen_guard); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _ndp_record_derefs_in_expr_ordered(&a, unprotected, seen_guard);
        }
    }
}
fn _ndp_deref_target(e: *Expr) -> string {
    if e == null { return ""; }
    if e.kind == EX_UNARY && e.op_code == UN_DEREF && e.operand != null
       && e.operand.kind == EX_IDENT { return e.operand.str_val; }
    if e.kind == EX_MEMBER && e.lhs != null && e.lhs.kind == EX_IDENT { return e.lhs.str_val; }
    if e.kind == EX_INDEX && e.lhs != null && e.lhs.kind == EX_IDENT { return e.lhs.str_val; }
    return "";
}
fn _ndp_derefs_in_expr(e: *Expr, derefed: *HashMap<bool>) {
    if e == null { return; }
    // `*p`
    if e.kind == EX_UNARY && e.op_code == UN_DEREF && e.operand != null
       && e.operand.kind == EX_IDENT {
        derefed.insert(e.operand.str_val, true);
    }
    // `p.field` and `p.method(...)` — both implicitly deref p.
    if e.kind == EX_MEMBER && e.lhs != null && e.lhs.kind == EX_IDENT {
        derefed.insert(e.lhs.str_val, true);
    }
    // `p[i]` — also deref.
    if e.kind == EX_INDEX && e.lhs != null && e.lhs.kind == EX_IDENT {
        derefed.insert(e.lhs.str_val, true);
    }
    if e.lhs != null { _ndp_derefs_in_expr(e.lhs, derefed); }
    if e.rhs != null { _ndp_derefs_in_expr(e.rhs, derefed); }
    if e.operand != null { _ndp_derefs_in_expr(e.operand, derefed); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _ndp_derefs_in_expr(&a, derefed);
        }
    }
}
// Walk a body and flag every call site where a null literal hits
// a known-non-null-required param of the callee.
fn _ndp_check_calls_in_body(t: *Typer, body: *Vector<Stmt>,
                           deref_params: *HashMap<string>) {
    if body == null { return; }
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.expr_value != null { _ndp_check_calls_in_expr(t, s.expr_value, deref_params); }
        if s.let_value != null { _ndp_check_calls_in_expr(t, s.let_value, deref_params); }
        if s.cond != null { _ndp_check_calls_in_expr(t, s.cond, deref_params); }
        if s.then_body != null { _ndp_check_calls_in_body(t, s.then_body, deref_params); }
        if s.else_body != null { _ndp_check_calls_in_body(t, s.else_body, deref_params); }
    }
}
fn _ndp_check_calls_in_expr(t: *Typer, e: *Expr, deref_params: *HashMap<string>) {
    if e == null { return; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT
       && e.args != null {
        let fname: string = e.lhs.str_val;
        if deref_params.contains(fname) {
            let idxs: string = deref_params.get(fname);
            // Parse comma-joined indices.
            let mut buf: string = "";
            let n: i32 = idxs.len();
            for let k: i32 = 0; k <= n; k++ {
                if k == n || idxs.at(k).to_int() == 44 {
                    if !buf.eq("") {
                        let idx: i32 = _ndp_atoi(buf);
                        if idx >= 0 && idx < e.args.len() {
                            let a: Expr = e.args.get(idx);
                            if a.kind == EX_NULL {
                                t.warn(a.line, a.column, "null-deref",
                                    "passing `null` to `".concat(fname).concat("` — param at index ").concat(idx.to_string()).concat(" is dereferenced without a null-check; this call will segfault"));
                            }
                        }
                        buf = "";
                    }
                } else { buf = buf.concat(idxs.substring(k, k + 1)); }
            }
        }
    }
    if e.lhs != null { _ndp_check_calls_in_expr(t, e.lhs, deref_params); }
    if e.rhs != null { _ndp_check_calls_in_expr(t, e.rhs, deref_params); }
    if e.operand != null { _ndp_check_calls_in_expr(t, e.operand, deref_params); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _ndp_check_calls_in_expr(t, &a, deref_params);
        }
    }
}
fn _ndp_atoi(s: string) -> i32 {
    let mut n: i32 = 0;
    for let i: i32 = 0; i < s.len(); i++ {
        let c: i32 = s.at(i).to_int();
        if c < 48 || c > 57 { return -1; }
        n = n * 10 + (c - 48);
    }
    return n;
}

fn _scan_null_body(t: *Typer, body: *Vector<Stmt>, nulls: *HashMap<bool>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        _scan_null_stmt(t, &s, nulls);
    }
}

fn _scan_null_stmt(t: *Typer, s: *Stmt, nulls: *HashMap<bool>) {
    if s == null { return; }
    // Walk RHS exprs first so derefs inside them get checked before
    // the let-binding decides anything.
    if s.let_value != null { _scan_null_expr(t, s.let_value, nulls); }
    if s.expr_value != null { _scan_null_expr(t, s.expr_value, nulls); }
    if s.cond != null { _scan_null_expr(t, s.cond, nulls); }
    if s.for_step != null { _scan_null_expr(t, s.for_step, nulls); }

    // Track the binding.
    if s.kind == ST_LET && s.name != null && !s.name.eq("") {
        if s.let_value != null && s.let_value.kind == EX_NULL {
            nulls.insert(s.name, true);
        } else {
            // Defined to something concrete — definitely not null.
            if nulls.contains(s.name) { nulls.insert(s.name, false); }
        }
    }
    if s.expr_value != null && s.expr_value.kind == EX_ASSIGN
       && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT
       && s.expr_value.rhs != null {
        let nm: string = s.expr_value.lhs.str_val;
        if s.expr_value.rhs.kind == EX_NULL { nulls.insert(nm, true); }
        else if nulls.contains(nm) { nulls.insert(nm, false); }
    }
    // Conditional + loop bodies invalidate our knowledge — we don't
    // track per-branch state. Anything we know about a name before
    // entering an if/while/for might be wrong on the other side.
    if s.then_body != null {
        _scan_null_body(t, s.then_body, nulls);
        _invalidate_assigned(s.then_body, nulls);
    }
    if s.else_body != null {
        _scan_null_body(t, s.else_body, nulls);
        _invalidate_assigned(s.else_body, nulls);
    }
}

// After running a conditional/loop body, mark every name that body
// might have assigned as "unknown" so subsequent stmts don't trust
// the pre-branch null bit. Simple over-approximation.
fn _invalidate_assigned(body: *Vector<Stmt>, nulls: *HashMap<bool>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.expr_value != null && s.expr_value.kind == EX_ASSIGN
           && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT {
            let nm: string = s.expr_value.lhs.str_val;
            if nulls.contains(nm) { nulls.insert(nm, false); }
        }
        if s.then_body != null { _invalidate_assigned(s.then_body, nulls); }
        if s.else_body != null { _invalidate_assigned(s.else_body, nulls); }
    }
}

// Walk an expr, emitting `null-deref` at every deref / member /
// method call against an identifier that's currently known-null.
fn _scan_null_expr(t: *Typer, e: *Expr, nulls: *HashMap<bool>) {
    if e == null { return; }
    // *p — direct deref
    if e.kind == EX_UNARY && e.op_code == UN_DEREF && e.operand != null {
        _check_null_target(t, e.operand, nulls, e.line, e.column);
    }
    // p.field — member access does an implicit deref
    if e.kind == EX_MEMBER && e.lhs != null {
        _check_null_target(t, e.lhs, nulls, e.line, e.column);
    }
    // p.method(...) — same shape as member
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER
       && e.lhs.lhs != null {
        _check_null_target(t, e.lhs.lhs, nulls, e.line, e.column);
    }
    // p[i] — index deref
    if e.kind == EX_INDEX && e.lhs != null {
        _check_null_target(t, e.lhs, nulls, e.line, e.column);
    }
    if e.lhs != null { _scan_null_expr(t, e.lhs, nulls); }
    if e.rhs != null { _scan_null_expr(t, e.rhs, nulls); }
    if e.operand != null { _scan_null_expr(t, e.operand, nulls); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _scan_null_expr(t, &a, nulls);
        }
    }
}

fn _check_null_target(t: *Typer, target: *Expr, nulls: *HashMap<bool>, line: i32, col: i32) {
    if target == null { return; }
    // Direct `*null` / `null.foo()` — definite bug.
    if target.kind == EX_NULL {
        t.warn(line, col, "null-deref",
            "dereferencing the `null` literal — this will segfault at runtime");
        return;
    }
    if target.kind == EX_IDENT && nulls.contains(target.str_val) && nulls.get(target.str_val) {
        t.warn(line, col, "null-deref",
            "`".concat(target.str_val).concat("` is `null` at this point — deref will segfault. Reassign or guard with `if ").concat(target.str_val).concat(" != null { … }`"));
    }
}

// Catches `free(x)` / `defer free(x)` where `x` is a Glide `string`.
// Strings in Glide are always allocated through the per-coro arena
// (palloc), so calling libc `free()` on one corrupts the heap and
// double-frees on the next arena drop. The arena handles cleanup
// automatically — the right fix is to delete the `free` call.
//
// Scope is intentionally narrow: only `let s: string = ...; free(s)`
// fires the warning. Vector / HashMap aren't included because their
// destructors (`p.free()` on a struct's `*Vector<…>` field) are
// legitimate uses; an interprocedural check would be needed to
// distinguish "this is the destructor releasing its own field" from
// "this is user code reaching into an arena-managed value".
pub fn analysis_bad_free(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            if _has_allow(&s, "bad-free") { continue; }
            t.current_origin = s.origin;
            let tys: *HashMap<string> = HashMap::new();
            _bf_scan_body(t, s.fn_body, tys, "");
            tys.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            // Detect a collection self-destructor: `impl Vector<T> {
            // fn free(self: *Vector<T>) { ... } }`. Only inside such
            // a method is `free(self as *void)` a legitimate pattern;
            // outside, calling libc free on a Vector / HashMap value
            // leaks its internal buffers.
            let impl_target: string = "";
            if s.impl_target != null {
                if s.impl_target.kind == TY_NAMED { impl_target = s.impl_target.name; }
                else if s.impl_target.kind == TY_GENERIC { impl_target = s.impl_target.name; }
            }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null { continue; }
                if _has_allow(&m, "bad-free") { continue; }
                if s.origin != null && !s.origin.eq("") {
                    t.current_origin = s.origin;
                }
                let mut self_destructor_of: string = "";
                if m.name.eq("free") && (impl_target.eq("Vector") || impl_target.eq("HashMap")) {
                    self_destructor_of = impl_target;
                }
                let tys: *HashMap<string> = HashMap::new();
                _bf_scan_body(t, m.fn_body, tys, self_destructor_of);
                tys.free();
            }
        }
    }
}

fn _bf_scan_body(t: *Typer, body: *Vector<Stmt>, tys: *HashMap<string>, self_destructor_of: string) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        _bf_scan_stmt(t, &s, tys, self_destructor_of);
    }
}

fn _bf_scan_stmt(t: *Typer, s: *Stmt, tys: *HashMap<string>, self_destructor_of: string) {
    if s == null { return; }
    if s.kind == ST_LET && s.name != null && !s.name.eq("") && s.let_ty != null {
        // Use bad-free-specific tag to distinguish managed value types
        // (`string` = arena string, must not free) from raw pointer
        // buffers (`*string` = char-array allocation, free is fine).
        tys.insert(s.name, _bf_ty_tag_for_free(s.let_ty));
    }
    if s.expr_value != null { _bf_check_expr(t, s.expr_value, tys, self_destructor_of); }
    if s.let_value != null { _bf_check_expr(t, s.let_value, tys, self_destructor_of); }
    if s.cond != null { _bf_check_expr(t, s.cond, tys, self_destructor_of); }
    if s.then_body != null { _bf_scan_body(t, s.then_body, tys, self_destructor_of); }
    if s.else_body != null { _bf_scan_body(t, s.else_body, tys, self_destructor_of); }
}

fn _bf_check_expr(t: *Typer, e: *Expr, tys: *HashMap<string>, self_destructor_of: string) {
    if e == null { return; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT
       && e.lhs.str_val.eq("free")
       && e.args != null && e.args.len() == 1 {
        let arg: Expr = e.args.get(0);
        // Peel `as *void` / `as *u8` / any cast.
        let mut probe: *Expr = &arg;
        while probe != null && probe.kind == EX_CAST { probe = probe.lhs; }
        if probe != null && probe.kind == EX_IDENT
           && tys.contains(probe.str_val) {
            let tag: string = tys.get(probe.str_val);
            if tag.eq("string") {
                t.warn(e.line, e.column, "bad-free",
                    "`free(".concat(probe.str_val).concat(")` corrupts the heap — strings are arena-managed and freed automatically. Remove this line."));
            } else if tag.eq("Vector") || tag.eq("HashMap") {
                // Vector / HashMap own internal buffers (keys/values/
                // data array). libc free on the outer struct leaks
                // those buffers; .free() releases everything.
                //
                // Exemption: inside `impl Vector { fn free(self) { … } }`
                // (or HashMap), `free(self as *void)` is the LAST step
                // of the destructor releasing the outer struct. Only
                // skip when the freed name is literally `self` AND
                // the enclosing fn is that exact destructor.
                if probe.str_val.eq("self") && tag.eq(self_destructor_of) {
                    // legitimate destructor finalizer
                } else {
                    t.warn(e.line, e.column, "bad-free",
                        "`free(".concat(probe.str_val).concat(")` leaks `").concat(probe.str_val).concat("`'s internal buffers — call `").concat(probe.str_val).concat(".free()` so the destructor releases keys/values/data first."));
                }
            }
        }
    }
    if e.lhs != null { _bf_check_expr(t, e.lhs, tys, self_destructor_of); }
    if e.rhs != null { _bf_check_expr(t, e.rhs, tys, self_destructor_of); }
    if e.operand != null { _bf_check_expr(t, e.operand, tys, self_destructor_of); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _bf_check_expr(t, &a, tys, self_destructor_of);
        }
    }
}

// Tag specialized for bad-free's rules. Distinguishes managed value
// types (Glide `string`) from raw buffers (`*string` = char-array).
// `*Vector<T>` / `*HashMap<V>` still resolve to their collection
// name since those are always passed as pointers.
fn _bf_ty_tag_for_free(ty: *Type) -> string {
    if ty == null { return ""; }
    // `string` value — arena-managed, must not be freed.
    if ty.kind == TY_NAMED && ty.name.eq("string") { return "string"; }
    // `*string` is a raw char-array — `free()` is fine, skip.
    if ty.kind == TY_POINTER && ty.inner != null
       && ty.inner.kind == TY_NAMED && ty.inner.name.eq("string") {
        return "";
    }
    // Pointer to Vector / HashMap (whether TY_NAMED or TY_GENERIC).
    if ty.kind == TY_POINTER && ty.inner != null {
        let mut inner_name: string = "";
        if ty.inner.kind == TY_NAMED { inner_name = ty.inner.name; }
        else if ty.inner.kind == TY_GENERIC { inner_name = ty.inner.name; }
        if inner_name.eq("Vector") || inner_name.eq("HashMap") { return inner_name; }
        // Other pointer types — return the inner name as a fallback
        // so callers can still match (e.g. for tracking impl targets).
        return inner_name;
    }
    if ty.kind == TY_GENERIC { return ty.name; }
    return "";
}

// Reduce a Type to a short tag we can store in a HashMap<string>.
// Returns "" for types we don't care about.
fn _bf_ty_tag(ty: *Type) -> string {
    if ty == null { return ""; }
    if ty.kind == TY_NAMED { return ty.name; }
    if ty.kind == TY_POINTER && ty.inner != null {
        // *Vector<T> / *HashMap<V> / *T — keep the inner head name.
        if ty.inner.kind == TY_NAMED { return ty.inner.name; }
        if ty.inner.kind == TY_GENERIC { return ty.inner.name; }
    }
    if ty.kind == TY_GENERIC { return ty.name; }
    return "";
}

// ============================================================================
// === Batch of bug-prevention lints                                        ===
// ============================================================================
// Ten lints sharing a common helper layer: type-tag tracking via let
// bindings, scope-aware walking of fn bodies, and a thin set of pure
// heuristics. Each one is intentionally narrow — we'd rather miss a
// case than flag legitimate code, so suppressions stay rare.

// Walk every fn / impl method, invoking `cb` with each one paired with
// the inferred origin file. `cb` is responsible for the body analysis.
// Centralizes the boilerplate every per-fn lint repeats.

// ---------- string-eq-with-== --------------------------------------------
// Glide strings are NUL-terminated `const char*`. The C `==` compares
// pointers, not content — `s == "foo"` is almost always wrong (returns
// true only when both sides reference the same interned literal).
// `.eq()` does the actual byte comparison.
pub fn analysis_string_eq_op(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null {
            if _has_allow(&s, "string-eq-op") { continue; }
            t.current_origin = s.origin;
            let tys: *HashMap<string> = HashMap::new();
            _seq_scan_body(t, s.fn_body, tys);
            tys.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null { continue; }
                if _has_allow(&m, "string-eq-op") { continue; }
                if s.origin != null && !s.origin.eq("") { t.current_origin = s.origin; }
                let tys: *HashMap<string> = HashMap::new();
                _seq_scan_body(t, m.fn_body, tys);
                tys.free();
            }
        }
    }
}
fn _seq_scan_body(t: *Typer, body: *Vector<Stmt>, tys: *HashMap<string>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null && !s.name.eq("") && s.let_ty != null {
            tys.insert(s.name, _bf_ty_tag(s.let_ty));
        }
        if s.expr_value != null { _seq_check_expr(t, s.expr_value, tys); }
        if s.let_value != null { _seq_check_expr(t, s.let_value, tys); }
        if s.cond != null { _seq_check_expr(t, s.cond, tys); }
        if s.then_body != null { _seq_scan_body(t, s.then_body, tys); }
        if s.else_body != null { _seq_scan_body(t, s.else_body, tys); }
    }
}
fn _seq_check_expr(t: *Typer, e: *Expr, tys: *HashMap<string>) {
    if e == null { return; }
    if e.kind == EX_BINARY && (e.op_code == OP_EQ || e.op_code == OP_NE)
       && e.lhs != null && e.rhs != null {
        // `s == null` / `s != null` is a legitimate pointer-presence
        // check — strings ARE nullable in Glide. Skip those.
        if e.lhs.kind == EX_NULL || e.rhs.kind == EX_NULL { /* skip */ }
        else {
        let lhs_str: bool = _seq_is_string_expr(e.lhs, tys);
        let rhs_str: bool = _seq_is_string_expr(e.rhs, tys);
        if lhs_str || rhs_str {
            let op_name: string = "==";
            if e.op_code == OP_NE { op_name = "!="; }
            let suggest: string = ".eq(…)";
            if e.op_code == OP_NE { suggest = "!… .eq(…)"; }
            t.warn(e.line, e.column, "string-eq-op",
                "`".concat(op_name).concat("` on strings compares pointers, not bytes — use `").concat(suggest).concat("` for the actual comparison"));
        }
        }
    }
    if e.lhs != null { _seq_check_expr(t, e.lhs, tys); }
    if e.rhs != null { _seq_check_expr(t, e.rhs, tys); }
    if e.operand != null { _seq_check_expr(t, e.operand, tys); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _seq_check_expr(t, &a, tys);
        }
    }
}
fn _seq_is_string_expr(e: *Expr, tys: *HashMap<string>) -> bool {
    if e == null { return false; }
    if e.kind == EX_STRING { return true; }
    if e.kind == EX_IDENT && tys.contains(e.str_val) {
        return tys.get(e.str_val).eq("string");
    }
    return false;
}

// ---------- unused-import ------------------------------------------------
// `import X::specific;` where no use of `specific` is found in the
// file. Wildcard / re-export forms aren't checked (impossible without
// dragging in module metadata). False-positive risk: a name might be
// referenced via macro expansion that we don't track here.
pub fn analysis_unused_import(t: *Typer, program: *Vector<Stmt>) {
    // Collect all identifiers referenced anywhere in the file. One
    // pass; we don't separate scopes because imports are top-level.
    let used: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_IMPORT { continue; }
        _ui_collect_stmt(&s, used);
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_IMPORT { continue; }
        if _has_allow(&s, "unused-import") { continue; }
        if s.import_wildcard { continue; }
        if s.imported_items == null || s.imported_items.len() == 0 { continue; }
        t.current_origin = s.origin;
        let mut any_used: bool = false;
        for let j: i32 = 0; j < s.imported_items.len(); j++ {
            let n: string = s.imported_items.get(j);
            if used.contains(n) { any_used = true; break; }
        }
        if !any_used {
            let first: string = s.imported_items.get(0);
            t.warn(s.line, s.column, "unused-import",
                "import of `".concat(first).concat("` is never referenced in this file — remove it"));
        }
    }
    used.free();
}
fn _ui_collect_stmt(s: *Stmt, used: *HashMap<bool>) {
    if s == null { return; }
    if s.let_value != null { _ui_collect_expr(s.let_value, used); }
    if s.expr_value != null { _ui_collect_expr(s.expr_value, used); }
    if s.cond != null { _ui_collect_expr(s.cond, used); }
    if s.for_step != null { _ui_collect_expr(s.for_step, used); }
    if s.for_init != null { _ui_collect_stmt(s.for_init, used); }
    if s.scrutinee != null { _ui_collect_expr(s.scrutinee, used); }
    // Attribute args: `@derive(JsonBind)`, `@expect("code")`, `@allow("x")`,
    // procedural macro use sites. Each arg expression's idents count as
    // uses of the corresponding import.
    if s.attrs != null {
        for let i: i32 = 0; i < s.attrs.len(); i++ {
            let a: Attr = s.attrs.get(i);
            if a.args == null { continue; }
            for let j: i32 = 0; j < a.args.len(); j++ {
                let ae: Expr = a.args.get(j);
                _ui_collect_expr(&ae, used);
            }
        }
    }
    // Types appearing in annotations / signatures / fields count as uses.
    // Without this, `fn(req: *HttpRequest)` and `let r: *Router = ...` look
    // like the imports `HttpRequest` / `Router` are dead code.
    _ui_collect_type(s.let_ty, used);
    _ui_collect_type(s.fn_ret_ty, used);
    _ui_collect_type(s.impl_target, used);
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            _ui_collect_type(p.ty, used);
        }
    }
    if s.struct_fields != null {
        for let i: i32 = 0; i < s.struct_fields.len(); i++ {
            let f: Field = s.struct_fields.get(i);
            _ui_collect_type(f.ty, used);
        }
    }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let c: Stmt = s.then_body.get(i);
            _ui_collect_stmt(&c, used);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let c: Stmt = s.else_body.get(i);
            _ui_collect_stmt(&c, used);
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let c: Stmt = s.fn_body.get(i);
            _ui_collect_stmt(&c, used);
        }
    }
    if s.impl_methods != null {
        for let i: i32 = 0; i < s.impl_methods.len(); i++ {
            let c: Stmt = s.impl_methods.get(i);
            _ui_collect_stmt(&c, used);
        }
    }
    if s.arms != null {
        for let i: i32 = 0; i < s.arms.len(); i++ {
            let a: MatchArm = s.arms.get(i);
            if a.body != null {
                for let j: i32 = 0; j < a.body.len(); j++ {
                    let c: Stmt = a.body.get(j);
                    _ui_collect_stmt(&c, used);
                }
            }
        }
    }
}
fn _ui_collect_expr(e: *Expr, used: *HashMap<bool>) {
    if e == null { return; }
    if e.kind == EX_IDENT { used.insert(e.str_val, true); }
    if e.kind == EX_MEMBER && e.field != null { used.insert(e.field, true); }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT {
        used.insert(e.lhs.str_val, true);
    }
    // `Type::method(...)` — both the type and the method count as a use of
    // the imported `Type` / `method` name. Without this `Router::new()`
    // looks like Router was imported and abandoned.
    if e.kind == EX_PATH {
        if e.str_val != null { used.insert(e.str_val, true); }
        if e.field != null { used.insert(e.field, true); }
    }
    // Anonymous fns can hold params + return-type annotations that name
    // imported types. Walk those before descending into the body.
    if e.kind == EX_FNEXPR {
        if e.fn_expr_params != null {
            for let i: i32 = 0; i < e.fn_expr_params.len(); i++ {
                let p: Param = e.fn_expr_params.get(i);
                _ui_collect_type(p.ty, used);
            }
        }
        _ui_collect_type(e.cast_to, used);
        if e.fn_expr_body != null {
            for let i: i32 = 0; i < e.fn_expr_body.len(); i++ {
                let bs: Stmt = e.fn_expr_body.get(i);
                _ui_collect_stmt(&bs, used);
            }
        }
    }
    // Cast targets (`expr as *Foo`) and sizeof(Type) usages.
    if e.kind == EX_CAST || e.kind == EX_SIZEOF { _ui_collect_type(e.cast_to, used); }
    // Struct literal names the type explicitly.
    if e.kind == EX_STRUCT_LIT && e.str_val != null { used.insert(e.str_val, true); }
    if e.lhs != null { _ui_collect_expr(e.lhs, used); }
    if e.rhs != null { _ui_collect_expr(e.rhs, used); }
    if e.operand != null { _ui_collect_expr(e.operand, used); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _ui_collect_expr(&a, used);
        }
    }
}
// Walk a type tree, marking every named carrier as a use. Catches
// `*HttpRequest`, `Vector<Router>`, `?HttpResponse`, etc.
fn _ui_collect_type(t: *Type, used: *HashMap<bool>) {
    if t == null { return; }
    if t.kind == TY_NAMED && t.name != null { used.insert(t.name, true); }
    if t.kind == TY_GENERIC && t.name != null { used.insert(t.name, true); }
    if t.inner != null { _ui_collect_type(t.inner, used); }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            _ui_collect_type(&a, used);
        }
    }
    // For TY_FNPTR `args` carries the param types and `fnptr_ret` the ret.
    if t.fnptr_ret != null { _ui_collect_type(t.fnptr_ret, used); }
}

// ---------- arena-set-without-restore ------------------------------------
// `__glide_palloc_set(arena)` makes that arena the active one for all
// allocations until the next set. Without a paired `_set(prev)` (or a
// `defer __glide_palloc_set(prev)` registered immediately after), the
// arena leaks across return paths — the same bug that caused the LSP
// completion crash earlier.
pub fn analysis_arena_set_unbalanced(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "arena-set") {
            t.current_origin = s.origin;
            _asu_check_fn(t, s.fn_body, s.line, s.column);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "arena-set") { continue; }
                if s.origin != null && !s.origin.eq("") { t.current_origin = s.origin; }
                _asu_check_fn(t, m.fn_body, m.line, m.column);
            }
        }
    }
}
fn _asu_check_fn(t: *Typer, body: *Vector<Stmt>, fn_line: i32, fn_col: i32) {
    let mut sets: i32 = 0;
    let mut defer_sets: i32 = 0;
    let mut first_set_line: i32 = 0;
    let mut first_set_col: i32 = 0;
    _asu_walk(body, &sets, &defer_sets, &first_set_line, &first_set_col, false);
    // Each non-defer set must be balanced by either another set (the
    // restore) or a defer set (the restore-via-defer).
    if sets > 0 && (defer_sets + sets) < (sets * 2) {
        t.warn(first_set_line, first_set_col, "arena-set",
            "`__glide_palloc_set(arena)` has no matching restore — add `defer __glide_palloc_set(prev);` immediately after the set");
    }
}
fn _asu_walk(body: *Vector<Stmt>, sets: *i32, defer_sets: *i32,
             fline: *i32, fcol: *i32, in_defer: bool) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_DEFER && s.expr_value != null {
            // Any palloc_set inside a defer counts as a restore —
            // even `_set(prev)` carries a non-null arg, and defers
            // fire on every exit so the restore is guaranteed.
            if _asu_is_palloc_set_any(s.expr_value) { *defer_sets = *defer_sets + 1; }
        } else if s.expr_value != null && _asu_is_palloc_set_active(s.expr_value) {
            // Only `_set(<non-null>)` needs a balancing restore.
            // `_set(null)` IS a restore (drops the active arena).
            *sets = *sets + 1;
            if *fline == 0 { *fline = s.line; *fcol = s.column; }
        } else if s.expr_value != null && _asu_is_palloc_set_any(s.expr_value) {
            // Bare `_set(null)` or `_set(prev)` — count as restore.
            *defer_sets = *defer_sets + 1;
        }
        if s.then_body != null { _asu_walk(s.then_body, sets, defer_sets, fline, fcol, in_defer); }
        if s.else_body != null { _asu_walk(s.else_body, sets, defer_sets, fline, fcol, in_defer); }
    }
}
fn _asu_is_palloc_set_any(e: *Expr) -> bool {
    if e == null { return false; }
    if e.kind != EX_CALL || e.lhs == null || e.lhs.kind != EX_IDENT { return false; }
    return e.lhs.str_val.eq("__glide_palloc_set");
}
fn _asu_is_palloc_set_active(e: *Expr) -> bool {
    if !_asu_is_palloc_set_any(e) { return false; }
    if e.args == null || e.args.len() != 1 { return false; }
    let arg: Expr = e.args.get(0);
    // Treat `_set(<arena-creating call>)` as the "active set" — that's
    // the form that actually starts a per-scope arena and needs a
    // restore. `_set(prev)` / `_set(null)` / `_set(saved_var)` are
    // restores, not new sets. Heuristic: look for a call to
    // `__glide_palloc_make` somewhere inside the arg.
    return _asu_arg_creates_arena(&arg);
}
fn _asu_arg_creates_arena(e: *Expr) -> bool {
    if e == null { return false; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT
       && e.lhs.str_val.eq("__glide_palloc_make") { return true; }
    if e.lhs != null && _asu_arg_creates_arena(e.lhs) { return true; }
    if e.operand != null && _asu_arg_creates_arena(e.operand) { return true; }
    return false;
}

// ---------- coro-blocking ------------------------------------------------
// `spawn` submits a call to the M:N scheduler — if the called fn does
// sync IO (fs_read, sync TCP, blocking sleep) it stalls the worker
// thread, defeating the point. We resolve the spawn target's body and
// walk it looking for blocking helpers; for `spawn_thread` we don't
// warn (a pthread is supposed to block).
pub fn analysis_coro_blocking(t: *Typer, program: *Vector<Stmt>) {
    let blocking: *HashMap<bool> = HashMap::new();
    blocking.insert("fs_read", true);
    blocking.insert("fs_read_bytes", true);
    blocking.insert("fs_write", true);
    blocking.insert("fs_write_bytes", true);
    blocking.insert("fs_append", true);
    blocking.insert("fs_copy", true);
    blocking.insert("__glide_sleep_ms_blocking", true);
    blocking.insert("process_run", true);
    blocking.insert("http_get_sync", true);
    // Build name → body so spawn lookups can walk the target.
    let bodies: *HashMap<*Vector<Stmt>> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null { bodies.insert(s.name, s.fn_body); }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body != null { bodies.insert(m.name, m.fn_body); }
            }
        }
    }
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "coro-blocking") {
            t.current_origin = s.origin;
            _cb_scan_for_spawn(t, s.fn_body, blocking, bodies);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "coro-blocking") { continue; }
                if s.origin != null && !s.origin.eq("") { t.current_origin = s.origin; }
                _cb_scan_for_spawn(t, m.fn_body, blocking, bodies);
            }
        }
    }
    bodies.free();
    blocking.free();
}
fn _cb_scan_for_spawn(t: *Typer, body: *Vector<Stmt>, blocking: *HashMap<bool>,
                     bodies: *HashMap<*Vector<Stmt>>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_SPAWN && !s.is_spawn_thread && s.expr_value != null
           && s.expr_value.kind == EX_CALL && s.expr_value.lhs != null
           && s.expr_value.lhs.kind == EX_IDENT {
            let tgt: string = s.expr_value.lhs.str_val;
            // Direct: spawn fs_read(...) — blocking name spawned.
            if blocking.contains(tgt) {
                t.warn(s.expr_value.line, s.expr_value.column, "coro-blocking",
                    "`".concat(tgt).concat("` blocks the worker thread — use `spawn_thread` instead of `spawn`"));
            } else if bodies.contains(tgt) {
                let target_body: *Vector<Stmt> = bodies.get(tgt);
                _cb_walk_for_blocking(t, target_body, blocking, tgt, s.line);
            }
        }
        if s.then_body != null { _cb_scan_for_spawn(t, s.then_body, blocking, bodies); }
        if s.else_body != null { _cb_scan_for_spawn(t, s.else_body, blocking, bodies); }
    }
}
fn _cb_walk_for_blocking(t: *Typer, body: *Vector<Stmt>, blocking: *HashMap<bool>,
                        spawn_target: string, spawn_line: i32) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.expr_value != null { _cb_check_blocking_call(t, s.expr_value, blocking, spawn_target); }
        if s.let_value != null { _cb_check_blocking_call(t, s.let_value, blocking, spawn_target); }
        if s.then_body != null { _cb_walk_for_blocking(t, s.then_body, blocking, spawn_target, spawn_line); }
        if s.else_body != null { _cb_walk_for_blocking(t, s.else_body, blocking, spawn_target, spawn_line); }
    }
}
fn _cb_check_blocking_call(t: *Typer, e: *Expr, blocking: *HashMap<bool>, spawned: string) {
    if e == null { return; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT
       && blocking.contains(e.lhs.str_val) {
        t.warn(e.line, e.column, "coro-blocking",
            "`".concat(e.lhs.str_val).concat("` blocks the worker thread — reached from `spawn ").concat(spawned).concat("()`. Use `spawn_thread` instead, or call the async variant"));
    }
    if e.lhs != null { _cb_check_blocking_call(t, e.lhs, blocking, spawned); }
    if e.rhs != null { _cb_check_blocking_call(t, e.rhs, blocking, spawned); }
    if e.operand != null { _cb_check_blocking_call(t, e.operand, blocking, spawned); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _cb_check_blocking_call(t, &a, blocking, spawned);
        }
    }
}

// ---------- unhandled-result ---------------------------------------------
// Calling a `fn -> !T` and discarding the value silently swallows the
// error. Accepted forms: `x?`, `let _ = …`, `let bound = …`, `match …`,
// or `return …`. Bare `ST_EXPR` with a `!T`-returning call is the bug.
//
// Method calls (`x.foo()`) are resolved by looking up the receiver's
// declared type from let bindings and consulting a per-type method
// table — so `Conn.write -> int` and `TcpStream.write -> !int` get
// distinguished even though they share a method name.
pub fn analysis_unhandled_result(t: *Typer, program: *Vector<Stmt>) {
    let ret_kinds: *HashMap<i32> = HashMap::new();
    let method_rets: *HashMap<i32> = HashMap::new();
    _ur_collect_sigs(program, ret_kinds, method_rets);
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "unhandled-result") {
            t.current_origin = s.origin;
            let tys: *HashMap<string> = HashMap::new();
            _ur_seed_params(s.fn_params, tys);
            _ur_walk(t, s.fn_body, ret_kinds, method_rets, tys);
            tys.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "unhandled-result") { continue; }
                if s.origin != null && !s.origin.eq("") { t.current_origin = s.origin; }
                let tys: *HashMap<string> = HashMap::new();
                _ur_seed_params(m.fn_params, tys);
                _ur_walk(t, m.fn_body, ret_kinds, method_rets, tys);
                tys.free();
            }
        }
    }
    ret_kinds.free();
    method_rets.free();
}
fn _ur_seed_params(params: *Vector<Param>, tys: *HashMap<string>) {
    if params == null { return; }
    for let i: i32 = 0; i < params.len(); i++ {
        let p: Param = params.get(i);
        if p.ty != null && !p.name.eq("") {
            tys.insert(p.name, _bf_ty_tag(p.ty));
        }
    }
}
fn _ur_collect_sigs(program: *Vector<Stmt>, ret_kinds: *HashMap<i32>,
                    method_rets: *HashMap<i32>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_ret_ty != null {
            ret_kinds.insert(s.name, s.fn_ret_ty.kind);
        }
        if s.kind == ST_IMPL && s.impl_methods != null && s.impl_target != null {
            let tname: string = "";
            if s.impl_target.kind == TY_NAMED { tname = s.impl_target.name; }
            else if s.impl_target.kind == TY_GENERIC { tname = s.impl_target.name; }
            if tname.eq("") { continue; }
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_ret_ty != null {
                    let key: string = tname.concat("::").concat(m.name);
                    method_rets.insert(key, m.fn_ret_ty.kind);
                }
            }
        }
    }
}
fn _ur_walk(t: *Typer, body: *Vector<Stmt>, ret_kinds: *HashMap<i32>,
            method_rets: *HashMap<i32>, tys: *HashMap<string>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null && !s.name.eq("") && s.let_ty != null {
            tys.insert(s.name, _bf_ty_tag(s.let_ty));
        }
        if s.kind == ST_EXPR && s.expr_value != null {
            _ur_check_call(t, s.expr_value, ret_kinds, method_rets, tys);
        }
        if s.then_body != null { _ur_walk(t, s.then_body, ret_kinds, method_rets, tys); }
        if s.else_body != null { _ur_walk(t, s.else_body, ret_kinds, method_rets, tys); }
        if s.fn_body != null { _ur_walk(t, s.fn_body, ret_kinds, method_rets, tys); }
    }
}
fn _ur_check_call(t: *Typer, e: *Expr, ret_kinds: *HashMap<i32>,
                  method_rets: *HashMap<i32>, tys: *HashMap<string>) {
    if e == null { return; }
    // `?` is enough — already propagating.
    if e.kind == EX_UNARY && e.op_code == UN_TRY { return; }
    if e.kind != EX_CALL || e.lhs == null { return; }

    let fn_label: string = "";
    let mut k: i32 = -1;

    if e.lhs.kind == EX_IDENT {
        // Bare fn: `foo(…)`.
        let n: string = e.lhs.str_val;
        if !ret_kinds.contains(n) { return; }
        fn_label = n;
        k = ret_kinds.get(n);
    } else if e.lhs.kind == EX_MEMBER && e.lhs.field != null
              && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT {
        // Method: `x.foo(…)`. Resolve x's declared type and look up
        // the per-type method table. Skip when receiver type isn't
        // tracked (param / let-without-annotation / chain receiver).
        let recv: string = e.lhs.lhs.str_val;
        if !tys.contains(recv) { return; }
        let tname: string = tys.get(recv);
        if tname.eq("") { return; }
        let key: string = tname.concat("::").concat(e.lhs.field);
        if !method_rets.contains(key) { return; }
        fn_label = recv.concat(".").concat(e.lhs.field);
        k = method_rets.get(key);
    } else {
        return;
    }

    if k == TY_RESULT || k == TY_OPT_RESULT {
        t.warn(e.line, e.column, "unhandled-result",
            "`".concat(fn_label).concat("` returns a `!T` whose error is being discarded — propagate with `?` or bind with `let r = …`"));
    }
}

// ---------- ignored-option -----------------------------------------------
// `.val` on a `?T` reaches into the payload regardless of whether it's
// some or none — reading the none branch is UB. Accepted shape:
// `if x.is_some() { … x.val … }` or `let v = x?`. Anything else is a
// landmine. We detect only the simplest case: a `.val` access whose
// receiver is an EX_IDENT typed as `?T` (no `is_some` check above it
// in the same straight-line block).
pub fn analysis_ignored_option(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "ignored-option") {
            t.current_origin = s.origin;
            let opts: *HashMap<bool> = HashMap::new();
            let checked: *HashMap<bool> = HashMap::new();
            _io_scan(t, s.fn_body, opts, checked);
            opts.free();
            checked.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "ignored-option") { continue; }
                if s.origin != null && !s.origin.eq("") { t.current_origin = s.origin; }
                let opts: *HashMap<bool> = HashMap::new();
                let checked: *HashMap<bool> = HashMap::new();
                _io_scan(t, m.fn_body, opts, checked);
                opts.free();
                checked.free();
            }
        }
    }
}
fn _io_scan(t: *Typer, body: *Vector<Stmt>, opts: *HashMap<bool>, checked: *HashMap<bool>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null && s.let_ty != null
           && s.let_ty.kind == TY_OPTION {
            opts.insert(s.name, true);
        }
        let gated: string = "";
        let mut negated: bool = false;
        if s.cond != null {
            // Recognise `if x.is_some() { … }` (then_body is the safe
            // branch) AND the inverse guard `if !x.has { early-exit }`
            // / `if x.is_none() { early-exit }` (rest of the OUTER
            // body becomes safe). The inverse form is what tight
            // loops use: `if !r.has { break; }` then read `r.val`.
            gated = _io_extract_check_unsigned(s.cond);
            if !gated.eq("") {
                negated = _io_is_negated_check(s.cond)
                          || _io_is_none_check(s.cond);
            }
        }
        if !gated.eq("") && !negated && s.then_body != null {
            let was_checked: bool = checked.contains(gated);
            checked.insert(gated, true);
            _io_scan(t, s.then_body, opts, checked);
            if !was_checked { checked.insert(gated, false); }
        } else if s.then_body != null {
            _io_scan(t, s.then_body, opts, checked);
        }
        if s.else_body != null { _io_scan(t, s.else_body, opts, checked); }
        if s.expr_value != null { _io_check_expr(t, s.expr_value, opts, checked); }
        if s.let_value != null { _io_check_expr(t, s.let_value, opts, checked); }
        // After a guard like `if !r.has { break/return/continue }`,
        // every subsequent sibling stmt is safe to read r.val.
        if !gated.eq("") && negated && s.then_body != null
           && _io_body_is_early_exit(s.then_body) {
            checked.insert(gated, true);
        }
    }
}
fn _io_extract_check_unsigned(e: *Expr) -> string {
    // Like _io_extract_check but strips the outer `!`.
    if e == null { return ""; }
    if e.kind == EX_UNARY && e.operand != null { return _io_extract_check_unsigned(e.operand); }
    return _io_extract_check(e);
}
fn _io_is_negated_check(e: *Expr) -> bool {
    if e == null { return false; }
    if e.kind == EX_UNARY { return true; }
    return false;
}
fn _io_is_none_check(e: *Expr) -> bool {
    if e == null { return false; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER
       && e.lhs.field != null && e.lhs.field.eq("is_none") { return true; }
    return false;
}
fn _io_body_is_early_exit(body: *Vector<Stmt>) -> bool {
    if body == null || body.len() == 0 { return false; }
    let last: Stmt = body.get(body.len() - 1);
    if last.kind == ST_RETURN || last.kind == ST_BREAK
       || last.kind == ST_CONTINUE { return true; }
    return false;
}
fn _io_extract_check(e: *Expr) -> string {
    if e == null { return ""; }
    // `x.is_some()` — method form.
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER
       && e.lhs.field != null && e.lhs.field.eq("is_some")
       && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT {
        return e.lhs.lhs.str_val;
    }
    // `x.has` — direct field access on the option struct (used in
    // tight loops where the method-call overhead matters).
    if e.kind == EX_MEMBER && e.field != null && e.field.eq("has")
       && e.lhs != null && e.lhs.kind == EX_IDENT {
        return e.lhs.str_val;
    }
    // `!x.is_some()` / `!x.has` — recurse through the unary !.
    if e.kind == EX_UNARY && e.operand != null {
        return _io_extract_check(e.operand);
    }
    return "";
}
fn _io_check_expr(t: *Typer, e: *Expr, opts: *HashMap<bool>, checked: *HashMap<bool>) {
    if e == null { return; }
    if e.kind == EX_MEMBER && e.field != null && e.field.eq("val")
       && e.lhs != null && e.lhs.kind == EX_IDENT
       && opts.contains(e.lhs.str_val) {
        let nm: string = e.lhs.str_val;
        if !(checked.contains(nm) && checked.get(nm)) {
            t.warn(e.line, e.column, "ignored-option",
                "`".concat(nm).concat(".val` reads the payload without checking `").concat(nm).concat(".is_some()` — guard with `if ").concat(nm).concat(".is_some() { … }` or unwrap via `let v = ").concat(nm).concat("?;`"));
        }
    }
    if e.lhs != null { _io_check_expr(t, e.lhs, opts, checked); }
    if e.rhs != null { _io_check_expr(t, e.rhs, opts, checked); }
    if e.operand != null { _io_check_expr(t, e.operand, opts, checked); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _io_check_expr(t, &a, opts, checked);
        }
    }
}

// ---------- use-after-free -----------------------------------------------
// `x.free()` invalidates `x`. Any subsequent use in the same block is a
// dangling-pointer access — exactly the shape of the LSP completion
// crash. `defer x.free()` is fine (fires at scope exit, value is still
// valid throughout the block).
pub fn analysis_use_after_free(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "use-after-free") {
            t.current_origin = s.origin;
            let freed: *HashMap<bool> = HashMap::new();
            _uaf_scan(t, s.fn_body, freed);
            freed.free();
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "use-after-free") { continue; }
                if s.origin != null && !s.origin.eq("") { t.current_origin = s.origin; }
                let freed: *HashMap<bool> = HashMap::new();
                _uaf_scan(t, m.fn_body, freed);
                freed.free();
            }
        }
    }
}
fn _uaf_scan(t: *Typer, body: *Vector<Stmt>, freed: *HashMap<bool>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        // Defer doesn't mark freed — fires at scope exit only.
        if s.kind == ST_DEFER { continue; }
        // A return / propagation marks the end of this control-flow
        // path. Any siblings after a return are reached via a different
        // path (else-branch fall-through up the chain) where the freed
        // state shouldn't carry. Clearing avoids the common pattern
        // `if c { x.free(); return; } x.free();` warning on the second
        // free.
        if s.kind == ST_RETURN { freed.clear(); continue; }
        // Reassignment clears the freed bit.
        if s.kind == ST_LET && s.name != null && freed.contains(s.name) {
            freed.insert(s.name, false);
        }
        if s.expr_value != null && s.expr_value.kind == EX_ASSIGN
           && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT
           && freed.contains(s.expr_value.lhs.str_val) {
            freed.insert(s.expr_value.lhs.str_val, false);
        }
        // The free call itself is allowed even though `x` appears in
        // it. Detect the free target up-front and skip its receiver
        // when we walk the expression.
        let mut free_target: string = "";
        if s.expr_value != null { free_target = _uaf_free_target(s.expr_value); }
        if s.expr_value != null { _uaf_check_expr(t, s.expr_value, freed, free_target); }
        if s.let_value != null { _uaf_check_expr(t, s.let_value, freed, ""); }
        if s.cond != null { _uaf_check_expr(t, s.cond, freed, ""); }
        if !free_target.eq("") { freed.insert(free_target, true); }
        if s.then_body != null { _uaf_scan(t, s.then_body, freed); }
        if s.else_body != null { _uaf_scan(t, s.else_body, freed); }
    }
}
fn _uaf_free_target(e: *Expr) -> string {
    if e == null { return ""; }
    if e.kind != EX_CALL || e.lhs == null || e.lhs.kind != EX_MEMBER { return ""; }
    if e.lhs.field == null || !e.lhs.field.eq("free") { return ""; }
    if e.lhs.lhs == null || e.lhs.lhs.kind != EX_IDENT { return ""; }
    return e.lhs.lhs.str_val;
}
fn _uaf_check_expr(t: *Typer, e: *Expr, freed: *HashMap<bool>, skip: string) {
    if e == null { return; }
    if e.kind == EX_IDENT && freed.contains(e.str_val) && freed.get(e.str_val)
       && !e.str_val.eq(skip) {
        t.warn(e.line, e.column, "use-after-free",
            "`".concat(e.str_val).concat("` was freed earlier in this scope — accessing it is a dangling-pointer read"));
        return;
    }
    if e.lhs != null { _uaf_check_expr(t, e.lhs, freed, skip); }
    if e.rhs != null { _uaf_check_expr(t, e.rhs, freed, skip); }
    if e.operand != null { _uaf_check_expr(t, e.operand, freed, skip); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _uaf_check_expr(t, &a, freed, skip);
        }
    }
}

// ---------- mutex-not-unlocked -------------------------------------------
// Every `m.lock()` needs an `m.unlock()` in the same block / fn. The
// check is balance-based (count locks vs unlocks per name); deeper
// control-flow checking would require building a CFG, but unbalanced
// counts already catch the common shapes.
pub fn analysis_mutex_unbalanced(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "mutex-unbalanced") {
            t.current_origin = s.origin;
            _mu_check_fn(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "mutex-unbalanced") { continue; }
                if s.origin != null && !s.origin.eq("") { t.current_origin = s.origin; }
                _mu_check_fn(t, m.fn_body);
            }
        }
    }
}
fn _mu_check_fn(t: *Typer, body: *Vector<Stmt>) {
    // Path-aware: walk stmts in order with `held` = the set of names
    // currently locked. Every exit path (return / ?-propagation /
    // break / continue / fall-off-the-end) must clear `held`. We
    // detect `?` operators inside expressions because each is a
    // potential early return.
    let held: *HashMap<i32> = HashMap::new();        // name -> line of lock
    let held_col: *HashMap<i32> = HashMap::new();
    let warned: *HashMap<bool> = HashMap::new();
    _mu_walk_path(t, body, held, held_col, warned);
    // Names still held at fall-through end of fn are bugs too.
    let names: *Vector<string> = held.keys();
    for let i: i32 = 0; i < names.len(); i++ {
        let nm: string = names.get(i);
        if warned.contains(nm) { continue; }
        t.warn(held.get(nm), held_col.get(nm), "mutex-unbalanced",
            "`".concat(nm).concat(".lock()` falls off the end of the fn without `.unlock()` — release it on every exit (a `defer ").concat(nm).concat(".unlock();` right after the lock covers all returns)"));
        warned.insert(nm, true);
    }
    held.free(); held_col.free(); warned.free();
}
fn _mu_walk_path(t: *Typer, body: *Vector<Stmt>,
                 held: *HashMap<i32>, held_col: *HashMap<i32>,
                 warned: *HashMap<bool>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.expr_value != null && _ler_expr_has_try(s.expr_value) {
            _mu_flag_held(t, held, held_col, warned, s.line, "?-propagation");
        }
        if s.let_value != null && _ler_expr_has_try(s.let_value) {
            _mu_flag_held(t, held, held_col, warned, s.line, "?-propagation");
        }
        if s.expr_value != null { _mu_update_state(s.expr_value, held, held_col); }
        if s.let_value != null { _mu_update_state(s.let_value, held, held_col); }
        if s.kind == ST_RETURN || s.kind == ST_BREAK || s.kind == ST_CONTINUE {
            let exit_label: string = "return";
            if s.kind == ST_BREAK { exit_label = "break"; }
            if s.kind == ST_CONTINUE { exit_label = "continue"; }
            _mu_flag_held(t, held, held_col, warned, s.line, exit_label);
            return;
        }
        if s.kind == ST_DEFER && s.expr_value != null {
            let nm: string = _mu_unlock_target(s.expr_value);
            if !nm.eq("") && held.contains(nm) { held.remove(nm); held_col.remove(nm); }
        }
        // For if/else, walk each branch with its own copy of the
        // held state so a lock acquired only in one branch doesn't
        // leak into the other. After both branches, merge: a name
        // is "held after" iff held in EITHER branch (worst case for
        // leak detection — drives a warning if any path leaves it
        // held at a later exit).
        if s.then_body != null || s.else_body != null {
            let snap: *HashMap<i32> = _mu_clone_int(held);
            let snap_col: *HashMap<i32> = _mu_clone_int(held_col);
            let then_held: *HashMap<i32> = _mu_clone_int(held);
            let then_col: *HashMap<i32> = _mu_clone_int(held_col);
            if s.then_body != null { _mu_walk_path(t, s.then_body, then_held, then_col, warned); }
            let else_held: *HashMap<i32> = _mu_clone_int(snap);
            let else_col: *HashMap<i32> = _mu_clone_int(snap_col);
            if s.else_body != null { _mu_walk_path(t, s.else_body, else_held, else_col, warned); }
            // Merge: union of both branches' remaining held names.
            held.clear();
            held_col.clear();
            _mu_merge_into(then_held, then_col, held, held_col);
            _mu_merge_into(else_held, else_col, held, held_col);
            then_held.free(); then_col.free();
            else_held.free(); else_col.free();
            snap.free(); snap_col.free();
        }
    }
}
fn _mu_clone_int(src: *HashMap<i32>) -> *HashMap<i32> {
    let out: *HashMap<i32> = HashMap::new();
    let ks: *Vector<string> = src.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        out.insert(k, src.get(k));
    }
    return out;
}
fn _mu_merge_into(src: *HashMap<i32>, src_col: *HashMap<i32>,
                  dst: *HashMap<i32>, dst_col: *HashMap<i32>) {
    let ks: *Vector<string> = src.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if !dst.contains(k) {
            dst.insert(k, src.get(k));
            if src_col.contains(k) { dst_col.insert(k, src_col.get(k)); }
        }
    }
}
fn _mu_flag_held(t: *Typer, held: *HashMap<i32>, held_col: *HashMap<i32>,
                 warned: *HashMap<bool>, exit_line: i32, exit_kind: string) {
    let names: *Vector<string> = held.keys();
    for let i: i32 = 0; i < names.len(); i++ {
        let nm: string = names.get(i);
        if warned.contains(nm) { continue; }
        t.warn(held.get(nm), held_col.get(nm), "mutex-unbalanced",
            "`".concat(nm).concat(".lock()` is still held at the ").concat(exit_kind).concat(" — wrap it with `defer ").concat(nm).concat(".unlock();` so every exit path releases the lock"));
        warned.insert(nm, true);
    }
}
fn _mu_update_state(e: *Expr, held: *HashMap<i32>, held_col: *HashMap<i32>) {
    if e == null { return; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER
       && e.lhs.field != null && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT {
        let recv: string = e.lhs.lhs.str_val;
        if e.lhs.field.eq("lock") && !held.contains(recv) {
            held.insert(recv, e.line);
            held_col.insert(recv, e.column);
        }
        if e.lhs.field.eq("unlock") && held.contains(recv) {
            held.remove(recv);
            held_col.remove(recv);
        }
    }
    if e.lhs != null { _mu_update_state(e.lhs, held, held_col); }
    if e.rhs != null { _mu_update_state(e.rhs, held, held_col); }
    if e.operand != null { _mu_update_state(e.operand, held, held_col); }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            _mu_update_state(&a, held, held_col);
        }
    }
}
fn _mu_unlock_target(e: *Expr) -> string {
    if e == null { return ""; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER
       && e.lhs.field != null && e.lhs.field.eq("unlock")
       && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT {
        return e.lhs.lhs.str_val;
    }
    return "";
}

// ---------- chan-leak ----------------------------------------------------
// A chan with receivers in a `while let v = c.recv()` (or similar)
// needs SOMEONE to call `c.close()` — otherwise the receivers block
// forever and the program never terminates. We approximate by
// flagging any chan declared in a fn that has no `close()` anywhere
// in that fn.
pub fn analysis_chan_leak(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "chan-leak") {
            t.current_origin = s.origin;
            _cl_check_fn(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "chan-leak") { continue; }
                if s.origin != null && !s.origin.eq("") { t.current_origin = s.origin; }
                _cl_check_fn(t, m.fn_body);
            }
        }
    }
}
fn _cl_check_fn(t: *Typer, body: *Vector<Stmt>) {
    // Two-step: collect every chan; then walk paths reporting at
    // every exit point that leaves the chan open. An exit is
    // return/break/continue at any depth, OR fall-off-the-end of
    // the top-level body.
    let chans: *HashMap<i32> = HashMap::new();
    let chans_col: *HashMap<i32> = HashMap::new();
    _cl_collect_chans(body, chans, chans_col);
    let names: *Vector<string> = chans.keys();
    for let i: i32 = 0; i < names.len(); i++ {
        let nm: string = names.get(i);
        let mut warned: bool = false;
        let r: i32 = _cl_walk(t, body, nm, false, chans.get(nm), chans_col.get(nm), &warned);
        // r encodes: 0 = falls through with closed=false (top-level
        // leak), 1 = closed at end, 2 = always exits before fall-through
        if r == 0 && !warned {
            t.warn(chans.get(nm), chans_col.get(nm), "chan-leak",
                "channel `".concat(nm).concat("` reaches the end of the fn without `close()` on the fall-through path — every exit must close before receivers can stop waiting"));
        }
    }
    chans.free(); chans_col.free();
}
fn _cl_collect_chans(body: *Vector<Stmt>, chans: *HashMap<i32>, chans_col: *HashMap<i32>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null && s.let_ty != null
           && s.let_ty.kind == TY_GENERIC && s.let_ty.name.eq("chan") {
            chans.insert(s.name, s.line);
            chans_col.insert(s.name, s.column);
        }
        if s.then_body != null { _cl_collect_chans(s.then_body, chans, chans_col); }
        if s.else_body != null { _cl_collect_chans(s.else_body, chans, chans_col); }
    }
}
// Walk `body`. Side-effect: warns once (via `*warned`) at the first
// return/break/continue where chan `nm` is still open. Return value:
//   0 = body falls through with closed=false
//   1 = body falls through with closed=true
//   2 = body never falls through (every path returned/break'd)
// The caller composes these for if/else merging.
fn _cl_walk(t: *Typer, body: *Vector<Stmt>, nm: string, closed_in: bool,
            chan_line: i32, chan_col: i32, warned: *bool) -> i32 {
    let mut closed: bool = closed_in;
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.expr_value != null && _cl_expr_closes(s.expr_value, nm) { closed = true; }
        if s.let_value != null && _cl_expr_closes(s.let_value, nm) { closed = true; }
        if s.kind == ST_RETURN || s.kind == ST_BREAK || s.kind == ST_CONTINUE {
            if !closed && !*warned {
                let exit_label: string = "return";
                if s.kind == ST_BREAK { exit_label = "break"; }
                if s.kind == ST_CONTINUE { exit_label = "continue"; }
                t.warn(chan_line, chan_col, "chan-leak",
                    "channel `".concat(nm).concat("` is still open at this ").concat(exit_label).concat(" — `close()` it before exiting so receivers can stop"));
                *warned = true;
            }
            return 2;
        }
        if s.kind == ST_IF {
            let mut fall_state: i32 = 0;
            if closed { fall_state = 1; }
            let mut then_r: i32 = fall_state;
            if s.then_body != null {
                then_r = _cl_walk(t, s.then_body, nm, closed, chan_line, chan_col, warned);
            }
            let mut else_r: i32 = fall_state;
            if s.else_body != null {
                else_r = _cl_walk(t, s.else_body, nm, closed, chan_line, chan_col, warned);
            }
            // Merge: if both never fall through, outer doesn't either.
            // Otherwise take the AND of fall-through closed states
            // (a branch that exited contributes nothing to the merge).
            if then_r == 2 && else_r == 2 { return 2; }
            let mut new_closed: bool = true;
            let mut any_fall: bool = false;
            if then_r != 2 { any_fall = true; if then_r == 0 { new_closed = false; } }
            if else_r != 2 { any_fall = true; if else_r == 0 { new_closed = false; } }
            if !any_fall { return 2; }
            closed = new_closed;
        }
    }
    if closed { return 1; }
    return 0;
}
fn _cl_expr_closes(e: *Expr, nm: string) -> bool {
    if e == null { return false; }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER
       && e.lhs.field != null && e.lhs.field.eq("close")
       && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT
       && e.lhs.lhs.str_val.eq(nm) { return true; }
    if e.lhs != null && _cl_expr_closes(e.lhs, nm) { return true; }
    if e.rhs != null && _cl_expr_closes(e.rhs, nm) { return true; }
    if e.operand != null && _cl_expr_closes(e.operand, nm) { return true; }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if _cl_expr_closes(&a, nm) { return true; }
        }
    }
    return false;
}

// ---------- leak-on-early-return -----------------------------------------
// `let x = make(); … x?; defer x.free();` — the `?` propagation fires
// before the defer registers, leaking x on the error path. The fix is
// to register the defer *immediately* after the binding.
pub fn analysis_leak_on_early_return(t: *Typer, program: *Vector<Stmt>) {
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_FN && s.fn_body != null && !_has_allow(&s, "leak-on-early-return") {
            t.current_origin = s.origin;
            _ler_check_fn(t, s.fn_body);
        }
        if s.kind == ST_IMPL && s.impl_methods != null {
            for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                let m: Stmt = s.impl_methods.get(j);
                if m.fn_body == null || _has_allow(&m, "leak-on-early-return") { continue; }
                if s.origin != null && !s.origin.eq("") { t.current_origin = s.origin; }
                _ler_check_fn(t, m.fn_body);
            }
        }
    }
}
fn _ler_check_fn(t: *Typer, body: *Vector<Stmt>) {
    // First pass: find every defer x.free() and remember the stmt index.
    let defer_idx: *HashMap<i32> = HashMap::new();    // name -> idx of defer
    let alloc_idx: *HashMap<i32> = HashMap::new();    // name -> idx of let
    let alloc_line: *HashMap<i32> = HashMap::new();   // name -> source line of defer
    let alloc_col: *HashMap<i32> = HashMap::new();
    let returning: *Vector<i32> = Vector::new();      // idx of ?/return stmts
    for let i: i32 = 0; i < body.len(); i++ {
        let s: Stmt = body.get(i);
        if s.kind == ST_LET && s.name != null && s.let_value != null
           && _ler_is_allocating_call(s.let_value) {
            alloc_idx.insert(s.name, i);
        }
        if s.kind == ST_DEFER && s.expr_value != null {
            // Three shapes count as "this defer releases x":
            //   defer x.free()              — method call
            //   defer free(x as *void)      — raw free of a pointer
            //   defer __glide_palloc_free(x)
            let nm: string = _ler_defer_target(s.expr_value);
            if !nm.eq("") {
                defer_idx.insert(nm, i);
                alloc_line.insert(nm, s.line);
                alloc_col.insert(nm, s.column);
            }
        }
        if _ler_has_early_exit(&s) { returning.push(i); }
    }
    let names: *Vector<string> = defer_idx.keys();
    for let i: i32 = 0; i < names.len(); i++ {
        let nm: string = names.get(i);
        if !alloc_idx.contains(nm) { continue; }
        let a: i32 = alloc_idx.get(nm);
        let d: i32 = defer_idx.get(nm);
        if d <= a + 1 { continue; }  // defer placed right after alloc — safe
        for let k: i32 = 0; k < returning.len(); k++ {
            let r: i32 = returning.get(k);
            if r > a && r < d {
                t.warn(alloc_line.get(nm), alloc_col.get(nm), "leak-on-early-return",
                    "`defer ".concat(nm).concat(".free()` is registered after an early exit on line — move it right after `let ").concat(nm).concat(" = …;` so the cleanup also fires on the error path"));
                break;
            }
        }
    }
    defer_idx.free(); alloc_idx.free();
    alloc_line.free(); alloc_col.free();
}
fn _ler_defer_target(e: *Expr) -> string {
    if e == null { return ""; }
    // x.free()
    let mc: string = _uaf_free_target(e);
    if !mc.eq("") { return mc; }
    // free(x as *void) / __glide_palloc_free(x)
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_IDENT
       && (e.lhs.str_val.eq("free") || e.lhs.str_val.eq("__glide_palloc_free"))
       && e.args != null && e.args.len() == 1 {
        let arg: Expr = e.args.get(0);
        let mut probe: *Expr = &arg;
        while probe != null && probe.kind == EX_CAST { probe = probe.lhs; }
        if probe != null && probe.kind == EX_IDENT { return probe.str_val; }
    }
    return "";
}
fn _ler_is_allocating_call(e: *Expr) -> bool {
    if e == null { return false; }
    // Peel cast wrappers: `malloc(n) as *T`, common at every alloc site.
    let mut p: *Expr = e;
    while p != null && p.kind == EX_CAST { p = p.lhs; }
    if p == null { return false; }
    if p.kind == EX_CALL && p.lhs != null && p.lhs.kind == EX_IDENT {
        let n: string = p.lhs.str_val;
        if n.eq("malloc") || n.eq("__glide_palloc_make") { return true; }
    }
    if p.kind == EX_CALL && p.lhs != null && p.lhs.kind == EX_MEMBER
       && p.lhs.field != null && p.lhs.field.eq("new") { return true; }
    return false;
}
fn _ler_has_early_exit(s: *Stmt) -> bool {
    if s == null { return false; }
    if s.kind == ST_RETURN { return true; }
    if s.expr_value != null && _ler_expr_has_try(s.expr_value) { return true; }
    if s.let_value != null && _ler_expr_has_try(s.let_value) { return true; }
    return false;
}
fn _ler_expr_has_try(e: *Expr) -> bool {
    if e == null { return false; }
    if e.kind == EX_UNARY && e.op_code == UN_TRY { return true; }
    if e.lhs != null && _ler_expr_has_try(e.lhs) { return true; }
    if e.rhs != null && _ler_expr_has_try(e.rhs) { return true; }
    if e.operand != null && _ler_expr_has_try(e.operand) { return true; }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if _ler_expr_has_try(&a) { return true; }
        }
    }
    return false;
}

// ---- Main loop ---------------------------------------------------------

// Dispatch one decoded LSP request to the right handler. Returns true
// when the loop should stop (graceful exit). Pulled out of lsp_main so
// the loop can free `raw` and `req` after each iteration without
// repeating cleanup before every `continue`.
fn lsp_dispatch(req: *JsonValue, state: *LspState) -> bool {
    let method: string = json_as_string(json_get(req, "method"));
    if method.eq("initialize") { handle_initialize(req); return false; }
    if method.eq("initialized") { return false; }
    if method.eq("shutdown") { handle_shutdown(req, state); return false; }
    if method.eq("exit") { return true; }
    if method.eq("textDocument/didOpen") { handle_did_open(req, state); return false; }
    if method.eq("textDocument/didChange") { handle_did_change(req, state); return false; }
    if method.eq("textDocument/didClose") { handle_did_close(req, state); return false; }
    if method.eq("textDocument/hover") { handle_hover(req, state); return false; }
    if method.eq("textDocument/documentSymbol") { handle_document_symbol(req, state); return false; }
    if method.eq("textDocument/definition") { handle_definition(req, state); return false; }
    if method.eq("textDocument/completion") { handle_completion(req, state); return false; }
    if method.eq("textDocument/references") { handle_references(req, state); return false; }
    if method.eq("textDocument/documentHighlight") { handle_document_highlight(req, state); return false; }
    if method.eq("textDocument/prepareRename") { handle_prepare_rename(req, state); return false; }
    if method.eq("textDocument/rename") { handle_rename(req, state); return false; }
    if method.eq("textDocument/formatting") { handle_formatting(req, state); return false; }
    if method.eq("textDocument/codeAction") { handle_code_action(req, state); return false; }
    if method.eq("glide/routeList") { handle_route_list(req, state); return false; }
    // Any unhandled request gets an empty-result reply so clients don't hang.
    let id: *JsonValue = json_get(req, "id");
    if id != null { lsp_send_response(id, json_null()); }
    return false;
}

pub fn lsp_main() -> i32 {
    __glide_set_binary_io();
    // Open ~/.glide/lsp.log (truncate per session) and redirect
    // stderr there so the SIGSEGV trap handler's stack trace
    // lands in the same file editors can't easily surface.
    let log_path: string = _lsp_log_path();
    __glide_lsp_log_open(log_path);
    _lsp_log("--- lsp boot ---");
    let state: *LspState = lsp_state_new();
    while true {
        let raw: string = lsp_read_message();
        if raw.eq("") {
            _lsp_log("read_message: EOF — exiting");
            break;
        }
        let req: *JsonValue = json_parse(raw);
        let mut should_exit: bool = false;
        if req != null {
            let method_v: *JsonValue = json_get(req, "method");
            let mid: *JsonValue = json_get(req, "id");
            let method_s: string = json_as_string(method_v);
            _lsp_log("> ".concat(method_s).concat(" id=").concat(int_to_str(json_as_int(mid))));
            // Per-request arena. Every Vector / HashMap / __glide_palloc
            // call inside the handler — completion's `seen` map, hover's
            // `uses` Vector, all the concat'd item labels and signatures,
            // all the JsonValue leaf strings the handler builds for the
            // response — bumps into this arena and is reclaimed in bulk
            // when the request finishes. Without this every Zed
            // keystroke that fires a completion or documentHighlight
            // leaks the full per-call working set (multi-MB on big
            // files; multi-GB after a few minutes of typing).
            let req_arena_initial: *void = __glide_palloc_make();
            __glide_palloc_set(req_arena_initial);
            should_exit = lsp_dispatch(req, state);
            _lsp_log("< done ".concat(method_s));
            // Read the final head — when dispatch grows the arena past
            // the initial chunk, palloc_chunk prepends new ones so the
            // free has to start from the latest head, not the make()
            // return that's now buried at the tail.
            let req_arena_head: *void = __glide_palloc_get();
            __glide_palloc_set(null);
            __glide_palloc_free(req_arena_head);
            // Reclaim the JSON tree wrappers. Leaf strings (uri / text /
            // method) live independently on the heap (json_parse ran
            // before the request arena was set), so handlers that hand
            // them to long-lived state (state.docs[uri].text etc) own
            // them now and free them when they overwrite the slot.
            json_free(req);
        }
        c_raw! { if (raw  !=  NULL) free((char*)(raw )); }
        if should_exit { break; }
    }
    _lsp_log("--- lsp shutdown ---");
    return 0;
}

