// Compiler driver and CLI entry point.
//
// Subcommands:
//   build <file> [-o out]    parse + check + emit C, hand off to a C
//                            compiler (zig cc / cc / cl), produce an exe.
//   run   <file>             build then exec the resulting binary.
//   check <file>             parse + typecheck only; print diagnostics.
//   fmt   <file> [--write]   parse + reformat; stdout by default.
//   ast   <file>             parse + dump JSON AST to stdout.
//   lsp                      run the Language Server over stdio.
//
// Module loading: `load_into_str` walks parsed source for `import` stmts,
// pulls each referenced file into the unit, and pre-scans for fully-
// qualified path refs (`a::b::c::Item`) so unimported call sites still
// resolve when their module file exists on disk.

import stdlib::hashmap::*;
import stdlib::fs::*;
import stdlib::os::*;
import stdlib::env::*;
import stdlib::io::*;
import stdlib::spinner::*;
import lexer;
import ast;
import parser;
import expander;
import interp;
import lower;
import typer;
import codegen;
import json;
import fmt;
import lsp;
import openapi;
import manifest;
import fetch;
import doc;
import embed;
import stdlib::compress::*;
import stdlib::tar::*;
import loader::*;

fn print_indent(n: i32) {
    for let i: i32 = 0; i < n; i++ { print!("  "); }
}

fn print_type(t: *Type) {
    if t == null { print!("<none>"); return; }
    if t.kind == TY_POINTER { print!("*"); print_type(t.inner); return; }
    if t.kind == TY_NAMED { print!(t.name); return; }
    print!("<ty?>");
}

fn op_name(op: i32) -> string {
    if op == OP_ADD { return "+"; }
    if op == OP_SUB { return "-"; }
    if op == OP_MUL { return "*"; }
    if op == OP_DIV { return "/"; }
    if op == OP_MOD { return "%"; }
    if op == OP_LT  { return "<"; }
    if op == OP_GT  { return ">"; }
    return "?";
}

fn print_expr(e: *Expr, indent: i32) {
    if e == null { print_indent(indent); println!("<null>"); return; }
    print_indent(indent);
    if e.kind == EX_INT { println!("Int", e.int_val); return; }
    if e.kind == EX_STRING { println!("String \"", e.str_val, "\""); return; }
    if e.kind == EX_BOOL { println!("Bool", e.bool_val); return; }
    if e.kind == EX_IDENT { println!("Ident", e.str_val); return; }
    if e.kind == EX_BINARY {
        println!("Binary", op_name(e.op_code));
        print_expr(e.lhs, indent + 1);
        print_expr(e.rhs, indent + 1);
        return;
    }
    if e.kind == EX_CALL {
        println!("Call");
        print_expr(e.lhs, indent + 1);
        print_indent(indent + 1); println!("args:", e.args.len());
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            print_expr(&a, indent + 2);
        }
        return;
    }
    println!("<expr kind ", e.kind, ">");
}

fn print_stmt(s: *Stmt, indent: i32) {
    if s == null { print_indent(indent); println!("<null stmt>"); return; }
    print_indent(indent);
    if s.kind == ST_FN {
        print!("Fn ", s.name, " (");
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            if i > 0 { print!(", "); }
            let prm: Param = s.fn_params.get(i);
            print!(prm.name, ": "); print_type(prm.ty);
        }
        print!(") -> "); print_type(s.fn_ret_ty); println!("");
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            print_stmt(&b, indent + 1);
        }
        return;
    }
    if s.kind == ST_LET {
        print!("Let ", s.name, ": "); print_type(s.let_ty); println!("");
        if s.let_value != null { print_expr(s.let_value, indent + 1); }
        return;
    }
    if s.kind == ST_RETURN {
        println!("Return");
        if s.expr_value != null { print_expr(s.expr_value, indent + 1); }
        return;
    }
    if s.kind == ST_EXPR {
        println!("Expr");
        print_expr(s.expr_value, indent + 1);
        return;
    }
    println!("<stmt kind ", s.kind, ">");
}


// FFI to libc + driver helpers (defined in the runtime emit).
extern fn __glide_redirect_to(path: string) -> i32;
extern fn __glide_restore_stdout(saved: i32);
extern fn __glide_shell(cmd: string) -> i32;
extern fn __glide_exe_path() -> string;
extern fn __glide_exe_dir() -> string;
// Newline-separated listing of files under `path` whose name ends in `suffix`.
// Empty `suffix` means "all files". Sorted ascending. Returns "" on missing dir.
// Defined in bootstrap/runtime/stdlib.c.
extern fn __glide_list_dir(path: string, suffix: string) -> string;

extern fn __glide_getenv(name: string) -> string;
extern fn __glide_is_windows() -> i32;
extern fn __glide_file_exists(path: string) -> bool;
// Wrap a raw byte buffer + length as a Glide string. Used by the
// embedded-blob extractors (sysroot / zig / src self-extract) to hand
// gzip_decode / tar_extract the decoded bytes. Declared here as well as
// in fetch.glide / stdlib::compress so the bootstrap seed's stricter
// extern-visibility check resolves it without leaning on a transitive
// import.
extern fn __glide_string_from_buf(buf: *void, n: i32) -> string;
// File I/O for the compiler driver itself. `stdlib::fs` wraps these for
// user-visible API; the bootstrap binary needs them raw.
extern fn read_file(path: string) -> string;
extern fn write_file(path: string, content: string) -> bool;

// ---- pretty diagnostics --------------------------------------------------

fn use_color() -> bool { return __glide_getenv("NO_COLOR").eq(""); }
fn col_red() -> string    { if use_color() { return "\x1b[1;31m"; } return ""; }
fn col_yellow() -> string { if use_color() { return "\x1b[1;33m"; } return ""; }
fn col_blue() -> string   { if use_color() { return "\x1b[1;36m"; } return ""; }
fn col_bold() -> string   { if use_color() { return "\x1b[1m"; } return ""; }
fn col_reset() -> string  { if use_color() { return "\x1b[0m"; } return ""; }

fn nth_line(src: string, n: i32) -> string {
    if n < 1 { return ""; }
    let total: i32 = src.len();
    let mut line: i32 = 1;
    let mut start: i32 = 0;
    let mut i: i32 = 0;
    while i < total {
        if src.at(i).to_int() == 10 {
            if line == n { return src.substring(start, i); }
            line = line + 1;
            start = i + 1;
        }
        i = i + 1;
    }
    if line == n && start <= total { return src.substring(start, total); }
    return "";
}

fn int_width(n: i32) -> i32 {
    let mut x: i32 = n;
    if x < 0 { x = -x; }
    let mut w: i32 = 1;
    while x >= 10 { x = x / 10; w = w + 1; }
    return w;
}

fn repeat_char(ch: string, n: i32) -> string {
    let mut s: string = "";
    for let i: i32 = 0; i < n; i++ { s = s.concat(ch); }
    return s;
}

fn help_for_code(code: string) -> string {
    if code.eq("infinite-recursion") { return "add a base case before the recursive call (e.g. `if n == 0 { return; }`)"; }
    if code.eq("arena-not-freed")    { return "free the arena with `arena_free(a)` or use `defer arena_free(a);`"; }
    if code.eq("addr-of-temporary")  { return "store the value in a `let` first, then take its address"; }
    if code.eq("large-return")       { return "return a pointer (`*T`) instead of a large struct"; }
    if code.eq("overlap-borrow")     { return "use distinct sources or split into separate statements"; }
    if code.eq("unused-fn")          { return "prefix with `_` if intentional, or remove the function"; }
    if code.eq("unused-var")         { return "prefix with `_` if intentional, or remove the variable"; }
    if code.eq("unused-param")       { return "prefix with `_` if intentional"; }
    if code.eq("unnecessary-mut")    { return "drop `mut` if the binding is never reassigned"; }
    if code.eq("unknown-type")       { return "check the spelling, or `import` the module that declares it"; }
    if code.eq("unknown-name")       { return "check the spelling, or declare/import the name before use"; }
    if code.eq("unknown-function")   { return "check the spelling, or `import` the module that declares it"; }
    if code.eq("no-field")           { return "check the field name; `pub` fields of structs in other files are the only ones visible cross-file"; }
    if code.eq("private-field")      { return "the field is private to its declaring file; mark it `pub` to read it elsewhere"; }
    if code.eq("private-construction") { return "the struct has private fields; build it through a public constructor (e.g. `T::new(...)`) in its own file"; }
    if code.eq("expected-semicolon") { return "statements end with `;` — insert one at the end of the previous line"; }
    if code.eq("expected-token")     { return "the parser expected a specific token here; check for an unbalanced `{`/`(`/`[` above"; }
    if code.eq("for-in-not-iterable") { return "`for-in` walks a range (`0..n`) or a collection, not a single number"; }
    if code.eq("unused-result")      { return "handle the result: check `.ok`, propagate with `?`, or default with `??`"; }
    return "";
}

// `print!` joins args with spaces, so we build single concatenated strings to
// keep ANSI escape sequences intact (no stray space between `\x1b[31m` and the
// next chunk). `int_to_str` lives in codegen.glide and is reused here.
// Default to ASCII on Windows because the console codepage is often cp850/437
// and writing UTF-8 produces mojibake. POSIX is UTF-8 by convention. Both can
// be overridden with GLIDE_UNICODE=1 / GLIDE_ASCII=1.
fn use_unicode() -> bool {
    let asc: string = __glide_getenv("GLIDE_ASCII");
    if !asc.eq("") && !asc.eq("0") { return false; }
    let uni: string = __glide_getenv("GLIDE_UNICODE");
    if !uni.eq("") && !uni.eq("0") { return true; }
    if __glide_is_windows() != 0 { return false; }
    return true;
}

fn glyph_err() -> string  { if use_unicode() { return "\xe2\x9c\x97"; } return "x"; } // ✗
fn glyph_warn() -> string { if use_unicode() { return "\xe2\x9a\xa0"; } return "!"; } // ⚠
fn glyph_info() -> string { if use_unicode() { return "\xe2\x84\xb9"; } return "i"; } // ℹ
fn glyph_help() -> string { if use_unicode() { return "\xe2\x86\xaa"; } return ">"; } // ↪
fn glyph_pipe() -> string { if use_unicode() { return "\xe2\x94\x8a"; } return "|"; } // ┊
fn glyph_under() -> string{ if use_unicode() { return "\xe2\x94\x81"; } return "-"; } // ━

fn print_pretty_diag(d: DiagEntry, src: string, src_path: string) {
    let mut sym: string = glyph_err();
    let mut color: string = col_red();
    if d.severity == 2 { sym = glyph_warn(); color = col_yellow(); }
    if d.severity == 3 { sym = glyph_info(); color = col_blue();   }
    if d.severity == 4 { sym = glyph_help(); color = col_blue();   }

    let reset: string = col_reset();
    let bold: string = col_bold();
    let dim_blue: string = col_blue();

    // Title:  ⨯ <code>     (then message on the next line, indented)
    let mut title: string = color.concat(sym).concat(" ").concat(reset).concat(bold);
    if !d.code.eq("") { title = title.concat(d.code); }
    else if d.severity == 1 { title = title.concat("error"); }
    else if d.severity == 2 { title = title.concat("warning"); }
    else { title = title.concat("info"); }
    title = title.concat(reset);
    println!(title);
    println!("  ".concat(d.message));
    println!("");

    // Location: "  in <path>:<line>:<col>"
    let loc: string = "  ".concat(dim_blue).concat("in ").concat(reset)
                          .concat(src_path).concat(":").concat(int_to_str(d.line))
                          .concat(":").concat(int_to_str(d.col));
    println!(loc);

    // Source snippet:
    //   N ┊  <line>
    //     ┊  ━━━━━
    let line_text: string = nth_line(src, d.line);
    let gw: i32 = int_width(d.line);
    let pad: string = repeat_char(" ", gw);
    let bar: string = glyph_pipe();
    println!(dim_blue.concat(int_to_str(d.line)).concat(" ").concat(bar).concat(" ").concat(reset).concat(line_text));

    let mut col0: i32 = d.col;
    if col0 < 1 { col0 = 1; }
    let mut span: i32 = d.end_col - d.col;
    if span < 1 { span = 1; }
    // Mirror the leading whitespace verbatim (tabs stay tabs) so the
    // underline lands under the offending span at any terminal tab width.
    let mut indent: string = "";
    let mut k: i32 = 0;
    let mut limit: i32 = col0 - 1;
    if limit > line_text.len() { limit = line_text.len(); }
    while k < limit {
        let ch: i32 = line_text.at(k).to_int();
        if ch == 9 { indent = indent.concat("\t"); }
        else { indent = indent.concat(" "); }
        k = k + 1;
    }
    let underline: string = pad.concat(" ").concat(dim_blue).concat(bar).concat(" ").concat(reset)
                               .concat(indent).concat(color)
                               .concat(repeat_char(glyph_under(), span))
                               .concat(reset);
    println!(underline);

    // Help line, if any:  ↪ help text  (or > help text on ASCII terminals)
    let help: string = help_for_code(d.code);
    if !help.eq("") {
        let h: string = "  ".concat(dim_blue).concat(glyph_help()).concat(" ").concat(reset).concat(help);
        println!("");
        println!(h);
    }
    println!("");
}

const MODE_EMIT: i32 = 0;
const MODE_BUILD: i32 = 1;
const MODE_RUN: i32 = 2;
const MODE_CHECK: i32 = 3;
const MODE_FMT: i32 = 4;

// Bumped manually on release. `glide --version` reads it; same value
// lives in glide.glide at the repo root (kept in sync by hand for now).
const GLIDE_VERSION: string = "0.4.1";

// Active `--lint-as-error=<code>` list, parsed from argv before any
// build / check runs. Lives in a c_raw global so the diagnostic
// loops in `run_build_q` / `MODE_CHECK` / `glide lint` can consult
// it without threading another param through every signature.
// Project-wide allow list (from `glide.glide`'s `lint.allow`) lives
// alongside, consulted by `_has_allow` in lsp.glide.
extern fn __glide_deny_set(p: *void);
extern fn __glide_deny_get() -> *void;
extern fn __glide_proj_allow_set(p: *void);
extern fn __glide_proj_allow_get() -> *void;

c_raw! {
    static void* __glide_deny_g = (void*)0;
    static void __glide_deny_set(void* p) { __glide_deny_g = p; }
    static void* __glide_deny_get(void)   { return __glide_deny_g; }

    static void* __glide_proj_allow_g = (void*)0;
    static void __glide_proj_allow_set(void* p) { __glide_proj_allow_g = p; }
    static void* __glide_proj_allow_get(void)   { return __glide_proj_allow_g; }
}

fn deny_codes() -> *Vector<string> {
    let p: *void = __glide_deny_get();
    if p == null { return null; }
    return p as *Vector<string>;
}

fn set_deny_codes(v: *Vector<string>) {
    __glide_deny_set(v as *void);
}

fn set_project_allow(v: *Vector<string>) {
    __glide_proj_allow_set(v as *void);
}

// Apply a manifest's lint config to the process-wide deny / allow
// globals. Idempotent — re-applying with the same manifest is fine.
fn apply_manifest_lint(m: *Manifest) {
    if m == null { return; }
    if m.lint_deny != null && m.lint_deny.len() > 0 {
        let existing: *Vector<string> = deny_codes();
        let merged: *Vector<string> = Vector::new();
        if existing != null {
            for let i: i32 = 0; i < existing.len(); i++ { merged.push(existing.get(i)); }
        }
        for let i: i32 = 0; i < m.lint_deny.len(); i++ { merged.push(m.lint_deny.get(i)); }
        set_deny_codes(merged);
    }
    if m.lint_allow != null && m.lint_allow.len() > 0 {
        set_project_allow(m.lint_allow);
    }
}

// Best-effort: walk up from `start_dir` looking for a manifest; if
// found and it carries a `lint` block, apply it. Used by build /
// check / lint entry points so the project's lint policy is picked
// up automatically without each command rewiring it.
fn apply_lint_for(start_dir: string) {
    let root: string = find_manifest_root(start_dir);
    if root.eq("") { return; }
    let m: *Manifest = read_manifest(root);
    if m == null { return; }
    apply_manifest_lint(m);
}

// True when a warning's diagnostic code matches any active
// `--lint-as-error` token. Reuses the group / prefix matching from
// the @allow logic so `--lint-as-error=alloc` covers all alloc lints
// and `--lint-as-error=lint:io*` matches every custom lint starting
// with `io`. `all` / `*` promote every warning.
fn _is_lint_promoted(code: string) -> bool {
    let dl: *Vector<string> = deny_codes();
    if dl == null { return false; }
    for let i: i32 = 0; i < dl.len(); i++ {
        if _code_matches_deny(dl.get(i), code) { return true; }
    }
    return false;
}

fn _code_matches_deny(token: string, code: string) -> bool {
    if token.eq(code) { return true; }
    if token.eq("all") || token.eq("*") { return true; }
    if token.eq("alloc") {
        if code.eq("unfreed-alloc") || code.eq("arena-not-freed") { return true; }
    }
    if token.eq("unused") {
        if code.eq("unused-var") || code.eq("unused-param")
           || code.eq("unused-fn") || code.eq("unnecessary-mut") { return true; }
    }
    if token.eq("experimental") {
        if code.eq("unstable-fn") || code.eq("deprecated-fn") { return true; }
    }
    if token.eq("lint") || token.eq("lint:*") {
        if code.starts_with("lint:") { return true; }
    }
    if token.len() > 1 {
        let last: i32 = token.at(token.len() - 1).to_int();
        if last == 42 {
            let prefix: string = token.substring(0, token.len() - 1);
            if code.starts_with(prefix) { return true; }
        }
    }
    return false;
}

// True when the project's `lint.allow` (from `glide.glide`) covers a
// diagnostic code. Used to drop suppressed warnings from the diag
// stream at the emit-time loops, so manifest-wide silencing works
// across every analysis — including the ones (unused-var, etc.) that
// don't consult `_has_allow` on a per-item basis.
fn _project_allow_drop(code: string) -> bool {
    let p: *void = __glide_proj_allow_get();
    if p == null { return false; }
    let v: *Vector<string> = p as *Vector<string>;
    for let i: i32 = 0; i < v.len(); i++ {
        if _code_matches_deny(v.get(i), code) { return true; }
    }
    return false;
}

fn print_usage() {
    println!("Glide compiler");
    println!("usage:");
    println!("  glide build <file> [-o <out>] [--target=<triple>]  (sysroot auto-fetched; see `glide target list`)");
    println!("  glide run <file>");
    println!("  glide emit <file>          (print generated C to stdout)");
    println!("  glide check <file>         (parse + type-check, no codegen)");
    println!("  glide lint [file]          (run all lints; project bin by default)");
    println!("  glide fix [file]           (apply mechanical fixes — unused-* prefix _)");
    println!("  glide fmt <file> [--write] (pretty-print to stdout, or rewrite in place)");
    println!("  glide new <name> [--lib] [--ai] [--no-vcs]");
    println!("  glide add <name> <git-url> <rev>");
    println!("  glide add <user/repo>[@<rev>]   (shorthand; defaults host=github.com, rev=main)");
    println!("  glide add --local <name> <path>");
    println!("  glide remove <name>        (drop a dep from glide.glide)");
    println!("  glide fetch [path]         (download git deps from glide.glide)");
    println!("  glide update               (refresh every git dep + rewrite lock)");
    println!("  glide tree                 (show the dep graph)");
    println!("  glide info <name>          (manifest+cache metadata for a dep)");
    println!("  glide search <query>       (search github for glide packages)");
    println!("  glide clean                (drop glide_modules/ + glide.lock)");
    println!("  glide install <path>");
    println!("  glide install <git-url> <rev>");
    println!("  glide target <list|add|remove|dir>  (cross-compile sysroots)");
    println!("  glide doc [--open] [--serve[=<port>]] [--ai] [--stdlib]");
    println!("  glide bench [path]         (run *_bench.glide microbenchmarks)");
    println!("  glide lsp                  (language server on stdio)");
}

// `glide fetch [path]` entry point. Walks up from `path` looking for a
// glide.glide, then downloads every git dep that isn't already cached.
fn run_fetch(start: string) -> i32 {
    let root: string = find_manifest_root(start);
    if root.eq("") {
        println!("fetch: no glide.glide found above", start);
        return 1;
    }
    let m: *Manifest = read_manifest(root);
    if m == null {
        println!("fetch: could not parse", root.concat("/glide.glide"));
        return 1;
    }
    // Pass 1: walk the dep graph and fetch every (url, rev) the
    // manifest tree mentions. Populates the cache so pass 2 has
    // sub-manifests to inspect.
    let fetched: i32 = fetch_all(m);
    if fetched == 0 { println!("fetch: everything up to date"); }
    // Pass 2: Go-MVS over the populated cache. Sets the global
    // override so the link + lockfile steps see the resolved rev.
    let mvs_errors: i32 = mvs_resolve(m);
    // Symlinks and lockfile entries now route every URL through the
    // resolved rev — `dep_cache_dir` consults the override map.
    link_all(m);
    let lf: *Lockfile = lockfile_from_manifest(m);
    write_lockfile(root, lf);
    if mvs_errors > 0 { return 1; }
    return 0;
}

// Auto-fetch path used by build/run/test: walks up from the source
// file, parses the manifest if any, fetches missing git deps. Failures
// are non-fatal — the resolver will surface a clean "alias not found"
// error if a dep didn't make it.
fn auto_fetch_for(src_path: string) {
    let dir: string = parent_dir(src_path);
    let root: string = find_manifest_root(dir);
    if root.eq("") { return; }
    let m: *Manifest = read_manifest(root);
    if m == null { return; }
    fetch_all(m);
}

// `glide new <name>` — scaffold a new project. Layout:
//
//     <name>/
//       glide.glide        (canonical manifest, empty deps list)
//       src/main.glide     (hello-world)
//
// Scaffolds into `name`. Two shapes:
//   - `glide new <name>`: creates `<name>/` (errors if it exists).
//   - `glide new .`     : scaffolds into the current directory; the
//                          project name comes from the CWD's basename.
// `--lib` produces a library project: `src/lib.glide` with a sample
// `pub fn` instead of `src/main.glide`, and the manifest omits `bin`.
// `--ai` drops AGENTS.md so any agent landing in the repo starts
// with the rules loaded. `--no-vcs` skips the default `git init`.
// Refuses to clobber an existing `glide.glide`.
fn run_new(name: string, is_lib: bool, emit_ai: bool, init_vcs: bool) -> i32 {
    let mut target_dir: string = name;
    let mut proj_name: string = name;
    let scaffold_in_place: bool = name.eq(".") || name.eq("./") || fs_is_dir(name);

    if scaffold_in_place {
        // Resolve the project name from the directory we're landing in.
        let mut dir: string = name;
        if name.eq(".") || name.eq("./") {
            let r: !string = os_cwd();
            if !r.ok {
                println!("new: could not resolve current directory");
                return 1;
            }
            dir = r.val;
        }
        target_dir = name;
        proj_name = _basename(dir);
        if proj_name.eq("") { proj_name = "project"; }
        // Already a Glide project? Don't clobber.
        if __glide_file_exists(target_dir.concat("/glide.glide")) {
            println!("new:", target_dir, "already contains a glide.glide");
            return 1;
        }
    } else {
        if __glide_file_exists(name) {
            println!("new:", name, "already exists");
            return 1;
        }
    }

    let src_dir: string = target_dir.concat("/src");
    if !fs_mkdir_p(src_dir) {
        println!("new: could not create", src_dir);
        return 1;
    }
    // Libraries declare `bin: ""` so `glide build` / `install` see
    // the project as non-executable and bail with a clear message
    // instead of trying to build a missing main.
    let bin_field: string = if is_lib { "" } else { "src/main.glide" };
    let manifest_body: string =
        "let manifest: Package = Package {\n"
        .concat("    name:        \"").concat(proj_name).concat("\",\n")
        .concat("    version:     \"0.1.0\",\n")
        .concat("    description: \"\",\n")
        .concat("    author:      \"\",\n")
        .concat("    license:     \"\",\n")
        .concat("    repository:  \"\",\n")
        .concat("    bin:         \"").concat(bin_field).concat("\",\n")
        .concat("    deps: vec_of(\n")
        .concat("    ),\n")
        .concat("};\n");
    if !write_file(target_dir.concat("/glide.glide"), manifest_body) {
        println!("new: could not write glide.glide");
        return 1;
    }
    // Don't overwrite an existing src/main.glide / src/lib.glide —
    // the user may have started with hand-written code before turning
    // the dir into a Glide project.
    if is_lib {
        // Library entry is `src/<name>.glide` so the module name equals the
        // package name: a consumer writes `import <name>;` and calls
        // `<name>::fn(...)`. (`module_path_from_path` derives the module
        // from the path after `src/`, so the filename IS the namespace.)
        let lib_path: string = target_dir.concat("/src/").concat(proj_name).concat(".glide");
        if !__glide_file_exists(lib_path) {
            let lib_body: string =
                "/// Greet someone by name.\n"
                .concat("///\n")
                .concat("/// ```glide\n")
                .concat("/// let s: string = hello(\"world\");   // \"hello, world\"\n")
                .concat("/// ```\n")
                .concat("pub fn hello(name: string) -> string {\n")
                .concat("    return \"hello, \".concat(name);\n")
                .concat("}\n");
            if !write_file(lib_path, lib_body) {
                println!("new: could not write", lib_path);
                return 1;
            }
        }
    } else {
        let main_path: string = target_dir.concat("/src/main.glide");
        if !__glide_file_exists(main_path) {
            let main_body: string =
                "fn main() -> i32 {\n"
                .concat("    println!(\"hello from ").concat(proj_name).concat("\");\n")
                .concat("    return 0;\n")
                .concat("}\n");
            if !write_file(main_path, main_body) {
                println!("new: could not write src/main.glide");
                return 1;
            }
        }
    }
    // .gitignore (only if missing — user may have curated their own)
    let gi_path: string = target_dir.concat("/.gitignore");
    if !__glide_file_exists(gi_path) {
        write_file(gi_path, _starter_gitignore());
    }

    // AGENTS.md when `--ai` is on.
    if emit_ai {
        let agents_path: string = target_dir.concat("/AGENTS.md");
        if !__glide_file_exists(agents_path) {
            write_agents_md(agents_path);
        }
    }

    // git init by default; `--no-vcs` opts out. Silent on absent git
    // — no point pretending the scaffold failed because the user
    // doesn't have git installed.
    if init_vcs && !__glide_file_exists(target_dir.concat("/.git")) {
        let cmd: string = "git -C \"".concat(target_dir).concat("\" init -q");
        let rc: i32 = __glide_shell(cmd);
        if rc != 0 {
            println!("(git init skipped — `git` not on PATH or init failed)");
        }
    }

    let kind: string = if is_lib { "library" } else { "binary" };
    if scaffold_in_place {
        println!("created", kind, "project", proj_name, "in", target_dir);
    } else {
        println!("created", kind, "project", target_dir.concat("/"));
    }
    return 0;
}

// Default ignore list dropped at scaffold time. Covers build outputs,
// dep cache symlinks, the test/bench/golden synth files the drivers
// regenerate, Windows debug symbols, and IDE / OS artefacts.
fn _starter_gitignore() -> string {
    return "# Glide build output\n"
        .concat("/build\n")
        .concat("/target\n")
        .concat("/glide_modules\n")
        .concat("\n")
        .concat("# Compiler intermediates + temp executables\n")
        .concat("*.__glide.c\n")
        .concat("__glide_run_tmp*\n")
        .concat("__glide_test_run*\n")
        .concat("__glide_bench_run*\n")
        .concat("__glide_golden*\n")
        .concat("\n")
        .concat("# Native build artefacts\n")
        .concat("*.exe\n")
        .concat("*.pdb\n")
        .concat("*.dll\n")
        .concat("*.dylib\n")
        .concat("*.so\n")
        .concat("a.out\n")
        .concat("\n")
        .concat("# OS / editor\n")
        .concat(".DS_Store\n")
        .concat("Thumbs.db\n")
        .concat(".idea/\n")
        .concat(".vscode/\n")
        .concat("*.swp\n");
}

// Last `/` or `\\`-separated segment of `path`. Drops a trailing
// separator first so `basename("/foo/bar/")` is `bar`.
fn _basename(path: string) -> string {
    let mut end: i32 = path.len();
    while end > 0 {
        let c: i32 = path.at(end - 1).to_int();
        if c == 47 || c == 92 { end = end - 1; }
        else { break; }
    }
    let mut start: i32 = 0;
    let mut i: i32 = 0;
    while i < end {
        let c: i32 = path.at(i).to_int();
        if c == 47 || c == 92 { start = i + 1; }
        i = i + 1;
    }
    if start >= end { return ""; }
    return path.substring(start, end);
}

// `glide add` dispatcher. Three shapes:
//   glide add --local <name> <path>           path dep
//   glide add <name> <git-url> <rev>          explicit git form
//   glide add <user/repo>[@<rev>]             shorthand: alias = repo,
//                                              url = github.com/<user>/<repo>,
//                                              rev = <rev> or "main"
// The shorthand also accepts a full host: `glide add github.com/u/r@v1.0`
// or `glide add gitlab.com/u/r@main`, in which case the host is preserved
// verbatim.
fn run_add(argc: i32) -> i32 {
    let root: string = find_manifest_root(".");
    if root.eq("") { println!("add: no glide.glide found"); return 1; }

    let mut is_local: bool = false;
    let positional: *Vector<string> = Vector::new();
    for let i: i32 = 2; i < argc; i++ {
        let a: string = args_at(i);
        if a.eq("--local") { is_local = true; continue; }
        positional.push(a);
    }

    if is_local {
        if positional.len() < 2 {
            println!("usage: glide add --local <name> <path>");
            return 1;
        }
        let dep_name: string = positional.get(0);
        let dep_path: string = positional.get(1);
        let line: string = "        Dep::path(\"".concat(dep_name)
            .concat("\", \"").concat(dep_path).concat("\"),");
        if !manifest_add_dep_line(root, line) {
            println!("add: could not edit manifest");
            return 1;
        }
        println!("added path dep:", dep_name, "->", dep_path);
        return 0;
    }

    // Shorthand: single positional that looks like `user/repo[@rev]` or
    // `host/user/repo[@rev]`. Expanded into the canonical three-arg form
    // so the manifest line is identical to what `glide add a b c` would
    // produce.
    let mut dep_name: string = "";
    let mut dep_url:  string = "";
    let mut dep_rev:  string = "";
    if positional.len() == 1 {
        let raw: string = positional.get(0);
        let parsed: bool = _expand_add_shorthand(raw, &dep_name, &dep_url, &dep_rev);
        if !parsed {
            println!("usage: glide add <name> <git-url> <rev>");
            println!("       glide add <user/repo>[@<rev>]");
            println!("       glide add --local <name> <path>");
            return 1;
        }
    } else if positional.len() >= 3 {
        dep_name = positional.get(0);
        dep_url  = positional.get(1);
        dep_rev  = positional.get(2);
    } else {
        println!("usage: glide add <name> <git-url> <rev>");
        println!("       glide add <user/repo>[@<rev>]");
        println!("       glide add --local <name> <path>");
        return 1;
    }

    let line: string = "        Dep::git(\"".concat(dep_name)
        .concat("\", \"").concat(dep_url)
        .concat("\", \"").concat(dep_rev).concat("\"),");
    if !manifest_add_dep_line(root, line) {
        println!("add: could not edit manifest");
        return 1;
    }
    println!("added git dep:", dep_name, dep_url, dep_rev);
    // Pull it down immediately so the next build doesn't surprise, and
    // refresh the lockfile to record the new entry.
    let m: *Manifest = read_manifest(root);
    if m != null {
        fetch_all(m);
        link_all(m);
        let lf: *Lockfile = lockfile_from_manifest(m);
        write_lockfile(root, lf);
    }
    return 0;
}

// Parse a shorthand string like `user/repo`, `user/repo@v1.2.3`,
// `github.com/user/repo`, or `gitlab.com/user/repo@main`. Sets *name to
// the repo segment, *url to the URL with host preserved (default
// github.com when only `user/repo` was given), and *rev to the
// post-`@` segment or "main" when absent. Returns false when the shape
// doesn't have at least two `/`-separated path parts.
fn _expand_add_shorthand(raw: string, name: *string, url: *string, rev: *string) -> bool {
    if raw == null || raw.eq("") { return false; }

    // Split on '@' to peel the rev. Only the LAST '@' counts — git URLs
    // never contain one in the host/path part.
    let mut at_idx: i32 = -1;
    for let i: i32 = 0; i < raw.len(); i++ {
        if raw.at(i).to_int() == 64 { at_idx = i; }
    }
    let mut body: string = raw;
    let mut rev_part: string = "main";
    if at_idx >= 0 {
        body = raw.substring(0, at_idx);
        let tail: string = raw.substring(at_idx + 1, raw.len()).trim();
        if !tail.eq("") { rev_part = tail; }
    }

    // Strip a leading scheme so `https://github.com/u/r@v1` works.
    if body.starts_with("https://") { body = body.substring(8, body.len()); }
    else if body.starts_with("http://") { body = body.substring(7, body.len()); }
    else if body.starts_with("git@") { body = body.substring(4, body.len()); }

    // Split on '/' once we know there's no scheme.
    let parts: *Vector<string> = body.split("/");
    let n: i32 = parts.len();
    if n < 2 { return false; }

    let mut host: string = "github.com";
    let mut owner: string = "";
    let mut repo:  string = "";
    if n == 2 {
        owner = parts.get(0);
        repo  = parts.get(1);
    } else {
        // 3+ segments: first is the host, last is the repo, anything in
        // between is the owner path (groups/subgroups for gitlab etc).
        host = parts.get(0);
        let mut owner_buf: string = parts.get(1);
        for let i: i32 = 2; i + 1 < n; i++ {
            owner_buf = owner_buf.concat("/").concat(parts.get(i));
        }
        owner = owner_buf;
        repo  = parts.get(n - 1);
    }
    if owner.eq("") || repo.eq("") { return false; }
    // Trim a trailing `.git` so the dep alias is clean.
    if repo.len() > 4 && repo.substring(repo.len() - 4, repo.len()).eq(".git") {
        repo = repo.substring(0, repo.len() - 4);
    }

    *name = repo;
    *url  = host.concat("/").concat(owner).concat("/").concat(repo);
    *rev  = rev_part;
    return true;
}

fn run_remove(name: string) -> i32 {
    let root: string = find_manifest_root(".");
    if root.eq("") { println!("remove: no glide.glide found"); return 1; }
    if !manifest_remove_dep(root, name) {
        println!("remove: no dep named", name);
        return 1;
    }
    // Drop the glide_modules link too so a stale junction doesn't
    // shadow a future re-add.
    let link: string = root.concat("/glide_modules/").concat(name);
    if fs_is_dir(link) { fs_remove_dir_rec(link); }
    println!("removed:", name);
    return 0;
}

// `glide update` — force-refresh every git dep. Path deps are
// untouched. Wipes the lockfile too so the next fetch writes a fresh
// snapshot.
fn run_update() -> i32 {
    let root: string = find_manifest_root(".");
    if root.eq("") { println!("update: no glide.glide found"); return 1; }
    let m: *Manifest = read_manifest(root);
    if m == null { println!("update: could not parse glide.glide"); return 1; }

    for let i: i32 = 0; i < m.deps.len(); i++ {
        let d: ManifestDep = m.deps.get(i);
        if d.kind != DEP_GIT { continue; }
        let cache: string = dep_cache_dir(m, d);
        if !cache.eq("") && fs_is_dir(cache) {
            fs_remove_dir_rec(cache);
            println!("update:", d.name, "- cache cleared");
        }
    }
    fs_remove_file(root.concat("/glide.lock"));

    let fetched: i32 = fetch_all(m);
    if fetched == 0 { println!("update: nothing to fetch"); }
    link_all(m);
    let lf: *Lockfile = lockfile_from_manifest(m);
    write_lockfile(root, lf);
    return 0;
}

// `glide tree` — walk the manifest's deps transitively and print the
// graph as an indented tree. The MVS override map is populated first so
// shown revs match what would actually be linked. Unfetched git deps
// are tagged "[not fetched]" so the user knows what `glide fetch` would
// pull down.
fn run_tree() -> i32 {
    let root: string = find_manifest_root(".");
    if root.eq("") { println!("tree: no glide.glide found"); return 1; }
    let m: *Manifest = read_manifest(root);
    if m == null { println!("tree: could not parse glide.glide"); return 1; }
    mvs_resolve(m);

    println!(m.name.concat(" v").concat(m.version));
    if m.deps.len() == 0 {
        println!("(no deps declared)");
        return 0;
    }
    let seen: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < m.deps.len(); i++ {
        let d: ManifestDep = m.deps.get(i);
        let last: bool = i + 1 == m.deps.len();
        _print_dep_tree(m, d, "", last, seen);
    }
    return 0;
}

fn _print_dep_tree(m: *Manifest, d: ManifestDep, prefix: string, is_last: bool, seen: *HashMap<bool>) {
    let branch: string = if is_last { "\xe2\x94\x94\xe2\x94\x80 " } else { "\xe2\x94\x9c\xe2\x94\x80 " };
    let label: string = _dep_label(m, d);
    println!(prefix.concat(branch).concat(label));

    if d.kind != DEP_GIT { return; }
    let key: string = d.path.concat("@").concat(d.rev);
    if seen.contains(key) { return; }
    seen.insert(key, true);

    let cache: string = dep_cache_dir(m, d);
    if cache.eq("") || !fs_is_dir(cache) { return; }
    let sub_m: *Manifest = read_manifest(cache);
    if sub_m == null || sub_m.deps.len() == 0 { return; }

    let child_prefix: string = prefix.concat(if is_last { "   " } else { "\xe2\x94\x82  " });
    for let i: i32 = 0; i < sub_m.deps.len(); i++ {
        let sd: ManifestDep = sub_m.deps.get(i);
        let last: bool = i + 1 == sub_m.deps.len();
        _print_dep_tree(sub_m, sd, child_prefix, last, seen);
    }
}

fn _dep_label(m: *Manifest, d: ManifestDep) -> string {
    if d.kind == DEP_PATH {
        return d.name.concat(" (path: ").concat(d.path).concat(")");
    }
    // Git: include the effective rev (post-MVS) and a [not fetched] tag
    // when the cache slot is missing on disk.
    let mut eff_rev: string = d.rev;
    let ov: *HashMap<string> = mvs_get_override();
    if ov != null && ov.contains(d.path) { eff_rev = ov.get(d.path); }
    let mut tag: string = "";
    let cache: string = dep_cache_dir(m, d);
    if cache.eq("") || !fs_is_dir(cache) { tag = " [not fetched]"; }
    return d.name.concat(" (").concat(d.path).concat("@").concat(eff_rev).concat(")").concat(tag);
}

// `glide info <name>` — print metadata for a dep declared in the
// current project's manifest. Useful when the user wants to know where
// it lives on disk, what rev is cached, or whether a fetch is still
// pending.
fn run_info(name: string) -> i32 {
    let root: string = find_manifest_root(".");
    if root.eq("") { println!("info: no glide.glide found"); return 1; }
    let m: *Manifest = read_manifest(root);
    if m == null { println!("info: could not parse glide.glide"); return 1; }

    let mut found: bool = false;
    for let i: i32 = 0; i < m.deps.len(); i++ {
        let d: ManifestDep = m.deps.get(i);
        if !d.name.eq(name) { continue; }
        found = true;
        println!("name:     ", d.name);
        if d.kind == DEP_PATH {
            println!("kind:      path");
            println!("path:     ", d.path);
            let dir: string = dep_cache_dir(m, d);
            println!("resolves: ", dir);
            println!("on disk:  ", if fs_is_dir(dir) { "yes" } else { "no" });
        } else {
            println!("kind:      git");
            println!("url:      ", d.path);
            println!("rev:      ", d.rev);
            let dir: string = dep_cache_dir(m, d);
            println!("cache:    ", dir);
            let cached: bool = fs_is_dir(dir);
            println!("fetched:  ", if cached { "yes" } else { "no" });
            if cached {
                let hash: string = read_dep_hash(m, d);
                if !hash.eq("") { println!("hash:     ", hash); }
                let sub_m: *Manifest = read_manifest(dir);
                if sub_m != null {
                    if !sub_m.description.eq("") { println!("desc:     ", sub_m.description); }
                    if !sub_m.repository.eq("")  { println!("repo:     ", sub_m.repository); }
                    if !sub_m.license.eq("")     { println!("license:  ", sub_m.license); }
                    println!("transitive deps:", int_to_str(sub_m.deps.len() as i64));
                }
            } else {
                println!("(run `glide fetch` to download it)");
            }
        }
        break;
    }
    if !found {
        println!("info: no dep named", name);
        if m.deps.len() > 0 {
            println!("declared deps:");
            for let i: i32 = 0; i < m.deps.len(); i++ {
                println!("  ", m.deps.get(i).name);
            }
        }
        return 1;
    }
    return 0;
}

// `glide search <q>` — hit the GitHub search API for repositories whose
// description / name matches `<q>` and that look like Glide packages
// (language=Glide isn't tracked by GitHub yet, so we filter on a
// `glide.glide` file in the root via a code-search fall-back). Prints
// the top hits with a copy-pasteable `glide add` shorthand.
fn run_search(query: string) -> i32 {
    if query.eq("") { println!("usage: glide search <query>"); return 1; }
    // GitHub's repo search supports `q=<terms>+filename:glide.glide` via
    // the code-search endpoint; the repo endpoint doesn't filter on
    // file presence, so we query the code endpoint and de-dupe by repo
    // full_name. This lands a "real Glide project" filter even though
    // GitHub doesn't know about the language tag yet.
    let url: string = "https://api.github.com/search/code?per_page=20&q="
        .concat(_url_escape(query))
        .concat("+filename:glide.glide");
    let tmp: string = _search_tmp_path();
    // Use Accept header to pin the API version; `-fsS` so a 4xx /
    // network error returns a non-zero exit instead of writing the
    // HTML error page into tmp.
    let cmd: string =
        "curl -fsS -H \"Accept: application/vnd.github+json\" -o \"".concat(tmp)
        .concat("\" \"").concat(url).concat("\"");
    let rc: i32 = __glide_shell(cmd);
    if rc != 0 {
        println!("search: network call failed (rc=".concat(int_to_str(rc as i64)).concat(")"));
        println!("(GitHub's API rate-limits unauthenticated requests; retry in a minute or set GITHUB_TOKEN)");
        return 1;
    }
    let body: string = read_file(tmp);
    fs_remove_file(tmp);
    if body.eq("") { println!("search: empty response"); return 1; }

    // De-dupe hits by `repository.full_name` and pull out description +
    // star count via a second per-repo GET-light pass. We avoid that
    // pass here to stay within rate limits — the repo full_name + the
    // shorthand is enough for `glide add`.
    let seen_repos: *HashMap<bool> = HashMap::new();
    let mut shown: i32 = 0;
    let mut idx: i32 = 0;
    while idx < body.len() && shown < 5 {
        let full: string = _extract_str_field(body, "full_name", idx);
        if full.eq("") { break; }
        idx = _advance_after(body, "full_name", idx);
        if seen_repos.contains(full) { continue; }
        seen_repos.insert(full, true);
        println!(full);
        println!("  glide add", full);
        shown = shown + 1;
    }
    if shown == 0 { println!("search: no hits for", query); return 1; }
    return 0;
}

fn _url_escape(s: string) -> string {
    let mut out: string = "";
    for let i: i32 = 0; i < s.len(); i++ {
        let c: i32 = s.at(i).to_int();
        let alnum: bool = (c >= 48 && c <= 57) || (c >= 65 && c <= 90) || (c >= 97 && c <= 122);
        if alnum || c == 45 || c == 46 || c == 95 {
            out = out.concat(s.substring(i, i + 1));
        } else if c == 32 {
            out = out.concat("+");
        } else {
            // Hex-encode the byte. Tiny bespoke table since stdlib::url
            // isn't on the bootstrap import path yet.
            let hex: string = "0123456789ABCDEF";
            let hi: i32 = (c >> 4) & 15;
            let lo: i32 = c & 15;
            out = out.concat("%").concat(hex.substring(hi, hi + 1)).concat(hex.substring(lo, lo + 1));
        }
    }
    return out;
}

fn _search_tmp_path() -> string {
    let tmp: string = __glide_getenv("TMP");
    if !tmp.eq("") { return tmp.concat("/glide_search.json"); }
    let tmp2: string = __glide_getenv("TMPDIR");
    if !tmp2.eq("") { return tmp2.concat("/glide_search.json"); }
    return "./.glide_search.json";
}

// Tiny JSON scan: find `"<key>": "<value>"` after `from`. Doesn't
// handle escape sequences in the value beyond `\"` (GitHub's
// full_name doesn't contain unicode escapes), which is enough for the
// search use case.
fn _extract_str_field(body: string, key: string, from: i32) -> string {
    let needle: string = "\"".concat(key).concat("\"");
    let mut i: i32 = from;
    while i + needle.len() <= body.len() {
        let mut hit: bool = true;
        for let j: i32 = 0; j < needle.len(); j++ {
            if body.at(i + j).to_int() != needle.at(j).to_int() { hit = false; break; }
        }
        if hit {
            // Skip whitespace + ':' + whitespace + '"' to land at the
            // first char of the value.
            let mut k: i32 = i + needle.len();
            while k < body.len() && (body.at(k).to_int() == 32 || body.at(k).to_int() == 58) { k = k + 1; }
            if k >= body.len() || body.at(k).to_int() != 34 { return ""; }
            k = k + 1;
            let mut end: i32 = k;
            while end < body.len() {
                let c: i32 = body.at(end).to_int();
                if c == 92 { end = end + 2; continue; }
                if c == 34 { break; }
                end = end + 1;
            }
            return body.substring(k, end);
        }
        i = i + 1;
    }
    return "";
}

fn _advance_after(body: string, key: string, from: i32) -> i32 {
    let needle: string = "\"".concat(key).concat("\"");
    let mut i: i32 = from;
    while i + needle.len() <= body.len() {
        let mut hit: bool = true;
        for let j: i32 = 0; j < needle.len(); j++ {
            if body.at(i + j).to_int() != needle.at(j).to_int() { hit = false; break; }
        }
        if hit { return i + needle.len(); }
        i = i + 1;
    }
    return body.len();
}

// `glide install <target> [rev]`:
//
//   glide install .                            # CWD project
//   glide install ../my_tool                   # local path
//   glide install github.com/u/r v1.0          # fetch + build + install
//
// Builds the target project's binary (`bin` from the manifest, default
// `src/main.glide`), copies it to `~/.glide/bin/<name>`, and warns
// when that directory isn't on PATH. Local installs build in place;
// git installs pull through the same fetch + cache path as `glide
// fetch`.
fn run_install(argc: i32) -> i32 {
    if argc < 3 {
        println!("usage: glide install <path>");
        println!("       glide install <git-url> <rev>");
        return 1;
    }
    let target: string = args_at(2);

    let mut project_root: string = "";
    if _looks_like_url(target) {
        if argc < 4 {
            println!("install: git URL needs a rev (tag / branch / commit)");
            return 1;
        }
        let rev: string = args_at(3);
        project_root = _fetch_for_install(target, rev);
        if project_root.eq("") { return 1; }
    } else {
        project_root = target;
        if !fs_is_dir(project_root) {
            println!("install: not a directory:", project_root);
            return 1;
        }
    }

    let m: *Manifest = read_manifest(project_root);
    if m == null {
        println!("install: no glide.glide in", project_root);
        return 1;
    }
    if m.name.eq("") {
        println!("install: manifest has no name field");
        return 1;
    }

    let bin_src: string = project_root.concat("/").concat(m.bin);
    let mut bin_name: string = m.name;
    if __glide_is_windows() != 0 { bin_name = bin_name.concat(".exe"); }

    let install_dir: string = _bin_root();
    if !fs_mkdir_p(install_dir) {
        println!("install: could not create", install_dir);
        return 1;
    }
    let final_path: string = install_dir.concat("/").concat(bin_name);

    // Build straight to the install path. Saves a copy step and keeps
    // the spinner's progress output coherent.
    let rc: i32 = run_build(bin_src, final_path, "", false);
    if rc != 0 { return rc; }

    // Compiler-style installs ship a `src/` tree alongside the binary
    // so the installed glide can find its own stdlib + builtins
    // wherever the user invokes it. Detected by the presence of
    // `src/builtins/builtins.glide` — generic enough for any tool
    // that wants to ride the same convention.
    let src_origin: string = project_root.concat("/src");
    if __glide_file_exists(src_origin.concat("/builtins/builtins.glide")) {
        let src_dest: string = install_dir.concat("/src");
        fs_remove_dir_rec(src_dest);
        if fs_copy_dir_rec(src_origin, src_dest) {
            println!("installed runtime ->", src_dest);
        } else {
            println!("warning: could not copy", src_origin, "->", src_dest,
                     "(install/build will fall back to CWD lookup)");
        }
    }

    // Proc-macro support: ship `bootstrap/` alongside `src/` so
    // `stdlib::http::handler` and `stdlib::json::derive` can resolve
    // their `import bootstrap::ast::*` / `import bootstrap::interp::*`
    // at proc-macro expand time. Without these, the LSP can't surface
    // `Stmt`/`Expr`/`Type` types for goto/hover inside the proc fns,
    // and the install can't act as a host for user-authored proc
    // macros either.
    let bs_origin: string = project_root.concat("/bootstrap");
    if fs_is_dir(bs_origin) {
        let bs_dest: string = install_dir.concat("/bootstrap");
        fs_remove_dir_rec(bs_dest);
        if fs_copy_dir_rec(bs_origin, bs_dest) {
            println!("installed bootstrap ->", bs_dest);
        } else {
            println!("warning: could not copy", bs_origin, "->", bs_dest,
                     "(proc-macros may lose goto/hover on bootstrap types)");
        }
    }

    // Same idea for `runtime/zig/`. Without it, `--target=<triple>`
    // builds can't find a cross-capable cc. Optional — we skip
    // silently when there's no zig in the source tree.
    let zig_origin: string = project_root.concat("/runtime/zig");
    if fs_is_dir(zig_origin) {
        let zig_dest: string = install_dir.concat("/runtime/zig");
        fs_remove_dir_rec(zig_dest);
        if fs_copy_dir_rec(zig_origin, zig_dest) {
            println!("installed toolchain ->", zig_dest);
        } else {
            println!("warning: could not copy", zig_origin, "->", zig_dest,
                     "(cross-compile will fall back to system zig if present)");
        }
    }

    println!("installed", m.name, "->", final_path);
    _ensure_on_path(install_dir);
    return 0;
}

// `~/.glide/bin` — sits next to the dep cache. Created lazily.
fn _bin_root() -> string {
    let home: !string = os_home_dir();
    if !home.ok {
        let tmp: string = __glide_getenv("TMP");
        if !tmp.eq("") { return tmp.concat("/.glide/bin"); }
        return "./.glide_bin";
    }
    return home.val.concat("/.glide/bin");
}

// Heuristic for `glide install` arg classification. Anything that
// looks like a hostname or http(s) URL goes through the fetcher;
// everything else is a local path.
fn _looks_like_url(s: string) -> bool {
    if s.starts_with("http://")  { return true; }
    if s.starts_with("https://") { return true; }
    if s.starts_with("git@")     { return true; }
    if s.starts_with("github.com/") { return true; }
    if s.starts_with("gitlab.com/") { return true; }
    if s.starts_with("bitbucket.org/") { return true; }
    return false;
}

// Stand up a one-shot manifest with `target` as a single git dep and
// drive the existing fetch path through it. Returns the cache dir on
// success, "" on failure.
fn _fetch_for_install(url: string, rev: string) -> string {
    let synthetic: ManifestDep;
    synthetic.name = "_install_target";
    synthetic.kind = DEP_GIT;
    synthetic.path = url;
    synthetic.rev  = rev;

    // `dep_cache_dir` only reads `path` + `rev` for git deps, so an
    // empty manifest works as the carrier.
    let m: *Manifest = __glide_palloc(sizeof(Manifest)) as *Manifest;
    m.name = "";
    m.version = "";
    m.bin = "src/main.glide";
    m.deps = Vector::new();
    m.root_dir = ".";

    return ensure_fetched(m, synthetic);
}

// Make sure `dir` ends up on the user's PATH. On Windows we do the
// modification ourselves (PowerShell touching HKCU\Environment) so the
// next shell sees the bin without the user copying a setx line by hand.
// On POSIX we still just print the export — picking the right rc file
// (`~/.zshrc` vs `~/.bash_profile` vs `~/.config/fish/config.fish`)
// without trampling the user's setup is too noisy.
fn _ensure_on_path(dir: string) {
    let path_env: string = __glide_getenv("PATH");
    if !path_env.eq("") && _path_contains(path_env, dir) { return; }
    if __glide_is_windows() != 0 {
        _add_to_user_path_win(dir);
    } else {
        println!("");
        println!("note:", dir, "is not on your PATH.");
        println!("      add `export PATH=\"".concat(dir).concat(":$PATH\"` to your shell rc."));
    }
}

// Modify the user-scope PATH via PowerShell. We avoid `setx PATH
// "%PATH%;..."` because %PATH% at runtime is the SYSTEM+USER merge —
// setx would duplicate every system entry into the user PATH. Reading
// only the User scope lets us append cleanly.
fn _add_to_user_path_win(dir: string) {
    let bs: string = _to_backslashes(dir);
    let ps: string =
        "$p = [Environment]::GetEnvironmentVariable('PATH', 'User');"
        .concat(" if ($p -eq $null) { $p = '' };")
        .concat(" if (-not $p.Contains('").concat(bs).concat("')) {")
        .concat(" if ($p -eq '') { $new = '").concat(bs).concat("' } else { $new = $p + ';").concat(bs).concat("' };")
        .concat(" [Environment]::SetEnvironmentVariable('PATH', $new, 'User');")
        .concat(" Write-Host 'glide: added' '").concat(bs).concat("' 'to user PATH'")
        .concat(" } else { Write-Host 'glide: already on user PATH' }");
    let cmd: string = "powershell -NoProfile -Command \"".concat(ps).concat("\"");
    let rc: i32 = __glide_shell(cmd);
    if rc != 0 {
        println!("");
        println!("note: could not modify PATH automatically (powershell missing?).");
        println!("      run manually:");
        println!("        setx PATH \"%PATH%;", bs, "\"");
    } else {
        println!("(restart your shell to pick up the new PATH)");
    }
}

fn _to_backslashes(s: string) -> string {
    let mut out: string = "";
    for let i: i32 = 0; i < s.len(); i++ {
        let c: i32 = s.at(i).to_int();
        if c == 47 { out = out.concat("\\"); }
        else       { out = out.concat(s.substring(i, i + 1)); }
    }
    return out;
}

// Split `path_env` on the platform separator (`;` on Windows, `:` on
// POSIX) and look for an exact match with `dir`. Comparison is
// case-sensitive on POSIX and case-insensitive on Windows.
fn _path_contains(path_env: string, dir: string) -> bool {
    let sep_char: i32 = 58;  // ':' POSIX
    if __glide_is_windows() != 0 { sep_char = 59; }  // ';'
    let mut start: i32 = 0;
    let n: i32 = path_env.len();
    let win: bool = __glide_is_windows() != 0;
    for let i: i32 = 0; i <= n; i++ {
        let at_end: bool = i == n;
        let c: i32 = 0;
        if !at_end { c = path_env.at(i).to_int(); }
        if at_end || c == sep_char {
            let seg: string = path_env.substring(start, i);
            if _path_eq(seg, dir, win) { return true; }
            start = i + 1;
        }
    }
    return false;
}

fn _path_eq(a: string, b: string, win: bool) -> bool {
    if !win { return a.eq(b); }
    if a.len() != b.len() { return false; }
    for let i: i32 = 0; i < a.len(); i++ {
        let ca: i32 = a.at(i).to_int();
        let cb: i32 = b.at(i).to_int();
        if ca >= 65 && ca <= 90 { ca = ca + 32; }
        if cb >= 65 && cb <= 90 { cb = cb + 32; }
        if ca == 92 { ca = 47; }
        if cb == 92 { cb = 47; }
        if ca != cb { return false; }
    }
    return true;
}

// Compute the build output path when the user didn't pass `-o`. In a
// project, every build lands under `<root>/build/<name>[.exe]` so the
// tree stays clean. Outside a project the fall-back depends on whether
// we're about to run the binary:
//
//   - `glide build foo.glide`  → a.exe / a.out in CWD (back-compat)
//   - `glide run foo.glide`    → temp dir (no CWD pollution)
fn _default_out_path(project_root: string, project_name: string, then_run: bool, target: string) -> string {
    let want_exe: bool = _target_wants_exe(target);
    if !project_root.eq("") {
        let build_dir: string = project_root.concat("/build");
        fs_mkdir_p(build_dir);
        let mut name: string = project_name;
        if name.eq("") { name = "app"; }
        if want_exe { name = name.concat(".exe"); }
        return build_dir.concat("/").concat(name);
    }
    if then_run {
        let tmp: string = _temp_dir();
        let mut name: string = "glide_run_tmp";
        if want_exe { name = name.concat(".exe"); }
        return tmp.concat("/").concat(name);
    }
    if want_exe { return "a.exe"; }
    return "a.out";
}

// `.exe` belongs on Windows binaries. When the user passes a target we
// follow the *target*'s OS; otherwise we follow the host.
fn _target_wants_exe(target: string) -> bool {
    if !target.eq("") {
        let os: string = _target_os(target);
        if !os.eq("") { return os.eq("windows"); }
    }
    return __glide_is_windows() != 0;
}

// Scratch directory for transient build artefacts (test/bench wrappers,
// golden runners, etc). In a project we drop them under `build/` so the
// tree stays clean; outside a project we fall back to the system temp
// dir. Created lazily — callers can assume it exists on success.
fn _scratch_dir() -> string {
    let root: string = find_manifest_root(".");
    if !root.eq("") {
        let d: string = root.concat("/build");
        fs_mkdir_p(d);
        return d;
    }
    return _temp_dir();
}

// Best-effort system temp dir lookup. Windows uses TEMP/TMP; POSIX
// falls back to /tmp.
fn _temp_dir() -> string {
    let win: bool = __glide_is_windows() != 0;
    let env_name: string = if win { "TEMP" } else { "TMPDIR" };
    let mut t: string = __glide_getenv(env_name);
    if t.eq("") { t = __glide_getenv("TMP"); }
    if t.eq("") {
        if win { return "."; }
        return "/tmp";
    }
    return t;
}

// Parse a decimal port string. Returns 0 on any non-digit or overflow.
fn _parse_port(s: string) -> i32 {
    if s.eq("") { return 0; }
    let mut acc: i32 = 0;
    for let i: i32 = 0; i < s.len(); i++ {
        let c: i32 = s.at(i).to_int();
        if c < 48 || c > 57 { return 0; }
        acc = (acc * 10) + (c - 48);
        if acc > 65535 { return 0; }
    }
    return acc;
}

// Render one diagnostic as a single JSON object on its own line —
// the `jsonl` format CI tools and editor plugins parse cheaply. Keys
// are stable: severity ("error"/"warning"/"info"), code, message,
// file (relative path), line/col (1-based), end_line/end_col.
fn _diag_to_jsonl(d: *DiagEntry, fallback_path: string) -> string {
    let mut path: string = d.origin;
    if path == null || path.eq("") { path = fallback_path; }
    let mut sev: string = "info";
    if d.severity == 1 { sev = "error"; }
    else if d.severity == 2 { sev = "warning"; }
    let mut out: string = "{";
    out = out.concat("\"severity\":\"").concat(sev).concat("\"");
    out = out.concat(",\"code\":\"").concat(_json_esc(d.code)).concat("\"");
    out = out.concat(",\"file\":\"").concat(_json_esc(path)).concat("\"");
    out = out.concat(",\"line\":").concat(int_to_str(d.line));
    out = out.concat(",\"col\":").concat(int_to_str(d.col));
    out = out.concat(",\"end_line\":").concat(int_to_str(d.end_line));
    out = out.concat(",\"end_col\":").concat(int_to_str(d.end_col));
    out = out.concat(",\"message\":\"").concat(_json_esc(d.message)).concat("\"");
    out = out.concat("}");
    return out;
}

// Minimal string escaper for the keys/values above. Covers `"`, `\\`,
// control chars below 0x20, and newlines/tabs. JSON-spec compliant
// for ASCII; non-ASCII bytes pass through unchanged (UTF-8).
fn _json_esc(s: string) -> string {
    if s == null { return ""; }
    let mut out: string = "";
    for let i: i32 = 0; i < s.len(); i++ {
        let c: i32 = s.at(i).to_int();
        if c == 34 { out = out.concat("\\\""); }
        else if c == 92 { out = out.concat("\\\\"); }
        else if c == 10 { out = out.concat("\\n"); }
        else if c == 13 { out = out.concat("\\r"); }
        else if c == 9 { out = out.concat("\\t"); }
        else if c < 32 { out = out.concat(" "); }
        else { out = out.concat(s.substring(i, i + 1)); }
    }
    return out;
}

fn _wants_json(argc: i32) -> bool {
    for let i: i32 = 0; i < argc; i++ {
        if args_at(i).eq("--json") { return true; }
    }
    return false;
}

// Counters returned by `_lint_one_file` so the directory walker can
// aggregate per-file results into a single summary line.
struct LintCounts {
    errors: i32,
    warnings: i32,
    promoted: i32,
    parse_failed: bool,
}

// `glide lint <target>` — `target` is either a file or a directory.
// File: run the analyses on it. Directory: walk every `.glide` under
// it (using fs_list_rec, same helper `glide doc` uses) and aggregate
// per-file counts. `--all` shows diagnostics from imported files;
// `--json` emits one JSON object per diagnostic (no summary).
// `--lint-as-error=<code>` promotes warnings into the failing set.
fn run_lint(target: string, argc: i32) -> i32 {
    let json: bool = _wants_json(argc);
    let mut want_all: bool = false;
    for let k: i32 = 0; k < argc; k++ {
        if args_at(k).eq("--all") { want_all = true; }
    }

    let mut files: *Vector<string> = Vector::new();
    if fs_is_dir(target) {
        files = fs_list_rec(target, ".glide");
    } else {
        files.push(target);
    }
    // Don't lint manifests — they're a literal `Package {…}` binding
    // with no code worth surfacing diagnostics on.
    let kept: *Vector<string> = Vector::new();
    for let i: i32 = 0; i < files.len(); i++ {
        let f: string = files.get(i);
        if _ends_with_str(f, "/glide.glide") || _ends_with_str(f, "\\glide.glide") { continue; }
        kept.push(f);
    }

    let mut total_errors: i32 = 0;
    let mut total_warnings: i32 = 0;
    let mut total_promoted: i32 = 0;
    let mut bad_parses: i32 = 0;
    for let i: i32 = 0; i < kept.len(); i++ {
        let f: string = kept.get(i);
        let r: LintCounts = _lint_one_file(f, want_all, json);
        total_errors = total_errors + r.errors;
        total_warnings = total_warnings + r.warnings;
        total_promoted = total_promoted + r.promoted;
        if r.parse_failed { bad_parses = bad_parses + 1; }
    }

    if !json {
        println!("");
        let mut summary: string = "lint: ".concat(int_to_str(total_errors)).concat(" error");
        if total_errors != 1 { summary = summary.concat("s"); }
        summary = summary.concat(", ").concat(int_to_str(total_warnings)).concat(" warning");
        if total_warnings != 1 { summary = summary.concat("s"); }
        if kept.len() > 1 {
            summary = summary.concat(" across ").concat(int_to_str(kept.len())).concat(" files");
        }
        if total_promoted > 0 {
            summary = summary.concat(" (").concat(int_to_str(total_promoted)).concat(" promoted via --lint-as-error)");
        }
        println!(summary);
    }
    if total_errors > 0 || total_promoted > 0 || bad_parses > 0 { return 1; }
    return 0;
}

// Run the lint pipeline on a single file and return per-file counts.
// Diagnostics are printed inline (or JSON-emitted) as they come, so
// the caller doesn't need to re-serialise.
fn _lint_one_file(src_path: string, want_all: bool, json: bool) -> LintCounts {
    let mut r: LintCounts = LintCounts {
        errors: 0, warnings: 0, promoted: 0, parse_failed: false,
    };
    apply_lint_for(parent_dir(src_path));
    let stmts: *Vector<Stmt> = Vector::new();
    let pdiags: *Vector<ParseDiag> = Vector::new();
    if !parse_program_into(stmts, src_path, pdiags) {
        r.parse_failed = true;
        return r;
    }
    let t: *Typer = Typer::new();
    merge_parse_diags(t, pdiags);
    build_visibility(t, stmts);
    t.enforce_visibility = true;
    check_program(t, stmts);
    run_extra_analyses(t, stmts);

    let src_text: string = read_file(src_path);
    let mut last_path: string = "";
    let mut last_snip: string = src_text;
    for let i: i32 = 0; i < t.diagnostics.len(); i++ {
        let d: DiagEntry = t.diagnostics.get(i);
        let mut path: string = d.origin;
        if path.eq("") { path = src_path; }
        if !want_all && !path.eq(src_path) { continue; }
        if d.severity == 2 && _project_allow_drop(d.code) { continue; }
        let promote: bool = d.severity == 2 && _is_lint_promoted(d.code);
        if json {
            println!(_diag_to_jsonl(&d, src_path));
        } else {
            let mut snippet: string = src_text;
            if !path.eq(src_path) {
                if !path.eq(last_path) {
                    last_snip = read_file(path);
                    last_path = path;
                }
                snippet = last_snip;
            }
            print_pretty_diag(d, snippet, path);
        }
        if d.severity == 1 { r.errors = r.errors + 1; }
        else if d.severity == 2 {
            r.warnings = r.warnings + 1;
            if promote { r.promoted = r.promoted + 1; }
        }
    }
    t.free();
    return r;
}

// `glide fix <target>` — apply mechanical auto-fixes inferred from
// the lint stream. Currently handles `unused-{var,param,fn}` by
// prefixing the named binding with `_`. Other repairs (removing
// `mut`, inserting `defer free(...)`, etc.) need source-text token
// scanning we haven't wired yet; they're a natural next iteration.
fn run_fix(target: string) -> i32 {
    let mut files: *Vector<string> = Vector::new();
    if fs_is_dir(target) {
        files = fs_list_rec(target, ".glide");
    } else {
        files.push(target);
    }
    let mut total_changed: i32 = 0;
    let mut total_edits: i32 = 0;
    for let i: i32 = 0; i < files.len(); i++ {
        let f: string = files.get(i);
        if _ends_with_str(f, "/glide.glide") || _ends_with_str(f, "\\glide.glide") { continue; }
        let n: i32 = _fix_one_file(f);
        if n > 0 { total_changed = total_changed + 1; total_edits = total_edits + n; }
    }
    println!("fix:", int_to_str(total_edits), "edits across", int_to_str(total_changed), "files");
    return 0;
}

fn _fix_one_file(src_path: string) -> i32 {
    apply_lint_for(parent_dir(src_path));
    let stmts: *Vector<Stmt> = Vector::new();
    let pdiags: *Vector<ParseDiag> = Vector::new();
    if !parse_program_into(stmts, src_path, pdiags) { return 0; }
    let t: *Typer = Typer::new();
    merge_parse_diags(t, pdiags);
    build_visibility(t, stmts);
    t.enforce_visibility = true;
    check_program(t, stmts);
    run_extra_analyses(t, stmts);

    // Two channels of fixes:
    //   1. Diagnostics that carry an explicit fix_replacement (set by
    //      `warn_with_fix`) — apply the replacement over its range.
    //   2. Legacy `unused-var` / `unused-param` codes that we know
    //      mean "prefix with _" even when the lint didn't fill in
    //      fix fields. Lets the unmigrated analyses still benefit.
    let starts: *Vector<i32> = Vector::new();
    let ends: *Vector<i32> = Vector::new();
    let repls: *Vector<string> = Vector::new();
    for let i: i32 = 0; i < t.diagnostics.len(); i++ {
        let d: DiagEntry = t.diagnostics.get(i);
        let mut origin: string = d.origin;
        if origin.eq("") { origin = src_path; }
        if !origin.eq(src_path) { continue; }
        if !d.fix_replacement.eq("") || d.fix_line > 0 {
            starts.push(_offset_of(d.fix_line, d.fix_col, src_path));
            ends.push(_offset_of(d.fix_end_line, d.fix_end_col, src_path));
            repls.push(d.fix_replacement);
            continue;
        }
        if d.code.eq("unused-var") || d.code.eq("unused-param") {
            let off: i32 = _offset_of(d.line, d.col, src_path);
            starts.push(off);
            ends.push(off);
            repls.push("_");
        }
    }
    t.free();
    if starts.len() == 0 { return 0; }

    // Sort by descending start so each splice doesn't invalidate the
    // remaining offsets. Selection sort — N is small.
    _sort_fixes_desc(starts, ends, repls);

    let src: string = read_file(src_path);
    let mut buf: string = src;
    let mut applied: i32 = 0;
    let mut prev_start: i32 = -1;
    for let i: i32 = 0; i < starts.len(); i++ {
        let off: i32 = starts.get(i);
        let endo: i32 = ends.get(i);
        let rep: string = repls.get(i);
        // Dedupe identical offsets — happens when two analyses both
        // flag the same site.
        if off == prev_start { continue; }
        prev_start = off;
        if off < 0 || off > buf.len() || endo < off || endo > buf.len() { continue; }
        // For insertion fixes (zero-width range) inserting `_`, skip if
        // the source already has `_` at that position.
        if off == endo && rep.eq("_") && off < buf.len() && buf.at(off).to_int() == 95 { continue; }
        let head: string = buf.substring(0, off);
        let tail: string = buf.substring(endo, buf.len());
        buf = head.concat(rep).concat(tail);
        applied = applied + 1;
    }
    if applied == 0 { return 0; }
    write_file(src_path, buf);
    println!("  fixed", int_to_str(applied), "→", src_path);
    return applied;
}

// Translate (1-indexed line, 1-indexed col) into a 0-based char offset
// inside the file at `src_path`. Returns -1 when the position is
// outside the file. Caches line starts per file via a tiny memoization
// to avoid re-scanning the source on every diagnostic — fix runs hit
// `_offset_of` once per diagnostic but most files have one fix.
fn _offset_of(line: i32, col: i32, src_path: string) -> i32 {
    if line < 1 { return -1; }
    let src: string = read_file(src_path);
    let mut cur_line: i32 = 1;
    let mut off: i32 = 0;
    while off < src.len() && cur_line < line {
        if src.at(off).to_int() == 10 { cur_line = cur_line + 1; }
        off = off + 1;
    }
    if cur_line != line { return -1; }
    let result: i32 = off + col - 1;
    if result < 0 || result > src.len() { return -1; }
    return result;
}

fn _sort_fixes_desc(starts: *Vector<i32>, ends: *Vector<i32>, repls: *Vector<string>) {
    let n: i32 = starts.len();
    for let i: i32 = 0; i < n - 1; i++ {
        let mut max_idx: i32 = i;
        for let j: i32 = i + 1; j < n; j++ {
            if starts.get(j) > starts.get(max_idx) { max_idx = j; }
        }
        if max_idx != i {
            let ts: i32 = starts.get(i); starts.set(i, starts.get(max_idx)); starts.set(max_idx, ts);
            let te: i32 = ends.get(i);   ends.set(i, ends.get(max_idx));     ends.set(max_idx, te);
            let tr: string = repls.get(i); repls.set(i, repls.get(max_idx)); repls.set(max_idx, tr);
        }
    }
}

// Plain ASCII suffix check, since stdlib::str is not in scope here.
fn _ends_with_str(s: string, suffix: string) -> bool {
    if s == null || suffix == null { return false; }
    if suffix.len() > s.len() { return false; }
    return s.substring(s.len() - suffix.len(), s.len()).eq(suffix);
}

// `glide clean` — wipe the per-project state. Doesn't touch the global
// cache (other projects share it).
fn run_clean() -> i32 {
    let root: string = find_manifest_root(".");
    if root.eq("") { println!("clean: no glide.glide found"); return 1; }
    fs_remove_dir_rec(root.concat("/glide_modules"));
    fs_remove_dir_rec(root.concat("/build"));
    fs_remove_file(root.concat("/glide.lock"));
    println!("clean: removed glide_modules/, build/ and glide.lock");
    return 0;
}

// `merge_parse_diags` moved to typer.glide so the LSP can reach it
// without importing main (which would be a circular dep).

// Build the per-file visibility map the typer uses to enforce selective
// imports. For each file `F` we accept a name `N` if any of:
//   * `N` is declared (pub or otherwise) in `F` itself
//   * `N` lives under `src/builtins/` (the implicit prelude)
//   * `N` is brought in by an `import` statement in `F`:
//     - `import a::b::c::N;` / `import a::b::c::{N, ...};` — selective
//     - `import a::b::c::*;` / `import "..."`              — all pub from target
// Insert into `into_f`'s visibility every name `target` exports: its own
// `pub` decls, plus — transitively — the exports of any module `target`
// pulls in with `pub import` (re-export). `seen` guards cyclic re-export
// graphs. This is what lets a barrel/prelude file collect symbols from
// several files and expose them under one import.


fn parse_program_into(stmts: *Vector<Stmt>, path: string, pdiags: *Vector<ParseDiag>) -> bool {
    let src: string = read_file(path);
    if src.eq("") {
        println!("could not read or empty file:", path);
        return false;
    }
    let loaded: *HashMap<bool> = HashMap::new();
    // Auto-inject `src/builtins/` — primitive types (Vector, string methods)
    // and the extern stubs every program inherently needs (malloc, printf,
    // sleep_ms, ...). Anything under `src/stdlib/` (HashMap, io, fs, time,
    // env, random, math, bytes) still requires an explicit `import`.
    // Resolve the builtins dir across the three layouts, in order:
    //   1. `src/builtins`              — repo checkout / cwd
    //   2. `<exe>/src/builtins`        — installed-next-to-binary
    //   3. `<home>/.glide/src/builtins`— bundle self-extract target
    // The last one is what makes a bundle binary work from any cwd: the
    // embedded `src/` tree lands under ~/.glide/src on first run, and
    // without this probe the Vector / string-method prelude wouldn't load
    // and every `v.push(...)` / `v.get(...)` would degrade to a field
    // access on an incomplete type.
    let mut builtins_dir: string = "src/builtins";
    if !__glide_file_exists("src/builtins/builtins.glide") {
        let exe_dir: string = __glide_exe_dir();
        let mut found: bool = false;
        if !exe_dir.eq("") {
            let exe_bi: string = exe_dir.concat("/src/builtins");
            if __glide_file_exists(exe_bi.concat("/builtins.glide")) {
                builtins_dir = exe_bi;
                found = true;
            }
        }
        if !found {
            let home: !string = os_home_dir();
            if home.ok {
                let home_bi: string = home.val.concat("/.glide/src/builtins");
                if __glide_file_exists(home_bi.concat("/builtins.glide")) {
                    builtins_dir = home_bi;
                }
            }
        }
    }
    // Freestanding / kernel projects don't get the hosted builtins prelude
    // (its arena uses mmap, its helpers call libc). The kernel supplies its
    // own primitives. Detected from the project's glide.glide.
    let mut _fs_skip_builtins: bool = false;
    let _bi_root: string = find_manifest_root(parent_dir(path));
    if !_bi_root.eq("") {
        let _bi_m: *Manifest = read_manifest(_bi_root);
        if _bi_m != null { _fs_skip_builtins = _bi_m.freestanding; }
    }
    if !_fs_skip_builtins {
        load_builtins_dir(stmts, builtins_dir, loaded, pdiags);
    }
    load_into_str(stmts, src, path, loaded, pdiags);
    let expanded: *Vector<Stmt> = expand_macros(stmts);
    let lowered: *Vector<Stmt> = lower_program(expanded);
    stmts.clear();
    for let i: i32 = 0; i < lowered.len(); i++ {
        let s: Stmt = lowered.get(i);
        stmts.push(s);
    }
    return true;
}

// Host C compiler with a plug-and-play fallback. Resolution order:
//   1. $CC (explicit override)
//   2. `cc` / `gcc` on PATH (gcc / clang / MSYS2 / Apple CLT)
//   3. the bundled zig as `cc` — ONLY when the program links no heavy
//      libs. Vanilla zig has no openssl/zlib, so it can only serve the
//      lib-free case, but that case is the bulk of programs and this is
//      what lets a clean machine (no system C compiler) build with just
//      the Glide download.
// Returns "" when nothing usable is found, so the caller can print a
// targeted hint.
fn pick_cc_host(needs_libs: bool) -> string {
    let env: string = __glide_getenv("CC");
    if !env.eq("") { return env; }
    if _have_on_path("cc")  { return "cc"; }
    if _have_on_path("gcc") { return "gcc"; }
    if !needs_libs {
        let zig: string = _find_zig();
        if !zig.eq("") { return "\"".concat(zig).concat("\" cc"); }
    }
    return "";
}

// Compile backend specifically for `--target=<triple>`. Plain `cc` (gcc)
// doesn't grok the `--target=` syntax, so cross-compile *requires* zig.
// Returns the backend command on success, or a human-readable error on
// failure. Resolution order matches `pick_cc` but skips $CC (which may
// well be host-only gcc).
fn pick_cc_for_target() -> !string {
    let zig: string = _find_zig();
    if zig.eq("") {
        return err("--target requires zig (not found beside the glide binary, in ./runtime/zig/, or on PATH).\n"
            .concat("  Install with: bash tools/install_toolchain.sh   (POSIX)\n")
            .concat("               powershell -f tools/install_toolchain.ps1   (Windows)\n")
            .concat("  Or install zig system-wide and re-run."));
    }
    return ok("\"".concat(zig).concat("\" cc"));
}

// Bundled zig (next to the binary, in `~/.glide/runtime/`, or in the
// source tree). Cross-compile also accepts a system `zig` on PATH via
// `_find_zig` — but host builds don't, because system zigs typically
// lack the openssl/zlib sysroot.
//
// Probes for both `zig.exe` and `zig` on Windows because zig's release
// tarballs ship the binary without the `.exe` suffix on some
// distributions — cmd.exe still launches it via the PATHEXT lookup.
fn _find_bundled_zig() -> string {
    let win: bool = __glide_is_windows() != 0;

    let exe_dir: string = __glide_exe_dir();
    let roots: *Vector<string> = Vector::new();
    if !exe_dir.eq("") { roots.push(exe_dir.concat("/runtime/zig")); }
    let home: !string = os_home_dir();
    if home.ok { roots.push(home.val.concat("/.glide/runtime/zig")); }
    roots.push("./runtime/zig");

    for let i: i32 = 0; i < roots.len(); i++ {
        let root: string = roots.get(i);
        // On Windows, only return a path the shell can actually launch
        // via cmd.exe / system(). A bare `zig` with no extension exists
        // in some Zig releases but cmd.exe refuses to run it; in that
        // case we fall back to the next probe (or system PATH) where a
        // `.exe`-suffixed binary is more likely.
        if win {
            let p_exe: string = root.concat("/zig.exe");
            if __glide_file_exists(p_exe) { return p_exe; }
        } else {
            let p: string = root.concat("/zig");
            if __glide_file_exists(p) { return p; }
        }
    }
    return "";
}

// Any usable zig — bundled first, then embedded (one-time self-extract
// from a bundle binary), then `zig` on PATH. Used by cross-compile,
// which doesn't link the heavy host-only libs and so doesn't need a
// configured sysroot.
fn _find_zig() -> string {
    let bundled: string = _find_bundled_zig();
    if !bundled.eq("") { return bundled; }
    if has_embedded_zig() {
        let extracted: string = _extract_embedded_zig();
        if !extracted.eq("") { return extracted; }
    }
    if _have_on_path("zig") { return "zig"; }
    return "";
}

// Extract the embedded `src/` tree (Glide stdlib + builtins) into
// `~/.glide/src/` on first run. The marker file `.glide_src_version`
// records which compiler version laid it out, so a fresh install
// always reads the matching stdlib. No-op on non-bundle builds and on
// repeat runs.
fn _maybe_install_embedded_src() {
    if !has_embedded_src() { return; }
    let home: !string = os_home_dir();
    if !home.ok { return; }
    let dest_root: string = home.val.concat("/.glide");
    let dest_src: string = dest_root.concat("/src");
    let marker: string = dest_src.concat("/.glide_src_version");

    // Marker already matches → nothing to do.
    if __glide_file_exists(marker) {
        let v: string = read_file(marker).trim();
        if v.eq(GLIDE_VERSION) { return; }
    }

    let bytes_ptr: *void = embedded_src();
    let bytes_len: i32 = embedded_src_len();
    if bytes_ptr == null || bytes_len <= 0 { return; }

    let archive_gz: string = __glide_string_from_buf(bytes_ptr, bytes_len);
    let mut decoded_len: i32 = 0;
    let raw: *void = gzip_decode(archive_gz, bytes_len, &decoded_len);
    if raw == null || decoded_len <= 0 { return; }
    let archive: string = __glide_string_from_buf(raw, decoded_len);

    fs_mkdir_p(dest_root);
    fs_remove_dir_rec(dest_src);
    if !fs_mkdir_p(dest_src) { free(raw); return; }
    // strip-1 collapses the leading `src/` directory in the tarball so
    // the contents land directly under `~/.glide/src/`.
    let extracted: i32 = tar_extract(archive, decoded_len, dest_src, 1);
    free(raw);
    if extracted < 0 {
        fs_remove_dir_rec(dest_src);
        return;
    }
    // Drop the marker so next run short-circuits.
    write_file(marker, GLIDE_VERSION);
}

// Extract the embedded Zig tarball into `~/.glide/runtime/zig/` the
// first time a build needs it. Idempotent — subsequent calls hit the
// already-laid-out tree via `_find_bundled_zig`. Returns the path to
// the zig binary on success, "" on failure.
fn _extract_embedded_zig() -> string {
    let win: bool = __glide_is_windows() != 0;
    let bytes_ptr: *void = embedded_zig();
    let bytes_len: i32 = embedded_zig_len();
    if bytes_ptr == null || bytes_len <= 0 { return ""; }

    let home: !string = os_home_dir();
    if !home.ok { return ""; }
    let runtime_dir: string = home.val.concat("/.glide/runtime");
    let zig_dir: string = runtime_dir.concat("/zig");

    let zig_exe: string = zig_dir.concat("/zig.exe");
    let zig_bare: string = zig_dir.concat("/zig");
    if win && __glide_file_exists(zig_exe) { return zig_exe; }
    if __glide_file_exists(zig_bare) { return zig_bare; }

    spinner_start("unpacking bundled Zig toolchain");
    if !fs_mkdir_p(runtime_dir) {
        spinner_finish(false, "");
        return "";
    }
    fs_remove_dir_rec(zig_dir);
    if !fs_mkdir_p(zig_dir) {
        spinner_finish(false, "");
        return "";
    }

    let archive_gz: string = __glide_string_from_buf(bytes_ptr, bytes_len);
    let mut decoded_len: i32 = 0;
    let raw: *void = gzip_decode(archive_gz, bytes_len, &decoded_len);
    if raw == null || decoded_len <= 0 {
        spinner_finish(false, "");
        return "";
    }
    let archive: string = __glide_string_from_buf(raw, decoded_len);
    // The Zig release tarball nests its files under a versioned dir
    // (`zig-<os>-<arch>-<ver>/`); strip-1 flattens that so we land
    // straight into `zig_dir`.
    let extracted: i32 = tar_extract(archive, decoded_len, zig_dir, 1);
    free(raw);
    if extracted < 0 {
        spinner_finish(false, "");
        fs_remove_dir_rec(zig_dir);
        return "";
    }
    // Windows demands the `.exe`; bare `zig` on Windows usually means
    // the bundle accidentally carried a Linux build and the shell
    // can't launch it. Treat that case as a failure so the user falls
    // back to the system PATH instead of silently producing a broken
    // command.
    if win {
        if __glide_file_exists(zig_exe) {
            spinner_finish(true, "Zig toolchain installed");
            return zig_exe;
        }
        spinner_finish(false, "");
        fs_remove_dir_rec(zig_dir);
        return "";
    }
    if __glide_file_exists(zig_bare) {
        spinner_finish(true, "Zig toolchain installed");
        return zig_bare;
    }
    spinner_finish(false, "");
    fs_remove_dir_rec(zig_dir);
    return "";
}

// `command -v` / `where` thin wrapper. Returns true if the program
// resolves on PATH.
fn _have_on_path(prog: string) -> bool {
    let cmd: string = if __glide_is_windows() != 0 {
        "where ".concat(prog).concat(" >nul 2>&1")
    } else {
        "command -v ".concat(prog).concat(" >/dev/null 2>&1")
    };
    return __glide_shell(cmd) == 0;
}

// Root for cached cross-compile sysroots (`glide target add ...`
// writes here; `--target=<triple>` reads). Mirrors `_bin_root()` shape.
fn _target_root() -> string {
    let home: !string = os_home_dir();
    if !home.ok {
        let tmp: string = __glide_getenv("TMP");
        if !tmp.eq("") { return tmp.concat("/.glide/targets"); }
        return "./.glide_targets";
    }
    return home.val.concat("/.glide/targets");
}

// Directory holding the cached sysroot for `triple` (if installed).
// Layout: <_target_root()>/<triple>/{include,lib}/.
fn _target_dir(triple: string) -> string {
    return _target_root().concat("/").concat(triple);
}

// Path to the host-architecture static-lib bundle shipped with the
// glide install. `tools/build_release.sh --bundle-libs` stages
// `lib/{libssl.a, libcrypto.a, libz.a, libngtcp2.a,
// libngtcp2_crypto_ossl.a, libnghttp3.a}` alongside the binary; host
// builds prefer those statics over system dynamic libs, eliminating
// the `apt install libssl-dev / libngtcp2-dev` prerequisite for end
// users.
//
// Returns "" when no bundle is present so the caller falls back to
// system dynamic linkage.
fn _host_lib_bundle_dir() -> string {
    let exe_dir: string = __glide_exe_dir();
    if exe_dir.eq("") { return ""; }
    // Install-style layout (~/.glide/bin/glide → ~/.glide/lib/) first;
    // inline layout (lib/ as a sibling of the binary in the dist
    // tarball) second.
    let install_lib: string = exe_dir.concat("/../lib");
    if fs_exists(install_lib.concat("/libssl.a")) { return install_lib; }
    let inline_lib: string = exe_dir.concat("/lib");
    if fs_exists(inline_lib.concat("/libssl.a")) { return inline_lib; }
    return "";
}

// Compute the canonical zig-style triple for the current host, e.g.
// `x86_64-windows-gnu`, `aarch64-linux-musl`, `aarch64-macos-none`.
// Returns "" only on truly unrecognised arch/OS combinations.
//
// Used by host-build sysroot probing: when the user runs a bare `glide
// build` (no --target=) and a sysroot for the host triple is already
// installed under ~/.glide/targets/, the build is wired through it
// instead of trying to resolve openssl/ngtcp2/… against system libs.
// That's what makes a fresh `glide install` plug-and-play — no MSYS2 /
// `apt install libssl-dev` / brew openssl required.
fn _host_triple() -> string {
    let arch: string = __glide_os_arch();
    let os: string = __glide_os_name();
    if arch.eq("") || os.eq("") || os.eq("unknown") || arch.eq("unknown") { return ""; }
    // Pick the libc/runtime tag matching the sysroots Glide actually
    // ships. Linux → musl (fully static portable binary), Windows →
    // gnu (mingw-w64), macOS → none (Apple uses the system runtime
    // directly, no libc tag).
    let mut abi: string = "";
    if os.eq("linux")   { abi = "musl"; }
    else if os.eq("windows") { abi = "gnu"; }
    else if os.eq("macos")   { abi = "none"; }
    else { return ""; }
    return arch.concat("-").concat(os).concat("-").concat(abi);
}

extern fn __glide_os_arch() -> string;
extern fn __glide_os_name() -> string;

// Returns true when a usable sysroot is cached for `triple` — checked
// by probing for the openssl ssl.h header which every TLS-aware
// cross build needs.
fn _has_target_sysroot(triple: string) -> bool {
    if triple.eq("") { return false; }
    let probe: string = _target_dir(triple).concat("/include/openssl/ssl.h");
    return __glide_file_exists(probe);
}

// Parse the OS field out of a Zig triple. Accepts e.g.:
//   x86_64-linux-gnu       -> "linux"
//   aarch64-macos-none     -> "macos"
//   x86_64-windows-gnu     -> "windows"
//   riscv64-linux-musl     -> "linux"
// Returns "" if the triple isn't recognisable.
fn _target_os(triple: string) -> string {
    if triple.eq("") { return ""; }
    let parts: *Vector<string> = triple.split("-");
    if parts.len() < 2 { return ""; }
    let os: string = parts.get(1);
    if os.eq("linux") || os.eq("macos") || os.eq("darwin")
        || os.eq("windows") || os.eq("freebsd") || os.eq("netbsd")
        || os.eq("openbsd") || os.eq("wasi") {
        return os;
    }
    return "";
}

// Triples we know how to fetch a sysroot for. Order matters: the
// first entry is what `glide target list` highlights as the default
// suggestion. Extend as we publish more.
fn _known_targets() -> *Vector<string> {
    let v: *Vector<string> = Vector::new();
    v.push("x86_64-linux-musl");
    v.push("aarch64-linux-musl");
    v.push("x86_64-windows-gnu");
    v.push("aarch64-macos-none");
    return v;
}

fn _is_known_target(triple: string) -> bool {
    let v: *Vector<string> = _known_targets();
    for let i: i32 = 0; i < v.len(); i++ {
        if v.get(i).eq(triple) { return true; }
    }
    return false;
}

// `glide target` dispatcher. Subcommands:
//   list           show installed + available targets
//   dir            print the cache root
//   add <triple>   fetch + stage a sysroot for cross-compilation
//   remove <t>     drop a cached sysroot (`rm` works too)
fn run_target(argc: i32) -> i32 {
    if argc < 3 { _print_target_help(); return 1; }
    let sub: string = args_at(2);
    if sub.eq("list") || sub.eq("ls") { return _target_list(); }
    if sub.eq("dir") {
        println!(_target_root());
        return 0;
    }
    if sub.eq("add") {
        if argc < 4 { println!("usage: glide target add <triple>"); return 1; }
        return _target_add(args_at(3));
    }
    if sub.eq("remove") || sub.eq("rm") {
        if argc < 4 { println!("usage: glide target remove <triple>"); return 1; }
        return _target_remove(args_at(3));
    }
    _print_target_help();
    return 1;
}

fn _print_target_help() {
    println!("usage: glide target <subcommand>");
    println!("");
    println!("Subcommands:");
    println!("  list                    show cross-compile targets + status");
    println!("  dir                     print the cache root");
    println!("  add <triple>            pre-fetch a target's sysroot");
    println!("  remove <triple>         drop a cached sysroot");
    println!("");
    println!("Sysroots ship the headers + static libs (openssl, zlib) the");
    println!("bundled zig toolchain doesn't carry. They're fetched");
    println!("automatically on the first `glide build --target=<triple>`,");
    println!("so `add` is only needed to pre-warm the cache (e.g. offline).");
    println!("Cache root:", _target_root());
}

// Human-friendly one-liner for a target triple — the architecture and
// what it's good for. Drives the `glide target list` tips. Empty for
// triples we don't have a blurb for.
fn _target_desc(triple: string) -> string {
    if triple.eq("x86_64-linux-musl")  { return "Linux on Intel/AMD 64-bit  (fully static musl)"; }
    if triple.eq("aarch64-linux-musl") { return "Linux on ARM64 — Graviton, Ampere, Raspberry Pi, cloud ARM  (static musl)"; }
    if triple.eq("x86_64-windows-gnu") { return "Windows on Intel/AMD 64-bit  (static mingw-w64)"; }
    if triple.eq("aarch64-macos-none") { return "macOS on Apple Silicon — M1, M2, M3, M4"; }
    return "";
}

fn _target_list() -> i32 {
    let known: *Vector<string> = _known_targets();
    println!("Cross-compile targets — fetched automatically on first build:");
    println!("");
    for let i: i32 = 0; i < known.len(); i++ {
        let t: string = known.get(i);
        let mut tag: string = "available";
        if _has_target_sysroot(t) { tag = "installed"; }
        // Pad the triple so the descriptions line up in a column.
        let mut label: string = t;
        while label.len() < 22 { label = label.concat(" "); }
        let line: string = "  ".concat(label).concat("[").concat(tag).concat("]  ").concat(_target_desc(t));
        println!(line);
    }
    println!("");
    println!("Build for one:    glide build --target=x86_64-linux-musl app.glide");
    println!("Set a default:    add  target: \"x86_64-linux-musl\"  to glide.glide");
    println!("Cache root:      ", _target_root());
    return 0;
}

// Extract an embedded sysroot tarball into `~/.glide/targets/<triple>/`.
// Returns 0 on success, non-zero on any decode / write failure so the
// caller can fall back to the network path.
//
// The embedded blob is a tar.gz held in .rodata — never freed. We wrap
// it in a Glide string for the existing gzip_decode / tar_extract
// APIs, then free only the decoder's own output buffer.
fn _install_sysroot_from_embed(triple: string) -> i32 {
    let bytes_ptr: *void = embedded_sysroot(triple);
    let bytes_len: i32 = embedded_sysroot_len(triple);
    if bytes_ptr == null || bytes_len <= 0 { return 1; }

    let archive_gz: string = __glide_string_from_buf(bytes_ptr, bytes_len);
    let mut decoded_len: i32 = 0;
    let raw: *void = gzip_decode(archive_gz, bytes_len, &decoded_len);
    if raw == null || decoded_len <= 0 { return 1; }
    let archive: string = __glide_string_from_buf(raw, decoded_len);

    let dest: string = _target_dir(triple);
    fs_remove_dir_rec(dest);
    if !fs_mkdir_p(dest) {
        free(raw);
        return 1;
    }
    let extracted: i32 = tar_extract(archive, decoded_len, dest, 0);
    free(raw);
    if extracted < 0 {
        fs_remove_dir_rec(dest);
        return 1;
    }
    if !_has_target_sysroot(triple) {
        fs_remove_dir_rec(dest);
        return 1;
    }
    return 0;
}

fn _target_add(triple: string) -> i32 {
    if !_is_known_target(triple) {
        println!("target:", triple, "is not a known target.");
        println!("Run `glide target list` to see what's available.");
        return 1;
    }
    if _has_target_sysroot(triple) {
        println!("target:", triple, "is already installed at", _target_dir(triple));
        return 0;
    }
    let root: string = _target_root();
    if !fs_mkdir_p(root) {
        println!("target: could not create cache root:", root);
        return 1;
    }

    // Bundle build: a sysroot baked into the binary skips the network
    // entirely. Decode in-memory and lay the files out exactly the
    // way the curl + tar path would.
    if has_embedded_sysroot(triple) {
        spinner_start("installing ".concat(triple).concat(" (embedded)"));
        let rc_embed: i32 = _install_sysroot_from_embed(triple);
        if rc_embed == 0 {
            spinner_finish(true, "installed ".concat(triple).concat(" -> ").concat(_target_dir(triple)));
            return 0;
        }
        spinner_finish(false, "");
        println!("target: embedded sysroot for", triple, "failed to extract; falling back to network.");
    }

    let archive_name: string = "glide-sysroot-".concat(triple).concat("-").concat(GLIDE_VERSION).concat(".tar.gz");
    let url: string = "https://github.com/glide-lang/Glide/releases/download/v"
        .concat(GLIDE_VERSION).concat("/").concat(archive_name);
    let tmp_archive: string = root.concat("/.glide_target_fetch.tar.gz");
    spinner_start("fetching ".concat(triple).concat(" (").concat(archive_name).concat(")"));
    let curl_cmd: string = "curl -fsSL -o \"".concat(tmp_archive).concat("\" \"").concat(url).concat("\"");
    let rc_fetch: i32 = __glide_shell(curl_cmd);
    if rc_fetch != 0 {
        spinner_finish(false, "");
        println!("target: download failed (curl exit", rc_fetch, ")");
        println!("       url:", url);
        fs_remove_file(tmp_archive);
        return 1;
    }
    spinner_set("extracting ".concat(triple));
    let dest: string = _target_dir(triple);
    fs_remove_dir_rec(dest);
    if !fs_mkdir_p(dest) {
        spinner_finish(false, "");
        println!("target: could not create", dest);
        fs_remove_file(tmp_archive);
        return 1;
    }
    // Extract in-process (gzip_decode + tar_extract), NOT via the system
    // `tar`: GNU tar on Windows/MSYS reads an absolute path like `C:\...` as a
    // remote `host:path` ("tar (child): Cannot connect to C: resolve failed"),
    // pipes nothing to gzip ("unexpected end of file"), and aborts — so the
    // sysroot never installs and every build re-fetches and re-spews the
    // error. The in-process path is what the embedded-sysroot install already
    // uses and works on every host.
    let mut read_len: i32 = 0;
    let archive_gz: string = fs_read_bytes(tmp_archive, &read_len);
    fs_remove_file(tmp_archive);
    if read_len <= 0 {
        spinner_finish(false, "");
        println!("target: downloaded archive was empty");
        fs_remove_dir_rec(dest);
        return 1;
    }
    let mut decoded_len: i32 = 0;
    let raw: *void = gzip_decode(archive_gz, read_len, &decoded_len);
    if raw == null || decoded_len <= 0 {
        spinner_finish(false, "");
        println!("target: could not inflate sysroot archive");
        fs_remove_dir_rec(dest);
        return 1;
    }
    let archive: string = __glide_string_from_buf(raw, decoded_len);
    let extracted: i32 = tar_extract(archive, decoded_len, dest, 0);
    free(raw);
    if extracted < 0 {
        spinner_finish(false, "");
        println!("target: extraction failed");
        fs_remove_dir_rec(dest);
        return 1;
    }
    if !_has_target_sysroot(triple) {
        spinner_finish(false, "");
        println!("target: archive extracted but openssl headers missing — bad bundle?");
        return 1;
    }
    spinner_finish(true, "installed ".concat(triple).concat(" -> ").concat(dest));
    return 0;
}

fn _target_remove(triple: string) -> i32 {
    let dir: string = _target_dir(triple);
    if !fs_is_dir(dir) {
        println!("target:", triple, "is not installed.");
        return 1;
    }
    fs_remove_dir_rec(dir);
    println!("removed", triple, "->", dir);
    return 0;
}

fn run_build(src_path: string, out_path: string, target: string, then_run: bool) -> i32 {
    return run_build_q(src_path, out_path, target, then_run, false);
}

// Same as `run_build` but with a `quiet` knob — the test / golden
// runners drive lots of builds in a row and the spinner-per-build
// would flood the log in non-TTY mode (no in-place redraw).
fn run_build_q(src_path: string, out_path: string, target: string, then_run: bool, quiet: bool) -> i32 {
    // 0. Auto-fetch missing git deps from the project's glide.glide
    //    before we start parsing anything. No-op when there's no manifest.
    auto_fetch_for(src_path);
    apply_lint_for(parent_dir(src_path));

    // Freestanding / kernel build is declared in glide.glide (`kind: "kernel"`
    // or `freestanding: true` + `linker: "<file>"`). Resolve it here so codegen
    // drops the hosted runtime and the cc step links freestanding.
    let mut freestanding: bool = false;
    let mut link_script: string = "";
    let _mroot: string = find_manifest_root(parent_dir(src_path));
    if !_mroot.eq("") {
        let _m: *Manifest = read_manifest(_mroot);
        if _m != null {
            freestanding = _m.freestanding;
            if !_m.link_script.eq("") {
                link_script = _mroot.concat("/").concat(_m.link_script);
            }
        }
    }

    if !quiet { spinner_start("parsing ".concat(src_path)); }

    // 1. Parse
    let stmts: *Vector<Stmt> = Vector::new();
    let pdiags: *Vector<ParseDiag> = Vector::new();
    if !parse_program_into(stmts, src_path, pdiags) {
        if !quiet { spinner_finish(false, "parse failed"); }
        return 1;
    }

    // 2. Type-check. Abort the build before codegen if the user file has
    //    errors (e.g. infinite-recursion, type mismatches).
    if !quiet { spinner_set("typechecking"); }
    let t: *Typer = Typer::new();
    t.freestanding = freestanding;
    merge_parse_diags(t, pdiags);
    build_visibility(t, stmts);
    t.enforce_visibility = true;
    check_program(t, stmts);
    run_extra_analyses(t, stmts);
    let src_text: string = read_file(src_path);
    let mut errors: i32 = 0;
    for let i: i32 = 0; i < t.diagnostics.len(); i++ {
        let d: DiagEntry = t.diagnostics.get(i);
        let mut dpath: string = d.origin;
        if dpath.eq("") { dpath = src_path; }
        if !dpath.eq(src_path) { continue; }
        // Drop warnings the project's `lint.allow` covers (manifest-wide).
        if d.severity == 2 && _project_allow_drop(d.code) { continue; }
        // Promote warning → error when `--lint-as-error=<code>` matches.
        // We don't mutate the original entry (it stays in the typer's
        // diagnostic list at severity 2), but we count it against the
        // error budget so the build refuses.
        let promoted: bool = d.severity == 2 && _is_lint_promoted(d.code);
        print_pretty_diag(d, src_text, dpath);
        if d.severity == 1 || promoted { errors = errors + 1; }
    }
    if errors > 0 {
        let mut tail: string = "could not compile due to 1 previous error";
        if errors > 1 { tail = "could not compile due to ".concat(int_to_str(errors)).concat(" previous errors"); }
        if !quiet { spinner_finish(false, ""); }
        println!(col_red().concat("error").concat(col_reset()).concat(": ").concat(tail));
        return 1;
    }

    // 3. Emit C to a temp file by saving stdout, redirecting, then restoring.
    if !quiet { spinner_set("emitting C"); }
    let tmp_c: string = out_path.concat(".__glide.c");
    let saved: i32 = __glide_redirect_to(tmp_c);
    if saved < 0 {
        if !quiet { spinner_finish(false, "could not open temp file: ".concat(tmp_c)); }
        return 1;
    }
    // Drop proc-macro impl fns + their bootstrap/* AST helpers — the
    // interp consumed them already, and the installed `~/.glide/bin/src`
    // ships no `bootstrap/`, so leaving them in stmts makes codegen emit
    // C referencing `Stmt`/`Expr`/`Type`/`Param` that the user binary
    // has no typedefs for. The visibility / typer passes above need
    // the proc-fns intact (import check reads `@proc_<kind>(Name)`),
    // which is why we strip here, not in `expand_macros`.
    let codegen_stmts: *Vector<Stmt> = strip_compile_time_only(stmts);
    emit_program_mode(codegen_stmts, freestanding);
    __glide_restore_stdout(saved);

    // Freestanding / kernel build: a self-contained path that links the
    // emitted C with zig as a bare-metal x86_64 ELF against the linker
    // script. Skips the hosted lib-scan / -lpthread / run-after-build below.
    if freestanding {
        return _build_freestanding(tmp_c, out_path, link_script, quiet);
    }

    // 3b. Decide which heavy libs to link by scanning the generated C for
    //     the headers each stdlib module pulls in through its c_raw blocks.
    //     Only libs the program actually references get a `-l` flag, so a
    //     program that never touches http/net/compress links against
    //     nothing but libc + pthread — no openssl/zlib/ngtcp2 needed on the
    //     machine. This is what makes a plain `glide build` plug-and-play.
    //     (The baked runtime includes none of these headers, so the scan
    //     is an accurate proxy for real usage.)
    let emitted_c: string = read_file(tmp_c);
    // Match the real `#include <…>` directive (not a bare header name), and
    // build each needle at runtime by concatenation. This matters because
    // the compiler's OWN source carries these very strings as link
    // detection literals — a bare `<openssl/` search would match the
    // compiler compiling itself and link libs it never uses. Only an actual
    // c_raw header include emits the contiguous `#include <…>` directive,
    // and the concatenated needle never appears whole in this source.
    let inc: string = "#include ".concat("<");
    let needs_zlib:    bool = emitted_c.contains(inc.concat("zlib.h>"));
    let needs_ngtcp2:  bool = emitted_c.contains(inc.concat("ngtcp2/"));
    let needs_nghttp3: bool = emitted_c.contains(inc.concat("nghttp3/"));
    let needs_h3:      bool = needs_ngtcp2 || needs_nghttp3;
    // ngtcp2_crypto_ossl pulls openssl, so HTTP/3 implies TLS underneath.
    let needs_ssl:     bool = emitted_c.contains(inc.concat("openssl/")) || needs_h3;
    let needs_any_lib: bool = needs_zlib || needs_ssl || needs_h3;

    // Plug-and-play host build: when the user passes no `--target=` but
    // the host's sysroot is already installed (or auto-fetchable), route
    // the build through the cross-compile pipeline with the host triple.
    // That gives bare `glide build` the same fully-static, self-contained
    // artefact a cross build produces — no system gcc / `apt install
    // libssl-dev` / MSYS2 dependency. The trigger is `needs_any_lib`,
    // so a lib-free program still goes through the cheap native-cc path.
    //
    // Stored as `eff_target` because Glide's codegen emits param + same-
    // named local as two declarations in one C scope, which gcc rejects.
    let mut eff_target: string = target;
    if eff_target.eq("") && needs_any_lib {
        let host_triple: string = _host_triple();
        if !host_triple.eq("") && _is_known_target(host_triple) {
            // Auto-install the host sysroot on first use, same as the
            // explicit-target branch below. Soft-fail to the host-cc
            // path if the download flops (offline, etc.) so old setups
            // still build.
            if !_has_target_sysroot(host_triple) {
                let rc: i32 = _target_add(host_triple);
                if rc == 0 {
                    eff_target = host_triple;
                }
            } else {
                eff_target = host_triple;
            }
        }
    }

    let cross: bool = !eff_target.eq("");

    // Plug-and-play cross compile: fetch a missing sysroot on demand, but
    // ONLY when the program actually links heavy libs. A lib-free program
    // cross-compiles with just zig + musl and needs no sysroot at all.
    // One-time download, no manual `glide target add`.
    if cross && needs_any_lib && _is_known_target(eff_target) && !_has_target_sysroot(eff_target) {
        if _target_add(eff_target) != 0 {
            if !quiet { spinner_finish(false, ""); }
            println!("could not auto-fetch the", eff_target, "sysroot.");
            println!("check your connection, or pre-warm it with: glide target add", eff_target);
            return 1;
        }
    }

    // 4. Build the cc command.
    if !quiet { spinner_set("compiling C -> ".concat(out_path)); }
    let mut cc: string = "";
    if cross {
        let pick: !string = pick_cc_for_target();
        if !pick.ok {
            if !quiet { spinner_finish(false, ""); }
            println!(col_red().concat("error").concat(col_reset()).concat(": ").concat(pick.err));
            return 1;
        }
        cc = pick.val;
    } else {
        // Host backend. Prefer a real system cc; on a bare machine with no
        // C compiler, fall back to the bundled zig as `cc` — but only when
        // the program links no heavy libs, since vanilla zig ships no
        // openssl/zlib. A plain program then builds with zero setup.
        cc = pick_cc_host(needs_any_lib);
        if cc.eq("") {
            if !quiet { spinner_finish(false, ""); }
            println!(col_red().concat("error").concat(col_reset()).concat(": no C compiler found on PATH."));
            if needs_any_lib {
                println!("this program links system libs (openssl/zlib) that the bundled");
                println!("zig can't supply for a host build. Install gcc/clang, or");
                println!("cross-compile to a self-contained target instead:");
                println!("  glide build --target=x86_64-linux-musl", src_path);
            } else {
                println!("install gcc or clang, or keep the bundled zig under runtime/zig/.");
            }
            return 1;
        }
    }
    let mut cmd: string = cc;
    // Quote paths only when they have a space - cmd.exe /c on Windows
    // strips/transforms double quotes in subtle ways that confuse cc's
    // input-file detection, which then hands the raw .c off to ld
    // instead of compiling it first (ld returns 1, build fails).
    // Spaces force quoting; the common case stays bare.
    if tmp_c.contains(" ") {
        cmd = cmd.concat(" \"").concat(tmp_c).concat("\"");
    } else {
        cmd = cmd.concat(" ").concat(tmp_c);
    }
    if out_path.contains(" ") {
        cmd = cmd.concat(" -o \"").concat(out_path).concat("\"");
    } else {
        cmd = cmd.concat(" -o ").concat(out_path);
    }
    // `-g` ships debug info so the runtime trap handler can resolve
    // each frame's instruction pointer back to a function name and
    // source line via dbghelp (Windows) / addr2line (POSIX). Cheap —
    // adds a few MB to the binary, no runtime cost.
    /* -fno-omit-frame-pointer is required for the stack-grow fault
       handler's saved-RBP chain walk (sched.c). Without it the C
       compiler at -O2 strips frame pointers, RBP becomes a
       general-purpose register, and the chain walk reads garbage.
       Cost: ~1-2% in hot loops (one reserved register, two extra
       prologue/epilogue ops). Worth it for the deep-recursion
       safety net the grow handler provides. */
    cmd = cmd.concat(" -O2 -g -w -fno-omit-frame-pointer -D_GNU_SOURCE -Wno-error=implicit-function-declaration -lpthread -lm");
    // HTTP/3: ngtcp2 / nghttp3 headers default to __declspec(dllimport) on
    // Windows, so linking their STATIC archives makes lld-link hunt for
    // __imp_* symbols a `.a` never exports ("undefined symbol: __declspec(
    // dllimport) ngtcp2_crypto_ossl_init"). The *_STATICLIB macros turn the
    // decoration off. Harmless on other targets — the EXTERN collapses to
    // plain, which is the correct form for static linking everywhere.
    if needs_h3 { cmd = cmd.concat(" -DNGTCP2_STATICLIB -DNGHTTP3_STATICLIB"); }
    /* On Linux, link liburing when present so the io_uring reactor
       backend in reactor.c is reachable. The header probe is via
       __has_include so the build still works on hosts without
       liburing-dev (the io_uring code is then #ifdef'd out). */
    let mut want_uring: bool = false;
    if !cross && __glide_is_windows() == 0 {
        if fs_exists("/usr/include/liburing.h")
           || fs_exists("/usr/local/include/liburing.h") {
            want_uring = true;
        }
    } else if cross {
        let target_os: string = _target_os(eff_target);
        if target_os.eq("linux") && _has_target_sysroot(eff_target) {
            let sysroot: string = _target_dir(eff_target);
            if fs_exists(sysroot.concat("/include/liburing.h")) {
                want_uring = true;
            }
        }
    }
    if want_uring { cmd = cmd.concat(" -luring"); }
    if cross {
        cmd = cmd.concat(" --target=").concat(eff_target);
    }
    // Pick platform-specific flags from the target when cross-compiling,
    // otherwise from the host. zig's `--target=` toggles its libc /
    // linker; the rest is winsock/dbghelp vs rdynamic.
    let mut win_target: bool = __glide_is_windows() != 0;
    if cross {
        let os: string = _target_os(eff_target);
        if !os.eq("") { win_target = os.eq("windows"); }
    }
    if win_target {
        cmd = cmd.concat(" -lws2_32 -lmswsock -ldbghelp -lpsapi");
        // Crypt32 backs the Windows cert store bridge used by stdlib::
        // net::tls when SSL is in play — OpenSSL on MSYS2/mingw has an
        // empty default verify path, so every HTTPS verify falls back
        // to enumerating ROOT/CA via CertOpenSystemStoreW.
        if needs_ssl { cmd = cmd.concat(" -lcrypt32"); }
    } else if !cross {
        // -rdynamic only on host POSIX builds — cross builds use static
        // linking where dynamic symbol export isn't applicable.
        cmd = cmd.concat(" -rdynamic");
    }
    // Resolve openssl / crypto / zlib — but only what the program actually
    // references (see the header scan above). A program that uses none of
    // them links against nothing heavy, so no system libs are required.
    //
    // Static-lib link order is one-pass left-to-right: a `-l` pulls .o
    // members only to satisfy refs seen earlier, and ngtcp2_crypto_ossl
    // references ngtcp2/openssl, so the order is crypto_ossl → ngtcp2 →
    // nghttp3 → ssl → crypto → z.
    if !cross {
        // Bundle-aware: if the install ships `<install>/lib/` with the
        // matching static libs, prefer them (self-contained install, no
        // `apt install libssl-dev` needed). Otherwise fall back to system
        // libs on the default search path.
        let bundle: string = _host_lib_bundle_dir();
        let have_bundle: bool = !bundle.eq("") && fs_exists(bundle.concat("/libssl.a"));
        if have_bundle {
            cmd = cmd.concat(" -L\"").concat(bundle).concat("\"");
            if needs_h3   { cmd = cmd.concat(" -l:libngtcp2_crypto_ossl.a -l:libngtcp2.a -l:libnghttp3.a"); }
            if needs_ssl  { cmd = cmd.concat(" -l:libssl.a -l:libcrypto.a"); }
            if needs_zlib { cmd = cmd.concat(" -l:libz.a"); }
        } else {
            // OpenSSL 3.5+ build of ngtcp2 (required for h3.glide's
            // `ngtcp2_crypto_ossl_*` syms) usually lives at /usr/local/lib
            // or /opt/openssl35; add those prefixes first when present.
            if needs_h3 && fs_exists("/usr/local/lib/libngtcp2_crypto_ossl.a") {
                cmd = cmd.concat(" -L/usr/local/lib");
            }
            if needs_ssl && fs_exists("/opt/openssl35/lib/libssl.so") {
                cmd = cmd.concat(" -I/opt/openssl35/include -L/opt/openssl35/lib -Wl,-rpath,/opt/openssl35/lib");
            }
            if needs_h3   { cmd = cmd.concat(" -lngtcp2_crypto_ossl -lngtcp2 -lnghttp3"); }
            if needs_ssl  { cmd = cmd.concat(" -lssl -lcrypto"); }
            if needs_zlib { cmd = cmd.concat(" -lz"); }
        }
    } else if needs_any_lib && _has_target_sysroot(eff_target) {
        let sysroot: string = _target_dir(eff_target);
        cmd = cmd.concat(" -I\"").concat(sysroot).concat("/include\"");
        cmd = cmd.concat(" -L\"").concat(sysroot).concat("/lib\"");
        // Static-link from the sysroot; include ngtcp2 + nghttp3 only when
        // the sysroot ships them (h3-capable cross builds) and the program
        // needs h3. The legacy unconditional `-static -lssl -lcrypto -lz`
        // is now split so a compress-only cross binary skips openssl.
        let has_h3libs: bool = fs_exists(sysroot.concat("/lib/libngtcp2.a"));
        cmd = cmd.concat(" -static");
        if needs_h3 && has_h3libs { cmd = cmd.concat(" -lngtcp2_crypto_ossl -lngtcp2 -lnghttp3"); }
        if needs_ssl  { cmd = cmd.concat(" -lssl -lcrypto"); }
        if needs_zlib { cmd = cmd.concat(" -lz"); }
    } else if cross && _target_os(eff_target).eq("linux") {
        // Lib-free Linux cross build: still static-link libc so the binary
        // is self-contained (runs on any Linux, incl. scratch/distroless).
        cmd = cmd.concat(" -static");
    }

    // On Windows, system() runs the command via `cmd.exe /c <cmd>`. When the
    // command itself starts with a quoted path containing backslashes / spaces,
    // cmd.exe's parser strips outer quotes inconsistently. Wrap the whole
    // thing in an extra layer ONLY when the cc binary is itself quoted - the
    // outer wrap conflicts with cmd.exe's parsing when the inner paths are
    // also quoted, so skip it for the common case of an unquoted cc on PATH.
    if __glide_is_windows() != 0 && cc.starts_with("\"") {
        cmd = "\"".concat(cmd).concat("\"");
    }

    let rc: i32 = __glide_shell(cmd);
    if rc != 0 {
        if !quiet { spinner_finish(false, ""); }
        println!("compilation failed (cc exit", rc, ")");
        println!("preserved C source at:", tmp_c);
        // If we hit a cross build without a sysroot, the user almost
        // always wanted TLS. Surface the fix proactively — no need
        // for them to grep the docs.
        if cross && !_has_target_sysroot(eff_target) && _is_known_target(eff_target) {
            println!("");
            println!("hint: this target has no sysroot cached. If your code uses");
            println!("      stdlib::http or stdlib::net, install one with:");
            println!("        glide target add", eff_target);
        }
        return rc;
    }

    // Build succeeded — the intermediate .__glide.c next to the
    // binary served its purpose. Wipe it so target/ only carries the
    // executable (failure path keeps it for debugging).
    fs_remove_file(tmp_c);

    // Windows runtime-DLL bundling: when we linked against MSYS2/mingw
    // shared libraries (ngtcp2, nghttp3, openssl, …) the produced .exe
    // depends on DLLs that only live in the cc's own bin dir. Without
    // them the binary errors out with exit code 127 the moment Windows
    // tries to load it — silently, before any printf runs. Copy each
    // dependency DLL next to the .exe so it works regardless of the
    // caller's PATH (same approach as Cargo / Go on Windows).
    if __glide_is_windows() != 0 && !cross {
        _bundle_runtime_dlls_win(out_path, cc);
    }

    if !quiet { spinner_finish(true, "built ".concat(out_path)); }

    if then_run {
        // A bare output name (a.exe / a.out) must be qualified with ./ or
        // .\ to be runnable from CWD. A path that already carries a
        // directory component — an absolute temp path, or build/<name> —
        // runs as-is. Prepending ./ to an absolute path like
        // C:\…\glide_run_tmp.exe yields `.\C:\…`, which the OS rejects with
        // "the filename, directory name, or volume label syntax is
        // incorrect" — the exact failure of `glide run` on a loose file.
        let mut run_target: string = out_path;
        if !out_path.contains("/") && !out_path.contains("\\") {
            if __glide_is_windows() != 0 { run_target = ".\\".concat(out_path); }
            else { run_target = "./".concat(out_path); }
        }
        let mut run_cmd: string = "\"".concat(run_target).concat("\"");
        if __glide_is_windows() != 0 {
            run_cmd = "\"".concat(run_cmd).concat("\"");
        }
        return __glide_shell(run_cmd);
    }
    return 0;
}

// Copy runtime DLLs the binary links against (libssl, libcrypto,
// libngtcp2, libnghttp3, libz, plus the mingw C runtime stubs) from the
// cc binary's directory into the same directory as `out_path`. Windows
// searches the .exe's own dir for DLLs before falling back to PATH, so
// this makes the binary self-contained. No-op when the cc dir can't be
// resolved or the DLLs simply aren't there (static link, or a non-mingw
// toolchain).
fn _bundle_runtime_dlls_win(out_path: string, cc: string) {
    let cc_dir: string = _resolve_cc_dir_win(cc);
    if cc_dir.eq("") { return; }
    let dst_dir: string = parent_dir(out_path);
    let final_dst: string = if dst_dir.eq("") { "." } else { dst_dir };

    // Hard-coded prefixes match every shared lib the stdlib transitively
    // links: openssl 3 (ssl + crypto), ngtcp2 + nghttp3 + the OSSL crypto
    // bridge, the optional XZ/zstd/zlib that compress.glide pulls in via
    // libcrypto. Stable across mingw + msys2 ucrt64; the version-suffix
    // bumps don't matter because the prefix match covers them.
    let prefixes: *Vector<string> = Vector::new();
    prefixes.push("libssl-");
    prefixes.push("libcrypto-");
    prefixes.push("libngtcp2-");
    prefixes.push("libngtcp2_crypto_ossl-");
    prefixes.push("libnghttp3-");
    prefixes.push("libnghttp2-");
    prefixes.push("zlib1");
    prefixes.push("libz-");
    prefixes.push("libwinpthread-");

    let entries: *Vector<string> = fs_list(cc_dir, ".dll");
    if entries == null { return; }
    for let i: i32 = 0; i < entries.len(); i++ {
        let name: string = entries.get(i);
        if name.eq("") { continue; }
        let mut matched: bool = false;
        for let j: i32 = 0; j < prefixes.len(); j++ {
            let p: string = prefixes.get(j);
            if name.len() >= p.len() && name.substring(0, p.len()).eq(p) {
                matched = true; break;
            }
        }
        if !matched { continue; }
        let src: string = cc_dir.concat("/").concat(name);
        let dst: string = final_dst.concat("/").concat(name);
        // Skip if the target already has an up-to-date copy. We don't
        // checksum — same-name in the binary's dir means a previous
        // build already placed it. Cheap enough to overwrite blindly
        // (a few MB), but skipping keeps repeated builds fast.
        if __glide_file_exists(dst) { continue; }
        fs_copy_file(src, dst);
    }
}

// Resolve a cc command (e.g. "cc", "gcc", an absolute path, or
// `"path/to/zig" cc`) to the directory holding the cc binary. Uses
// `where` on Windows to look up bare names; absolute paths are split
// at the last separator. Returns "" when we can't tell — caller treats
// that as "skip bundling, the user is on their own".
fn _resolve_cc_dir_win(cc: string) -> string {
    if cc.eq("") { return ""; }
    // `pick_cc_for_target` returns `"<zigpath>" cc` for cross builds;
    // host builds without zig fall through to plain "gcc" / "cc".
    // The zig case never bundles MSYS DLLs (zig's own libc has no
    // openssl), so we just bail.
    if cc.contains("zig") { return ""; }

    let raw: string = cc.trim();
    // Absolute / quoted path: take the dirname directly.
    if raw.len() > 1 && (raw.at(0).to_int() == 34 || raw.contains(":/")
                          || raw.contains(":\\")) {
        let mut p: string = raw;
        if p.at(0).to_int() == 34 {
            // Strip leading `"` and everything from the closing `"`
            // onward (handles `"C:/path/to/cc.exe" -flag`).
            let mut end: i32 = 1;
            while end < p.len() && p.at(end).to_int() != 34 { end = end + 1; }
            p = p.substring(1, end);
        }
        return parent_dir(p);
    }

    // Bare name like `gcc` / `cc`. Use `where` to resolve.
    let tmp: string = _search_tmp_path();
    let cmd: string = "where ".concat(raw).concat(" > \"").concat(tmp).concat("\" 2>nul");
    let rc: i32 = __glide_shell(cmd);
    if rc != 0 { fs_remove_file(tmp); return ""; }
    let body: string = read_file(tmp);
    fs_remove_file(tmp);
    if body.eq("") { return ""; }
    // First non-empty line is the highest-priority hit.
    let lines: *Vector<string> = body.split("\n");
    for let i: i32 = 0; i < lines.len(); i++ {
        let line: string = lines.get(i).trim();
        if !line.eq("") { return parent_dir(line); }
    }
    return "";
}

// Freestanding / kernel link path. Compiles the emitted C as a bare-metal
// x86_64 ELF with zig (clang under the hood): no libc, no startup, no PIE,
// red-zone off for interrupt safety, higher-half code model. The user's
// linker script (`linker:` in glide.glide) owns the layout + entry point.
fn _build_freestanding(tmp_c: string, out_path: string, link_script: string, quiet: bool) -> i32 {
    let zig: string = _find_zig();
    if zig.eq("") {
        if !quiet { spinner_finish(false, ""); }
        println!(col_red().concat("error").concat(col_reset()).concat(": freestanding build requires zig (bundled under runtime/zig/ or on PATH)."));
        return 1;
    }
    if link_script.eq("") {
        if !quiet { spinner_finish(false, ""); }
        println!(col_red().concat("error").concat(col_reset()).concat(": freestanding build needs a linker script — set `linker: \"linker.ld\"` in glide.glide."));
        return 1;
    }
    if !fs_exists(link_script) {
        if !quiet { spinner_finish(false, ""); }
        println!(col_red().concat("error").concat(col_reset()).concat(": linker script not found: ").concat(link_script));
        return 1;
    }
    if !quiet { spinner_set("linking freestanding ELF -> ".concat(out_path)); }
    let mut cmd: string = "\"".concat(zig).concat("\" cc");
    if tmp_c.contains(" ") { cmd = cmd.concat(" \"").concat(tmp_c).concat("\""); }
    else { cmd = cmd.concat(" ").concat(tmp_c); }
    if out_path.contains(" ") { cmd = cmd.concat(" -o \"").concat(out_path).concat("\""); }
    else { cmd = cmd.concat(" -o ").concat(out_path); }
    cmd = cmd.concat(" -target x86_64-freestanding-none");
    cmd = cmd.concat(" -ffreestanding -nostdlib -static -no-pie -fno-pie -fno-pic");
    cmd = cmd.concat(" -fno-stack-protector -mno-red-zone -mcmodel=kernel");
    // NB: SSE stays enabled. zig's compiler_rt fails to build with -mno-sse
    // (half-float ABI needs xmm), and Limine hands the kernel off in long mode
    // with SSE usable. A kernel that wants SSE strictly off would avoid zig's
    // compiler_rt instead. Red-zone is still disabled (interrupt safety).
    cmd = cmd.concat(" -O2 -g -w");
    if link_script.contains(" ") {
        cmd = cmd.concat(" -Wl,-T,\"").concat(link_script).concat("\"");
    } else {
        cmd = cmd.concat(" -Wl,-T,").concat(link_script);
    }
    // Force the entry symbol on the command line: zig's driver otherwise
    // defaults lld to `_start` and ignores the script's ENTRY(), which leaves
    // e_entry = 0 and lets --gc drop all code. The kernel entry is `kmain`.
    cmd = cmd.concat(" -Wl,-e,kmain");
    cmd = cmd.concat(" -Wl,--build-id=none");
    // zig is invoked through a quoted path; on Windows cmd.exe needs the
    // whole command re-wrapped (mirrors the hosted cc path's workaround).
    if __glide_is_windows() != 0 {
        cmd = "\"".concat(cmd).concat("\"");
    }
    let rc: i32 = __glide_shell(cmd);
    if rc != 0 {
        if !quiet { spinner_finish(false, ""); }
        println!("freestanding link failed (zig cc exit", rc, ")");
        println!("preserved C source at:", tmp_c);
        return rc;
    }
    fs_remove_file(tmp_c);
    if !quiet { spinner_finish(true, "built ".concat(out_path)); }
    return 0;
}

// Scan a source string for top-level `fn test_*` (and `pub fn test_*`) and
// return the function names in order of appearance. The scan is line-based
// and intentionally dumb — it doesn't tokenize, so commented-out test
// declarations would still match. That's acceptable for the test runner:
// false positives produce a link error from the call site, which is louder
// than a silent skip.
// Same shape as `scan_test_fns` but looks for `fn bench_*`. The
// declaration may be `pub fn bench_x(b: *Bencher)` or unqualified.
fn scan_bench_fns(src: string) -> *Vector<string> {
    let names: *Vector<string> = Vector::new();
    let lines: *Vector<string> = src.split("\n");
    let prefix: string = "fn bench_";
    for let i: i32 = 0; i < lines.len(); i++ {
        let raw: string = lines.get(i);
        let trimmed: string = raw.trim();
        let mut body: string = trimmed;
        if body.starts_with("pub ") {
            body = body.substring(4, body.len());
            let mut k: i32 = 0;
            while k < body.len() && body.at(k).to_int() == 32 { k = k + 1; }
            body = body.substring(k, body.len());
        }
        if !body.starts_with(prefix) { continue; }
        let after: string = body.substring(3, body.len());
        let n: i32 = after.len();
        let mut end: i32 = 0;
        while end < n {
            let c: i32 = after.at(end).to_int();
            if c == 40 || c == 32 || c == 9 { break; }
            end = end + 1;
        }
        if end == 0 { continue; }
        names.push(after.substring(0, end));
    }
    return names;
}

// `glide bench [path]` — for every `*_bench.glide` under `path` (or
// the single file passed), synth a main() that runs each `bench_*`
// through `bench_run`, build, execute.
fn run_bench(path: string) -> i32 {
    let mut search_path: string = path;
    if search_path.eq("") { search_path = "."; }

    let files: *Vector<string> = Vector::new();
    // A directory is the common case (`glide test tests`). Detect it FIRST:
    // read_file() on a directory returns "" on some filesystems but NULL on
    // others (ext4 on the CI runner), and calling .eq() on a null string
    // segfaults — which is exactly why `glide test <dir>` crashed on Linux CI
    // while a single file worked. fs_is_dir is the reliable signal.
    let is_dir: bool = fs_is_dir(search_path);
    let direct: string = if is_dir { "" } else { read_file(search_path) };
    if !is_dir && direct != null && !direct.eq("") {
        files.push(search_path);
    } else {
        let raw: string = __glide_list_dir(search_path, "_bench.glide");
        if raw.eq("") {
            println!("no *_bench.glide files found under:", search_path);
            return 1;
        }
        let names: *Vector<string> = raw.split("\n");
        for let i: i32 = 0; i < names.len(); i++ {
            let nm: string = names.get(i);
            if nm.eq("") { continue; }
            files.push(search_path.concat("/").concat(nm));
        }
    }

    let mut total_files: i32 = 0;
    let mut failed_files: i32 = 0;
    let scratch: string = _scratch_dir();
    let tmp_path: string = scratch.concat("/__glide_bench_run.glide");
    let mut out_path: string = scratch.concat("/__glide_bench_run.exe");
    if __glide_is_windows() == 0 { out_path = scratch.concat("/__glide_bench_run"); }

    for let i: i32 = 0; i < files.len(); i++ {
        let f: string = files.get(i);
        let src: string = read_file(f);
        if src.eq("") { continue; }

        let bench_fns: *Vector<string> = scan_bench_fns(src);
        if bench_fns.len() == 0 {
            println!("(no bench_* functions in", f, "—  skipping)");
            continue;
        }

        // Synth: prepend the bench module, append a main() that pipes
        // every bench_* through `bench_run`.
        let mut synth: string = "import stdlib::bench::*;\n".concat(src);
        synth = synth.concat("\n\nfn main() -> i32 {\n");
        for let j: i32 = 0; j < bench_fns.len(); j++ {
            let name: string = bench_fns.get(j);
            synth = synth.concat("    bench_run(\"").concat(name).concat("\", ").concat(name).concat(");\n");
        }
        synth = synth.concat("    return bench_summary();\n}\n");

        if !write_file(tmp_path, synth) {
            println!("could not write temp bench file");
            return 1;
        }

        println!(col_blue().concat("benching").concat(col_reset()), f,
                 "(", bench_fns.len(), "bench(es) )");
        let rc: i32 = run_build_q(tmp_path, out_path, "", true, true);
        total_files = total_files + 1;
        if rc != 0 { failed_files = failed_files + 1; }
    }

    write_file(tmp_path, "");
    if failed_files > 0 {
        println!(col_red().concat("bench result:").concat(col_reset()),
                 failed_files, "of", total_files, "files had failures");
        return 1;
    }
    return 0;
}

fn scan_test_fns(src: string) -> *Vector<string> {
    let names: *Vector<string> = Vector::new();
    let lines: *Vector<string> = src.split("\n");
    let prefix: string = "fn test_";
    for let i: i32 = 0; i < lines.len(); i++ {
        let raw: string = lines.get(i);
        let trimmed: string = raw.trim();
        let mut body: string = trimmed;
        if body.starts_with("pub ") {
            body = body.substring(4, body.len());
            // Allow extra whitespace after `pub`.
            let mut k: i32 = 0;
            while k < body.len() && body.at(k).to_int() == 32 { k = k + 1; }
            body = body.substring(k, body.len());
        }
        if !body.starts_with(prefix) { continue; }
        // Strip the `fn ` and read the identifier up to `(` or whitespace.
        let after: string = body.substring(3, body.len());
        let n: i32 = after.len();
        let mut end: i32 = 0;
        while end < n {
            let c: i32 = after.at(end).to_int();
            if c == 40 || c == 32 || c == 9 { break; }
            end = end + 1;
        }
        if end == 0 { continue; }
        names.push(after.substring(0, end));
    }
    return names;
}

// `glide test [path]` — run every `test_*` function across `*_test.glide`
// files under `path`. Per-file: scan, synthesise a `main()` that calls each
// test in order, hand off to the regular build+run pipeline. Aggregate exit
// codes; non-zero if any file's run reported failed assertions.
fn run_test(path: string) -> i32 {
    let mut search_path: string = path;
    if search_path.eq("") { search_path = "."; }

    // Decide whether `search_path` is a single file or a directory of tests.
    let files: *Vector<string> = Vector::new();
    // A directory is the common case (`glide test tests`). Detect it FIRST:
    // read_file() on a directory returns "" on some filesystems but NULL on
    // others (ext4 on the CI runner), and calling .eq() on a null string
    // segfaults — which is exactly why `glide test <dir>` crashed on Linux CI
    // while a single file worked. fs_is_dir is the reliable signal.
    let is_dir: bool = fs_is_dir(search_path);
    let direct: string = if is_dir { "" } else { read_file(search_path) };
    if !is_dir && direct != null && !direct.eq("") {
        files.push(search_path);
    } else {
        let raw: string = __glide_list_dir(search_path, "_test.glide");
        if raw.eq("") {
            println!("no *_test.glide files found under:", search_path);
            return 1;
        }
        let names: *Vector<string> = raw.split("\n");
        for let i: i32 = 0; i < names.len(); i++ {
            let nm: string = names.get(i);
            if nm.eq("") { continue; }
            files.push(search_path.concat("/").concat(nm));
        }
    }

    let mut total_files: i32 = 0;
    let mut failed_files: i32 = 0;
    let scratch: string = _scratch_dir();
    let tmp_path: string = scratch.concat("/__glide_test_run.glide");
    let mut out_path: string = scratch.concat("/__glide_test_run.exe");
    if __glide_is_windows() == 0 { out_path = scratch.concat("/__glide_test_run"); }

    for let i: i32 = 0; i < files.len(); i++ {
        let f: string = files.get(i);
        let src: string = read_file(f);
        if src.eq("") { continue; }

        let test_fns: *Vector<string> = scan_test_fns(src);
        if test_fns.len() == 0 {
            println!("(no test_* functions in", f, "—  skipping)");
            continue;
        }

        // Synthesise: prepend testing import (idempotent — loader dedups),
        // append a main() that calls each test_* in declaration order.
        let mut synth: string = "import stdlib::testing::*;\n".concat(src);
        synth = synth.concat("\n\nfn main() -> i32 {\n");
        for let j: i32 = 0; j < test_fns.len(); j++ {
            let name: string = test_fns.get(j);
            synth = synth.concat("    test_begin(\"").concat(name).concat("\");\n");
            synth = synth.concat("    if ").concat(name).concat("() == 0 { test_pass(); }\n");
        }
        synth = synth.concat("    return test_summary();\n}\n");

        if !write_file(tmp_path, synth) {
            println!("could not write temp test file");
            return 1;
        }

        println!(col_blue().concat("running").concat(col_reset()), f,
                 "(", test_fns.len(), "tests )");
        let rc: i32 = run_build_q(tmp_path, out_path, "", true, true);
        total_files = total_files + 1;
        if rc != 0 { failed_files = failed_files + 1; }
    }

    // Best-effort cleanup; ignore errors.
    write_file(tmp_path, "");
    println!("");
    if failed_files > 0 {
        println!(col_red().concat("test result:").concat(col_reset()),
                 failed_files, "of", total_files, "files had failures");
        return 1;
    }
    println!(col_blue().concat("test result:").concat(col_reset()),
             "all", total_files, "files passed");
    return 0;
}

// Build `name` (a `*.glide` path) into a fresh executable, run it with
// stdout captured to `out_txt`, and return the run's exit code (or -1 if
// the build itself failed). Build artefacts go under `_scratch_dir()`
// (project `build/` or system temp); cleanup is best-effort.
fn _golden_build_and_run(src: string, out_txt: string) -> i32 {
    let scratch: string = _scratch_dir();
    let mut exe: string = scratch.concat("/__glide_golden.exe");
    if __glide_is_windows() == 0 { exe = scratch.concat("/__glide_golden"); }
    let rc_build: i32 = run_build_q(src, exe, "", false, true);
    if rc_build != 0 { return -1; }
    let cmd: string = "\"".concat(exe).concat("\" > \"").concat(out_txt).concat("\"");
    let mut wrapped: string = cmd;
    if __glide_is_windows() != 0 {
        wrapped = "\"".concat(cmd).concat("\"");
    }
    return __glide_shell(wrapped);
}

// Drop CR bytes so `\r\n` → `\n`. Windows shell redirection writes CRLF
// even when the producer emitted LF, so the .expected file (typically
// LF) won't match unless we strip them on read-back.
fn _golden_normalize(s: string) -> string {
    let n: i32 = s.len();
    let mut out: string = "";
    for let i: i32 = 0; i < n; i++ {
        let c: i32 = s.at(i).to_int();
        if c == 13 { continue; }
        out = out.concat(s.substring(i, i + 1));
    }
    return out;
}

// Print the first byte where `actual` and `expected` diverge, with up
// to 60 chars of context on each side. Anchors the eye in long outputs
// without dumping a full diff.
fn _golden_show_diff(actual: string, expected: string) {
    let na: i32 = actual.len();
    let ne: i32 = expected.len();
    let mut i: i32 = 0;
    while i < na && i < ne && actual.at(i).to_int() == expected.at(i).to_int() {
        i = i + 1;
    }
    let mut line: i32 = 1;
    let mut col: i32 = 1;
    for let k: i32 = 0; k < i; k++ {
        if actual.at(k).to_int() == 10 { line = line + 1; col = 1; }
        else { col = col + 1; }
    }
    let mut win_a_lo: i32 = 0;
    if i > 30 { win_a_lo = i - 30; }
    let mut win_a_hi: i32 = na;
    if i + 30 < na { win_a_hi = i + 30; }
    let mut win_e_lo: i32 = 0;
    if i > 30 { win_e_lo = i - 30; }
    let mut win_e_hi: i32 = ne;
    if i + 30 < ne { win_e_hi = i + 30; }
    println!("        first diff at line", line, "col", col);
    println!("        actual:   ", actual.substring(win_a_lo, win_a_hi));
    println!("        expected: ", expected.substring(win_e_lo, win_e_hi));
}

// `glide test --golden <dir>` — for every `*.glide` under `<dir>` that
// has a sibling `<name>.expected`, build it, run it, and diff stdout
// against the file. Files without a `.expected` sibling are skipped
// (they'd be examples that aren't yet pinned).
fn run_golden(dir: string) -> i32 {
    let mut search_dir: string = dir;
    if search_dir.eq("") { search_dir = "."; }
    let raw: string = __glide_list_dir(search_dir, ".glide");
    if raw.eq("") {
        println!("no *.glide files under:", search_dir);
        return 1;
    }
    let names: *Vector<string> = raw.split("\n");

    let stdout_path: string = "__glide_golden_stdout.txt";
    let mut passed: i32 = 0;
    let mut failed: i32 = 0;
    let mut skipped: i32 = 0;

    for let i: i32 = 0; i < names.len(); i++ {
        let nm: string = names.get(i);
        if nm.eq("") { continue; }
        // Skip helper test files — those are L1, not goldens.
        if nm.len() >= 12 && nm.substring(nm.len() - 12, nm.len()).eq("_test.glide") { continue; }

        let src: string = search_dir.concat("/").concat(nm);
        // Build expected path: strip ".glide", append ".expected".
        let expected_path: string = search_dir.concat("/")
            .concat(nm.substring(0, nm.len() - 6))
            .concat(".expected");

        if !__glide_file_exists(expected_path) {
            skipped = skipped + 1;
            continue;
        }
        let expected: string = read_file(expected_path);

        let rc: i32 = _golden_build_and_run(src, stdout_path);
        if rc < 0 {
            failed = failed + 1;
            println!(col_red().concat("FAIL").concat(col_reset()), src, "(build failed)");
            continue;
        }
        let actual_raw: string = read_file(stdout_path);
        let actual: string = _golden_normalize(actual_raw);
        let expected_norm: string = _golden_normalize(expected);
        if actual.eq(expected_norm) {
            passed = passed + 1;
            println!(col_blue().concat("ok").concat(col_reset()).concat("  "), src);
        } else {
            failed = failed + 1;
            println!(col_red().concat("FAIL").concat(col_reset()), src);
            _golden_show_diff(actual, expected_norm);
        }
    }

    // Best-effort cleanup.
    write_file(stdout_path, "");
    println!("");
    if failed > 0 {
        println!(col_red().concat("golden result:").concat(col_reset()),
                 passed, "passed,", failed, "failed,", skipped, "skipped");
        return 1;
    }
    println!(col_blue().concat("golden result:").concat(col_reset()),
             passed, "passed,", skipped, "skipped");
    return 0;
}

fn main() -> i32 {
    let argc: i32 = args_count();
    // Bundle binaries ship the entire `src/` tree (Glide stdlib +
    // builtins) baked in. Extract it to `~/.glide/src/` on first run
    // so resolve_import can find `stdlib::foo` from any cwd, with no
    // installer script. Idempotent — the second run sees the marker
    // file and skips the extract.
    _maybe_install_embedded_src();
    if argc < 2 {
        print_usage();
        return 1;
    }
    // Scan for the global lint promotion flag before dispatch so every
    // subcommand (build / run / check / lint) sees the same setting.
    // Repeatable: `--lint-as-error=deprecated-fn --lint-as-error=unused`.
    // Also accepts `--lint-as-error=all` to deny every warning.
    let deny: *Vector<string> = Vector::new();
    let flag_prefix: string = "--lint-as-error=";
    let flag_len: i32 = flag_prefix.len();
    for let i: i32 = 0; i < argc; i++ {
        let a: string = args_at(i);
        if a.len() <= flag_len { continue; }
        if !a.substring(0, flag_len).eq(flag_prefix) { continue; }
        let val: string = a.substring(flag_len, a.len());
        let toks: *Vector<string> = val.split(",");
        for let j: i32 = 0; j < toks.len(); j++ {
            let tk: string = toks.get(j).trim();
            if !tk.eq("") { deny.push(tk); }
        }
    }
    if deny.len() > 0 { set_deny_codes(deny); }
    let cmd: string = args_at(1);

    // `--version` / `-v` / `-V` / `--v` / `version` — print and exit.
    if cmd.eq("--version") || cmd.eq("--v")
       || cmd.eq("-v") || cmd.eq("-V") || cmd.eq("version") {
        println!("glide", GLIDE_VERSION);
        return 0;
    }

    // `--help` / `-h` — same as no-args, but exit 0 instead of 1.
    if cmd.eq("--help") || cmd.eq("-h") || cmd.eq("help") {
        print_usage();
        return 0;
    }

    // `lsp` takes no positional file arg.
    if cmd.eq("lsp") { return lsp_main(); }

    // `openapi <file.glide>` — emit OpenAPI 3.0.3 YAML for every
    // @route'd handler reachable from <file>.
    if cmd.eq("openapi") {
        if argc < 3 { println!("usage: glide openapi <file.glide>"); return 1; }
        return openapi_main(args_at(2));
    }

    // `routes <file.glide>` — compact `METHOD PATH -> handler` listing,
    // consumed by editor integrations (Zed `/glide-routes` slash cmd).
    if cmd.eq("routes") {
        if argc < 3 { println!("usage: glide routes <file.glide>"); return 1; }
        return routes_main(args_at(2));
    }

    // `fetch [path]` — walk the manifest at <path>'s closest glide.glide
    // and download every missing git dep. Default <path> = ".".
    if cmd.eq("fetch") {
        let mut start: string = ".";
        if argc >= 3 { start = args_at(2); }
        return run_fetch(start);
    }

    // `new <name> [--lib] [--ai] [--no-vcs]` — scaffold a fresh
    // project directory. `glide new .` scaffolds into CWD using the
    // dir basename as the project name; `--lib` produces a library
    // project (no `bin`, src/lib.glide with a sample pub fn); `--ai`
    // drops AGENTS.md alongside; `--no-vcs` skips the default git
    // init.
    if cmd.eq("new") {
        if argc < 3 { println!("usage: glide new <name> [--lib] [--ai] [--no-vcs]"); return 1; }
        let mut new_name: string = "";
        let mut is_lib: bool = false;
        let mut emit_ai: bool = false;
        let mut init_vcs: bool = true;
        for let i: i32 = 2; i < argc; i++ {
            let a: string = args_at(i);
            if a.eq("--lib") { is_lib = true; continue; }
            if a.eq("--ai") { emit_ai = true; continue; }
            if a.eq("--no-vcs") { init_vcs = false; continue; }
            if new_name.eq("") { new_name = a; }
        }
        if new_name.eq("") { println!("usage: glide new <name> [--lib] [--ai] [--no-vcs]"); return 1; }
        return run_new(new_name, is_lib, emit_ai, init_vcs);
    }

    // `add` — write a new entry into the nearest glide.glide:
    //   glide add --local <name> <path>       path dep
    //   glide add <name> <git-url> <rev>      git dep
    if cmd.eq("add") {
        return run_add(argc);
    }

    // `remove <name>` — drop the matching dep entry.
    if cmd.eq("remove") {
        if argc < 3 { println!("usage: glide remove <name>"); return 1; }
        return run_remove(args_at(2));
    }

    // `update` — wipe glide.lock + each git dep's cache dir, then refetch.
    if cmd.eq("update") {
        return run_update();
    }

    // `tree` — print the manifest's dep graph (direct + transitive).
    if cmd.eq("tree") {
        return run_tree();
    }

    // `info <name>` — metadata for a declared dep.
    if cmd.eq("info") {
        if argc < 3 { println!("usage: glide info <name>"); return 1; }
        return run_info(args_at(2));
    }

    // `search <query>` — GitHub code-search for repos with a glide.glide
    // at root. Prints a shortlist of `glide add` lines.
    if cmd.eq("search") {
        if argc < 3 { println!("usage: glide search <query>"); return 1; }
        let mut q: string = args_at(2);
        for let i: i32 = 3; i < argc; i++ {
            q = q.concat(" ").concat(args_at(i));
        }
        return run_search(q);
    }

    // `clean` — drop the per-project glide_modules/ + glide.lock. Global
    // cache (~/.glide/cache) is left alone since other projects share it.
    if cmd.eq("clean") {
        return run_clean();
    }

    // `fix [file]` — apply mechanical auto-fixes for the lints that
    // ship a known repair. Today: prefix `unused-{var,param,fn}` with
    // `_`. Reads each file, splices in the underscores at the
    // diagnostic positions, writes back. Edits are applied in reverse
    // source order so earlier offsets stay valid.
    if cmd.eq("fix") {
        let mut target: string = "";
        for let i: i32 = 2; i < argc; i++ {
            let a: string = args_at(i);
            if a.len() > 0 && a.at(0).to_int() == 45 { continue; }
            target = a; break;
        }
        if target.eq("") {
            let root: string = find_manifest_root(".");
            if root.eq("") {
                println!("no glide.glide found; pass a file to fix or run inside a project");
                return 1;
            }
            let m: *Manifest = read_manifest(root);
            if m == null || m.bin.eq("") {
                println!("project has no `bin` to fix; pass a file explicitly");
                return 1;
            }
            target = root.concat("/").concat(m.bin);
        }
        return run_fix(target);
    }

    // `lint [file]` — run the lint analyses without producing an
    // artifact. Same diagnostic pipeline as `glide check`, but the
    // banner / exit policy is tuned for CI: `--lint-as-error=<code>`
    // promotes warnings to errors; `--all` shows diagnostics from
    // imported files; exit 1 when anything fires, 0 when clean.
    if cmd.eq("lint") {
        let mut target: string = "";
        for let i: i32 = 2; i < argc; i++ {
            let a: string = args_at(i);
            if a.len() > 0 && a.at(0).to_int() == 45 { continue; }   // skip flags
            target = a; break;
        }
        if target.eq("") {
            // Project mode: read manifest, lint the `bin` file.
            let root: string = find_manifest_root(".");
            if root.eq("") {
                println!("no glide.glide found; pass a file to lint or run inside a project");
                return 1;
            }
            let m: *Manifest = read_manifest(root);
            if m == null || m.bin.eq("") {
                println!("project has no `bin` to lint; pass a file explicitly");
                return 1;
            }
            target = root.concat("/").concat(m.bin);
        }
        return run_lint(target, argc);
    }

    // `target {list,add,remove,dir}` — manage cross-compile sysroots
    // cached under ~/.glide/targets/. Each sysroot bundles the headers
    // + static libs that the target platform needs for openssl / zlib,
    // so `glide build --target=<triple>` produces a self-contained
    // binary instead of failing at link time.
    if cmd.eq("target") {
        return run_target(argc);
    }

    // `install <path>` / `install <git-url> <rev>` — build the target
    // and copy its binary into ~/.glide/bin.
    if cmd.eq("install") {
        return run_install(argc);
    }

    // `bench [path]` — run *_bench.glide microbenchmarks. Each
    // `bench_*` fn gets auto-tuned iterations until ≥500ms then
    // prints ns/op.
    if cmd.eq("bench") {
        let mut bpath: string = "";
        if argc >= 3 { bpath = args_at(2); }
        return run_bench(bpath);
    }

    // `doc [--open] [--serve[=<port>]]` — emit static HTML for every
    // pub item with a `///` docstring to build/doc/. `--open` shells
    // out to the platform browser launcher; `--serve` boots a tiny
    // HTTP server on the chosen port (default 3030) so the browser
    // can hit http://127.0.0.1:<port>/ directly.
    if cmd.eq("doc") {
        let mut want_open: bool = false;
        let mut serve_port: i32 = 0;
        let mut emit_ai: bool = false;
        let mut include_stdlib: bool = false;
        for let i: i32 = 2; i < argc; i++ {
            let a: string = args_at(i);
            if a.eq("--open") { want_open = true; continue; }
            if a.eq("--serve") { serve_port = 3030; continue; }
            if a.eq("--ai") { emit_ai = true; continue; }
            if a.eq("--stdlib") { include_stdlib = true; continue; }
            if a.len() > 8 && a.substring(0, 8).eq("--serve=") {
                let n: string = a.substring(8, a.len());
                let parsed: i32 = _parse_port(n);
                if parsed > 0 { serve_port = parsed; }
                continue;
            }
        }
        let root: string = find_manifest_root(".");
        let target_root: string = if root.eq("") { "." } else { root };
        return run_doc(target_root, want_open, serve_port, emit_ai, include_stdlib);
    }

    // `test [path]`           — run *_test.glide files (default cwd).
    // `test --golden <dir>`   — run each <dir>/*.glide and diff stdout
    //                            against <name>.expected.
    if cmd.eq("test") {
        let mut tpath: string = "";
        let mut golden: bool = false;
        for let i: i32 = 2; i < argc; i++ {
            let a: string = args_at(i);
            if a.eq("--golden") { golden = true; continue; }
            if tpath.eq("") { tpath = a; }
        }
        if golden { return run_golden(tpath); }
        return run_test(tpath);
    }

    // Default action when the user types `glide <file>` with no
    // subcommand: build + execute, like `cargo run` / `go run`.
    // Pass `--emit` to keep the legacy "print generated C to stdout"
    // behaviour for tooling that piped it.
    let mut mode: i32 = MODE_RUN;
    let mut src_arg_idx: i32 = 2;
    if cmd.eq("build") { mode = MODE_BUILD; }
    else if cmd.eq("run") { mode = MODE_RUN; }
    else if cmd.eq("emit") { mode = MODE_EMIT; }
    else if cmd.eq("check") { mode = MODE_CHECK; }
    else if cmd.eq("fmt") { mode = MODE_FMT; }
    else {
        // No subcommand — first positional arg is the source file.
        src_arg_idx = 1;
        for let i: i32 = 0; i < argc; i++ {
            if args_at(i).eq("--emit") { mode = MODE_EMIT; src_arg_idx = i + 1; }
        }
    }
    // Skip leading flags so `glide build --target=... -o foo` still
    // resolves the source from the manifest. A flag is anything that
    // starts with `-`; `-o <out>` swallows its value too.
    while src_arg_idx < argc {
        let a: string = args_at(src_arg_idx);
        if a.len() == 0 || a.at(0).to_int() != 45 { break; }
        if a.eq("-o") { src_arg_idx = src_arg_idx + 2; continue; }
        src_arg_idx = src_arg_idx + 1;
    }

    // No positional source: project mode for `build` / `run`. Resolve
    // `src_path` from the nearest glide.glide's `bin` field — same
    // contract as `cargo run` in a package directory.
    let mut src_path: string = "";
    let mut project_root: string = "";
    let mut project_name: string = "";
    let mut manifest_target: string = "";
    if src_arg_idx >= argc {
        if mode == MODE_BUILD || mode == MODE_RUN || mode == MODE_CHECK {
            let root: string = find_manifest_root(".");
            if root.eq("") {
                println!("no glide.glide found; run `glide", cmd.concat(" <file>` or scaffold with `glide new <name>`"));
                return 1;
            }
            let m: *Manifest = read_manifest(root);
            if m == null {
                println!("could not parse glide.glide at", root);
                return 1;
            }
            project_root = root;
            project_name = m.name;
            manifest_target = m.target;
            if !m.bin.eq("") {
                src_path = root.concat("/").concat(m.bin);
            } else if mode == MODE_CHECK {
                // Library project: no `bin`, so check the conventional
                // entry (type-checks it + everything it imports). Prefer
                // `src/<name>.glide` (current scaffold), fall back to the
                // older `src/lib.glide`. `glide build`/`run` reject libs below.
                let named_entry: string = root.concat("/src/").concat(m.name).concat(".glide");
                let lib_entry: string = root.concat("/src/lib.glide");
                if __glide_file_exists(named_entry) {
                    src_path = named_entry;
                } else if __glide_file_exists(lib_entry) {
                    src_path = lib_entry;
                } else {
                    println!(m.name, "is a library with no `src/".concat(m.name).concat(".glide` to check; pass a file: `glide check <file>`"));
                    return 1;
                }
            } else {
                println!(m.name, "is a library project (no `bin`).");
                println!("nothing to build/run — import it from another project:");
                println!("  import", m.name.concat("::…;"));
                return 1;
            }
        } else {
            print_usage();
            return 1;
        }
    } else {
        src_path = args_at(src_arg_idx);
        let root: string = find_manifest_root(parent_dir(src_path));
        if !root.eq("") {
            let m: *Manifest = read_manifest(root);
            if m != null {
                project_root = root;
                project_name = m.name;
                manifest_target = m.target;
            }
        }
    }

    // Parse remaining flags: -o <out>, --target=<triple>, --write
    let mut out_path: string = "";
    let mut target: string = "";
    let mut write_in_place: bool = false;
    let flag_start: i32 = if src_arg_idx >= argc { 2 } else { src_arg_idx + 1 };
    for let i: i32 = flag_start; i < argc; i++ {
        let a: string = args_at(i);
        if a.eq("-o") && (i + 1) < argc {
            out_path = args_at(i + 1);
        }
        if a.eq("--write") { write_in_place = true; }
        if a.len() > 9 {
            let prefix: string = a.substring(0, 9);
            if prefix.eq("--target=") {
                target = a.substring(9, a.len());
            }
        }
    }

    // No `--target=` on the command line: fall back to the manifest's
    // default `target`. Build-only — `glide run` always targets the host
    // because it has to execute the result locally.
    if target.eq("") && mode == MODE_BUILD && !manifest_target.eq("") {
        target = manifest_target;
        println!("target:", target, "(from glide.glide)");
    }

    if mode == MODE_BUILD {
        if out_path.eq("") {
            out_path = _default_out_path(project_root, project_name, false, target);
        }
        return run_build(src_path, out_path, target, false);
    }
    if mode == MODE_RUN {
        if out_path.eq("") {
            out_path = _default_out_path(project_root, project_name, true, target);
        }
        return run_build(src_path, out_path, target, true);
    }

    if mode == MODE_FMT {
        // Parse only the user's file (no stdlib autoload — we want to format
        // exactly what's on disk, nothing more).
        let src: string = read_file(src_path);
        if src.eq("") { println!("could not read or empty file:", src_path); return 1; }
        let lex: *Lexer = Lexer::new(src);
        let p: *Parser = Parser::new(lex);
        let parsed: *Vector<Stmt> = parse_program(p);
        let formatted: string = fmt_program(parsed);
        if write_in_place {
            if !write_file(src_path, formatted) {
                println!("could not write:", src_path);
                return 1;
            }
            return 0;
        }
        __glide_write_str(formatted);
        __glide_flush_stdout();
        return 0;
    }

    // emit / check / fallback
    let stmts: *Vector<Stmt> = Vector::new();
    let pdiags: *Vector<ParseDiag> = Vector::new();
    if !parse_program_into(stmts, src_path, pdiags) { return 1; }

    if mode == MODE_CHECK {
        apply_lint_for(parent_dir(src_path));
        let t: *Typer = Typer::new();
        merge_parse_diags(t, pdiags);
        // The manifest (`glide.glide`) is parsed for its fields but never
        // compiled; its `Package` / `Dep` / `vec_of` identifiers are
        // undeclared by design, so run only the parse pass on it.
        if !path_is_manifest(src_path) {
            build_visibility(t, stmts);
            t.enforce_visibility = true;
            check_program(t, stmts);
            run_extra_analyses(t, stmts);
        }
        let src_text: string = read_file(src_path);
        let mut user_errors: i32 = 0;
        let json: bool = _wants_json(argc);
        let mut want_all: bool = false;
        for let k: i32 = 0; k < argc; k++ {
            if args_at(k).eq("--all") { want_all = true; }
        }
        for let i: i32 = 0; i < t.diagnostics.len(); i++ {
            let d: DiagEntry = t.diagnostics.get(i);
            let mut path: string = d.origin;
            if path.eq("") { path = src_path; }
            if !want_all && !path.eq(src_path) { continue; }
            if d.severity == 2 && _project_allow_drop(d.code) { continue; }
            let promoted: bool = d.severity == 2 && _is_lint_promoted(d.code);
            if json {
                println!(_diag_to_jsonl(&d, src_path));
            } else {
                let mut snippet: string = src_text;
                if !path.eq(src_path) { snippet = read_file(path); }
                print_pretty_diag(d, snippet, path);
            }
            if d.severity == 1 || promoted { user_errors = user_errors + 1; }
        }
        let mut check_exit: i32 = 0;
        if user_errors > 0 {
            if !json {
                let mut tail: string = "found 1 error";
                if user_errors > 1 { tail = "found ".concat(int_to_str(user_errors)).concat(" errors"); }
                println!(col_red().concat("error").concat(col_reset()).concat(": ").concat(tail));
            }
            check_exit = 1;
        } else if !json {
            println!(col_blue().concat("ok").concat(col_reset()));
        }
        t.free();
        return check_exit;
    }

    // MODE_EMIT
    emit_program(strip_compile_time_only(stmts));
    return 0;
}
