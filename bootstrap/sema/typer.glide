                    t.err_code_range(wa.line, wa.column, wa.str_val.len(), "wrapper-inner-mismatch", "`".concat(e.rhs.lhs.str_val).concat("(...)` here must wrap `").concat(type_to_string(wfin.inner)).concat("`, but the value is a `").concat(wa.str_val).concat("` literal").concat(bx_hint));
                }
            }
        }
        // Move-on-assign: a plain `=` whose RHS is an owned local moves it; later
        // reads of that local are use-after-move (ownership now belongs to the
        // target). Mark AFTER inferring rt so the RHS read here is not flagged.
        if e.rhs != null && e.rhs.kind == EX_IDENT && (t.owned_locals.contains(e.rhs.str_val) || t.call_owned.contains(e.rhs.str_val)) {
            t.consumed_locals.insert(e.rhs.str_val, true);
            t.moved_out.insert(e.rhs.str_val, true);
        }
        if !types_compat(lt, rt) {
            let mut _as_l: i32 = e.line;
            let mut _as_c: i32 = e.column;
            if e.rhs != null {
                _as_l = e.rhs.line;
                _as_c = e.rhs.column;
            }
            t.err_code_range(_as_l, _as_c, _arg_span(e.rhs), "assign-type-mismatch", "assignment type mismatch: ".concat(type_to_string(lt)).concat(" = ").concat(type_to_string(rt)));
        }
        return lt;
    }
    if e.kind == EX_CALL {
        // 256-bit constructors: `u256::from(n)` / `i256::from(n)`. These name
        // a primitive (not a struct/module), so resolve them here before the
        // generic path machinery would flag `u256` as an unknown module.
        if e.lhs != null && e.lhs.kind == EX_PATH && e.lhs.field.eq("from") && (e.lhs.str_val.eq("u256") || e.lhs.str_val.eq("i256")) {
            return ty_named(e.lhs.str_val);
        }
        // Borrow check: forbid aliased borrows of the same source within
        // a single call (`&x + &mut x`, `&mut x + &mut x`).
        check_call_aliasing(t, e);
        // as_slice() intrinsic: `Vector<T>.as_slice()` -> `[]T`, a fat-pointer
        // view over the source's data+len. (The exclusive borrow that keeps the
        // source frozen while the slice is live is registered in the ST_LET path.)
        if e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.field != null && e.lhs.field.eq("as_slice") && (e.args == null || e.args.len() == 0) && e.lhs.lhs != null {
            let _ass: *Type = strip_ptr(infer_expr(t, e.lhs.lhs));
            if _ass != null && _ass.kind == TY_GENERIC && _ass.name.eq("Vector") && _ass.args != null && _ass.args.len() > 0 {
                let _elp: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *_elp = _ass.args.get(0);
                return ty_slice(_elp);
            }
        }
        // as_bytes() intrinsic: `string.as_bytes()` -> `[]u8`, a zero-copy view
        // (ptr = the SDS data, len = the header length). The SHARED borrow that
        // pins the source string while the view is live is registered in ST_LET.
        if e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.field != null && e.lhs.field.eq("as_bytes") && (e.args == null || e.args.len() == 0) && e.lhs.lhs != null {
            let _abr: *Type = infer_expr(t, e.lhs.lhs);
            if _abr != null && _abr.kind == TY_NAMED && _abr.name != null && _abr.name.eq("string") {
                return ty_slice(ty_named("u8"));
            }
        }
        // `free(x)` where x is a borrow: a borrow is a view, never the owner.
        // (The cast form `free(r as *void)` carries the borrow under EX_CAST.)
        if e.lhs != null && e.lhs.kind == EX_IDENT && e.lhs.str_val != null && e.lhs.str_val.eq("free") && e.args != null && e.args.len() == 1 {
            let _fa: Expr = e.args.get(0);
            let mut _fae: *Expr = &_fa;
            if _fae.kind == EX_CAST && _fae.lhs != null {
                _fae = _fae.lhs;
            }
            let _fat: *Type = infer_expr(t, _fae);
            if _fat != null && (_fat.kind == TY_BORROW || _fat.kind == TY_BORROW_MUT) {
                t.err_code_range(_fa.line, _fa.column, _arg_span(&_fa), "free-borrow", "cannot free through a borrow — the owner frees; take `*T` if this function must consume the value");
            } else {
                // `free(p)` while a borrow rooted at p is live → dangling view.
                let _fr: string = _borrow_root_ident(_fae);
                if !_fr.eq("") {
                    let _frx: i32 = _live_borrow_of(t, _fr, false);
                    if _frx >= 0 {
                        let _fre: BorrowEvent = t.borrows.get(_frx);
                        t.err_code_range(_fa.line, _fa.column, _arg_span(&_fa), "free-while-borrowed", "cannot free `".concat(_fr).concat("` while `").concat(_fre.binder).concat("` borrows it — the borrow would dangle"));
                        _relate_first_borrow(t, _fr, false);
                    }
                }
            }
        }
        // ---- chan: `c.send(x)` / `c.recv()` / `c.close()` ------------
        // Check arity + arg-vs-inner type, and surface the inner as the
        // recv() return type so subsequent let-init inferences fire.
        if e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.lhs != null {
            let mname: string = e.lhs.field;
            let recv_ty: *Type = infer_expr(t, e.lhs.lhs);
            // Use-after-free: `<ident>.free()` consumes the receiver.
            // Mark AFTER recv_ty was read so the receiver's own EX_IDENT
            // check doesn't fire on this very call.
            if mname.eq("free") && e.lhs.lhs.kind == EX_IDENT {
                // Freeing through a borrow: a borrow is a VIEW, never the
                // owner — only the owner frees.
                if recv_ty != null && (recv_ty.kind == TY_BORROW || recv_ty.kind == TY_BORROW_MUT) {
                    t.err_code_range(e.lhs.lhs.line, e.lhs.lhs.column, e.lhs.lhs.str_val.len(), "free-borrow", "cannot free through a borrow — the owner frees; take `*T` if this function must consume the value");
                } else {
                    // Freeing the owner while a borrow of it is live leaves
                    // the borrow dangling (use-after-free through the view).
                    let _fw: i32 = _live_borrow_of(t, e.lhs.lhs.str_val, false);
                    if _fw >= 0 {
                        let _fwe: BorrowEvent = t.borrows.get(_fw);
                        t.err_code_range(e.lhs.lhs.line, e.lhs.lhs.column, e.lhs.lhs.str_val.len(), "free-while-borrowed", "cannot free `".concat(e.lhs.lhs.str_val).concat("` while `").concat(_fwe.binder).concat("` borrows it — the borrow would dangle"));
                        _relate_first_borrow(t, e.lhs.lhs.str_val, false);
                    }
                    t.consumed_locals.insert(e.lhs.lhs.str_val, true);
                }
            }
            let inner: *Type = chan_inner(recv_ty);
            if inner != null {
                let mut nargs: i32 = 0;
                if e.args != null {
                    nargs = e.args.len();
                }
                if mname.eq("send") {
                    if nargs != 1 {
                        t.err(e.line, e.column, "`chan.send` takes exactly 1 argument");
                    } else {
                        let a: Expr = e.args.get(0);
                        let at: *Type = infer_expr(t, &a);
                        // A channel is a store that crosses task lifetimes, so
                        // a borrow can never go through it — the receiver may
                        // outlive the borrowed object. Both the syntactic form
                        // (`c.send(&x)`) and a borrow-typed value are banned.
                        if a.kind == EX_UNARY && (a.op_code == UN_ADDR || a.op_code == UN_ADDR_MUT) {
                            t.err_code_range(a.line, a.column, _arg_span(&a), "borrow-escape", "cannot send a borrow through a channel — the receiver may outlive it; send a value or a `*T`");
                        } else {
                            if at != null && (at.kind == TY_BORROW || at.kind == TY_BORROW_MUT) {
                                t.err_code_range(a.line, a.column, _arg_span(&a), "borrow-escape", "cannot send a borrow through a channel — the receiver may outlive it; send a value or a `*T`");
                            }
                        }
                        if !types_compat(inner, at) {
                            t.err_code_range(a.line, a.column, _arg_span(&a), "chan-arg-mismatch", "chan.send arg type mismatch: expected ".concat(type_to_string(inner)).concat(", got ").concat(type_to_string(at)));
                        }
                    }
                    return ty_named("void");
                }
                if mname.eq("recv") {
                    if nargs != 0 {
                        t.err(e.line, e.column, "`chan.recv` takes no arguments");
                    }
                    let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
                    *p = *inner;
                    return p;
                }
                if mname.eq("close") {
                    if nargs != 0 {
                        t.err(e.line, e.column, "`chan.close` takes no arguments");
                    }
                    return ty_named("void");
                }
            }
            // Option (`?T`) / Result (`!T`) intrinsic methods. Resolve the
            // return type so chaining + `let x: bool = o.is_some()` type-check.
            let _ors: *Type = strip_ptr(recv_ty);
            // OptResult (`?!T`) intrinsics: the three-state tag gets the
            // union of both accessor families (is_some/is_none/is_err) plus
            // the unwrap family, all yielding the same shapes as ?T / !T.
            if _ors != null && _ors.kind == TY_OPT_RESULT {
                if mname.eq("is_some") || mname.eq("is_none") || mname.eq("is_err") {
                    return ty_named("bool");
                }
                if mname.eq("unwrap") || mname.eq("expect") || mname.eq("unwrap_or") || mname.eq("unwrap_or_else") {
                    if _ors.inner != null {
                        return _ors.inner;
                    }
                    return ty_named("void");
                }
                if mname.eq("unwrap_err") {
                    return ty_named("string");
                }
            }
            if _ors != null && (_ors.kind == TY_OPTION || _ors.kind == TY_RESULT) {
                let iso: bool = _ors.kind == TY_OPTION;
                if iso && (mname.eq("is_some") || mname.eq("is_none")) || !iso && (mname.eq("is_ok") || mname.eq("is_err")) {
                    return ty_named("bool");
                }
                if mname.eq("unwrap") || mname.eq("expect") || mname.eq("unwrap_or") || mname.eq("unwrap_or_else") {
                    if _ors.inner != null {
                        return _ors.inner;
                    }
                    return ty_named("void");
                }
                if !iso && mname.eq("unwrap_err") {
                    return ty_named("string");
                }
                if iso && mname.eq("ok_or") {
                    return ty_result(_ors.inner);
                }
                if !iso && mname.eq("ok") {
                    return ty_option(_ors.inner);
                }
                if iso && mname.eq("filter") || !iso && mname.eq("map_err") {
                    return _ors;
                }
                if mname.eq("map") && e.args != null && e.args.len() == 1 {
                    let _cl: Expr = e.args.get(0);
                    if _cl.kind == EX_FNEXPR && _cl.cast_to != null {
                        if iso {
                            return ty_option(_cl.cast_to);
                        }
                        return ty_result(_cl.cast_to);
                    }
                    return null;
                }
                if mname.eq("and_then") && e.args != null && e.args.len() == 1 {
                    let _cl: Expr = e.args.get(0);
                    if _cl.kind == EX_FNEXPR && _cl.cast_to != null {
                        return _cl.cast_to;
                    }
                    return null;
                }
            }
            // Impl method lookup: `recv.method(args)` -> `<Type>_method` in
            // the fn registry. Without this the call's return type leaks as
            // null and the surrounding check (e.g. `return r.listen()`) lets
            // `!int` slip past a fn declared `-> int`, surfacing only at C
            // compile time. Falls through to the generic args-walk below if
            // the method isn't a known impl entry.
            let stripped: *Type = strip_ptr(recv_ty);
            if stripped != null && (stripped.kind == TY_NAMED || stripped.kind == TY_GENERIC) {
                // Try the specialized key first (`Vector<int>_max` for
                // `*Vector<int>.max()`); fall back to the bare-name key
                // (`Vector_max` for the generic `impl<T> Vector<T>`). Without
                // this, three sibling specializations all collide under
                // `Vector_max` and the last-registered one wins.
                let mut mkey: string = "";
                let specialized: string = type_to_string(stripped).concat("_").concat(mname);
                if t.fns.contains(specialized) {
                    mkey = specialized;
                } else {
                    let generic_key: string = stripped.name.concat("_").concat(mname);
                    if t.fns.contains(generic_key) {
                        mkey = generic_key;
                    }
                }
                if !mkey.eq("") {
                    let msig: FnSig = t.fns.get(mkey);
                    // `impl<T: Bound> Type<T>` bounds enforce at the method
                    // call: the receiver's concrete type args must satisfy
                    // the impl's declared bounds — parsed-and-dropped bounds
                    // were a silent lie. Only concrete user structs are judged.
                    if stripped.kind == TY_GENERIC && stripped.args != null && msig.owner_type_params != null && msig.owner_type_param_bounds != null && msig.owner_type_params.len() == stripped.args.len() {
                        let obn: i32 = msig.owner_type_param_bounds.len();
                        for let oi: i32 = 0; oi < msig.owner_type_params.len(); oi++ {
                            if oi >= obn {
                                break;
                            }
                            let obounds: string = msig.owner_type_param_bounds.get(oi);
                            if obounds == null || obounds.eq("") {
                                continue;
                            }
                            let oarg: Type = stripped.args.get(oi);
                            let ocon: *Type = strip_ptr(&oarg);
                            if ocon == null || ocon.kind != TY_NAMED || ocon.name == null || !t.structs.contains(ocon.name) || _is_current_type_param(t, ocon.name) {
                                continue;
                            }
                            let oparts: *Vector<string> = split_bounds(obounds);
                            for let oj: i32 = 0; oj < oparts.len(); oj++ {
                                let obnd: string = oparts.get(oj);
                                if !t.impl_set.contains(obnd.concat("::").concat(ocon.name)) {
                                    t.err_code_range(_field_pos_line(e.lhs), _field_pos_col(e.lhs), mname.len(), "unsatisfied-bound", "type `".concat(ocon.name).concat("` does not implement `").concat(obnd).concat("` (required by `").concat(msig.owner_type_params.get(oi)).concat("` of `impl ").concat(stripped.name).concat("`)"));
                                }
                            }
                            oparts.free();
                        }
                    }
                    // Arity: user args (excluding the implicit `self`) must
                    // match the method's declared params minus self. Missing
                    // or extra args are an error — same aggressiveness as a
                    // bare fn call.
                    if msig.params != null {
                        let m_alen: i32 = if e.args != null { e.args.len() } else { 0 };
                        let m_plen: i32 = msig.params.len();
                        // A method whose first param is NOT `self` is an
                        // associated function — dot-calling it would bind the
                        // receiver to a normal parameter and produce a baffling
                        // arity error ("expected 0, got 1"). Point at the fix.
                        let mut m_has_self: bool = false;
                        if m_plen > 0 {
                            let mp0: Param = msig.params.get(0);
                            if mp0.name != null && mp0.name.eq("self") {
                                m_has_self = true;
                            }
                        }
                        if !m_has_self {
                            t.err_code_range(_field_pos_line(e.lhs), _field_pos_col(e.lhs), mname.len(), "assoc-fn-dot-call", "`".concat(mname).concat("` has no `self` receiver — it's an associated function; call it as `").concat(stripped.name).concat("::").concat(mname).concat("(…)` or add `&self` to its signature"));
                            return null;
                        }
                        // A method that takes `self` BY VALUE cannot be called
                        // through a pointer/borrow receiver: codegen inserts no
                        // auto-deref, so the C call passes `T*` where `T` is
                        // expected (invalid C — cc ICE). Trait methods default
                        // to `self: Self`, so this bit doc-blessed trait code.
                        // The inverse direction (value receiver, `*Self`
                        // method) has the auto-`&` and stays fine; borrowed
                        // PRIMITIVES auto-deref on read and stay fine too.
                        if recv_ty != null && (recv_ty.kind == TY_POINTER || recv_ty.kind == TY_BORROW || recv_ty.kind == TY_BORROW_MUT) && !_is_prim_name(stripped.name) {
                            let mp0v: Param = msig.params.get(0);
                            if mp0v.ty != null && mp0v.ty.kind != TY_POINTER && mp0v.ty.kind != TY_BORROW && mp0v.ty.kind != TY_BORROW_MUT {
                                t.err_code_range(_field_pos_line(e.lhs), _field_pos_col(e.lhs), mname.len(), "self-by-value-via-ptr", "`".concat(mname).concat("` takes `self` by value, but the receiver here is `").concat(type_to_string(recv_ty)).concat("` — auto-deref is not supported yet; change the method to `self: *").concat(stripped.name).concat("`, or call it on a value binding"));
                            }
                        }
                        let mut m_expected: i32 = 0;
                        if m_plen > 0 {
                            m_expected = m_plen - 1;
                        } // drop self
                        let mut m_bad: bool = m_alen != m_expected;
                        if msig.is_variadic && m_alen >= m_expected {
                            m_bad = false;
                        }
                        if m_bad {
                            t.err_code_range(_field_pos_line(e.lhs), _field_pos_col(e.lhs), mname.len(), "", "wrong arg count for `".concat(mname).concat("`: expected ").concat(int_to_str(m_expected)).concat(", got ").concat(int_to_str(m_alen)));
                        }
                    }
                    // Check each arg against the matching impl param. Skip the
                    // implicit `self` param (params[0]). Without this, passing
                    // a `fn(*HttpRequest) -> Json<X>` to `r.get("/", handler)`
                    // where Router::get wants `fn(*HttpRequest) -> HttpResponse`
                    // gets silently accepted — the ABI mismatch then crashes
                    // at runtime.
                    let user_arg_types: *Vector<*Type> = Vector::new();
                    let params_after_self: *Vector<Param> = Vector::new();
                    if e.args != null && msig.params != null {
                        let alen: i32 = e.args.len();
                        let plen: i32 = msig.params.len();
                        // params[0] = self, so user args map to params[1..plen]
                        for let i: i32 = 0; i < alen; i++ {
                            let a: Expr = e.args.get(i);
                            let at: *Type = infer_expr(t, &a);
                            user_arg_types.push(at);
                            let pidx: i32 = i + 1;
                            if pidx >= plen {
                                continue;
                            }
                            let p: Param = msig.params.get(pidx);
                            params_after_self.push(p);
                            if p.ty == null {
                                continue;
                            }
                            // Substitute owner type params in the expected
                            // type, mirroring how the return type is fixed
                            // up below.
                            let mut want_p: *Type = p.ty;
                            if stripped.kind == TY_GENERIC && stripped.args != null && msig.owner_type_params != null && msig.owner_type_params.len() == stripped.args.len() {
                                want_p = _subst_type_local(p.ty, msig.owner_type_params, stripped.args);
                                if _type_references_any(want_p, msig.owner_type_params) {
                                    continue; // can't resolve, skip check
                                }
                            }
                            _check_null_borrow_arg(t, want_p, &a);
                            _check_scalar_borrow_forward(t, want_p, &a);
                            if !arg_compat(want_p, at, msig.type_params) {
                                if !_coerce_dyn_arg(t, want_p, at, e.args, i) && !_coerce_ref_generic_arg(t, want_p, at, msig.type_params, e.args, i) {
                                    let got_name: string = if a.kind == EX_IDENT { a.str_val } else { "" };
                                    t.err_code_range(a.line, a.column, _arg_span(&a), "", "arg ".concat(p.name).concat(" type mismatch: expected ").concat(type_to_string(want_p)).concat(", got ").concat(type_to_string(at)).concat(_fnptr_hint(t, want_p, at, got_name)));
                                }
                            }
                        }
                    } else {
                        if e.args != null {
                            for let i: i32 = 0; i < e.args.len(); i++ {
                                let a: Expr = e.args.get(i);
                                let at: *Type = infer_expr(t, &a);
                                user_arg_types.push(at);
                            }
                        }
                    }
                    // First-use element binding. When the receiver is a plain
                    // local whose generic element is still an unbound owner
                    // type param (`v` from `let v = Vector::new()` is stored as
                    // `*Vector<T>`), infer the element from this call's args and
                    // rewrite the local's scope type. That concretizes the
                    // element so LATER calls + the return are checked:
                    // `v.push(32); v.push("x")` then flags the second push,
                    // which an unbound `*Vector<T>` would silently accept.
                    if e.lhs.lhs.kind == EX_IDENT && stripped.kind == TY_GENERIC && stripped.args != null && msig.owner_type_params != null && msig.owner_type_params.len() > 0 && _type_references_any(stripped, msig.owner_type_params) {
                        let bound_recv: *Type = _infer_method_tparams(stripped, msig.owner_type_params, params_after_self, user_arg_types);
                        // Only commit a FULLY concrete element — never bind to
                        // another unbound param (e.g. forwarding an outer
                        // generic fn's own `T`).
                        if bound_recv != null && !_type_references_any(bound_recv, msig.owner_type_params) {
                            let mut committed: *Type = bound_recv;
                            if recv_ty != null && recv_ty.kind == TY_POINTER {
                                committed = ty_pointer(bound_recv);
                            }
                            t.scope.insert(e.lhs.lhs.str_val, *committed);
                        }
                    }
                    // Substitute the impl's `<T, U>` in the return type using
                    // the receiver's concrete args. `*Vector<int>.get()` ->
                    // int, not the placeholder T. Without subst, downstream
                    // `let x: int = v.get(0)` fires a spurious "got T".
                    if stripped.kind == TY_GENERIC && stripped.args != null && msig.owner_type_params != null && msig.owner_type_params.len() == stripped.args.len() {
                        let mut substituted: *Type = _subst_type_local(msig.ret_type, msig.owner_type_params, stripped.args);
                        // Now resolve any method-level `<U>` in the return by
                        // walking each user arg against its substituted param
                        // type. `v.fold(0, _add)` on `*Vector<int>`: owner subst
                        // turned the ret from `U` into `U` (unchanged — only T
                        // was bound). This pass binds `U` to `int` via `init: U`
                        // matched against the literal `0`.
                        if msig.type_params != null && msig.type_params.len() > 0 && _type_references_any(substituted, msig.type_params) {
                            let subst_params: *Vector<Param> = Vector::new();
                            for let i: i32 = 0; i < params_after_self.len(); i++ {
                                // Copy the param, then rewrite its type. `let np
                                // = p` on a value struct with a `string` field
                                // trips the move tracker (POD-copy of string-
                                // bearing structs is entangled with the string
                                // memory model), so mutate the fresh copy in
                                // place instead of aliasing a second binding.
                                let mut np: Param = params_after_self.get(i);
                                np.ty = _subst_type_local(np.ty, msig.owner_type_params, stripped.args);
                                subst_params.push(np);
                            }
                            substituted = _infer_method_tparams(substituted, msig.type_params, subst_params, user_arg_types);
                        }
                        // Receiver still generic? (`HashMap::new()` with no
                        // annotation -> *HashMap<V>, then `m.get(k)` would
                        // resolve to V again). Fall back to null so the
                        // surrounding check stays permissive — we don't know
                        // the concrete value type without flow-sensitive
                        // inference.
                        if _type_references_any(substituted, msig.owner_type_params) {
                            return null;
                        }
                        return substituted;
                    }
                    // Non-generic owner: bind method-level type params from args
                    // before falling back to null. `m.with(_inc)` on `*Mutex<int>`:
                    // owner is generic (Mutex<T>) so this branch shouldn't fire,
                    // but for plain impls like `impl Foo { fn bar<U>(x: U) -> U }`
                    // we still need to resolve U from the args.
                    let mut substituted2: *Type = msig.ret_type;
                    if msig.type_params != null && msig.type_params.len() > 0 && _type_references_any(substituted2, msig.type_params) {
                        substituted2 = _infer_method_tparams(substituted2, msig.type_params, params_after_self, user_arg_types);
                    }
                    if msig.type_params != null && msig.type_params.len() > 0 && _type_references_any(substituted2, msig.type_params) {
                        return null;
                    }
