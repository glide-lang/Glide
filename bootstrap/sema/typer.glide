                    let mut lbad: bool = lplen != lalen;
                    if lsig.is_variadic && lalen >= lplen {
                        lbad = false;
                    }
                    if lbad {
                        let lspan: i32 = prefix.len() + 2 + e.lhs.field.len();
                        t.err_code_range(e.lhs.line, e.lhs.column, lspan, "", "wrong arg count for `".concat(prefix).concat("::").concat(e.lhs.field).concat("`: expected ").concat(int_to_str(lplen)).concat(", got ").concat(int_to_str(lalen)));
