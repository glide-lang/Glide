            // already-dyn sources stay permissive.
            if _dsrc != null && _dsrc.kind == TY_NAMED && _dsrc.name != null && t.structs.contains(_dsrc.name) && !_is_current_type_param(t, _dsrc.name) && !t.impl_set.contains(_dtr.concat("::").concat(_dsrc.name)) {
                t.err_code_range(e.line, e.column, _arg_span(e), "unsatisfied-bound", "type `".concat(_dsrc.name).concat("` does not implement `").concat(_dtr).concat("` (required to coerce to `*dyn ").concat(_dtr).concat("`)"));
