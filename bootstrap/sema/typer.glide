                    } else {
                        // Enforce `<T: Trait>` bounds BEFORE the loop below marks
                        // owned args as moved: check_generic_bounds re-infers the
                        // args to pin each T, and inferring a just-consumed arg
                        // would wrongly report use-after-move (`fn max<T: Ord>` on
                        // owned `*T` values hit exactly this).
                        check_generic_bounds(t, &sig, e.args, e.line, e.column);
                        for let i: i32 = 0; i < plen; i++ {
                            let p: Param = sig.params.get(i);
                            let a: Expr = e.args.get(i);
                            let at: *Type = infer_expr(t, &a);
                            _check_null_borrow_arg(t, p.ty, &a);
                            _check_scalar_borrow_forward(t, p.ty, &a);
