// Typer — semantic analysis on the AST.
//
// Runs in two passes:
//   1. `pre_register` — index every fn signature, struct decl, trait, impl,
//      and macro reachable from the root. Builds `g.impl_set`, the trait/type
//      table the bound checker relies on. Also resolves module aliases from
//      `import` so qualified paths (`stdlib::math::min_int`) become callable.
//   2. `check` — walk stmts and exprs, attaching types to every node, raising
//      diagnostics for type mismatches, undefined names, missing trait
//      methods, unsatisfied generic bounds (`<T: Render>`), null safety,
//      arena-not-freed, unused locals, etc.
//
// Generic functions are typechecked with TY_NAMED placeholders for type
// parameters; monomorphization happens later in codegen. Borrow rules
// (`&` / `&mut`) are enforced here without lifetime annotations.
import stdlib::hashmap::*;
import bootstrap::syntax::ast::*;
import bootstrap::syntax::parser; // for ParseDiag (used by merge_parse_diags below)

// ---- type helpers --------------------------------------------------------

// types_compat is the looser companion to type_eq used by call sites.
// Was private; exported so the LSP (and any analyser running outside the
// main pipeline) can reach it.

// Convert parser-side diagnostics into typer DiagEntry shape and append
// them to the typer's diagnostics vector so the pretty-printer / LSP
// publish path picks them up alongside type errors. Always severity 1
// (`error`) with code `parse`.
pub fn merge_parse_diags(t: *Typer, pdiags: *Vector<ParseDiag>) {
    if t == null || pdiags == null {
        return;
    }
    for let i: i32 = 0; i < pdiags.len(); i++ {
        let d: ParseDiag = pdiags.get(i);
        let mut code: string = d.code;
        if code.eq("") {
            code = "parse";
        }
        let mut span: i32 = d.span;
        if span < 1 {
            span = 1;
        }
        let e: DiagEntry = DiagEntry { line: d.line, col: d.col, end_line: d.line, end_col: d.col + span, severity: 1, code: code, message: d.msg, origin: d.origin, tag: 0, fix_line: d.fix_line, fix_col: d.fix_col, fix_end_line: d.fix_end_line, fix_end_col: d.fix_end_col, fix_replacement: d.fix_replacement };
        t.diagnostics.push(e);
    }
}

pub fn type_eq(a: *Type, b: *Type) -> bool {
    if a == null {
        return b == null;
    }
    if b == null {
        return false;
    }
    if a.kind != b.kind {
        return false;
    }
    if a.kind == TY_NAMED {
        return a.name.eq(b.name);
    }
    if a.kind == TY_DYN {
        return a.name.eq(b.name);
    }
    if a.kind == TY_ASSOC {
        if !a.name.eq(b.name) {
            return false;
        }
        return type_eq(a.inner, b.inner);
    }
    if a.kind == TY_TUPLE {
        let an: i32 = if a.args != null { a.args.len() } else { 0 };
        let bn: i32 = if b.args != null { b.args.len() } else { 0 };
        if an != bn {
            return false;
        }
        for let i: i32 = 0; i < an; i++ {
            let ae: Type = a.args.get(i);
            let be: Type = b.args.get(i);
            if !type_eq(&ae, &be) {
                return false;
            }
        }
        return true;
    }
    return type_eq(a.inner, b.inner);
}

pub fn type_to_string(t: *Type) -> string {
    if t == null {
        return "<none>";
    }
    if t.kind == TY_NAMED {
        return t.name;
    }
    if t.kind == TY_POINTER {
        return "*".concat(type_to_string(t.inner));
    }
    if t.kind == TY_BORROW {
        return "&".concat(type_to_string(t.inner));
    }
    if t.kind == TY_BORROW_MUT {
        return "&mut ".concat(type_to_string(t.inner));
    }
    if t.kind == TY_SLICE {
        return "[]".concat(type_to_string(t.inner));
    }
    if t.kind == TY_GENERIC {
        let mut out: string = t.name.concat("<");
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                if i > 0 {
                    out = out.concat(", ");
                }
                let a: Type = t.args.get(i);
                out = out.concat(type_to_string(&a));
            }
        }
        return out.concat(">");
    }
    if t.kind == TY_RESULT {
        return "!".concat(type_to_string(t.inner));
    }
    if t.kind == TY_OPTION {
        return "?".concat(type_to_string(t.inner));
    }
    if t.kind == TY_OPT_RESULT {
        return "?!".concat(type_to_string(t.inner));
    }
    if t.kind == TY_DYN {
        return "dyn ".concat(t.name);
    }
    if t.kind == TY_ASSOC {
        return type_to_string(t.inner).concat("::").concat(t.name);
    }
    if t.kind == TY_TUPLE {
        let mut out: string = "(";
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                if i > 0 {
                    out = out.concat(", ");
                }
                let a: Type = t.args.get(i);
                out = out.concat(type_to_string(&a));
            }
        }
        return out.concat(")");
    }
    if t.kind == TY_FNPTR {
        let mut s: string = "fn(";
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                if i > 0 {
                    s = s.concat(", ");
                }
                let a: Type = t.args.get(i);
                s = s.concat(type_to_string(&a));
            }
        }
        s = s.concat(")");
        if t.fnptr_ret != null {
            s = s.concat(" -> ").concat(type_to_string(t.fnptr_ret));
        }
        return s;
    }
    return "<ty?>";
}

// Operator-overloading method name for an arithmetic op (`+`->add, …), or ""
// for non-arithmetic ops. `%` maps to `rem`, matching the Rust naming.
fn _arith_method(op: i32) -> string {
    if op == OP_ADD { return "add"; }
    if op == OP_SUB { return "sub"; }
    if op == OP_MUL { return "mul"; }
    if op == OP_DIV { return "div"; }
    if op == OP_MOD { return "rem"; }
    return "";
}

// The source symbol for an operator, for diagnostics.
fn _op_symbol(op: i32) -> string {
    if op == OP_EQ { return "=="; }
    if op == OP_NE { return "!="; }
    if op == OP_ADD { return "+"; }
    if op == OP_SUB { return "-"; }
    if op == OP_MUL { return "*"; }
    if op == OP_DIV { return "/"; }
    if op == OP_MOD { return "%"; }
    if op == OP_LT { return "<"; }
    if op == OP_LE { return "<="; }
    if op == OP_GT { return ">"; }
    if op == OP_GE { return ">="; }
    return "?";
}

fn is_int_type(t: *Type) -> bool {
    if t == null {
        return false;
    }
    if t.kind != TY_NAMED {
        return false;
    }
    let n: string = t.name;
    if n.eq("i8") {
        return true;
    }
    if n.eq("i16") {
        return true;
    }
    if n.eq("i32") {
        return true;
    }
    if n.eq("i64") {
        return true;
    }
    if n.eq("u8") {
        return true;
    }
    if n.eq("u16") {
        return true;
    }
    if n.eq("u32") {
        return true;
    }
    if n.eq("u64") {
        return true;
    }
    if n.eq("i128") {
        return true;
    }
    if n.eq("u128") {
        return true;
    }
    if n.eq("usize") {
        return true;
    }
    if n.eq("isize") {
        return true;
    }
    if n.eq("char") {
        return true;
    }
    return false;
}

fn is_float_type(t: *Type) -> bool {
    if t == null {
        return false;
    }
    if t.kind != TY_NAMED {
        return false;
    }
    return t.name.eq("f32") || t.name.eq("f64");
}

// True if `n` names an integer primitive (any width). Used to type the
// associated constants `<inttype>::MAX` / `::MIN`.
fn _is_int_prim_name(n: string) -> bool {
    if n.eq("i8") || n.eq("i16") || n.eq("i32") || n.eq("i64") || n.eq("i128") || n.eq("i256") {
        return true;
    }
    if n.eq("u8") || n.eq("u16") || n.eq("u32") || n.eq("u64") || n.eq("u128") || n.eq("u256") {
        return true;
    }
    if n.eq("usize") || n.eq("isize") {
        return true;
    }
    return false;
}

fn is_bool_type(t: *Type) -> bool {
    if t == null {
        return false;
    }
    return t.kind == TY_NAMED && t.name.eq("bool");
}

// `for x in <init>` lowers to `let __glide_iter_N = <init>;` plus an index
// loop that calls `.len()` / `.get()` on it. Iterating a scalar (the classic
// `for i in v.len()` mistake) used to slip past the typer and only blow up at
// link time with an undefined `__glide_int_len`. True when `<init>` is a
// scalar — by inferred type, or, when inference fails (imported `.len()`),
// by recognising a length/count call or a numeric literal syntactically.
fn _foreach_scalar_misuse(val_ty: *Type, init: *Expr) -> bool {
    if is_int_type(val_ty) || is_float_type(val_ty) || is_bool_type(val_ty) {
        return true;
    }
    if init == null {
        return false;
    }
    if init.kind == EX_INT || init.kind == EX_FLOAT {
        return true;
    }
    if is_unknown_type(val_ty) && init.kind == EX_CALL && init.lhs != null && init.lhs.kind == EX_MEMBER && init.lhs.field != null {
        let m: string = init.lhs.field;
        if m.eq("len") || m.eq("count") || m.eq("size") {
            return true;
        }
    }
    return false;
}

// Underline width for an iterable expression so the squiggle covers the whole
// thing instead of just its first byte. Handles `recv.method()` via the parsed
// member field column; falls back to `_arg_span` for idents / literals.
fn _iter_expr_span(e: *Expr) -> i32 {
    if e == null {
        return 1;
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.field != null && e.lhs.field_col > 0 {
        let w: i32 = e.lhs.field_col - e.column + e.lhs.field.len() + 2;
        if w > 0 {
            return w;
        }
    }
    return _arg_span(e);
}

fn is_unknown_type(t: *Type) -> bool {
    if t == null {
        return true;
    }
    return t.kind == TY_NAMED && t.name.eq("__unknown__");
}

// True if `t` (recursively) names any of the strings in `names`. Used to
// detect still-generic return types after impl-param subst so we fall back
// to null (permissive) instead of surfacing an unresolved `T` upstream.
// Infer method-level type-params (`<U>` on `fn fold<U>(init: U, f: fn(U,T) -> U) -> U`)
// from the call's args, then substitute them into the return type. `params_after_self`
// is the method's param list with the implicit self stripped; `arg_types` is the inferred
// type of each user-supplied arg in lockstep. Returns the rewritten return type.
//
// Without this, calling `v.fold(0, _add)` on `*Vector<int>` returns the literal `U` named
// type — the owner-type subst above only handles the impl block's `<T>`, not the method's
// own `<U>`. `extract_for_var` walks each (param, arg) pair to locate U's concrete binding.
fn _infer_method_tparams(ret: *Type, method_tparams: *Vector<string>, params_after_self: *Vector<Param>, arg_types: *Vector<*Type>) -> *Type {
    if ret == null || method_tparams == null || method_tparams.len() == 0 {
        return ret;
    }
    if params_after_self == null || arg_types == null {
        return ret;
    }
    let plen: i32 = params_after_self.len();
    let alen: i32 = arg_types.len();
    let n: i32 = if plen < alen { plen } else { alen };
    let names: *Vector<string> = Vector::new();
    let bound: *Vector<Type> = Vector::new();
    for let ti: i32 = 0; ti < method_tparams.len(); ti++ {
        let tp_name: string = method_tparams.get(ti);
        let mut concrete: *Type = null;
        for let i: i32 = 0; i < n; i++ {
            let p: Param = params_after_self.get(i);
            let at: *Type = arg_types.get(i);
            if p.ty == null || at == null {
                continue;
            }
            let extracted: *Type = extract_for_var(p.ty, at, tp_name);
            if extracted != null {
                concrete = extracted;
                break;
            }
        }
        if concrete != null {
            names.push(tp_name);
            bound.push(*concrete);
        }
    }
    if names.len() == 0 {
        return ret;
    }
    return _subst_type_local(ret, names, bound);
}

fn _type_references_any(t: *Type, names: *Vector<string>) -> bool {
    if t == null || names == null {
        return false;
    }
    if t.kind == TY_NAMED {
        for let i: i32 = 0; i < names.len(); i++ {
            if t.name.eq(names.get(i)) {
                return true;
            }
        }
        return false;
    }
    if t.inner != null && _type_references_any(t.inner, names) {
        return true;
    }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            if _type_references_any(&a, names) {
                return true;
            }
        }
    }
    return false;
}

// Head of a type, used by the hint gate: "Json<Res>" -> "Json", "*Foo" ->
// "Foo", "!int" -> "Result", "?int" -> "Option", "?!int" -> "OptResult".
fn _type_head_name(t: *Type) -> string {
    if t == null {
        return "";
    }
    if t.kind == TY_POINTER || t.kind == TY_BORROW || t.kind == TY_BORROW_MUT {
        return _type_head_name(t.inner);
    }
    if t.kind == TY_RESULT {
        return "Result";
    }
    if t.kind == TY_OPTION {
        return "Option";
    }
    if t.kind == TY_OPT_RESULT {
        return "OptResult";
    }
    if t.kind == TY_NAMED {
        return t.name;
    }
    if t.kind == TY_GENERIC {
        return t.name;
    }
    return "";
}

// Comma-joined membership test. "Json,Result" contains "Json" -> true.
fn _csv_contains(csv: string, needle: string) -> bool {
    if csv == null || csv.eq("") {
        return false;
    }
    let n: i32 = csv.len();
    let mut start: i32 = 0;
    let mut i: i32 = 0;
    while i <= n {
        let at_end: bool = i == n;
        let mut sep: bool = at_end;
        if !at_end {
            if csv.at(i).to_int() == 44 {
                sep = true;
            }
        }
        if sep {
            let seg: string = csv.substring(start, i);
            if seg.eq(needle) {
                return true;
            }
            start = i + 1;
        }
        i = i + 1;
    }
    return false;
}

// Replace every `%key%` in `tpl` with `value`. We use `%...%` (not the
// usual `${...}`) because the Glide lexer parses `${expr}` as a string-
// interpolation macro and synthesises an EX_MACRO call on attribute
// args — which trips the EX_STRING check upstream.
fn _tpl_replace(tpl: string, key: string, value: string) -> string {
    if tpl == null || tpl.eq("") {
        return tpl;
    }
    let pat: string = "%".concat(key).concat("%");
    let pl: i32 = pat.len();
    let tl: i32 = tpl.len();
    let mut out: string = "";
    let mut i: i32 = 0;
    while i < tl {
        if i + pl <= tl && tpl.substring(i, i + pl).eq(pat) {
            out = out.concat(value);
            i = i + pl;
        } else {
            out = out.concat(tpl.substring(i, i + 1));
            i = i + 1;
        }
    }
    return out;
}

// Param count of a fn / fn-ptr type. -1 for non-fnptr.
fn _fnptr_arity(t: *Type) -> i32 {
    if t == null || t.kind != TY_FNPTR {
        return -1;
    }
    if t.args == null {
        return 0;
    }
    return t.args.len();
}

// True if the `got_param_shape` gate accepts `got`'s arity. Supported
// values: "" (any), "0", "1+".
fn _param_shape_ok(shape: string, got: *Type) -> bool {
    if shape == null || shape.eq("") {
        return true;
    }
    let n: i32 = _fnptr_arity(got);
    if n < 0 {
        return true;
    }
    if shape.eq("0") {
        return n == 0;
    }
    if shape.eq("1+") {
        return n >= 1;
    }
    if shape.eq("any") {
        return true;
    }
    return true;
}

// If `want` is a fn-ptr whose return type matches a registered
// `@suggest_for_fnptr` hint, return the hint message prefixed with
// `\n  hint: `. Empty when there's no match. Lets proc-macro authors
// surface "annotate with @handler" (or similar) when a user passes
// a raw fn where a wrapped fn-ptr was expected.
//
// Message template supports `${want}` / `${got}` / `${want_ret}` /
// `${got_ret}` / `${got_name}` placeholders that the typer fills in
// at emit time. Optional `@suggest_when_got_returns` /
// `@suggest_when_got_params` companion attrs gate the hint to user
// fns the proc-macro can actually wrap.
fn _fnptr_hint(t: *Typer, want: *Type, got: *Type, got_name: string) -> string {
    if t == null || want == null {
        return "";
    }
    if want.kind != TY_FNPTR {
        return "";
    }
    if want.fnptr_ret == null {
        return "";
    }
    if want.fnptr_ret.kind != TY_NAMED {
        return "";
    }
    if t.fnptr_hints == null {
        return "";
    }
    let ret_name: string = want.fnptr_ret.name;
    let got_ret_head: string = if got != null && got.kind == TY_FNPTR && got.fnptr_ret != null { _type_head_name(got.fnptr_ret) } else { "" };
    for let i: i32 = 0; i < t.fnptr_hints.len(); i++ {
        let h: FnptrHint = t.fnptr_hints.get(i);
        if !h.ret_type_name.eq(ret_name) {
            continue;
        }
        // Got-side gate: optional return-head allow list.
        if !h.got_ret_heads.eq("") && !got_ret_head.eq("") {
            if !_csv_contains(h.got_ret_heads, got_ret_head) {
                continue;
            }
        }
        // Got-side gate: optional param-shape constraint.
        if !_param_shape_ok(h.got_param_shape, got) {
            continue;
        }
        // Substitute placeholders.
        let want_str: string = type_to_string(want);
        let got_str: string = if got != null { type_to_string(got) } else { "" };
        let want_ret_str: string = type_to_string(want.fnptr_ret);
        let got_ret_str: string = if got != null && got.kind == TY_FNPTR && got.fnptr_ret != null { type_to_string(got.fnptr_ret) } else { "" };
        let mut msg: string = h.message;
        msg = _tpl_replace(msg, "want", want_str);
        msg = _tpl_replace(msg, "got", got_str);
        msg = _tpl_replace(msg, "want_ret", want_ret_str);
        msg = _tpl_replace(msg, "got_ret", got_ret_str);
        msg = _tpl_replace(msg, "got_name", got_name);
        return "\n  hint: ".concat(msg);
    }
    return "";
}

// Minimal subst for method-call return-type inference. Walks the type tree
// and rewrites any TY_NAMED whose name appears in `params` with the
// corresponding entry of `args`. Mirrors codegen's `subst_type` for just
// the shapes we hit during inference.
fn _subst_type_local(t: *Type, params: *Vector<string>, args: *Vector<Type>) -> *Type {
    if t == null {
        return null;
    }
    if t.kind == TY_NAMED && params != null {
        for let i: i32 = 0; i < params.len(); i++ {
            if t.name.eq(params.get(i)) {
                let a: Type = args.get(i);
                let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *p = a;
                return p;
            }
        }
        return t;
    }
    if t.kind == TY_POINTER {
        return ty_pointer(_subst_type_local(t.inner, params, args));
    }
    if t.kind == TY_RESULT {
        return ty_result(_subst_type_local(t.inner, params, args));
    }
    if t.kind == TY_OPTION {
        return ty_option(_subst_type_local(t.inner, params, args));
    }
    if t.kind == TY_OPT_RESULT {
        return ty_optres(_subst_type_local(t.inner, params, args));
    }
    if t.kind == TY_BORROW {
        let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW;
        p.inner = _subst_type_local(t.inner, params, args);
        return p;
    }
    if t.kind == TY_BORROW_MUT {
        let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW_MUT;
        p.inner = _subst_type_local(t.inner, params, args);
        return p;
    }
    if t.kind == TY_GENERIC {
        let new_args: *Vector<Type> = Vector::new();
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                let sa: *Type = _subst_type_local(&a, params, args);
                if sa != null {
                    new_args.push(*sa);
                }
            }
        }
        return ty_generic(t.name, new_args);
    }
    if t.kind == TY_TUPLE {
        let new_args: *Vector<Type> = Vector::new();
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                let sa: *Type = _subst_type_local(&a, params, args);
                if sa != null {
                    new_args.push(*sa);
                }
            }
        }
        return ty_tuple(new_args);
    }
    return t;
}

pub fn types_compat(want: *Type, got: *Type) -> bool {
    // If either side couldn't be inferred (the typer is permissive and many
    // expressions still return null), don't pretend it's a mismatch — that
    // would flood callers with cascading false-positive diagnostics.
    if want == null || got == null {
        return true;
    }
    if is_unknown_type(want) || is_unknown_type(got) {
        return true;
    }
    if type_eq(want, got) {
        return true;
    }
    // A bare generic-struct literal (`Box { … }` / `Json { … }`) infers as the
    // un-parameterized name (`Box` / `Json`), but its declared/return/field type
    // is `Box<T>` / `Json<T>`. Same base name => compatible; the literal's type
    // args are inferred from its field values, not a real mismatch.
    if want.kind == TY_GENERIC && got.kind == TY_NAMED && want.name.eq(got.name) {
        return true;
    }
    if want.kind == TY_NAMED && got.kind == TY_GENERIC && want.name.eq(got.name) {
        return true;
    }
    if is_int_type(want) && is_int_type(got) {
        return true;
    }
    if is_float_type(want) && is_float_type(got) {
        return true;
    }
    // *T <-> *void (libc malloc/calloc result, plus the type of `null`).
    // Must run BEFORE the structural pointer recursion below; otherwise the
    // recursion compares Stmt vs void at the leaf and returns false.
    if want.kind == TY_POINTER && got.kind == TY_POINTER {
        if want.inner != null && want.inner.kind == TY_NAMED && want.inner.name.eq("void") {
            return true;
        }
        if got.inner != null && got.inner.kind == TY_NAMED && got.inner.name.eq("void") {
            return true;
        }
    }
    // *T <-> &T <-> &mut T are interconvertible.
    if (want.kind == TY_POINTER || want.kind == TY_BORROW || want.kind == TY_BORROW_MUT) && (got.kind == TY_POINTER || got.kind == TY_BORROW || got.kind == TY_BORROW_MUT) {
        return types_compat(want.inner, got.inner);
    }
    // Tuples: same arity, element-wise compatible (so int-literal widening
    // through `(1, 2): (i64, i64)` doesn't read as a mismatch).
    if want.kind == TY_TUPLE && got.kind == TY_TUPLE {
        let wn: i32 = if want.args != null { want.args.len() } else { 0 };
        let gn: i32 = if got.args != null { got.args.len() } else { 0 };
        if wn != gn {
            return false;
        }
        for let i: i32 = 0; i < wn; i++ {
            let we: Type = want.args.get(i);
            let ge: Type = got.args.get(i);
            if !types_compat(&we, &ge) {
                return false;
            }
        }
        return true;
    }
    return false;
}

// True when `ty` is a "plain" named type, or a pointer/borrow chain ending in
// one — excluding generics (`Vector<T>`), tuples, option/result wrappers,
// fn-pointers, and the typer's placeholder names. Struct-literal field-value
// checking compares ONLY these, so it never false-positives on a `Vector<T>`,
// a `?T`, an unresolved (`__unknown__`) value, or a `Self`/generic field.
fn _struct_field_checkable(ty: *Type) -> bool {
    if ty == null {
        return false;
    }
    let mut b: *Type = ty;
    while b != null && (b.kind == TY_POINTER || b.kind == TY_BORROW || b.kind == TY_BORROW_MUT) {
        b = b.inner;
    }
    if b == null || b.kind != TY_NAMED {
        return false;
    }
    let n: string = b.name;
    if n.eq("__unknown__") || n.eq("__fn__") || n.eq("__error__") || n.eq("Self") || n.eq("void") {
        return false;
    }
    return true;
}

// ---- function signatures -------------------------------------------------
pub struct FnSig {
    pub name: string,
    pub params: *Vector<Param>,
    pub ret_type: *Type,
    pub owned_return: bool, // fn returns one of its own struct-literal auto-drop locals (move-out)
    pub is_variadic: bool, // C-style trailing `...` (extern fn printf etc.)
    // Generic type parameter names (e.g. `["T", "U"]`) and their `+`-joined
    // trait bounds in lockstep (`["Ord+Clone", ""]`). Both are null/empty
    // for non-generic fns. Used by EX_CALL to enforce bounds at the call
    // site after inferring the concrete type for each T from the args.
    pub type_params: *Vector<string>,
    pub type_param_bounds: *Vector<string>,
    // For impl methods: the owning impl block's `<T, U>` (separate from the
    // method's own `type_params` — usually empty). Lets method-call type
    // inference substitute `T` in the return type using the receiver's
    // concrete args (`*Vector<int>.get()` -> int, not T).
    pub owner_type_params: *Vector<string>,
    // Bounds on the owning impl's type params, in lockstep with
    // owner_type_params (`impl<T: Show> GBox<T>` -> ["Show"]). Checked at
    // method-call sites against the receiver's concrete type args.
    pub owner_type_param_bounds: *Vector<string>,
    // Declaration site of the fn, so an unsatisfied-bound error can point
    // "`T: Trait` bound declared here" via relatedInformation.
    pub decl_origin: string,
    pub decl_line: i32,
    pub decl_col: i32,
}

// ---- typer state ---------------------------------------------------------
pub struct BorrowEvent {
    pub source: string,
    pub is_mut: bool,
    // The let-binder that holds this borrow (`r` in `let r = &x`). Used
    // by NLL kill-after-last-use: a block walker scans the remaining
    // stmts after each step; an event whose binder no longer appears is
    // dropped so subsequent mutation of `source` is allowed.
    pub binder: string,
    // Where the borrow was taken, so an overlap-borrow error can point
    // "`x` was first borrowed here" via relatedInformation.
    pub line: i32,
    pub col: i32,
}

// Severity levels match LSP's DiagnosticSeverity:
//   1 = error, 2 = warning, 3 = information, 4 = hint
pub struct DiagEntry {
    pub line: i32,
    pub col: i32,
    pub end_line: i32,
    pub end_col: i32,
    pub severity: i32,
    pub code: string, // stable identifier (e.g. "unused-var", "type-mismatch")
    pub message: string,
    pub origin: string, // source file path (set from t.current_origin)
    pub tag: i32, // 0 = none, 1 = Unnecessary (faded), 2 = Deprecated (struck-through)
    // Optional mechanical fix. `fix_replacement` is the text to splice
    // in over the range `(fix_line, fix_col)..(fix_end_line, fix_end_col)`.
    // Zero-width range (start == end) is an insertion. Empty
    // replacement on a non-zero range is a deletion. Empty
    // replacement on a zero-width range means the diagnostic has no
    // mechanical fix and `glide fix` skips it.
    pub fix_line: i32,
    pub fix_col: i32,
    pub fix_end_line: i32,
    pub fix_end_col: i32,
    pub fix_replacement: string,
}

// A secondary "this is why" location attached to a diagnostic, surfaced as
// LSP relatedInformation. Kept in a side-vector keyed by the diagnostic's
// index (rather than embedded in DiagEntry) so the many DiagEntry literals
// don't all need new fields.
pub struct DiagRelated {
    pub diag_index: i32, // index into Typer.diagnostics this explains
    pub origin: string, // source file of the related location
    pub line: i32,
    pub col: i32,
    pub end_line: i32,
    pub end_col: i32,
    pub message: string, // e.g. "trait method `foo` declared here"
}

pub struct Typer {
    pub fns: *HashMap<FnSig>,
    pub structs: *HashMap<bool>, // just registry of names for now
    // `<TypeName>::<method>` -> true for every method declared in ANY impl
    // (generic OR specialized) of that type. Lets "no method" detection
    // tell a real typo from a specialized method (`Vector<int>::sum`) whose
    // exact monomorphized key the receiver type didn't resolve to.
    pub method_names: *HashMap<bool>,
    // `<StructName>::<field>` -> true for every declared field. Drives
    // "no field" detection for `obj.field` reads on known structs.
    pub struct_fields_all: *HashMap<bool>,
    // `<StructName>::<field>` -> declared field Type. Drives struct-literal
    // field-value type checking (pointer-vs-value, wrong-struct mismatches).
    pub struct_field_types: *HashMap<Type>,
    // Struct names that declare `<T, ...>` type params. Their field types can
    // reference those params, so literal field-value checking is skipped for
    // them (no monomorphization at this stage) to avoid false positives.
    pub struct_generic: *HashMap<bool>,
    // Opaque `extern type Foo;` names. Registered in `structs` too (so `*Foo`
    // resolves), but by-value uses and struct literals are rejected — the C
    // side owns the definition and Glide never knows the size.
    pub extern_types: *HashMap<bool>,
    pub scope: *HashMap<Type>, // current scope: name -> Type (heap-alloc'd)
    pub module_scope: *HashMap<Type>, // top-level consts (visible inside any fn body)
    // Freestanding / kernel build: also register top-level `let` globals in
    // module_scope so fn bodies can read/write them (a kernel needs mutable
    // global state). Set from the build before check_program runs.
    pub freestanding: bool,
    pub owned_locals: *HashMap<bool>, // names that must not escape (auto-drop)
    // Local `*Arena` bindings declared in the current fn body. Anything
    // allocated from one of these can't escape via return - the caller
    // would read freed memory after this fn's `defer arena.free()` ran.
    // Params and globals never enter this map; their lifetimes are the
    // caller's problem.
    pub arena_locals: *HashMap<bool>,
    // Per-name: the arena ident this value derives from (only populated
    // when the source arena is currently local). `let p: *T = a.create(T)`
    // sets arena_origin[p] = "a"; return p then triggers the escape
    // check against arena_locals.
    pub arena_origin: *HashMap<string>,
    // Names that have had a `.free()` (or similar consume) call against
    // them in the current fn body. Subsequent reads error with
    // `use-after-free`.
    pub consumed_locals: *HashMap<bool>,
    // Owned locals moved out (assigned / stored / passed). Also recorded in
    // consumed_locals (which drives the read-after error + branch handling);
    // this parallel set only distinguishes the message: `use-after-move` vs
    // `use-after-free`.
    pub moved_out: *HashMap<bool>,
    // Locals bound to an owned-returning call (`let x = make()`). Tracked apart
    // from owned_locals so the `owned-move` lint is unaffected; used to flag
    // use-after-move when such a local is later assigned away.
    pub call_owned: *HashMap<bool>,
    // `let` mutability: name -> declared with `mut`? A write (`x = …`, `x += …`,
    // `x++`, `&mut x`) against a `false` entry is an `assign-immutable` error.
    // Params register as `false`; a `for`-init `let` registers `true` (its
    // step clause mutates it by design, so the idiomatic loop needs no `mut`).
    pub mut_locals: *HashMap<bool>,
    // name -> declaration name-token position packed as line*4096+col. The
    // `assign-immutable` fix splices `mut ` in right there; 0 marks a param
    // (no splice point — `mut` is not param syntax), which switches the
    // message to the copy-into-a-local suggestion.
    pub mut_decl_pos: *HashMap<i32>,
    // Block-scope `const` names (per-fn, saved/restored like mut_locals).
    // Switches the assign-immutable wording to "constant" and drops the
    // `let mut` fix-it — a `const` can never be made mutable.
    pub const_bindings: *HashMap<bool>,
    // File-scope `const` names (whole program, filled by pre_register). A
    // write whose root resolves here — and is not shadowed by a local — is
    // an assign-immutable error; before this the only backstop was cc's
    // "lvalue required" misreported as an ICE. Freestanding top-level `let`
    // globals are NOT in this set: they are mutable by design.
    pub module_consts: *HashMap<bool>,
    pub borrows: *Vector<BorrowEvent>, // active let-bound borrows; save/restore per block
    pub current_ret: *Type,
    // Body of the fn currently being checked (for the 2B value-copy escape
    // walker _let_binding_escapes). null outside a fn body => conservative MOVE.
    pub cur_fn_body: *Vector<Stmt>,
    // Recursion guard for the alias-chain case in that walker (`let c = b`
    // re-aliases the copy); above the cap => conservative escape (MOVE).
    pub esc_alias_depth: i32,
    // Type parameters of the enclosing fn (e.g. `["T", "U"]`). Used by
    // EX_PATH resolution: `T::method(v)` is valid inside a `<T: Trait>`
    // body when T is one of these. Null/empty outside any generic fn.
    pub current_type_params: *Vector<string>,
    // Impl-body checking. impl_type_params holds the enclosing `impl<T>`'s own
    // type params so they're in scope inside its methods.
    pub impl_type_params: *Vector<string>,
    pub current_origin: string, // file the typer is currently checking
    // LSP-only: when set to the edited file's path, check_program skips the
    // BODY typecheck of functions from OTHER (imported) files — their
    // diagnostics are discarded at publish anyway, and registration
    // (_canon_decls / pre_register / build_visibility) is still whole-program,
    // so cross-file resolution is unchanged. Empty ("") = full checking (CLI).
    pub user_origin: string,
    // The CLI entry file being compiled. Unlike user_origin (which SKIPS
    // imported bodies), this only scopes the visibility/scope checks
    // (`unknown-name`, `type-not-in-scope`, module-path-allowed): those rules
    // apply to the entry file only. Imported files still get their BODIES
    // checked whole-program (real type/borrow/mut errors surface), but their
    // import-scope is trusted — the per-file visibility map does not model
    // transitive/wildcard re-exports well enough to judge them without false
    // positives, and each file's own scope is validated when IT is the entry.
    // Empty ("") = enforce visibility everywhere (the old whole-program mode).
    pub entry_origin: string,
    // Per-file visibility: `<origin>::<name>` -> bool. A name is visible
    // from file `F` only if it appears in `F`'s visibility set. Selective
    // imports (`import a::b::c::Item;`) populate this; src/builtins/ pub
    // names are added to every file's set so they act as a prelude.
    pub visibility: *HashMap<bool>,
    // Per-file module aliases: `<origin>::<short>` -> bool. Populated by
    // `import a::b::c;` (pure module import) - the short name `c` becomes
    // a callable namespace from inside `<origin>`. Used by EX_PATH
    // enforcement to allow `c::Item(...)` while rejecting unimported
    // partial paths.
    pub module_imports: *HashMap<bool>,
    // Set of every loaded file's full module path (e.g. `stdlib::math`).
    // Always-allowed for fully qualified path expressions even without an
    // explicit import.
    pub module_full_paths: *HashMap<bool>,
    // Field-level pub map: key `<struct>::<field>` -> true if the field
    // was declared with `pub`. Missing entry = private.
    pub field_pub: *HashMap<bool>,
    pub struct_has_private: *HashMap<bool>, // struct name -> has >=1 non-pub field
    // Where each struct was declared, so we know whether a `obj.field`
    // access is happening inside the struct's own file (always allowed)
    // or from another file (then `field_pub` enforces).
    pub struct_origin: *HashMap<string>,
    // Names flagged as duplicate definitions — the unused-* lints skip them so
    // a conflict shows only the error, not a redundant "never used" warning.
    pub dup_flagged: *HashMap<bool>,
    // >0 while inferring the operand of `&x` / `&mut x` (taking a borrow is
    // not a "use" of the source — overlap-borrow judges it) and while
    // inferring an assignment LHS (the write check has its own message).
    // Suppresses the read-under-&mut check on EX_IDENT.
    pub addr_ctx: i32,
    // Whether visibility enforcement is active for this run. Off by default
    // so existing files that haven't been migrated keep compiling; the
    // compiler entry point flips it on when the user-facing build runs.
    pub enforce_visibility: bool,
    // Set of `<trait>::<type>` keys for every `impl Trait for Type` in the
    // program. Built up front in pre_register and consulted to verify
    // `<T: Trait>` bounds at call sites.
    pub impl_set: *HashMap<bool>,
    // Associated-type lookup: `<Trait>::<TargetTypeName>::<AssocName>` -> Type.
    // Populated alongside impl_set. Consulted to resolve `T::Item` projections
    // when T has a trait bound and a concrete impl is in scope.
    pub assoc_table: *HashMap<Type>,
    // Enum exhaustiveness: enum name -> comma-joined variant names. Built in
    // pre_register; consulted by ST_MATCH check to flag uncovered variants.
    pub enums: *HashMap<string>,
    // True while check_fn is visiting an impl METHOD (LSP focused mode).
    // A bare call `free(x)` inside a method named `free` targets the FREE
    // FUNCTION, never the method — so the self-recursion lint must not fire.
    pub in_impl_method: bool,
    // "Enum::Variant" -> payload field count, for pattern-arity checking.
    pub enum_arities: *HashMap<i32>,
    // "Enum::Variant#i" -> payload field type, so match-arm bindings get their
    // real type (not a compatible-with-anything placeholder).
    pub enum_payload_tys: *HashMap<Type>,
    pub error_count: i32,
    pub diagnostics: *Vector<DiagEntry>,
    // Related "why" locations, keyed by diagnostic index. See DiagRelated.
    pub related: *Vector<DiagRelated>,
    // Proc-macro authors can attach `@suggest_for_fnptr(RetType, "msg")`
    // to their impl fn so any fn-ptr-arg mismatch whose expected return
    // type matches `RetType` gets the hint appended. Lets `@handler` say
    // "annotate with @handler" without baking HTTP knowledge into the
    // typer.
    pub fnptr_hints: *Vector<FnptrHint>,
    // POD-struct memo for the copy-vs-move rule: struct name -> 1 (pure data,
    // copies on `let b = a`) / 2 (owns heap or unknown, moves). Lazy.
    pub pod_cache: *HashMap<i32>,
    // Bounds on generic STRUCT type params: `<Struct>#<i>` -> the `+`-joined
    // bound list of param i (only non-empty bounds are stored). Checked at
    // instantiation sites (type annotations) against impl_set.
    pub struct_tp_bounds: *HashMap<string>,
    // Cross-file member privacy for QUALIFIED access: `<origin>::<name>` for
    // every non-`pub` top-level fn/const/struct declared in a non-builtin
    // file. Filled by build_visibility. `mod::name` resolution consults it so
    // a private member isn't silently usable through the qualified form when
    // a selective import of the same name would be rejected.
    pub decl_private: *HashMap<bool>,
    // Where each top-level const was declared (name -> origin file), so the
    // qualified-const privacy check can allow same-file access.
    pub const_origin: *HashMap<string>,
    // Module qualifiers consumed by TYPE positions: `let x: *lib::T` collapses
    // to bare `T` in _canon_type BEFORE the unused-import lint runs, erasing
    // the only textual use of `lib`. The collapse records the module name here
    // so the lint doesn't tell the user to delete a load-bearing import.
    pub mod_type_uses: *HashMap<bool>,
    // >0 while checking a loop body (while / for / while-let). `defer` lowers
    // to ONE run at fn end (the __gdefer slots), so inside a loop it is a
    // silent lie — and a deferred expr naming the loop var is emitted past
    // the var's C scope (invalid C). ST_DEFER checks this and rejects.
    pub loop_depth: i32,
    // While checking an fn-expr (closure) body: the ENCLOSING fn's scope.
    // Closures can't capture, so a name from here is unknown inside the
    // closure — but "unknown name" alone sends users hunting for typos.
    // Lets the EX_IDENT miss say "closures cannot capture" instead. Null
    // outside closures.
    pub fnexpr_outer_scope: *HashMap<Type>,
}

pub struct FnptrHint {
    pub ret_type_name: string,
    pub message: string,
    // Optional gate: comma-joined list of return-type heads the GOT fn
    // can have for this hint to fire. e.g. `"Json,Result,Option"` means
    // "only show this hint if the user's fn returns Json<T>, !T, or ?T".
    // Empty string = always fire on want-side match.
    pub got_ret_heads: string,
    // Optional gate: comma-joined list of param-shape requirements.
    // For now we support simple counts: `"0"`, `"any"`, `"1+"`. The
    // typer's matcher decides; default = always match.
    pub got_param_shape: string,
}

// Free helper: looks up `name` in the enclosing fn's type parameter
// list. Used by EX_PATH resolution to allow `T::method(v)` when T is
// a generic type parameter — the actual concrete type is substituted
// later at monomorphization time.
fn _is_current_type_param(t: *Typer, name: string) -> bool {
    if name == null || name.eq("") {
        return false;
    }
    if t.current_type_params != null {
        for let i: i32 = 0; i < t.current_type_params.len(); i++ {
            if t.current_type_params.get(i).eq(name) {
                return true;
            }
        }
    }
    // Also the enclosing impl's own type params, in scope inside its methods.
    if t.impl_type_params != null {
        for let i: i32 = 0; i < t.impl_type_params.len(); i++ {
            if t.impl_type_params.get(i).eq(name) {
                return true;
            }
        }
    }
    return false;
}

// Line/col of a member expression's field name, falling back to the
// expression start when the parser didn't record a field position (a
// member node synthesized by lowering/codegen has field_line == 0).
fn _field_pos_line(m: *Expr) -> i32 {
    if m == null {
        return 0;
    }
    if m.field_line > 0 {
        return m.field_line;
    }
    return m.line;
}

fn _field_pos_col(m: *Expr) -> i32 {
    if m == null {
        return 0;
    }
    if m.field_line > 0 {
        return m.field_col;
    }
    return m.column;
}

// A reasonable squiggle width for an argument expression: the identifier
// length for a bare name (so the underline covers the whole name), else 1
// (point at the start). Keeps arg diagnostics tight without needing the
// full source extent of arbitrary expressions.
fn _arg_span(a: *Expr) -> i32 {
    if a == null {
        return 1;
    }
    if a.kind == EX_IDENT && a.str_val != null {
        let n: i32 = a.str_val.len();
        if n > 0 {
            return n;
        }
    }
    if a.kind == EX_STRING && a.str_val != null {
        return a.str_val.len() + 2; // include the surrounding quotes
    }
    if a.kind == EX_INT {
        // Digits of the literal, so `if 42 {` underlines the whole `42`.
        return format!("{}", a.int_val).len();
    }
    if a.kind == EX_FLOAT && a.float_val != null {
        return a.float_val.len();
    }
    if a.kind == EX_BOOL {
        if a.bool_val {
            return 4; // true
        }
        return 5; // false
    }
    if a.kind == EX_NULL {
        return 4; // null
    }
    return 1;
}

// Count `{}` placeholders in a `format!` string. Mirrors codegen's lowering
// exactly: a `{` immediately followed by `}` is one hole (consuming one arg),
// scanning advances past both; everything else is a literal char. There is no
// `{{` escape — codegen emits a lone `{` verbatim.
fn _count_fmt_placeholders(raw: string) -> i32 {
    if raw == null {
        return 0;
    }
    let n: i32 = raw.len();
    let mut i: i32 = 0;
    let mut count: i32 = 0;
    while i < n {
        if raw.at(i).to_int() == 123 && i + 1 < n && raw.at(i + 1).to_int() == 125 {
            count = count + 1;
            i = i + 2;
        } else {
            i = i + 1;
        }
    }
    return count;
}

// True when `n` names a real type: a primitive (list mirrors codegen's
// `type_to_c`), a declared struct/enum (t.structs holds both), a type
// parameter in scope, or `Self`. Empty = inferred, treated as known.
fn _is_known_type_name(t: *Typer, n: string) -> bool {
    if n == null || n.eq("") {
        return true;
    }
    if n.eq("Self") || n.eq("__fn__") || n.eq("__fn_ptr__") {
        return true;
    }
    if n.eq("i8") || n.eq("i16") || n.eq("i32") || n.eq("i64") || n.eq("u8") || n.eq("u16") || n.eq("u32") || n.eq("u64") || n.eq("i128") || n.eq("u128") || n.eq("i256") || n.eq("u256") || n.eq("usize") || n.eq("isize") || n.eq("f32") || n.eq("f64") || n.eq("bool") || n.eq("char") || n.eq("string") || n.eq("void") {
        return true;
    }
    if t.structs.contains(n) {
        return true;
    }
    if _is_current_type_param(t, n) {
        return true;
    }
    return false;
}

// Byte-level Levenshtein edit distance. Used to suggest the closest known
// name on an "unknown X" error. Names are short, so the O(la*lb) cost is
// negligible.
fn _edit_distance(a: string, b: string) -> i32 {
    let la: i32 = a.len();
    let lb: i32 = b.len();
    if la == 0 {
        return lb;
    }
    if lb == 0 {
        return la;
    }
    let prev: *Vector<i32> = Vector::with_cap(lb + 1);
    defer prev.free();
    let cur: *Vector<i32> = Vector::with_cap(lb + 1);
    defer cur.free();
    for let j: i32 = 0; j <= lb; j++ {
        prev.push(j);
        cur.push(0);
    }
    for let i: i32 = 1; i <= la; i++ {
        cur.set(0, i);
        let ca: i32 = a.at(i - 1).to_int();
        for let j: i32 = 1; j <= lb; j++ {
            let cb: i32 = b.at(j - 1).to_int();
            let mut cost: i32 = 1;
            if ca == cb {
                cost = 0;
            }
            let del: i32 = prev.get(j) + 1;
            let ins: i32 = cur.get(j - 1) + 1;
            let sub: i32 = prev.get(j - 1) + cost;
            let mut m: i32 = del;
            if ins < m {
                m = ins;
            }
            if sub < m {
                m = sub;
            }
            cur.set(j, m);
        }
        for let j: i32 = 0; j <= lb; j++ {
            prev.set(j, cur.get(j));
        }
    }
    return prev.get(lb);
}

// The closest candidate to `target`, or "" when nothing is close enough. The
// threshold scales with length so short names need an almost-exact hit (avoids
// noisy suggestions). Caller owns `cands` (this does not free it).
fn _closest_name(target: string, cands: *Vector<string>) -> string {
    if target == null || target.eq("") || cands == null {
        return "";
    }
    let mut best: string = "";
    let mut bestd: i32 = 99;
    for let i: i32 = 0; i < cands.len(); i++ {
        let c: string = cands.get(i);
        if c == null || c.eq("") || c.eq(target) {
            continue;
        }
        let d: i32 = _edit_distance(target, c);
        if d < bestd {
            bestd = d;
            best = c;
        }
    }
    let mut lim: i32 = target.len() / 2;
    if lim < 1 {
        lim = 1;
    }
    if lim > 2 {
        lim = 2;
    }
    if best.eq("") || bestd > lim {
        return "";
    }
    return best;
}

// `; did you mean `X`?` for the closest candidate, or "" when none is close.
fn _did_you_mean(target: string, cands: *Vector<string>) -> string {
    let c: string = _closest_name(target, cands);
    if c.eq("") {
        return "";
    }
    return "; did you mean `".concat(c).concat("`?");
}

// The replacement a `glide fix` / quick-fix should splice in for an unknown
// type `n`: a retired C-style spelling maps to its canonical form, otherwise
// the closest known type name (or "" when nothing is close).
fn _type_fix_target(t: *Typer, n: string) -> string {
    if n.eq("int") {
        return "i32";
    }
    if n.eq("uint") {
        return "u32";
    }
    if n.eq("long") {
        return "i64";
    }
    if n.eq("ulong") {
        return "u64";
    }
    if n.eq("float") {
        return "f64";
    }
    let c: *Vector<string> = _type_candidates(t);
    defer c.free();
    return _closest_name(n, c);
}

// Candidate type names: the primitives plus every registered struct/enum name.
fn _type_candidates(t: *Typer) -> *Vector<string> {
    let v: *Vector<string> = Vector::new();
    v.push("i8");
    v.push("i16");
    v.push("i32");
    v.push("i64");
    v.push("u8");
    v.push("u16");
    v.push("u32");
    v.push("u64");
    v.push("i128");
    v.push("u128");
    v.push("usize");
    v.push("isize");
    v.push("f32");
    v.push("f64");
    v.push("bool");
    v.push("char");
    v.push("string");
    v.push("void");
    if t.structs != null {
        let ks: *Vector<string> = t.structs.keys();
        for let i: i32 = 0; i < ks.len(); i++ {
            v.push(ks.get(i));
        }
        ks.free();
    }
    return v;
}

// Candidate value names in scope: locals/params, module consts, and fns.
fn _name_candidates(t: *Typer) -> *Vector<string> {
    let v: *Vector<string> = Vector::new();
    if t.scope != null {
        let a: *Vector<string> = t.scope.keys();
        for let i: i32 = 0; i < a.len(); i++ {
            v.push(a.get(i));
        }
        a.free();
    }
    if t.module_scope != null {
        let b: *Vector<string> = t.module_scope.keys();
        for let i: i32 = 0; i < b.len(); i++ {
            v.push(b.get(i));
        }
        b.free();
    }
    if t.fns != null {
        let c: *Vector<string> = t.fns.keys();
        for let i: i32 = 0; i < c.len(); i++ {
            v.push(c.get(i));
        }
        c.free();
    }
    return v;
}

// Candidate field names of struct `sname` (from the `Struct::field` registry).
fn _field_candidates(t: *Typer, sname: string) -> *Vector<string> {
    let v: *Vector<string> = Vector::new();
    if t.struct_fields_all == null {
        return v;
    }
    let pfx: string = sname.concat("::");
    let pl: i32 = pfx.len();
    let ks: *Vector<string> = t.struct_fields_all.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if k.len() > pl && k.substring(0, pl).eq(pfx) {
            v.push(k.substring(pl, k.len()));
        }
    }
    ks.free();
    return v;
}

// `unknown type `X`` message, with a `; use `iN`` hint when `X` is a retired
// C-style numeric spelling, or a `; did you mean `Y`?` suggestion otherwise.
fn _unknown_type_msg(t: *Typer, n: string) -> string {
    let msg: string = "unknown type `".concat(n).concat("`");
    let mut hint: string = "";
    if n.eq("int") {
        hint = "i32";
    }
    if n.eq("uint") {
        hint = "u32";
    }
    if n.eq("long") {
        hint = "i64";
    }
    if n.eq("ulong") {
        hint = "u64";
    }
    if n.eq("float") {
        hint = "f64";
    }
    if !hint.eq("") {
        return msg.concat("; use `").concat(hint).concat("`");
    }
    let cands: *Vector<string> = _type_candidates(t);
    defer cands.free();
    return msg.concat(_did_you_mean(n, cands));
}

// Emit an "unknown type" error spanning `n` at (line, col), attaching a quick
// fix that replaces the name when there's a confident suggestion (retired
// C-style spelling or a close known type). The editor surfaces it as a
// one-click "Change to `X`" action, and `glide fix` applies it.
fn _emit_unknown_type(t: *Typer, n: string, line: i32, col: i32) {
    let msg: string = _unknown_type_msg(t, n);
    let repl: string = _type_fix_target(t, n);
    let span: i32 = n.len();
    if repl.eq("") {
        t.err_code_range(line, col, span, "unknown-type", msg);
    } else {
        t.err_code_range_fix(line, col, span, "unknown-type", msg, line, col, line, col + span, repl);
    }
}

// Recursively flag any unknown named type inside an annotation. `dyn`
// and fn-pointer shapes are skipped — trait names + fn-shape params live
// outside the struct/primitive registries, so checking them would
// false-flag. Only runs under enforce_visibility (full registry loaded).
fn _check_type_known(t: *Typer, ty: *Type, line: i32, col: i32) {
    if ty == null {
        return;
    }
    if !t.enforce_visibility {
        return;
    }
    // Prefer the type's own recorded position (set by the parser) so the
    // squiggle lands exactly on the type name; fall back to the caller's
    // position for synthesized types that carry none.
    let mut pl: i32 = line;
    let mut pc: i32 = col;
    if ty.line > 0 {
        pl = ty.line;
        pc = ty.col;
    }
    if ty.kind == TY_NAMED {
        if !_is_known_type_name(t, ty.name) {
            _emit_unknown_type(t, ty.name, pl, pc);
        } else {
            // Known but not imported here: a real declared struct loaded via
            // some other file still needs its own import to be named.
            if t.struct_origin.contains(ty.name) && !t.is_visible(ty.name) {
                t.err_code_range(pl, pc, ty.name.len(), "type-not-in-scope", "type `".concat(ty.name).concat("` is not in scope; import it or qualify it (`<module>::").concat(ty.name).concat("`)"));
            }
        }
        return;
    }
    if ty.kind == TY_POINTER || ty.kind == TY_BORROW || ty.kind == TY_BORROW_MUT || ty.kind == TY_SLICE {
        _check_type_known(t, ty.inner, line, col);
        return;
    }
    if ty.kind == TY_RESULT || ty.kind == TY_OPTION || ty.kind == TY_OPT_RESULT {
        _check_type_known(t, ty.inner, line, col);
        return;
    }
    if ty.kind == TY_TUPLE {
        if ty.args != null {
            for let i: i32 = 0; i < ty.args.len(); i++ {
                let a: Type = ty.args.get(i);
                _check_type_known(t, &a, line, col);
            }
        }
        return;
    }
    if ty.kind == TY_GENERIC {
        if !ty.name.eq("chan") && !t.structs.contains(ty.name) && !_is_current_type_param(t, ty.name) {
            _emit_unknown_type(t, ty.name, pl, pc);
        }
        if ty.args != null {
            for let i: i32 = 0; i < ty.args.len(); i++ {
                let a: Type = ty.args.get(i);
                _check_type_known(t, &a, line, col);
                // `struct S<T: Ord>` bounds enforce at instantiation. Only
                // concrete user structs are judged (primitives / type params /
                // wrapped types stay permissive — same posture as the fn-call
                // bound check on unresolvable args).
                let bkey: string = ty.name.concat("#").concat(int_to_str(i));
                if t.struct_tp_bounds.contains(bkey) {
                    let carg: *Type = strip_ptr(&a);
                    if carg != null && carg.kind == TY_NAMED && carg.name != null && t.structs.contains(carg.name) && !_is_current_type_param(t, carg.name) {
                        let bparts: *Vector<string> = split_bounds(t.struct_tp_bounds.get(bkey));
                        for let bj: i32 = 0; bj < bparts.len(); bj++ {
                            let bnd: string = bparts.get(bj);
                            if !t.impl_set.contains(bnd.concat("::").concat(carg.name)) {
                                t.err_code_range(pl, pc, ty.name.len(), "unsatisfied-bound", "type `".concat(carg.name).concat("` does not implement `").concat(bnd).concat("` (required by the bounds of `struct ").concat(ty.name).concat("`)"));
                            }
                        }
                        bparts.free();
                    }
                }
            }
        }
        return;
    }
}

// ---- POD (copy-class) structs --------------------------------------------
// A pure-data stack struct — every field recursively free of pointers, heap
// types and owning wrappers — copies on `let b = a;` (C struct assignment is
// a value copy, same as the already-copying param path). Only structs that
// own heap state move. Payload-less enums are plain int tags (copy); payload
// enums stay conservative (move) since their union may hold pointers.
fn _ty_is_pod(t: *Typer, ty: *Type) -> bool {
    if ty == null {
        return false;
    }
    if ty.kind == TY_NAMED {
        if is_int_type(ty) || is_float_type(ty) || is_bool_type(ty) {
            return true;
        }
        if ty.name == null {
            return false;
        }
        if ty.name.eq("char") {
            return true;
        }
        if t.enums.contains(ty.name) {
            // POD iff every variant is payload-less.
            let vlist: string = t.enums.get(ty.name);
            let mut start: i32 = 0;
            let n: i32 = vlist.len();
            while start < n {
                let rest: string = vlist.substring(start, n);
                let cc: i32 = rest.index_of(",");
                let mut vname: string = rest;
                if cc >= 0 {
                    vname = rest.substring(0, cc);
                }
                if !vname.eq("") && t.enum_arities.contains(ty.name.concat("::").concat(vname)) {
                    if t.enum_arities.get(ty.name.concat("::").concat(vname)) > 0 {
                        return false;
                    }
                }
                if cc < 0 {
                    break;
                }
                start = start + cc + 1;
            }
            return true;
        }
        if t.structs.contains(ty.name) {
            return _struct_is_pod(t, ty.name);
        }
        return false;
    }
    if ty.kind == TY_TUPLE {
        if ty.args == null {
            return true;
        }
        for let i: i32 = 0; i < ty.args.len(); i++ {
            let a: Type = ty.args.get(i);
            if !_ty_is_pod(t, &a) {
                return false;
            }
        }
        return true;
    }
    // Pointers, borrows, slices, strings, generics, fn-ptrs, wrappers: not POD.
    return false;
}

fn _struct_is_pod(t: *Typer, name: string) -> bool {
    if name == null || name.eq("") {
        return false;
    }
    if t.pod_cache.contains(name) {
        return t.pod_cache.get(name) == 1;
    }
    if t.extern_types.contains(name) || t.struct_generic.contains(name) || t.enums.contains(name) {
        t.pod_cache.insert(name, 2);
        return false;
    }
    // Seed "not POD" so a (pathological) by-value cycle terminates.
    t.pod_cache.insert(name, 2);
    let mut pod: bool = true;
    let prefix: string = name.concat("::");
    let keys: *Vector<string> = t.struct_field_types.keys();
    for let i: i32 = 0; i < keys.len(); i++ {
        let k: string = keys.get(i);
        if !k.starts_with(prefix) {
            continue;
        }
        let fty: Type = t.struct_field_types.get(k);
        if !_ty_is_pod(t, &fty) {
            pod = false;
            break;
        }
    }
    keys.free();
    if pod {
        t.pod_cache.insert(name, 1);
    }
    return pod;
}

// Cross-file privacy for QUALIFIED access (`mod::name`): a member that a
// selective import would reject as private-import must not be reachable
// through the qualified spelling either. `origin` is the member's declaring
// file; same-file access (and builtins/externs, which never enter
// decl_private) always passes.
fn _check_qualified_private(t: *Typer, name: string, origin: string, line: i32, col: i32, span: i32) {
    if !t.enforce_visibility {
        return;
    }
    if name == null || name.eq("") || origin == null || origin.eq("") {
        return;
    }
    if t.current_origin == null || t.current_origin.eq("") {
        return;
    }
    if origin.eq(t.current_origin) {
        return;
    }
    if !t.decl_private.contains(origin.concat("::").concat(name)) {
        return;
    }
    t.err_code_range(line, col, span, "private-import", "`".concat(name).concat("` exists in `").concat(origin).concat("` but is not `pub`"));
}

// A literal `null` argument where the parameter is a borrow: `&T` promises
// non-null (the let-binding form is already rejected), so the call-arg hole
// let accepted programs segfault. NOTE: only the LITERAL is caught here — a
// `*T` value flowing into `&T` can't be proven non-null statically; the
// runtime assert on that coercion is deferred (wave 2).
fn _check_null_borrow_arg(t: *Typer, want: *Type, a: *Expr) {
    if want == null || a == null || a.kind != EX_NULL {
        return;
    }
    if want.kind != TY_BORROW && want.kind != TY_BORROW_MUT {
        return;
    }
    t.err_code_range(a.line, a.column, 4, "null-borrow", "borrow `".concat(type_to_string(want)).concat("` cannot be null; pass a reference to a live value"));
}

// Primitive names whose borrows codegen auto-derefs on every bare read
// (mirrors codegen's `is_stdlib_primitive`): the int family, floats, bool,
// char, string. Struct borrows keep their pointer repr and are unaffected.
fn _is_prim_name(n: string) -> bool {
    if n == null {
        return false;
    }
    if _is_int_prim_name(n) {
        return true;
    }
    return n.eq("f32") || n.eq("f64") || n.eq("bool") || n.eq("char") || n.eq("string");
}

// Forwarding a SCALAR borrow onward (`fn f(r: &i32) { rd(r); }`) emits
// invalid C today: codegen materializes a borrowed primitive by value on
// every bare read (the `(*r)` auto-deref), so the callee receives an `int`
// where it expects `int*` and cc ICEs. Struct borrows forward fine — their
// repr stays a pointer. Until the lowering is context-sensitive on the
// expected parameter type (wave 2), reject the forward with a real
// diagnostic instead of the cc failure.
fn _check_scalar_borrow_forward(t: *Typer, want: *Type, a: *Expr) {
    if want == null || a == null || a.kind != EX_IDENT {
        return;
    }
    if want.kind != TY_BORROW && want.kind != TY_BORROW_MUT && want.kind != TY_POINTER {
        return;
    }
    if !t.scope.contains(a.str_val) {
        return;
    }
    let bt: Type = t.scope.get(a.str_val);
    if bt.kind != TY_BORROW && bt.kind != TY_BORROW_MUT {
        return;
    }
    if bt.inner == null || bt.inner.kind != TY_NAMED || !_is_prim_name(bt.inner.name) {
        return;
    }
    t.err_code_range(a.line, a.column, a.str_val.len(), "scalar-borrow-forward", "cannot forward the scalar borrow `".concat(a.str_val).concat("` (`").concat(type_to_string(&bt)).concat("`) into another call — scalar borrows are read by value and cannot re-materialize as a reference yet; pass the owner's `&x` directly, or take `").concat(type_to_string(bt.inner)).concat("` by value"));
}

// `extern type Foo;` is opaque — Glide never knows its size — so it can only
// live behind a pointer. Flags a bare `Foo` at the TOP level of a declared
// type (`let x: Foo`, `fn f(h: Foo) -> Foo`, a `Foo` field); `*Foo` is fine.
// Without this the by-value use sailed through to cc as an incomplete type.
fn _check_no_bare_extern_type(t: *Typer, ty: *Type, line: i32, col: i32) {
    if ty == null || ty.kind != TY_NAMED || ty.name == null {
        return;
    }
    if !t.extern_types.contains(ty.name) {
        return;
    }
    let mut pl: i32 = line;
    let mut pc: i32 = col;
    if ty.line > 0 {
        pl = ty.line;
        pc = ty.col;
    }
    t.err_code_range(pl, pc, ty.name.len(), "opaque-extern-type", "`".concat(ty.name).concat("` is an opaque `extern type` with no known size; use it behind a pointer (`*").concat(ty.name).concat("`)"));
}

impl Typer {
    pub fn new() -> *Typer {
        let t: *Typer = __glide_palloc(sizeof(Typer)) as *Typer;
        let fns: *HashMap<FnSig> = HashMap::new();
        let structs: *HashMap<bool> = HashMap::new();
        let method_names: *HashMap<bool> = HashMap::new();
        let struct_fields_all: *HashMap<bool> = HashMap::new();
        let scope: *HashMap<Type> = HashMap::new();
        let mscope: *HashMap<Type> = HashMap::new();
        let owned: *HashMap<bool> = HashMap::new();
        let ar_locals: *HashMap<bool> = HashMap::new();
        let ar_origin: *HashMap<string> = HashMap::new();
        let consumed: *HashMap<bool> = HashMap::new();
        let bw: *Vector<BorrowEvent> = Vector::new();
        let dg: *Vector<DiagEntry> = Vector::new();
        t.fns = fns;
        t.structs = structs;
        t.method_names = method_names;
        t.struct_fields_all = struct_fields_all;
        t.struct_field_types = HashMap::new();
        t.struct_generic = HashMap::new();
        t.extern_types = HashMap::new();
        t.scope = scope;
        t.module_scope = mscope;
        t.freestanding = false;
        t.owned_locals = owned;
        t.arena_locals = ar_locals;
        t.arena_origin = ar_origin;
        t.consumed_locals = consumed;
        t.mut_locals = HashMap::new();
        t.mut_decl_pos = HashMap::new();
        t.const_bindings = HashMap::new();
        t.module_consts = HashMap::new();
        t.moved_out = HashMap::new();
        t.call_owned = HashMap::new();
        t.borrows = bw;
        t.diagnostics = dg;
        let rel: *Vector<DiagRelated> = Vector::new();
        t.related = rel;
        t.current_ret = null;
        t.cur_fn_body = null;
        t.esc_alias_depth = 0;
        t.current_type_params = null;
        t.impl_type_params = null;
        t.current_origin = "";
        t.user_origin = "";
        t.entry_origin = "";
        let vis: *HashMap<bool> = HashMap::new();
        t.visibility = vis;
        let mi: *HashMap<bool> = HashMap::new();
        t.module_imports = mi;
        let mfp: *HashMap<bool> = HashMap::new();
        t.module_full_paths = mfp;
        let fp: *HashMap<bool> = HashMap::new();
        t.field_pub = fp;
        let shp: *HashMap<bool> = HashMap::new();
        t.struct_has_private = shp;
        let so: *HashMap<string> = HashMap::new();
        t.struct_origin = so;
        let df: *HashMap<bool> = HashMap::new();
        t.dup_flagged = df;
        t.addr_ctx = 0;
        t.enforce_visibility = false;
        let is: *HashMap<bool> = HashMap::new();
        t.impl_set = is;
        let at: *HashMap<Type> = HashMap::new();
        t.assoc_table = at;
        let en: *HashMap<string> = HashMap::new();
        t.enums = en;
        t.in_impl_method = false;
        let ena: *HashMap<i32> = HashMap::new();
        t.enum_arities = ena;
        let enp: *HashMap<Type> = HashMap::new();
        t.enum_payload_tys = enp;
        t.error_count = 0;
        let fh: *Vector<FnptrHint> = Vector::new();
        t.fnptr_hints = fh;
        t.pod_cache = HashMap::new();
        t.struct_tp_bounds = HashMap::new();
        t.decl_private = HashMap::new();
        t.const_origin = HashMap::new();
        t.mod_type_uses = HashMap::new();
        t.loop_depth = 0;
        t.fnexpr_outer_scope = null;
        return t;
    }

    fn is_visible(self: *Typer, name: string) -> bool {
        if !self.enforce_visibility {
            return true;
        }
        // Visibility is an entry-file concern: an imported file's own scope was
        // validated when it was authored/checked, and the per-file map can't
        // judge its transitive imports without false positives. So trust any
        // file that isn't the entry.
        if self.entry_origin != null && !self.entry_origin.eq("") && self.current_origin != null && !self.current_origin.eq(self.entry_origin) {
            return true;
        }
        if self.current_origin == null || self.current_origin.eq("") {
            return true;
        }
        if name == null || name.eq("") {
            return true;
        }
        let key: string = self.current_origin.concat("::").concat(name);
        return self.visibility.contains(key);
    }

    // True if `prefix` (the str_val of an EX_PATH) names a module the
    // current file is allowed to call into. Either the prefix matches
    // some loaded file's full module path (always allowed) OR the file
    // brought it into scope via `import x::y::<prefix>;`.
    fn is_module_path_allowed(self: *Typer, prefix: string) -> bool {
        if !self.enforce_visibility {
            return true;
        }
        if prefix == null || prefix.eq("") {
            return true;
        }
        if self.module_full_paths.contains(prefix) {
            return true;
        }
        // Same entry-file scoping as is_visible: trust imported files' own
        // module qualifiers (validated when they are the entry).
        if self.entry_origin != null && !self.entry_origin.eq("") && self.current_origin != null && !self.current_origin.eq(self.entry_origin) {
            return true;
        }
        if self.current_origin == null || self.current_origin.eq("") {
            return true;
        }
        let key: string = self.current_origin.concat("::").concat(prefix);
        return self.module_imports.contains(key);
    }

    // True when `name` is a module the current file imported (the short
    // alias from `import a::b::name;`) or a full module path. Independent of
    // `enforce_visibility`, unlike is_module_path_allowed.
    // How many leading segments of `qual` form a module path that
    // suffix-matches some imported module (e.g. `http::client` against the
    // import `stdlib::http::client` -> 2). 0 when none do.
    fn _module_suffix_segs(self: *Typer, qual: string) -> i32 {
        let mut best: i32 = 0;
        let mut end: i32 = qual.index_of("::");
        let mut segs: i32 = 1;
        while end >= 0 {
            let cand: string = qual.substring(0, end);
            if self.module_full_paths.contains(cand) {
                best = segs;
            } else {
                let keys: *Vector<string> = self.module_full_paths.keys();
                for let i: i32 = 0; i < keys.len(); i++ {
                    if keys.get(i).ends_with("::".concat(cand)) {
                        best = segs;
                        break;
                    }
                }
                keys.free();
            }
            let nx: i32 = qual.substring(end + 2, qual.len()).index_of("::");
            if nx < 0 {
                break;
            }
            end = end + 2 + nx;
            segs = segs + 1;
        }
        // A single leading segment is the plain case handled by
        // _is_imported_module; only multi-segment runs are interesting here.
        if best < 2 {
            return 0;
        }
        return best;
    }

    fn _is_imported_module(self: *Typer, name: string) -> bool {
        if name == null || name.eq("") {
            return false;
        }
        if self.module_full_paths.contains(name) {
            return true;
        }
        if self.current_origin == null || self.current_origin.eq("") {
            return false;
        }
        return self.module_imports.contains(self.current_origin.concat("::").concat(name));
    }

    // Record every `::`-separated segment of a module qualifier that a type
    // annotation spent (`lib2::Hidden2` -> segment `lib2`). The unused-import
    // lint runs AFTER _canon_type collapsed the annotation to its bare leaf,
    // so without this the only textual use of the module vanishes and the
    // lint tells the user to delete a load-bearing import.
    fn _record_mod_qualifier(self: *Typer, qual: string) {
        if qual == null || qual.eq("") {
            return;
        }
        let mut start: i32 = 0;
        let n: i32 = qual.len();
        while start < n {
            let rest: string = qual.substring(start, n);
            let cc: i32 = rest.index_of("::");
            let mut seg: string = rest;
            if cc >= 0 {
                seg = rest.substring(0, cc);
            }
            if !seg.eq("") {
                self.mod_type_uses.insert(seg, true);
            }
            if cc < 0 {
                break;
            }
            start = start + cc + 2;
        }
    }

    // Strip a leading imported-module segment from a qualified prefix, so
    // `ip::SocketAddr` (module `ip` + type) resolves as the bare `SocketAddr`
    // via the normal type/method registry. Leaves non-module prefixes (a
    // bare `Type`, a type param) untouched.
    fn _strip_mod_prefix(self: *Typer, prefix: string) -> string {
        if prefix == null {
            return prefix;
        }
        let cc: i32 = prefix.index_of("::");
        if cc < 0 {
            return prefix;
        }
        let head: string = prefix.substring(0, cc);
        if !self._is_imported_module(head) {
            // Multi-segment module qualifier: `http::client::HttpClient` where
            // the import is `stdlib::http::client`. Accept the LONGEST leading
            // run of segments that suffix-matches an imported module path and
            // strip it whole, so file+folder packages can be referenced by
            // their long form.
            let mseg: i32 = self._module_suffix_segs(prefix);
            if mseg > 0 {
                let mut cut: i32 = 0;
                let mut left: i32 = mseg;
                while left > 0 {
                    let nx: i32 = prefix.substring(cut, prefix.len()).index_of("::");
                    if nx < 0 {
                        return prefix;
                    }
                    cut = cut + nx + 2;
                    left = left - 1;
                }
                return self._strip_mod_prefix(prefix.substring(cut, prefix.len()));
            }
            return prefix;
        }
        let rest: string = prefix.substring(cc + 2, prefix.len());
        return self._strip_mod_prefix(rest);
    }

    // Canonicalize a module-qualified type annotation to its bare global type,
    // in place. Glide types are not namespaced: `foo::Bar` (parsed as a
    // TY_ASSOC projection `Bar of foo`) names the SAME global struct as bare
    // `Bar`, but the parser keeps the module prefix, so type_eq and codegen
    // would treat them as distinct (and codegen lowers the stray TY_ASSOC to
    // `void`). Collapse `module::Bar` -> bare `Bar` while LEAVING a genuine
    // associated-type projection (`Self::Item`, `T::Item`, head not a module)
    // untouched. Recurses through pointer/borrow/option/result wrappers and
    // generic/tuple/fnptr element lists so `Vector<foo::Bar>`, `?foo::Bar`,
    // `(foo::A, foo::B)`, `fn(foo::A) -> foo::B` are all normalized.
    fn _canon_type(self: *Typer, ty: *Type) {
        if ty == null {
            return;
        }
        if ty.kind == TY_ASSOC {
            if ty.inner != null && ty.inner.kind == TY_NAMED && self._is_imported_module(ty.inner.name) {
                // The qualifier is about to be erased from the AST — record it
                // so the unused-import lint still sees `lib` of `lib::T` used.
                self._record_mod_qualifier(ty.inner.name);
                ty.kind = TY_NAMED;
                ty.inner = null;
                // The qualifier IS the explicit module reference — a
                // `time::Duration` annotation is in scope by construction
                // (Rust allows it with just `use time;`). Record the collapsed
                // bare name as visible so the type-in-scope gate doesn't flag
                // the normalized form.
                if self.current_origin != null && !self.current_origin.eq("") && ty.name != null {
                    self.visibility.insert(self.current_origin.concat("::").concat(ty.name), true);
                }
                return;
            }
            self._canon_type(ty.inner);
            return;
        }
        if ty.kind == TY_NAMED {
            if ty.name != null && ty.name.index_of("::") >= 0 {
                let _pre_strip: string = ty.name;
                ty.name = self._strip_mod_prefix(ty.name);
                // Record the stripped qualifier segments (everything before
                // the surviving leaf) for the unused-import lint.
                if ty.name != null && _pre_strip.len() > ty.name.len() {
                    self._record_mod_qualifier(_pre_strip.substring(0, _pre_strip.len() - ty.name.len()));
                }
                if self.current_origin != null && !self.current_origin.eq("") && ty.name != null && ty.name.index_of("::") < 0 {
                    self.visibility.insert(self.current_origin.concat("::").concat(ty.name), true);
                }
            }
            return;
        }
        if ty.inner != null {
            self._canon_type(ty.inner);
        }
        if ty.fnptr_ret != null {
            self._canon_type(ty.fnptr_ret);
        }
        if ty.args != null {
            for let i: i32 = 0; i < ty.args.len(); i++ {
                let a: Type = ty.args.get(i);
                self._canon_type(&a);
                ty.args.set(i, a);
            }
        }
    }

    // Canonicalize every type annotation on a fn signature (params + return).
    fn _canon_fn_sig(self: *Typer, s: *Stmt) {
        if s.fn_params != null {
            for let i: i32 = 0; i < s.fn_params.len(); i++ {
                let p: Param = s.fn_params.get(i);
                if p.ty != null {
                    self._canon_type(p.ty);
                }
            }
        }
        if s.fn_ret_ty != null {
            self._canon_type(s.fn_ret_ty);
        }
    }

    // Walk top-level decls and canonicalize qualified type annotations in the
    // AST before registration / checking / codegen all read them. Must run
    // with `current_origin` set per-stmt so `_is_imported_module` can resolve
    // origin-scoped imports.
    fn _canon_decls(self: *Typer, program: *Vector<Stmt>) {
        for let i: i32 = 0; i < program.len(); i++ {
            let s: Stmt = program.get(i);
            let saved: string = self.current_origin;
            self.current_origin = s.origin;
            if s.kind == ST_FN {
                self._canon_fn_sig(&s);
            } else {
                if s.kind == ST_STRUCT {
                    if s.struct_fields != null {
                        for let j: i32 = 0; j < s.struct_fields.len(); j++ {
                            let f: Field = s.struct_fields.get(j);
                            if f.ty != null {
                                self._canon_type(f.ty);
                            }
                        }
                    }
                } else {
                    if s.kind == ST_ENUM {
                        if s.enum_variants != null {
                            for let j: i32 = 0; j < s.enum_variants.len(); j++ {
                                let ev: EnumVariant = s.enum_variants.get(j);
                                if ev.fields != null {
                                    for let k: i32 = 0; k < ev.fields.len(); k++ {
                                        let a: Type = ev.fields.get(k);
                                        self._canon_type(&a);
                                        ev.fields.set(k, a);
                                    }
                                }
                            }
                        }
                    } else {
                        if s.kind == ST_IMPL {
                            if s.impl_target != null {
                                self._canon_type(s.impl_target);
                            }
                            if s.impl_methods != null {
                                for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                                    let m: Stmt = s.impl_methods.get(j);
                                    self._canon_fn_sig(&m);
                                }
                            }
                        }
                    }
                }
            }
            self.current_origin = saved;
        }
    }

    pub fn free(self: *Typer) {
        self.fns.free();
        self.structs.free();
        self.method_names.free();
        self.struct_fields_all.free();
        self.struct_field_types.free();
        self.struct_generic.free();
        self.extern_types.free();
        self.scope.free();
        self.module_scope.free();
        self.owned_locals.free();
        self.mut_locals.free();
        self.mut_decl_pos.free();
        self.const_bindings.free();
        self.module_consts.free();
        self.borrows.free();
        self.diagnostics.free();
        self.visibility.free();
        self.module_imports.free();
        self.module_full_paths.free();
        self.field_pub.free();
        self.struct_origin.free();
        self.dup_flagged.free();
        self.impl_set.free();
        self.enums.free();
        self.pod_cache.free();
        self.struct_tp_bounds.free();
        self.decl_private.free();
        self.const_origin.free();
        self.mod_type_uses.free();
        __glide_pfree(self as *void);
    }

    fn push_diag_tag(self: *Typer, line: i32, col: i32, severity: i32, code: string, msg: string, tag: i32) {
        // Synth-position diagnostics (proc-macro outputs, builtin
        // surrogates) anchor at line 0 and render at line 1 in the
        // editor — useless to the user, since they can't fix the
        // generated code. Drop them at the source.
        if line <= 0 {
            return;
        }
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + 1, severity: severity, code: code, message: msg, origin: origin, tag: tag, fix_line: 0, fix_col: 0, fix_end_line: 0, fix_end_col: 0, fix_replacement: "" };
        self.diagnostics.push(e);
    }

    fn push_diag(self: *Typer, line: i32, col: i32, severity: i32, code: string, msg: string) {
        self.push_diag_tag(line, col, severity, code, msg, 0);
    }

    // Attach a "this is why" location to the most recently pushed diagnostic.
    // No-op when no diagnostic has been emitted yet. Surfaced by the LSP as
    // relatedInformation; the CLI ignores it.
    fn relate_last(self: *Typer, origin: string, line: i32, col: i32, end_line: i32, end_col: i32, message: string) {
        if self.diagnostics.len() == 0 {
            return;
        }
        let mut o: string = origin;
        if o == null {
            o = "";
        }
        let r: DiagRelated = DiagRelated { diag_index: self.diagnostics.len() - 1, origin: o, line: line, col: col, end_line: end_line, end_col: end_col, message: message };
        self.related.push(r);
    }

    fn warn_unused(self: *Typer, line: i32, col: i32, code: string, msg: string) {
        self.push_diag_tag(line, col, 2, code, msg, 1); // tag 1 = Unnecessary
    }

    // Same as warn_unused but with explicit end-column so the editor's
    // fade / strikethrough effect spans the whole identifier instead of a
    // single character. Pass the position of the name and its length.
    fn warn_unused_range(self: *Typer, line: i32, col: i32, len: i32, code: string, msg: string) {
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let mut e_len: i32 = len;
        if e_len < 1 {
            e_len = 1;
        }
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + e_len, severity: 2, code: code, message: msg, origin: origin, tag: 1, fix_line: 0, fix_col: 0, fix_end_line: 0, fix_end_col: 0, fix_replacement: "" };
        self.diagnostics.push(e);
    }

    // Emit a warning with an attached mechanical fix. `glide fix`
    // reads the (fix_line, fix_col)..(fix_end_line, fix_end_col)
    // range and replaces it with `replacement`. Pass a zero-width
    // range to insert; an empty replacement to delete.
    fn warn_with_fix(self: *Typer, line: i32, col: i32, end_len: i32, code: string, msg: string, fl: i32, fc: i32, fel: i32, fec: i32, repl: string) {
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let mut e_len: i32 = end_len;
        if e_len < 1 {
            e_len = 1;
        }
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + e_len, severity: 2, code: code, message: msg, origin: origin, tag: 1, fix_line: fl, fix_col: fc, fix_end_line: fel, fix_end_col: fec, fix_replacement: repl };
        self.diagnostics.push(e);
    }

    fn err(self: *Typer, line: i32, col: i32, msg: string) {
        self.push_diag(line, col, 1, "", msg);
        self.error_count = self.error_count + 1;
    }

    fn err_code(self: *Typer, line: i32, col: i32, code: string, msg: string) {
        self.push_diag(line, col, 1, code, msg);
        self.error_count = self.error_count + 1;
    }

    fn err_code_range(self: *Typer, line: i32, col: i32, span: i32, code: string, msg: string) {
        let mut e_len: i32 = span;
        if e_len < 1 {
            e_len = 1;
        }
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + e_len, severity: 1, code: code, message: msg, origin: origin, tag: 0, fix_line: 0, fix_col: 0, fix_end_line: 0, fix_end_col: 0, fix_replacement: "" };
        self.diagnostics.push(e);
        self.error_count = self.error_count + 1;
    }

    // Error (severity 1) carrying a mechanical fix the LSP turns into a
    // quick fix: splice `repl` over the range (fl,fc)..(fel,fec) (1-indexed).
    fn err_code_range_fix(self: *Typer, line: i32, col: i32, span: i32, code: string, msg: string, fl: i32, fc: i32, fel: i32, fec: i32, repl: string) {
        let mut e_len: i32 = span;
        if e_len < 1 {
            e_len = 1;
        }
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + e_len, severity: 1, code: code, message: msg, origin: origin, tag: 0, fix_line: fl, fix_col: fc, fix_end_line: fel, fix_end_col: fec, fix_replacement: repl };
        self.diagnostics.push(e);
        self.error_count = self.error_count + 1;
    }

    fn warn(self: *Typer, line: i32, col: i32, code: string, msg: string) {
        self.push_diag(line, col, 2, code, msg);
    }

    // Warning (severity 2) underlining a `span`-wide range instead of a
    // single char, so the squiggle covers the whole offending expression
    // (e.g. `r.val`) rather than just its first character.
    fn warn_range(self: *Typer, line: i32, col: i32, span: i32, code: string, msg: string) {
        let mut e_len: i32 = span;
        if e_len < 1 {
            e_len = 1;
        }
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + e_len, severity: 2, code: code, message: msg, origin: origin, tag: 0, fix_line: 0, fix_col: 0, fix_end_line: 0, fix_end_col: 0, fix_replacement: "" };
        self.diagnostics.push(e);
    }
}

// ---- pre-register --------------------------------------------------------
// True when `fn_stmt` returns one of its own struct-literal auto-drop locals
// directly (`let t: *T = T{..}; ...; return t;`) - it hands an owned value to
// its caller. Mirrors the codegen's _returns_auto_owned_local so the typer can
// treat `let x = make()` as owned for use-after-move.
fn _fn_returns_owned(fn_stmt: *Stmt) -> bool {
    if fn_stmt == null || fn_stmt.fn_body == null {
        return false;
    }
    let body: *Vector<Stmt> = fn_stmt.fn_body;
    let owned: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < body.len(); i = i + 1 {
        let st: Stmt = body.get(i);
        if st.kind == ST_LET && st.is_auto_owned {
            owned.insert(st.name, true);
        }
        if st.kind == ST_LET && st.let_ty != null && st.let_ty.kind == TY_POINTER && st.let_value != null && st.let_value.kind == EX_STRUCT_LIT && st.let_ty.inner != null && st.let_ty.inner.kind == TY_NAMED && st.let_ty.inner.name.eq(st.let_value.str_val) {
            owned.insert(st.name, true);
        }
    }
    let mut hit: bool = false;
    for let i: i32 = 0; i < body.len(); i = i + 1 {
        let st: Stmt = body.get(i);
        if st.kind == ST_RETURN && st.expr_value != null && st.expr_value.kind == EX_IDENT && owned.contains(st.expr_value.str_val) {
            hit = true;
        }
    }
    owned.free();
    return hit;
}

// True when the call `e` targets a fn whose FnSig is owned_return. `let_ty` (the
// binding's type) supplies the receiver type for a method key `<T>_<method>`.
fn _call_owned_return(t: *Typer, call: *Expr, let_ty: *Type) -> bool {
    if call == null || call.lhs == null {
        return false;
    }
    let callee: *Expr = call.lhs;
    let mut key: string = "";
    if callee.kind == EX_IDENT {
        key = callee.str_val;
    } else if callee.field != null && !callee.field.eq("") && let_ty != null && let_ty.kind == TY_POINTER && let_ty.inner != null && let_ty.inner.kind == TY_NAMED {
        key = let_ty.inner.name.concat("_").concat(callee.field);
    }
    if key.eq("") || !t.fns.contains(key) {
        return false;
    }
    let sig: FnSig = t.fns.get(key);
    return sig.owned_return;
}

// Second-class borrows: a borrow may appear ONLY as a top-level parameter
// type (flow-down). Nested anywhere a value can be stored or produced —
// generic args (`Vector<&T>`, `chan<&T>`), tuples, `*&T`, `!&T`, `?&T`, or a
// fn-pointer's return — it could outlive its owner, so it's rejected.
// `allow_top` is true only where a bare `&T` is itself legal (params, let
// annotations); recursion always clears it. Deliberately NOT part of
// _check_type_known: that one early-returns without enforce_visibility,
// which would silently disable a safety rule.
fn _reject_nested_borrow(t: *Typer, ty: *Type, line: i32, col: i32, allow_top: bool) {
    if ty == null {
        return;
    }
    if ty.kind == TY_BORROW || ty.kind == TY_BORROW_MUT {
        if !allow_top {
            t.err_code(line, col, "borrow-in-generic", "borrow `".concat(type_to_string(ty)).concat("` not allowed here — borrows cannot be stored or wrapped; use `*T`"));
        }
        _reject_nested_borrow(t, ty.inner, line, col, false);
        return;
    }
    if ty.kind == TY_POINTER || ty.kind == TY_SLICE || ty.kind == TY_RESULT || ty.kind == TY_OPTION || ty.kind == TY_OPT_RESULT {
        _reject_nested_borrow(t, ty.inner, line, col, false);
        return;
    }
    if ty.kind == TY_GENERIC || ty.kind == TY_TUPLE {
        if ty.args != null {
            for let i: i32 = 0; i < ty.args.len(); i++ {
                let a: Type = ty.args.get(i);
                _reject_nested_borrow(t, &a, line, col, false);
            }
        }
        return;
    }
    if ty.kind == TY_FNPTR {
        // A callback may RECEIVE borrows (flow-down at its call time), but a
        // fn pointer that YIELDS a borrow is out-flow.
        if ty.args != null {
            for let i: i32 = 0; i < ty.args.len(); i++ {
                let a: Type = ty.args.get(i);
                _reject_nested_borrow(t, &a, line, col, true);
            }
        }
        _reject_nested_borrow(t, ty.fnptr_ret, line, col, false);
        return;
    }
}

// A fn/method signature may take borrows but never return one: borrows flow
// into calls, never out. Also walks each param for nested-borrow violations.
fn _ban_borrow_signature(t: *Typer, m: *Stmt) {
    if m == null {
        return;
    }
    let mut nl: i32 = m.name_line;
    let mut nc: i32 = m.name_col;
    if nl == 0 {
        nl = m.line;
        nc = m.column;
    }
    if m.fn_ret_ty != null && (m.fn_ret_ty.kind == TY_BORROW || m.fn_ret_ty.kind == TY_BORROW_MUT || m.fn_ret_ty.kind == TY_SLICE) {
        t.err_code(nl, nc, "borrow-return-type", "cannot return a borrow `".concat(type_to_string(m.fn_ret_ty)).concat("` — borrows and slices flow into calls, never out; return `*T` or a value"));
    } else {
        _reject_nested_borrow(t, m.fn_ret_ty, nl, nc, false);
    }
    if m.fn_params != null {
        for let i: i32 = 0; i < m.fn_params.len(); i++ {
            let p: Param = m.fn_params.get(i);
            _reject_nested_borrow(t, p.ty, nl, nc, true);
        }
    }
}

pub fn pre_register(t: *Typer, program: *Vector<Stmt>) {
    // C-runtime types that aren't declared in any Glide source file but
    // user code expects to call as `Arena::new(...)`, etc. Hardcoded for
    // now; replace with proper `extern type` declarations later.
    t.structs.insert("Arena", true);
    // Arena's runtime methods (defined in runtime/stdlib.c, not Glide) so the
    // method-existence check treats `arena.alloc(...)` / `.used()` / `.reset()`
    // as known rather than flagging them like a typo. `free` is special-cased
    // separately; `new` is a static (`Arena::new`).
    t.method_names.insert("Arena::alloc", true);
    t.method_names.insert("Arena::used", true);
    t.method_names.insert("Arena::reset", true);
    t.method_names.insert("Arena::free", true);
    // Same-file duplicate top-level definitions. Functions, structs, enums
    // and traits share ONE namespace here: `struct Alelo` + `enum Alelo` (or
    // `trait Alelo`, or `fn Alelo` — whose C lowering collides with the
    // struct's typedef and died as an ICE) silently last-wins'd in the
    // registries, surfacing only as confusing downstream symptoms. Track each
    // name's defining file + kind and error at the SECOND definition. Same
    // names across DIFFERENT files stay legal.
    let dup_names: *HashMap<string> = HashMap::new();
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        // `extern fn` is a DECLARATION (redeclaring one is harmless, as in C —
        // and the loader injects some runtime externs more than once), so only
        // definitions participate in the duplicate check.
        if s.name != null && s.origin != null && (s.kind == ST_FN && !s.is_extern || s.kind == ST_STRUCT || s.kind == ST_ENUM || s.kind == ST_TRAIT) {
            let mut what: string = "struct";
            if s.kind == ST_FN {
                what = "function";
            }
            if s.kind == ST_ENUM {
                what = "enum";
            }
            if s.kind == ST_TRAIT {
                what = "trait";
            }
            // Stored as `origin#kind#cfg` so complementary `@cfg`-guarded
            // functions (`@cfg("posix") fn plat` + `@cfg("windows") fn plat`
            // in one file) are NOT flagged: only one #if arm is ever active,
            // so there is no real collision (codegen's stub-suppression keeps
            // the C side single-defined too). Any other same-name pair collides.
            let mut cur_cfg: string = "";
            if s.cfg_target != null {
                cur_cfg = s.cfg_target;
            }
            if dup_names.contains(s.name) {
                let prev: string = dup_names.get(s.name);
                if prev.starts_with(s.origin.concat("#")) {
                    let rest: string = prev.substring(s.origin.len() + 1, prev.len());
                    let hpos: i32 = rest.index_of("#");
                    let mut prev_kind: string = rest;
                    let mut prev_cfg: string = "";
                    if hpos >= 0 {
                        prev_kind = rest.substring(0, hpos);
                        prev_cfg = rest.substring(hpos + 1, rest.len());
                    }
                    // Exempt a pair of functions each carrying a distinct,
                    // non-empty @cfg target — the platform guards are disjoint.
                    let cfg_disjoint: bool = what.eq("function") && prev_kind.eq("function") && !cur_cfg.eq("") && !prev_cfg.eq("") && !cur_cfg.eq(prev_cfg);
                    if !cfg_disjoint {
                        let mut msg: string = "the ".concat(what).concat(" `").concat(s.name).concat("` is defined more than once in this file");
                        if !prev_kind.eq(what) {
                            msg = "`".concat(s.name).concat("` is already defined in this file as a ").concat(prev_kind).concat("; a ").concat(what).concat(" cannot share the name");
                        }
                        t.err_code_range(s.name_line, s.name_col, s.name.len(), "duplicate-definition", msg);
                        // Suppress the unused-* lint for the whole conflicting set.
                        t.dup_flagged.insert(s.name, true);
                    }
                }
            } else {
                dup_names.insert(s.name, s.origin.concat("#").concat(what).concat("#").concat(cur_cfg));
            }
        }
        if s.kind == ST_CONST {
            // Registered even when the type can't be inferred: const-ness is
            // what the write check keys on, not the type.
            t.module_consts.insert(s.name, true);
            // Declaring file, so qualified `mod::CONST` access can allow
            // same-file uses and privacy-check the rest.
            if s.origin != null && !s.origin.eq("") {
                t.const_origin.insert(s.name, s.origin);
            }
            // Top-level const: type from annotation if any, otherwise infer
            // from the literal value (covers `const X: int = 1;` and friends).
            let mut ty: *Type = s.let_ty;
            if ty == null && s.let_value != null {
                if s.let_value.kind == EX_INT {
                    if s.let_value.int_val > 2147483647 || s.let_value.int_val < -2147483648 {
                        ty = ty_named("i64");
                    } else {
                        ty = ty_named("i32");
                    }
                } else {
                    if s.let_value.kind == EX_FLOAT {
                        ty = ty_named("f64");
                    } else {
                        if s.let_value.kind == EX_STRING {
                            ty = ty_named("string");
                        } else {
                            if s.let_value.kind == EX_BOOL {
                                ty = ty_named("bool");
                            } else {
                                if s.let_value.kind == EX_CHAR {
                                    ty = ty_named("char");
                                }
                            }
                        }
                    }
                }
            }
            if ty != null {
                t.module_scope.insert(s.name, *ty);
            }
        }
        if s.kind == ST_LET && t.freestanding {
            // Top-level `let` in a freestanding/kernel build is a mutable
            // global, visible inside any fn body (same as a const). Type from
            // the annotation, else inferred from the literal value.
            let mut lty: *Type = s.let_ty;
            if lty == null && s.let_value != null {
                if s.let_value.kind == EX_INT {
                    if s.let_value.int_val > 2147483647 || s.let_value.int_val < -2147483648 {
                        lty = ty_named("i64");
                    } else {
                        lty = ty_named("i32");
                    }
                } else {
                    if s.let_value.kind == EX_FLOAT {
                        lty = ty_named("f64");
                    } else {
                        if s.let_value.kind == EX_STRING {
                            lty = ty_named("string");
                        } else {
                            if s.let_value.kind == EX_BOOL {
                                lty = ty_named("bool");
                            } else {
                                if s.let_value.kind == EX_CHAR {
                                    lty = ty_named("char");
                                } else {
                                    if s.let_value.kind == EX_STRUCT_LIT {
                                        lty = ty_named(s.let_value.str_val);
                                    }
                                }
                            }
                        }
                    }
                }
            }
            if lty != null {
                t.module_scope.insert(s.name, *lty);
            }
        }
        if s.kind == ST_FN {
            let no_owner: *Vector<string> = null;
            let sig: FnSig = FnSig { name: s.name, params: s.fn_params, ret_type: s.fn_ret_ty, owned_return: _fn_returns_owned(&s), is_variadic: s.is_variadic, type_params: s.type_params, type_param_bounds: s.type_param_bounds, owner_type_params: no_owner, owner_type_param_bounds: no_owner, decl_origin: s.origin, decl_line: s.name_line, decl_col: s.name_col };
            t.fns.insert(s.name, sig);
            if !s.is_extern {
                _ban_borrow_signature(t, &s);
            }
        }
        // Trait method DECLARATIONS carry signatures too — ban borrow
        // returns there so an impl can't inherit an un-declarable shape.
        if s.kind == ST_TRAIT && s.impl_methods != null {
            for let tj: i32 = 0; tj < s.impl_methods.len(); tj++ {
                let tm: Stmt = s.impl_methods.get(tj);
                if tm.kind == ST_FN {
                    _ban_borrow_signature(t, &tm);
                }
            }
        }
        if s.kind == ST_ENUM {
            // Enums share the type-name registry with structs so EX_PATH
            // enforcement can tell `MyEnum::Variant` apart from a free
            // module call.
            t.structs.insert(s.name, true);
            // Record the variant list for exhaustiveness checking.
            let mut vlist: string = "";
            if s.enum_variants != null {
                for let j: i32 = 0; j < s.enum_variants.len(); j++ {
                    let ev: EnumVariant = s.enum_variants.get(j);
                    if j > 0 {
                        vlist = vlist.concat(",");
                    }
                    vlist = vlist.concat(ev.name);
                    let mut _ar: i32 = 0;
                    if ev.fields != null {
                        _ar = ev.fields.len();
                        for let fk: i32 = 0; fk < ev.fields.len(); fk++ {
                            t.enum_payload_tys.insert(s.name.concat("::").concat(ev.name).concat("#").concat(int_to_str(fk)), ev.fields.get(fk));
                        }
                    }
                    t.enum_arities.insert(s.name.concat("::").concat(ev.name), _ar);
                }
            }
            t.enums.insert(s.name, vlist);
        }
        if s.kind == ST_STRUCT {
            t.structs.insert(s.name, true);
            // Opaque `extern type Foo;` (parsed as a fieldless extern struct):
            // remember it so by-value uses / literals can be rejected.
            if s.is_extern {
                t.extern_types.insert(s.name, true);
            }
            // Generic structs (`struct Box<T>`) have field types that may name a
            // type param, so their literal field-value checking is skipped.
            if s.type_params != null && s.type_params.len() > 0 {
                t.struct_generic.insert(s.name, true);
                // Record per-param bounds (`struct S<T: Ord>`) so annotation
                // sites (`let x: S<Plain>`) can enforce them; parsed-and-
                // dropped bounds were a silent lie.
                if s.type_param_bounds != null {
                    for let bi: i32 = 0; bi < s.type_param_bounds.len(); bi++ {
                        let bs: string = s.type_param_bounds.get(bi);
                        if bs != null && !bs.eq("") {
                            t.struct_tp_bounds.insert(s.name.concat("#").concat(int_to_str(bi)), bs);
                        }
                    }
                }
            }
            // Borrow rule: reject `&T` / `&mut T` in struct fields. They would
            // require lifetimes to be sound; Glide's design picks `*T` instead.
            if s.struct_fields != null {
                for let j: i32 = 0; j < s.struct_fields.len(); j++ {
                    let f: Field = s.struct_fields.get(j);
                    t.struct_fields_all.insert(s.name.concat("::").concat(f.name), true);
                    if f.ty != null {
                        t.struct_field_types.insert(s.name.concat("::").concat(f.name), *f.ty);
                    }
                    if f.ty != null && (f.ty.kind == TY_BORROW || f.ty.kind == TY_BORROW_MUT || f.ty.kind == TY_SLICE) {
                        t.err_code(s.line, s.column, "borrow-in-field", "borrow/slice `".concat(type_to_string(f.ty)).concat("` not allowed in struct field `").concat(f.name).concat("` (use `*T` instead)"));
                    } else {
                        // Nested borrow (`Vector<&T>` field, `!&T`, …) is the
                        // same store-a-borrow hole one level down.
                        _reject_nested_borrow(t, f.ty, s.line, s.column, false);
                    }
                    // A by-value field of an opaque `extern type` has no size.
                    _check_no_bare_extern_type(t, f.ty, s.line, s.column);
                }
            }
        }
        // Register impl methods so `Type::method(args)` callers can lookup
        // their return type via the same `t.fns` path. Stored under
        // `Type_method` matching the codegen's mangling. Generic params on
        // the impl/method stay un-substituted (T as TY_NAMED("T")) — good
        // enough for arity / pointer-vs-value mismatch diagnostics.
        if s.kind == ST_IMPL && s.impl_target != null && s.impl_methods != null {
            let mut tname: string = "";
            if s.impl_target.kind == TY_NAMED {
                tname = s.impl_target.name;
            }
            if s.impl_target.kind == TY_GENERIC {
                tname = s.impl_target.name;
            }
            if !tname.eq("") {
                // A generic struct must be impl'd WITH its type params — a
                // bare `impl LinkedList { fn new<T>(..) -> Self }` leaves
                // `Self`/`T` unresolved in the registered signatures and used
                // to die at cc as a please-report ICE. Point at the target.
                if t.struct_generic.contains(tname)
                    && (s.type_params == null || s.type_params.len() == 0)
                    && (s.impl_target.args == null || s.impl_target.args.len() == 0) {
                    let mut il: i32 = s.impl_target.line;
                    let mut ic: i32 = s.impl_target.col;
                    if il == 0 {
                        il = s.line;
                        ic = s.column;
                    }
                    t.err_code_range(il, ic, tname.len(), "impl-missing-type-params", "struct `".concat(tname).concat("` is generic; impl it with its type parameters — `impl<T> ").concat(tname).concat("<T>` — or specialize it (`impl ").concat(tname).concat("<i32>`)"));
                }
                // Specialized impls on concrete arg types (`impl Vector<int>`)
                // register under a fully-qualified key — `Vector<int>_max` —
                // so they don't collide with sibling specializations or the
                // generic `impl<T> Vector<T>` entry. Lookup tries the
                // specialized key first, falls back to the bare name.
                let mut is_specialized: bool = false;
                if s.impl_target.kind == TY_GENERIC && s.impl_target.args != null && s.impl_target.args.len() > 0 && (s.type_params == null || s.type_params.len() == 0) {
                    is_specialized = true;
                }
                let key_prefix: string = if is_specialized { type_to_string(s.impl_target) } else { tname };
                for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                    let m: Stmt = s.impl_methods.get(j);
                    if m.kind == ST_FN {
                        _ban_borrow_signature(t, &m);
                        // A method re-declaring one of the impl's own type
                        // params (`impl<T> X<T> { fn insert<T>(..) }`) is a
                        // shadow: monomorphization combines them into [T, T]
                        // and dies downstream. Reject at the method name.
                        if m.type_params != null && s.type_params != null {
                            for let ti: i32 = 0; ti < m.type_params.len(); ti++ {
                                let tp: string = m.type_params.get(ti);
                                for let tj: i32 = 0; tj < s.type_params.len(); tj++ {
                                    if s.type_params.get(tj).eq(tp) {
                                        t.err_code_range(m.name_line, m.name_col, m.name.len(), "type-param-shadow", "method `".concat(m.name).concat("` re-declares type parameter `").concat(tp).concat("`, which is already in scope from the enclosing `impl<").concat(tp).concat(">` — drop `<").concat(tp).concat(">` from the method"));
                                    }
                                }
                            }
                        }
                        let fname: string = key_prefix.concat("_").concat(m.name);
                        let sig: FnSig = FnSig { name: fname, params: m.fn_params, ret_type: m.fn_ret_ty, owned_return: _fn_returns_owned(&m), is_variadic: m.is_variadic, type_params: m.type_params, type_param_bounds: m.type_param_bounds, owner_type_params: s.type_params, owner_type_param_bounds: s.type_param_bounds, decl_origin: s.origin, decl_line: m.name_line, decl_col: m.name_col };
                        t.fns.insert(fname, sig);
                        // Record under the BASE type name (not the
                        // specialized key) so "no method" detection knows
                        // the method exists on some variant of the type.
                        t.method_names.insert(tname.concat("::").concat(m.name), true);
                    }
                }
            }
        }
    }
    // Build impl_set: `<trait>::<type>` → true for every concrete impl in
    // the program. Generic-bounded calls consult this to decide whether
    // the inferred concrete type satisfies a `T: Trait` clause.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_IMPL {
            continue;
        }
        if s.impl_trait_name == null || s.impl_trait_name.eq("") {
            continue;
        }
        if s.impl_target == null {
            continue;
        }
        let mut tname: string = "";
        if s.impl_target.kind == TY_NAMED {
            tname = s.impl_target.name;
        }
        if s.impl_target.kind == TY_GENERIC {
            tname = s.impl_target.name;
        }
        if tname.eq("") {
            continue;
        }
        t.impl_set.insert(s.impl_trait_name.concat("::").concat(tname), true);
        // Every method in a trait impl must be a member of the trait (Rust
        // E0407). An extra method also broke the C vtable initializer — the
        // `.name = thunk` field doesn't exist on the trait's vt struct — and
        // died in cc as an ICE.
        let tdcl: *Stmt = find_top_decl(program, s.impl_trait_name);
        if tdcl != null && tdcl.kind == ST_TRAIT && tdcl.impl_methods != null && s.impl_methods != null {
            for let mi: i32 = 0; mi < s.impl_methods.len(); mi++ {
                let im: Stmt = s.impl_methods.get(mi);
                if im.kind != ST_FN || im.name == null {
                    continue;
                }
                let mut member: bool = false;
                for let ti: i32 = 0; ti < tdcl.impl_methods.len(); ti++ {
                    let tm: Stmt = tdcl.impl_methods.get(ti);
                    if tm.name != null && tm.name.eq(im.name) {
                        member = true;
                        break;
                    }
                }
                if !member {
                    t.err_code_range(im.name_line, im.name_col, im.name.len(), "not-a-trait-member", "method `".concat(im.name).concat("` is not a member of trait `").concat(s.impl_trait_name).concat("`; declare it there, or move it to a plain `impl ").concat(tname).concat(" { … }` block"));
                }
            }
        }
        // Register `type Name = X;` decls under
        // `<Trait>::<TargetTypeName>::<Name>` so T::Item lookups resolve.
        if s.assoc_decls != null {
            for let j: i32 = 0; j < s.assoc_decls.len(); j++ {
                let a: Param = s.assoc_decls.get(j);
                if a.ty == null {
                    continue;
                }
                let key: string = s.impl_trait_name.concat("::").concat(tname).concat("::").concat(a.name);
                t.assoc_table.insert(key, *a.ty);
            }
        }
    }
    // Collect `@suggest_for_fnptr(RetType, "message")` annotations from
    // every fn in the program. Each entry: hint shown when a fn-ptr arg
    // mismatch's expected return type matches `RetType` (the "want"
    // side). Optional companion attrs tighten the gate further so the
    // hint only fires on user fns the macro can actually wrap:
    //
    //   @suggest_when_got_returns(Json, Result, Option, HttpResponse)
    //   @suggest_when_got_params("0")     // 0 / 1+ / any
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_FN || s.attrs == null {
            continue;
        }
        for let j: i32 = 0; j < s.attrs.len(); j++ {
            let a: Attr = s.attrs.get(j);
            if a.name == null || !a.name.eq("suggest_for_fnptr") {
                continue;
            }
            if a.args == null || a.args.len() < 2 {
                continue;
            }
            let ret_arg: Expr = a.args.get(0);
            let msg_arg: Expr = a.args.get(1);
            if ret_arg.kind != EX_IDENT {
                continue;
            }
            if msg_arg.kind != EX_STRING {
                continue;
            }
            // Companion gates (same fn's other attrs).
            let mut got_heads: string = "";
            let mut got_params: string = "";
            for let k: i32 = 0; k < s.attrs.len(); k++ {
                let b: Attr = s.attrs.get(k);
                if b.name == null {
                    continue;
                }
                if b.name.eq("suggest_when_got_returns") && b.args != null {
                    for let m: i32 = 0; m < b.args.len(); m++ {
                        let pe: Expr = b.args.get(m);
                        if pe.kind != EX_IDENT {
                            continue;
                        }
                        if !got_heads.eq("") {
                            got_heads = got_heads.concat(",");
                        }
                        got_heads = got_heads.concat(pe.str_val);
                    }
                }
                if b.name.eq("suggest_when_got_params") && b.args != null && b.args.len() >= 1 {
                    let pe: Expr = b.args.get(0);
                    if pe.kind == EX_STRING {
                        got_params = pe.str_val;
                    }
                }
            }
            let h: FnptrHint = FnptrHint { ret_type_name: ret_arg.str_val, message: msg_arg.str_val, got_ret_heads: got_heads, got_param_shape: got_params };
            t.fnptr_hints.push(h);
        }
    }
}

// ---- generic bounds enforcement -----------------------------------------
fn type_var_contains(tps: *Vector<string>, name: string) -> bool {
    if tps == null {
        return false;
    }
    for let i: i32 = 0; i < tps.len(); i++ {
        if tps.get(i).eq(name) {
            return true;
        }
    }
    return false;
}

// Generic-aware variant of types_compat used for fn-call arg checks.
// A param type that names one of the fn's type-vars matches anything;
// pointer/borrow/result wrappers recurse so `*T` matches `*Animal`.
// Falls back to plain types_compat for everything else.
// Implicit dyn coercion, Rust-style: an argument of concrete type `T` (or
// `*T` / `&T`) where the parameter wants `*dyn Trait` and `impl Trait for T`
// exists is rewritten IN PLACE to the fat-pointer form — `&arg as *dyn Trait`
// for a value, `arg as *dyn Trait` for a pointer — so call sites don't need
// the cast spelled out. Returns true when the rewrite happened.
fn _coerce_dyn_arg(t: *Typer, want: *Type, got: *Type, args: *Vector<Expr>, idx: i32) -> bool {
    if want == null || got == null || args == null || idx < 0 || idx >= args.len() {
        return false;
    }
    if !(want.kind == TY_POINTER && want.inner != null && want.inner.kind == TY_DYN && want.inner.name != null) {
        return false;
    }
    let tr: string = want.inner.name;
    let mut is_value: bool = true;
    let mut st: *Type = got;
    if got.kind == TY_POINTER || got.kind == TY_BORROW || got.kind == TY_BORROW_MUT {
        st = got.inner;
        is_value = false;
    }
    if st == null || st.kind != TY_NAMED || st.name == null {
        return false;
    }
    if !t.impl_set.contains(tr.concat("::").concat(st.name)) {
        return false;
    }
    let a: Expr = args.get(idx);
    let ap: *Expr = __glide_palloc(sizeof(Expr)) as *Expr;
    *ap = a;
    let mut src: *Expr = ap;
    if is_value {
        src = expr_unary(UN_ADDR, ap, a.line, a.column);
    }
    let dt: *Type = __glide_palloc(sizeof(Type)) as *Type;
    dt.kind = TY_DYN;
    dt.name = tr;
    let cast: *Expr = expr_cast(src, ty_pointer(dt));
    args.set(idx, *cast);
    return true;
}

// Auto-ref for generic-bound params: a VALUE argument where the parameter
// wants `*T` (T a type param — the `impl Trait` desugar and hand-written
// bounds both produce that shape) is rewritten to `&arg`, so
// `a(Alelo { … })` works like Rust's auto-ref. Returns true on rewrite.
fn _coerce_ref_generic_arg(t: *Typer, want: *Type, got: *Type, tps: *Vector<string>, args: *Vector<Expr>, idx: i32) -> bool {
    if want == null || got == null || args == null || tps == null || idx < 0 || idx >= args.len() {
        return false;
    }
    if !(want.kind == TY_POINTER && want.inner != null && want.inner.kind == TY_NAMED && want.inner.name != null) {
        return false;
    }
    let mut is_tp: bool = false;
    for let i: i32 = 0; i < tps.len(); i++ {
        if tps.get(i).eq(want.inner.name) {
            is_tp = true;
            break;
        }
    }
    if !is_tp {
        return false;
    }
    if got.kind != TY_NAMED || got.name == null || !t.structs.contains(got.name) {
        return false;
    }
    let a: Expr = args.get(idx);
    let ap: *Expr = __glide_palloc(sizeof(Expr)) as *Expr;
    *ap = a;
    let refd: *Expr = expr_unary(UN_ADDR, ap, a.line, a.column);
    args.set(idx, *refd);
    return true;
}

fn arg_compat(want: *Type, got: *Type, tps: *Vector<string>) -> bool {
    if want == null || got == null {
        return true;
    }
    if want.kind == TY_NAMED && type_var_contains(tps, want.name) {
        return true;
    }
    if (want.kind == TY_POINTER || want.kind == TY_BORROW || want.kind == TY_BORROW_MUT) && (got.kind == TY_POINTER || got.kind == TY_BORROW || got.kind == TY_BORROW_MUT) {
        // `null` is typed as `*void` by infer_expr — accept it against
        // any pointer-shaped parameter so `stmt_if(cond, then_b, null, …)`
        // and other "no else branch" patterns type-check cleanly.
        if got.inner != null && got.inner.kind == TY_NAMED && got.inner.name.eq("void") {
            return true;
        }
        if want.inner != null && want.inner.kind == TY_NAMED && want.inner.name.eq("void") {
            return true;
        }
        return arg_compat(want.inner, got.inner, tps);
    }
    if want.kind == TY_RESULT && got.kind == TY_RESULT {
        return arg_compat(want.inner, got.inner, tps);
    }
    if want.kind == TY_OPTION && got.kind == TY_OPTION {
        return arg_compat(want.inner, got.inner, tps);
    }
    if want.kind == TY_OPT_RESULT && got.kind == TY_OPT_RESULT {
        return arg_compat(want.inner, got.inner, tps);
    }
    // Fn pointers: recurse element-wise so type vars inside the signature
    // (`fn(T) -> U`) match concrete fn types (`fn(int) -> string`).
    if want.kind == TY_FNPTR && got.kind == TY_FNPTR {
        if want.args == null || got.args == null {
            return false;
        }
        if want.args.len() != got.args.len() {
            return false;
        }
        for let i: i32 = 0; i < want.args.len(); i++ {
            let wp: Type = want.args.get(i);
            let gp: Type = got.args.get(i);
            if !arg_compat(&wp, &gp, tps) {
                return false;
            }
        }
        return arg_compat(want.fnptr_ret, got.fnptr_ret, tps);
    }
    // EX_IDENT for a top-level fn name is typed as `__fn__` placeholder
    // by the typer (no full fn-pointer typing yet at the use site). Accept
    // that against any TY_FNPTR — the codegen does the proper TY_FNPTR
    // binding from the fn's signature for mono purposes.
    if want.kind == TY_FNPTR && got.kind == TY_NAMED && got.name.eq("__fn__") {
        return true;
    }
    return types_compat(want, got);
}

// Split "Ord+Clone" → ["Ord", "Clone"]. Empty input → empty vector.
fn split_bounds(s: string) -> *Vector<string> {
    let out: *Vector<string> = Vector::new();
    if s == null || s.eq("") {
        return out;
    }
    let n: i32 = s.len();
    let mut start: i32 = 0;
    let mut i: i32 = 0;
    while i < n {
        if s.at(i).to_int() == 43 {
            if i > start {
                out.push(s.substring(start, i));
            }
            start = i + 1;
        }
        i = i + 1;
    }
    if n > start {
        out.push(s.substring(start, n));
    }
    return out;
}

// Walk a (possibly nested) param type and pick the corresponding concrete
// chunk out of the arg type for the named type-var. Handles direct
// TY_NAMED("T"), `*T`, `&T`, `&mut T`. Returns null if nothing matches.
fn extract_for_var(param_ty: *Type, arg_ty: *Type, var_name: string) -> *Type {
    if param_ty == null || arg_ty == null {
        return null;
    }
    if param_ty.kind == TY_NAMED && param_ty.name.eq(var_name) {
        return arg_ty;
    }
    if (param_ty.kind == TY_POINTER || param_ty.kind == TY_BORROW || param_ty.kind == TY_BORROW_MUT) && (arg_ty.kind == TY_POINTER || arg_ty.kind == TY_BORROW || arg_ty.kind == TY_BORROW_MUT) {
        return extract_for_var(param_ty.inner, arg_ty.inner, var_name);
    }
    if param_ty.kind == TY_GENERIC && arg_ty.kind == TY_GENERIC && param_ty.name.eq(arg_ty.name) && param_ty.args != null && arg_ty.args != null && param_ty.args.len() == arg_ty.args.len() {
        for let i: i32 = 0; i < param_ty.args.len(); i++ {
            // Heap-copy each arg so the recursive call's match-result —
            // which may be aa itself — doesn't dangle when our stack
            // locals (pa, aa) go out of scope on early return.
            let pa_v: Type = param_ty.args.get(i);
            let aa_v: Type = arg_ty.args.get(i);
            let pa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
            let aa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
            *pa_p = pa_v;
            *aa_p = aa_v;
            let r: *Type = extract_for_var(pa_p, aa_p, var_name);
            if r != null {
                return r;
            }
        }
    }
    if param_ty.kind == TY_OPTION && arg_ty.kind == TY_OPTION {
        return extract_for_var(param_ty.inner, arg_ty.inner, var_name);
    }
    if param_ty.kind == TY_RESULT && arg_ty.kind == TY_RESULT {
        return extract_for_var(param_ty.inner, arg_ty.inner, var_name);
    }
    if param_ty.kind == TY_OPT_RESULT && arg_ty.kind == TY_OPT_RESULT {
        return extract_for_var(param_ty.inner, arg_ty.inner, var_name);
    }
    // Tuples: pair-wise on elements so `(T, U)` matched against `(int, string)`
    // binds T=int / U=string.
    if param_ty.kind == TY_TUPLE && arg_ty.kind == TY_TUPLE && param_ty.args != null && arg_ty.args != null && param_ty.args.len() == arg_ty.args.len() {
        for let i: i32 = 0; i < param_ty.args.len(); i++ {
            let pa_v: Type = param_ty.args.get(i);
            let aa_v: Type = arg_ty.args.get(i);
            let pa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
            let aa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
            *pa_p = pa_v;
            *aa_p = aa_v;
            let r: *Type = extract_for_var(pa_p, aa_p, var_name);
            if r != null {
                return r;
            }
        }
    }
    // Fn pointers: pair-wise on args + return so `fn(*T) -> U` matched against
    // `fn(*int) -> int` extracts both T and U. Without this, method-level type
    // params that appear only inside an fn-ptr param (e.g. `Mutex.with<U>(f: fn(*T) -> U) -> U`)
    // never bind and the return type leaks the literal `U`.
    if param_ty.kind == TY_FNPTR && arg_ty.kind == TY_FNPTR {
        if param_ty.args != null && arg_ty.args != null && param_ty.args.len() == arg_ty.args.len() {
            for let i: i32 = 0; i < param_ty.args.len(); i++ {
                let pa_v: Type = param_ty.args.get(i);
                let aa_v: Type = arg_ty.args.get(i);
                let pa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
                let aa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *pa_p = pa_v;
                *aa_p = aa_v;
                let r: *Type = extract_for_var(pa_p, aa_p, var_name);
                if r != null {
                    return r;
                }
            }
        }
        return extract_for_var(param_ty.fnptr_ret, arg_ty.fnptr_ret, var_name);
    }
    return null;
}

// After a generic call's bound check, walk the return type and resolve any
// `T::Item` projection by looking up `<Trait>::<Concrete>::<Item>` in the
// assoc_table. T's concrete is inferred from the args (same trick as
// check_generic_bounds). Mutates a shallow copy; the caller's sig is intact.
fn resolve_assoc_in_ret(t: *Typer, sig: *FnSig, args: *Vector<Expr>, ret: *Type) -> *Type {
    if ret == null {
        return null;
    }
    if sig == null {
        return ret;
    }
    if sig.type_params == null || sig.type_params.len() == 0 {
        return ret;
    }
    if sig.params == null || args == null {
        return ret;
    }
    let plen: i32 = sig.params.len();
    let alen: i32 = args.len();
    if plen != alen {
        return ret;
    }
    let mut bn: i32 = 0;
    if sig.type_param_bounds != null {
        bn = sig.type_param_bounds.len();
    }
    return rewrite_assoc_in_type(t, sig, args, ret, plen, bn);
}

fn rewrite_assoc_in_type(t: *Typer, sig: *FnSig, args: *Vector<Expr>, ty: *Type, plen: i32, bn: i32) -> *Type {
    if ty == null {
        return null;
    }
    // TY_NAMED that's a type-param: substitute with the concrete inferred from
    // args. Without this, generic fns like `iter_fold<T, U>(...) -> U` return
    // the literal "U" type and the caller sees "expected int, got U".
    if ty.kind == TY_NAMED && sig.type_params != null {
        for let ti: i32 = 0; ti < sig.type_params.len(); ti++ {
            let tp_name: string = sig.type_params.get(ti);
            if !tp_name.eq(ty.name) {
                continue;
            }
            for let i: i32 = 0; i < plen; i++ {
                let p: Param = sig.params.get(i);
                let a: Expr = args.get(i);
                let at: *Type = infer_expr(t, &a);
                let extracted: *Type = extract_for_var(p.ty, at, tp_name);
                if extracted != null {
                    return extracted;
                }
            }
            return ty;
        }
    }
    if ty.kind == TY_ASSOC && ty.inner != null && ty.inner.kind == TY_NAMED {
        let owner_name: string = ty.inner.name;
        // Is owner_name one of the type params? If so, find its bound + concrete.
        for let ti: i32 = 0; ti < sig.type_params.len(); ti++ {
            let tp_name: string = sig.type_params.get(ti);
            if !tp_name.eq(owner_name) {
                continue;
            }
            let mut bounds: string = "";
            if ti < bn {
                bounds = sig.type_param_bounds.get(ti);
            }
            if bounds.eq("") {
                continue;
            }
            // Infer concrete by scanning params for the var.
            let mut concrete: *Type = null;
            for let i: i32 = 0; i < plen; i++ {
                let p: Param = sig.params.get(i);
                let a: Expr = args.get(i);
                let at: *Type = infer_expr(t, &a);
                let extracted: *Type = extract_for_var(p.ty, at, tp_name);
                if extracted != null {
                    concrete = extracted;
                    break;
                }
            }
            if concrete == null || concrete.kind != TY_NAMED {
                return ty;
            }
            let cname: string = concrete.name;
            // Look up in assoc_table by the first matching bound.
            let parts: *Vector<string> = split_bounds(bounds);
            for let bi: i32 = 0; bi < parts.len(); bi++ {
                let bound: string = parts.get(bi);
                let key: string = bound.concat("::").concat(cname).concat("::").concat(ty.name);
                if t.assoc_table.contains(key) {
                    let resolved: Type = t.assoc_table.get(key);
                    let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
                    *p = resolved;
                    return p;
                }
            }
            return ty;
        }
        return ty;
    }
    // Recurse through wrappers.
    if ty.kind == TY_OPTION || ty.kind == TY_RESULT || ty.kind == TY_OPT_RESULT || ty.kind == TY_POINTER || ty.kind == TY_BORROW || ty.kind == TY_BORROW_MUT || ty.kind == TY_SLICE {
        let new_inner: *Type = rewrite_assoc_in_type(t, sig, args, ty.inner, plen, bn);
        let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
        *p = *ty;
        p.inner = new_inner;
        return p;
    }
    // Recurse into tuple elements so `-> (T, U)` resolves each slot.
    if ty.kind == TY_TUPLE {
        let new_args: *Vector<Type> = Vector::new();
        if ty.args != null {
            for let i: i32 = 0; i < ty.args.len(); i++ {
                let a: Type = ty.args.get(i);
                let na: *Type = rewrite_assoc_in_type(t, sig, args, &a, plen, bn);
                if na != null {
                    new_args.push(*na);
                }
            }
        }
        return ty_tuple(new_args);
    }
    return ty;
}

fn check_generic_bounds(t: *Typer, sig: *FnSig, args: *Vector<Expr>, line: i32, col: i32) {
    if sig == null {
        return;
    }
    if sig.type_params == null || sig.type_params.len() == 0 {
        return;
    }
    if sig.type_param_bounds == null {
        return;
    }
    if sig.params == null || args == null {
        return;
    }
    let plen: i32 = sig.params.len();
    let alen: i32 = args.len();
    if plen != alen {
        return;
    } // arity reported separately
    let bn: i32 = sig.type_param_bounds.len();
    for let ti: i32 = 0; ti < sig.type_params.len(); ti++ {
        let tp_name: string = sig.type_params.get(ti);
        let mut bounds: string = "";
        if ti < bn {
            bounds = sig.type_param_bounds.get(ti);
        }
        if bounds.eq("") {
            continue;
        }
        // Infer T → concrete by scanning params for the first one that
        // mentions the var (directly or behind one pointer/borrow).
        let mut concrete: *Type = null;
        for let i: i32 = 0; i < plen; i++ {
            let p: Param = sig.params.get(i);
            let a: Expr = args.get(i);
            let at: *Type = infer_expr(t, &a);
            let extracted: *Type = extract_for_var(p.ty, at, tp_name);
            if extracted != null {
                concrete = extracted;
                break;
            }
        }
        if concrete == null {
            continue;
        }
        if concrete.kind != TY_NAMED {
            continue;
        }
        let cname: string = concrete.name;
        let parts: *Vector<string> = split_bounds(bounds);
        for let bi: i32 = 0; bi < parts.len(); bi++ {
            let bound: string = parts.get(bi);
            let key: string = bound.concat("::").concat(cname);
            if !t.impl_set.contains(key) {
                t.err_code(line, col, "unsatisfied-bound", "type `".concat(cname).concat("` does not implement `").concat(bound).concat("` (required by `").concat(tp_name).concat("` of `").concat(sig.name).concat("`)"));
                if sig.decl_origin != null && !sig.decl_origin.eq("") && sig.decl_line > 0 {
                    let mut nlen: i32 = 1;
                    if sig.name != null {
                        nlen = sig.name.len();
                    }
                    t.relate_last(sig.decl_origin, sig.decl_line, sig.decl_col, sig.decl_line, sig.decl_col + nlen, "`".concat(tp_name).concat(": ").concat(bound).concat("` bound is declared here"));
                }
            }
        }
    }
}

// ---- arena escape tracking ----------------------------------------------

// True for `*Arena` and any pointer typedef whose Named target is "Arena".
fn _is_arena_type(ty: *Type) -> bool {
    if ty == null {
        return false;
    }
    if ty.kind != TY_POINTER {
        return false;
    }
    if ty.inner == null {
        return false;
    }
    if ty.inner.kind != TY_NAMED {
        return false;
    }
    return ty.inner.name.eq("Arena");
}

// If `e` is `<ident>.<method>(...)` where the receiver is a known local
// arena, return the arena's name. Otherwise "". Doesn't chase
// field/path receivers - those are out of scope for v1.
fn _arena_method_origin(t: *Typer, e: *Expr) -> string {
    if e == null || e.kind != EX_CALL {
        return "";
    }
    if e.lhs == null || e.lhs.kind != EX_MEMBER {
        return "";
    }
    let recv: *Expr = e.lhs.lhs;
    if recv == null || recv.kind != EX_IDENT {
        return "";
    }
    if !t.arena_locals.contains(recv.str_val) {
        return "";
    }
    return recv.str_val;
}

// Look up the arena that a value derives from. Handles direct method
// calls on a local arena receiver, plus aliasing via prior `let p = q`,
// plus pass-through casts (`arena.alloc(n) as *T`).
fn _expr_arena_origin(t: *Typer, e: *Expr) -> string {
    if e == null {
        return "";
    }
    if e.kind == EX_CAST {
        return _expr_arena_origin(t, e.lhs);
    }
    if e.kind == EX_IDENT {
        if t.arena_origin.contains(e.str_val) {
            return t.arena_origin.get(e.str_val);
        }
        return "";
    }
    return _arena_method_origin(t, e);
}

// ---- borrow tracking helpers --------------------------------------------

// `e` (or any sub-expression) reads the binder `name`. Recursive walk
// over the AST fields the parser populates - enough to catch reads in
// args, member chains, unary/binary ops, casts, and nested fn-exprs.
fn _expr_uses_name(e: *Expr, name: string) -> bool {
    if e == null {
        return false;
    }
    if e.kind == EX_IDENT && e.str_val.eq(name) {
        return true;
    }
    if e.lhs != null && _expr_uses_name(e.lhs, name) {
        return true;
    }
    if e.rhs != null && _expr_uses_name(e.rhs, name) {
        return true;
    }
    if e.operand != null && _expr_uses_name(e.operand, name) {
        return true;
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if _expr_uses_name(&a, name) {
                return true;
            }
        }
    }
    if e.fn_expr_body != null {
        for let i: i32 = 0; i < e.fn_expr_body.len(); i++ {
            let b: Stmt = e.fn_expr_body.get(i);
            if _stmt_uses_name(&b, name) {
                return true;
            }
        }
    }
    return false;
}

fn _stmt_uses_name(s: *Stmt, name: string) -> bool {
    if s == null {
        return false;
    }
    if s.let_value != null && _expr_uses_name(s.let_value, name) {
        return true;
    }
    if s.expr_value != null && _expr_uses_name(s.expr_value, name) {
        return true;
    }
    if s.cond != null && _expr_uses_name(s.cond, name) {
        return true;
    }
    if s.for_step != null && _expr_uses_name(s.for_step, name) {
        return true;
    }
    if s.for_init != null && _stmt_uses_name(s.for_init, name) {
        return true;
    }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            if _stmt_uses_name(&b, name) {
                return true;
            }
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            if _stmt_uses_name(&b, name) {
                return true;
            }
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            if _stmt_uses_name(&b, name) {
                return true;
            }
        }
    }
    return false;
}

// ---- Value-copy escape walker (increment 2B) -----------------------------
// Does the binding `name` ESCAPE its function — i.e. could a copy of it outlive
// the value it was copied from? A binding is always declared in the source's
// scope or an inner one, so it can only outlive the source by leaving the fn:
// `return name`, embedding it in a struct literal, or storing it into a place.
// NOT escapes: a projection READ (`name.f`, `name[i]`), a method receiver
// (`name.m(..)`), a by-value pass `f(name)` (the callee's C copy dies with the
// call; whether the callee aliases the copy's owned FIELDS out is the codegen
// drop-walker's independent, conservative question), and a re-alias
// `let c = name` whose new binding is ITSELF contained (recursive,
// depth-capped). On any doubt a bare `name` ident is reached => escape
// (conservative => keep the MOVE). Used to relax the move-on-rebind so a
// CONTAINED copy (`let u2 = u; let u3 = u`) leaves u usable.
fn _let_esc_args(t: *Typer, args: *Vector<Expr>, name: string) -> bool {
    if args == null { return false; }
    for let i: i32 = 0; i < args.len(); i++ {
        let a: Expr = args.get(i);
        if _let_esc_expr(t, &a, name) { return true; }
    }
    return false;
}
fn _let_esc_expr(t: *Typer, e: *Expr, name: string) -> bool {
    if e == null { return false; }
    // A bare value use of `name` escapes.
    if e.kind == EX_IDENT { return e.str_val != null && e.str_val.eq(name); }
    // `name.field` / `name.field.g` — reading a field, NOT an escape of name.
    if e.kind == EX_MEMBER && e.lhs != null && e.lhs.kind == EX_IDENT && e.lhs.str_val != null && e.lhs.str_val.eq(name) {
        return false;
    }
    // `name[i]` — indexing name; not an escape of name, but the index may use name.
    if e.kind == EX_INDEX && e.lhs != null && e.lhs.kind == EX_IDENT && e.lhs.str_val != null && e.lhs.str_val.eq(name) {
        return _let_esc_expr(t, e.rhs, name);
    }
    // `name.method(args)` — receiver is a borrow/read, not an escape; scan args.
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER
        && e.lhs.lhs != null && e.lhs.lhs.kind == EX_IDENT && e.lhs.lhs.str_val != null && e.lhs.lhs.str_val.eq(name) {
        return _let_esc_args(t, e.args, name);
    }
    // `f(name)` — a by-value pass C-copies the argument: the callee's copy dies
    // with the call, so the local can only outlive its source via the OTHER
    // shapes (return/store/embed), and whether the callee aliases the copy's
    // owned FIELDS out is the codegen drop-walker's question — judged there,
    // independently and conservatively. Value semantics: not an escape of
    // name. Other arg shapes (`&name`, embedding in a literal) still recurse;
    // a call THROUGH name (`name(..)`) is caught by the lhs scan.
    if e.kind == EX_CALL {
        if _let_esc_expr(t, e.lhs, name) { return true; }
        if e.args != null {
            for let i: i32 = 0; i < e.args.len(); i++ {
                let a: Expr = e.args.get(i);
                if a.kind == EX_IDENT && a.str_val != null && a.str_val.eq(name) { continue; }
                if _let_esc_expr(t, &a, name) { return true; }
            }
        }
        return false;
    }
    if _let_esc_expr(t, e.lhs, name) { return true; }
    if _let_esc_expr(t, e.rhs, name) { return true; }
    if _let_esc_expr(t, e.operand, name) { return true; }
    if _let_esc_args(t, e.args, name) { return true; }
    if e.fn_expr_body != null {
        for let i: i32 = 0; i < e.fn_expr_body.len(); i++ {
            let b: Stmt = e.fn_expr_body.get(i);
            if _let_esc_stmt(t, &b, name) { return true; }
        }
    }
    if e.match_arms != null {
        for let i: i32 = 0; i < e.match_arms.len(); i++ {
            let ar: MatchArm = e.match_arms.get(i);
            if _let_esc_expr(t, ar.lit, name) { return true; }
            if ar.body != null {
                for let j: i32 = 0; j < ar.body.len(); j++ { let bs: Stmt = ar.body.get(j); if _let_esc_stmt(t, &bs, name) { return true; } }
            }
        }
    }
    return false;
}
fn _let_esc_stmt(t: *Typer, s: *Stmt, name: string) -> bool {
    if s == null { return false; }
    // `let c = name` re-aliases the copy. Like a by-value pass, the alias only
    // threatens the source if IT escapes — recurse on c (its uses walk this
    // same set of rules). Depth-capped against shadow cycles; cap exceeded or
    // no body in view => conservative escape (MOVE).
    if s.let_value != null && s.let_value.kind == EX_IDENT
        && s.let_value.str_val != null && s.let_value.str_val.eq(name)
        && s.name != null && !s.name.eq("") && !s.name.eq(name) {
        if t.esc_alias_depth >= 4 { return true; }
        t.esc_alias_depth = t.esc_alias_depth + 1;
        let chain_escapes: bool = _let_binding_escapes(t, s.name);
        t.esc_alias_depth = t.esc_alias_depth - 1;
        if chain_escapes { return true; }
    } else if _let_esc_expr(t, s.let_value, name) { return true; }
    if _let_esc_expr(t, s.expr_value, name) { return true; }
    if _let_esc_expr(t, s.cond, name) { return true; }
    if _let_esc_expr(t, s.for_step, name) { return true; }
    if _let_esc_expr(t, s.scrutinee, name) { return true; }
    if s.for_init != null && _let_esc_stmt(t, s.for_init, name) { return true; }
    if s.then_body != null { for let i: i32 = 0; i < s.then_body.len(); i++ { let b: Stmt = s.then_body.get(i); if _let_esc_stmt(t, &b, name) { return true; } } }
    if s.else_body != null { for let i: i32 = 0; i < s.else_body.len(); i++ { let b: Stmt = s.else_body.get(i); if _let_esc_stmt(t, &b, name) { return true; } } }
    if s.fn_body != null { for let i: i32 = 0; i < s.fn_body.len(); i++ { let b: Stmt = s.fn_body.get(i); if _let_esc_stmt(t, &b, name) { return true; } } }
    if s.arms != null { for let i: i32 = 0; i < s.arms.len(); i++ { let ar: MatchArm = s.arms.get(i); if _let_esc_expr(t, ar.lit, name) { return true; } if ar.body != null { for let j: i32 = 0; j < ar.body.len(); j++ { let bs: Stmt = ar.body.get(j); if _let_esc_stmt(t, &bs, name) { return true; } } } } }
    if s.select_arms != null { for let i: i32 = 0; i < s.select_arms.len(); i++ { let sa: SelectArm = s.select_arms.get(i); if _let_esc_expr(t, sa.chan_expr, name) { return true; } if _let_esc_expr(t, sa.send_value, name) { return true; } if sa.body != null { for let j: i32 = 0; j < sa.body.len(); j++ { let bs: Stmt = sa.body.get(j); if _let_esc_stmt(t, &bs, name) { return true; } } } } }
    return false;
}
fn _let_binding_escapes(t: *Typer, bname: string) -> bool {
    if bname == null || bname.eq("") { return true; }
    if t.cur_fn_body == null { return true; } // no body in view => conservative MOVE
    for let i: i32 = 0; i < t.cur_fn_body.len(); i++ {
        let st: Stmt = t.cur_fn_body.get(i);
        if _let_esc_stmt(t, &st, bname) { return true; }
    }
    return false;
}

// One-level field type of `<ident>.<field>` via the declared-field table —
// a pure scope + struct_field_types lookup, NO infer_expr re-run (that would
// duplicate its diagnostics). infer_expr defers member types to codegen, so
// checks that need a field's declared type (the option-null-compare reject)
// use this. Generic receivers resolve to the template's RAW field type
// (`?Box<LL<T>>`): only its KIND is consulted, which substitution preserves.
fn _simple_field_ty(t: *Typer, e: *Expr) -> *Type {
    if e == null || e.kind != EX_MEMBER || e.field == null || e.field.eq("") { return null; }
    if e.lhs == null || e.lhs.kind != EX_IDENT || e.lhs.str_val == null { return null; }
    if !t.scope.contains(e.lhs.str_val) { return null; }
    let vt: Type = t.scope.get(e.lhs.str_val);
    let st: *Type = strip_ptr(&vt);
    if st == null || st.name == null || st.name.eq("") { return null; }
    if st.kind != TY_NAMED && st.kind != TY_GENERIC { return null; }
    let key: string = st.name.concat("::").concat(e.field);
    if !t.struct_field_types.contains(key) { return null; }
    let ft: Type = t.struct_field_types.get(key);
    let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
    *p = ft;
    return p;
}

fn _body_uses_name_after(body: *Vector<Stmt>, idx: i32, name: string) -> bool {
    let n: i32 = body.len();
    let mut i: i32 = idx + 1;
    while i < n {
        let s: Stmt = body.get(i);
        if _stmt_uses_name(&s, name) {
            return true;
        }
        i = i + 1;
    }
    return false;
}

// NLL: after `check_stmt` returns, scan the rest of the block for any
// reference to each active borrow's binder. Drop events whose binder is
// never used again - subsequent mutations of `source` then pass.
fn kill_dead_borrows(t: *Typer, body: *Vector<Stmt>, idx: i32) {
    let mut i: i32 = t.borrows.len() - 1;
    while i >= 0 {
        let ev: BorrowEvent = t.borrows.get(i);
        if !ev.binder.eq("") && !_body_uses_name_after(body, idx, ev.binder) {
            let last_idx: i32 = t.borrows.len() - 1;
            if i != last_idx {
                let last_ev: BorrowEvent = t.borrows.get(last_idx);
                t.borrows.set(i, last_ev);
            }
            let _: BorrowEvent = t.borrows.pop();
        }
        i = i - 1;
    }
}

fn count_borrows(t: *Typer, name: string, want_mut: bool) -> i32 {
    let n: i32 = t.borrows.len();
    let mut c: i32 = 0;
    for let i: i32 = 0; i < n; i++ {
        let ev: BorrowEvent = t.borrows.get(i);
        if ev.source.eq(name) && ev.is_mut == want_mut {
            c = c + 1;
        }
    }
    return c;
}

// Point the "why" at the borrow already in flight. `mut_only` restricts to
// the prior mutable borrow (the conflict for a new shared borrow); otherwise
// any prior borrow of `source` (the conflict for a new mutable borrow).
fn _relate_first_borrow(t: *Typer, source: string, mut_only: bool) {
    for let i: i32 = 0; i < t.borrows.len(); i++ {
        let ev: BorrowEvent = t.borrows.get(i);
        if !ev.source.eq(source) {
            continue;
        }
        if mut_only && !ev.is_mut {
            continue;
        }
        t.relate_last(t.current_origin, ev.line, ev.col, ev.line, ev.col + source.len(), "`".concat(source).concat("` was first borrowed here"));
        return;
    }
}

fn record_borrow(t: *Typer, source: string, is_mut: bool, binder: string, line: i32, col: i32) {
    let n_shared: i32 = count_borrows(t, source, false);
    let n_mut: i32 = count_borrows(t, source, true);
    if is_mut {
        if n_mut > 0 || n_shared > 0 {
            t.err_code(line, col, "overlap-borrow", "cannot borrow `".concat(source).concat("` as mutable: already borrowed (across statements)"));
            _relate_first_borrow(t, source, false);
        }
    } else {
        if n_mut > 0 {
            t.err_code(line, col, "overlap-borrow", "cannot borrow `".concat(source).concat("` as immutable: already mutably borrowed"));
            _relate_first_borrow(t, source, true);
        }
    }
    let ev: BorrowEvent = BorrowEvent { source: source, is_mut: is_mut, binder: binder, line: line, col: col };
    t.borrows.push(ev);
}

fn enter_borrow_scope(t: *Typer) -> i32 {
    return t.borrows.len();
}

fn exit_borrow_scope(t: *Typer, saved: i32) {
    while t.borrows.len() > saved {
        let _ev: BorrowEvent = t.borrows.pop();
    }
}

// Walk a call's args. Each arg of form `&x` or `&mut x` records (x, is_mut).
// Then check pairs: two &mut x or & + &mut on the same source is forbidden.
// The root identifier a borrow expression ultimately reaches into: `x` → x,
// `s.f.g` → s, `arr[i]` → arr, `*p` → p. Two borrows sharing a root MAY alias
// (conservative — `&mut s.a` vs `&mut s.b` are disjoint but collide here;
// place-path tracking refines this later). "" when the base isn't an ident
// (e.g. a call result), which is skipped like today.
fn _borrow_root_ident(e: *Expr) -> string {
    if e == null {
        return "";
    }
    if e.kind == EX_IDENT {
        return e.str_val;
    }
    if e.kind == EX_MEMBER || e.kind == EX_INDEX {
        return _borrow_root_ident(e.lhs);
    }
    if e.kind == EX_UNARY && e.op_code == UN_DEREF {
        return _borrow_root_ident(e.operand);
    }
    return "";
}

// Index of a live borrow whose SOURCE is `name`, or -1. `want_mut_only`
// restricts the scan to exclusive borrows (the read check); the write/free
// checks pass false to match any live borrow.
fn _live_borrow_of(t: *Typer, name: string, want_mut_only: bool) -> i32 {
    if name == null || name.eq("") {
        return 0 - 1;
    }
    for let i: i32 = 0; i < t.borrows.len(); i++ {
        let ev: BorrowEvent = t.borrows.get(i);
        if ev.source.eq(name) && (!want_mut_only || ev.is_mut) {
            return i;
        }
    }
    return 0 - 1;
}

// Remove every live borrow BOUND to `binder` (rebinding or moving the binder
// ends its borrow). Swap-remove, order doesn't matter.
fn _kill_binder_borrows(t: *Typer, binder: string) {
    let mut i: i32 = t.borrows.len() - 1;
    while i >= 0 {
        let ev: BorrowEvent = t.borrows.get(i);
        if ev.binder.eq(binder) {
            let last: i32 = t.borrows.len() - 1;
            if i != last {
                t.borrows.set(i, t.borrows.get(last));
            }
            t.borrows.pop();
        }
        i = i - 1;
    }
}

fn check_call_aliasing(t: *Typer, call: *Expr) {
    if call == null || call.kind != EX_CALL || call.args == null {
        return;
    }
    let names: *Vector<string> = Vector::new();
    let muts: *Vector<bool> = Vector::new();
    for let i: i32 = 0; i < call.args.len(); i++ {
        let a: Expr = call.args.get(i);
        if a.kind == EX_UNARY && (a.op_code == UN_ADDR || a.op_code == UN_ADDR_MUT) && a.operand != null {
            let root: string = _borrow_root_ident(a.operand);
            if !root.eq("") {
                names.push(root);
                muts.push(a.op_code == UN_ADDR_MUT);
            }
        }
        // A bare binding passed as an argument is an access path too. When it
        // is `&mut`-TYPED (forwarding an exclusive borrow param), it counts as
        // a mutable leg — `g(m, m)` with `m: &mut i32` is two live exclusive
        // aliases; local roots were caught, borrow-param roots slipped through.
        // Any other bare binding counts as a read leg, so `f(&mut x, x)` (a
        // `restrict` write path plus a same-call read) collides as the
        // message always claimed. Sequential forwarding (`wr(m); wr(m)`)
        // stays legal by design: each call's exclusive use ends before the
        // next begins (reborrow semantics, matching Rust).
        if a.kind == EX_IDENT && a.str_val != null && !a.str_val.eq("") {
            let mut _amut: bool = false;
            if t.scope.contains(a.str_val) {
                let _aty: Type = t.scope.get(a.str_val);
                if _aty.kind == TY_BORROW_MUT {
                    _amut = true;
                }
            }
            names.push(a.str_val);
            muts.push(_amut);
        }
    }
    // The method receiver is itself an access path to its object: `s.m(&mut s)`
    // passes `s` as the receiver AND `&mut s` as an argument. Since a `&mut`
    // argument is lowered to a `restrict` pointer, any other access to the same
    // object in the call — including through the receiver — is undefined. Fold
    // the receiver's root ident into the alias set as a (non-mut) access path
    // so the overlap check below catches it (incl. `s.v.m(&mut s)` chains).
    if call.lhs != null && call.lhs.kind == EX_MEMBER && call.lhs.lhs != null {
        let rroot: string = _borrow_root_ident(call.lhs.lhs);
        if !rroot.eq("") {
            names.push(rroot);
            muts.push(false);
        }
    }
    let n: i32 = names.len();
    for let i: i32 = 0; i < n; i++ {
        for let j: i32 = i + 1; j < n; j++ {
            if names.get(i).eq(names.get(j)) {
                let im: bool = muts.get(i);
                let jm: bool = muts.get(j);
                if im || jm {
                    t.err_code(call.line, call.column, "borrow-alias-in-call", "cannot pass `".concat(names.get(i)).concat("` as a mutable borrow while it is also borrowed or received in the same call (aliasing)"));
                }
            }
        }
    }
}

// ---- main check ----------------------------------------------------------

// True when `s` belongs to an imported file (not the LSP's edited buffer) and
// should have its body skipped. Synthesized/builtin stmts (null/empty origin)
// and the CLI default (user_origin "") are never skipped.
fn _skip_imported(t: *Typer, s: *Stmt) -> bool {
    if t.user_origin == null || t.user_origin.eq("") {
        return false;
    }
    if s.origin == null || s.origin.eq("") {
        return false;
    }
    return !s.origin.eq(t.user_origin);
}

pub fn check_program(t: *Typer, program: *Vector<Stmt>) {
    t._canon_decls(program);
    pre_register(t, program);
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        // LSP: registration above is whole-program, but the body typecheck of
        // imported fns is wasted work (its diagnostics are filtered out before
        // publish) that would otherwise fill the retained per-doc arena.
        if _skip_imported(t, &s) {
            continue;
        }
        t.current_origin = s.origin;
        check_top(t, &s);
    }
    _drain_pass_diags(t);
}

// Merge custom-lint diagnostics emitted by compiler passes / macros via
// `pass_diag(...)` (recorded in a process-global sink during expansion) into
// the typer's own list, so they print with location + a suppressible `code`
// and count toward the error total (severity 1 fails the build).
fn _drain_pass_diags(t: *Typer) {
    let n: i32 = __glide_pd_count();
    for let i: i32 = 0; i < n; i++ {
        let line: i32 = __glide_pd_line(i);
        let col: i32 = __glide_pd_col(i);
        let sev: i32 = __glide_pd_sev(i);
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + 1, severity: sev, code: __glide_pd_code(i), message: __glide_pd_msg(i), origin: "", tag: 0, fix_line: 0, fix_col: 0, fix_end_line: 0, fix_end_col: 0, fix_replacement: "" };
        t.diagnostics.push(e);
        if sev == 1 {
            t.error_count = t.error_count + 1;
        }
    }
}

fn check_top(t: *Typer, s: *Stmt) {
    if s.kind == ST_FN {
        check_fn(t, s);
        return;
    }
    if s.kind == ST_STRUCT {
        // Field type annotations must name real types — same check as fn
        // params / returns (previously structs were skipped entirely, so a
        // typo like `name: strin` only surfaced later, at a use site, with a
        // confusing "expects `strin`" message). The struct's own `<T>` params
        // go in scope so `struct Box<T> { item: T }` doesn't see `T` as unknown.
        if s.struct_fields != null {
            let saved_tps: *Vector<string> = t.current_type_params;
            t.current_type_params = s.type_params;
            for let i: i32 = 0; i < s.struct_fields.len(); i++ {
                let f: Field = s.struct_fields.get(i);
                // f.ty carries its own parser position, so the squiggle lands on
                // the type token; the struct's line/col is only the fallback.
                _check_type_known(t, f.ty, s.line, s.column);
            }
            t.current_type_params = saved_tps;
        }
        return;
    }
    if s.kind == ST_IMPL {
        // Impl method bodies are type-checked whole-program with the SAME hard
        // errors as top-level fns — value-site borrow checks (use-after-move,
        // assign/free-while-borrowed) included. This was historically demoted to
        // warnings against a latent backlog; the borrow-safety pass (F1/F2) drove
        // that backlog to zero, so the demotion is gone and the safe layer now
        // covers method bodies, not just signatures. The impl's own type params
        // are put in scope so an `impl<T>` method body doesn't see `T` as unknown.
        if s.impl_methods != null {
            let saved_tps: *Vector<string> = t.impl_type_params;
            t.impl_type_params = s.type_params;
            t.in_impl_method = true;
            for let i: i32 = 0; i < s.impl_methods.len(); i++ {
                let m: Stmt = s.impl_methods.get(i);
                if m.kind == ST_FN {
                    check_fn(t, &m);
                }
            }
            t.in_impl_method = false;
            t.impl_type_params = saved_tps;
        }
        return;
    }
    if s.kind == ST_CONST {
        check_let_or_const(t, s);
        return;
    }
    if s.kind == ST_LET {
        check_let_or_const(t, s);
        return;
    }
    if s.kind == ST_IMPORT {
        return;
    }
    // unknown — ignore for now
}

fn is_self_call_expr(e: *Expr, name: string) -> bool {
    if e == null {
        return false;
    }
    if e.kind != EX_CALL {
        return false;
    }
    if e.lhs == null {
        return false;
    }
    if e.lhs.kind != EX_IDENT {
        return false;
    }
    return e.lhs.str_val.eq(name);
}

// Walk the body's top-level statements in order. If we hit a branching or
// return-like statement first, assume the user has a base case. If we hit a
// self-call expression (statement OR let initializer) first, the recursion
// is unconditional and every invocation overflows the stack.
fn first_unconditional_self_call(body: *Vector<Stmt>, name: string) -> *Expr {
    if body == null {
        return null;
    }
    for let i: i32 = 0; i < body.len(); i++ {
        let st: Stmt = body.get(i);
        // `return f();` recurses just as unconditionally as a bare `f();` —
        // check the returned expression before treating the return as a stop.
        if st.kind == ST_RETURN {
            if is_self_call_expr(st.expr_value, name) {
                return st.expr_value;
            }
            return null;
        }
        if st.kind == ST_IF || st.kind == ST_WHILE || st.kind == ST_FOR || st.kind == ST_MATCH || st.kind == ST_BREAK || st.kind == ST_CONTINUE {
            return null;
        }
        if st.kind == ST_EXPR && is_self_call_expr(st.expr_value, name) {
            return st.expr_value;
        }
        if st.kind == ST_LET && is_self_call_expr(st.let_value, name) {
            return st.let_value;
        }
    }
    return null;
}

fn check_fn(t: *Typer, s: *Stmt) {
    let saved_scope: *HashMap<Type> = t.scope;
    let saved_owned: *HashMap<bool> = t.owned_locals;
    let saved_arena_locals: *HashMap<bool> = t.arena_locals;
    let saved_arena_origin: *HashMap<string> = t.arena_origin;
    let saved_consumed: *HashMap<bool> = t.consumed_locals;
    let saved_moved_out: *HashMap<bool> = t.moved_out;
    let saved_mut_locals: *HashMap<bool> = t.mut_locals;
    let saved_mut_decl_pos: *HashMap<i32> = t.mut_decl_pos;
    let saved_const_bindings: *HashMap<bool> = t.const_bindings;
    let saved_borrows: *Vector<BorrowEvent> = t.borrows;
    let saved_ret: *Type = t.current_ret;
    let saved_body: *Vector<Stmt> = t.cur_fn_body;
    let saved_tps: *Vector<string> = t.current_type_params;
    let new_scope: *HashMap<Type> = HashMap::new();
    let new_owned: *HashMap<bool> = HashMap::new();
    let new_arena_locals: *HashMap<bool> = HashMap::new();
    let new_arena_origin: *HashMap<string> = HashMap::new();
    let new_consumed: *HashMap<bool> = HashMap::new();
    let new_moved_out: *HashMap<bool> = HashMap::new();
    let new_borrows: *Vector<BorrowEvent> = Vector::new();
    t.scope = new_scope;
    t.owned_locals = new_owned;
    t.arena_locals = new_arena_locals;
    t.arena_origin = new_arena_origin;
    t.consumed_locals = new_consumed;
    t.moved_out = new_moved_out;
    t.mut_locals = HashMap::new();
    t.mut_decl_pos = HashMap::new();
    t.const_bindings = HashMap::new();
    t.call_owned = HashMap::new();
    t.borrows = new_borrows;
    t.current_ret = s.fn_ret_ty;
    t.cur_fn_body = s.fn_body;
    t.current_type_params = s.type_params;
    // Param + return type annotations must name real types. (Only top-level
    // `fn`s reach check_fn — impl methods are skipped by check_top — so the
    // type params in scope are exactly this fn's own `<…>`.)
    _check_type_known(t, s.fn_ret_ty, s.line, s.column);
    _check_no_bare_extern_type(t, s.fn_ret_ty, s.line, s.column);
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            if p.ty != null {
                _check_type_known(t, p.ty, s.line, s.column);
                _check_no_bare_extern_type(t, p.ty, p.name_line, p.name_col);
                t.scope.insert(p.name, *p.ty);
                // Params honor their own `mut` (`fn f(mut n: i32)`). The
                // NEGATIVE packed pos marks "param" so the diagnostic offers
                // the `mut n: T` wording; the splice point is the same.
                t.mut_locals.insert(p.name, p.is_mut);
                t.mut_decl_pos.insert(p.name, 0 - (p.name_line * 4096 + p.name_col));
            }
        }
    }
    // A `naked fn` has no prologue/epilogue — ordinary statements compile
    // under __attribute__((naked)) but execute with no stack frame and
    // SIGILL at runtime. The documented contract (asm-only body) finally
    // gets its checker. `c_raw!` stays allowed: it's the manual escape
    // hatch and emits verbatim.
    if s.is_naked && s.fn_body != null {
        for let ni: i32 = 0; ni < s.fn_body.len(); ni++ {
            let nb: Stmt = s.fn_body.get(ni);
            if nb.kind != ST_ASM && nb.kind != ST_CRAW && nb.kind != ST_COMMENT {
                t.err_code_range(nb.line, nb.column, 1, "naked-body", "`naked fn ".concat(s.name).concat("` body must contain only `asm!` blocks — it has no prologue/epilogue, so ordinary statements execute without a stack frame"));
                break;
            }
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            check_stmt(t, &b);
            kill_dead_borrows(t, s.fn_body, i);
        }
        let rc: *Expr = first_unconditional_self_call(s.fn_body, s.name);
        if rc != null && !t.in_impl_method {
            t.err_code_range(rc.line, rc.column, s.name.len(), "infinite-recursion", "function `".concat(s.name).concat("` recurses unconditionally; every call overflows the stack"));
        }
    }
    t.scope.free();
    t.owned_locals.free();
    t.arena_locals.free();
    t.arena_origin.free();
    t.consumed_locals.free();
    t.moved_out.free();
    t.mut_locals.free();
    t.mut_decl_pos.free();
    t.const_bindings.free();
    t.borrows.free();
    t.scope = saved_scope;
    t.owned_locals = saved_owned;
    t.arena_locals = saved_arena_locals;
    t.arena_origin = saved_arena_origin;
    t.consumed_locals = saved_consumed;
    t.moved_out = saved_moved_out;
    t.mut_locals = saved_mut_locals;
    t.mut_decl_pos = saved_mut_decl_pos;
    t.const_bindings = saved_const_bindings;
    t.borrows = saved_borrows;
    t.current_ret = saved_ret;
    t.cur_fn_body = saved_body;
    t.current_type_params = saved_tps;
}

// When a bare value is given where `?T` / `!T` is expected and the value
// matches the inner type, the fix is to wrap it in `some(...)` / `ok(...)`.
// Returns the diagnostic code that tells the LSP which constructor to apply
// (it builds the actual edit from source); "" when no wrap applies.
fn _wrap_ctor_code(expected: *Type, got: *Type) -> string {
    if expected == null || got == null {
        return "";
    }
    if expected.inner == null {
        return "";
    }
    if expected.kind == TY_OPTION && types_compat(expected.inner, got) {
        return "wrap-some";
    }
    if expected.kind == TY_RESULT && types_compat(expected.inner, got) {
        return "wrap-ok";
    }
    return "";
}

// Readable name of a call's callee for diagnostics: `foo`, `Type::method`,
// or `.method` for a receiver method. Falls back to "the call".
fn _call_display_name(e: *Expr) -> string {
    if e == null || e.lhs == null {
        return "the call";
    }
    let c: *Expr = e.lhs;
    if c.kind == EX_IDENT && c.str_val != null {
        return "`".concat(c.str_val).concat("`");
    }
    if c.kind == EX_PATH && c.str_val != null && c.field != null {
        return "`".concat(c.str_val).concat("::").concat(c.field).concat("`");
    }
    if c.kind == EX_MEMBER && c.field != null {
        return "`.".concat(c.field).concat("`");
    }
    return "the call";
}

// True when `body`'s last statement exits the control-flow path
// (return / break / continue), so frees inside it don't reach siblings after.
fn _body_exits(body: *Vector<Stmt>) -> bool {
    if body == null || body.len() == 0 {
        return false;
    }
    let last: Stmt = body.get(body.len() - 1);
    return last.kind == ST_RETURN || last.kind == ST_BREAK || last.kind == ST_CONTINUE;
}

// Snapshot the currently-freed locals so a branch's frees can be rolled back.
fn _consumed_snapshot(t: *Typer) -> *HashMap<bool> {
    let snap: *HashMap<bool> = HashMap::new();
    let ks: *Vector<string> = t.consumed_locals.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if t.consumed_locals.get(k) {
            snap.insert(k, true);
        }
    }
    ks.free();
    return snap;
}

// Undo any free that happened since `snap` (a free inside an exiting branch
// must not mark the variable freed for code that runs only when the branch
// wasn't taken). Keeps frees that were already in effect before the branch.
fn _consumed_restore(t: *Typer, snap: *HashMap<bool>) {
    let ks: *Vector<string> = t.consumed_locals.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if t.consumed_locals.get(k) && !snap.contains(k) {
            t.consumed_locals.insert(k, false);
        }
    }
    ks.free();
}

// Collect into `out` every local that became freed in this branch — i.e.
// consumed now but NOT in `base` (the pre-branch snapshot).
fn _consumed_collect_new(t: *Typer, base: *HashMap<bool>, out: *HashMap<bool>) {
    let ks: *Vector<string> = t.consumed_locals.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if t.consumed_locals.get(k) && !base.contains(k) {
            out.insert(k, true);
        }
    }
    ks.free();
}

// Re-apply a captured set of frees onto the live consumed-set.
fn _consumed_apply(t: *Typer, keep: *HashMap<bool>) {
    let ks: *Vector<string> = keep.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if keep.get(k) {
            t.consumed_locals.insert(k, true);
        }
    }
    ks.free();
}

// Validate match arm variant names against the scrutinee and, for enums,
// check exhaustiveness. Shared by the statement and expression match forms so
// both reject a typo'd variant (which otherwise leaked `case Enum_Bogus` to
// cc) and a non-exhaustive enum match (which otherwise fell through to an
// uninitialized C switch result).
// The real type of a match-arm payload binding, derived from the scrutinee:
// `ok(v)` on `!T` binds T, `err(e)` binds string, `some(v)` on `?T` binds T,
// and an enum variant binds its declared payload field. Falls back to the
// `__unknown__` placeholder when the scrutinee can't be resolved.
fn _typer_bind_ty(t: *Typer, scrut_ty: *Type, variant: string, k: i32) -> *Type {
    if scrut_ty != null && variant != null {
        if scrut_ty.kind == TY_RESULT || scrut_ty.kind == TY_OPT_RESULT {
            if variant.eq("ok") && k == 0 && scrut_ty.inner != null {
                return scrut_ty.inner;
            }
            if variant.eq("err") && k == 0 {
                return ty_named("string");
            }
        }
        if (scrut_ty.kind == TY_OPTION || scrut_ty.kind == TY_OPT_RESULT) && variant.eq("some") && k == 0 && scrut_ty.inner != null {
            return scrut_ty.inner;
        }
        if scrut_ty.kind == TY_NAMED && scrut_ty.name != null {
            let pkey: string = scrut_ty.name.concat("::").concat(variant).concat("#").concat(int_to_str(k));
            if t.enum_payload_tys.contains(pkey) {
                let pt: Type = t.enum_payload_tys.get(pkey);
                let pp: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *pp = pt;
                return pp;
            }
        }
    }
    return ty_named("__unknown__");
}

// True for the `void` type (an expression that yields nothing). Used to reject
// binding / passing a value that doesn't exist.
fn _ty_is_void(ty: *Type) -> bool {
    return ty != null && ty.kind == TY_NAMED && ty.name != null && ty.name.eq("void");
}

fn _check_match_coverage(t: *Typer, scrut_ty: *Type, arms: *Vector<MatchArm>, line: i32, col: i32) {
    if arms == null {
        return;
    }
    let is_enum: bool = scrut_ty != null && scrut_ty.kind == TY_NAMED && t.enums.contains(scrut_ty.name);
    let is_opt: bool = scrut_ty != null && scrut_ty.kind == TY_OPTION;
    let is_res: bool = scrut_ty != null && scrut_ty.kind == TY_RESULT;
    let mut parts: *Vector<string> = null;
    if is_enum {
        let vlist: string = t.enums.get(scrut_ty.name);
        if !vlist.eq("") {
            parts = vlist.split(",");
        }
    }
    let mut has_wildcard: bool = false;
    let mut has_literal: bool = false;
    let covered: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < arms.len(); i++ {
        let a: MatchArm = arms.get(i);
        // Anchor every arm diagnostic at the arm's own pattern token; older
        // ASTs (line 0) fall back to the match head.
        let mut a_line: i32 = a.line;
        let mut a_col: i32 = a.col;
        let mut a_span: i32 = a.variant.len();
        if a_line < 1 {
            a_line = line;
            a_col = col;
            a_span = 5;
        }
        if a.variant.eq("_") {
            has_wildcard = true;
            continue;
        }
        // Literal pattern (`1 =>`, `"s" =>`): only valid against a value
        // scrutinee, and it must match the scrutinee's type.
        if a.lit != null {
            has_literal = true;
            if is_enum || is_opt || is_res {
                t.err_code_range(a_line, a_col, a_span, "invalid-pattern", "literal pattern `".concat(a.variant).concat("` cannot match a `").concat(type_to_string(scrut_ty)).concat("` scrutinee"));
                continue;
            }
            let lt: *Type = infer_expr(t, a.lit);
            if scrut_ty != null && !types_compat(scrut_ty, lt) {
                t.err_code_range(a_line, a_col, a_span, "pattern-type-mismatch", "literal pattern `".concat(a.variant).concat("` has type `").concat(type_to_string(lt)).concat("`, but the match scrutinee is `").concat(type_to_string(scrut_ty)).concat("`"));
            }
            continue;
        }
        // A repeated arm is dead — and the C lowering emitted a duplicate
        // `case` label, which died in cc as a self-blaming ICE.
        if covered.contains(a.variant) {
            t.err_code_range(a_line, a_col, a_span, "duplicate-arm", "`".concat(a.variant).concat("` is matched more than once; this arm is unreachable"));
            continue;
        }
        covered.insert(a.variant, true);
        // A qualified pattern (`Enum::variant`) must name the scrutinee's
        // enum. The parser used to drop the qualifier entirely, so
        // `WrongEnum::red` — or `garbage::red` — silently matched any
        // scrutinee with a `red` variant. A module qualifier (`m::red`,
        // `m::Enum::red`) stays legal: the leaf segment is the enum (or the
        // whole qualifier is an imported module path).
        if is_enum && a.qualifier != null && !a.qualifier.eq("") {
            let qsegs: *Vector<string> = a.qualifier.split("::");
            let qleaf: string = qsegs.get(qsegs.len() - 1);
            if !qleaf.eq(scrut_ty.name) && !t._is_imported_module(a.qualifier) {
                t.err_code_range(a_line, a_col, a.qualifier.len(), "pattern-enum-mismatch", "pattern names `".concat(a.qualifier).concat("::").concat(a.variant).concat("`, but the scrutinee is `").concat(scrut_ty.name).concat("`"));
            }
        }
        // Binding arity: more names than the payload has fields miscompiled
        // (undeclared C locals). Fewer is fine — the payload is just ignored.
        let mut bind_n: i32 = 0;
        if a.bindings != null {
            bind_n = a.bindings.len();
        }
        if is_enum && parts != null {
            let mut found: bool = false;
            for let j: i32 = 0; j < parts.len(); j++ {
                if parts.get(j).eq(a.variant) {
                    found = true;
                    break;
                }
            }
            if !found {
                t.err_code_range(a_line, a_col, a_span, "unknown-variant", "`".concat(a.variant).concat("` is not a variant of `").concat(scrut_ty.name).concat("`"));
            } else {
                let akey: string = scrut_ty.name.concat("::").concat(a.variant);
                if t.enum_arities.contains(akey) && bind_n > t.enum_arities.get(akey) {
                    t.err_code_range(a_line, a_col, a_span, "pattern-arity", "`".concat(a.variant).concat("` has ").concat(format!("{}", t.enum_arities.get(akey))).concat(" payload field(s), but ").concat(format!("{}", bind_n)).concat(" names are bound"));
                }
            }
        } else {
            if is_opt {
                if !a.variant.eq("some") && !a.variant.eq("none") {
                    t.err_code_range(a_line, a_col, a_span, "unknown-variant", "`".concat(a.variant).concat("` is not a variant of an Option; use `some` / `none`"));
                } else {
                    let mut _want: i32 = 1;
                    if a.variant.eq("none") {
                        _want = 0;
                    }
                    if bind_n > _want {
                        t.err_code_range(a_line, a_col, a_span, "pattern-arity", "`".concat(a.variant).concat("` binds at most ").concat(format!("{}", _want)).concat(" value(s), but ").concat(format!("{}", bind_n)).concat(" names are bound"));
                    }
                }
            } else {
                if is_res {
                    if !a.variant.eq("ok") && !a.variant.eq("err") {
                        t.err_code_range(a_line, a_col, a_span, "unknown-variant", "`".concat(a.variant).concat("` is not a variant of a Result; use `ok` / `err`"));
                    } else {
                        if bind_n > 1 {
                            t.err_code_range(a_line, a_col, a_span, "pattern-arity", "`".concat(a.variant).concat("` binds at most 1 value, but ").concat(format!("{}", bind_n)).concat(" names are bound"));
                        }
                    }
                }
            }
        }
    }
    // Literal arms can never cover a whole value domain, so they demand a
    // catch-all sibling.
    if has_literal && !has_wildcard {
        t.err_code_range(line, col, 5, "match-not-exhaustive", "match with literal patterns is not exhaustive; add a `_ =>` arm");
    }
    if !has_wildcard && is_enum && parts != null {
        let mut missing: string = "";
        let mut miss_count: i32 = 0;
        for let i: i32 = 0; i < parts.len(); i++ {
            let v: string = parts.get(i);
            if !covered.contains(v) {
                if miss_count > 0 {
                    missing = missing.concat(", ");
                }
                missing = missing.concat("`").concat(v).concat("`");
                miss_count = miss_count + 1;
            }
        }
        if miss_count > 0 {
            t.err_code_range(line, col, 5, "match-not-exhaustive", "match on `".concat(scrut_ty.name).concat("` is not exhaustive: missing ").concat(missing).concat(". Add an arm for each, or `_ =>` to handle the rest."));
        }
    }
    // Result / Option / OptResult are closed sums too — require every
    // constructor (or a `_`), so a `match r { ok(v) => {} }` that silently drops
    // the error arm is rejected. `match` is exhaustive, like Rust.
    let is_optres: bool = scrut_ty != null && scrut_ty.kind == TY_OPT_RESULT;
    if !has_wildcard && !has_literal && (is_opt || is_res || is_optres) {
        let needed: *Vector<string> = Vector::new();
        if is_opt {
            needed.push("some");
            needed.push("none");
        }
        if is_res {
            needed.push("ok");
            needed.push("err");
        }
        if is_optres {
            needed.push("ok");
            needed.push("err");
            needed.push("none");
        }
        let mut missing2: string = "";
        let mut mc2: i32 = 0;
        for let i: i32 = 0; i < needed.len(); i++ {
            let nm: string = needed.get(i);
            if !covered.contains(nm) {
                if mc2 > 0 {
                    missing2 = missing2.concat(", ");
                }
                missing2 = missing2.concat("`").concat(nm).concat("`");
                mc2 = mc2 + 1;
            }
        }
        if mc2 > 0 {
            let mut kindname: string = "Option";
            if is_res {
                kindname = "Result";
            }
            if is_optres {
                kindname = "OptResult";
            }
            t.err_code_range(line, col, 5, "match-not-exhaustive", "match on a ".concat(kindname).concat(" is not exhaustive: missing ").concat(missing2).concat(". Add an arm for each, or `_ =>` to handle the rest."));
        }
        needed.free();
    }
    if parts != null {
        parts.free();
    }
    covered.free();
}

// Type-check each statement in a block, expiring borrows that die after it.
fn check_body(t: *Typer, body: *Vector<Stmt>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let b: Stmt = body.get(i);
        check_stmt(t, &b);
        kill_dead_borrows(t, body, i);
    }
}

// Check a block in its own borrow scope (the common while / block case).
fn check_scoped_body(t: *Typer, body: *Vector<Stmt>) {
    let saved: i32 = enter_borrow_scope(t);
    check_body(t, body);
    exit_borrow_scope(t, saved);
}

fn check_stmt(t: *Typer, s: *Stmt) {
    if s.kind == ST_LET || s.kind == ST_CONST {
        check_let_or_const(t, s);
        return;
    }
    if s.kind == ST_RETURN {
        check_return(t, s);
        return;
    }
    if s.kind == ST_EXPR {
        if s.expr_value != null {
            let et: *Type = infer_expr(t, s.expr_value);
            // Must-use: a `!T` / `?T` / `?!T` produced by a call and used as a
            // bare statement throws away BOTH the value and the error/none
            // case. Errors-as-values makes that almost always a bug. Warn (not
            // error) so it's advisory. `?` / `??` / a `.ok` check all consume
            // the result, so those forms infer to `T` and never reach here.
            if s.expr_value.kind == EX_CALL && et != null && (et.kind == TY_RESULT || et.kind == TY_OPTION || et.kind == TY_OPT_RESULT) {
                let nm: string = _call_display_name(s.expr_value);
                let mut tail: string = "its error is discarded";
                if et.kind == TY_OPTION {
                    tail = "the empty (`none`) case is discarded";
                }
                t.warn_range(s.expr_value.line, s.expr_value.column, nm.len(), "unused-result", "result of ".concat(nm).concat(" (`").concat(type_to_string(et)).concat("`) is ignored: ").concat(tail).concat(". Propagate it with `?`, supply a default with `??`, or check `.ok` / `.has`."));
            }
        }
        return;
    }
    if s.kind == ST_SPAWN {
        check_spawn(t, s);
        return;
    }
    if s.kind == ST_IF {
        if s.cond != null {
            let ct: *Type = infer_expr(t, s.cond);
            if ct != null && !is_unknown_type(ct) && !is_bool_type(ct) {
                t.err_code_range(s.cond.line, s.cond.column, _arg_span(s.cond), "cond-not-bool", "if condition must be bool");
            }
        }
        // `then` and `else` are mutually exclusive paths: a free inside one
        // must NOT mark the local freed while the OTHER branch is checked.
        // Snapshot before each branch, roll that branch's frees back, and
        // after both branches re-apply only the frees from branches that fall
        // through (a branch that returns/breaks/continues never reaches the
        // code after the `if`, so its frees don't persist there either).
        let s0: *HashMap<bool> = _consumed_snapshot(t);
        let then_keep: *HashMap<bool> = HashMap::new();
        let else_keep: *HashMap<bool> = HashMap::new();
        if s.then_body != null {
            check_scoped_body(t, s.then_body);
            if !_body_exits(s.then_body) {
                _consumed_collect_new(t, s0, then_keep);
            }
            _consumed_restore(t, s0); // roll then's frees back before else
        }
        if s.else_body != null {
            check_scoped_body(t, s.else_body);
            if !_body_exits(s.else_body) {
                _consumed_collect_new(t, s0, else_keep);
            }
            _consumed_restore(t, s0); // roll else's frees back; union re-applied below
        }
        // Post-`if` state = pre-`if` frees plus the frees from each branch
        // that falls through. A read after the `if` of a value freed on any
        // reachable path is still flagged (real use-after-free preserved).
        _consumed_apply(t, then_keep);
        _consumed_apply(t, else_keep);
        s0.free();
        then_keep.free();
        else_keep.free();
        return;
    }
    if s.kind == ST_WHILE_RECV {
        // Validate the RHS is `recv_chan.recv()` and infer the binder's type
        // from the chan's inner T.
        let mut binder_ty: *Type = s.let_ty;
        let recv: *Expr = s.let_value;
        if recv != null && recv.kind == EX_CALL && recv.lhs != null && recv.lhs.kind == EX_MEMBER && recv.lhs.field.eq("recv") {
            let recv_target_ty: *Type = infer_expr(t, recv.lhs.lhs);
            let inner: *Type = chan_inner(recv_target_ty);
            if inner != null {
                if binder_ty == null {
                    binder_ty = inner;
                } else {
                    if !types_compat(binder_ty, inner) {
                        t.err_code_range(s.let_value.line, s.let_value.column, _arg_span(s.let_value), "while-let-mismatch", "while-let binder type mismatch: expected ".concat(type_to_string(binder_ty)).concat(", chan yields ").concat(type_to_string(inner)));
                    }
                }
            } else {
                t.err(s.line, s.column, "while-let RHS must be a `chan<T>.recv()` call");
            }
        } else {
            t.err(s.line, s.column, "while-let RHS must be a `chan<T>.recv()` call");
        }
        // A rejected RHS leaves the binder untyped; bind it to the
        // `__unknown__` placeholder anyway so the body doesn't cascade a
        // spurious unknown-name for every use of the binder.
        if binder_ty == null {
            binder_ty = ty_named("__unknown__");
        }
        if binder_ty != null {
            t.scope.insert(s.name, *binder_ty);
            // The while-let binder is rebound by the loop itself, never by
            // user code — register it immutable.
            _reg_mut(t, s.name, false, s.name_line, s.name_col);
        }
        if s.then_body != null {
            t.loop_depth = t.loop_depth + 1;
            check_scoped_body(t, s.then_body);
            t.loop_depth = t.loop_depth - 1;
        }
        return;
    }
    if s.kind == ST_WHILE {
        if s.cond != null {
            let ct: *Type = infer_expr(t, s.cond);
            if ct != null && !is_unknown_type(ct) && !is_bool_type(ct) {
                t.err_code_range(s.cond.line, s.cond.column, _arg_span(s.cond), "cond-not-bool", "while condition must be bool");
            }
        }
        if s.then_body != null {
            t.loop_depth = t.loop_depth + 1;
            check_scoped_body(t, s.then_body);
            t.loop_depth = t.loop_depth - 1;
        }
        return;
    }
    if s.kind == ST_FOR {
        let saved: i32 = enter_borrow_scope(t);
        if s.for_init != null {
            check_stmt(t, s.for_init);
            // The step clause (`i++`) mutates the init binding by design —
            // a `for let i` is implicitly mutable, so the idiomatic loop
            // needs no `mut`.
            if s.for_init.kind == ST_LET && s.for_init.name != null {
                t.mut_locals.insert(s.for_init.name, true);
            }
        }
        if s.cond != null {
            let _u0: *Type = infer_expr(t, s.cond);
        }
        if s.for_step != null {
            let _u1: *Type = infer_expr(t, s.for_step);
        }
        if s.then_body != null {
            t.loop_depth = t.loop_depth + 1;
            check_body(t, s.then_body);
            t.loop_depth = t.loop_depth - 1;
        }
        exit_borrow_scope(t, saved);
        return;
    }
    if s.kind == ST_BLOCK {
        if s.then_body != null {
            check_scoped_body(t, s.then_body);
        }
        return;
    }
    if s.kind == ST_MATCH {
        let mut scrut_ty: *Type = null;
        if s.scrutinee != null {
            scrut_ty = infer_expr(t, s.scrutinee);
        }
        // Check each arm body in a borrow scope, binding payload names with
        // `__unknown__` placeholders (codegen emits them via `__typeof__`, so
        // only their presence matters here). Previously arm bodies were not
        // recursed into, so undefined names / bad statements inside them
        // slipped past the typer and surfaced as raw cc errors.
        if s.arms != null {
            for let i: i32 = 0; i < s.arms.len(); i++ {
                let a: MatchArm = s.arms.get(i);
                let saved: i32 = enter_borrow_scope(t);
                if a.bindings != null {
                    for let k: i32 = 0; k < a.bindings.len(); k++ {
                        let bty: *Type = _typer_bind_ty(t, scrut_ty, a.variant, k);
                        t.scope.insert(a.bindings.get(k), *bty);
                    }
                }
                if a.body != null {
                    for let k: i32 = 0; k < a.body.len(); k++ {
                        let b: Stmt = a.body.get(k);
                        check_stmt(t, &b);
                    }
                }
                exit_borrow_scope(t, saved);
            }
        }
        _check_match_coverage(t, scrut_ty, s.arms, s.line, s.column);
        return;
    }
    if s.kind == ST_BREAK {
        return;
    }
    if s.kind == ST_CONTINUE {
        return;
    }
    if s.kind == ST_DEFER || s.kind == ST_DEFER_ERR {
        // Deferred stmts lower to ONE run at fn end (the __gdefer slots).
        // Inside a loop that's a silent lie: there is no per-iteration
        // cleanup, and a deferred expr naming the loop var is emitted past
        // the var's C scope (invalid C, cc failure). Reject until real
        // scope-exit lowering exists.
        if t.loop_depth > 0 {
            let mut _dspan: i32 = 5;
            if s.kind == ST_DEFER_ERR {
                _dspan = 9;
            }
            t.err_code_range(s.line, s.column, _dspan, "defer-in-loop", "`defer` inside a loop is not supported — it would run once at function end, not per iteration; do the cleanup at the end of the loop body instead");
        }
        return;
    }
    // Raw C/asm payload — opaque to the typer.
    if s.kind == ST_CRAW {
        return;
    }
    if s.kind == ST_ASM {
        // Operand exprs go through infer_expr so undefined-name diagnostics
        // still fire; constraint strings and clobbers are GCC syntax and pass
        // through unchanged.
        if s.asm_out_exprs != null {
            for let i: i32 = 0; i < s.asm_out_exprs.len(); i++ {
                let e: Expr = s.asm_out_exprs.get(i);
                infer_expr(t, &e);
                // An output constraint ("=r"(x)) WRITES x — same rule as an
                // assignment, same `let mut` fix-it. (The unnecessary-mut
                // analysis counts asm outputs as writes too, so a correct
                // `let mut` output doesn't earn a false warning.)
                _check_immutable_write(t, &e, "write asm output to");
            }
        }
        if s.asm_in_exprs != null {
            for let i: i32 = 0; i < s.asm_in_exprs.len(); i++ {
                let e: Expr = s.asm_in_exprs.get(i);
                infer_expr(t, &e);
            }
        }
        return;
    }
}

// Record a binding's declared mutability + the splice point for the
// `mut ` fix (see the field docs on Typer).
fn _reg_mut(t: *Typer, name: string, is_mut: bool, line: i32, col: i32) {
    if name == null || name.eq("") {
        return;
    }
    t.mut_locals.insert(name, is_mut);
    t.mut_decl_pos.insert(name, line * 4096 + col);
}

// `let` without `mut` is frozen: a direct write to the binding — and a write
// into the fields/elements of a VALUE binding — is an `assign-immutable`
// error. Writes through a pointer/borrow/slice binding (`p.x = …` where
// p: *T) mutate the pointee, not the binding, and stay legal: that's how
// `Vector::push` works on a plain `let v`. `verb` slots into the message
// ("assign to" / "modify").
fn _check_immutable_write(t: *Typer, lhs: *Expr, verb: string) {
    if lhs == null {
        return;
    }
    let root: string = _borrow_root_ident(lhs);
    if root.eq("") {
        return;
    }
    // Writing INTO a place reached through a SHARED borrow (`p.x = …`,
    // `p.inner.x = …`, `*p = …`, `view[i] = …` where the root is a `&T`
    // binding or the binder of a live `&`-borrow) mutates the borrowed
    // object through a read view. C's const is shallow — cc accepts the
    // nested-pointer forms — so the typer owns this rule, not cc. Applies
    // regardless of the binding's own `mut` (rebinding is a different write).
    if lhs.kind != EX_IDENT {
        if t.scope.contains(root) {
            let brt: Type = t.scope.get(root);
            if brt.kind == TY_BORROW {
                let mut _wt: string = "T";
                if brt.inner != null {
                    _wt = type_to_string(brt.inner);
                }
                t.err_code_range(lhs.line, lhs.column, root.len(), "write-through-shared-borrow", "cannot write through `".concat(root).concat("` — `&").concat(_wt).concat("` is a shared borrow (a read view); take `&mut ").concat(_wt).concat("` to write"));
                return;
            }
        }
        // Binder of a live shared borrow: `let r = &x` infers as a raw
        // pointer, so the scope type can't tell — but the borrow event can.
        // Also covers string-derived slices (`s[lo..hi]` / `s.as_bytes()`),
        // whose views alias read-only string storage: writes through them
        // scribbled on literal memory (segfault) before this check.
        for let _wbi: i32 = 0; _wbi < t.borrows.len(); _wbi++ {
            let _wbe: BorrowEvent = t.borrows.get(_wbi);
            if _wbe.binder.eq(root) && !_wbe.is_mut {
                t.err_code_range(lhs.line, lhs.column, root.len(), "write-through-shared-borrow", "cannot write through `".concat(root).concat("` — it is a shared (read-only) view of `").concat(_wbe.source).concat("`"));
                return;
            }
        }
    }
    // Bindings this fn declared are judged below; a root that resolves to a
    // file-scope `const` instead (and is not shadowed by any local) is a
    // write to a constant. Freestanding kernel globals (top-level `let`)
    // stay writable — the check keys on const-ness, not module scope.
    if !t.mut_locals.contains(root) {
        if t.module_consts.contains(root) && !t.scope.contains(root) {
            t.err_code_range(lhs.line, lhs.column, root.len(), "assign-immutable", "cannot ".concat(verb).concat(" constant `").concat(root).concat("` — `const` bindings can never be reassigned"));
        }
        return;
    }
    if t.mut_locals.get(root) {
        return;
    }
    if lhs.kind != EX_IDENT {
        // Path write: frozen only when the root is a value. An unknown root
        // type (inference gap) gets the benefit of the doubt. Pointer roots
        // mutate the pointee, not the binding (`Vector::push` on a plain
        // `let v`). Slice roots are NOT exempt: `view[i] = …` writes through
        // the view, and the binding must say `mut` to signal write intent.
        if !t.scope.contains(root) {
            return;
        }
        let rt: Type = t.scope.get(root);
        if rt.kind == TY_POINTER || rt.kind == TY_BORROW_MUT {
            return;
        }
        if rt.kind == TY_NAMED && rt.name != null && rt.name.eq("__unknown__") {
            return;
        }
    }
    let mut pos: i32 = 0;
    if t.mut_decl_pos.contains(root) {
        pos = t.mut_decl_pos.get(root);
    }
    if pos < 0 {
        // The receiver gets its own wording: splicing `mut ` in front of a
        // bare `self` yields `mut self` (now a parse error), and suggesting
        // `mut self: T` would silently switch the receiver from *T to a
        // by-value copy — mutations would hit the copy. No auto-fix here.
        if root.eq("self") {
            t.err_code_range(lhs.line, lhs.column, root.len(), "assign-immutable", "cannot ".concat(verb).concat(" `self` — the receiver binding is immutable; declare it `mut self: *Self` to rebind the pointer locally"));
            return;
        }
        // Param (negative marker): the fix is `mut name: T` at the decl.
        let pdl: i32 = (0 - pos) / 4096;
        let pdc: i32 = (0 - pos) % 4096;
        t.err_code_range_fix(lhs.line, lhs.column, root.len(), "assign-immutable", "cannot ".concat(verb).concat(" parameter `").concat(root).concat("` — parameters are immutable; declare it `mut ").concat(root).concat(": T`"), pdl, pdc, pdl, pdc, "mut ");
        return;
    }
    if pos == 0 {
        // Synthesized binding with no source decl — no splice point.
        t.err_code_range(lhs.line, lhs.column, root.len(), "assign-immutable", "cannot ".concat(verb).concat(" immutable binding `").concat(root).concat("`"));
        return;
    }
    let dl: i32 = pos / 4096;
    let dc: i32 = pos % 4096;
    // A `const` gets its own wording and NO `let mut` fix-it — splicing
    // `mut ` in front of a const name would suggest `const mut`, which
    // isn't a thing; constants can never be reassigned.
    if t.const_bindings.contains(root) {
        t.err_code_range(lhs.line, lhs.column, root.len(), "assign-immutable", "cannot ".concat(verb).concat(" constant `").concat(root).concat("` — it was declared `const` on line ").concat(int_to_str(dl)).concat("; `const` bindings can never be reassigned"));
        return;
    }
    t.err_code_range_fix(lhs.line, lhs.column, root.len(), "assign-immutable", "cannot ".concat(verb).concat(" `").concat(root).concat("` — it was declared immutable on line ").concat(int_to_str(dl)).concat("; declare it `let mut ").concat(root).concat("`"), dl, dc, dl, dc, "mut ");
}

fn check_let_or_const(t: *Typer, s: *Stmt) {
    // Canonicalize a qualified declared type (`let b: foo::Bar = ...`) before
    // it is compared against the initializer or recorded in scope.
    if s.let_ty != null {
        t._canon_type(s.let_ty);
        _check_no_bare_extern_type(t, s.let_ty, s.line, s.column);
    }
    // Tuple destructuring: `let (a, b, c) = expr;`. Infer the value's tuple
    // type and bind each name to its element type. Falls back to permissive
    // `__unknown__` bindings when the element type can't be resolved.
    if s.let_names != null && s.let_names.len() > 0 {
        let mut vt: *Type = null;
        if s.let_value != null {
            vt = infer_expr(t, s.let_value);
        }
        let stripped: *Type = strip_ptr(vt);
        if stripped != null && stripped.kind != TY_TUPLE {
            t.err_code_range(s.let_value.line, s.let_value.column, _arg_span(s.let_value), "tuple-destructure", "cannot destructure non-tuple value of type `".concat(type_to_string(vt)).concat("`"));
        }
        for let i: i32 = 0; i < s.let_names.len(); i++ {
            let nm: string = s.let_names.get(i);
            let mut bind: *Type = ty_named("__unknown__");
            if stripped != null && stripped.kind == TY_TUPLE && stripped.args != null && i < stripped.args.len() {
                let el: Type = stripped.args.get(i);
                let pp: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *pp = el;
                bind = pp;
            }
            t.scope.insert(nm, *bind);
            // Per-binding `mut` (`let (mut a, b) = …`), anchored at each
            // binder's own name token for the `mut ` splice.
            let mut bm: bool = s.is_mut;
            if s.let_muts != null && i < s.let_muts.len() {
                bm = s.let_muts.get(i);
            }
            let mut bl: i32 = s.name_line;
            let mut bc: i32 = s.name_col;
            if s.let_name_lines != null && i < s.let_name_lines.len() {
                bl = s.let_name_lines.get(i);
                bc = s.let_name_cols.get(i);
            }
            _reg_mut(t, nm, bm, bl, bc);
        }
        return;
    }
    let mut final_ty: *Type = s.let_ty;
    // The annotation (if any) must name a real type — catches
    // `let x: NoSuchType = …`.
    _check_type_known(t, s.let_ty, s.line, s.column);
    // `let r: &T` is a legal short-lived view; a borrow WRAPPED in anything
    // storable (`*Vector<&T>`, `(&T, …)`, `!&T`) is not.
    _reject_nested_borrow(t, s.let_ty, s.line, s.column, true);
    // Null safety: borrows can never be null. `let r: &T = null` and friends
    // are rejected. This applies to any borrow-typed binding, regardless of
    // initializer.
    if s.let_ty != null && (s.let_ty.kind == TY_BORROW || s.let_ty.kind == TY_BORROW_MUT) {
        if s.let_value != null && s.let_value.kind == EX_NULL {
            t.err_code_range(s.let_value.line, s.let_value.column, _arg_span(s.let_value), "null-borrow", "borrow `".concat(type_to_string(s.let_ty)).concat("` cannot be null"));
        }
    }
    // Null safety: auto-drop owned (`let v* = expr`) cannot be initialized
    // with null — auto-free would call free(null) or hit a method on null.
    if s.kind == ST_LET && s.is_auto_owned && s.let_value != null && s.let_value.kind == EX_NULL {
        t.err_code_range(s.let_value.line, s.let_value.column, _arg_span(s.let_value), "null-auto-drop", "auto-drop binding `".concat(s.name).concat("` cannot be initialized with null"));
    }
    // `let b = a` where a is owned is a MOVE (a is consumed below; the codegen
    // re-targets the auto-drop from a to b), not an error.
    // Detect auto-drop:
    //   - explicit `let v* = expr` marker, OR
    //   - `let p: *T = T { ... }` struct-lit pattern.
    let mut is_auto_owned: bool = false;
    if s.kind == ST_LET && s.is_auto_owned {
        is_auto_owned = true;
    }
    if s.kind == ST_LET && final_ty != null && final_ty.kind == TY_POINTER && s.let_value != null && s.let_value.kind == EX_STRUCT_LIT && final_ty.inner != null && final_ty.inner.kind == TY_NAMED && final_ty.inner.name.eq(s.let_value.str_val) {
        is_auto_owned = true;
    }
    if s.let_value != null {
        let val_ty: *Type = infer_expr(t, s.let_value);
        // Move on rebind: `let b = a` where a is a struct VALUE or an owned
        // pointer (struct-lit, explicit, or call-result owned) moves a; reading a
        // afterward is use-after-move. Primitives copy — and so do POD structs
        // (pure-data stack values with no owning fields): C struct assignment
        // is a value copy, matching the already-copying param path, so the
        // documented copy-mutation-isolation pattern compiles again.
        // Marked AFTER inferring the RHS so the read on this line is not
        // itself flagged.
        if s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_IDENT {
            let mut _rebind_moves: bool = t.owned_locals.contains(s.let_value.str_val) || t.call_owned.contains(s.let_value.str_val);
            // Value semantics (2B/2D): a non-POD struct rebind `let b = a` is
            // ALWAYS a copy — never a move-error. A CONTAINED copy leaves the
            // source droppable exactly once (codegen free-once); a copy that
            // ESCAPES the fn makes the lifetimes diverge — no single owner —
            // and codegen's independent walker then keeps the source's heap
            // fields alive (conservative leak, sound: drops only fire when
            // EVERY alias is proven contained, so never double-free/UAF).
            // Auto-clone at diverging sites (turning that leak into one
            // visible allocation) is the planned follow-up; the semantics —
            // it always compiles, the source stays usable — land here. The
            // owned-pointer case (line above) stays an unconditional MOVE:
            // codegen retargets its auto-drop, so a copy there WOULD
            // double-free.
            if _rebind_moves {
                t.consumed_locals.insert(s.let_value.str_val, true);
                t.moved_out.insert(s.let_value.str_val, true);
            }
        }
        // Synthesized `for x in <scalar>` binding (lowered for-in): the
        // iterable is a number, not a range/collection. Report it here with a
        // quick fix that wraps it in `0..` — far better than the link-time
        // `undefined __glide_int_len` the lowered `.len()/.get()` would cause.
        if s.name != null && s.name.starts_with("__glide_iter_") && _foreach_scalar_misuse(val_ty, s.let_value) {
            let mut what: string = "`".concat(type_to_string(val_ty)).concat("`");
            if is_unknown_type(val_ty) {
                what = "a length / count value";
            }
            t.err_code_range_fix(s.let_value.line, s.let_value.column, _iter_expr_span(s.let_value), "for-in-not-iterable", "cannot iterate over ".concat(what).concat(": `for-in` walks a range or a collection, not a single value. ").concat("To count, wrap it in a range like `0..n` (end-exclusive) or `0..=n` (inclusive). ").concat("To visit each element, iterate the `Vector` itself."), s.let_value.line, s.let_value.column, s.let_value.line, s.let_value.column, "0..");
        }
        if final_ty != null {
            // `let p: *T = T { .. }` auto-drop pattern: the struct literal is a
            // value but the binding is a pointer; codegen heap-allocates it
            // (malloc+init), so this is not a real mismatch. Previously it only
            // slipped through inside impl method bodies (which skip typechecking),
            // so the same line erred in a plain fn - this makes it consistent.
            let _slauto: bool = final_ty.kind == TY_POINTER && s.let_value.kind == EX_STRUCT_LIT && val_ty != null && val_ty.kind == TY_NAMED && final_ty.inner != null && final_ty.inner.kind == TY_NAMED && final_ty.inner.name.eq(val_ty.name);
            if !_slauto && !types_compat(final_ty, val_ty) {
                let wc: string = _wrap_ctor_code(final_ty, val_ty);
                let base: string = "let initializer type mismatch: expected ".concat(type_to_string(final_ty)).concat(", got ").concat(type_to_string(val_ty));
                // Pointer-vs-value: a by-value annotation (`let v: Vector<i32>`)
                // against a heap ctor that returns `*Vector<T>`. The raw message
                // reads like a deep error (and shows an unresolved `T`); point at
                // the pointer annotation or dropping it (it's inferred) instead.
                let ptr_hint: bool = final_ty.kind != TY_POINTER && val_ty.kind == TY_POINTER && val_ty.inner != null && final_ty.name != null && val_ty.inner.name != null && !final_ty.name.eq("") && final_ty.name.eq(val_ty.inner.name);
                if ptr_hint {
                    let want: string = "*".concat(type_to_string(final_ty));
                    t.err_code_range(s.let_value.line, s.let_value.column, _arg_span(s.let_value), "", base.concat(". `").concat(final_ty.name).concat("::new()` returns a pointer — annotate `").concat(want).concat("`, or drop the annotation (it's inferred)."));
                } else {
                    if wc.eq("") {
                        t.err_code_range(s.let_value.line, s.let_value.column, _arg_span(s.let_value), "", base);
                    } else {
                        let mut ctor: string = "ok";
                        if wc.eq("wrap-some") {
                            ctor = "some";
                        }
                        t.err_code_range(s.let_value.line, s.let_value.column, _arg_span(s.let_value), wc, base.concat(". Wrap the value in `").concat(ctor).concat("(...)`."));
                    }
                }
            }
        } else {
            // A binding whose initializer yields nothing (a void-returning call,
            // or a `match` whose arms are all `{}`) is a mistake — void has no
            // value to bind, and downstream it miscompiled (the alelo `let res =
            // match … {}` fed into `stream.write(res)`). Reject it; the fix is to
            // call the expression as its own statement.
            if _ty_is_void(val_ty) {
                t.err_code_range(s.name_line, s.name_col, s.name.len(), "void-binding", "cannot bind `".concat(s.name).concat("`: this expression yields nothing (void). Call it as a statement instead."));
            }
            final_ty = val_ty;
        }
    }
    // A `let` with NO initializer (`let v: T;`) is a deferred-init slot: its
    // later `v = …` assignments are initialization, not mutation, so they are
    // allowed without `mut` (the `let v; if c { v = a } else { v = b }` idiom,
    // sound like Rust's definite assignment). A `let` WITH an initializer stays
    // immutable — reassigning it needs `mut`.
    let _deferred_init: bool = s.let_value == null && (s.let_names == null || s.let_names.len() == 0);
    if final_ty != null {
        t.scope.insert(s.name, *final_ty);
        _reg_mut(t, s.name, s.is_mut || _deferred_init, s.name_line, s.name_col);
        if is_auto_owned {
            t.owned_locals.insert(s.name, true);
        }
    } else {
        // Couldn't infer (e.g. `let v = Vector::new()` — the typer's call
        // resolver doesn't know stdlib generic ctors). Still register the
        // name so subsequent references don't fail with `unknown name`. The
        // placeholder is treated as compatible-with-anything in types_compat.
        let placeholder: *Type = ty_named("__unknown__");
        t.scope.insert(s.name, *placeholder);
        _reg_mut(t, s.name, s.is_mut || _deferred_init, s.name_line, s.name_col);
        if is_auto_owned {
            t.owned_locals.insert(s.name, true);
        }
    }
    // `const` carries its own flavor of immutability: the assign-immutable
    // diagnostic says "constant" and offers no `let mut` fix.
    if s.kind == ST_CONST {
        t.const_bindings.insert(s.name, true);
    }
    // Call-result owned: `let x = make()` where `make` returns an owned value.
    // Track it (apart from owned_locals) so a later `a = x` flags use-after-move.
    if s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_CALL && _call_owned_return(t, s.let_value, final_ty) {
        t.call_owned.insert(s.name, true);
    }
    // Borrow rule R7: track let-bound `let r = &<place>` / `&mut <place>` for
    // overlapping-borrow detection across statements. The place collapses to
    // its ROOT ident (`&s.f` -> s, `&*p` -> p, `&a[i]` -> a) — conservative
    // but sound: two borrows sharing a root may alias. Scope is per-block
    // (see enter/exit_borrow_scope around if/while/for/block bodies).
    if s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_UNARY && (s.let_value.op_code == UN_ADDR || s.let_value.op_code == UN_ADDR_MUT) && s.let_value.operand != null {
        let src: string = _borrow_root_ident(s.let_value.operand);
        if !src.eq("") {
            let is_mut: bool = s.let_value.op_code == UN_ADDR_MUT;
            record_borrow(t, src, is_mut, s.name, s.line, s.column);
        }
    }
    // `let sl = v.as_slice()` exclusively borrows the source Vector: mutating /
    // reassigning / freeing v while sl is live is a compile error (via the shipped
    // use/assign/free-while-borrowed checks). Stricter than Rust's shared &[T] but
    // sound with zero new machinery.
    if s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_CALL && s.let_value.lhs != null && s.let_value.lhs.kind == EX_MEMBER && s.let_value.lhs.field != null && s.let_value.lhs.field.eq("as_slice") && s.let_value.lhs.lhs != null {
        let _slsrc: string = _borrow_root_ident(s.let_value.lhs.lhs);
        if !_slsrc.eq("") {
            record_borrow(t, _slsrc, true, s.name, s.line, s.column);
        }
    }
    // `let bs = s.as_bytes()` SHARED-borrows the source string: assigning or
    // freeing s while bs is live is a compile error (assign/free-while-borrowed
    // fire on shared borrows too), while reads of s stay legal. MANDATORY — the
    // ONLY guard on the owned-local `let mut out* = <heap>` overwrite-free path
    // (emit.glide) that the drop-disqualification does not cover.
    if s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_CALL && s.let_value.lhs != null && s.let_value.lhs.kind == EX_MEMBER && s.let_value.lhs.field != null && s.let_value.lhs.field.eq("as_bytes") && s.let_value.lhs.lhs != null {
        let _absrc: string = _borrow_root_ident(s.let_value.lhs.lhs);
        if !_absrc.eq("") {
            record_borrow(t, _absrc, false, s.name, s.line, s.column);
        }
    }
    // `let s = base[lo..hi]` (range slice) EXCLUSIVELY re-borrows a SLICE base,
    // mirroring as_slice: mutating/reassigning/freeing the base while s lives is
    // an error. Raw-pointer bases are the manual layer -> not borrow-tracked.
    if s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_INDEX && s.let_value.rhs != null && s.let_value.rhs.kind == EX_RANGE && s.let_value.lhs != null {
        let _rbase: *Type = infer_expr(t, s.let_value.lhs);
        if _rbase != null && _rbase.kind == TY_SLICE {
            let _rsrc: string = _borrow_root_ident(s.let_value.lhs);
            if !_rsrc.eq("") {
                record_borrow(t, _rsrc, true, s.name, s.line, s.column);
            }
        }
        // `let sub = str[lo..hi]` SHARED-borrows the source string (immutable, so
        // reads of it stay legal; reassigning/freeing it while sub lives errors) —
        // mirrors as_bytes. Makes the zero-copy str-slice sound with no new machinery.
        if _rbase != null && _rbase.kind == TY_NAMED && _rbase.name != null && _rbase.name.eq("string") {
            let _rsrc2: string = _borrow_root_ident(s.let_value.lhs);
            if !_rsrc2.eq("") {
                record_borrow(t, _rsrc2, false, s.name, s.line, s.column);
            }
        }
    }
    // Copying a borrow: `let b = a` where a is borrow-typed. A shared copy is
    // a second live view (recorded so overlap/NLL survive the chain); copying
    // a `&mut` MOVES it — the old binder\'s exclusive view ends and later uses
    // of it are use-after-move.
    if s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_IDENT {
        let _bc_name: string = s.let_value.str_val;
        // A borrow binding is found two ways: it's the BINDER of a live
        // tracked borrow (`let a = &mut s; let b = a;` — the expr `&mut s`
        // infers as a raw pointer, so the scope type can't tell), or it's a
        // borrow-TYPED name (a `&T` param).
        let mut _bc_src: string = "";
        let mut _bc_mut: bool = false;
        for let bi: i32 = 0; bi < t.borrows.len(); bi++ {
            let bev: BorrowEvent = t.borrows.get(bi);
            if bev.binder.eq(_bc_name) {
                _bc_src = bev.source;
                _bc_mut = bev.is_mut;
            }
        }
        if _bc_src.eq("") && t.scope.contains(_bc_name) {
            let _bc_ty: Type = t.scope.get(_bc_name);
            if _bc_ty.kind == TY_BORROW || _bc_ty.kind == TY_BORROW_MUT {
                _bc_src = _bc_name;
                _bc_mut = _bc_ty.kind == TY_BORROW_MUT;
            }
        }
        if !_bc_src.eq("") {
            // Copying a shared borrow adds a second live view; copying a
            // `&mut` MOVES it — the old binder's exclusive view ends and
            // later uses of it are use-after-move.
            if _bc_mut {
                _kill_binder_borrows(t, _bc_name);
                t.consumed_locals.insert(_bc_name, true);
                t.moved_out.insert(_bc_name, true);
            }
            record_borrow(t, _bc_src, _bc_mut, s.name, s.line, s.column);
        }
    }
    // Arena escape tracking:
    //   `let arena: *Arena = ...`                  -> arena_locals[name]
    //   `let arena: *Arena = <existing_local_arena>` -> propagate
    //   `let p: *T = local_arena.method(...)`      -> arena_origin[p] = "local_arena"
    //   `let p: *T = q` where q is in arena_origin -> propagate
    if s.kind == ST_LET && s.name != null && !s.name.eq("") {
        // A fresh `let name = ...` rebinds the name to a live value, so any
        // earlier free of an old binding with the same name no longer
        // applies. Clearing here (after the RHS was already checked) stops a
        // later read of the new binding being flagged use-after-free — the
        // common `let x = make(); x.free();` repeated in sibling blocks.
        if t.consumed_locals.contains(s.name) {
            t.consumed_locals.insert(s.name, false);
        }
        if _is_arena_type(s.let_ty) {
            let mut treat_as_local: bool = true;
            if s.let_value != null && s.let_value.kind == EX_IDENT && !t.arena_locals.contains(s.let_value.str_val) {
                // `let arena2: *Arena = arena_param` - param-owned arena
                // stays out of arena_locals (its lifetime is the caller's).
                treat_as_local = false;
            }
            if treat_as_local {
                t.arena_locals.insert(s.name, true);
            }
        } else {
            if s.let_value != null {
                let origin: string = _expr_arena_origin(t, s.let_value);
                if !origin.eq("") {
                    t.arena_origin.insert(s.name, origin);
                }
            }
        }
    }
}

// `spawn fn(args)` / `spawn_thread fn(args)`: each captured arg is now
// owned by a task that may outlive the calling fn. Anything derived
// from a local arena would dangle once the calling fn's `defer
// arena.free()` runs - the coro / pthread might still be alive.
//
// Conservative rule: reject any arg whose region resolves to a local
// arena. The user can clone into an owned value or pass a longer-lived
// arena explicitly.
fn check_spawn(t: *Typer, s: *Stmt) {
    if s.expr_value == null {
        return;
    }
    let call: *Expr = s.expr_value;
    let _ret: *Type = infer_expr(t, call);
    if call.args == null {
        return;
    }
    let mut kind: string = "spawn";
    if s.is_spawn_thread {
        kind = "spawn_thread";
    }
    for let i: i32 = 0; i < call.args.len(); i++ {
        let a: Expr = call.args.get(i);
        // A spawned task may run after this frame returns, so a borrow of a
        // local can never cross into one — same family as sending a borrow
        // through a channel. Both the syntactic `&x` / `&mut x` form and a
        // borrow-typed value are banned.
        if a.kind == EX_UNARY && (a.op_code == UN_ADDR || a.op_code == UN_ADDR_MUT) {
            t.err_code_range(a.line, a.column, _arg_span(&a), "borrow-escape", kind.concat(" may outlive this frame — a borrow cannot cross into a task; pass a value or a `*T` you own"));
        } else {
            if a.kind == EX_IDENT && t.scope.contains(a.str_val) {
                let _sb: Type = t.scope.get(a.str_val);
                if _sb.kind == TY_BORROW || _sb.kind == TY_BORROW_MUT {
                    t.err_code_range(a.line, a.column, _arg_span(&a), "borrow-escape", kind.concat(" may outlive this frame — a borrow cannot cross into a task; pass a value or a `*T` you own"));
                }
            }
        }
        let origin: string = _expr_arena_origin(t, &a);
        if origin.eq("") {
            continue;
        }
        if !t.arena_locals.contains(origin) {
            continue;
        }
        t.err_code(a.line, a.column, "spawn-arena-escape", kind.concat(" captures a value derived from local arena `").concat(origin).concat("`; the arena is freed when this fn returns but the spawned task may still run. Copy the data into an owned value first, or pass a longer-lived arena from the caller."));
    }
}

fn check_return(t: *Typer, s: *Stmt) {
    if s.expr_value == null {
        if t.current_ret != null {
            // `return;` inside a `fn -> !` is a valid early-success — codegen
            // rewrites it to `return __glide_ok_void();`.
            if t.current_ret.kind == TY_RESULT && t.current_ret.inner != null && t.current_ret.inner.kind == TY_NAMED && t.current_ret.inner.name.eq("void") {
                return;
            }
            t.err_code_range(s.line, s.column, 6, "missing-return-value", "missing return value");
        }
        return;
    }
    let e: *Expr = s.expr_value;
    // Arena escape: pointer derived from a local `*Arena` must not leave
    // the fn - the caller would dereference into freed memory after the
    // arena's `defer free()` ran.
    let arena_src: string = _expr_arena_origin(t, e);
    if !arena_src.eq("") && t.arena_locals.contains(arena_src) {
        t.err_code(s.line, s.column, "arena-escape", "returned pointer derives from local arena `".concat(arena_src).concat("`; the caller would read freed memory. Accept the arena as a parameter so its lifetime is owned by the caller."));
    }
    // Returning an owned local is a MOVE, not a bug: codegen skips its auto-drop
    // at the `return` (move-out) so the caller receives a live pointer and takes
    // ownership of it. (This was an error before move-out existed.)
    // Borrow rule: `return &x` / `return &mut x` is ALWAYS rejected — borrows
    // are second-class and flow into calls, never out. (Param pass-through was
    // once allowed; the total signature ban `borrow-return-type` made that
    // shape un-declarable, and this value-site check remains the guard for
    // returning a fresh address out of a `-> *T` fn.)
    if e.kind == EX_UNARY && (e.op_code == UN_ADDR || e.op_code == UN_ADDR_MUT) && e.operand != null && e.operand.kind == EX_IDENT {
        let n: string = e.operand.str_val;
        t.err_code_range(e.line, e.column, _arg_span(e), "return-borrow", "cannot return a borrow of `".concat(n).concat("` — borrows flow into calls, never out (it would dangle); return `*T` from an allocation, or a value"));
    }
    let vt: *Type = infer_expr(t, e);
    if t.current_ret == null {
        // Underline the returned VALUE (the offending token), not the first
        // character of `return`.
        t.err_code_range(e.line, e.column, _arg_span(e), "return-in-void-fn", "return with value in fn declared without ret type");
        return;
    }
    if !types_compat(t.current_ret, vt) {
        let mut rl: i32 = s.line;
        let mut rc: i32 = s.column;
        let mut rspan: i32 = 6; // the `return` keyword
        if e != null && e.line > 0 {
            rl = e.line;
            rc = e.column;
            rspan = _arg_span(e);
        }
        let base: string = "return type mismatch: expected ".concat(type_to_string(t.current_ret)).concat(", got ").concat(type_to_string(vt));
        let mut wc: string = "";
        if e != null && e.line > 0 {
            wc = _wrap_ctor_code(t.current_ret, vt);
        }
        if wc.eq("") {
            t.err_code_range(rl, rc, rspan, "", base);
        } else {
            let mut ctor: string = "ok";
            if wc.eq("wrap-some") {
                ctor = "some";
            }
            t.err_code_range(rl, rc, rspan, wc, base.concat(". Wrap the value in `").concat(ctor).concat("(...)`."));
        }
    }
}

// ---- expression inference ------------------------------------------------

// Strip pointer/borrow wrappers, then return the chan's inner type if `t`
// is a `chan<T>`. Returns null otherwise.
fn chan_inner(t: *Type) -> *Type {
    if t == null {
        return null;
    }
    let mut x: *Type = t;
    while x != null && (x.kind == TY_POINTER || x.kind == TY_BORROW || x.kind == TY_BORROW_MUT) {
        x = x.inner;
    }
    if x == null {
        return null;
    }
    if x.kind != TY_GENERIC {
        return null;
    }
    if !x.name.eq("chan") {
        return null;
    }
    if x.args == null || x.args.len() == 0 {
        return null;
    }
    let inner: Type = x.args.get(0);
    let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
    *p = inner;
    return p;
}

// Bare macros that legitimately survive expansion to the typer/codegen. The
// list is deliberately generous (includes the pre-pass builtins that are
// normally rewritten away earlier) so it never flags a real macro in an edge
// path; anything outside it is a genuine typo. User `macro` defs + proc macros
// are already expanded and their defs stripped, so they never reach here.
fn _is_surviving_builtin_macro(name: string) -> bool {
    return name.eq("println") || name.eq("print") || name.eq("format") || name.eq("dbg") || name.eq("vec_of")
        || name.eq("panic") || name.eq("assert") || name.eq("assert_eq") || name.eq("assert_str_eq")
        || name.eq("todo") || name.eq("unimplemented") || name.eq("unreachable")
        || name.eq("file") || name.eq("line") || name.eq("column") || name.eq("function")
        || name.eq("pkg") || name.eq("cfg") || name.eq("env") || name.eq("stringify");
}

// `*void` — the type of a bare `null` literal.
fn _is_void_ptr(ty: *Type) -> bool {
    return ty != null && ty.kind == TY_POINTER && ty.inner != null && ty.inner.kind == TY_NAMED && ty.inner.name.eq("void");
}

// A pointer-ish (nullable) type that a `null` may stand in for.
fn _is_ptr_like(ty: *Type) -> bool {
    if ty == null {
        return false;
    }
    return ty.kind == TY_POINTER || ty.kind == TY_BORROW || ty.kind == TY_BORROW_MUT;
}

pub fn infer_expr(t: *Typer, e: *Expr) -> *Type {
    if e == null {
        return null;
    }
    if e.kind == EX_INT {
        // An explicit type suffix (`0i32`, `3u8`) pins the type.
        if e.cast_to != null {
            return e.cast_to;
        }
        // Auto-widen literals that don't fit in a 32-bit int. Without
        // this `let n = 19_999_999_998;` infers as `int` and truncates
        // to -1474836482 in codegen, which silently breaks comparisons
        // — most visibly inside macros like `assert_eq!` where the
        // user can't easily annotate the binding.
        if e.int_val > 2147483647 || e.int_val < -2147483648 {
            return ty_named("i64");
        }
        return ty_named("i32");
    }
    if e.kind == EX_FLOAT {
        if e.cast_to != null {
            return e.cast_to;
        }
        return ty_named("f64");
    }
    if e.kind == EX_STRING {
        return ty_named("string");
    }
    if e.kind == EX_BOOL {
        return ty_named("bool");
    }
    if e.kind == EX_CHAR {
        return ty_named("char");
    }
    if e.kind == EX_NULL {
        return ty_pointer(ty_named("void"));
    }
    if e.kind == EX_IF {
        // Expression-position if: both branches must produce the same
        // type, and there must be an else branch (otherwise there's
        // no value when cond is false).
        let cond_ty: *Type = infer_expr(t, e.lhs);
        if cond_ty != null && cond_ty.kind == TY_NAMED && !cond_ty.name.eq("bool") {
            t.push_diag(e.line, e.column, 1, "if-cond-type", "if condition must be `bool`, got `".concat(type_to_string(cond_ty)).concat("`"));
        }
        if e.operand == null {
            t.push_diag(e.line, e.column, 1, "if-expr-needs-else", "expression-position `if` requires an `else` branch");
            return infer_expr(t, e.rhs);
        }
        let then_ty: *Type = infer_expr(t, e.rhs);
        let else_ty: *Type = infer_expr(t, e.operand);
        // `null` (typed `*void`) unifies with any pointer branch — `if c {
        // g.lookup(x) } else { null }` yields `*Type`, not a mismatch. Skip
        // when one side is null-typed and the other is pointer-ish.
        let then_null: bool = _is_void_ptr(then_ty);
        let else_null: bool = _is_void_ptr(else_ty);
        let null_ok: bool = (then_null && _is_ptr_like(else_ty)) || (else_null && _is_ptr_like(then_ty));
        if then_ty != null && else_ty != null && !type_eq(then_ty, else_ty) && !null_ok {
            t.push_diag(e.line, e.column, 1, "if-branch-type-mismatch", "`if` branches produce different types: `".concat(type_to_string(then_ty)).concat("` vs `").concat(type_to_string(else_ty)).concat("`"));
        }
        if then_ty != null {
            return then_ty;
        }
        return else_ty;
    }
    if e.kind == EX_BLOCK {
        // Run lead-in stmts in a fresh borrow scope; the value's type is
        // the type of the trailing expression.
        let saved: i32 = enter_borrow_scope(t);
        if e.block_stmts != null {
            for let i: i32 = 0; i < e.block_stmts.len(); i++ {
                let b: Stmt = e.block_stmts.get(i);
                check_stmt(t, &b);
            }
        }
        let v_ty: *Type = infer_expr(t, e.operand);
        exit_borrow_scope(t, saved);
        return v_ty;
    }
    if e.kind == EX_MATCH {
        let scrut_ty: *Type = infer_expr(t, e.lhs);
        let mut result_ty: *Type = null;
        let mut saw_value_arm: bool = false;
        let mut saw_void_arm: bool = false;
        if e.match_arms != null {
            for let i: i32 = 0; i < e.match_arms.len(); i++ {
                let a: MatchArm = e.match_arms.get(i);
                let saved: i32 = enter_borrow_scope(t);
                // Bind payload names with their REAL types (derived from the
                // scrutinee), so an arm value like `ok(v) => v` carries the
                // payload type into the match result — and misuse downstream
                // (`stream.write(res)` on a `*File`) errs here, not in cc.
                if a.bindings != null {
                    for let k: i32 = 0; k < a.bindings.len(); k++ {
                        let bty: *Type = _typer_bind_ty(t, scrut_ty, a.variant, k);
                        t.scope.insert(a.bindings.get(k), *bty);
                    }
                }
                let mut arm_ty: *Type = ty_named("void");
                let mut arm_diverges: bool = false;
                if a.body != null && a.body.len() > 0 {
                    let last_idx: i32 = a.body.len() - 1;
                    for let k: i32 = 0; k < last_idx; k++ {
                        let b: Stmt = a.body.get(k);
                        check_stmt(t, &b);
                    }
                    let last: Stmt = a.body.get(last_idx);
                    if last.kind == ST_RETURN && !last.is_arm_yield {
                        // A USER-written `return` exits the enclosing function
                        // (Rust semantics). It type-checks against the fn's
                        // return type and the arm constrains nothing.
                        check_stmt(t, &last);
                        arm_diverges = true;
                    } else {
                        if last.expr_value != null {
                            // A bare `=> v` yield, or a trailing expression
                            // statement in a block: the arm's value.
                            arm_ty = infer_expr(t, last.expr_value);
                        } else {
                            // A non-value trailing statement (`{}`, an `if`, …):
                            // the arm produces nothing.
                            check_stmt(t, &last);
                        }
                    }
                }
                // Unify: every value-producing arm must agree on a type, so a
                // `match` used as a value can't mix `i32` and `string` (which
                // ICE'd in cc). A diverging arm (user `return`) constrains
                // nothing — like Rust's `!`. A PLAIN void arm alongside a
                // value arm is an error: that arm would leave the match's
                // value undefined at runtime.
                if arm_diverges {
                    // nothing to unify
                } else {
                    if _ty_is_void(arm_ty) {
                        saw_void_arm = true;
                    } else {
                        saw_value_arm = true;
                        if result_ty == null || _ty_is_void(result_ty) {
                            result_ty = arm_ty;
                        } else {
                            if !types_compat(result_ty, arm_ty) {
                                t.err_code_range(e.line, e.column, 5, "match-arm-mismatch", "match arms have incompatible types: `".concat(type_to_string(result_ty)).concat("` vs `").concat(type_to_string(arm_ty)).concat("`"));
                            }
                        }
                    }
                }
                exit_borrow_scope(t, saved);
            }
        }
        // Expression-position match was missing the variant + exhaustiveness
        // checks the statement form had, so a non-exhaustive enum match
        // silently produced an uninitialized C switch result. e.line/e.column
        // anchor the diagnostic at the `match`.
        _check_match_coverage(t, scrut_ty, e.match_arms, e.line, e.column);
        // Mixed arms: one yields a value, another is a plain `{}` (and doesn't
        // return from the fn) — taking the void arm would leave the match's
        // value undefined.
        if saw_value_arm && saw_void_arm {
            t.err_code_range(e.line, e.column, 5, "match-arm-mismatch", "match arms have incompatible types: `".concat(type_to_string(result_ty)).concat("` vs nothing — every arm must yield a value or return"));
        }
        // A match whose arms all yield nothing IS a void value — return that (not
        // null), so binding it (`let x = match …{ …=>{} }`) or passing it to a
        // typed slot trips the void-in-value checks instead of miscompiling.
        if result_ty == null {
            return ty_named("void");
        }
        return result_ty;
    }
    if e.kind == EX_FNEXPR {
        // Check the closure body in a FRESH scope holding only its own params
        // (mirrors check_fn), with the closure's own return type. Globals,
        // consts (module_scope) and top-level fns resolve outside t.scope, so
        // they stay visible — but enclosing LOCALS do not. A closure that
        // references an enclosing local is a capture, which isn't supported
        // (codegen lifts the body to a top-level fn, leaving the captured name
        // undeclared in C); it now surfaces as a clean `unknown name` error at
        // check time instead of a confusing cc failure. This also catches
        // genuinely undefined names and bad statements inside the closure,
        // which the typer previously skipped entirely.
        let saved_fscope: *HashMap<Type> = t.scope;
        let saved_fret: *Type = t.current_ret;
        // Closure params obey the same immutability rule as named-fn params
        // (mirrors check_fn): immutable unless `mut`, with the fresh maps
        // saved/restored so closure entries don't leak into the enclosing fn.
        let saved_fmut: *HashMap<bool> = t.mut_locals;
        let saved_fmpos: *HashMap<i32> = t.mut_decl_pos;
        let saved_fconst: *HashMap<bool> = t.const_bindings;
        // The closure body is its own fn: a `defer` in it is fn-scoped to the
        // CLOSURE, so the enclosing loop context must not leak in. Same for
        // the capture hint — remember the enclosing scope so an unknown name
        // that exists out there gets the "closures cannot capture" wording.
        let saved_floop: i32 = t.loop_depth;
        let saved_fouter: *HashMap<Type> = t.fnexpr_outer_scope;
        t.loop_depth = 0;
        t.fnexpr_outer_scope = saved_fscope;
        let fresh_scope: *HashMap<Type> = HashMap::new();
        t.scope = fresh_scope;
        t.current_ret = e.cast_to;
        t.mut_locals = HashMap::new();
        t.mut_decl_pos = HashMap::new();
        t.const_bindings = HashMap::new();
        if e.fn_expr_params != null {
            for let i: i32 = 0; i < e.fn_expr_params.len(); i++ {
                let p: Param = e.fn_expr_params.get(i);
                if p.ty != null {
                    t.scope.insert(p.name, *p.ty);
                    // NEGATIVE packed pos marks "param" so the diagnostic
                    // offers the `mut name: T` wording (see check_fn).
                    t.mut_locals.insert(p.name, p.is_mut);
                    t.mut_decl_pos.insert(p.name, 0 - (p.name_line * 4096 + p.name_col));
                }
            }
        }
        if e.fn_expr_body != null {
            for let i: i32 = 0; i < e.fn_expr_body.len(); i++ {
                let b: Stmt = e.fn_expr_body.get(i);
                check_stmt(t, &b);
            }
        }
        t.scope.free();
        t.mut_locals.free();
        t.mut_decl_pos.free();
        t.const_bindings.free();
        t.scope = saved_fscope;
        t.current_ret = saved_fret;
        t.mut_locals = saved_fmut;
        t.mut_decl_pos = saved_fmpos;
        t.const_bindings = saved_fconst;
        t.loop_depth = saved_floop;
        t.fnexpr_outer_scope = saved_fouter;
        return ty_named("__unknown__");
    }
    if e.kind == EX_IDENT {
        // `cfg!("...")` was lowered by the expander to a `__glide_cfg_<cond>`
        // flag — a compile-time bool whose value the C preprocessor decides.
        if e.str_val != null && e.str_val.starts_with("__glide_cfg_") {
            return ty_named("bool");
        }
        // Use-after-free: a `<name>.free()` earlier in the fn flagged
        // this binding; reading it now would touch reclaimed memory.
        // Type lookup continues so downstream diagnostics still resolve.
        if t.consumed_locals.contains(e.str_val) && t.consumed_locals.get(e.str_val) {
            if t.moved_out.contains(e.str_val) && t.moved_out.get(e.str_val) {
                t.err_code_range(e.line, e.column, e.str_val.len(), "use-after-move", "value `".concat(e.str_val).concat("` was moved earlier in this function; its ownership now belongs to the target"));
            } else {
                t.err_code_range(e.line, e.column, e.str_val.len(), "use-after-free", "value `".concat(e.str_val).concat("` was freed earlier in this function; subsequent reads touch reclaimed memory"));
            }
        }
        // Exclusive-borrow discipline: while a `&mut x` is live, the ONLY way
        // to touch x is through the borrow. A direct read of the source here
        // would alias the exclusive view (and `&mut` params lower to
        // `restrict`). Suppressed under `&`-of (a re-borrow, judged by
        // overlap-borrow) and on assignment LHS (write check owns it).
        if t.addr_ctx == 0 {
            let _rb: i32 = _live_borrow_of(t, e.str_val, true);
            if _rb >= 0 {
                let _rbe: BorrowEvent = t.borrows.get(_rb);
