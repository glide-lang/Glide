// Typer — semantic analysis on the AST.
//
// Runs in two passes:
//   1. `pre_register` — index every fn signature, struct decl, trait, impl,
//      and macro reachable from the root. Builds `g.impl_set`, the trait/type
//      table the bound checker relies on. Also resolves module aliases from
//      `import` so qualified paths (`stdlib::math::min_int`) become callable.
//   2. `check` — walk stmts and exprs, attaching types to every node, raising
//      diagnostics for type mismatches, undefined names, missing trait
//      methods, unsatisfied generic bounds (`<T: Render>`), null safety,
//      arena-not-freed, unused locals, etc.
//
// Generic functions are typechecked with TY_NAMED placeholders for type
// parameters; monomorphization happens later in codegen. Borrow rules
// (`&` / `&mut`) are enforced here without lifetime annotations.
import stdlib::hashmap::*;
import bootstrap::syntax::ast;
import bootstrap::syntax::parser; // for ParseDiag (used by merge_parse_diags below)

// ---- type helpers --------------------------------------------------------

// types_compat is the looser companion to type_eq used by call sites.
// Was private; exported so the LSP (and any analyser running outside the
// main pipeline) can reach it.

// Convert parser-side diagnostics into typer DiagEntry shape and append
// them to the typer's diagnostics vector so the pretty-printer / LSP
// publish path picks them up alongside type errors. Always severity 1
// (`error`) with code `parse`.
pub fn merge_parse_diags(t: *Typer, pdiags: *Vector<ParseDiag>) {
    if t == null || pdiags == null {
        return;
    }
    for let i: i32 = 0; i < pdiags.len(); i++ {
        let d: ParseDiag = pdiags.get(i);
        let mut code: string = d.code;
        if code.eq("") {
            code = "parse";
        }
        let mut span: i32 = d.span;
        if span < 1 {
            span = 1;
        }
        let e: DiagEntry = DiagEntry { line: d.line, col: d.col, end_line: d.line, end_col: d.col + span, severity: 1, code: code, message: d.msg, origin: d.origin, tag: 0, fix_line: d.fix_line, fix_col: d.fix_col, fix_end_line: d.fix_end_line, fix_end_col: d.fix_end_col, fix_replacement: d.fix_replacement };
        t.diagnostics.push(e);
    }
}

pub fn type_eq(a: *Type, b: *Type) -> bool {
    if a == null {
        return b == null;
    }
    if b == null {
        return false;
    }
    if a.kind != b.kind {
        return false;
    }
    if a.kind == TY_NAMED {
        return a.name.eq(b.name);
    }
    if a.kind == TY_DYN {
        return a.name.eq(b.name);
    }
    if a.kind == TY_ASSOC {
        if !a.name.eq(b.name) {
            return false;
        }
        return type_eq(a.inner, b.inner);
    }
    if a.kind == TY_TUPLE {
        let an: i32 = if a.args != null { a.args.len() } else { 0 };
        let bn: i32 = if b.args != null { b.args.len() } else { 0 };
        if an != bn {
            return false;
        }
        for let i: i32 = 0; i < an; i++ {
            let ae: Type = a.args.get(i);
            let be: Type = b.args.get(i);
            if !type_eq(&ae, &be) {
                return false;
            }
        }
        return true;
    }
    return type_eq(a.inner, b.inner);
}

pub fn type_to_string(t: *Type) -> string {
    if t == null {
        return "<none>";
    }
    if t.kind == TY_NAMED {
        return t.name;
    }
    if t.kind == TY_POINTER {
        return "*".concat(type_to_string(t.inner));
    }
    if t.kind == TY_BORROW {
        return "&".concat(type_to_string(t.inner));
    }
    if t.kind == TY_BORROW_MUT {
        return "&mut ".concat(type_to_string(t.inner));
    }
    if t.kind == TY_SLICE {
        return "[]".concat(type_to_string(t.inner));
    }
    if t.kind == TY_GENERIC {
        let mut out: string = t.name.concat("<");
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                if i > 0 {
                    out = out.concat(", ");
                }
                let a: Type = t.args.get(i);
                out = out.concat(type_to_string(&a));
            }
        }
        return out.concat(">");
    }
    if t.kind == TY_RESULT {
        return "!".concat(type_to_string(t.inner));
    }
    if t.kind == TY_OPTION {
        return "?".concat(type_to_string(t.inner));
    }
    if t.kind == TY_OPT_RESULT {
        return "?!".concat(type_to_string(t.inner));
    }
    if t.kind == TY_DYN {
        return "dyn ".concat(t.name);
    }
    if t.kind == TY_ASSOC {
        return type_to_string(t.inner).concat("::").concat(t.name);
    }
    if t.kind == TY_TUPLE {
        let mut out: string = "(";
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                if i > 0 {
                    out = out.concat(", ");
                }
                let a: Type = t.args.get(i);
                out = out.concat(type_to_string(&a));
            }
        }
        return out.concat(")");
    }
    if t.kind == TY_FNPTR {
        let mut s: string = "fn(";
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                if i > 0 {
                    s = s.concat(", ");
                }
                let a: Type = t.args.get(i);
                s = s.concat(type_to_string(&a));
            }
        }
        s = s.concat(")");
        if t.fnptr_ret != null {
            s = s.concat(" -> ").concat(type_to_string(t.fnptr_ret));
        }
        return s;
    }
    return "<ty?>";
}

fn is_int_type(t: *Type) -> bool {
    if t == null {
        return false;
    }
    if t.kind != TY_NAMED {
        return false;
    }
    let n: string = t.name;
    if n.eq("i8") {
        return true;
    }
    if n.eq("i16") {
        return true;
    }
    if n.eq("i32") {
        return true;
    }
    if n.eq("i64") {
        return true;
    }
    if n.eq("u8") {
        return true;
    }
    if n.eq("u16") {
        return true;
    }
    if n.eq("u32") {
        return true;
    }
    if n.eq("u64") {
        return true;
    }
    if n.eq("i128") {
        return true;
    }
    if n.eq("u128") {
        return true;
    }
    if n.eq("usize") {
        return true;
    }
    if n.eq("isize") {
        return true;
    }
    if n.eq("char") {
        return true;
    }
    return false;
}

fn is_float_type(t: *Type) -> bool {
    if t == null {
        return false;
    }
    if t.kind != TY_NAMED {
        return false;
    }
    return t.name.eq("f32") || t.name.eq("f64");
}

// True if `n` names an integer primitive (any width). Used to type the
// associated constants `<inttype>::MAX` / `::MIN`.
fn _is_int_prim_name(n: string) -> bool {
    if n.eq("i8") || n.eq("i16") || n.eq("i32") || n.eq("i64") || n.eq("i128") || n.eq("i256") {
        return true;
    }
    if n.eq("u8") || n.eq("u16") || n.eq("u32") || n.eq("u64") || n.eq("u128") || n.eq("u256") {
        return true;
    }
    if n.eq("usize") || n.eq("isize") {
        return true;
    }
    return false;
}

fn is_bool_type(t: *Type) -> bool {
    if t == null {
        return false;
    }
    return t.kind == TY_NAMED && t.name.eq("bool");
}

// `for x in <init>` lowers to `let __glide_iter_N = <init>;` plus an index
// loop that calls `.len()` / `.get()` on it. Iterating a scalar (the classic
// `for i in v.len()` mistake) used to slip past the typer and only blow up at
// link time with an undefined `__glide_int_len`. True when `<init>` is a
// scalar — by inferred type, or, when inference fails (imported `.len()`),
// by recognising a length/count call or a numeric literal syntactically.
fn _foreach_scalar_misuse(val_ty: *Type, init: *Expr) -> bool {
    if is_int_type(val_ty) || is_float_type(val_ty) || is_bool_type(val_ty) {
        return true;
    }
    if init == null {
        return false;
    }
    if init.kind == EX_INT || init.kind == EX_FLOAT {
        return true;
    }
    if is_unknown_type(val_ty) && init.kind == EX_CALL && init.lhs != null && init.lhs.kind == EX_MEMBER && init.lhs.field != null {
        let m: string = init.lhs.field;
        if m.eq("len") || m.eq("count") || m.eq("size") {
            return true;
        }
    }
    return false;
}

// Underline width for an iterable expression so the squiggle covers the whole
// thing instead of just its first byte. Handles `recv.method()` via the parsed
// member field column; falls back to `_arg_span` for idents / literals.
fn _iter_expr_span(e: *Expr) -> i32 {
    if e == null {
        return 1;
    }
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.field != null && e.lhs.field_col > 0 {
        let w: i32 = e.lhs.field_col - e.column + e.lhs.field.len() + 2;
        if w > 0 {
            return w;
        }
    }
    return _arg_span(e);
}

fn is_unknown_type(t: *Type) -> bool {
    if t == null {
        return true;
    }
    return t.kind == TY_NAMED && t.name.eq("__unknown__");
}

// True if `t` (recursively) names any of the strings in `names`. Used to
// detect still-generic return types after impl-param subst so we fall back
// to null (permissive) instead of surfacing an unresolved `T` upstream.
// Infer method-level type-params (`<U>` on `fn fold<U>(init: U, f: fn(U,T) -> U) -> U`)
// from the call's args, then substitute them into the return type. `params_after_self`
// is the method's param list with the implicit self stripped; `arg_types` is the inferred
// type of each user-supplied arg in lockstep. Returns the rewritten return type.
//
// Without this, calling `v.fold(0, _add)` on `*Vector<int>` returns the literal `U` named
// type — the owner-type subst above only handles the impl block's `<T>`, not the method's
// own `<U>`. `extract_for_var` walks each (param, arg) pair to locate U's concrete binding.
fn _infer_method_tparams(ret: *Type, method_tparams: *Vector<string>, params_after_self: *Vector<Param>, arg_types: *Vector<*Type>) -> *Type {
    if ret == null || method_tparams == null || method_tparams.len() == 0 {
        return ret;
    }
    if params_after_self == null || arg_types == null {
        return ret;
    }
    let plen: i32 = params_after_self.len();
    let alen: i32 = arg_types.len();
    let n: i32 = if plen < alen { plen } else { alen };
    let names: *Vector<string> = Vector::new();
    let bound: *Vector<Type> = Vector::new();
    for let ti: i32 = 0; ti < method_tparams.len(); ti++ {
        let tp_name: string = method_tparams.get(ti);
        let mut concrete: *Type = null;
        for let i: i32 = 0; i < n; i++ {
            let p: Param = params_after_self.get(i);
            let at: *Type = arg_types.get(i);
            if p.ty == null || at == null {
                continue;
            }
            let extracted: *Type = extract_for_var(p.ty, at, tp_name);
            if extracted != null {
                concrete = extracted;
                break;
            }
        }
        if concrete != null {
            names.push(tp_name);
            bound.push(*concrete);
        }
    }
    if names.len() == 0 {
        return ret;
    }
    return _subst_type_local(ret, names, bound);
}

fn _type_references_any(t: *Type, names: *Vector<string>) -> bool {
    if t == null || names == null {
        return false;
    }
    if t.kind == TY_NAMED {
        for let i: i32 = 0; i < names.len(); i++ {
            if t.name.eq(names.get(i)) {
                return true;
            }
        }
        return false;
    }
    if t.inner != null && _type_references_any(t.inner, names) {
        return true;
    }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            if _type_references_any(&a, names) {
                return true;
            }
        }
    }
    return false;
}

// Head of a type, used by the hint gate: "Json<Res>" -> "Json", "*Foo" ->
// "Foo", "!int" -> "Result", "?int" -> "Option", "?!int" -> "OptResult".
fn _type_head_name(t: *Type) -> string {
    if t == null {
        return "";
    }
    if t.kind == TY_POINTER || t.kind == TY_BORROW || t.kind == TY_BORROW_MUT {
        return _type_head_name(t.inner);
    }
    if t.kind == TY_RESULT {
        return "Result";
    }
    if t.kind == TY_OPTION {
        return "Option";
    }
    if t.kind == TY_OPT_RESULT {
        return "OptResult";
    }
    if t.kind == TY_NAMED {
        return t.name;
    }
    if t.kind == TY_GENERIC {
        return t.name;
    }
    return "";
}

// Comma-joined membership test. "Json,Result" contains "Json" -> true.
fn _csv_contains(csv: string, needle: string) -> bool {
    if csv == null || csv.eq("") {
        return false;
    }
    let n: i32 = csv.len();
    let mut start: i32 = 0;
    let mut i: i32 = 0;
    while i <= n {
        let at_end: bool = i == n;
        let mut sep: bool = at_end;
        if !at_end {
            if csv.at(i).to_int() == 44 {
                sep = true;
            }
        }
        if sep {
            let seg: string = csv.substring(start, i);
            if seg.eq(needle) {
                return true;
            }
            start = i + 1;
        }
        i = i + 1;
    }
    return false;
}

// Replace every `%key%` in `tpl` with `value`. We use `%...%` (not the
// usual `${...}`) because the Glide lexer parses `${expr}` as a string-
// interpolation macro and synthesises an EX_MACRO call on attribute
// args — which trips the EX_STRING check upstream.
fn _tpl_replace(tpl: string, key: string, value: string) -> string {
    if tpl == null || tpl.eq("") {
        return tpl;
    }
    let pat: string = "%".concat(key).concat("%");
    let pl: i32 = pat.len();
    let tl: i32 = tpl.len();
    let mut out: string = "";
    let mut i: i32 = 0;
    while i < tl {
        if i + pl <= tl && tpl.substring(i, i + pl).eq(pat) {
            out = out.concat(value);
            i = i + pl;
        } else {
            out = out.concat(tpl.substring(i, i + 1));
            i = i + 1;
        }
    }
    return out;
}

// Param count of a fn / fn-ptr type. -1 for non-fnptr.
fn _fnptr_arity(t: *Type) -> i32 {
    if t == null || t.kind != TY_FNPTR {
        return -1;
    }
    if t.args == null {
        return 0;
    }
    return t.args.len();
}

// True if the `got_param_shape` gate accepts `got`'s arity. Supported
// values: "" (any), "0", "1+".
fn _param_shape_ok(shape: string, got: *Type) -> bool {
    if shape == null || shape.eq("") {
        return true;
    }
    let n: i32 = _fnptr_arity(got);
    if n < 0 {
        return true;
    }
    if shape.eq("0") {
        return n == 0;
    }
    if shape.eq("1+") {
        return n >= 1;
    }
    if shape.eq("any") {
        return true;
    }
    return true;
}

// If `want` is a fn-ptr whose return type matches a registered
// `@suggest_for_fnptr` hint, return the hint message prefixed with
// `\n  hint: `. Empty when there's no match. Lets proc-macro authors
// surface "annotate with @handler" (or similar) when a user passes
// a raw fn where a wrapped fn-ptr was expected.
//
// Message template supports `${want}` / `${got}` / `${want_ret}` /
// `${got_ret}` / `${got_name}` placeholders that the typer fills in
// at emit time. Optional `@suggest_when_got_returns` /
// `@suggest_when_got_params` companion attrs gate the hint to user
// fns the proc-macro can actually wrap.
fn _fnptr_hint(t: *Typer, want: *Type, got: *Type, got_name: string) -> string {
    if t == null || want == null {
        return "";
    }
    if want.kind != TY_FNPTR {
        return "";
    }
    if want.fnptr_ret == null {
        return "";
    }
    if want.fnptr_ret.kind != TY_NAMED {
        return "";
    }
    if t.fnptr_hints == null {
        return "";
    }
    let ret_name: string = want.fnptr_ret.name;
    let got_ret_head: string = if got != null && got.kind == TY_FNPTR && got.fnptr_ret != null { _type_head_name(got.fnptr_ret) } else { "" };
    for let i: i32 = 0; i < t.fnptr_hints.len(); i++ {
        let h: FnptrHint = t.fnptr_hints.get(i);
        if !h.ret_type_name.eq(ret_name) {
            continue;
        }
        // Got-side gate: optional return-head allow list.
        if !h.got_ret_heads.eq("") && !got_ret_head.eq("") {
            if !_csv_contains(h.got_ret_heads, got_ret_head) {
                continue;
            }
        }
        // Got-side gate: optional param-shape constraint.
        if !_param_shape_ok(h.got_param_shape, got) {
            continue;
        }
        // Substitute placeholders.
        let want_str: string = type_to_string(want);
        let got_str: string = if got != null { type_to_string(got) } else { "" };
        let want_ret_str: string = type_to_string(want.fnptr_ret);
        let got_ret_str: string = if got != null && got.kind == TY_FNPTR && got.fnptr_ret != null { type_to_string(got.fnptr_ret) } else { "" };
        let mut msg: string = h.message;
        msg = _tpl_replace(msg, "want", want_str);
        msg = _tpl_replace(msg, "got", got_str);
        msg = _tpl_replace(msg, "want_ret", want_ret_str);
        msg = _tpl_replace(msg, "got_ret", got_ret_str);
        msg = _tpl_replace(msg, "got_name", got_name);
        return "\n  hint: ".concat(msg);
    }
    return "";
}

// Minimal subst for method-call return-type inference. Walks the type tree
// and rewrites any TY_NAMED whose name appears in `params` with the
// corresponding entry of `args`. Mirrors codegen's `subst_type` for just
// the shapes we hit during inference.
fn _subst_type_local(t: *Type, params: *Vector<string>, args: *Vector<Type>) -> *Type {
    if t == null {
        return null;
    }
    if t.kind == TY_NAMED && params != null {
        for let i: i32 = 0; i < params.len(); i++ {
            if t.name.eq(params.get(i)) {
                let a: Type = args.get(i);
                let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *p = a;
                return p;
            }
        }
        return t;
    }
    if t.kind == TY_POINTER {
        return ty_pointer(_subst_type_local(t.inner, params, args));
    }
    if t.kind == TY_RESULT {
        return ty_result(_subst_type_local(t.inner, params, args));
    }
    if t.kind == TY_OPTION {
        return ty_option(_subst_type_local(t.inner, params, args));
    }
    if t.kind == TY_OPT_RESULT {
        return ty_optres(_subst_type_local(t.inner, params, args));
    }
    if t.kind == TY_BORROW {
        let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW;
        p.inner = _subst_type_local(t.inner, params, args);
        return p;
    }
    if t.kind == TY_BORROW_MUT {
        let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW_MUT;
        p.inner = _subst_type_local(t.inner, params, args);
        return p;
    }
    if t.kind == TY_GENERIC {
        let new_args: *Vector<Type> = Vector::new();
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                let sa: *Type = _subst_type_local(&a, params, args);
                if sa != null {
                    new_args.push(*sa);
                }
            }
        }
        return ty_generic(t.name, new_args);
    }
    if t.kind == TY_TUPLE {
        let new_args: *Vector<Type> = Vector::new();
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                let sa: *Type = _subst_type_local(&a, params, args);
                if sa != null {
                    new_args.push(*sa);
                }
            }
        }
        return ty_tuple(new_args);
    }
    return t;
}

pub fn types_compat(want: *Type, got: *Type) -> bool {
    // If either side couldn't be inferred (the typer is permissive and many
    // expressions still return null), don't pretend it's a mismatch — that
    // would flood callers with cascading false-positive diagnostics.
    if want == null || got == null {
        return true;
    }
    if is_unknown_type(want) || is_unknown_type(got) {
        return true;
    }
    if type_eq(want, got) {
        return true;
    }
    // A bare generic-struct literal (`Box { … }` / `Json { … }`) infers as the
    // un-parameterized name (`Box` / `Json`), but its declared/return/field type
    // is `Box<T>` / `Json<T>`. Same base name => compatible; the literal's type
    // args are inferred from its field values, not a real mismatch.
    if want.kind == TY_GENERIC && got.kind == TY_NAMED && want.name.eq(got.name) {
        return true;
    }
    if want.kind == TY_NAMED && got.kind == TY_GENERIC && want.name.eq(got.name) {
        return true;
    }
    if is_int_type(want) && is_int_type(got) {
        return true;
    }
    if is_float_type(want) && is_float_type(got) {
        return true;
    }
    // *T <-> *void (libc malloc/calloc result, plus the type of `null`).
    // Must run BEFORE the structural pointer recursion below; otherwise the
    // recursion compares Stmt vs void at the leaf and returns false.
    if want.kind == TY_POINTER && got.kind == TY_POINTER {
        if want.inner != null && want.inner.kind == TY_NAMED && want.inner.name.eq("void") {
            return true;
        }
        if got.inner != null && got.inner.kind == TY_NAMED && got.inner.name.eq("void") {
            return true;
        }
    }
    // *T <-> &T <-> &mut T are interconvertible.
    if (want.kind == TY_POINTER || want.kind == TY_BORROW || want.kind == TY_BORROW_MUT) && (got.kind == TY_POINTER || got.kind == TY_BORROW || got.kind == TY_BORROW_MUT) {
        return types_compat(want.inner, got.inner);
    }
    // Tuples: same arity, element-wise compatible (so int-literal widening
    // through `(1, 2): (i64, i64)` doesn't read as a mismatch).
    if want.kind == TY_TUPLE && got.kind == TY_TUPLE {
        let wn: i32 = if want.args != null { want.args.len() } else { 0 };
        let gn: i32 = if got.args != null { got.args.len() } else { 0 };
        if wn != gn {
            return false;
        }
        for let i: i32 = 0; i < wn; i++ {
            let we: Type = want.args.get(i);
            let ge: Type = got.args.get(i);
            if !types_compat(&we, &ge) {
                return false;
            }
        }
        return true;
    }
    return false;
}

// True when `ty` is a "plain" named type, or a pointer/borrow chain ending in
// one — excluding generics (`Vector<T>`), tuples, option/result wrappers,
// fn-pointers, and the typer's placeholder names. Struct-literal field-value
// checking compares ONLY these, so it never false-positives on a `Vector<T>`,
// a `?T`, an unresolved (`__unknown__`) value, or a `Self`/generic field.
fn _struct_field_checkable(ty: *Type) -> bool {
    if ty == null {
        return false;
    }
    let mut b: *Type = ty;
    while b != null && (b.kind == TY_POINTER || b.kind == TY_BORROW || b.kind == TY_BORROW_MUT) {
        b = b.inner;
    }
    if b == null || b.kind != TY_NAMED {
        return false;
    }
    let n: string = b.name;
    if n.eq("__unknown__") || n.eq("__fn__") || n.eq("__error__") || n.eq("Self") || n.eq("void") {
        return false;
    }
    return true;
}

// ---- function signatures -------------------------------------------------
pub struct FnSig {
    pub name: string,
    pub params: *Vector<Param>,
    pub ret_type: *Type,
    pub owned_return: bool, // fn returns one of its own struct-literal auto-drop locals (move-out)
    pub is_variadic: bool, // C-style trailing `...` (extern fn printf etc.)
    // Generic type parameter names (e.g. `["T", "U"]`) and their `+`-joined
    // trait bounds in lockstep (`["Ord+Clone", ""]`). Both are null/empty
    // for non-generic fns. Used by EX_CALL to enforce bounds at the call
    // site after inferring the concrete type for each T from the args.
    pub type_params: *Vector<string>,
    pub type_param_bounds: *Vector<string>,
    // For impl methods: the owning impl block's `<T, U>` (separate from the
    // method's own `type_params` — usually empty). Lets method-call type
    // inference substitute `T` in the return type using the receiver's
    // concrete args (`*Vector<int>.get()` -> int, not T).
    pub owner_type_params: *Vector<string>,
    // Declaration site of the fn, so an unsatisfied-bound error can point
    // "`T: Trait` bound declared here" via relatedInformation.
    pub decl_origin: string,
    pub decl_line: i32,
    pub decl_col: i32,
}

// ---- typer state ---------------------------------------------------------
pub struct BorrowEvent {
    pub source: string,
    pub is_mut: bool,
    // The let-binder that holds this borrow (`r` in `let r = &x`). Used
    // by NLL kill-after-last-use: a block walker scans the remaining
    // stmts after each step; an event whose binder no longer appears is
    // dropped so subsequent mutation of `source` is allowed.
    pub binder: string,
    // Where the borrow was taken, so an overlap-borrow error can point
    // "`x` was first borrowed here" via relatedInformation.
    pub line: i32,
    pub col: i32,
}

// Severity levels match LSP's DiagnosticSeverity:
//   1 = error, 2 = warning, 3 = information, 4 = hint
pub struct DiagEntry {
    pub line: i32,
    pub col: i32,
    pub end_line: i32,
    pub end_col: i32,
    pub severity: i32,
    pub code: string, // stable identifier (e.g. "unused-var", "type-mismatch")
    pub message: string,
    pub origin: string, // source file path (set from t.current_origin)
    pub tag: i32, // 0 = none, 1 = Unnecessary (faded), 2 = Deprecated (struck-through)
    // Optional mechanical fix. `fix_replacement` is the text to splice
    // in over the range `(fix_line, fix_col)..(fix_end_line, fix_end_col)`.
    // Zero-width range (start == end) is an insertion. Empty
    // replacement on a non-zero range is a deletion. Empty
    // replacement on a zero-width range means the diagnostic has no
    // mechanical fix and `glide fix` skips it.
    pub fix_line: i32,
    pub fix_col: i32,
    pub fix_end_line: i32,
    pub fix_end_col: i32,
    pub fix_replacement: string,
}

// A secondary "this is why" location attached to a diagnostic, surfaced as
// LSP relatedInformation. Kept in a side-vector keyed by the diagnostic's
// index (rather than embedded in DiagEntry) so the many DiagEntry literals
// don't all need new fields.
pub struct DiagRelated {
    pub diag_index: i32, // index into Typer.diagnostics this explains
    pub origin: string, // source file of the related location
    pub line: i32,
    pub col: i32,
    pub end_line: i32,
    pub end_col: i32,
    pub message: string, // e.g. "trait method `foo` declared here"
}

pub struct Typer {
    pub fns: *HashMap<FnSig>,
    pub structs: *HashMap<bool>, // just registry of names for now
    // `<TypeName>::<method>` -> true for every method declared in ANY impl
    // (generic OR specialized) of that type. Lets "no method" detection
    // tell a real typo from a specialized method (`Vector<int>::sum`) whose
    // exact monomorphized key the receiver type didn't resolve to.
    pub method_names: *HashMap<bool>,
    // `<StructName>::<field>` -> true for every declared field. Drives
    // "no field" detection for `obj.field` reads on known structs.
    pub struct_fields_all: *HashMap<bool>,
    // `<StructName>::<field>` -> declared field Type. Drives struct-literal
    // field-value type checking (pointer-vs-value, wrong-struct mismatches).
    pub struct_field_types: *HashMap<Type>,
    // Struct names that declare `<T, ...>` type params. Their field types can
    // reference those params, so literal field-value checking is skipped for
    // them (no monomorphization at this stage) to avoid false positives.
    pub struct_generic: *HashMap<bool>,
    pub scope: *HashMap<Type>, // current scope: name -> Type (heap-alloc'd)
    pub module_scope: *HashMap<Type>, // top-level consts (visible inside any fn body)
    // Freestanding / kernel build: also register top-level `let` globals in
    // module_scope so fn bodies can read/write them (a kernel needs mutable
    // global state). Set from the build before check_program runs.
    pub freestanding: bool,
    pub owned_locals: *HashMap<bool>, // names that must not escape (auto-drop)
    // Local `*Arena` bindings declared in the current fn body. Anything
    // allocated from one of these can't escape via return - the caller
    // would read freed memory after this fn's `defer arena.free()` ran.
    // Params and globals never enter this map; their lifetimes are the
    // caller's problem.
    pub arena_locals: *HashMap<bool>,
    // Per-name: the arena ident this value derives from (only populated
    // when the source arena is currently local). `let p: *T = a.create(T)`
    // sets arena_origin[p] = "a"; return p then triggers the escape
    // check against arena_locals.
    pub arena_origin: *HashMap<string>,
    // Names that have had a `.free()` (or similar consume) call against
    // them in the current fn body. Subsequent reads error with
    // `use-after-free`.
    pub consumed_locals: *HashMap<bool>,
    // Owned locals moved out (assigned / stored / passed). Also recorded in
    // consumed_locals (which drives the read-after error + branch handling);
    // this parallel set only distinguishes the message: `use-after-move` vs
    // `use-after-free`.
    pub moved_out: *HashMap<bool>,
    // Locals bound to an owned-returning call (`let x = make()`). Tracked apart
    // from owned_locals so the `owned-move` lint is unaffected; used to flag
    // use-after-move when such a local is later assigned away.
    pub call_owned: *HashMap<bool>,
    pub borrows: *Vector<BorrowEvent>, // active let-bound borrows; save/restore per block
    pub current_ret: *Type,
    // Type parameters of the enclosing fn (e.g. `["T", "U"]`). Used by
    // EX_PATH resolution: `T::method(v)` is valid inside a `<T: Trait>`
    // body when T is one of these. Null/empty outside any generic fn.
    pub current_type_params: *Vector<string>,
    // Impl-body checking. impl_type_params holds the enclosing `impl<T>`'s own
    // type params so they're in scope inside its methods. demote_errors turns
    // method-body errors into warnings: impl bodies were never type-checked, so
    // emitting the backlog as hard errors would break the self-host; warnings
    // let the issues surface and get fixed before promoting them to errors.
    pub impl_type_params: *Vector<string>,
    pub demote_errors: bool,
    pub current_origin: string, // file the typer is currently checking
    // LSP-only: when set to the edited file's path, check_program skips the
    // BODY typecheck of functions from OTHER (imported) files — their
    // diagnostics are discarded at publish anyway, and registration
    // (_canon_decls / pre_register / build_visibility) is still whole-program,
    // so cross-file resolution is unchanged. Empty ("") = full checking (CLI).
    pub user_origin: string,
    // Per-file visibility: `<origin>::<name>` -> bool. A name is visible
    // from file `F` only if it appears in `F`'s visibility set. Selective
    // imports (`import a::b::c::Item;`) populate this; src/builtins/ pub
    // names are added to every file's set so they act as a prelude.
    pub visibility: *HashMap<bool>,
    // Per-file module aliases: `<origin>::<short>` -> bool. Populated by
    // `import a::b::c;` (pure module import) - the short name `c` becomes
    // a callable namespace from inside `<origin>`. Used by EX_PATH
    // enforcement to allow `c::Item(...)` while rejecting unimported
    // partial paths.
    pub module_imports: *HashMap<bool>,
    // Set of every loaded file's full module path (e.g. `stdlib::math`).
    // Always-allowed for fully qualified path expressions even without an
    // explicit import.
    pub module_full_paths: *HashMap<bool>,
    // Field-level pub map: key `<struct>::<field>` -> true if the field
    // was declared with `pub`. Missing entry = private.
    pub field_pub: *HashMap<bool>,
    pub struct_has_private: *HashMap<bool>, // struct name -> has >=1 non-pub field
    // Where each struct was declared, so we know whether a `obj.field`
    // access is happening inside the struct's own file (always allowed)
    // or from another file (then `field_pub` enforces).
    pub struct_origin: *HashMap<string>,
    // Whether visibility enforcement is active for this run. Off by default
    // so existing files that haven't been migrated keep compiling; the
    // compiler entry point flips it on when the user-facing build runs.
    pub enforce_visibility: bool,
    // Set of `<trait>::<type>` keys for every `impl Trait for Type` in the
    // program. Built up front in pre_register and consulted to verify
    // `<T: Trait>` bounds at call sites.
    pub impl_set: *HashMap<bool>,
    // Associated-type lookup: `<Trait>::<TargetTypeName>::<AssocName>` -> Type.
    // Populated alongside impl_set. Consulted to resolve `T::Item` projections
    // when T has a trait bound and a concrete impl is in scope.
    pub assoc_table: *HashMap<Type>,
    // Enum exhaustiveness: enum name -> comma-joined variant names. Built in
    // pre_register; consulted by ST_MATCH check to flag uncovered variants.
    pub enums: *HashMap<string>,
    pub error_count: i32,
    pub diagnostics: *Vector<DiagEntry>,
    // Related "why" locations, keyed by diagnostic index. See DiagRelated.
    pub related: *Vector<DiagRelated>,
    // Proc-macro authors can attach `@suggest_for_fnptr(RetType, "msg")`
    // to their impl fn so any fn-ptr-arg mismatch whose expected return
    // type matches `RetType` gets the hint appended. Lets `@handler` say
    // "annotate with @handler" without baking HTTP knowledge into the
    // typer.
    pub fnptr_hints: *Vector<FnptrHint>,
}

pub struct FnptrHint {
    pub ret_type_name: string,
    pub message: string,
    // Optional gate: comma-joined list of return-type heads the GOT fn
    // can have for this hint to fire. e.g. `"Json,Result,Option"` means
    // "only show this hint if the user's fn returns Json<T>, !T, or ?T".
    // Empty string = always fire on want-side match.
    pub got_ret_heads: string,
    // Optional gate: comma-joined list of param-shape requirements.
    // For now we support simple counts: `"0"`, `"any"`, `"1+"`. The
    // typer's matcher decides; default = always match.
    pub got_param_shape: string,
}

// Free helper: looks up `name` in the enclosing fn's type parameter
// list. Used by EX_PATH resolution to allow `T::method(v)` when T is
// a generic type parameter — the actual concrete type is substituted
// later at monomorphization time.
fn _is_current_type_param(t: *Typer, name: string) -> bool {
    if name == null || name.eq("") {
        return false;
    }
    if t.current_type_params != null {
        for let i: i32 = 0; i < t.current_type_params.len(); i++ {
            if t.current_type_params.get(i).eq(name) {
                return true;
            }
        }
    }
    // Also the enclosing impl's own type params, in scope inside its methods.
    if t.impl_type_params != null {
        for let i: i32 = 0; i < t.impl_type_params.len(); i++ {
            if t.impl_type_params.get(i).eq(name) {
                return true;
            }
        }
    }
    return false;
}

// Line/col of a member expression's field name, falling back to the
// expression start when the parser didn't record a field position (a
// member node synthesized by lowering/codegen has field_line == 0).
fn _field_pos_line(m: *Expr) -> i32 {
    if m == null {
        return 0;
    }
    if m.field_line > 0 {
        return m.field_line;
    }
    return m.line;
}

fn _field_pos_col(m: *Expr) -> i32 {
    if m == null {
        return 0;
    }
    if m.field_line > 0 {
        return m.field_col;
    }
    return m.column;
}

// A reasonable squiggle width for an argument expression: the identifier
// length for a bare name (so the underline covers the whole name), else 1
// (point at the start). Keeps arg diagnostics tight without needing the
// full source extent of arbitrary expressions.
fn _arg_span(a: *Expr) -> i32 {
    if a == null {
        return 1;
    }
    if a.kind == EX_IDENT && a.str_val != null {
        let n: i32 = a.str_val.len();
        if n > 0 {
            return n;
        }
    }
    if a.kind == EX_STRING && a.str_val != null {
        return a.str_val.len() + 2; // include the surrounding quotes
    }
    return 1;
}

// Count `{}` placeholders in a `format!` string. Mirrors codegen's lowering
// exactly: a `{` immediately followed by `}` is one hole (consuming one arg),
// scanning advances past both; everything else is a literal char. There is no
// `{{` escape — codegen emits a lone `{` verbatim.
fn _count_fmt_placeholders(raw: string) -> i32 {
    if raw == null {
        return 0;
    }
    let n: i32 = raw.len();
    let mut i: i32 = 0;
    let mut count: i32 = 0;
    while i < n {
        if raw.at(i).to_int() == 123 && i + 1 < n && raw.at(i + 1).to_int() == 125 {
            count = count + 1;
            i = i + 2;
        } else {
            i = i + 1;
        }
    }
    return count;
}

// True when `n` names a real type: a primitive (list mirrors codegen's
// `type_to_c`), a declared struct/enum (t.structs holds both), a type
// parameter in scope, or `Self`. Empty = inferred, treated as known.
fn _is_known_type_name(t: *Typer, n: string) -> bool {
    if n == null || n.eq("") {
        return true;
    }
    if n.eq("Self") || n.eq("__fn__") || n.eq("__fn_ptr__") {
        return true;
    }
    if n.eq("i8") || n.eq("i16") || n.eq("i32") || n.eq("i64") || n.eq("u8") || n.eq("u16") || n.eq("u32") || n.eq("u64") || n.eq("i128") || n.eq("u128") || n.eq("i256") || n.eq("u256") || n.eq("usize") || n.eq("isize") || n.eq("f32") || n.eq("f64") || n.eq("bool") || n.eq("char") || n.eq("string") || n.eq("void") {
        return true;
    }
    if t.structs.contains(n) {
        return true;
    }
    if _is_current_type_param(t, n) {
        return true;
    }
    return false;
}

// Byte-level Levenshtein edit distance. Used to suggest the closest known
// name on an "unknown X" error. Names are short, so the O(la*lb) cost is
// negligible.
fn _edit_distance(a: string, b: string) -> i32 {
    let la: i32 = a.len();
    let lb: i32 = b.len();
    if la == 0 {
        return lb;
    }
    if lb == 0 {
        return la;
    }
    let prev: *Vector<i32> = Vector::with_cap(lb + 1);
    defer prev.free();
    let cur: *Vector<i32> = Vector::with_cap(lb + 1);
    defer cur.free();
    for let j: i32 = 0; j <= lb; j++ {
        prev.push(j);
        cur.push(0);
    }
    for let i: i32 = 1; i <= la; i++ {
        cur.set(0, i);
        let ca: i32 = a.at(i - 1).to_int();
        for let j: i32 = 1; j <= lb; j++ {
            let cb: i32 = b.at(j - 1).to_int();
            let mut cost: i32 = 1;
            if ca == cb {
                cost = 0;
            }
            let del: i32 = prev.get(j) + 1;
            let ins: i32 = cur.get(j - 1) + 1;
            let sub: i32 = prev.get(j - 1) + cost;
            let mut m: i32 = del;
            if ins < m {
                m = ins;
            }
            if sub < m {
                m = sub;
            }
            cur.set(j, m);
        }
        for let j: i32 = 0; j <= lb; j++ {
            prev.set(j, cur.get(j));
        }
    }
    return prev.get(lb);
}

// The closest candidate to `target`, or "" when nothing is close enough. The
// threshold scales with length so short names need an almost-exact hit (avoids
// noisy suggestions). Caller owns `cands` (this does not free it).
fn _closest_name(target: string, cands: *Vector<string>) -> string {
    if target == null || target.eq("") || cands == null {
        return "";
    }
    let mut best: string = "";
    let mut bestd: i32 = 99;
    for let i: i32 = 0; i < cands.len(); i++ {
        let c: string = cands.get(i);
        if c == null || c.eq("") || c.eq(target) {
            continue;
        }
        let d: i32 = _edit_distance(target, c);
        if d < bestd {
            bestd = d;
            best = c;
        }
    }
    let mut lim: i32 = target.len() / 2;
    if lim < 1 {
        lim = 1;
    }
    if lim > 2 {
        lim = 2;
    }
    if best.eq("") || bestd > lim {
        return "";
    }
    return best;
}

// `; did you mean `X`?` for the closest candidate, or "" when none is close.
fn _did_you_mean(target: string, cands: *Vector<string>) -> string {
    let c: string = _closest_name(target, cands);
    if c.eq("") {
        return "";
    }
    return "; did you mean `".concat(c).concat("`?");
}

// The replacement a `glide fix` / quick-fix should splice in for an unknown
// type `n`: a retired C-style spelling maps to its canonical form, otherwise
// the closest known type name (or "" when nothing is close).
fn _type_fix_target(t: *Typer, n: string) -> string {
    if n.eq("int") {
        return "i32";
    }
    if n.eq("uint") {
        return "u32";
    }
    if n.eq("long") {
        return "i64";
    }
    if n.eq("ulong") {
        return "u64";
    }
    if n.eq("float") {
        return "f64";
    }
    let c: *Vector<string> = _type_candidates(t);
    defer c.free();
    return _closest_name(n, c);
}

// Candidate type names: the primitives plus every registered struct/enum name.
fn _type_candidates(t: *Typer) -> *Vector<string> {
    let v: *Vector<string> = Vector::new();
    v.push("i8");
    v.push("i16");
    v.push("i32");
    v.push("i64");
    v.push("u8");
    v.push("u16");
    v.push("u32");
    v.push("u64");
    v.push("i128");
    v.push("u128");
    v.push("usize");
    v.push("isize");
    v.push("f32");
    v.push("f64");
    v.push("bool");
    v.push("char");
    v.push("string");
    v.push("void");
    if t.structs != null {
        let ks: *Vector<string> = t.structs.keys();
        for let i: i32 = 0; i < ks.len(); i++ {
            v.push(ks.get(i));
        }
        ks.free();
    }
    return v;
}

// Candidate value names in scope: locals/params, module consts, and fns.
fn _name_candidates(t: *Typer) -> *Vector<string> {
    let v: *Vector<string> = Vector::new();
    if t.scope != null {
        let a: *Vector<string> = t.scope.keys();
        for let i: i32 = 0; i < a.len(); i++ {
            v.push(a.get(i));
        }
        a.free();
    }
    if t.module_scope != null {
        let b: *Vector<string> = t.module_scope.keys();
        for let i: i32 = 0; i < b.len(); i++ {
            v.push(b.get(i));
        }
        b.free();
    }
    if t.fns != null {
        let c: *Vector<string> = t.fns.keys();
        for let i: i32 = 0; i < c.len(); i++ {
            v.push(c.get(i));
        }
        c.free();
    }
    return v;
}

// Candidate field names of struct `sname` (from the `Struct::field` registry).
fn _field_candidates(t: *Typer, sname: string) -> *Vector<string> {
    let v: *Vector<string> = Vector::new();
    if t.struct_fields_all == null {
        return v;
    }
    let pfx: string = sname.concat("::");
    let pl: i32 = pfx.len();
    let ks: *Vector<string> = t.struct_fields_all.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if k.len() > pl && k.substring(0, pl).eq(pfx) {
            v.push(k.substring(pl, k.len()));
        }
    }
    ks.free();
    return v;
}

// `unknown type `X`` message, with a `; use `iN`` hint when `X` is a retired
// C-style numeric spelling, or a `; did you mean `Y`?` suggestion otherwise.
fn _unknown_type_msg(t: *Typer, n: string) -> string {
    let msg: string = "unknown type `".concat(n).concat("`");
    let mut hint: string = "";
    if n.eq("int") {
        hint = "i32";
    }
    if n.eq("uint") {
        hint = "u32";
    }
    if n.eq("long") {
        hint = "i64";
    }
    if n.eq("ulong") {
        hint = "u64";
    }
    if n.eq("float") {
        hint = "f64";
    }
    if !hint.eq("") {
        return msg.concat("; use `").concat(hint).concat("`");
    }
    let cands: *Vector<string> = _type_candidates(t);
    defer cands.free();
    return msg.concat(_did_you_mean(n, cands));
}

// Emit an "unknown type" error spanning `n` at (line, col), attaching a quick
// fix that replaces the name when there's a confident suggestion (retired
// C-style spelling or a close known type). The editor surfaces it as a
// one-click "Change to `X`" action, and `glide fix` applies it.
fn _emit_unknown_type(t: *Typer, n: string, line: i32, col: i32) {
    let msg: string = _unknown_type_msg(t, n);
    let repl: string = _type_fix_target(t, n);
    let span: i32 = n.len();
    if repl.eq("") {
        t.err_code_range(line, col, span, "unknown-type", msg);
    } else {
        t.err_code_range_fix(line, col, span, "unknown-type", msg, line, col, line, col + span, repl);
    }
}

// Recursively flag any unknown named type inside an annotation. `dyn`
// and fn-pointer shapes are skipped — trait names + fn-shape params live
// outside the struct/primitive registries, so checking them would
// false-flag. Only runs under enforce_visibility (full registry loaded).
fn _check_type_known(t: *Typer, ty: *Type, line: i32, col: i32) {
    if ty == null {
        return;
    }
    if !t.enforce_visibility {
        return;
    }
    // Prefer the type's own recorded position (set by the parser) so the
    // squiggle lands exactly on the type name; fall back to the caller's
    // position for synthesized types that carry none.
    let mut pl: i32 = line;
    let mut pc: i32 = col;
    if ty.line > 0 {
        pl = ty.line;
        pc = ty.col;
    }
    if ty.kind == TY_NAMED {
        if !_is_known_type_name(t, ty.name) {
            _emit_unknown_type(t, ty.name, pl, pc);
        }
        return;
    }
    if ty.kind == TY_POINTER || ty.kind == TY_BORROW || ty.kind == TY_BORROW_MUT || ty.kind == TY_SLICE {
        _check_type_known(t, ty.inner, line, col);
        return;
    }
    if ty.kind == TY_RESULT || ty.kind == TY_OPTION || ty.kind == TY_OPT_RESULT {
        _check_type_known(t, ty.inner, line, col);
        return;
    }
    if ty.kind == TY_TUPLE {
        if ty.args != null {
            for let i: i32 = 0; i < ty.args.len(); i++ {
                let a: Type = ty.args.get(i);
                _check_type_known(t, &a, line, col);
            }
        }
        return;
    }
    if ty.kind == TY_GENERIC {
        if !ty.name.eq("chan") && !t.structs.contains(ty.name) && !_is_current_type_param(t, ty.name) {
            _emit_unknown_type(t, ty.name, pl, pc);
        }
        if ty.args != null {
            for let i: i32 = 0; i < ty.args.len(); i++ {
                let a: Type = ty.args.get(i);
                _check_type_known(t, &a, line, col);
            }
        }
        return;
    }
}

impl Typer {
    pub fn new() -> *Typer {
        let t: *Typer = __glide_palloc(sizeof(Typer)) as *Typer;
        let fns: *HashMap<FnSig> = HashMap::new();
        let structs: *HashMap<bool> = HashMap::new();
        let method_names: *HashMap<bool> = HashMap::new();
        let struct_fields_all: *HashMap<bool> = HashMap::new();
        let scope: *HashMap<Type> = HashMap::new();
        let mscope: *HashMap<Type> = HashMap::new();
        let owned: *HashMap<bool> = HashMap::new();
        let ar_locals: *HashMap<bool> = HashMap::new();
        let ar_origin: *HashMap<string> = HashMap::new();
        let consumed: *HashMap<bool> = HashMap::new();
        let bw: *Vector<BorrowEvent> = Vector::new();
        let dg: *Vector<DiagEntry> = Vector::new();
        t.fns = fns;
        t.structs = structs;
        t.method_names = method_names;
        t.struct_fields_all = struct_fields_all;
        t.struct_field_types = HashMap::new();
        t.struct_generic = HashMap::new();
        t.scope = scope;
        t.module_scope = mscope;
        t.freestanding = false;
        t.owned_locals = owned;
        t.arena_locals = ar_locals;
        t.arena_origin = ar_origin;
        t.consumed_locals = consumed;
        t.moved_out = HashMap::new();
        t.call_owned = HashMap::new();
        t.borrows = bw;
        t.diagnostics = dg;
        let rel: *Vector<DiagRelated> = Vector::new();
        t.related = rel;
        t.current_ret = null;
        t.current_type_params = null;
        t.impl_type_params = null;
        t.demote_errors = false;
        t.current_origin = "";
        t.user_origin = "";
        let vis: *HashMap<bool> = HashMap::new();
        t.visibility = vis;
        let mi: *HashMap<bool> = HashMap::new();
        t.module_imports = mi;
        let mfp: *HashMap<bool> = HashMap::new();
        t.module_full_paths = mfp;
        let fp: *HashMap<bool> = HashMap::new();
        t.field_pub = fp;
        let shp: *HashMap<bool> = HashMap::new();
        t.struct_has_private = shp;
        let so: *HashMap<string> = HashMap::new();
        t.struct_origin = so;
        t.enforce_visibility = false;
        let is: *HashMap<bool> = HashMap::new();
        t.impl_set = is;
        let at: *HashMap<Type> = HashMap::new();
        t.assoc_table = at;
        let en: *HashMap<string> = HashMap::new();
        t.enums = en;
        t.error_count = 0;
        let fh: *Vector<FnptrHint> = Vector::new();
        t.fnptr_hints = fh;
        return t;
    }

    fn is_visible(self: *Typer, name: string) -> bool {
        if !self.enforce_visibility {
            return true;
        }
        if self.current_origin == null || self.current_origin.eq("") {
            return true;
        }
        if name == null || name.eq("") {
            return true;
        }
        let key: string = self.current_origin.concat("::").concat(name);
        return self.visibility.contains(key);
    }

    // True if `prefix` (the str_val of an EX_PATH) names a module the
    // current file is allowed to call into. Either the prefix matches
    // some loaded file's full module path (always allowed) OR the file
    // brought it into scope via `import x::y::<prefix>;`.
    fn is_module_path_allowed(self: *Typer, prefix: string) -> bool {
        if !self.enforce_visibility {
            return true;
        }
        if prefix == null || prefix.eq("") {
            return true;
        }
        if self.module_full_paths.contains(prefix) {
            return true;
        }
        if self.current_origin == null || self.current_origin.eq("") {
            return true;
        }
        let key: string = self.current_origin.concat("::").concat(prefix);
        return self.module_imports.contains(key);
    }

    // True when `name` is a module the current file imported (the short
    // alias from `import a::b::name;`) or a full module path. Independent of
    // `enforce_visibility`, unlike is_module_path_allowed.
    fn _is_imported_module(self: *Typer, name: string) -> bool {
        if name == null || name.eq("") {
            return false;
        }
        if self.module_full_paths.contains(name) {
            return true;
        }
        if self.current_origin == null || self.current_origin.eq("") {
            return false;
        }
        return self.module_imports.contains(self.current_origin.concat("::").concat(name));
    }

    // Strip a leading imported-module segment from a qualified prefix, so
    // `ip::SocketAddr` (module `ip` + type) resolves as the bare `SocketAddr`
    // via the normal type/method registry. Leaves non-module prefixes (a
    // bare `Type`, a type param) untouched.
    fn _strip_mod_prefix(self: *Typer, prefix: string) -> string {
        if prefix == null {
            return prefix;
        }
        let cc: i32 = prefix.index_of("::");
        if cc < 0 {
            return prefix;
        }
        let head: string = prefix.substring(0, cc);
        if !self._is_imported_module(head) {
            return prefix;
        }
        let rest: string = prefix.substring(cc + 2, prefix.len());
        return self._strip_mod_prefix(rest);
    }

    // Canonicalize a module-qualified type annotation to its bare global type,
    // in place. Glide types are not namespaced: `foo::Bar` (parsed as a
    // TY_ASSOC projection `Bar of foo`) names the SAME global struct as bare
    // `Bar`, but the parser keeps the module prefix, so type_eq and codegen
    // would treat them as distinct (and codegen lowers the stray TY_ASSOC to
    // `void`). Collapse `module::Bar` -> bare `Bar` while LEAVING a genuine
    // associated-type projection (`Self::Item`, `T::Item`, head not a module)
    // untouched. Recurses through pointer/borrow/option/result wrappers and
    // generic/tuple/fnptr element lists so `Vector<foo::Bar>`, `?foo::Bar`,
    // `(foo::A, foo::B)`, `fn(foo::A) -> foo::B` are all normalized.
    fn _canon_type(self: *Typer, ty: *Type) {
        if ty == null {
            return;
        }
        if ty.kind == TY_ASSOC {
            if ty.inner != null && ty.inner.kind == TY_NAMED && self._is_imported_module(ty.inner.name) {
                ty.kind = TY_NAMED;
                ty.inner = null;
                return;
            }
            self._canon_type(ty.inner);
            return;
        }
        if ty.kind == TY_NAMED {
            if ty.name != null && ty.name.index_of("::") >= 0 {
                ty.name = self._strip_mod_prefix(ty.name);
            }
            return;
        }
        if ty.inner != null {
            self._canon_type(ty.inner);
        }
        if ty.fnptr_ret != null {
            self._canon_type(ty.fnptr_ret);
        }
        if ty.args != null {
            for let i: i32 = 0; i < ty.args.len(); i++ {
                let a: Type = ty.args.get(i);
                self._canon_type(&a);
                ty.args.set(i, a);
            }
        }
    }

    // Canonicalize every type annotation on a fn signature (params + return).
    fn _canon_fn_sig(self: *Typer, s: *Stmt) {
        if s.fn_params != null {
            for let i: i32 = 0; i < s.fn_params.len(); i++ {
                let p: Param = s.fn_params.get(i);
                if p.ty != null {
                    self._canon_type(p.ty);
                }
            }
        }
        if s.fn_ret_ty != null {
            self._canon_type(s.fn_ret_ty);
        }
    }

    // Walk top-level decls and canonicalize qualified type annotations in the
    // AST before registration / checking / codegen all read them. Must run
    // with `current_origin` set per-stmt so `_is_imported_module` can resolve
    // origin-scoped imports.
    fn _canon_decls(self: *Typer, program: *Vector<Stmt>) {
        for let i: i32 = 0; i < program.len(); i++ {
            let s: Stmt = program.get(i);
            let saved: string = self.current_origin;
            self.current_origin = s.origin;
            if s.kind == ST_FN {
                self._canon_fn_sig(&s);
            } else {
                if s.kind == ST_STRUCT {
                    if s.struct_fields != null {
                        for let j: i32 = 0; j < s.struct_fields.len(); j++ {
                            let f: Field = s.struct_fields.get(j);
                            if f.ty != null {
                                self._canon_type(f.ty);
                            }
                        }
                    }
                } else {
                    if s.kind == ST_ENUM {
                        if s.enum_variants != null {
                            for let j: i32 = 0; j < s.enum_variants.len(); j++ {
                                let ev: EnumVariant = s.enum_variants.get(j);
                                if ev.fields != null {
                                    for let k: i32 = 0; k < ev.fields.len(); k++ {
                                        let a: Type = ev.fields.get(k);
                                        self._canon_type(&a);
                                        ev.fields.set(k, a);
                                    }
                                }
                            }
                        }
                    } else {
                        if s.kind == ST_IMPL {
                            if s.impl_target != null {
                                self._canon_type(s.impl_target);
                            }
                            if s.impl_methods != null {
                                for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                                    let m: Stmt = s.impl_methods.get(j);
                                    self._canon_fn_sig(&m);
                                }
                            }
                        }
                    }
                }
            }
            self.current_origin = saved;
        }
    }

    pub fn free(self: *Typer) {
        self.fns.free();
        self.structs.free();
        self.method_names.free();
        self.struct_fields_all.free();
        self.struct_field_types.free();
        self.struct_generic.free();
        self.scope.free();
        self.module_scope.free();
        self.owned_locals.free();
        self.borrows.free();
        self.diagnostics.free();
        self.visibility.free();
        self.module_imports.free();
        self.module_full_paths.free();
        self.field_pub.free();
        self.struct_origin.free();
        self.impl_set.free();
        self.enums.free();
        __glide_pfree(self as *void);
    }

    fn push_diag_tag(self: *Typer, line: i32, col: i32, severity: i32, code: string, msg: string, tag: i32) {
        // Synth-position diagnostics (proc-macro outputs, builtin
        // surrogates) anchor at line 0 and render at line 1 in the
        // editor — useless to the user, since they can't fix the
        // generated code. Drop them at the source.
        if line <= 0 {
            return;
        }
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + 1, severity: severity, code: code, message: msg, origin: origin, tag: tag, fix_line: 0, fix_col: 0, fix_end_line: 0, fix_end_col: 0, fix_replacement: "" };
        self.diagnostics.push(e);
    }

    fn push_diag(self: *Typer, line: i32, col: i32, severity: i32, code: string, msg: string) {
        self.push_diag_tag(line, col, severity, code, msg, 0);
    }

    // Attach a "this is why" location to the most recently pushed diagnostic.
    // No-op when no diagnostic has been emitted yet. Surfaced by the LSP as
    // relatedInformation; the CLI ignores it.
    fn relate_last(self: *Typer, origin: string, line: i32, col: i32, end_line: i32, end_col: i32, message: string) {
        if self.diagnostics.len() == 0 {
            return;
        }
        let mut o: string = origin;
        if o == null {
            o = "";
        }
        let r: DiagRelated = DiagRelated { diag_index: self.diagnostics.len() - 1, origin: o, line: line, col: col, end_line: end_line, end_col: end_col, message: message };
        self.related.push(r);
    }

    fn warn_unused(self: *Typer, line: i32, col: i32, code: string, msg: string) {
        self.push_diag_tag(line, col, 2, code, msg, 1); // tag 1 = Unnecessary
    }

    // Same as warn_unused but with explicit end-column so the editor's
    // fade / strikethrough effect spans the whole identifier instead of a
    // single character. Pass the position of the name and its length.
    fn warn_unused_range(self: *Typer, line: i32, col: i32, len: i32, code: string, msg: string) {
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let mut e_len: i32 = len;
        if e_len < 1 {
            e_len = 1;
        }
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + e_len, severity: 2, code: code, message: msg, origin: origin, tag: 1, fix_line: 0, fix_col: 0, fix_end_line: 0, fix_end_col: 0, fix_replacement: "" };
        self.diagnostics.push(e);
    }

    // Emit a warning with an attached mechanical fix. `glide fix`
    // reads the (fix_line, fix_col)..(fix_end_line, fix_end_col)
    // range and replaces it with `replacement`. Pass a zero-width
    // range to insert; an empty replacement to delete.
    fn warn_with_fix(self: *Typer, line: i32, col: i32, end_len: i32, code: string, msg: string, fl: i32, fc: i32, fel: i32, fec: i32, repl: string) {
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let mut e_len: i32 = end_len;
        if e_len < 1 {
            e_len = 1;
        }
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + e_len, severity: 2, code: code, message: msg, origin: origin, tag: 1, fix_line: fl, fix_col: fc, fix_end_line: fel, fix_end_col: fec, fix_replacement: repl };
        self.diagnostics.push(e);
    }

    fn err(self: *Typer, line: i32, col: i32, msg: string) {
        if self.demote_errors {
            self.push_diag(line, col, 2, "", msg);
            return;
        }
        self.push_diag(line, col, 1, "", msg);
        self.error_count = self.error_count + 1;
    }

    fn err_code(self: *Typer, line: i32, col: i32, code: string, msg: string) {
        if self.demote_errors {
            self.push_diag(line, col, 2, code, msg);
            return;
        }
        self.push_diag(line, col, 1, code, msg);
        self.error_count = self.error_count + 1;
    }

    fn err_code_range(self: *Typer, line: i32, col: i32, span: i32, code: string, msg: string) {
        let mut e_len: i32 = span;
        if e_len < 1 {
            e_len = 1;
        }
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let sev: i32 = if self.demote_errors { 2 } else { 1 };
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + e_len, severity: sev, code: code, message: msg, origin: origin, tag: 0, fix_line: 0, fix_col: 0, fix_end_line: 0, fix_end_col: 0, fix_replacement: "" };
        self.diagnostics.push(e);
        if !self.demote_errors {
            self.error_count = self.error_count + 1;
        }
    }

    // Error (severity 1) carrying a mechanical fix the LSP turns into a
    // quick fix: splice `repl` over the range (fl,fc)..(fel,fec) (1-indexed).
    fn err_code_range_fix(self: *Typer, line: i32, col: i32, span: i32, code: string, msg: string, fl: i32, fc: i32, fel: i32, fec: i32, repl: string) {
        let mut e_len: i32 = span;
        if e_len < 1 {
            e_len = 1;
        }
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let sev: i32 = if self.demote_errors { 2 } else { 1 };
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + e_len, severity: sev, code: code, message: msg, origin: origin, tag: 0, fix_line: fl, fix_col: fc, fix_end_line: fel, fix_end_col: fec, fix_replacement: repl };
        self.diagnostics.push(e);
        if !self.demote_errors {
            self.error_count = self.error_count + 1;
        }
    }

    fn warn(self: *Typer, line: i32, col: i32, code: string, msg: string) {
        self.push_diag(line, col, 2, code, msg);
    }

    // Warning (severity 2) underlining a `span`-wide range instead of a
    // single char, so the squiggle covers the whole offending expression
    // (e.g. `r.val`) rather than just its first character.
    fn warn_range(self: *Typer, line: i32, col: i32, span: i32, code: string, msg: string) {
        let mut e_len: i32 = span;
        if e_len < 1 {
            e_len = 1;
        }
        let mut origin: string = self.current_origin;
        if origin == null {
            origin = "";
        }
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + e_len, severity: 2, code: code, message: msg, origin: origin, tag: 0, fix_line: 0, fix_col: 0, fix_end_line: 0, fix_end_col: 0, fix_replacement: "" };
        self.diagnostics.push(e);
    }
}

// ---- pre-register --------------------------------------------------------
// True when `fn_stmt` returns one of its own struct-literal auto-drop locals
// directly (`let t: *T = T{..}; ...; return t;`) - it hands an owned value to
// its caller. Mirrors the codegen's _returns_auto_owned_local so the typer can
// treat `let x = make()` as owned for use-after-move.
fn _fn_returns_owned(fn_stmt: *Stmt) -> bool {
    if fn_stmt == null || fn_stmt.fn_body == null {
        return false;
    }
    let body: *Vector<Stmt> = fn_stmt.fn_body;
    let owned: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < body.len(); i = i + 1 {
        let st: Stmt = body.get(i);
        if st.kind == ST_LET && st.is_auto_owned {
            owned.insert(st.name, true);
        }
        if st.kind == ST_LET && st.let_ty != null && st.let_ty.kind == TY_POINTER && st.let_value != null && st.let_value.kind == EX_STRUCT_LIT && st.let_ty.inner != null && st.let_ty.inner.kind == TY_NAMED && st.let_ty.inner.name.eq(st.let_value.str_val) {
            owned.insert(st.name, true);
        }
    }
    let mut hit: bool = false;
    for let i: i32 = 0; i < body.len(); i = i + 1 {
        let st: Stmt = body.get(i);
        if st.kind == ST_RETURN && st.expr_value != null && st.expr_value.kind == EX_IDENT && owned.contains(st.expr_value.str_val) {
            hit = true;
        }
    }
    owned.free();
    return hit;
}

// True when the call `e` targets a fn whose FnSig is owned_return. `let_ty` (the
// binding's type) supplies the receiver type for a method key `<T>_<method>`.
fn _call_owned_return(t: *Typer, call: *Expr, let_ty: *Type) -> bool {
    if call == null || call.lhs == null {
        return false;
    }
    let callee: *Expr = call.lhs;
    let mut key: string = "";
    if callee.kind == EX_IDENT {
        key = callee.str_val;
    } else if callee.field != null && !callee.field.eq("") && let_ty != null && let_ty.kind == TY_POINTER && let_ty.inner != null && let_ty.inner.kind == TY_NAMED {
        key = let_ty.inner.name.concat("_").concat(callee.field);
    }
    if key.eq("") || !t.fns.contains(key) {
        return false;
    }
    let sig: FnSig = t.fns.get(key);
    return sig.owned_return;
}

pub fn pre_register(t: *Typer, program: *Vector<Stmt>) {
    // C-runtime types that aren't declared in any Glide source file but
    // user code expects to call as `Arena::new(...)`, etc. Hardcoded for
    // now; replace with proper `extern type` declarations later.
    t.structs.insert("Arena", true);
    // Arena's runtime methods (defined in runtime/stdlib.c, not Glide) so the
    // method-existence check treats `arena.alloc(...)` / `.used()` / `.reset()`
    // as known rather than flagging them like a typo. `free` is special-cased
    // separately; `new` is a static (`Arena::new`).
    t.method_names.insert("Arena::alloc", true);
    t.method_names.insert("Arena::used", true);
    t.method_names.insert("Arena::reset", true);
    t.method_names.insert("Arena::free", true);
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind == ST_CONST {
            // Top-level const: type from annotation if any, otherwise infer
            // from the literal value (covers `const X: int = 1;` and friends).
            let mut ty: *Type = s.let_ty;
            if ty == null && s.let_value != null {
                if s.let_value.kind == EX_INT {
                    if s.let_value.int_val > 2147483647 || s.let_value.int_val < -2147483648 {
                        ty = ty_named("i64");
                    } else {
                        ty = ty_named("i32");
                    }
                } else {
                    if s.let_value.kind == EX_FLOAT {
                        ty = ty_named("f64");
                    } else {
                        if s.let_value.kind == EX_STRING {
                            ty = ty_named("string");
                        } else {
                            if s.let_value.kind == EX_BOOL {
                                ty = ty_named("bool");
                            } else {
                                if s.let_value.kind == EX_CHAR {
                                    ty = ty_named("char");
                                }
                            }
                        }
                    }
                }
            }
            if ty != null {
                t.module_scope.insert(s.name, *ty);
            }
        }
        if s.kind == ST_LET && t.freestanding {
            // Top-level `let` in a freestanding/kernel build is a mutable
            // global, visible inside any fn body (same as a const). Type from
            // the annotation, else inferred from the literal value.
            let mut lty: *Type = s.let_ty;
            if lty == null && s.let_value != null {
                if s.let_value.kind == EX_INT {
                    if s.let_value.int_val > 2147483647 || s.let_value.int_val < -2147483648 {
                        lty = ty_named("i64");
                    } else {
                        lty = ty_named("i32");
                    }
                } else {
                    if s.let_value.kind == EX_FLOAT {
                        lty = ty_named("f64");
                    } else {
                        if s.let_value.kind == EX_STRING {
                            lty = ty_named("string");
                        } else {
                            if s.let_value.kind == EX_BOOL {
                                lty = ty_named("bool");
                            } else {
                                if s.let_value.kind == EX_CHAR {
                                    lty = ty_named("char");
                                } else {
                                    if s.let_value.kind == EX_STRUCT_LIT {
                                        lty = ty_named(s.let_value.str_val);
                                    }
                                }
                            }
                        }
                    }
                }
            }
            if lty != null {
                t.module_scope.insert(s.name, *lty);
            }
        }
        if s.kind == ST_FN {
            let no_owner: *Vector<string> = null;
            let sig: FnSig = FnSig { name: s.name, params: s.fn_params, ret_type: s.fn_ret_ty, owned_return: _fn_returns_owned(&s), is_variadic: s.is_variadic, type_params: s.type_params, type_param_bounds: s.type_param_bounds, owner_type_params: no_owner, decl_origin: s.origin, decl_line: s.name_line, decl_col: s.name_col };
            t.fns.insert(s.name, sig);
        }
        if s.kind == ST_ENUM {
            // Enums share the type-name registry with structs so EX_PATH
            // enforcement can tell `MyEnum::Variant` apart from a free
            // module call.
            t.structs.insert(s.name, true);
            // Record the variant list for exhaustiveness checking.
            let mut vlist: string = "";
            if s.enum_variants != null {
                for let j: i32 = 0; j < s.enum_variants.len(); j++ {
                    let ev: EnumVariant = s.enum_variants.get(j);
                    if j > 0 {
                        vlist = vlist.concat(",");
                    }
                    vlist = vlist.concat(ev.name);
                }
            }
            t.enums.insert(s.name, vlist);
        }
        if s.kind == ST_STRUCT {
            t.structs.insert(s.name, true);
            // Generic structs (`struct Box<T>`) have field types that may name a
            // type param, so their literal field-value checking is skipped.
            if s.type_params != null && s.type_params.len() > 0 {
                t.struct_generic.insert(s.name, true);
            }
            // Borrow rule: reject `&T` / `&mut T` in struct fields. They would
            // require lifetimes to be sound; Glide's design picks `*T` instead.
            if s.struct_fields != null {
                for let j: i32 = 0; j < s.struct_fields.len(); j++ {
                    let f: Field = s.struct_fields.get(j);
                    t.struct_fields_all.insert(s.name.concat("::").concat(f.name), true);
                    if f.ty != null {
                        t.struct_field_types.insert(s.name.concat("::").concat(f.name), *f.ty);
                    }
                    if f.ty != null && (f.ty.kind == TY_BORROW || f.ty.kind == TY_BORROW_MUT) {
                        t.err_code(s.line, s.column, "borrow-in-field", "borrow `".concat(type_to_string(f.ty)).concat("` not allowed in struct field `").concat(f.name).concat("` (use `*T` instead)"));
                    }
                }
            }
        }
        // Register impl methods so `Type::method(args)` callers can lookup
        // their return type via the same `t.fns` path. Stored under
        // `Type_method` matching the codegen's mangling. Generic params on
        // the impl/method stay un-substituted (T as TY_NAMED("T")) — good
        // enough for arity / pointer-vs-value mismatch diagnostics.
        if s.kind == ST_IMPL && s.impl_target != null && s.impl_methods != null {
            let mut tname: string = "";
            if s.impl_target.kind == TY_NAMED {
                tname = s.impl_target.name;
            }
            if s.impl_target.kind == TY_GENERIC {
                tname = s.impl_target.name;
            }
            if !tname.eq("") {
                // Specialized impls on concrete arg types (`impl Vector<int>`)
                // register under a fully-qualified key — `Vector<int>_max` —
                // so they don't collide with sibling specializations or the
                // generic `impl<T> Vector<T>` entry. Lookup tries the
                // specialized key first, falls back to the bare name.
                let mut is_specialized: bool = false;
                if s.impl_target.kind == TY_GENERIC && s.impl_target.args != null && s.impl_target.args.len() > 0 && (s.type_params == null || s.type_params.len() == 0) {
                    is_specialized = true;
                }
                let key_prefix: string = if is_specialized { type_to_string(s.impl_target) } else { tname };
                for let j: i32 = 0; j < s.impl_methods.len(); j++ {
                    let m: Stmt = s.impl_methods.get(j);
                    if m.kind == ST_FN {
                        let fname: string = key_prefix.concat("_").concat(m.name);
                        let sig: FnSig = FnSig { name: fname, params: m.fn_params, ret_type: m.fn_ret_ty, owned_return: _fn_returns_owned(&m), is_variadic: m.is_variadic, type_params: m.type_params, type_param_bounds: m.type_param_bounds, owner_type_params: s.type_params, decl_origin: s.origin, decl_line: m.name_line, decl_col: m.name_col };
                        t.fns.insert(fname, sig);
                        // Record under the BASE type name (not the
                        // specialized key) so "no method" detection knows
                        // the method exists on some variant of the type.
                        t.method_names.insert(tname.concat("::").concat(m.name), true);
                    }
                }
            }
        }
    }
    // Build impl_set: `<trait>::<type>` → true for every concrete impl in
    // the program. Generic-bounded calls consult this to decide whether
    // the inferred concrete type satisfies a `T: Trait` clause.
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_IMPL {
            continue;
        }
        if s.impl_trait_name == null || s.impl_trait_name.eq("") {
            continue;
        }
        if s.impl_target == null {
            continue;
        }
        let mut tname: string = "";
        if s.impl_target.kind == TY_NAMED {
            tname = s.impl_target.name;
        }
        if s.impl_target.kind == TY_GENERIC {
            tname = s.impl_target.name;
        }
        if tname.eq("") {
            continue;
        }
        t.impl_set.insert(s.impl_trait_name.concat("::").concat(tname), true);
        // Register `type Name = X;` decls under
        // `<Trait>::<TargetTypeName>::<Name>` so T::Item lookups resolve.
        if s.assoc_decls != null {
            for let j: i32 = 0; j < s.assoc_decls.len(); j++ {
                let a: Param = s.assoc_decls.get(j);
                if a.ty == null {
                    continue;
                }
                let key: string = s.impl_trait_name.concat("::").concat(tname).concat("::").concat(a.name);
                t.assoc_table.insert(key, *a.ty);
            }
        }
    }
    // Collect `@suggest_for_fnptr(RetType, "message")` annotations from
    // every fn in the program. Each entry: hint shown when a fn-ptr arg
    // mismatch's expected return type matches `RetType` (the "want"
    // side). Optional companion attrs tighten the gate further so the
    // hint only fires on user fns the macro can actually wrap:
    //
    //   @suggest_when_got_returns(Json, Result, Option, HttpResponse)
    //   @suggest_when_got_params("0")     // 0 / 1+ / any
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        if s.kind != ST_FN || s.attrs == null {
            continue;
        }
        for let j: i32 = 0; j < s.attrs.len(); j++ {
            let a: Attr = s.attrs.get(j);
            if a.name == null || !a.name.eq("suggest_for_fnptr") {
                continue;
            }
            if a.args == null || a.args.len() < 2 {
                continue;
            }
            let ret_arg: Expr = a.args.get(0);
            let msg_arg: Expr = a.args.get(1);
            if ret_arg.kind != EX_IDENT {
                continue;
            }
            if msg_arg.kind != EX_STRING {
                continue;
            }
            // Companion gates (same fn's other attrs).
            let mut got_heads: string = "";
            let mut got_params: string = "";
            for let k: i32 = 0; k < s.attrs.len(); k++ {
                let b: Attr = s.attrs.get(k);
                if b.name == null {
                    continue;
                }
                if b.name.eq("suggest_when_got_returns") && b.args != null {
                    for let m: i32 = 0; m < b.args.len(); m++ {
                        let pe: Expr = b.args.get(m);
                        if pe.kind != EX_IDENT {
                            continue;
                        }
                        if !got_heads.eq("") {
                            got_heads = got_heads.concat(",");
                        }
                        got_heads = got_heads.concat(pe.str_val);
                    }
                }
                if b.name.eq("suggest_when_got_params") && b.args != null && b.args.len() >= 1 {
                    let pe: Expr = b.args.get(0);
                    if pe.kind == EX_STRING {
                        got_params = pe.str_val;
                    }
                }
            }
            let h: FnptrHint = FnptrHint { ret_type_name: ret_arg.str_val, message: msg_arg.str_val, got_ret_heads: got_heads, got_param_shape: got_params };
            t.fnptr_hints.push(h);
        }
    }
}

// ---- generic bounds enforcement -----------------------------------------
fn type_var_contains(tps: *Vector<string>, name: string) -> bool {
    if tps == null {
        return false;
    }
    for let i: i32 = 0; i < tps.len(); i++ {
        if tps.get(i).eq(name) {
            return true;
        }
    }
    return false;
}

// Generic-aware variant of types_compat used for fn-call arg checks.
// A param type that names one of the fn's type-vars matches anything;
// pointer/borrow/result wrappers recurse so `*T` matches `*Animal`.
// Falls back to plain types_compat for everything else.
fn arg_compat(want: *Type, got: *Type, tps: *Vector<string>) -> bool {
    if want == null || got == null {
        return true;
    }
    if want.kind == TY_NAMED && type_var_contains(tps, want.name) {
        return true;
    }
    if (want.kind == TY_POINTER || want.kind == TY_BORROW || want.kind == TY_BORROW_MUT) && (got.kind == TY_POINTER || got.kind == TY_BORROW || got.kind == TY_BORROW_MUT) {
        // `null` is typed as `*void` by infer_expr — accept it against
        // any pointer-shaped parameter so `stmt_if(cond, then_b, null, …)`
        // and other "no else branch" patterns type-check cleanly.
        if got.inner != null && got.inner.kind == TY_NAMED && got.inner.name.eq("void") {
            return true;
        }
        if want.inner != null && want.inner.kind == TY_NAMED && want.inner.name.eq("void") {
            return true;
        }
        return arg_compat(want.inner, got.inner, tps);
    }
    if want.kind == TY_RESULT && got.kind == TY_RESULT {
        return arg_compat(want.inner, got.inner, tps);
    }
    if want.kind == TY_OPTION && got.kind == TY_OPTION {
        return arg_compat(want.inner, got.inner, tps);
    }
    if want.kind == TY_OPT_RESULT && got.kind == TY_OPT_RESULT {
        return arg_compat(want.inner, got.inner, tps);
    }
    // Fn pointers: recurse element-wise so type vars inside the signature
    // (`fn(T) -> U`) match concrete fn types (`fn(int) -> string`).
    if want.kind == TY_FNPTR && got.kind == TY_FNPTR {
        if want.args == null || got.args == null {
            return false;
        }
        if want.args.len() != got.args.len() {
            return false;
        }
        for let i: i32 = 0; i < want.args.len(); i++ {
            let wp: Type = want.args.get(i);
            let gp: Type = got.args.get(i);
            if !arg_compat(&wp, &gp, tps) {
                return false;
            }
        }
        return arg_compat(want.fnptr_ret, got.fnptr_ret, tps);
    }
    // EX_IDENT for a top-level fn name is typed as `__fn__` placeholder
    // by the typer (no full fn-pointer typing yet at the use site). Accept
    // that against any TY_FNPTR — the codegen does the proper TY_FNPTR
    // binding from the fn's signature for mono purposes.
    if want.kind == TY_FNPTR && got.kind == TY_NAMED && got.name.eq("__fn__") {
        return true;
    }
    return types_compat(want, got);
}

// Split "Ord+Clone" → ["Ord", "Clone"]. Empty input → empty vector.
fn split_bounds(s: string) -> *Vector<string> {
    let out: *Vector<string> = Vector::new();
    if s == null || s.eq("") {
        return out;
    }
    let n: i32 = s.len();
    let mut start: i32 = 0;
    let mut i: i32 = 0;
    while i < n {
        if s.at(i).to_int() == 43 {
            if i > start {
                out.push(s.substring(start, i));
            }
            start = i + 1;
        }
        i = i + 1;
    }
    if n > start {
        out.push(s.substring(start, n));
    }
    return out;
}

// Walk a (possibly nested) param type and pick the corresponding concrete
// chunk out of the arg type for the named type-var. Handles direct
// TY_NAMED("T"), `*T`, `&T`, `&mut T`. Returns null if nothing matches.
fn extract_for_var(param_ty: *Type, arg_ty: *Type, var_name: string) -> *Type {
    if param_ty == null || arg_ty == null {
        return null;
    }
    if param_ty.kind == TY_NAMED && param_ty.name.eq(var_name) {
        return arg_ty;
    }
    if (param_ty.kind == TY_POINTER || param_ty.kind == TY_BORROW || param_ty.kind == TY_BORROW_MUT) && (arg_ty.kind == TY_POINTER || arg_ty.kind == TY_BORROW || arg_ty.kind == TY_BORROW_MUT) {
        return extract_for_var(param_ty.inner, arg_ty.inner, var_name);
    }
    if param_ty.kind == TY_GENERIC && arg_ty.kind == TY_GENERIC && param_ty.name.eq(arg_ty.name) && param_ty.args != null && arg_ty.args != null && param_ty.args.len() == arg_ty.args.len() {
        for let i: i32 = 0; i < param_ty.args.len(); i++ {
            // Heap-copy each arg so the recursive call's match-result —
            // which may be aa itself — doesn't dangle when our stack
            // locals (pa, aa) go out of scope on early return.
            let pa_v: Type = param_ty.args.get(i);
            let aa_v: Type = arg_ty.args.get(i);
            let pa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
            let aa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
            *pa_p = pa_v;
            *aa_p = aa_v;
            let r: *Type = extract_for_var(pa_p, aa_p, var_name);
            if r != null {
                return r;
            }
        }
    }
    if param_ty.kind == TY_OPTION && arg_ty.kind == TY_OPTION {
        return extract_for_var(param_ty.inner, arg_ty.inner, var_name);
    }
    if param_ty.kind == TY_RESULT && arg_ty.kind == TY_RESULT {
        return extract_for_var(param_ty.inner, arg_ty.inner, var_name);
    }
    if param_ty.kind == TY_OPT_RESULT && arg_ty.kind == TY_OPT_RESULT {
        return extract_for_var(param_ty.inner, arg_ty.inner, var_name);
    }
    // Tuples: pair-wise on elements so `(T, U)` matched against `(int, string)`
    // binds T=int / U=string.
    if param_ty.kind == TY_TUPLE && arg_ty.kind == TY_TUPLE && param_ty.args != null && arg_ty.args != null && param_ty.args.len() == arg_ty.args.len() {
        for let i: i32 = 0; i < param_ty.args.len(); i++ {
            let pa_v: Type = param_ty.args.get(i);
            let aa_v: Type = arg_ty.args.get(i);
            let pa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
            let aa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
            *pa_p = pa_v;
            *aa_p = aa_v;
            let r: *Type = extract_for_var(pa_p, aa_p, var_name);
            if r != null {
                return r;
            }
        }
    }
    // Fn pointers: pair-wise on args + return so `fn(*T) -> U` matched against
    // `fn(*int) -> int` extracts both T and U. Without this, method-level type
    // params that appear only inside an fn-ptr param (e.g. `Mutex.with<U>(f: fn(*T) -> U) -> U`)
    // never bind and the return type leaks the literal `U`.
    if param_ty.kind == TY_FNPTR && arg_ty.kind == TY_FNPTR {
        if param_ty.args != null && arg_ty.args != null && param_ty.args.len() == arg_ty.args.len() {
            for let i: i32 = 0; i < param_ty.args.len(); i++ {
                let pa_v: Type = param_ty.args.get(i);
                let aa_v: Type = arg_ty.args.get(i);
                let pa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
                let aa_p: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *pa_p = pa_v;
                *aa_p = aa_v;
                let r: *Type = extract_for_var(pa_p, aa_p, var_name);
                if r != null {
                    return r;
                }
            }
        }
        return extract_for_var(param_ty.fnptr_ret, arg_ty.fnptr_ret, var_name);
    }
    return null;
}

// After a generic call's bound check, walk the return type and resolve any
// `T::Item` projection by looking up `<Trait>::<Concrete>::<Item>` in the
// assoc_table. T's concrete is inferred from the args (same trick as
// check_generic_bounds). Mutates a shallow copy; the caller's sig is intact.
fn resolve_assoc_in_ret(t: *Typer, sig: *FnSig, args: *Vector<Expr>, ret: *Type) -> *Type {
    if ret == null {
        return null;
    }
    if sig == null {
        return ret;
    }
    if sig.type_params == null || sig.type_params.len() == 0 {
        return ret;
    }
    if sig.params == null || args == null {
        return ret;
    }
    let plen: i32 = sig.params.len();
    let alen: i32 = args.len();
    if plen != alen {
        return ret;
    }
    let mut bn: i32 = 0;
    if sig.type_param_bounds != null {
        bn = sig.type_param_bounds.len();
    }
    return rewrite_assoc_in_type(t, sig, args, ret, plen, bn);
}

fn rewrite_assoc_in_type(t: *Typer, sig: *FnSig, args: *Vector<Expr>, ty: *Type, plen: i32, bn: i32) -> *Type {
    if ty == null {
        return null;
    }
    // TY_NAMED that's a type-param: substitute with the concrete inferred from
    // args. Without this, generic fns like `iter_fold<T, U>(...) -> U` return
    // the literal "U" type and the caller sees "expected int, got U".
    if ty.kind == TY_NAMED && sig.type_params != null {
        for let ti: i32 = 0; ti < sig.type_params.len(); ti++ {
            let tp_name: string = sig.type_params.get(ti);
            if !tp_name.eq(ty.name) {
                continue;
            }
            for let i: i32 = 0; i < plen; i++ {
                let p: Param = sig.params.get(i);
                let a: Expr = args.get(i);
                let at: *Type = infer_expr(t, &a);
                let extracted: *Type = extract_for_var(p.ty, at, tp_name);
                if extracted != null {
                    return extracted;
                }
            }
            return ty;
        }
    }
    if ty.kind == TY_ASSOC && ty.inner != null && ty.inner.kind == TY_NAMED {
        let owner_name: string = ty.inner.name;
        // Is owner_name one of the type params? If so, find its bound + concrete.
        for let ti: i32 = 0; ti < sig.type_params.len(); ti++ {
            let tp_name: string = sig.type_params.get(ti);
            if !tp_name.eq(owner_name) {
                continue;
            }
            let mut bounds: string = "";
            if ti < bn {
                bounds = sig.type_param_bounds.get(ti);
            }
            if bounds.eq("") {
                continue;
            }
            // Infer concrete by scanning params for the var.
            let mut concrete: *Type = null;
            for let i: i32 = 0; i < plen; i++ {
                let p: Param = sig.params.get(i);
                let a: Expr = args.get(i);
                let at: *Type = infer_expr(t, &a);
                let extracted: *Type = extract_for_var(p.ty, at, tp_name);
                if extracted != null {
                    concrete = extracted;
                    break;
                }
            }
            if concrete == null || concrete.kind != TY_NAMED {
                return ty;
            }
            let cname: string = concrete.name;
            // Look up in assoc_table by the first matching bound.
            let parts: *Vector<string> = split_bounds(bounds);
            for let bi: i32 = 0; bi < parts.len(); bi++ {
                let bound: string = parts.get(bi);
                let key: string = bound.concat("::").concat(cname).concat("::").concat(ty.name);
                if t.assoc_table.contains(key) {
                    let resolved: Type = t.assoc_table.get(key);
                    let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
                    *p = resolved;
                    return p;
                }
            }
            return ty;
        }
        return ty;
    }
    // Recurse through wrappers.
    if ty.kind == TY_OPTION || ty.kind == TY_RESULT || ty.kind == TY_OPT_RESULT || ty.kind == TY_POINTER || ty.kind == TY_BORROW || ty.kind == TY_BORROW_MUT || ty.kind == TY_SLICE {
        let new_inner: *Type = rewrite_assoc_in_type(t, sig, args, ty.inner, plen, bn);
        let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
        *p = *ty;
        p.inner = new_inner;
        return p;
    }
    // Recurse into tuple elements so `-> (T, U)` resolves each slot.
    if ty.kind == TY_TUPLE {
        let new_args: *Vector<Type> = Vector::new();
        if ty.args != null {
            for let i: i32 = 0; i < ty.args.len(); i++ {
                let a: Type = ty.args.get(i);
                let na: *Type = rewrite_assoc_in_type(t, sig, args, &a, plen, bn);
                if na != null {
                    new_args.push(*na);
                }
            }
        }
        return ty_tuple(new_args);
    }
    return ty;
}

fn check_generic_bounds(t: *Typer, sig: *FnSig, args: *Vector<Expr>, line: i32, col: i32) {
    if sig == null {
        return;
    }
    if sig.type_params == null || sig.type_params.len() == 0 {
        return;
    }
    if sig.type_param_bounds == null {
        return;
    }
    if sig.params == null || args == null {
        return;
    }
    let plen: i32 = sig.params.len();
    let alen: i32 = args.len();
    if plen != alen {
        return;
    } // arity reported separately
    let bn: i32 = sig.type_param_bounds.len();
    for let ti: i32 = 0; ti < sig.type_params.len(); ti++ {
        let tp_name: string = sig.type_params.get(ti);
        let mut bounds: string = "";
        if ti < bn {
            bounds = sig.type_param_bounds.get(ti);
        }
        if bounds.eq("") {
            continue;
        }
        // Infer T → concrete by scanning params for the first one that
        // mentions the var (directly or behind one pointer/borrow).
        let mut concrete: *Type = null;
        for let i: i32 = 0; i < plen; i++ {
            let p: Param = sig.params.get(i);
            let a: Expr = args.get(i);
            let at: *Type = infer_expr(t, &a);
            let extracted: *Type = extract_for_var(p.ty, at, tp_name);
            if extracted != null {
                concrete = extracted;
                break;
            }
        }
        if concrete == null {
            continue;
        }
        if concrete.kind != TY_NAMED {
            continue;
        }
        let cname: string = concrete.name;
        let parts: *Vector<string> = split_bounds(bounds);
        for let bi: i32 = 0; bi < parts.len(); bi++ {
            let bound: string = parts.get(bi);
            let key: string = bound.concat("::").concat(cname);
            if !t.impl_set.contains(key) {
                t.err_code(line, col, "unsatisfied-bound", "type `".concat(cname).concat("` does not implement `").concat(bound).concat("` (required by `").concat(tp_name).concat("` of `").concat(sig.name).concat("`)"));
                if sig.decl_origin != null && !sig.decl_origin.eq("") && sig.decl_line > 0 {
                    let mut nlen: i32 = 1;
                    if sig.name != null {
                        nlen = sig.name.len();
                    }
                    t.relate_last(sig.decl_origin, sig.decl_line, sig.decl_col, sig.decl_line, sig.decl_col + nlen, "`".concat(tp_name).concat(": ").concat(bound).concat("` bound is declared here"));
                }
            }
        }
    }
}

// ---- arena escape tracking ----------------------------------------------

// True for `*Arena` and any pointer typedef whose Named target is "Arena".
fn _is_arena_type(ty: *Type) -> bool {
    if ty == null {
        return false;
    }
    if ty.kind != TY_POINTER {
        return false;
    }
    if ty.inner == null {
        return false;
    }
    if ty.inner.kind != TY_NAMED {
        return false;
    }
    return ty.inner.name.eq("Arena");
}

// If `e` is `<ident>.<method>(...)` where the receiver is a known local
// arena, return the arena's name. Otherwise "". Doesn't chase
// field/path receivers - those are out of scope for v1.
fn _arena_method_origin(t: *Typer, e: *Expr) -> string {
    if e == null || e.kind != EX_CALL {
        return "";
    }
    if e.lhs == null || e.lhs.kind != EX_MEMBER {
        return "";
    }
    let recv: *Expr = e.lhs.lhs;
    if recv == null || recv.kind != EX_IDENT {
        return "";
    }
    if !t.arena_locals.contains(recv.str_val) {
        return "";
    }
    return recv.str_val;
}

// Look up the arena that a value derives from. Handles direct method
// calls on a local arena receiver, plus aliasing via prior `let p = q`,
// plus pass-through casts (`arena.alloc(n) as *T`).
fn _expr_arena_origin(t: *Typer, e: *Expr) -> string {
    if e == null {
        return "";
    }
    if e.kind == EX_CAST {
        return _expr_arena_origin(t, e.lhs);
    }
    if e.kind == EX_IDENT {
        if t.arena_origin.contains(e.str_val) {
            return t.arena_origin.get(e.str_val);
        }
        return "";
    }
    return _arena_method_origin(t, e);
}

// ---- borrow tracking helpers --------------------------------------------

// `e` (or any sub-expression) reads the binder `name`. Recursive walk
// over the AST fields the parser populates - enough to catch reads in
// args, member chains, unary/binary ops, casts, and nested fn-exprs.
fn _expr_uses_name(e: *Expr, name: string) -> bool {
    if e == null {
        return false;
    }
    if e.kind == EX_IDENT && e.str_val.eq(name) {
        return true;
    }
    if e.lhs != null && _expr_uses_name(e.lhs, name) {
        return true;
    }
    if e.rhs != null && _expr_uses_name(e.rhs, name) {
        return true;
    }
    if e.operand != null && _expr_uses_name(e.operand, name) {
        return true;
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            if _expr_uses_name(&a, name) {
                return true;
            }
        }
    }
    if e.fn_expr_body != null {
        for let i: i32 = 0; i < e.fn_expr_body.len(); i++ {
            let b: Stmt = e.fn_expr_body.get(i);
            if _stmt_uses_name(&b, name) {
                return true;
            }
        }
    }
    return false;
}

fn _stmt_uses_name(s: *Stmt, name: string) -> bool {
    if s == null {
        return false;
    }
    if s.let_value != null && _expr_uses_name(s.let_value, name) {
        return true;
    }
    if s.expr_value != null && _expr_uses_name(s.expr_value, name) {
        return true;
    }
    if s.cond != null && _expr_uses_name(s.cond, name) {
        return true;
    }
    if s.for_step != null && _expr_uses_name(s.for_step, name) {
        return true;
    }
    if s.for_init != null && _stmt_uses_name(s.for_init, name) {
        return true;
    }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            if _stmt_uses_name(&b, name) {
                return true;
            }
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            if _stmt_uses_name(&b, name) {
                return true;
            }
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            if _stmt_uses_name(&b, name) {
                return true;
            }
        }
    }
    return false;
}

fn _body_uses_name_after(body: *Vector<Stmt>, idx: i32, name: string) -> bool {
    let n: i32 = body.len();
    let mut i: i32 = idx + 1;
    while i < n {
        let s: Stmt = body.get(i);
        if _stmt_uses_name(&s, name) {
            return true;
        }
        i = i + 1;
    }
    return false;
}

// NLL: after `check_stmt` returns, scan the rest of the block for any
// reference to each active borrow's binder. Drop events whose binder is
// never used again - subsequent mutations of `source` then pass.
fn kill_dead_borrows(t: *Typer, body: *Vector<Stmt>, idx: i32) {
    let mut i: i32 = t.borrows.len() - 1;
    while i >= 0 {
        let ev: BorrowEvent = t.borrows.get(i);
        if !ev.binder.eq("") && !_body_uses_name_after(body, idx, ev.binder) {
            let last_idx: i32 = t.borrows.len() - 1;
            if i != last_idx {
                let last_ev: BorrowEvent = t.borrows.get(last_idx);
                t.borrows.set(i, last_ev);
            }
            let _: BorrowEvent = t.borrows.pop();
        }
        i = i - 1;
    }
}

fn count_borrows(t: *Typer, name: string, want_mut: bool) -> i32 {
    let n: i32 = t.borrows.len();
    let mut c: i32 = 0;
    for let i: i32 = 0; i < n; i++ {
        let ev: BorrowEvent = t.borrows.get(i);
        if ev.source.eq(name) && ev.is_mut == want_mut {
            c = c + 1;
        }
    }
    return c;
}

// Point the "why" at the borrow already in flight. `mut_only` restricts to
// the prior mutable borrow (the conflict for a new shared borrow); otherwise
// any prior borrow of `source` (the conflict for a new mutable borrow).
fn _relate_first_borrow(t: *Typer, source: string, mut_only: bool) {
    for let i: i32 = 0; i < t.borrows.len(); i++ {
        let ev: BorrowEvent = t.borrows.get(i);
        if !ev.source.eq(source) {
            continue;
        }
        if mut_only && !ev.is_mut {
            continue;
        }
        t.relate_last(t.current_origin, ev.line, ev.col, ev.line, ev.col + source.len(), "`".concat(source).concat("` was first borrowed here"));
        return;
    }
}

fn record_borrow(t: *Typer, source: string, is_mut: bool, binder: string, line: i32, col: i32) {
    let n_shared: i32 = count_borrows(t, source, false);
    let n_mut: i32 = count_borrows(t, source, true);
    if is_mut {
        if n_mut > 0 || n_shared > 0 {
            t.err_code(line, col, "overlap-borrow", "cannot borrow `".concat(source).concat("` as mutable: already borrowed (across statements)"));
            _relate_first_borrow(t, source, false);
        }
    } else {
        if n_mut > 0 {
            t.err_code(line, col, "overlap-borrow", "cannot borrow `".concat(source).concat("` as immutable: already mutably borrowed"));
            _relate_first_borrow(t, source, true);
        }
    }
    let ev: BorrowEvent = BorrowEvent { source: source, is_mut: is_mut, binder: binder, line: line, col: col };
    t.borrows.push(ev);
}

fn enter_borrow_scope(t: *Typer) -> i32 {
    return t.borrows.len();
}

fn exit_borrow_scope(t: *Typer, saved: i32) {
    while t.borrows.len() > saved {
        let _ev: BorrowEvent = t.borrows.pop();
    }
}

// Walk a call's args. Each arg of form `&x` or `&mut x` records (x, is_mut).
// Then check pairs: two &mut x or & + &mut on the same source is forbidden.
fn check_call_aliasing(t: *Typer, call: *Expr) {
    if call == null || call.kind != EX_CALL || call.args == null {
        return;
    }
    let names: *Vector<string> = Vector::new();
    let muts: *Vector<bool> = Vector::new();
    for let i: i32 = 0; i < call.args.len(); i++ {
        let a: Expr = call.args.get(i);
        if a.kind == EX_UNARY && (a.op_code == UN_ADDR || a.op_code == UN_ADDR_MUT) && a.operand != null && a.operand.kind == EX_IDENT {
            names.push(a.operand.str_val);
            muts.push(a.op_code == UN_ADDR_MUT);
        }
    }
    let n: i32 = names.len();
    for let i: i32 = 0; i < n; i++ {
        for let j: i32 = i + 1; j < n; j++ {
            if names.get(i).eq(names.get(j)) {
                let im: bool = muts.get(i);
                let jm: bool = muts.get(j);
                if im || jm {
                    t.err_code(call.line, call.column, "borrow-alias-in-call", "cannot pass `".concat(names.get(i)).concat("` aliased through both shared and mutable borrow in same call"));
                }
            }
        }
    }
}

// ---- main check ----------------------------------------------------------

// True when `s` belongs to an imported file (not the LSP's edited buffer) and
// should have its body skipped. Synthesized/builtin stmts (null/empty origin)
// and the CLI default (user_origin "") are never skipped.
fn _skip_imported(t: *Typer, s: *Stmt) -> bool {
    if t.user_origin == null || t.user_origin.eq("") {
        return false;
    }
    if s.origin == null || s.origin.eq("") {
        return false;
    }
    return !s.origin.eq(t.user_origin);
}

pub fn check_program(t: *Typer, program: *Vector<Stmt>) {
    t._canon_decls(program);
    pre_register(t, program);
    for let i: i32 = 0; i < program.len(); i++ {
        let s: Stmt = program.get(i);
        // LSP: registration above is whole-program, but the body typecheck of
        // imported fns is wasted work (its diagnostics are filtered out before
        // publish) that would otherwise fill the retained per-doc arena.
        if _skip_imported(t, &s) {
            continue;
        }
        t.current_origin = s.origin;
        check_top(t, &s);
    }
    _drain_pass_diags(t);
}

// Merge custom-lint diagnostics emitted by compiler passes / macros via
// `pass_diag(...)` (recorded in a process-global sink during expansion) into
// the typer's own list, so they print with location + a suppressible `code`
// and count toward the error total (severity 1 fails the build).
fn _drain_pass_diags(t: *Typer) {
    let n: i32 = __glide_pd_count();
    for let i: i32 = 0; i < n; i++ {
        let line: i32 = __glide_pd_line(i);
        let col: i32 = __glide_pd_col(i);
        let sev: i32 = __glide_pd_sev(i);
        let e: DiagEntry = DiagEntry { line: line, col: col, end_line: line, end_col: col + 1, severity: sev, code: __glide_pd_code(i), message: __glide_pd_msg(i), origin: "", tag: 0, fix_line: 0, fix_col: 0, fix_end_line: 0, fix_end_col: 0, fix_replacement: "" };
        t.diagnostics.push(e);
        if sev == 1 {
            t.error_count = t.error_count + 1;
        }
    }
}

fn check_top(t: *Typer, s: *Stmt) {
    if s.kind == ST_FN {
        check_fn(t, s);
        return;
    }
    if s.kind == ST_STRUCT {
        return;
    }
    if s.kind == ST_IMPL {
        // Impl method bodies were historically never type-checked. Check them
        // now, but in demote mode: their errors surface as WARNINGS so the
        // backlog can be triaged and fixed before promoting them to hard errors
        // (doing it as errors now would break the self-host). Scoped to focused
        // checking (LSP / `glide check <file>`, where user_origin is set) so full
        // builds stay quiet. The impl's own type params are put in scope so an
        // `impl<T>` method body doesn't see `T` as an unknown type.
        if t.user_origin != null && !t.user_origin.eq("") && s.impl_methods != null {
            let saved_tps: *Vector<string> = t.impl_type_params;
            t.impl_type_params = s.type_params;
            // The user's own impl methods (in the focused file) get real errors,
            // exactly like a top-level fn. Imported impls stay demoted to
            // warnings so their latent backlog doesn't surface as errors here.
            let own_impl: bool = s.origin == null || s.origin.eq("") || s.origin.eq(t.user_origin);
            t.demote_errors = !own_impl;
            for let i: i32 = 0; i < s.impl_methods.len(); i++ {
                let m: Stmt = s.impl_methods.get(i);
                if m.kind == ST_FN {
                    check_fn(t, &m);
                }
            }
            t.demote_errors = false;
            t.impl_type_params = saved_tps;
        }
        return;
    }
    if s.kind == ST_CONST {
        check_let_or_const(t, s);
        return;
    }
    if s.kind == ST_LET {
        check_let_or_const(t, s);
        return;
    }
    if s.kind == ST_IMPORT {
        return;
    }
    // unknown — ignore for now
}

fn is_self_call_expr(e: *Expr, name: string) -> bool {
    if e == null {
        return false;
    }
    if e.kind != EX_CALL {
        return false;
    }
    if e.lhs == null {
        return false;
    }
    if e.lhs.kind != EX_IDENT {
        return false;
    }
    return e.lhs.str_val.eq(name);
}

// Walk the body's top-level statements in order. If we hit a branching or
// return-like statement first, assume the user has a base case. If we hit a
// self-call expression (statement OR let initializer) first, the recursion
// is unconditional and every invocation overflows the stack.
fn first_unconditional_self_call(body: *Vector<Stmt>, name: string) -> *Expr {
    if body == null {
        return null;
    }
    for let i: i32 = 0; i < body.len(); i++ {
        let st: Stmt = body.get(i);
        if st.kind == ST_IF || st.kind == ST_WHILE || st.kind == ST_FOR || st.kind == ST_MATCH || st.kind == ST_RETURN || st.kind == ST_BREAK || st.kind == ST_CONTINUE {
            return null;
        }
        if st.kind == ST_EXPR && is_self_call_expr(st.expr_value, name) {
            return st.expr_value;
        }
        if st.kind == ST_LET && is_self_call_expr(st.let_value, name) {
            return st.let_value;
        }
    }
    return null;
}

fn check_fn(t: *Typer, s: *Stmt) {
    let saved_scope: *HashMap<Type> = t.scope;
    let saved_owned: *HashMap<bool> = t.owned_locals;
    let saved_arena_locals: *HashMap<bool> = t.arena_locals;
    let saved_arena_origin: *HashMap<string> = t.arena_origin;
    let saved_consumed: *HashMap<bool> = t.consumed_locals;
    let saved_moved_out: *HashMap<bool> = t.moved_out;
    let saved_borrows: *Vector<BorrowEvent> = t.borrows;
    let saved_ret: *Type = t.current_ret;
    let saved_tps: *Vector<string> = t.current_type_params;
    let new_scope: *HashMap<Type> = HashMap::new();
    let new_owned: *HashMap<bool> = HashMap::new();
    let new_arena_locals: *HashMap<bool> = HashMap::new();
    let new_arena_origin: *HashMap<string> = HashMap::new();
    let new_consumed: *HashMap<bool> = HashMap::new();
    let new_moved_out: *HashMap<bool> = HashMap::new();
    let new_borrows: *Vector<BorrowEvent> = Vector::new();
    t.scope = new_scope;
    t.owned_locals = new_owned;
    t.arena_locals = new_arena_locals;
    t.arena_origin = new_arena_origin;
    t.consumed_locals = new_consumed;
    t.moved_out = new_moved_out;
    t.call_owned = HashMap::new();
    t.borrows = new_borrows;
    t.current_ret = s.fn_ret_ty;
    t.current_type_params = s.type_params;
    // Param + return type annotations must name real types. (Only top-level
    // `fn`s reach check_fn — impl methods are skipped by check_top — so the
    // type params in scope are exactly this fn's own `<…>`.)
    _check_type_known(t, s.fn_ret_ty, s.line, s.column);
    if s.fn_params != null {
        for let i: i32 = 0; i < s.fn_params.len(); i++ {
            let p: Param = s.fn_params.get(i);
            if p.ty != null {
                _check_type_known(t, p.ty, s.line, s.column);
                t.scope.insert(p.name, *p.ty);
            }
        }
    }
    if s.fn_body != null {
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            check_stmt(t, &b);
            kill_dead_borrows(t, s.fn_body, i);
        }
        let rc: *Expr = first_unconditional_self_call(s.fn_body, s.name);
        if rc != null {
            t.err_code_range(rc.line, rc.column, s.name.len(), "infinite-recursion", "function `".concat(s.name).concat("` recurses unconditionally; every call overflows the stack"));
        }
    }
    t.scope.free();
    t.owned_locals.free();
    t.arena_locals.free();
    t.arena_origin.free();
    t.consumed_locals.free();
    t.moved_out.free();
    t.borrows.free();
    t.scope = saved_scope;
    t.owned_locals = saved_owned;
    t.arena_locals = saved_arena_locals;
    t.arena_origin = saved_arena_origin;
    t.consumed_locals = saved_consumed;
    t.moved_out = saved_moved_out;
    t.borrows = saved_borrows;
    t.current_ret = saved_ret;
    t.current_type_params = saved_tps;
}

// When a bare value is given where `?T` / `!T` is expected and the value
// matches the inner type, the fix is to wrap it in `some(...)` / `ok(...)`.
// Returns the diagnostic code that tells the LSP which constructor to apply
// (it builds the actual edit from source); "" when no wrap applies.
fn _wrap_ctor_code(expected: *Type, got: *Type) -> string {
    if expected == null || got == null {
        return "";
    }
    if expected.inner == null {
        return "";
    }
    if expected.kind == TY_OPTION && types_compat(expected.inner, got) {
        return "wrap-some";
    }
    if expected.kind == TY_RESULT && types_compat(expected.inner, got) {
        return "wrap-ok";
    }
    return "";
}

// Readable name of a call's callee for diagnostics: `foo`, `Type::method`,
// or `.method` for a receiver method. Falls back to "the call".
fn _call_display_name(e: *Expr) -> string {
    if e == null || e.lhs == null {
        return "the call";
    }
    let c: *Expr = e.lhs;
    if c.kind == EX_IDENT && c.str_val != null {
        return "`".concat(c.str_val).concat("`");
    }
    if c.kind == EX_PATH && c.str_val != null && c.field != null {
        return "`".concat(c.str_val).concat("::").concat(c.field).concat("`");
    }
    if c.kind == EX_MEMBER && c.field != null {
        return "`.".concat(c.field).concat("`");
    }
    return "the call";
}

// True when `body`'s last statement exits the control-flow path
// (return / break / continue), so frees inside it don't reach siblings after.
fn _body_exits(body: *Vector<Stmt>) -> bool {
    if body == null || body.len() == 0 {
        return false;
    }
    let last: Stmt = body.get(body.len() - 1);
    return last.kind == ST_RETURN || last.kind == ST_BREAK || last.kind == ST_CONTINUE;
}

// Snapshot the currently-freed locals so a branch's frees can be rolled back.
fn _consumed_snapshot(t: *Typer) -> *HashMap<bool> {
    let snap: *HashMap<bool> = HashMap::new();
    let ks: *Vector<string> = t.consumed_locals.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if t.consumed_locals.get(k) {
            snap.insert(k, true);
        }
    }
    ks.free();
    return snap;
}

// Undo any free that happened since `snap` (a free inside an exiting branch
// must not mark the variable freed for code that runs only when the branch
// wasn't taken). Keeps frees that were already in effect before the branch.
fn _consumed_restore(t: *Typer, snap: *HashMap<bool>) {
    let ks: *Vector<string> = t.consumed_locals.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if t.consumed_locals.get(k) && !snap.contains(k) {
            t.consumed_locals.insert(k, false);
        }
    }
    ks.free();
}

// Collect into `out` every local that became freed in this branch — i.e.
// consumed now but NOT in `base` (the pre-branch snapshot).
fn _consumed_collect_new(t: *Typer, base: *HashMap<bool>, out: *HashMap<bool>) {
    let ks: *Vector<string> = t.consumed_locals.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if t.consumed_locals.get(k) && !base.contains(k) {
            out.insert(k, true);
        }
    }
    ks.free();
}

// Re-apply a captured set of frees onto the live consumed-set.
fn _consumed_apply(t: *Typer, keep: *HashMap<bool>) {
    let ks: *Vector<string> = keep.keys();
    for let i: i32 = 0; i < ks.len(); i++ {
        let k: string = ks.get(i);
        if keep.get(k) {
            t.consumed_locals.insert(k, true);
        }
    }
    ks.free();
}

// Validate match arm variant names against the scrutinee and, for enums,
// check exhaustiveness. Shared by the statement and expression match forms so
// both reject a typo'd variant (which otherwise leaked `case Enum_Bogus` to
// cc) and a non-exhaustive enum match (which otherwise fell through to an
// uninitialized C switch result).
fn _check_match_coverage(t: *Typer, scrut_ty: *Type, arms: *Vector<MatchArm>, line: i32, col: i32) {
    if arms == null {
        return;
    }
    let is_enum: bool = scrut_ty != null && scrut_ty.kind == TY_NAMED && t.enums.contains(scrut_ty.name);
    let is_opt: bool = scrut_ty != null && scrut_ty.kind == TY_OPTION;
    let is_res: bool = scrut_ty != null && scrut_ty.kind == TY_RESULT;
    let mut parts: *Vector<string> = null;
    if is_enum {
        let vlist: string = t.enums.get(scrut_ty.name);
        if !vlist.eq("") {
            parts = vlist.split(",");
        }
    }
    let mut has_wildcard: bool = false;
    let covered: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < arms.len(); i++ {
        let a: MatchArm = arms.get(i);
        if a.variant.eq("_") {
            has_wildcard = true;
            continue;
        }
        covered.insert(a.variant, true);
        if is_enum && parts != null {
            let mut found: bool = false;
            for let j: i32 = 0; j < parts.len(); j++ {
                if parts.get(j).eq(a.variant) {
                    found = true;
                    break;
                }
            }
            if !found {
                t.err_code(line, col, "unknown-variant", "`".concat(a.variant).concat("` is not a variant of `").concat(scrut_ty.name).concat("`"));
            }
        } else {
            if is_opt {
                if !a.variant.eq("some") && !a.variant.eq("none") {
                    t.err_code(line, col, "unknown-variant", "`".concat(a.variant).concat("` is not a variant of an Option; use `some` / `none`"));
                }
            } else {
                if is_res {
                    if !a.variant.eq("ok") && !a.variant.eq("err") {
                        t.err_code(line, col, "unknown-variant", "`".concat(a.variant).concat("` is not a variant of a Result; use `ok` / `err`"));
                    }
                }
            }
        }
    }
    if !has_wildcard && is_enum && parts != null {
        let mut missing: string = "";
        let mut miss_count: i32 = 0;
        for let i: i32 = 0; i < parts.len(); i++ {
            let v: string = parts.get(i);
            if !covered.contains(v) {
                if miss_count > 0 {
                    missing = missing.concat(", ");
                }
                missing = missing.concat("`").concat(v).concat("`");
                miss_count = miss_count + 1;
            }
        }
        if miss_count > 0 {
            t.push_diag(line, col, 1, "match-not-exhaustive", "match on `".concat(scrut_ty.name).concat("` is not exhaustive: missing ").concat(missing).concat(". Add an arm for each, or `_ =>` to handle the rest."));
        }
    }
    if parts != null {
        parts.free();
    }
    covered.free();
}

// Type-check each statement in a block, expiring borrows that die after it.
fn check_body(t: *Typer, body: *Vector<Stmt>) {
    for let i: i32 = 0; i < body.len(); i++ {
        let b: Stmt = body.get(i);
        check_stmt(t, &b);
        kill_dead_borrows(t, body, i);
    }
}

// Check a block in its own borrow scope (the common while / block case).
fn check_scoped_body(t: *Typer, body: *Vector<Stmt>) {
    let saved: i32 = enter_borrow_scope(t);
    check_body(t, body);
    exit_borrow_scope(t, saved);
}

fn check_stmt(t: *Typer, s: *Stmt) {
    if s.kind == ST_LET || s.kind == ST_CONST {
        check_let_or_const(t, s);
        return;
    }
    if s.kind == ST_RETURN {
        check_return(t, s);
        return;
    }
    if s.kind == ST_EXPR {
        if s.expr_value != null {
            let et: *Type = infer_expr(t, s.expr_value);
            // Must-use: a `!T` / `?T` / `?!T` produced by a call and used as a
            // bare statement throws away BOTH the value and the error/none
            // case. Errors-as-values makes that almost always a bug. Warn (not
            // error) so it's advisory. `?` / `??` / a `.ok` check all consume
            // the result, so those forms infer to `T` and never reach here.
            if s.expr_value.kind == EX_CALL && et != null && (et.kind == TY_RESULT || et.kind == TY_OPTION || et.kind == TY_OPT_RESULT) {
                let nm: string = _call_display_name(s.expr_value);
                let mut tail: string = "its error is discarded";
                if et.kind == TY_OPTION {
                    tail = "the empty (`none`) case is discarded";
                }
                t.warn_range(s.expr_value.line, s.expr_value.column, nm.len(), "unused-result", "result of ".concat(nm).concat(" (`").concat(type_to_string(et)).concat("`) is ignored: ").concat(tail).concat(". Propagate it with `?`, supply a default with `??`, or check `.ok` / `.has`."));
            }
        }
        return;
    }
    if s.kind == ST_SPAWN {
        check_spawn(t, s);
        return;
    }
    if s.kind == ST_IF {
        if s.cond != null {
            let ct: *Type = infer_expr(t, s.cond);
            if ct != null && !is_unknown_type(ct) && !is_bool_type(ct) {
                t.err(s.line, s.column, "if condition must be bool");
            }
        }
        // `then` and `else` are mutually exclusive paths: a free inside one
        // must NOT mark the local freed while the OTHER branch is checked.
        // Snapshot before each branch, roll that branch's frees back, and
        // after both branches re-apply only the frees from branches that fall
        // through (a branch that returns/breaks/continues never reaches the
        // code after the `if`, so its frees don't persist there either).
        let s0: *HashMap<bool> = _consumed_snapshot(t);
        let then_keep: *HashMap<bool> = HashMap::new();
        let else_keep: *HashMap<bool> = HashMap::new();
        if s.then_body != null {
            check_scoped_body(t, s.then_body);
            if !_body_exits(s.then_body) {
                _consumed_collect_new(t, s0, then_keep);
            }
            _consumed_restore(t, s0); // roll then's frees back before else
        }
        if s.else_body != null {
            check_scoped_body(t, s.else_body);
            if !_body_exits(s.else_body) {
                _consumed_collect_new(t, s0, else_keep);
            }
            _consumed_restore(t, s0); // roll else's frees back; union re-applied below
        }
        // Post-`if` state = pre-`if` frees plus the frees from each branch
        // that falls through. A read after the `if` of a value freed on any
        // reachable path is still flagged (real use-after-free preserved).
        _consumed_apply(t, then_keep);
        _consumed_apply(t, else_keep);
        s0.free();
        then_keep.free();
        else_keep.free();
        return;
    }
    if s.kind == ST_WHILE_RECV {
        // Validate the RHS is `recv_chan.recv()` and infer the binder's type
        // from the chan's inner T.
        let mut binder_ty: *Type = s.let_ty;
        let recv: *Expr = s.let_value;
        if recv != null && recv.kind == EX_CALL && recv.lhs != null && recv.lhs.kind == EX_MEMBER && recv.lhs.field.eq("recv") {
            let recv_target_ty: *Type = infer_expr(t, recv.lhs.lhs);
            let inner: *Type = chan_inner(recv_target_ty);
            if inner != null {
                if binder_ty == null {
                    binder_ty = inner;
                } else {
                    if !types_compat(binder_ty, inner) {
                        t.err(s.line, s.column, "while-let binder type mismatch: expected ".concat(type_to_string(binder_ty)).concat(", chan yields ").concat(type_to_string(inner)));
                    }
                }
            } else {
                t.err(s.line, s.column, "while-let RHS must be a `chan<T>.recv()` call");
            }
        } else {
            t.err(s.line, s.column, "while-let RHS must be a `chan<T>.recv()` call");
        }
        if binder_ty != null {
            t.scope.insert(s.name, *binder_ty);
        }
        if s.then_body != null {
            check_scoped_body(t, s.then_body);
        }
        return;
    }
    if s.kind == ST_WHILE {
        if s.cond != null {
            let ct: *Type = infer_expr(t, s.cond);
            if ct != null && !is_unknown_type(ct) && !is_bool_type(ct) {
                t.err(s.line, s.column, "while condition must be bool");
            }
        }
        if s.then_body != null {
            check_scoped_body(t, s.then_body);
        }
        return;
    }
    if s.kind == ST_FOR {
        let saved: i32 = enter_borrow_scope(t);
        if s.for_init != null {
            check_stmt(t, s.for_init);
        }
        if s.cond != null {
            let _u0: *Type = infer_expr(t, s.cond);
        }
        if s.for_step != null {
            let _u1: *Type = infer_expr(t, s.for_step);
        }
        if s.then_body != null {
            check_body(t, s.then_body);
        }
        exit_borrow_scope(t, saved);
        return;
    }
    if s.kind == ST_BLOCK {
        if s.then_body != null {
            check_scoped_body(t, s.then_body);
        }
        return;
    }
    if s.kind == ST_MATCH {
        let mut scrut_ty: *Type = null;
        if s.scrutinee != null {
            scrut_ty = infer_expr(t, s.scrutinee);
        }
        // Check each arm body in a borrow scope, binding payload names with
        // `__unknown__` placeholders (codegen emits them via `__typeof__`, so
        // only their presence matters here). Previously arm bodies were not
        // recursed into, so undefined names / bad statements inside them
        // slipped past the typer and surfaced as raw cc errors.
        if s.arms != null {
            for let i: i32 = 0; i < s.arms.len(); i++ {
                let a: MatchArm = s.arms.get(i);
                let saved: i32 = enter_borrow_scope(t);
                if a.bindings != null {
                    let placeholder: *Type = ty_named("__unknown__");
                    for let k: i32 = 0; k < a.bindings.len(); k++ {
                        t.scope.insert(a.bindings.get(k), *placeholder);
                    }
                }
                if a.body != null {
                    for let k: i32 = 0; k < a.body.len(); k++ {
                        let b: Stmt = a.body.get(k);
                        check_stmt(t, &b);
                    }
                }
                exit_borrow_scope(t, saved);
            }
        }
        _check_match_coverage(t, scrut_ty, s.arms, s.line, s.column);
        return;
    }
    if s.kind == ST_BREAK {
        return;
    }
    if s.kind == ST_CONTINUE {
        return;
    }
    // Raw C/asm payload — opaque to the typer.
    if s.kind == ST_CRAW {
        return;
    }
    if s.kind == ST_ASM {
        // Operand exprs go through infer_expr so undefined-name diagnostics
        // still fire; constraint strings and clobbers are GCC syntax and pass
        // through unchanged.
        if s.asm_out_exprs != null {
            for let i: i32 = 0; i < s.asm_out_exprs.len(); i++ {
                let e: Expr = s.asm_out_exprs.get(i);
                infer_expr(t, &e);
            }
        }
        if s.asm_in_exprs != null {
            for let i: i32 = 0; i < s.asm_in_exprs.len(); i++ {
                let e: Expr = s.asm_in_exprs.get(i);
                infer_expr(t, &e);
            }
        }
        return;
    }
}

fn check_let_or_const(t: *Typer, s: *Stmt) {
    // Canonicalize a qualified declared type (`let b: foo::Bar = ...`) before
    // it is compared against the initializer or recorded in scope.
    if s.let_ty != null {
        t._canon_type(s.let_ty);
    }
    // Tuple destructuring: `let (a, b, c) = expr;`. Infer the value's tuple
    // type and bind each name to its element type. Falls back to permissive
    // `__unknown__` bindings when the element type can't be resolved.
    if s.let_names != null && s.let_names.len() > 0 {
        let mut vt: *Type = null;
        if s.let_value != null {
            vt = infer_expr(t, s.let_value);
        }
        let stripped: *Type = strip_ptr(vt);
        if stripped != null && stripped.kind != TY_TUPLE {
            t.err_code(s.line, s.column, "tuple-destructure", "cannot destructure non-tuple value of type `".concat(type_to_string(vt)).concat("`"));
        }
        for let i: i32 = 0; i < s.let_names.len(); i++ {
            let nm: string = s.let_names.get(i);
            let mut bind: *Type = ty_named("__unknown__");
            if stripped != null && stripped.kind == TY_TUPLE && stripped.args != null && i < stripped.args.len() {
                let el: Type = stripped.args.get(i);
                let pp: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *pp = el;
                bind = pp;
            }
            t.scope.insert(nm, *bind);
        }
        return;
    }
    let mut final_ty: *Type = s.let_ty;
    // The annotation (if any) must name a real type — catches
    // `let x: NoSuchType = …`.
    _check_type_known(t, s.let_ty, s.line, s.column);
    // Null safety: borrows can never be null. `let r: &T = null` and friends
    // are rejected. This applies to any borrow-typed binding, regardless of
    // initializer.
    if s.let_ty != null && (s.let_ty.kind == TY_BORROW || s.let_ty.kind == TY_BORROW_MUT) {
        if s.let_value != null && s.let_value.kind == EX_NULL {
            t.err_code(s.line, s.column, "null-borrow", "borrow `".concat(type_to_string(s.let_ty)).concat("` cannot be null"));
        }
    }
    // Null safety: auto-drop owned (`let v* = expr`) cannot be initialized
    // with null — auto-free would call free(null) or hit a method on null.
    if s.kind == ST_LET && s.is_auto_owned && s.let_value != null && s.let_value.kind == EX_NULL {
        t.err_code(s.line, s.column, "null-auto-drop", "auto-drop binding `".concat(s.name).concat("` cannot be initialized with null"));
    }
    // `let b = a` where a is owned is a MOVE (a is consumed below; the codegen
    // re-targets the auto-drop from a to b), not an error.
    // Detect auto-drop:
    //   - explicit `let v* = expr` marker, OR
    //   - `let p: *T = T { ... }` struct-lit pattern.
    let mut is_auto_owned: bool = false;
    if s.kind == ST_LET && s.is_auto_owned {
        is_auto_owned = true;
    }
    if s.kind == ST_LET && final_ty != null && final_ty.kind == TY_POINTER && s.let_value != null && s.let_value.kind == EX_STRUCT_LIT && final_ty.inner != null && final_ty.inner.kind == TY_NAMED && final_ty.inner.name.eq(s.let_value.str_val) {
        is_auto_owned = true;
    }
    if s.let_value != null {
        let val_ty: *Type = infer_expr(t, s.let_value);
        // Move on rebind: `let b = a` where a is a struct VALUE or an owned
        // pointer (struct-lit, explicit, or call-result owned) moves a; reading a
        // afterward is use-after-move. Primitives copy. Marked AFTER inferring the
        // RHS so the read on this line is not itself flagged.
        if s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_IDENT && ((val_ty != null && val_ty.kind == TY_NAMED && t.structs.contains(val_ty.name)) || t.owned_locals.contains(s.let_value.str_val) || t.call_owned.contains(s.let_value.str_val)) {
            t.consumed_locals.insert(s.let_value.str_val, true);
            t.moved_out.insert(s.let_value.str_val, true);
        }
        // Synthesized `for x in <scalar>` binding (lowered for-in): the
        // iterable is a number, not a range/collection. Report it here with a
        // quick fix that wraps it in `0..` — far better than the link-time
        // `undefined __glide_int_len` the lowered `.len()/.get()` would cause.
        if s.name != null && s.name.starts_with("__glide_iter_") && _foreach_scalar_misuse(val_ty, s.let_value) {
            let mut what: string = "`".concat(type_to_string(val_ty)).concat("`");
            if is_unknown_type(val_ty) {
                what = "a length / count value";
            }
            t.err_code_range_fix(s.let_value.line, s.let_value.column, _iter_expr_span(s.let_value), "for-in-not-iterable", "cannot iterate over ".concat(what).concat(": `for-in` walks a range or a collection, not a single value. ").concat("To count, wrap it in a range like `0..n` (end-exclusive) or `0..=n` (inclusive). ").concat("To visit each element, iterate the `Vector` itself."), s.let_value.line, s.let_value.column, s.let_value.line, s.let_value.column, "0..");
        }
        if final_ty != null {
            // `let p: *T = T { .. }` auto-drop pattern: the struct literal is a
            // value but the binding is a pointer; codegen heap-allocates it
            // (malloc+init), so this is not a real mismatch. Previously it only
            // slipped through inside impl method bodies (which skip typechecking),
            // so the same line erred in a plain fn - this makes it consistent.
            let _slauto: bool = final_ty.kind == TY_POINTER && s.let_value.kind == EX_STRUCT_LIT && val_ty != null && val_ty.kind == TY_NAMED && final_ty.inner != null && final_ty.inner.kind == TY_NAMED && final_ty.inner.name.eq(val_ty.name);
            if !_slauto && !types_compat(final_ty, val_ty) {
                let wc: string = _wrap_ctor_code(final_ty, val_ty);
                let base: string = "let initializer type mismatch: expected ".concat(type_to_string(final_ty)).concat(", got ").concat(type_to_string(val_ty));
                // Pointer-vs-value: a by-value annotation (`let v: Vector<i32>`)
                // against a heap ctor that returns `*Vector<T>`. The raw message
                // reads like a deep error (and shows an unresolved `T`); point at
                // the pointer annotation or dropping it (it's inferred) instead.
                let ptr_hint: bool = final_ty.kind != TY_POINTER && val_ty.kind == TY_POINTER && val_ty.inner != null && final_ty.name != null && val_ty.inner.name != null && !final_ty.name.eq("") && final_ty.name.eq(val_ty.inner.name);
                if ptr_hint {
                    let want: string = "*".concat(type_to_string(final_ty));
                    t.err_code_range(s.let_value.line, s.let_value.column, _arg_span(s.let_value), "", base.concat(". `").concat(final_ty.name).concat("::new()` returns a pointer — annotate `").concat(want).concat("`, or drop the annotation (it's inferred)."));
                } else {
                    if wc.eq("") {
                        t.err_code_range(s.let_value.line, s.let_value.column, _arg_span(s.let_value), "", base);
                    } else {
                        let mut ctor: string = "ok";
                        if wc.eq("wrap-some") {
                            ctor = "some";
                        }
                        t.err_code_range(s.let_value.line, s.let_value.column, _arg_span(s.let_value), wc, base.concat(". Wrap the value in `").concat(ctor).concat("(...)`."));
                    }
                }
            }
        } else {
            final_ty = val_ty;
        }
    }
    if final_ty != null {
        t.scope.insert(s.name, *final_ty);
        if is_auto_owned {
            t.owned_locals.insert(s.name, true);
        }
    } else {
        // Couldn't infer (e.g. `let v = Vector::new()` — the typer's call
        // resolver doesn't know stdlib generic ctors). Still register the
        // name so subsequent references don't fail with `unknown name`. The
        // placeholder is treated as compatible-with-anything in types_compat.
        let placeholder: *Type = ty_named("__unknown__");
        t.scope.insert(s.name, *placeholder);
        if is_auto_owned {
            t.owned_locals.insert(s.name, true);
        }
    }
    // Call-result owned: `let x = make()` where `make` returns an owned value.
    // Track it (apart from owned_locals) so a later `a = x` flags use-after-move.
    if s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_CALL && _call_owned_return(t, s.let_value, final_ty) {
        t.call_owned.insert(s.name, true);
    }
    // Borrow rule R7: track let-bound `let r = &n` / `let r = &mut n` for
    // overlapping-borrow detection across statements. Scope is per-block
    // (see enter/exit_borrow_scope around if/while/for/block bodies).
    if s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_UNARY && (s.let_value.op_code == UN_ADDR || s.let_value.op_code == UN_ADDR_MUT) && s.let_value.operand != null && s.let_value.operand.kind == EX_IDENT {
        let src: string = s.let_value.operand.str_val;
        let is_mut: bool = s.let_value.op_code == UN_ADDR_MUT;
        record_borrow(t, src, is_mut, s.name, s.line, s.column);
    }
    // Arena escape tracking:
    //   `let arena: *Arena = ...`                  -> arena_locals[name]
    //   `let arena: *Arena = <existing_local_arena>` -> propagate
    //   `let p: *T = local_arena.method(...)`      -> arena_origin[p] = "local_arena"
    //   `let p: *T = q` where q is in arena_origin -> propagate
    if s.kind == ST_LET && s.name != null && !s.name.eq("") {
        // A fresh `let name = ...` rebinds the name to a live value, so any
        // earlier free of an old binding with the same name no longer
        // applies. Clearing here (after the RHS was already checked) stops a
        // later read of the new binding being flagged use-after-free — the
        // common `let x = make(); x.free();` repeated in sibling blocks.
        if t.consumed_locals.contains(s.name) {
            t.consumed_locals.insert(s.name, false);
        }
        if _is_arena_type(s.let_ty) {
            let mut treat_as_local: bool = true;
            if s.let_value != null && s.let_value.kind == EX_IDENT && !t.arena_locals.contains(s.let_value.str_val) {
                // `let arena2: *Arena = arena_param` - param-owned arena
                // stays out of arena_locals (its lifetime is the caller's).
                treat_as_local = false;
            }
            if treat_as_local {
                t.arena_locals.insert(s.name, true);
            }
        } else {
            if s.let_value != null {
                let origin: string = _expr_arena_origin(t, s.let_value);
                if !origin.eq("") {
                    t.arena_origin.insert(s.name, origin);
                }
            }
        }
    }
}

// `spawn fn(args)` / `spawn_thread fn(args)`: each captured arg is now
// owned by a task that may outlive the calling fn. Anything derived
// from a local arena would dangle once the calling fn's `defer
// arena.free()` runs - the coro / pthread might still be alive.
//
// Conservative rule: reject any arg whose region resolves to a local
// arena. The user can clone into an owned value or pass a longer-lived
// arena explicitly.
fn check_spawn(t: *Typer, s: *Stmt) {
    if s.expr_value == null {
        return;
    }
    let call: *Expr = s.expr_value;
    let _ret: *Type = infer_expr(t, call);
    if call.args == null {
        return;
    }
    let kind: string = "spawn";
    if s.is_spawn_thread {
        kind = "spawn_thread";
    }
    for let i: i32 = 0; i < call.args.len(); i++ {
        let a: Expr = call.args.get(i);
        let origin: string = _expr_arena_origin(t, &a);
        if origin.eq("") {
            continue;
        }
        if !t.arena_locals.contains(origin) {
            continue;
        }
        t.err_code(a.line, a.column, "spawn-arena-escape", kind.concat(" captures a value derived from local arena `").concat(origin).concat("`; the arena is freed when this fn returns but the spawned task may still run. Copy the data into an owned value first, or pass a longer-lived arena from the caller."));
    }
}

fn check_return(t: *Typer, s: *Stmt) {
    if s.expr_value == null {
        if t.current_ret != null {
            // `return;` inside a `fn -> !` is a valid early-success — codegen
            // rewrites it to `return __glide_ok_void();`.
            if t.current_ret.kind == TY_RESULT && t.current_ret.inner != null && t.current_ret.inner.kind == TY_NAMED && t.current_ret.inner.name.eq("void") {
                return;
            }
            t.err(s.line, s.column, "missing return value");
        }
        return;
    }
    let e: *Expr = s.expr_value;
    // Arena escape: pointer derived from a local `*Arena` must not leave
    // the fn - the caller would dereference into freed memory after the
    // arena's `defer free()` ran.
    let arena_src: string = _expr_arena_origin(t, e);
    if !arena_src.eq("") && t.arena_locals.contains(arena_src) {
        t.err_code(s.line, s.column, "arena-escape", "returned pointer derives from local arena `".concat(arena_src).concat("`; the caller would read freed memory. Accept the arena as a parameter so its lifetime is owned by the caller."));
    }
    // Returning an owned local is a MOVE, not a bug: codegen skips its auto-drop
    // at the `return` (move-out) so the caller receives a live pointer and takes
    // ownership of it. (This was an error before move-out existed.)
    // Borrow rule: cannot return `&local` / `&mut local`. Pass-through of a
    // borrow-typed param is allowed since the borrow's lifetime extends
    // beyond this fn.
    if e.kind == EX_UNARY && (e.op_code == UN_ADDR || e.op_code == UN_ADDR_MUT) && e.operand != null && e.operand.kind == EX_IDENT {
        let n: string = e.operand.str_val;
        let mut is_param_borrow: bool = false;
        if t.scope.contains(n) {
            let st: Type = t.scope.get(n);
            if st.kind == TY_BORROW || st.kind == TY_BORROW_MUT {
                is_param_borrow = true;
            }
        }
        if !is_param_borrow {
            t.err(s.line, s.column, "cannot return borrow of local `".concat(n).concat("` (would dangle after function returns)"));
        }
    }
    let vt: *Type = infer_expr(t, e);
    if t.current_ret == null {
        t.err(s.line, s.column, "return with value in fn declared without ret type");
        return;
    }
    if !types_compat(t.current_ret, vt) {
        let mut rl: i32 = s.line;
        let mut rc: i32 = s.column;
        let mut rspan: i32 = 6; // the `return` keyword
        if e != null && e.line > 0 {
            rl = e.line;
            rc = e.column;
            rspan = _arg_span(e);
        }
        let base: string = "return type mismatch: expected ".concat(type_to_string(t.current_ret)).concat(", got ").concat(type_to_string(vt));
        let mut wc: string = "";
        if e != null && e.line > 0 {
            wc = _wrap_ctor_code(t.current_ret, vt);
        }
        if wc.eq("") {
            t.err_code_range(rl, rc, rspan, "", base);
        } else {
            let mut ctor: string = "ok";
            if wc.eq("wrap-some") {
                ctor = "some";
            }
            t.err_code_range(rl, rc, rspan, wc, base.concat(". Wrap the value in `").concat(ctor).concat("(...)`."));
        }
    }
}

// ---- expression inference ------------------------------------------------

// Strip pointer/borrow wrappers, then return the chan's inner type if `t`
// is a `chan<T>`. Returns null otherwise.
fn chan_inner(t: *Type) -> *Type {
    if t == null {
        return null;
    }
    let mut x: *Type = t;
    while x != null && (x.kind == TY_POINTER || x.kind == TY_BORROW || x.kind == TY_BORROW_MUT) {
        x = x.inner;
    }
    if x == null {
        return null;
    }
    if x.kind != TY_GENERIC {
        return null;
    }
    if !x.name.eq("chan") {
        return null;
    }
    if x.args == null || x.args.len() == 0 {
        return null;
    }
    let inner: Type = x.args.get(0);
    let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
    *p = inner;
    return p;
}

pub fn infer_expr(t: *Typer, e: *Expr) -> *Type {
    if e == null {
        return null;
    }
    if e.kind == EX_INT {
        // Auto-widen literals that don't fit in a 32-bit int. Without
        // this `let n = 19_999_999_998;` infers as `int` and truncates
        // to -1474836482 in codegen, which silently breaks comparisons
        // — most visibly inside macros like `assert_eq!` where the
        // user can't easily annotate the binding.
        if e.int_val > 2147483647 || e.int_val < -2147483648 {
            return ty_named("i64");
        }
        return ty_named("i32");
    }
    if e.kind == EX_FLOAT {
        return ty_named("f64");
    }
    if e.kind == EX_STRING {
        return ty_named("string");
    }
    if e.kind == EX_BOOL {
        return ty_named("bool");
    }
    if e.kind == EX_CHAR {
        return ty_named("char");
    }
    if e.kind == EX_NULL {
        return ty_pointer(ty_named("void"));
    }
    if e.kind == EX_IF {
        // Expression-position if: both branches must produce the same
        // type, and there must be an else branch (otherwise there's
        // no value when cond is false).
        let cond_ty: *Type = infer_expr(t, e.lhs);
        if cond_ty != null && cond_ty.kind == TY_NAMED && !cond_ty.name.eq("bool") {
            t.push_diag(e.line, e.column, 1, "if-cond-type", "if condition must be `bool`, got `".concat(type_to_string(cond_ty)).concat("`"));
        }
        if e.operand == null {
            t.push_diag(e.line, e.column, 1, "if-expr-needs-else", "expression-position `if` requires an `else` branch");
            return infer_expr(t, e.rhs);
        }
        let then_ty: *Type = infer_expr(t, e.rhs);
        let else_ty: *Type = infer_expr(t, e.operand);
        if then_ty != null && else_ty != null && !type_eq(then_ty, else_ty) {
            t.push_diag(e.line, e.column, 1, "if-branch-type-mismatch", "`if` branches produce different types: `".concat(type_to_string(then_ty)).concat("` vs `").concat(type_to_string(else_ty)).concat("`"));
        }
        if then_ty != null {
            return then_ty;
        }
        return else_ty;
    }
    if e.kind == EX_BLOCK {
        // Run lead-in stmts in a fresh borrow scope; the value's type is
        // the type of the trailing expression.
        let saved: i32 = enter_borrow_scope(t);
        if e.block_stmts != null {
            for let i: i32 = 0; i < e.block_stmts.len(); i++ {
                let b: Stmt = e.block_stmts.get(i);
                check_stmt(t, &b);
            }
        }
        let v_ty: *Type = infer_expr(t, e.operand);
        exit_borrow_scope(t, saved);
        return v_ty;
    }
    if e.kind == EX_MATCH {
        let scrut_ty: *Type = infer_expr(t, e.lhs);
        let mut result_ty: *Type = null;
        if e.match_arms != null {
            for let i: i32 = 0; i < e.match_arms.len(); i++ {
                let a: MatchArm = e.match_arms.get(i);
                let saved: i32 = enter_borrow_scope(t);
                // Bind payload names with `__unknown__` placeholders. Codegen
                // emits them via `__typeof__` from the enum's payload field
                // so the runtime type is correct; the typer just needs each
                // name in scope to silence "unknown name" diags.
                if a.bindings != null {
                    let placeholder: *Type = ty_named("__unknown__");
                    for let k: i32 = 0; k < a.bindings.len(); k++ {
                        t.scope.insert(a.bindings.get(k), *placeholder);
                    }
                }
                if a.body != null && a.body.len() > 0 {
                    let last_idx: i32 = a.body.len() - 1;
                    for let k: i32 = 0; k < last_idx; k++ {
                        let b: Stmt = a.body.get(k);
                        check_stmt(t, &b);
                    }
                    let last: Stmt = a.body.get(last_idx);
                    let v: *Expr = last.expr_value;
                    let arm_ty: *Type = infer_expr(t, v);
                    if result_ty == null {
                        result_ty = arm_ty;
                    }
                }
                exit_borrow_scope(t, saved);
            }
        }
        // Expression-position match was missing the variant + exhaustiveness
        // checks the statement form had, so a non-exhaustive enum match
        // silently produced an uninitialized C switch result. e.line/e.column
        // anchor the diagnostic at the `match`.
        _check_match_coverage(t, scrut_ty, e.match_arms, e.line, e.column);
        if scrut_ty == null {
            return result_ty;
        }
        return result_ty;
    }
    if e.kind == EX_FNEXPR {
        // Check the closure body in a FRESH scope holding only its own params
        // (mirrors check_fn), with the closure's own return type. Globals,
        // consts (module_scope) and top-level fns resolve outside t.scope, so
        // they stay visible — but enclosing LOCALS do not. A closure that
        // references an enclosing local is a capture, which isn't supported
        // (codegen lifts the body to a top-level fn, leaving the captured name
        // undeclared in C); it now surfaces as a clean `unknown name` error at
        // check time instead of a confusing cc failure. This also catches
        // genuinely undefined names and bad statements inside the closure,
        // which the typer previously skipped entirely.
        let saved_fscope: *HashMap<Type> = t.scope;
        let saved_fret: *Type = t.current_ret;
        let fresh_scope: *HashMap<Type> = HashMap::new();
        t.scope = fresh_scope;
        t.current_ret = e.cast_to;
        if e.fn_expr_params != null {
            for let i: i32 = 0; i < e.fn_expr_params.len(); i++ {
                let p: Param = e.fn_expr_params.get(i);
                if p.ty != null {
                    t.scope.insert(p.name, *p.ty);
                }
            }
        }
        if e.fn_expr_body != null {
            for let i: i32 = 0; i < e.fn_expr_body.len(); i++ {
                let b: Stmt = e.fn_expr_body.get(i);
                check_stmt(t, &b);
            }
        }
        t.scope.free();
        t.scope = saved_fscope;
        t.current_ret = saved_fret;
        return ty_named("__unknown__");
    }
    if e.kind == EX_IDENT {
        // `cfg!("...")` was lowered by the expander to a `__glide_cfg_<cond>`
        // flag — a compile-time bool whose value the C preprocessor decides.
        if e.str_val != null && e.str_val.starts_with("__glide_cfg_") {
            return ty_named("bool");
        }
        // Use-after-free: a `<name>.free()` earlier in the fn flagged
        // this binding; reading it now would touch reclaimed memory.
        // Type lookup continues so downstream diagnostics still resolve.
        if t.consumed_locals.contains(e.str_val) && t.consumed_locals.get(e.str_val) {
            if t.moved_out.contains(e.str_val) && t.moved_out.get(e.str_val) {
                t.err_code(e.line, e.column, "use-after-move", "value `".concat(e.str_val).concat("` was moved earlier in this function; its ownership now belongs to the target"));
            } else {
                t.err_code(e.line, e.column, "use-after-free", "value `".concat(e.str_val).concat("` was freed earlier in this function; subsequent reads touch reclaimed memory"));
            }
        }
        // Locals + parameters always win; visibility check skipped for them.
        if t.scope.contains(e.str_val) {
            let ty: Type = t.scope.get(e.str_val);
            let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
            *p = ty;
            return p;
        }
        // Top-level consts (and other module-level bindings) live here so
        // they remain visible inside fn bodies whose local scope is fresh.
        if t.module_scope.contains(e.str_val) {
            if !t.is_visible(e.str_val) {
                t.err(e.line, e.column, "name `".concat(e.str_val).concat("` is not in scope; add an `import` for it"));
                return null;
            }
            let ty: Type = t.module_scope.get(e.str_val);
            let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
            *p = ty;
            return p;
        }
        // Maybe it's a function name. Build a real TY_FNPTR from the
        // registered signature so passing `handler` to a `r.get(...,
        // fn(*HttpRequest) -> HttpResponse)` arg actually type-checks
        // the return shape. Without this the call accepts any fn name
        // and the mismatch only surfaces at runtime as a segfault
        // (`Json<Res>` returned where `HttpResponse` was expected ABI-
        // smashes the receiver pointer chain).
        if t.fns.contains(e.str_val) {
            if !t.is_visible(e.str_val) {
                t.err(e.line, e.column, "name `".concat(e.str_val).concat("` is not in scope; add an `import` for it"));
                return null;
            }
            let sig: FnSig = t.fns.get(e.str_val);
            // Generic fns can't be expressed as a concrete fn-ptr (we
            // don't know the mono args here). Fall back to the legacy
            // placeholder so the call site stays permissive.
            if sig.type_params != null && sig.type_params.len() > 0 {
                return ty_named("__fn__");
            }
            let params: *Vector<Type> = Vector::new();
            if sig.params != null {
                for let i: i32 = 0; i < sig.params.len(); i++ {
                    let p: Param = sig.params.get(i);
                    if p.ty == null {
                        return ty_named("__fn__");
                    }
                    params.push(*p.ty);
                }
            }
            return ty_fnptr(params, sig.ret_type);
        }
        let nc: *Vector<string> = _name_candidates(t);
        let sug: string = _closest_name(e.str_val, nc);
        nc.free();
        let span: i32 = e.str_val.len();
        let msg: string = "unknown name `".concat(e.str_val).concat("`");
        if sug.eq("") {
            t.err_code_range(e.line, e.column, span, "unknown-name", msg);
        } else {
            t.err_code_range_fix(e.line, e.column, span, "unknown-name", msg.concat("; did you mean `").concat(sug).concat("`?"), e.line, e.column, e.line, e.column + span, sug);
        }
        return null;
    }
    if e.kind == EX_BINARY {
        let lt: *Type = infer_expr(t, e.lhs);
        let rt: *Type = infer_expr(t, e.rhs);
        // comparison ops -> bool
        let op: i32 = e.op_code;
        if op == OP_EQ || op == OP_NE || op == OP_LT || op == OP_LE || op == OP_GT || op == OP_GE {
            // `==` / `!=` on strings now compares CONTENTS — codegen routes to
            // the byte-compare runtime, so the old pointer-identity footgun is
            // gone. (Structural struct/tuple equality lands in a later slice;
            // until then tuple `==` still gets a clear message, not a cc error.)
            if op == OP_EQ || op == OP_NE {
                if lt != null && lt.kind == TY_TUPLE || rt != null && rt.kind == TY_TUPLE {
                    t.err_code(e.line, e.column, "tuple-eq", "tuples can't be compared with `==`/`!=` yet; compare the elements (e.g. `a.0 == b.0 && a.1 == b.1`)");
                }
            }
            return ty_named("bool");
        }
        if op == OP_AND || op == OP_OR {
            return ty_named("bool");
        }
        if op == OP_COALESCE {
            // `??` extracts the inner of an Option/Result/nullable. Result
            // type matches the LHS inner; the RHS supplies the fallback.
            let inner_lt: *Type = lt;
            if lt != null && (lt.kind == TY_OPTION || lt.kind == TY_RESULT) {
                inner_lt = lt.inner;
            }
            // RHS may either match the inner directly (fallback value) or
            // be an `err(...)` call → wraps the result back into !T.
            return inner_lt;
        }
        if !types_compat(lt, rt) {
            t.err(e.line, e.column, "binary op type mismatch: ".concat(type_to_string(lt)).concat(" vs ").concat(type_to_string(rt)));
        }
        // Numeric width promotion: if either operand is the wider of a
        // compatible pair (`i64` paired with `int`, `f64` paired with
        // `f32`), the whole expression takes the wider type. Without this
        // `2 * NANOS_PER_HOUR` infers `int` from the literal and overflows
        // (or formats with `%d` instead of `%lld`) downstream.
        let lname: string = "";
        let rname: string = "";
        if lt != null && lt.kind == TY_NAMED {
            lname = lt.name;
        }
        if rt != null && rt.kind == TY_NAMED {
            rname = rt.name;
        }
        if lname.eq("f64") || rname.eq("f64") {
            return ty_named("f64");
        }
        if lname.eq("i64") || rname.eq("i64") {
            return ty_named("i64");
        }
        return lt;
    }
    if e.kind == EX_UNARY {
        let inner: *Type = infer_expr(t, e.operand);
        if e.op_code == UN_NOT {
            return ty_named("bool");
        }
        if e.op_code == UN_DEREF {
            if inner != null && (inner.kind == TY_POINTER || inner.kind == TY_BORROW || inner.kind == TY_BORROW_MUT) {
                return inner.inner;
            }
            return inner;
        }
        if e.op_code == UN_ADDR {
            return ty_pointer(inner);
        }
        if e.op_code == UN_ADDR_MUT {
            return ty_pointer(inner);
        }
        if e.op_code == UN_TRY {
            // `expr?` is polymorphic by inner type: !T / ?T / ?!T all propagate
            // and yield the underlying T to the caller. The None→Err coercion
            // matrix lives in codegen, but two well-formedness rules must hold
            // for that lowering to be valid — codegen assumes both and falls
            // back to `/* invalid ? */` when they don't (emit_expr), so the
            // typer is the only place they can actually be reported.
            //   1. the operand must be propagatable (!T / ?T / ?!T);
            //   2. the enclosing fn must return a type that can carry what is
            //      propagated.
            // A null `inner` means the operand type wasn't inferable here (e.g.
            // a `*dyn Trait` method whose return only codegen recovers), not
            // that it is wrong — stay quiet on rule 1 in that case.
            if inner != null && inner.kind != TY_RESULT && inner.kind != TY_OPTION && inner.kind != TY_OPT_RESULT {
                t.err(e.line, e.column, "`?` expects a `!T`, `?T`, or `?!T` value, got ".concat(type_to_string(inner)));
                return inner;
            }
            // Rule 2 holds regardless of whether the operand was inferable.
            let ret: *Type = t.current_ret;
            if ret == null || (ret.kind != TY_RESULT && ret.kind != TY_OPTION && ret.kind != TY_OPT_RESULT) {
                let mut rd: string = "nothing (void)";
                if ret != null {
                    rd = "`".concat(type_to_string(ret)).concat("`");
                }
                t.err(e.line, e.column, "`?` can only propagate inside a function that returns `!T`, `?T`, or `?!T`, but this function returns ".concat(rd));
            } else if inner != null && inner.kind == TY_RESULT && ret.kind == TY_OPTION {
                // A plain `?U` return cannot hold an Err, so propagating a pure
                // `!T` there would silently drop the error. (`?!T` in a `?U` fn
                // is fine: the caller kept only the None arm on purpose.)
                let u: string = type_to_string(ret.inner);
                t.err(e.line, e.column, "`?` here propagates an error, but this function returns `".concat(type_to_string(ret)).concat("` which cannot carry one; return `!").concat(u).concat("` or `?!").concat(u).concat("` instead"));
            }
            if inner == null {
                return inner;
            }
            return inner.inner;
        }
        return inner;
    }
    if e.kind == EX_ASSIGN {
        // `c = ...` writes c, so clear any moved/consumed state on it first (the
        // LHS is a write target; c is valid again afterward). Avoids a false
        // use-after-move when reassigning a previously-moved variable.
        if e.lhs != null && e.lhs.kind == EX_IDENT {
            t.consumed_locals.insert(e.lhs.str_val, false);
            t.moved_out.insert(e.lhs.str_val, false);
        }
        let lt: *Type = infer_expr(t, e.lhs);
        let rt: *Type = infer_expr(t, e.rhs);
        // Move-on-assign: a plain `=` whose RHS is an owned local moves it; later
        // reads of that local are use-after-move (ownership now belongs to the
        // target). Mark AFTER inferring rt so the RHS read here is not flagged.
        if e.rhs != null && e.rhs.kind == EX_IDENT && (t.owned_locals.contains(e.rhs.str_val) || t.call_owned.contains(e.rhs.str_val)) {
            t.consumed_locals.insert(e.rhs.str_val, true);
            t.moved_out.insert(e.rhs.str_val, true);
        }
        if !types_compat(lt, rt) {
            t.err(e.line, e.column, "assignment type mismatch: ".concat(type_to_string(lt)).concat(" = ").concat(type_to_string(rt)));
        }
        return lt;
    }
    if e.kind == EX_CALL {
        // 256-bit constructors: `u256::from(n)` / `i256::from(n)`. These name
        // a primitive (not a struct/module), so resolve them here before the
        // generic path machinery would flag `u256` as an unknown module.
        if e.lhs != null && e.lhs.kind == EX_PATH && e.lhs.field.eq("from") && (e.lhs.str_val.eq("u256") || e.lhs.str_val.eq("i256")) {
            return ty_named(e.lhs.str_val);
        }
        // Borrow check: forbid aliased borrows of the same source within
        // a single call (`&x + &mut x`, `&mut x + &mut x`).
        check_call_aliasing(t, e);
        // ---- chan: `c.send(x)` / `c.recv()` / `c.close()` ------------
        // Check arity + arg-vs-inner type, and surface the inner as the
        // recv() return type so subsequent let-init inferences fire.
        if e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.lhs != null {
            let mname: string = e.lhs.field;
            let recv_ty: *Type = infer_expr(t, e.lhs.lhs);
            // Use-after-free: `<ident>.free()` consumes the receiver.
            // Mark AFTER recv_ty was read so the receiver's own EX_IDENT
            // check doesn't fire on this very call.
            if mname.eq("free") && e.lhs.lhs.kind == EX_IDENT {
                t.consumed_locals.insert(e.lhs.lhs.str_val, true);
            }
            let inner: *Type = chan_inner(recv_ty);
            if inner != null {
                let mut nargs: i32 = 0;
                if e.args != null {
                    nargs = e.args.len();
                }
                if mname.eq("send") {
                    if nargs != 1 {
                        t.err(e.line, e.column, "`chan.send` takes exactly 1 argument");
                    } else {
                        let a: Expr = e.args.get(0);
                        let at: *Type = infer_expr(t, &a);
                        if !types_compat(inner, at) {
                            t.err(a.line, a.column, "chan.send arg type mismatch: expected ".concat(type_to_string(inner)).concat(", got ").concat(type_to_string(at)));
                        }
                    }
                    return ty_named("void");
                }
                if mname.eq("recv") {
                    if nargs != 0 {
                        t.err(e.line, e.column, "`chan.recv` takes no arguments");
                    }
                    let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
                    *p = *inner;
                    return p;
                }
                if mname.eq("close") {
                    if nargs != 0 {
                        t.err(e.line, e.column, "`chan.close` takes no arguments");
                    }
                    return ty_named("void");
                }
            }
            // Option (`?T`) / Result (`!T`) intrinsic methods. Resolve the
            // return type so chaining + `let x: bool = o.is_some()` type-check.
            let _ors: *Type = strip_ptr(recv_ty);
            if _ors != null && (_ors.kind == TY_OPTION || _ors.kind == TY_RESULT) {
                let iso: bool = _ors.kind == TY_OPTION;
                if iso && (mname.eq("is_some") || mname.eq("is_none")) || !iso && (mname.eq("is_ok") || mname.eq("is_err")) {
                    return ty_named("bool");
                }
                if mname.eq("unwrap") || mname.eq("expect") || mname.eq("unwrap_or") || mname.eq("unwrap_or_else") {
                    if _ors.inner != null {
                        return _ors.inner;
                    }
                    return ty_named("void");
                }
                if !iso && mname.eq("unwrap_err") {
                    return ty_named("string");
                }
                if iso && mname.eq("ok_or") {
                    return ty_result(_ors.inner);
                }
                if !iso && mname.eq("ok") {
                    return ty_option(_ors.inner);
                }
                if iso && mname.eq("filter") || !iso && mname.eq("map_err") {
                    return _ors;
                }
                if mname.eq("map") && e.args != null && e.args.len() == 1 {
                    let _cl: Expr = e.args.get(0);
                    if _cl.kind == EX_FNEXPR && _cl.cast_to != null {
                        if iso {
                            return ty_option(_cl.cast_to);
                        }
                        return ty_result(_cl.cast_to);
                    }
                    return null;
                }
                if mname.eq("and_then") && e.args != null && e.args.len() == 1 {
                    let _cl: Expr = e.args.get(0);
                    if _cl.kind == EX_FNEXPR && _cl.cast_to != null {
                        return _cl.cast_to;
                    }
                    return null;
                }
            }
            // Impl method lookup: `recv.method(args)` -> `<Type>_method` in
            // the fn registry. Without this the call's return type leaks as
            // null and the surrounding check (e.g. `return r.listen()`) lets
            // `!int` slip past a fn declared `-> int`, surfacing only at C
            // compile time. Falls through to the generic args-walk below if
            // the method isn't a known impl entry.
            let stripped: *Type = strip_ptr(recv_ty);
            if stripped != null && (stripped.kind == TY_NAMED || stripped.kind == TY_GENERIC) {
                // Try the specialized key first (`Vector<int>_max` for
                // `*Vector<int>.max()`); fall back to the bare-name key
                // (`Vector_max` for the generic `impl<T> Vector<T>`). Without
                // this, three sibling specializations all collide under
                // `Vector_max` and the last-registered one wins.
                let mut mkey: string = "";
                let specialized: string = type_to_string(stripped).concat("_").concat(mname);
                if t.fns.contains(specialized) {
                    mkey = specialized;
                } else {
                    let generic_key: string = stripped.name.concat("_").concat(mname);
                    if t.fns.contains(generic_key) {
                        mkey = generic_key;
                    }
                }
                if !mkey.eq("") {
                    let msig: FnSig = t.fns.get(mkey);
                    // Arity: user args (excluding the implicit `self`) must
                    // match the method's declared params minus self. Missing
                    // or extra args are an error — same aggressiveness as a
                    // bare fn call.
                    if msig.params != null {
                        let m_alen: i32 = if e.args != null { e.args.len() } else { 0 };
                        let m_plen: i32 = msig.params.len();
                        let mut m_expected: i32 = 0;
                        if m_plen > 0 {
                            m_expected = m_plen - 1;
                        } // drop self
                        let mut m_bad: bool = m_alen != m_expected;
                        if msig.is_variadic && m_alen >= m_expected {
                            m_bad = false;
                        }
                        if m_bad {
                            t.err_code_range(_field_pos_line(e.lhs), _field_pos_col(e.lhs), mname.len(), "", "wrong arg count for `".concat(mname).concat("`: expected ").concat(int_to_str(m_expected)).concat(", got ").concat(int_to_str(m_alen)));
                        }
                    }
                    // Check each arg against the matching impl param. Skip the
                    // implicit `self` param (params[0]). Without this, passing
                    // a `fn(*HttpRequest) -> Json<X>` to `r.get("/", handler)`
                    // where Router::get wants `fn(*HttpRequest) -> HttpResponse`
                    // gets silently accepted — the ABI mismatch then crashes
                    // at runtime.
                    let user_arg_types: *Vector<*Type> = Vector::new();
                    let params_after_self: *Vector<Param> = Vector::new();
                    if e.args != null && msig.params != null {
                        let alen: i32 = e.args.len();
                        let plen: i32 = msig.params.len();
                        // params[0] = self, so user args map to params[1..plen]
                        for let i: i32 = 0; i < alen; i++ {
                            let a: Expr = e.args.get(i);
                            let at: *Type = infer_expr(t, &a);
                            user_arg_types.push(at);
                            let pidx: i32 = i + 1;
                            if pidx >= plen {
                                continue;
                            }
                            let p: Param = msig.params.get(pidx);
                            params_after_self.push(p);
                            if p.ty == null {
                                continue;
                            }
                            // Substitute owner type params in the expected
                            // type, mirroring how the return type is fixed
                            // up below.
                            let mut want_p: *Type = p.ty;
                            if stripped.kind == TY_GENERIC && stripped.args != null && msig.owner_type_params != null && msig.owner_type_params.len() == stripped.args.len() {
                                want_p = _subst_type_local(p.ty, msig.owner_type_params, stripped.args);
                                if _type_references_any(want_p, msig.owner_type_params) {
                                    continue; // can't resolve, skip check
                                }
                            }
                            if !arg_compat(want_p, at, msig.type_params) {
                                let got_name: string = if a.kind == EX_IDENT { a.str_val } else { "" };
                                t.err_code_range(a.line, a.column, _arg_span(&a), "", "arg ".concat(p.name).concat(" type mismatch: expected ").concat(type_to_string(want_p)).concat(", got ").concat(type_to_string(at)).concat(_fnptr_hint(t, want_p, at, got_name)));
                            }
                        }
                    } else {
                        if e.args != null {
                            for let i: i32 = 0; i < e.args.len(); i++ {
                                let a: Expr = e.args.get(i);
                                let at: *Type = infer_expr(t, &a);
                                user_arg_types.push(at);
                            }
                        }
                    }
                    // First-use element binding. When the receiver is a plain
                    // local whose generic element is still an unbound owner
                    // type param (`v` from `let v = Vector::new()` is stored as
                    // `*Vector<T>`), infer the element from this call's args and
                    // rewrite the local's scope type. That concretizes the
                    // element so LATER calls + the return are checked:
                    // `v.push(32); v.push("x")` then flags the second push,
                    // which an unbound `*Vector<T>` would silently accept.
                    if e.lhs.lhs.kind == EX_IDENT && stripped.kind == TY_GENERIC && stripped.args != null && msig.owner_type_params != null && msig.owner_type_params.len() > 0 && _type_references_any(stripped, msig.owner_type_params) {
                        let bound_recv: *Type = _infer_method_tparams(stripped, msig.owner_type_params, params_after_self, user_arg_types);
                        // Only commit a FULLY concrete element — never bind to
                        // another unbound param (e.g. forwarding an outer
                        // generic fn's own `T`).
                        if bound_recv != null && !_type_references_any(bound_recv, msig.owner_type_params) {
                            let mut committed: *Type = bound_recv;
                            if recv_ty != null && recv_ty.kind == TY_POINTER {
                                committed = ty_pointer(bound_recv);
                            }
                            t.scope.insert(e.lhs.lhs.str_val, *committed);
                        }
                    }
                    // Substitute the impl's `<T, U>` in the return type using
                    // the receiver's concrete args. `*Vector<int>.get()` ->
                    // int, not the placeholder T. Without subst, downstream
                    // `let x: int = v.get(0)` fires a spurious "got T".
                    if stripped.kind == TY_GENERIC && stripped.args != null && msig.owner_type_params != null && msig.owner_type_params.len() == stripped.args.len() {
                        let mut substituted: *Type = _subst_type_local(msig.ret_type, msig.owner_type_params, stripped.args);
                        // Now resolve any method-level `<U>` in the return by
                        // walking each user arg against its substituted param
                        // type. `v.fold(0, _add)` on `*Vector<int>`: owner subst
                        // turned the ret from `U` into `U` (unchanged — only T
                        // was bound). This pass binds `U` to `int` via `init: U`
                        // matched against the literal `0`.
                        if msig.type_params != null && msig.type_params.len() > 0 && _type_references_any(substituted, msig.type_params) {
                            let subst_params: *Vector<Param> = Vector::new();
                            for let i: i32 = 0; i < params_after_self.len(); i++ {
                                let p: Param = params_after_self.get(i);
                                let np: Param = p;
                                np.ty = _subst_type_local(p.ty, msig.owner_type_params, stripped.args);
                                subst_params.push(np);
                            }
                            substituted = _infer_method_tparams(substituted, msig.type_params, subst_params, user_arg_types);
                        }
                        // Receiver still generic? (`HashMap::new()` with no
                        // annotation -> *HashMap<V>, then `m.get(k)` would
                        // resolve to V again). Fall back to null so the
                        // surrounding check stays permissive — we don't know
                        // the concrete value type without flow-sensitive
                        // inference.
                        if _type_references_any(substituted, msig.owner_type_params) {
                            return null;
                        }
                        return substituted;
                    }
                    // Non-generic owner: bind method-level type params from args
                    // before falling back to null. `m.with(_inc)` on `*Mutex<int>`:
                    // owner is generic (Mutex<T>) so this branch shouldn't fire,
                    // but for plain impls like `impl Foo { fn bar<U>(x: U) -> U }`
                    // we still need to resolve U from the args.
                    let mut substituted2: *Type = msig.ret_type;
                    if msig.type_params != null && msig.type_params.len() > 0 && _type_references_any(substituted2, msig.type_params) {
                        substituted2 = _infer_method_tparams(substituted2, msig.type_params, params_after_self, user_arg_types);
                    }
                    if msig.type_params != null && msig.type_params.len() > 0 && _type_references_any(substituted2, msig.type_params) {
                        return null;
                    }
                    return substituted2;
                }
                // Method not found on a known concrete type → typo or wrong
                // receiver. chan methods + `free` are handled elsewhere; we
                // only flag named structs whose impls the typer fully
                // tracks, so generic/dyn/runtime types stay permissive.
                if t.structs.contains(stripped.name) && !mname.eq("free") && !t.method_names.contains(stripped.name.concat("::").concat(mname)) {
                    t.err_code_range(_field_pos_line(e.lhs), _field_pos_col(e.lhs), mname.len(), "", "no method `".concat(mname).concat("` on type `").concat(stripped.name).concat("`"));
                }
            }
        }
        // ---- make_chan(cap) ----------------------------------------
        if e.lhs != null && e.lhs.kind == EX_IDENT && e.lhs.str_val.eq("make_chan") {
            let mut nargs: i32 = 0;
            if e.args != null {
                nargs = e.args.len();
            }
            if nargs != 1 {
                t.err(e.line, e.column, "`make_chan` takes exactly 1 argument (capacity)");
            } else {
                let a: Expr = e.args.get(0);
                let at: *Type = infer_expr(t, &a);
                let want: *Type = ty_named("i32");
                if !types_compat(want, at) {
                    t.err(a.line, a.column, "make_chan capacity must be int, got ".concat(type_to_string(at)));
                }
            }
            return null;
        }
        // Resolve callee. If ident, look up in fn registry.
        if e.lhs != null && e.lhs.kind == EX_IDENT {
            let name: string = e.lhs.str_val;
            if t.fns.contains(name) {
                if !t.is_visible(name) {
                    t.err_code_range(e.lhs.line, e.lhs.column, name.len(), "", "name `".concat(name).concat("` is not in scope; add an `import` for it"));
                    return null;
                }
                let sig: FnSig = t.fns.get(name);
                // Check arity (if we have args). For C-style variadics
                // (`extern fn printf(fmt: string, ...)`) we only require the
                // declared params to be present and skip type-checking the
                // tail.
                if sig.params != null && e.args != null {
                    let plen: i32 = sig.params.len();
                    let alen: i32 = e.args.len();
                    let mut bad_arity: bool = plen != alen;
                    if sig.is_variadic && alen >= plen {
                        bad_arity = false;
                    }
                    if bad_arity {
                        t.err_code_range(e.lhs.line, e.lhs.column, name.len(), "", "wrong arg count for `".concat(name).concat("`"));
                    } else {
                        for let i: i32 = 0; i < plen; i++ {
                            let p: Param = sig.params.get(i);
                            let a: Expr = e.args.get(i);
                            let at: *Type = infer_expr(t, &a);
                            // `*T` param takes ownership: passing an owned value
                            // MOVES it - the source is consumed (later reads are
                            // use-after-move) and the callee owns it. A `&T` param
                            // borrows (no move). Marked AFTER inferring `at` so the
                            // arg read on this line is not itself flagged.
                            if a.kind == EX_IDENT && (t.owned_locals.contains(a.str_val) || t.call_owned.contains(a.str_val)) && p.ty != null && p.ty.kind == TY_POINTER {
                                t.consumed_locals.insert(a.str_val, true);
                                t.moved_out.insert(a.str_val, true);
                            }
                            if !arg_compat(p.ty, at, sig.type_params) {
                                let got_name: string = if a.kind == EX_IDENT { a.str_val } else { "" };
                                t.err_code_range(a.line, a.column, _arg_span(&a), "", "arg ".concat(p.name).concat(" type mismatch: expected ").concat(type_to_string(p.ty)).concat(", got ").concat(type_to_string(at)).concat(_fnptr_hint(t, p.ty, at, got_name)));
                            }
                        }
                        // Walk variadic tail args for nested type errors but
                        // don't compare against any param type.
                        if sig.is_variadic {
                            for let i: i32 = plen; i < alen; i++ {
                                let a: Expr = e.args.get(i);
                                let _u: *Type = infer_expr(t, &a);
                            }
                        }
                        check_generic_bounds(t, &sig, e.args, e.line, e.column);
                    }
                }
                return resolve_assoc_in_ret(t, &sig, e.args, sig.ret_type);
            }
            // Bare ident but not a known fn. Could be a local function
            // pointer in scope, or a language-level builtin lowered by the
            // codegen (`ok` / `err` for Result, `make_chan` for channels);
            // otherwise this is a missing import.
            let is_builtin: bool = name.eq("ok") || name.eq("err") || name.eq("some") || name.eq("none") || name.eq("make_chan") || name.eq("sizeof") || name.eq("printf")
                // Compiler intrinsics (`__name__`): `__program__()` exposes
                // the program snapshot to proc-macros, `__typeof__` is the
                // codegen type probe. Provided by the interpreter/codegen,
                // never user-declared.
                || name.eq("__program__")
                || name.eq("__typeof__");
            if !is_builtin && !t.scope.contains(name) && t.enforce_visibility {
                let fc: *Vector<string> = _name_candidates(t);
                let sug: string = _closest_name(name, fc);
                fc.free();
                let span: i32 = name.len();
                let mut fm: string = "unknown function `".concat(name).concat("`");
                if sug.eq("") {
                    fm = fm.concat("; did you forget an `import`?");
                    t.err_code_range(e.lhs.line, e.lhs.column, span, "unknown-function", fm);
                } else {
                    fm = fm.concat("; did you mean `").concat(sug).concat("`?");
                    t.err_code_range_fix(e.lhs.line, e.lhs.column, span, "unknown-function", fm, e.lhs.line, e.lhs.column, e.lhs.line, e.lhs.column + span, sug);
                }
                return null;
            }
        }
        // `Type::method(args)` — looked up via the same registry the impl
        // pre-pass populated. Returns the method's declared ret_type so
        // surrounding type-checks (let-init, chan.send, etc.) fire on
        // shape-mismatches even when full generic monomorphization isn't
        // run in the typer.
        if e.lhs != null && e.lhs.kind == EX_PATH {
            let prefix: string = t._strip_mod_prefix(e.lhs.str_val);
            let pname: string = prefix.concat("_").concat(e.lhs.field);
            // Allow if any of: prefix is a known type (struct/enum), the
            // mangled `<Type>_<method>` is registered (covers C-runtime
            // types like `Arena`), the prefix is a module path the file
            // is allowed to use, or the prefix is a generic type
            // parameter of the enclosing fn (`<T: Trait>` then
            // `T::method(v)` resolves at monomorphization time).
            let is_type: bool = t.structs.contains(prefix);
            let is_known_method: bool = t.fns.contains(pname);
            let is_type_param: bool = _is_current_type_param(t, prefix);
            if !is_type && !is_known_method && !is_type_param && !t.is_module_path_allowed(prefix) {
                let path_span: i32 = prefix.len() + 2 + e.lhs.field.len();
                t.err_code_range(e.lhs.line, e.lhs.column, path_span, "", "module `".concat(prefix).concat("` not in scope; add `import ").concat(prefix).concat(";` or use the full path"));
                return null;
            }
            if t.fns.contains(pname) {
                let sig: FnSig = t.fns.get(pname);
                // Arity check for `Type::method(args)` — missing/extra args
                // are an error, same as a bare fn call.
                let plen: i32 = if sig.params != null { sig.params.len() } else { 0 };
                if sig.params != null && e.args != null {
                    let alen: i32 = e.args.len();
                    let mut bad_arity: bool = plen != alen;
                    if sig.is_variadic && alen >= plen {
                        bad_arity = false;
                    }
                    if bad_arity {
                        let path_span: i32 = prefix.len() + 2 + e.lhs.field.len();
                        t.err_code_range(e.lhs.line, e.lhs.column, path_span, "", "wrong arg count for `".concat(prefix).concat("::").concat(e.lhs.field).concat("`: expected ").concat(int_to_str(plen)).concat(", got ").concat(int_to_str(alen)));
                    }
                }
                if e.args != null {
                    for let i: i32 = 0; i < e.args.len(); i++ {
                        let a: Expr = e.args.get(i);
                        let at: *Type = infer_expr(t, &a);
                        // Type-check each arg against its param. Skip params
                        // whose declared type mentions a method- OR owner-
                        // level type parameter (generic ctors like
                        // `Vector::new()` / `Vector::from(x: T)` — T can't be
                        // bound here without monomorphization).
                        if i < plen {
                            let p: Param = sig.params.get(i);
                            if p.ty != null && !_type_references_any(p.ty, sig.type_params) && !_type_references_any(p.ty, sig.owner_type_params) && !arg_compat(p.ty, at, sig.type_params) {
                                t.err_code_range(a.line, a.column, _arg_span(&a), "", "arg ".concat(p.name).concat(" type mismatch: expected ").concat(type_to_string(p.ty)).concat(", got ").concat(type_to_string(at)));
                            }
                        }
                    }
                }
                return sig.ret_type;
            }
        }
        // Unknown callee or method/macro: just walk args, return null
        if e.args != null {
            for let i: i32 = 0; i < e.args.len(); i++ {
                let a: Expr = e.args.get(i);
                let _u2: *Type = infer_expr(t, &a);
            }
        }
        return null;
    }
    if e.kind == EX_MEMBER {
        let recv_ty: *Type = infer_expr(t, e.lhs);
        // Tuple index `t.0` / `t.1`: numeric field selects the element type.
        let tup: *Type = strip_ptr(recv_ty);
        if tup != null && tup.kind == TY_TUPLE && tuple_field_is_index(e.field) {
            let idx: i32 = tuple_index_value(e.field);
            if tup.args != null && idx >= 0 && idx < tup.args.len() {
                let el: Type = tup.args.get(idx);
                let pp: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *pp = el;
                return pp;
            }
            return null;
        }
        // Field access on an unwrapped Result/Option/OptResult. The wrapper only
        // exposes its own fields (ok/has/tag, err, val); the wrapped value's own
        // fields are NOT reachable through it — codegen would emit them against
        // the wrapper struct and the C compiler would reject it. Type the real
        // wrapper fields, and give a clear "unwrap first" error for anything else
        // instead of leaking a confusing generated-C failure.
        if recv_ty != null && (recv_ty.kind == TY_RESULT || recv_ty.kind == TY_OPTION || recv_ty.kind == TY_OPT_RESULT) && e.field != null && !e.field.eq("") {
            if e.field.eq("val") {
                return recv_ty.inner;
            }
            if recv_ty.kind == TY_RESULT && e.field.eq("ok") || recv_ty.kind == TY_OPTION && e.field.eq("has") {
                return ty_named("bool");
            }
            if recv_ty.kind == TY_OPT_RESULT && e.field.eq("tag") {
                return ty_named("i32");
            }
            if (recv_ty.kind == TY_RESULT || recv_ty.kind == TY_OPT_RESULT) && e.field.eq("err") {
                return ty_named("string");
            }
            let unwrapper: string = if recv_ty.kind == TY_OPTION { "some" } else { "ok" };
            let fl: i32 = _field_pos_line(e);
            let fcol: i32 = _field_pos_col(e);
            t.err_code_range(fl, fcol, e.field.len(), "unwrap-needed", "`".concat(e.field).concat("` is a field of the value wrapped by `").concat(type_to_string(recv_ty)).concat("`, not of the wrapper itself; unwrap it first with `if let ").concat(unwrapper).concat("(x) = ...`, `match`, or `?`"));
            return null;
        }
        // Cross-file field privacy: if the receiver resolves to a known
        // struct and the field isn't marked `pub`, only that struct's
        // own file can access it. Methods are still resolved later via
        // the EX_CALL path; this branch fires for plain field reads.
        if recv_ty != null && t.enforce_visibility && e.field != null && !e.field.eq("") {
            let stripped: *Type = strip_ptr(recv_ty);
            // `struct_origin` only holds structs declared WITH a field list,
            // so we know their full set of fields — opaque/runtime structs
            // (Arena, …) aren't in it and stay permissive.
            if stripped != null && stripped.kind == TY_NAMED && t.struct_origin.contains(stripped.name) {
                let key: string = stripped.name.concat("::").concat(e.field);
                // Unknown field: not a declared field AND not a method
                // reference (`obj.method` as a value). A real typo.
                if !t.struct_fields_all.contains(key) && !t.method_names.contains(key) {
                    let dc: *Vector<string> = _field_candidates(t, stripped.name);
                    let sug: string = _closest_name(e.field, dc);
                    dc.free();
                    let span: i32 = e.field.len();
                    let fl: i32 = _field_pos_line(e);
                    let fcol: i32 = _field_pos_col(e);
                    let dm: string = "no field `".concat(e.field).concat("` on struct `").concat(stripped.name).concat("`");
                    if sug.eq("") {
                        t.err_code_range(fl, fcol, span, "no-field", dm);
                    } else {
                        t.err_code_range_fix(fl, fcol, span, "no-field", dm.concat("; did you mean `").concat(sug).concat("`?"), fl, fcol, fl, fcol + span, sug);
                    }
                    return null;
                }
                // Cross-file privacy: a declared-but-private field is only
                // reachable from the struct's own file.
                let owner: string = t.struct_origin.get(stripped.name);
                if !owner.eq(t.current_origin) {
                    if !t.field_pub.contains(key) {
                        // Cross-file access to a private field is a hard error:
                        // the field is encapsulated to its declaring file, so
                        // reading it elsewhere blocks the build (mirrors the
                        // strict `private-construction` rule on literals). Inside
                        // the struct's own file this branch never fires.
                        t.err_code_range(_field_pos_line(e), _field_pos_col(e), e.field.len(), "private-field", "field `".concat(e.field).concat("` of struct `").concat(stripped.name).concat("` is private to its own file; declare it `pub` to expose it"));
                    }
                }
            }
        }
        return null; // field type resolution still deferred to codegen
    }
    if e.kind == EX_INDEX {
        let _u4: *Type = infer_expr(t, e.lhs);
        let _u5: *Type = infer_expr(t, e.rhs);
        return null; // Need element type. Defer.
    }
    if e.kind == EX_CAST {
        let _u6: *Type = infer_expr(t, e.lhs);
        if e.cast_to != null {
            t._canon_type(e.cast_to);
        }
        return e.cast_to;
    }
    if e.kind == EX_PATH {
        // Associated int constants: `i32::MAX` / `u64::MIN` type as the int.
        if (e.field.eq("MAX") || e.field.eq("MIN")) && _is_int_prim_name(e.str_val) {
            return ty_named(e.str_val);
        }
        // A payload-less enum variant `Enum::Variant` is a value of type Enum.
        // Typing it (rather than returning null) lets `match Color::Red { ... }`
        // and an unannotated `let c = Color::Red` resolve the scrutinee as the
        // enum, so the variant/exhaustiveness checks fire without an explicit
        // type annotation. (Payload-carrying variants are EX_CALL, handled below.)
        let _epre: string = t._strip_mod_prefix(e.str_val);
        if t.enums.contains(_epre) {
            return ty_named(_epre);
        }
        let prefix: string = t._strip_mod_prefix(e.str_val);
        let pname: string = prefix.concat("_").concat(e.field);
        let is_type: bool = t.structs.contains(prefix);
        let is_known_method: bool = t.fns.contains(pname);
        let is_type_param: bool = _is_current_type_param(t, prefix);
        if !is_type && !is_known_method && !is_type_param && !t.is_module_path_allowed(prefix) {
            t.err(e.line, e.column, "module `".concat(prefix).concat("` not in scope; add `import ").concat(prefix).concat(";` or use the full path"));
            return null;
        }
        if t.fns.contains(pname) {
            return ty_named("__fn__");
        }
        return null;
    }
    if e.kind == EX_MACRO {
        // `format!("…{}…", args)` — the `{}` placeholders must match the
        // argument count (codegen consumes one arg per `{}`; a shortfall
        // reads a missing printf arg = UB). Only checked when the format is
        // a string literal. `println!`/`print!` space-join their args (no
        // placeholders), so their `{}` are literal and not checked.
        if e.str_val != null && e.str_val.eq("format") && e.args != null && e.args.len() > 0 {
            let first: Expr = e.args.get(0);
            if first.kind == EX_STRING {
                let holes: i32 = _count_fmt_placeholders(first.str_val);
                let supplied: i32 = e.args.len() - 1;
                if holes != supplied {
                    t.err_code_range(first.line, first.column, _arg_span(&first), "format-args", "format! has ".concat(int_to_str(holes)).concat(" `{}` placeholder").concat(if holes == 1 { "" } else { "s" }).concat(" but ").concat(int_to_str(supplied)).concat(if supplied == 1 { " argument" } else { " arguments" }).concat(if supplied == 1 { " was" } else { " were" }).concat(" supplied"));
                }
            }
        }
        // `vec_of!(a, b, c)` builds a `*Vector<T>` where T is the element type
        // (taken from the first argument). All elements must share that type —
        // codegen lowers each into a `push`, monomorphized over T. Owns its own
        // arg walk (so each arg is inferred exactly once) and checks homogeneity.
        if e.str_val != null && e.str_val.eq("vec_of") {
            if e.args == null || e.args.len() == 0 {
                t.err_code_range(e.line, e.column, 6, "vec-of-empty", "vec_of! needs at least one element to infer the vector's type; use `Vector::new()` for an empty vector");
                return null;
            }
            let first: Expr = e.args.get(0);
            let elem: *Type = infer_expr(t, &first);
            for let i: i32 = 1; i < e.args.len(); i++ {
                let a: Expr = e.args.get(i);
                let at: *Type = infer_expr(t, &a);
                if elem != null && at != null && !type_eq(at, elem) {
                    t.err_code_range(a.line, a.column, _arg_span(&a), "vec-of-mixed", "vec_of! elements must all be the same type: expected `".concat(type_to_string(elem)).concat("`, found `").concat(type_to_string(at)).concat("`"));
                }
            }
            if elem == null {
                return null;
            }
            return ty_vector_of(elem);
        }
        // Walk args for nested errors.
        if e.args != null {
            for let i: i32 = 0; i < e.args.len(); i++ {
                let a: Expr = e.args.get(i);
                let _u7: *Type = infer_expr(t, &a);
            }
        }
        if e.str_val != null && e.str_val.eq("format") {
            return ty_named("string");
        }
        // `dbg!(x)` evaluates to `x`, so it carries x's type.
        if e.str_val != null && e.str_val.eq("dbg") && e.args != null && e.args.len() >= 1 {
            let da: Expr = e.args.get(0);
            return infer_expr(t, &da);
        }
        return null;
    }
    if e.kind == EX_POSTINC || e.kind == EX_POSTDEC {
        return infer_expr(t, e.lhs);
    }
    if e.kind == EX_STRUCT_LIT {
        // Type-check every field VALUE expression. Without this an unknown name
        // in a literal slips past the typer and only surfaces at codegen as an
        // undeclared-C-variable ICE — most easily hit through field shorthand
        // (`T { a }` is sugar for `T { a: a }`, so a bare `a` with no local `a`
        // in scope must error `unknown name a`, exactly like `T { a: a }` does).
        // Also compare each value's type against the declared FIELD type so a
        // wrong-struct or pointer-vs-value field (`client: HttpClient::new()`
        // into a `*HttpResponse` field, or `*T` into a `T` field) is reported
        // here instead of silently miscompiling. Gated hard: skipped for
        // generic structs, and only "plain named / pointer" type pairs are
        // compared (see `_struct_field_checkable`) so unresolved / generic /
        // wrapper values never produce a false positive.
        if e.args != null {
            let _sl_sn: string = if e.str_val != null { t._strip_mod_prefix(e.str_val) } else { "" };
            let _sl_check: bool = !_sl_sn.eq("") && !t.struct_generic.contains(_sl_sn);
            for let i: i32 = 0; i < e.args.len(); i++ {
                let fv: Expr = e.args.get(i);
                let _vt: *Type = infer_expr(t, &fv);
                if _sl_check && e.field_names != null && i < e.field_names.len() {
                    let _fn: string = e.field_names.get(i);
                    let _key: string = _sl_sn.concat("::").concat(_fn);
                    if t.struct_field_types.contains(_key) {
                        let _ft: Type = t.struct_field_types.get(_key);
                        if _struct_field_checkable(&_ft) && _struct_field_checkable(_vt) && !types_compat(&_ft, _vt) {
                            t.err_code_range(fv.line, fv.column, _arg_span(&fv), "field-type-mismatch", "field `".concat(_fn).concat("` of `").concat(_sl_sn).concat("` expects `").concat(type_to_string(&_ft)).concat("`, got `").concat(type_to_string(_vt)).concat("`"));
                        }
                    }
                }
            }
        }
        // The struct type must be in scope. A sibling file's struct used
        // WITHOUT an import type-checks fine here but fails at codegen
        // ('unknown type name'); flag it using the same registry the
        // type-annotation check uses, so the LSP and `glide check` match the
        // compiler. A qualified `mod::Struct{}` is exempt: its module was
        // auto-loaded by the path pre-pass, so the name is already registered.
        if t.enforce_visibility && e.str_val != null && !_is_known_type_name(t, e.str_val) {
            t.err_code_range(e.line, e.column, e.str_val.len(), "", "unknown struct `".concat(e.str_val).concat("` — did you forget an `import`?"));
            return ty_named(e.str_val);
        }
        // Construction-site field visibility: setting a field of a struct
        // declared in ANOTHER file requires that field to be `pub` — exactly
        // like reading it. Without this a `pub struct` with private fields
        // could be built cross-file even though those fields can't be read,
        // so a fully-private struct would be constructible but unusable.
        // Construction visibility (Rust-style, strict): a struct with ANY
        // private field cannot be built with a literal outside its own file —
        // the private fields aren't settable there, so the type owns its
        // construction through a public function (`T::new(...)`).
        if t.enforce_visibility && e.str_val != null && t.struct_origin.contains(e.str_val) && t.struct_has_private.contains(e.str_val) {
            let owner: string = t.struct_origin.get(e.str_val);
            if !owner.eq(t.current_origin) {
                t.err_code_range(e.line, e.column, e.str_val.len(), "private-construction", "struct `".concat(e.str_val).concat("` has private fields and can't be built with a literal here; construct it through a public function (e.g. `").concat(e.str_val).concat("::new(...)`) in its own file"));
            }
        }
        return ty_named(e.str_val);
    }
    if e.kind == EX_TUPLE {
        let elems: *Vector<Type> = Vector::new();
        if e.args != null {
            for let i: i32 = 0; i < e.args.len(); i++ {
                let a: Expr = e.args.get(i);
                let et: *Type = infer_expr(t, &a);
                if et != null {
                    elems.push(*et);
                } else {
                    elems.push(*ty_named("__unknown__"));
                }
            }
        }
        return ty_tuple(elems);
    }
    return null;
}
