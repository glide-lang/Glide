        // no payload to infer from, so propagate the callee's declared param
        // type — same monomorphization as `let x: ?T = none()`. Skips params
        // that still mention an unsubstituted type param (the payload
        // inference below covers `take_generic(some(5))`). The rewrite
        // mutates the shared `lhs` node, so it survives the copy from get().
        if e.args != null {
            let _ctp: *Vector<string> = callee_type_params(g, e);
            for let _ri: i32 = 0; _ri < e.args.len(); _ri++ {
                let _ra: Expr = e.args.get(_ri);
                if _ra.kind == EX_CALL && _ra.lhs != null && _ra.lhs.kind == EX_IDENT {
                    let _rn: string = _ra.lhs.str_val;
                    if _rn.eq("some") || _rn.eq("none") || _rn.eq("ok") || _rn.eq("err") {
                        let mut _rpt: *Type = callee_param_ty(g, e, _ri);
                        // A still-generic param (`Vector<?i32>.push(x: T)`)
                        // resolves through the receiver's instantiation args
                        // when they bind every template param.
                        if _rpt != null && _ty_mentions_param(_rpt, _ctp) && e.lhs.kind == EX_MEMBER && e.lhs.lhs != null {
                            let _rrt: *Type = strip_ptr(infer_for_codegen(g, e.lhs.lhs));
                            if _rrt != null && _rrt.kind == TY_GENERIC && _rrt.args != null && _ctp != null && _rrt.args.len() >= _ctp.len() {
                                _rpt = subst_type(_rpt, _ctp, _rrt.args);
                            } else {
                                _rpt = null;
                            }
                        }
                        if _rpt != null && !_ty_mentions_param(_rpt, _ctp) {
                            _rewrite_opt_ctor(&_ra, _rpt);
                        }
                    }
                }
            }
        }
        // Bare `some(x)` / `ok(x)` ctor with no surrounding type hint (the let/
        // fn-ret paths rewrite the callee to `__glide_some_<m>` before emit, so
        // those never reach here). Lower it from the argument's inferred type so
        // a method on the literal — `some(3).unwrap_or(0)` — gets a real option/
        // result value instead of an undefined `some(...)` C call.
        if e.lhs != null && e.lhs.kind == EX_IDENT && e.args != null && e.args.len() == 1 && (e.lhs.str_val.eq("some") || e.lhs.str_val.eq("ok")) {
            let _ca0: Expr = e.args.get(0);
            let _cat: *Type = infer_for_codegen(g, &_ca0);
            if _cat != null {
                print!("__glide_".concat(e.lhs.str_val).concat("_").concat(mangle_type(_cat)).concat("("));
                emit_expr(g, &_ca0);
                print!(")");
                return;
            }
        }
        // 256-bit constructors: `u256::from(n)` / `i256::from(n)` build the
        // software struct from an int (printf/`=` can't, since it's a struct).
        if e.lhs != null && e.lhs.kind == EX_PATH && e.lhs.field.eq("from") && (e.lhs.str_val.eq("u256") || e.lhs.str_val.eq("i256")) {
            print!("__glide_".concat(e.lhs.str_val).concat("_from_i64("));
            if e.args != null && e.args.len() > 0 {
                let a0: Expr = e.args.get(0);
                emit_expr(g, &a0);
            }
            print!(")");
            return;
        }
        // Enum ctor: `Shape::Circle(5)` → struct lit. Also accepts the
        // module-qualified form `mod::path::Shape::Circle(5)` by resolving
        // the prefix back to the bare enum name first. Only fires when the
        // trailing segment is actually a variant of the enum - otherwise
        // it's an `impl <Enum> { fn from_int(...) }` method call and the
        // normal call path handles it.
        let mut _is_enum_ctor: bool = false;
        let mut _ec_ename: string = "";
        if e.lhs != null && e.lhs.kind == EX_PATH {
            let mut probe: string = e.lhs.str_val;
            if !g.enums.contains(probe) {
                probe = resolve_type_prefix(g, probe);
            }
            if g.enums.contains(probe) {
                let edef: Stmt = g.enums.get(probe);
                if edef.enum_variants != null {
                    for let vi: i32 = 0; vi < edef.enum_variants.len(); vi++ {
                        let v: EnumVariant = edef.enum_variants.get(vi);
                        if v.name.eq(e.lhs.field) {
                            _is_enum_ctor = true;
                            break;
                        }
                    }
                }
                if _is_enum_ctor {
                    _ec_ename = probe;
                }
            }
        }
        if _is_enum_ctor {
            let ename: string = _ec_ename;
            let vname: string = e.lhs.field;
            print!("((");
            print!(ename);
            print!("){.tag = ");
            print!(ename.concat("_").concat(vname));
            if e.args != null && e.args.len() > 0 {
                if e.args.len() == 1 {
                    print!(", .data.v_");
                    print!(vname);
                    print!(" = ");
                    let a: Expr = e.args.get(0);
                    emit_expr(g, &a);
                } else {
                    print!(", .data.v_");
                    print!(vname);
                    print!(" = {");
                    for let i: i32 = 0; i < e.args.len(); i++ {
                        if i > 0 {
                            print!(", ");
                        }
                        let a: Expr = e.args.get(i);
                        emit_expr(g, &a);
                    }
                    print!("}");
                }
            }
            print!("})");
            return;
        }
        // ---- chan method-style: rewrite `c.send(x)` / `c.recv()` /
        // `c.close()` to the same lowering as `send(c, x)` etc.
        if e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.lhs != null {
            let mname: string = e.lhs.field;
            let recv_e: *Expr = e.lhs.lhs;
            let recv_ty: *Type = infer_for_codegen(g, recv_e);
            let stripped: *Type = strip_ptr(recv_ty);
            if stripped != null && stripped.kind == TY_GENERIC && stripped.name.eq("chan") && stripped.args != null && stripped.args.len() > 0 {
                let inner: Type = stripped.args.get(0);
                let m: string = mangle_type(&inner);
                let mut nargs: i32 = 0;
                if e.args != null {
                    nargs = e.args.len();
                }
                // `chan<T>` lowers to `__glide_chan_T_t*` on the C side
                // already, so the send/recv/close helpers want one level
                // of pointer. A Glide-side `*chan<T>` (or `**chan<T>`)
                // adds extra indirection — emit one deref per pointer
                // wrapper to drop back to the helper's expected shape.
                let mut deref_n: i32 = 0;
                let mut t: *Type = recv_ty;
                while t != null && (t.kind == TY_POINTER || t.kind == TY_BORROW || t.kind == TY_BORROW_MUT) {
                    deref_n = deref_n + 1;
                    t = t.inner;
                }
                if mname.eq("send") && nargs == 1 {
                    print!("__glide_send_".concat(m).concat("("));
                    _emit_chan_recv(g, recv_e, deref_n);
                    print!(", ");
                    let v: Expr = e.args.get(0);
                    emit_expr(g, &v);
                    print!(")");
                    return;
                }
                if mname.eq("recv") && nargs == 0 {
                    print!("__glide_recv_".concat(m).concat("("));
                    _emit_chan_recv(g, recv_e, deref_n);
                    print!(")");
                    return;
                }
                if mname.eq("close") && nargs == 0 {
                    print!("__glide_close_".concat(m).concat("("));
                    _emit_chan_recv(g, recv_e, deref_n);
                    print!(")");
                    return;
                }
            }
        }
        // ---- Option / Result intrinsic methods ----
        if _emit_opt_res_method(g, e) {
            return;
        }
        // ---- chan builtins: make_chan / send / recv / close ----
        if e.lhs != null && e.lhs.kind == EX_IDENT && e.args != null {
            let cname: string = e.lhs.str_val;
            if cname.eq("unwrap") && e.args.len() == 1 {
                let r0: Expr = e.args.get(0);
                let rt: *Type = infer_for_codegen(g, &r0);
                if rt != null && rt.kind == TY_RESULT {
                    let m: string = mangle_type(rt.inner);
                    print!("__glide_unwrap_".concat(m).concat("("));
                    emit_expr(g, &r0);
                    print!(")");
                    return;
                }
            }
        }
        // Try generic monomorphization based on arg types (no ret-hint here).
        let no_mono_hint: *Type = null;
        let _mono_ok: bool = try_mono_call(g, e, no_mono_hint);
        // Method call: callee is a Member. Rewrite to Type_method(receiver, args).
        if e.lhs != null && e.lhs.kind == EX_MEMBER {
            let recv: *Expr = e.lhs.lhs;
            let method: string = e.lhs.field;
            let recv_ty: *Type = infer_for_codegen(g, recv);
            let stripped: *Type = strip_ptr(recv_ty);
            // Trait-object dispatch: receiver is `*dyn Trait` (fat pointer
            // struct). Look the method up in the vtable at runtime.
            if stripped != null && stripped.kind == TY_DYN {
                print!("((");
                emit_expr(g, recv);
                print!(").vtable->".concat(method).concat("(("));
                emit_expr(g, recv);
                print!(").data");
                if e.args != null {
                    for let i: i32 = 0; i < e.args.len(); i++ {
                        print!(", ");
                        let a: Expr = e.args.get(i);
                        emit_expr(g, &a);
                    }
                }
                print!("))");
                return;
            }
            // Specialized concrete impl (e.g. `impl Vector<int> { fn sum() }`).
            // The mangled prefix `Vector__int` already exists in g.fns as a
            // concrete fn — emit a direct call, no mono needed. Wins over the
            // generic family below when both define the same method name.
            if stripped != null && stripped.kind == TY_GENERIC {
                let spec_prefix: string = mangle_generic(stripped.name, stripped.args);
                let spec_name: string = spec_prefix.concat("_").concat(method);
                if g.fns.contains(spec_name) {
                    print!(spec_name);
                    print!("(");
                    let spec_needs_addr: bool = recv_ty != null && recv_ty.kind != TY_POINTER && recv_ty.kind != TY_BORROW && recv_ty.kind != TY_BORROW_MUT;
                    if spec_needs_addr {
                        print!("&");
                    }
                    emit_expr(g, recv);
                    if e.args != null {
                        for let i: i32 = 0; i < e.args.len(); i++ {
                            print!(", ");
                            let a: Expr = e.args.get(i);
                            emit_expr(g, &a);
                        }
                    }
                    print!(")");
                    return;
                }
            }
            // Generic method on a generic receiver (e.g. `v.push(x)` on
            // `*Vector<int>`). The receiver's type args bind the impl's
            // type params; mangle accordingly. If the method declares
            // additional `<U>`-style params, infer them from call args.
            if stripped != null && stripped.kind == TY_GENERIC {
                let base: string = stripped.name;
                let mname: string = base.concat("_").concat(method);
                if g.generic_fns.contains(mname) {
                    let template: Stmt = g.generic_fns.get(mname);
                    let mut full_args: *Vector<Type> = resolve_method_call_args(g, e, &template, stripped.args);
                    if full_args == null {
                        full_args = stripped.args;
                    }
                    // Defensive: a method with extra type params (e.g.
                    // `Vector.map<U>`) whose U couldn't be inferred would queue
                    // a mono with fewer args than type_params, and subst_type's
                    // args.get() would read out of bounds and segfault the
                    // compiler. Pad a CLONE (never mutate the shared
                    // stripped.args) so it fails cc cleanly instead of crashing.
                    if template.type_params != null && full_args.len() < template.type_params.len() {
                        let padded: *Vector<Type> = Vector::new();
                        for let pi: i32 = 0; pi < full_args.len(); pi++ {
                            padded.push(full_args.get(pi));
                        }
                        while padded.len() < template.type_params.len() {
                            padded.push(*ty_named("void"));
                        }
                        full_args = padded;
                    }
                    let mangled: string = mangle_generic(mname, full_args);
                    if !g.emitted_monos.contains(mangled) {
                        g.emitted_monos.insert(mangled, true);
                        let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: full_args };
                        g.fn_mono_queue.push(entry);
                    }
                    print!(mangled);
                    print!("(");
                    // Methods with `self: *T` (pointer receiver, the
                    // common case) want `&recv` when recv is a value;
                    // methods with `self: T` (by-value receiver) take
                    // recv directly. Inspect the template's first param
                    // to decide.
                    let mut p_is_ptr: bool = true;
                    if template.fn_params != null && template.fn_params.len() > 0 {
                        let first: Param = template.fn_params.get(0);
                        if first.ty != null && first.ty.kind != TY_POINTER && first.ty.kind != TY_BORROW && first.ty.kind != TY_BORROW_MUT {
                            p_is_ptr = false;
                        }
                    }
                    let r_is_ptr: bool = recv_ty != null && (recv_ty.kind == TY_POINTER || recv_ty.kind == TY_BORROW || recv_ty.kind == TY_BORROW_MUT);
                    let needs_addr: bool = p_is_ptr && !r_is_ptr;
                    let needs_deref: bool = !p_is_ptr && r_is_ptr;
                    if needs_addr {
                        print!("&");
                    }
                    if needs_deref {
                        print!("*");
                    }
                    emit_expr(g, recv);
                    if e.args != null {
                        for let i: i32 = 0; i < e.args.len(); i++ {
                            print!(", ");
                            let a: Expr = e.args.get(i);
                            emit_expr(g, &a);
                        }
                    }
                    print!(")");
                    return;
                }
            }
            if stripped != null && stripped.kind == TY_NAMED {
                let prefix: string = stripped.name;
                let mut fn_name: string = "";
                // Qualified call `s.NS::method(...)` — encoded as `NS::method` in `field`.
                // Skip the dispatch search and go straight to `NS_<type>_method`.
                let qpos: i32 = ns_split_pos(method);
                if qpos > 0 {
                    let ns: string = method.substring(0, qpos);
                    let real: string = method.substring(qpos + 2, method.len());
                    fn_name = ns.concat("_").concat(prefix).concat("_").concat(real);
                } else {
                    if is_stdlib_primitive(stripped.name) {
                        // Three-step dispatch for `s.method()` on a primitive:
                        //   1. Bareword `<type>_<method>` (impl with no namespace) — wins if it exists.
                        //   2. Namespaced `<*>_<type>_<method>` (impl in NS { ... }) — scan all fns
                        //      for keys ending in `_<type>_<method>`. Exactly one match → use it;
                        //      two or more → ambiguity error embedded in the C source so the build
                        //      fails with a clear message rather than picking arbitrarily.
                        //   3. `__glide_<type>_<method>` C runtime fallback (s.len, c.is_digit,
                        //      i.abs and the other primitive ops baked into stdlib.c).
                        let glide_name: string = prefix.concat("_").concat(method);
                        // Only sugar to `obj.method()` if the function came from
                        // an `impl T { ... }` block. A free fn coincidentally
                        // named `<Type>_<method>` is just a regular function and
                        // must be called positionally.
                        if g.fns.contains(glide_name) && g.method_fns.contains(glide_name) {
                            fn_name = glide_name;
                        } else {
                            // O(1) lookup via the method index. Multi-match values
                            // are `;`-joined; >1 segment means namespaced collision
                            // and we abort below with a build-time error.
                            let mut found: string = "";
                            let mut count: i32 = 0;
                            if g.method_index.contains(glide_name) {
                                let entry: string = g.method_index.get(glide_name);
                                let n: i32 = entry.len();
                                let mut start: i32 = 0;
                                let mut i: i32 = 0;
                                while i <= n {
                                    if i == n || entry.at(i).to_int() == 59 {
                                        let part: string = entry.substring(start, i);
                                        if part.len() > 0 {
                                            found = part;
                                            count = count + 1;
                                        }
                                        start = i + 1;
                                    }
                                    i = i + 1;
                                }
                            }
                            if count == 1 {
                                fn_name = found;
                            } else {
                                if count >= 2 {
                                    // #error in the emitted C aborts the compile with a clear message
                                    // (codegen has no direct path to the parser's diagnostic stream, and
                                    // we don't want to silently let printf("(null)") fall through).
                                    println!("");
                                    print!("#error \"ambiguous method `");
                                    print!(method);
                                    print!("` on `");
                                    print!(prefix);
                                    print!("`: multiple impl blocks register it; qualify the call as `value.NS::");
                                    print!(method);
                                    print!("()` or rename one impl\"");
                                    println!("");
                                    return;
                                } else {
                                    // The <=64-bit int widths share the i64-wide
                                    // `__glide_int_*` helpers; 128-bit ints have their
                                    // own (printf can't format __int128). char/bool/
                                    // string keep their own prefix.
                                    let mut rt_prefix: string = prefix;
                                    if prefix.eq("i128") {
                                        rt_prefix = "i128";
                                    } else {
                                        if prefix.eq("u128") {
                                            rt_prefix = "u128";
                                        } else {
                                            if _is_uint_family(prefix) {
                                                rt_prefix = "uint";
                                            } else {
                                                if _is_int_family(prefix) {
                                                    rt_prefix = "int";
                                                }
                                            }
                                        }
                                    }
                                    fn_name = "__glide_".concat(rt_prefix).concat("_").concat(method);
                                }
                            }
                        }
                    } else {
                        fn_name = prefix.concat("_").concat(method);
                    }
                }
                // Whether to insert an auto-`&` on the receiver depends on
                // the resolved method's first param: pointer-ish param + value
                // receiver -> add `&`; everything else stays as-is. Default to
                // the legacy "non-primitive non-pointer => addr" rule when we
                // can't see the signature (extern fn, runtime fallback).
                let is_prim: bool = is_stdlib_primitive(stripped.name);
                let r_is_ptr: bool = recv_ty != null && (recv_ty.kind == TY_POINTER || recv_ty.kind == TY_BORROW || recv_ty.kind == TY_BORROW_MUT);
                let mut needs_addr: bool = false;
                if g.fns.contains(fn_name) {
                    let sig: Stmt = g.fns.get(fn_name);
                    if sig.fn_params != null && sig.fn_params.len() > 0 {
                        let first: Param = sig.fn_params.get(0);
                        let p_is_ptr: bool = first.ty != null && (first.ty.kind == TY_POINTER || first.ty.kind == TY_BORROW || first.ty.kind == TY_BORROW_MUT);
                        if p_is_ptr && !r_is_ptr {
                            needs_addr = true;
                        }
                    }
                } else {
                    // Unknown signature (extern / runtime prim methods like
                    // `__glide_string_concat`): those take a VALUE receiver, so
                    // a borrowed `self` (pointer) must be dereferenced.
                    needs_addr = !is_prim && !r_is_ptr;
                }
                // `&<literal>` / `&<call()>` is not valid C (rvalue). Spill the
                // receiver into a statement-expression temp so a borrowed
                // receiver works on `"".method()` and friends. Lvalues keep
                // the direct `&x` (no behavior change).
                let recv_rvalue: bool = recv.kind != EX_IDENT && recv.kind != EX_MEMBER && recv.kind != EX_INDEX && recv.kind != EX_UNARY;
                if needs_addr && recv_rvalue {
                    print!("({ __auto_type __glide_rcv = ");
                    emit_expr(g, recv);
                    print!("; ");
                    print!(fn_name);
                    print!("(&__glide_rcv");
                    if e.args != null {
                        for let i: i32 = 0; i < e.args.len(); i++ {
                            print!(", ");
                            let a: Expr = e.args.get(i);
                            emit_expr(g, &a);
                        }
                    }
                    print!("); })");
                    return;
                }
                print!(fn_name);
                print!("(");
                if needs_addr {
                    print!("&");
                }
                emit_expr(g, recv);
                if e.args != null {
                    for let i: i32 = 0; i < e.args.len(); i++ {
                        print!(", ");
                        let a: Expr = e.args.get(i);
                        emit_expr(g, &a);
                    }
                }
                print!(")");
                return;
            }
            // Fallback: emit as plain member call.
        }
        // Indirect call through a fn-ptr (void*) — needs an inline cast in C.
        let callee_ty: *Type = infer_for_codegen(g, e.lhs);
        if callee_ty != null && callee_ty.kind == TY_FNPTR {
            print!("((");
            print!(fnptr_cast_str(callee_ty));
            print!(")");
            emit_expr(g, e.lhs);
            print!(")");
        } else {
            emit_expr(g, e.lhs);
        }
        print!("(");
        if e.args != null {
            for let i: i32 = 0; i < e.args.len(); i++ {
                if i > 0 {
                    print!(", ");
                }
                let a: Expr = e.args.get(i);
                emit_expr(g, &a);
            }
        }
        print!(")");
        return;
    }
    if e.kind == EX_MEMBER {
        // Auto-deref for pointer receivers: `p.x` -> `p->x` for *T,
        // but C also allows `(*p).x`. Emit `->` when receiver is pointer.
        // Tuple index members (`t.0`) emit the `_0` struct field name.
        let mut fld: string = c_safe_ident(e.field);
        if tuple_field_is_index(e.field) {
            fld = "_".concat(e.field);
        }
        let recv_ty: *Type = infer_for_codegen(g, e.lhs);
        if recv_ty != null && (recv_ty.kind == TY_POINTER || recv_ty.kind == TY_BORROW || recv_ty.kind == TY_BORROW_MUT) {
            print!("(");
            emit_expr(g, e.lhs);
            print!("->", fld, ")");
            return;
        }
        print!("(");
        emit_expr(g, e.lhs);
        print!(".", fld, ")");
        return;
    }
    if e.kind == EX_INDEX {
        emit_expr(g, e.lhs);
        print!("[");
        emit_expr(g, e.rhs);
        print!("]");
        return;
    }
    if e.kind == EX_CAST {
        // `expr as *dyn Trait` produces a fat pointer literal. We need the
        // source's concrete type to pick the right vtable. infer_for_codegen
        // gives us back e.g. `*Cat`; we strip the pointer and use the inner
        // name to find the static `__glide_<Type>_as_<Trait>_vt`.
        let mut dyn_trait: string = "";
        if e.cast_to != null && e.cast_to.kind == TY_POINTER && e.cast_to.inner != null && e.cast_to.inner.kind == TY_DYN {
            dyn_trait = e.cast_to.inner.name;
        } else {
            if e.cast_to != null && e.cast_to.kind == TY_DYN {
                dyn_trait = e.cast_to.name;
            }
        }
        if !dyn_trait.eq("") {
            let src_ty: *Type = infer_for_codegen(g, e.lhs);
            let inner: *Type = strip_ptr(src_ty);
            let mut src_name: string = "?";
            if inner != null && inner.kind == TY_NAMED {
                src_name = inner.name;
            }
            print!("((__glide_dyn_".concat(dyn_trait).concat("){.data = (void*)"));
            emit_expr(g, e.lhs);
            print!(", .vtable = &__glide_".concat(src_name).concat("_as_").concat(dyn_trait).concat("_vt})"));
            return;
        }
        print!("((", type_to_c(e.cast_to), ")");
        emit_expr(g, e.lhs);
        print!(")");
        return;
    }
    if e.kind == EX_SIZEOF {
        print!("sizeof(", type_to_c(e.cast_to), ")");
        return;
    }
    if e.kind == EX_FNEXPR {
        // Lift to a uniquely-named top-level fn; expression evaluates to its
        // address (which decays to a fn pointer in C).
        let id: i32 = g.anon_count;
        g.anon_count = id + 1;
        let name: string = "__glide_anon_".concat(int_to_str(id));
        let af: AnonFn = AnonFn { name: name, params: e.fn_expr_params, ret_ty: e.cast_to, body: e.fn_expr_body };
        g.anon_fns.push(af);
        print!(name);
        return;
    }
    if e.kind == EX_PATH {
        // Associated int constants: `i32::MAX` / `u64::MIN` / `u256::MAX` …
        if e.field.eq("MAX") || e.field.eq("MIN") {
            let lim: string = _int_limit_c(e.str_val, e.field.eq("MAX"));
            if !lim.eq("") {
                print!(lim);
                return;
            }
        }
        // First try the full qualified form `<prefix>::<field>` as a free
        // function alias (e.g. `stdlib::math::min_int`). Falls back to the
        // legacy `<Type>_<field>` form, with the `Type` prefix resolved
        // through the alias table so multi-segment module paths still hit
        // the existing flat C symbol.
        if g.module_aliases.contains(e.str_val.concat("::").concat(e.field)) {
            print!(g.module_aliases.get(e.str_val.concat("::").concat(e.field)));
            return;
        }
        let ty: string = resolve_type_prefix(g, e.str_val);
        // Payload-less enum variant in expression position. The `<Type>_<Var>`
        // #define is an int tag; wrap it as a struct literal so the value
        // is assignable to a `<Type>` binding. Match arms use a separate
        // emit path (`case <Type>_<Var>:`) and still see the int.
        if g.enums.contains(ty) {
            let edef: Stmt = g.enums.get(ty);
            if edef.enum_variants != null {
                for let i: i32 = 0; i < edef.enum_variants.len(); i++ {
                    let v: EnumVariant = edef.enum_variants.get(i);
                    if v.name.eq(e.field) && (v.fields == null || v.fields.len() == 0) {
                        print!("((", ty, "){.tag = ", ty.concat("_").concat(e.field), "})");
                        return;
                    }
                }
            }
        }
        print!(ty.concat("_").concat(e.field));
        return;
    }
    if e.kind == EX_POSTINC {
        emit_expr(g, e.lhs);
        print!("++");
        return;
    }
    if e.kind == EX_POSTDEC {
        emit_expr(g, e.lhs);
        print!("--");
        return;
    }
    if e.kind == EX_MACRO {
        if e.str_val.eq("println") || e.str_val.eq("print") {
            print!("printf(\"");
            // Build a format string by walking args, joining with spaces.
            if e.args != null {
                for let i: i32 = 0; i < e.args.len(); i++ {
                    if i > 0 {
                        print!(" ");
                    }
                    let a: Expr = e.args.get(i);
                    let at: *Type = infer_for_codegen(g, &a);
                    if cg_is_display(g, at) {
                        print!("%s");
                    } else {
                        print!(format_spec_for(at));
                    }
                }
            }
            if e.str_val.eq("println") {
                print!("\\n");
            }
            print!("\"");
            // Then emit args (with bool→string conversion).
            if e.args != null {
                for let i: i32 = 0; i < e.args.len(); i++ {
                    print!(", ");
                    let a: Expr = e.args.get(i);
                    let at: *Type = infer_for_codegen(g, &a);
                    if cg_is_display(g, at) {
                        emit_display_arg(g, &a, at);
                    } else {
                        if at != null && at.kind == TY_NAMED && at.name.eq("bool") {
                            print!("__glide_bool_to_string(");
                            emit_expr(g, &a);
                            print!(")");
                        } else {
                            if !_narrow_int_ctype(at).eq("") {
                                // Truncate inline narrow-int arithmetic to its declared
                                // width so it matches the stored-variable value.
                                print!("(".concat(_narrow_int_ctype(at)).concat(")("));
                                emit_expr(g, &a);
                                print!(")");
                            } else {
                                if at != null && at.kind == TY_NAMED && (at.name.eq("i64") || at.name.eq("isize") || at.name.eq("long")) {
                                    // Cast to (long long) so `%lld` works regardless of whether
                                    // int64_t is `long long` (Windows) or `long` (Linux). Quiets
                                    // -Wformat without forcing an inttypes.h dance.
                                    print!("(long long)(");
                                    emit_expr(g, &a);
                                    print!(")");
                                } else {
                                    if at != null && at.kind == TY_NAMED && (at.name.eq("u64") || at.name.eq("usize") || at.name.eq("ulong")) {
                                        print!("(unsigned long long)(");
                                        emit_expr(g, &a);
                                        print!(")");
                                    } else {
                                        if at != null && at.kind == TY_NAMED && at.name.eq("i128") {
                                            print!("__glide_i128_to_string(");
                                            emit_expr(g, &a);
                                            print!(")");
                                        } else {
                                            if at != null && at.kind == TY_NAMED && at.name.eq("u128") {
                                                print!("__glide_u128_to_string(");
                                                emit_expr(g, &a);
                                                print!(")");
                                            } else {
                                                if at != null && at.kind == TY_NAMED && at.name.eq("u256") {
                                                    print!("__glide_u256_to_string(");
                                                    emit_expr(g, &a);
                                                    print!(")");
                                                } else {
                                                    if at != null && at.kind == TY_NAMED && at.name.eq("i256") {
                                                        print!("__glide_i256_to_string(");
                                                        emit_expr(g, &a);
                                                        print!(")");
                                                    } else {
                                                        emit_expr(g, &a);
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            print!(")");
            return;
        }
        if e.str_val.eq("dbg") {
            // dbg!(x) -> ({ T __dbg = (x); fprintf(stderr,"[dbg file:line] = FMT\n", conv); __dbg; })
            // — prints to stderr and yields the value, type-aware via format_spec_for.
            if e.args == null || e.args.len() < 1 {
                print!("0");
                return;
            }
            let a: Expr = e.args.get(0);
            let at: *Type = infer_for_codegen(g, &a);
            let mut loc: string = e.macro_owner;
            if loc == null {
                loc = "";
            }
            print!("({ ");
            print!(type_to_c(at));
            print!(" __dbg = (");
            emit_expr(g, &a);
            print!("); fprintf(stderr, \"[dbg ");
            print!(loc);
            print!("] = ");
            if cg_is_display(g, at) {
                print!("%s");
            } else {
                print!(format_spec_for(at));
            }
            print!("\\n\", ");
            if cg_is_display(g, at) {
                emit_field_render_c(g, "__dbg", at, 0);
            } else {
                if at != null && at.kind == TY_NAMED && at.name.eq("bool") {
                    print!("__glide_bool_to_string(__dbg)");
                } else {
                    if !_narrow_int_ctype(at).eq("") {
                        print!("(".concat(_narrow_int_ctype(at)).concat(")(__dbg)"));
                    } else {
                        if at != null && at.kind == TY_NAMED && (at.name.eq("i64") || at.name.eq("isize") || at.name.eq("long")) {
                            print!("(long long)(__dbg)");
                        } else {
                            if at != null && at.kind == TY_NAMED && (at.name.eq("u64") || at.name.eq("usize") || at.name.eq("ulong")) {
                                print!("(unsigned long long)(__dbg)");
                            } else {
                                if at != null && at.kind == TY_NAMED && at.name.eq("i128") {
                                    print!("__glide_i128_to_string(__dbg)");
                                } else {
                                    if at != null && at.kind == TY_NAMED && at.name.eq("u128") {
                                        print!("__glide_u128_to_string(__dbg)");
                                    } else {
                                        if at != null && at.kind == TY_NAMED && at.name.eq("u256") {
                                            print!("__glide_u256_to_string(__dbg)");
                                        } else {
                                            if at != null && at.kind == TY_NAMED && at.name.eq("i256") {
                                                print!("__glide_i256_to_string(__dbg)");
                                            } else {
                                                print!("__dbg");
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            print!("); __dbg; })");
            return;
        }
        if e.str_val.eq("format") {
            // `format!(s)` with a single non-literal arg is identity over an
            // already-built string. Wrapping it in __glide_format(s) would
            // re-interpret s as a printf format string, so any `%` in it (e.g.
            // from a nested `${}` interpolation, which lowers to its own
            // format!) is read as a bogus conversion. Emit the value directly.
            if e.args != null && e.args.len() == 1 {
                let only0: Expr = e.args.get(0);
                if only0.kind != EX_STRING {
                    emit_expr(g, &only0);
                    return;
                }
            }
            print!("__glide_format(");
            // First arg: format string with {} converted to appropriate %fmt.
            if e.args != null && e.args.len() > 0 {
                let first: Expr = e.args.get(0);
                if first.kind == EX_STRING {
                    print!("\"");
                    let raw: string = first.str_val;
                    let mut arg_idx: i32 = 1;
                    let n: i32 = raw.len();
                    let mut i: i32 = 0;
                    while i < n {
                        let c: char = raw.at(i);
                        if c.to_int() == 123 && i + 1 < n && raw.at(i + 1).to_int() == 125 {
                            if e.args != null && arg_idx < e.args.len() {
                                let a: Expr = e.args.get(arg_idx);
                                let at: *Type = infer_for_codegen(g, &a);
                                if cg_is_display(g, at) {
                                    print!("%s");
                                } else {
                                    print!(format_spec_for(at));
                                }
                            } else {
                                print!("%s");
                            }
                            arg_idx = arg_idx + 1;
                            i = i + 2;
                        } else {
                            // emit char literal-safe
                            if c.to_int() == 34 {
                                print!("\\\"");
                            } else {
                                if c.to_int() == 92 {
                                    print!("\\\\");
                                } else {
                                    if c.to_int() == 37 {
                                        print!("%%");
                                    } else {
                                        print!(c);
                                    }
                                }
                            }
                            i = i + 1;
                        }
                    }
                    print!("\"");
                } else {
                    emit_expr(g, &first);
                }
                for let j: i32 = 1; j < e.args.len(); j++ {
                    print!(", ");
                    let a: Expr = e.args.get(j);
                    let at: *Type = infer_for_codegen(g, &a);
                    if cg_is_display(g, at) {
                        emit_display_arg(g, &a, at);
                    } else {
                        if !_narrow_int_ctype(at).eq("") {
                            print!("(".concat(_narrow_int_ctype(at)).concat(")("));
                            emit_expr(g, &a);
                            print!(")");
                        } else {
                            if at != null && at.kind == TY_NAMED && (at.name.eq("i64") || at.name.eq("isize") || at.name.eq("long")) {
                                print!("(long long)(");
                                emit_expr(g, &a);
                                print!(")");
                            } else {
                                if at != null && at.kind == TY_NAMED && (at.name.eq("u64") || at.name.eq("usize") || at.name.eq("ulong")) {
                                    print!("(unsigned long long)(");
                                    emit_expr(g, &a);
                                    print!(")");
                                } else {
                                    if at != null && at.kind == TY_NAMED && at.name.eq("i128") {
                                        print!("__glide_i128_to_string(");
                                        emit_expr(g, &a);
                                        print!(")");
                                    } else {
                                        if at != null && at.kind == TY_NAMED && at.name.eq("u128") {
                                            print!("__glide_u128_to_string(");
                                            emit_expr(g, &a);
                                            print!(")");
                                        } else {
                                            if at != null && at.kind == TY_NAMED && at.name.eq("u256") {
                                                print!("__glide_u256_to_string(");
                                                emit_expr(g, &a);
                                                print!(")");
                                            } else {
                                                if at != null && at.kind == TY_NAMED && at.name.eq("i256") {
                                                    print!("__glide_i256_to_string(");
                                                    emit_expr(g, &a);
                                                    print!(")");
                                                } else {
                                                    emit_expr(g, &a);
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            print!(")");
            return;
        }
        if e.str_val.eq("vec_of") {
            // Normally the prescan already lowered this to a block; if a
            // position the prescan didn't reach left it intact, lower and emit
            // it here too so the shape is still correct.
            _vec_of_rewrite(g, e);
            if e.kind == EX_BLOCK {
                emit_expr(g, e);
                return;
            }
        }
        print!("/* macro ", e.str_val, " */ 0");
        return;
    }
    if e.kind == EX_TUPLE {
        let tt: *Type = infer_for_codegen(g, e);
        if tt == null || tt.kind != TY_TUPLE {
            print!("/* tuple infer fail */ 0");
            return;
        }
        // Ensure the typedef exists even if the collection pass missed this
        // literal (e.g. it appears only in a context with no type annotation).
        register_tuple_type(g, tt);
        print!("((".concat(type_to_c(tt)).concat("){"));
        if e.args != null {
            for let i: i32 = 0; i < e.args.len(); i++ {
                if i > 0 {
                    print!(", ");
                }
                print!("._".concat(int_to_str(i)).concat(" = "));
                let v: Expr = e.args.get(i);
                emit_expr(g, &v);
            }
        }
        print!("})");
        return;
    }
    if e.kind == EX_STRUCT_LIT {
        print!("((", e.str_val, "){");
        if e.field_names != null && e.args != null {
            for let i: i32 = 0; i < e.args.len(); i++ {
                if i > 0 {
                    print!(", ");
                }
                let fname: string = e.field_names.get(i);
                print!(".", c_safe_ident(fname), " = ");
                let mut v: Expr = e.args.get(i);
                let mut fty: *Type = _field_ty_in_struct(g, e.str_val, fname);
                // Mono struct-lit (`Stack__i32 { items: Vector::new() }`): the
                // mangled name isn't in g.structs, but subst_expr left the
                // concrete generic type on cast_to — substitute the template
                // field type so an inline generic ctor gets its hint.
                if fty == null && e.cast_to != null && e.cast_to.kind == TY_GENERIC && g.generic_structs.contains(e.cast_to.name) {
                    let tmpl: Stmt = g.generic_structs.get(e.cast_to.name);
                    if tmpl.struct_fields != null && tmpl.type_params != null {
                        for let j: i32 = 0; j < tmpl.struct_fields.len(); j++ {
                            let tf: Field = tmpl.struct_fields.get(j);
                            if tf.name.eq(fname) {
                                fty = subst_type(tf.ty, tmpl.type_params, e.cast_to.args);
                            }
                        }
                    }
                }
                // `null` against a `*dyn Trait` field needs the
                // fat-pointer zero-init, not literal NULL.
                if v.kind == EX_NULL {
                    if _is_dyn_ptr(fty) {
                        _emit_null_for(fty);
                        continue;
                    }
                }
                // Propagate the field's declared type so some()/none()/
                // ok()/err() in field position monomorphize the same way
                // they do for `let x: ?T = ...`.
                _rewrite_opt_ctor(&v, fty);
                // Monomorphize a generic ctor field value (`Vector::new()`)
                // against the field type — the mono fn body that holds this
                // struct-lit is emitted without a prescan pass, so the call
                // wouldn't otherwise pick up its `*Vector<T>` hint.
                let _fmono: bool = try_mono_call(g, &v, fty);
                // Move-on-store: an owned local placed into a struct field
                // transfers ownership to the field, so skip its auto-drop.
                if v.kind == EX_IDENT && _is_owned_local(g, v.str_val) {
                    g.moved_locals.insert(v.str_val, true);
                }
                emit_expr(g, &v);
            }
        }
        print!("})");
        return;
    }
    print!("/* unknown expr ", e.kind, " */ 0");
}

// ---- statements ----------------------------------------------------------

// Emits a Glide `asm [volatile] { "instr" : outs : ins : clobbers }` block as
// a GCC-style `__asm__` statement. Each instruction line is wrapped in its
// own quoted string + "\n\t" so the generated C reads naturally and the
// assembler sees each line as a separate instruction. Constraints and clobbers
// pass through verbatim.
fn emit_asm_stmt(g: *CG, s: *Stmt, depth: i32) {
    ind(depth);
    print!("__asm__");
    if s.is_volatile {
        print!(" volatile");
    }
    print!("(");
    if s.asm_strings == null || s.asm_strings.len() == 0 {
        print!("\"\"");
    } else {
        for let i: i32 = 0; i < s.asm_strings.len(); i++ {
            if i > 0 {
                println!("");
                ind(depth + 1);
            }
            let line: string = s.asm_strings.get(i);
            print!("\"");
            // escape backslashes and quotes
            let n: i32 = line.len();
            let mut k: i32 = 0;
            while k < n {
                let c: char = line.at(k);
                if c.to_int() == 34 {
                    print!("\\\"");
                } else {
                    if c.to_int() == 92 {
                        print!("\\\\");
                    } else {
                        print!(c);
                    }
                }
                k = k + 1;
            }
            print!("\\n\\t\"");
        }
    }
    // Outputs (always emit `:` so positional sections line up if anything follows).
    let has_out: bool = s.asm_out_constraints != null && s.asm_out_constraints.len() > 0;
    let has_in: bool = s.asm_in_constraints != null && s.asm_in_constraints.len() > 0;
    let has_clb: bool = s.asm_clobbers != null && s.asm_clobbers.len() > 0;
    if has_out || has_in || has_clb {
        print!(" : ");
        if has_out {
            for let i: i32 = 0; i < s.asm_out_constraints.len(); i++ {
                if i > 0 {
                    print!(", ");
                }
                let cstr: string = "\"".concat(s.asm_out_constraints.get(i)).concat("\"(");
                print!(cstr);
                let e: Expr = s.asm_out_exprs.get(i);
                emit_expr(g, &e);
                print!(")");
            }
        }
    }
    if has_in || has_clb {
        print!(" : ");
        if has_in {
            for let i: i32 = 0; i < s.asm_in_constraints.len(); i++ {
                if i > 0 {
                    print!(", ");
                }
                let cstr: string = "\"".concat(s.asm_in_constraints.get(i)).concat("\"(");
                print!(cstr);
                let e: Expr = s.asm_in_exprs.get(i);
                emit_expr(g, &e);
                print!(")");
            }
        }
    }
    if has_clb {
        print!(" : ");
        for let i: i32 = 0; i < s.asm_clobbers.len(); i++ {
            if i > 0 {
                print!(", ");
            }
            let cstr: string = "\"".concat(s.asm_clobbers.get(i)).concat("\"");
            print!(cstr);
        }
    }
    println!(");");
}

// Statement-level `@cfg("windows"|"posix")` gate. Wraps the statement's
// emission in the same #ifdef/#endif the decl-level form uses, so a single
// stmt (or `{ ... }` block) can be target-specific inside one function.
pub fn emit_stmt(g: *CG, s: *Stmt, depth: i32) {
    if s == null {
        return;
    }
    let cfg: string = s.cfg_target;
    let gated: bool = cfg != null && (cfg.eq("windows") || cfg.eq("posix"));
    if gated {
        emit_cfg_open(cfg);
    }
    emit_stmt_inner(g, s, depth);
    if gated {
        emit_cfg_close(cfg);
    }
}

fn emit_stmt_inner(g: *CG, s: *Stmt, depth: i32) {
    if s == null {
        return;
    }
    g.emit_line_dir(s.line, s.origin);
    // Tuple destructuring: `let (a, b) = expr;`. Bind the value to a temp,
    // then declare each name as the corresponding tuple element.
    if s.kind == ST_LET && s.let_names != null && s.let_names.len() > 0 {
        let tup_ty: *Type = infer_for_codegen(g, s.let_value);
        let id: i32 = g.anon_count;
        g.anon_count = id + 1;
        let tmp: string = "__glide_dtup_".concat(int_to_str(id));
        ind(depth);
        print!("__typeof__(");
        emit_expr(g, s.let_value);
        print!(") ", tmp, " = ");
        emit_expr(g, s.let_value);
        println!(";");
        for let i: i32 = 0; i < s.let_names.len(); i++ {
            let nm: string = c_safe_ident(s.let_names.get(i));
            let field: string = tmp.concat("._").concat(int_to_str(i));
            ind(depth);
            print!("__typeof__(", field, ") ", nm, " = ", field, ";");
            println!("");
            // Declare the element type so later infer_for_codegen resolves it.
            if tup_ty != null && tup_ty.kind == TY_TUPLE && tup_ty.args != null && i < tup_ty.args.len() {
                let el: Type = tup_ty.args.get(i);
                let pp: *Type = __glide_palloc(sizeof(Type)) as *Type;
                *pp = el;
                g.declare(s.let_names.get(i), pp);
            }
        }
        return;
    }
    if s.kind == ST_LET || s.kind == ST_CONST {
        // Auto-drop modes:
        //   struct_lit_auto: `let p: *T = T { ... }` rewrites RHS to malloc+init.
        //   explicit_auto: `let v* = expr` (explicit `*` after binding name).
        // Both push a cleanup expression onto the defer stack: a method call
        // `v.free()` if the type defines one, otherwise `free(v as *void)`.
        let mut struct_lit_auto: bool = false;
        if s.kind == ST_LET && s.let_ty != null && s.let_ty.kind == TY_POINTER && s.let_value != null && s.let_value.kind == EX_STRUCT_LIT {
            if s.let_ty.inner != null && s.let_ty.inner.kind == TY_NAMED {
                if s.let_ty.inner.name.eq(s.let_value.str_val) {
                    struct_lit_auto = true;
                }
            }
        }
        let mut auto_owned: bool = struct_lit_auto || s.is_auto_owned;
        // Caller-side move: `let x: *T = make()` where `make` returns a value it
        // owns (a struct-literal local it moved out) takes ownership of that
        // value, so x is auto-dropped at scope end and the caller never frees it
        // by hand. malloc-based constructors are not owned-returning, so they are
        // unaffected; an unresolved call just leaks (never double-frees).
        if !auto_owned && s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_CALL {
            let _ck: string = _call_target_key(s.let_value, s.let_ty);
            if !_ck.eq("") && g.fns.contains(_ck) {
                let _callee: Stmt = g.fns.get(_ck);
                if _returns_auto_owned_local(g, &_callee, 0) {
                    auto_owned = true;
                }
            }
        }
        // Let-rebind move: `let e = c` where c is an owned local moves it to e -
        // e inherits the auto-drop and c is marked moved (so c is not also freed).
        if !auto_owned && s.kind == ST_LET && s.let_value != null && s.let_value.kind == EX_IDENT && _is_owned_local(g, s.let_value.str_val) {
            g.moved_locals.insert(s.let_value.str_val, true);
            auto_owned = true;
        }
        // ---- pre-pass: detect generic fn call BEFORE we emit anything,
        //      since we may need to print a forward decl on its own line.

        // Generic struct literal hint: `let b: Box<int> = Box { ... }` →
        // rewrite the struct lit type_name to the mangled mono name.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_GENERIC {
            if s.let_value.kind == EX_STRUCT_LIT && s.let_value.str_val.eq(s.let_ty.name) {
                s.let_value.str_val = mangle_generic(s.let_ty.name, s.let_ty.args);
            }
        }
        // make_chan(cap) hint: rewrite to __glide_make_chan_<m>(cap) using let-annot.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_GENERIC && s.let_ty.name.eq("chan") && s.let_ty.args != null && s.let_ty.args.len() > 0 && s.let_value.kind == EX_CALL && s.let_value.lhs != null && s.let_value.lhs.kind == EX_IDENT && s.let_value.lhs.str_val.eq("make_chan") {
            let inner: Type = s.let_ty.args.get(0);
            let m: string = mangle_type(&inner);
            s.let_value.lhs.str_val = "__glide_make_chan_".concat(m);
        }
        // ok(v)/err(s) hint: rewrite to __glide_ok_<m>/__glide_err_<m> using let-annot `!T`.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_RESULT && s.let_value.kind == EX_CALL && s.let_value.lhs != null && s.let_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(s.let_ty.inner);
            if s.let_value.lhs.str_val.eq("ok") {
                s.let_value.lhs.str_val = "__glide_ok_".concat(m);
            }
            if s.let_value.lhs.str_val.eq("err") {
                s.let_value.lhs.str_val = "__glide_err_".concat(m);
            }
        }
        // some(v)/none() hint: rewrite for ?T let-init.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_OPTION && s.let_value.kind == EX_CALL && s.let_value.lhs != null && s.let_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(s.let_ty.inner);
            if s.let_value.lhs.str_val.eq("some") {
                s.let_value.lhs.str_val = "__glide_some_".concat(m);
            }
            if s.let_value.lhs.str_val.eq("none") {
                s.let_value.lhs.str_val = "__glide_none_".concat(m);
            }
        }
        // some(v)/none()/err(s) hint: rewrite for ?!T let-init.
        if s.let_value != null && s.let_ty != null && s.let_ty.kind == TY_OPT_RESULT && s.let_value.kind == EX_CALL && s.let_value.lhs != null && s.let_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(s.let_ty.inner);
            if s.let_value.lhs.str_val.eq("some") {
                s.let_value.lhs.str_val = "__glide_optres_some_".concat(m);
            }
            if s.let_value.lhs.str_val.eq("none") {
                s.let_value.lhs.str_val = "__glide_optres_none_".concat(m);
            }
            if s.let_value.lhs.str_val.eq("err") {
                s.let_value.lhs.str_val = "__glide_optres_err_".concat(m);
            }
        }
        // Generic fn call mono attempt — uses let-annot as ret-hint plus args.
        if s.let_value != null && s.let_value.kind == EX_CALL {
            let _ok: bool = try_mono_call(g, s.let_value, s.let_ty);
        }
        // ---- now emit the let stmt itself ----
        ind(depth);
        let cname: string = c_safe_ident(s.name);
        if s.let_ty != null {
            print!(type_to_c(s.let_ty), " ", cname);
            g.declare(s.name, s.let_ty);
        } else {
            if s.let_value != null {
                // Try to infer from value. If the value is an Ident referencing
                // a lifted anon fn, use void* (fn-pointer slot).
                let mut handled: bool = false;
                if s.let_value.kind == EX_IDENT {
                    for let k: i32 = 0; k < g.anon_fns.len(); k++ {
                        let af: AnonFn = g.anon_fns.get(k);
                        if af.name.eq(s.let_value.str_val) {
                            // The C slot is a void*, but declare the binding's Glide
                            // type as the closure's fn-ptr signature so a later call
                            // `f(x)` emits the fn-ptr cast (a plain void* slot can't
                            // be called). Previously declared void* -> cc rejected
                            // `f(x)` as "not a function or function pointer".
                            print!("void* ", cname);
                            g.declare(s.name, _build_fnptr_ty(af.params, af.ret_ty));
                            handled = true;
                            break;
                        }
                    }
                }
                if !handled {
                    let vt: *Type = infer_for_codegen(g, s.let_value);
                    if vt != null {
                        print!(type_to_c(vt), " ", cname);
                        g.declare(s.name, vt);
                    } else {
                        print!("/* infer */ int ", cname);
                    }
                }
            } else {
                print!("/* infer */ int ", cname);
            }
        }
        if struct_lit_auto {
            // T* p = malloc(sizeof(T)); *p = (T){...};
            print!(" = (");
            print!(type_to_c(s.let_ty));
            print!(")malloc(sizeof(");
            print!(type_to_c(s.let_ty.inner));
            print!("));");
            println!("");
            ind(depth);
            print!("*");
            print!(cname);
            print!(" = ");
            emit_expr(g, s.let_value);
            println!(";");
        } else {
            if s.let_value != null {
                print!(" = ");
                // `let p: *dyn Foo = null;` — fat-pointer struct
                // can't take literal NULL; emit zero-init.
                if s.let_value.kind == EX_NULL && _is_dyn_ptr(s.let_ty) {
                    _emit_null_for(s.let_ty);
                } else {
                    emit_expr(g, s.let_value);
                }
            }
            println!(";");
        }
        if auto_owned {
            // Decide cleanup: prefer `v.free()` method if type defines one
            // (e.g. Vector_free); otherwise libc `free(v as *void)`.
            let inner_ty: *Type = strip_ptr(s.let_ty);
            let mut method_name: string = "";
            let mut has_method: bool = false;
            if inner_ty != null && inner_ty.kind == TY_NAMED {
                method_name = inner_ty.name.concat("_free");
                if g.fns.contains(method_name) {
                    has_method = true;
                }
            }
            if inner_ty != null && inner_ty.kind == TY_GENERIC {
                method_name = inner_ty.name.concat("_free");
                if g.generic_fns.contains(method_name) {
                    has_method = true;
                }
            }
            // Does T have `own` fields? Then its cleanup is the generated
            // recursive drop fn (computed inline to avoid a cross-file call).
            let mut t_has_own: bool = false;
            if inner_ty != null && inner_ty.kind == TY_NAMED && g.structs.contains(inner_ty.name) {
                let _osd: Stmt = g.structs.get(inner_ty.name);
                if _osd.struct_fields != null {
                    for let _ofi: i32 = 0; _ofi < _osd.struct_fields.len(); _ofi = _ofi + 1 {
                        let _off: Field = _osd.struct_fields.get(_ofi);
                        if _off.is_own {
                            t_has_own = true;
                        }
                    }
                }
            }
            if has_method {
                // Push `v.free()` (member call) onto defer; emit_expr will
                // dispatch through the existing method-on-receiver path,
                // including mono for generic receivers.
                let recv: *Expr = expr_ident(s.name, s.line, s.column);
                let mem: *Expr = expr_member(recv, "free");
                let no_args: *Vector<Expr> = Vector::new();
                let call: *Expr = expr_call(mem, no_args);
                g.auto_drop_stack.push(*call);
            } else if t_has_own {
                // T owns heap fields (`own *F` / `own F`); call its generated
                // recursive drop fn, which frees those fields then frees `v`.
                let dcallee: *Expr = expr_ident("__glide_drop_".concat(inner_ty.name), s.line, s.column);
                let dargs: *Vector<Expr> = Vector::new();
                dargs.push(*expr_ident(s.name, s.line, s.column));
                let dcall: *Expr = expr_call(dcallee, dargs);
                g.auto_drop_stack.push(*dcall);
            } else {
                let free_call: *Expr = calloc(1, sizeof(Expr)) as *Expr;
                free_call.kind = EX_CALL;
                free_call.line = s.line;
                free_call.column = s.column;
                let callee: *Expr = expr_ident("free", s.line, s.column);
                free_call.lhs = callee;
                let args: *Vector<Expr> = Vector::new();
                let cast_arg: *Expr = expr_cast(expr_ident(s.name, s.line, s.column), ty_pointer(ty_named("void")));
                args.push(*cast_arg);
                free_call.args = args;
                g.auto_drop_stack.push(*free_call);
            }
        }
        return;
    }
    if s.kind == ST_RETURN {
        // Detect `return err(...)` BEFORE rewriting `err` -> `__glide_err_X`
        // so `defer_err` cleanups can fire on this path only.
        let mut is_err_return: bool = false;
        if s.expr_value != null && s.expr_value.kind == EX_CALL && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT && s.expr_value.lhs.str_val.eq("err") {
            is_err_return = true;
        }
        // ok(v)/err(s) hint via current fn ret-type `!T`.
        if s.expr_value != null && g.current_ret_ty != null && g.current_ret_ty.kind == TY_RESULT && s.expr_value.kind == EX_CALL && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(g.current_ret_ty.inner);
            if s.expr_value.lhs.str_val.eq("ok") {
                s.expr_value.lhs.str_val = "__glide_ok_".concat(m);
            }
            if s.expr_value.lhs.str_val.eq("err") {
                s.expr_value.lhs.str_val = "__glide_err_".concat(m);
            }
        }
        // some(v)/none() hint via current fn ret-type `?T`.
        if s.expr_value != null && g.current_ret_ty != null && g.current_ret_ty.kind == TY_OPTION && s.expr_value.kind == EX_CALL && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(g.current_ret_ty.inner);
            if s.expr_value.lhs.str_val.eq("some") {
                s.expr_value.lhs.str_val = "__glide_some_".concat(m);
            }
            if s.expr_value.lhs.str_val.eq("none") {
                s.expr_value.lhs.str_val = "__glide_none_".concat(m);
            }
        }
        // some(v)/none()/err(s) hint via current fn ret-type `?!T`.
        if s.expr_value != null && g.current_ret_ty != null && g.current_ret_ty.kind == TY_OPT_RESULT && s.expr_value.kind == EX_CALL && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT {
            let m: string = mangle_type(g.current_ret_ty.inner);
            if s.expr_value.lhs.str_val.eq("some") {
                s.expr_value.lhs.str_val = "__glide_optres_some_".concat(m);
            }
            if s.expr_value.lhs.str_val.eq("none") {
                s.expr_value.lhs.str_val = "__glide_optres_none_".concat(m);
            }
            if s.expr_value.lhs.str_val.eq("err") {
                s.expr_value.lhs.str_val = "__glide_optres_err_".concat(m);
            }
        }
        // If there's a value AND there are pending cleanups (auto-drop or
        // explicit defer), capture the value in a temp BEFORE running cleanups
        // so e.g. `return v.get(0)` doesn't read freed memory after auto-drop
        // of v fires.
        let has_err_defers: bool = is_err_return && g.err_defer_stack.len() > 0;
        let has_cleanup: bool = g.defer_stack.len() > 0 || g.auto_drop_stack.len() > 0 || has_err_defers;
        // `return <local>` moves that local out to the caller; skip its auto-drop
        // here so the returned pointer does not dangle. A wrapped
        // `return ok(v)` / `some(v)` / `err(v)` also escapes the owned local `v`
        // into the returned Result/Option — skip its drop too, else the wrapped
        // pointer is freed before the caller sees it. The skip is local to this
        // return, so a conditional fall-through path still drops it.
        let mut ret_name: string = "";
        if s.expr_value != null && s.expr_value.kind == EX_IDENT {
            ret_name = s.expr_value.str_val;
        } else if s.expr_value != null && s.expr_value.kind == EX_CALL && s.expr_value.args != null && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_IDENT {
            // Only the Option/Result constructors retain the pointer (already
            // rewritten to `__glide_ok_*` / `some` / `err` / `optres_*` above).
            // Restricting to them avoids skipping the drop for an auto-borrow
            // arg (`&T` param), which would leak.
            let cn: string = s.expr_value.lhs.str_val;
            let is_wrapper: bool = cn.starts_with("__glide_ok_") || cn.starts_with("__glide_some_") || cn.starts_with("__glide_err_") || cn.starts_with("__glide_optres_");
            if is_wrapper {
                let mut ai: i32 = 0;
                while ai < s.expr_value.args.len() && ret_name.eq("") {
                    let a: Expr = s.expr_value.args.get(ai);
                    if a.kind == EX_IDENT && _is_owned_local(g, a.str_val) {
                        ret_name = a.str_val;
                    }
                    ai = ai + 1;
                }
            }
        }
        if s.expr_value != null && has_cleanup {
            ind(depth);
            print!("__typeof__(");
            emit_expr(g, s.expr_value);
            print!(") __glide_ret = ");
            emit_expr(g, s.expr_value);
            println!(";");
            if has_err_defers {
                g.emit_err_defers_reverse(depth);
            }
            g.emit_deferred_reverse(depth, ret_name);
            ind(depth);
            println!("return __glide_ret;");
        } else {
            if has_err_defers {
                g.emit_err_defers_reverse(depth);
            }
            g.emit_deferred_reverse(depth, ret_name);
            ind(depth);
            print!("return");
            if s.expr_value != null {
                print!(" ");
                emit_expr(g, s.expr_value);
            } else {
                if g.current_ret_ty != null && g.current_ret_ty.kind == TY_RESULT && g.current_ret_ty.inner != null && g.current_ret_ty.inner.kind == TY_NAMED && g.current_ret_ty.inner.name.eq("void") {
                    // `return;` inside a `fn -> !` body = explicit early success.
                    print!(" __glide_ok_void()");
                }
            }
            println!(";");
        }
        return;
    }
    if s.kind == ST_DEFER {
        if s.expr_value != null {
            let k: i32 = g.defer_flag_ctr;
            g.defer_flag_ctr = k + 1;
            ind(depth);
            println!("__gdefer[".concat(k.to_string()).concat("] = 1;"));
            g.defer_stack.push(*s.expr_value);
            g.defer_flags.push(k);
        }
        return;
    }
    if s.kind == ST_DEFER_ERR {
        if s.expr_value != null {
            g.err_defer_stack.push(*s.expr_value);
        }
        return;
    }
    if s.kind == ST_SPAWN {
        let id: i32 = g.spawn_count;
        g.spawn_count = id + 1;
        let ids: string = int_to_str(id);
        let call: *Expr = s.expr_value;
        let mut n_args: i32 = 0;
        if call != null && call.args != null {
            n_args = call.args.len();
        }
        // Leaf detection: if the spawned function carries the `@leaf`
        // attribute, the runtime can dispatch it inline on the worker
        // thread without ever mmaping a coro stack — paying ~sizeof(task)
        // bytes of RSS instead of ~4 KB (Linux page floor). The function
        // is contractually leaf: no chan ops, no sleep, no I/O. If it
        // attempts to park anyway, __glide_park aborts with a clear
        // message (see sched.c).
        let mut is_leaf_call: bool = false;
        if call != null && call.lhs != null && call.lhs.kind == EX_IDENT && g.fns.contains(call.lhs.str_val) {
            let target: Stmt = g.fns.get(call.lhs.str_val);
            if target.attrs != null {
                for let ai: i32 = 0; ai < target.attrs.len(); ai++ {
                    let a: Attr = target.attrs.get(ai);
                    if a.name != null && a.name.eq("leaf") {
                        is_leaf_call = true;
                        break;
                    }
                }
            }
        }
        // spawn_thread (real OS pthread) is incompatible with leaf —
        // pthread_create needs a function-shaped entry that takes void*
        // and returns void*, and we don't want to pay pthread cost for
        // a "leaf" anyway.
        if s.is_spawn_thread {
            is_leaf_call = false;
        }
        let spawn_fn: string = if is_leaf_call { "__glide_spawn_leaf" } else { "__glide_spawn" };
        // Zero-arg fast path — skip the malloc/free of an empty struct.
        if n_args == 0 {
            ind(depth);
            if s.is_spawn_thread {
                println!("{ pthread_t __tid; pthread_create(&__tid, NULL, __glide_spawn_stub_".concat(ids).concat(", NULL); pthread_detach(__tid); }"));
            } else {
                println!(spawn_fn.concat("(__glide_spawn_stub_").concat(ids).concat(", NULL);"));
            }
            return;
        }
        let an: string = "__glide_spawn_args_".concat(ids);
        ind(depth);
        println!("{");
        ind(depth + 1);
        println!(an.concat("* __args = (").concat(an).concat("*)malloc(sizeof(").concat(an).concat("));"));
        for let i: i32 = 0; i < call.args.len(); i++ {
            ind(depth + 1);
            print!("__args->a".concat(int_to_str(i)).concat(" = "));
            let a: Expr = call.args.get(i);
            emit_expr(g, &a);
            println!(";");
        }
        if s.is_spawn_thread {
            ind(depth + 1);
            println!("pthread_t __tid;");
            ind(depth + 1);
            println!("pthread_create(&__tid, NULL, __glide_spawn_stub_".concat(ids).concat(", __args);"));
            ind(depth + 1);
            println!("pthread_detach(__tid);");
        } else {
            ind(depth + 1);
            println!(spawn_fn.concat("(__glide_spawn_stub_").concat(ids).concat(", __args);"));
        }
        ind(depth);
        println!("}");
        return;
    }
    if s.kind == ST_EXPR {
        // Field-assign generic mono hint: for `obj.field = Generic::new()`,
        // infer T from the field's declared type and rewrite the call to
        // `Generic_new__T()` before emitting. Lets users skip the let-init
        // dance — `c.args = Vector::new()` Just Works.
        if s.expr_value != null && s.expr_value.kind == EX_ASSIGN && s.expr_value.lhs != null && s.expr_value.lhs.kind == EX_MEMBER && s.expr_value.rhs != null && s.expr_value.rhs.kind == EX_CALL {
            let field_ty: *Type = infer_for_codegen(g, s.expr_value.lhs);
            if field_ty != null {
                // some()/none()/ok()/err() RHS: monomorphize against the
                // field's declared `?T` / `!T` type, same as let-init.
                _rewrite_opt_ctor(s.expr_value.rhs, field_ty);
                let _ok: bool = try_mono_call(g, s.expr_value.rhs, field_ty);
            }
        }
        ind(depth);
        emit_expr(g, s.expr_value);
        println!(";");
        return;
    }
    if s.kind == ST_BREAK {
        ind(depth);
        println!("break;");
        return;
    }
    if s.kind == ST_CONTINUE {
        ind(depth);
        println!("continue;");
        return;
    }
    if s.kind == ST_ASM {
        emit_asm_stmt(g, s, depth);
        return;
    }
    // c_raw block: emit body verbatim, no escaping, no transformation. Trust the
    // user to produce valid C/asm.
    if s.kind == ST_CRAW {
        print!(s.name);
        return;
    }
    if s.kind == ST_IF {
        ind(depth);
        print!("if (");
        emit_expr(g, s.cond);
        println!(") {");
        if s.then_body != null {
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth);
        if s.else_body != null {
            println!("} else {");
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.else_body.len(); i++ {
                let b: Stmt = s.else_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
            ind(depth);
            println!("}");
        } else {
            println!("}");
        }
        return;
    }
    if s.kind == ST_WHILE_RECV {
        // `while let v [: T] = chan_expr.recv() { body }`
        // Lower to: { T v; while (__glide_recv_into_<m>(chan_expr, &v)) { body } }
        let recv: *Expr = s.let_value;
        let recv_target: *Expr = recv.lhs.lhs;
        let target_ty: *Type = infer_for_codegen(g, recv_target);
        let stripped: *Type = strip_ptr(target_ty);
        if stripped == null || stripped.kind != TY_GENERIC || !stripped.name.eq("chan") || stripped.args == null || stripped.args.len() == 0 {
            ind(depth);
            println!("/* while-let: receiver is not a chan<T> */");
            return;
        }
        let inner: Type = stripped.args.get(0);
        let m: string = mangle_type(&inner);
        let tc: string = type_to_c(&inner);
        let var: string = s.name;
        // Declare the binder. Use the user's annotation when present so the
        // C type matches their expectation; otherwise the chan inner type.
        let mut decl_ty: string = tc;
        if s.let_ty != null {
            decl_ty = type_to_c(s.let_ty);
        }
        ind(depth);
        println!("{");
        ind(depth + 1);
        println!(decl_ty.concat(" ").concat(var).concat(";"));
        ind(depth + 1);
        print!("while (__glide_recv_into_".concat(m).concat("("));
        emit_expr(g, recv_target);
        println!(", &".concat(var).concat(")) {"));
        g.declare(var, &inner);
        if s.then_body != null {
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 2);
            }
            g.emit_block_drops(saved, depth + 2);
        }
        ind(depth + 1);
        println!("}");
        ind(depth);
        println!("}");
        return;
    }
    if s.kind == ST_SELECT {
        // `select! { arm => { body } ... }` — race over chan ops.
        // v1 strategy: polling loop with adaptive backoff (yield_now → sleep_ms).
        // True parking on N chans is deferred (would need a wait-node refactor).
        let arms: *Vector<SelectArm> = s.select_arms;
        if arms == null || arms.len() == 0 {
            ind(depth);
            println!("/* empty select */");
            return;
        }
        let id_str: string = int_to_str(s.line * 1000 + s.column);
        let end_label: string = "__sel_end_".concat(id_str);
        let mut default_idx: i32 = -1;
        for let i: i32 = 0; i < arms.len(); i++ {
            let a: SelectArm = arms.get(i);
            if a.kind == SEL_DEFAULT {
                default_idx = i;
            }
        }
        ind(depth);
        println!("{");
        // Per-arm temp vars for value-binding recv arms.
        for let i: i32 = 0; i < arms.len(); i++ {
            let a: SelectArm = arms.get(i);
            if a.kind == SEL_RECV || a.kind == SEL_RECV_SOME {
                let chan_ty: *Type = infer_for_codegen(g, a.chan_expr);
                let stripped: *Type = strip_ptr(chan_ty);
                if stripped == null || stripped.kind != TY_GENERIC || !stripped.name.eq("chan") || stripped.args == null || stripped.args.len() == 0 {
                    ind(depth + 1);
                    println!("/* select: arm receiver is not a chan<T> */");
                    continue;
                }
                let inner: Type = stripped.args.get(0);
                let tc: string = type_to_c(&inner);
                ind(depth + 1);
                println!(tc.concat(" __sel_tmp_").concat(int_to_str(i)).concat(";"));
            }
        }
        ind(depth + 1);
        println!("int __sel_iters_".concat(id_str).concat(" = 0;"));
        ind(depth + 1);
        println!("while (1) {");
        for let i: i32 = 0; i < arms.len(); i++ {
            let a: SelectArm = arms.get(i);
            if a.kind == SEL_DEFAULT {
                continue;
            }
            if a.kind == SEL_RECV || a.kind == SEL_RECV_SOME {
                let chan_ty: *Type = infer_for_codegen(g, a.chan_expr);
                let stripped: *Type = strip_ptr(chan_ty);
                if stripped == null || stripped.kind != TY_GENERIC || !stripped.name.eq("chan") || stripped.args == null || stripped.args.len() == 0 {
                    ind(depth + 2);
                    println!("/* select arm: receiver is not a chan<T> */");
                    continue;
                }
                let inner: Type = stripped.args.get(0);
                let m: string = mangle_type(&inner);
                let tc: string = type_to_c(&inner);
                let tmp: string = "__sel_tmp_".concat(int_to_str(i));
                ind(depth + 2);
                print!("if (__glide_try_recv_".concat(m).concat("("));
                emit_expr(g, a.chan_expr);
                println!(", &".concat(tmp).concat(")) {"));
                ind(depth + 3);
                print!("__glide_wake_send_".concat(m).concat("("));
                emit_expr(g, a.chan_expr);
                println!(");");
                ind(depth + 3);
                println!("{");
                ind(depth + 4);
                println!(tc.concat(" ").concat(a.bind_name).concat(" = ").concat(tmp).concat(";"));
                g.declare(a.bind_name, &inner);
                if a.body != null {
                    let saved: i32 = g.auto_drop_stack.len();
                    for let j: i32 = 0; j < a.body.len(); j++ {
                        let bs: Stmt = a.body.get(j);
                        emit_stmt(g, &bs, depth + 4);
                    }
                    g.emit_block_drops(saved, depth + 4);
                }
                ind(depth + 4);
                println!("goto ".concat(end_label).concat(";"));
                ind(depth + 3);
                println!("}");
                ind(depth + 2);
                println!("}");
            }
            if a.kind == SEL_RECV_NONE {
                let chan_ty: *Type = infer_for_codegen(g, a.chan_expr);
                let stripped: *Type = strip_ptr(chan_ty);
                if stripped == null || stripped.kind != TY_GENERIC || !stripped.name.eq("chan") {
                    ind(depth + 2);
                    println!("/* select arm: none receiver is not a chan<T> */");
                    continue;
                }
                ind(depth + 2);
                print!("if (atomic_load_explicit(&((");
                emit_expr(g, a.chan_expr);
                println!(")->closed), memory_order_acquire)) {");
                ind(depth + 3);
                println!("{");
                if a.body != null {
                    let saved: i32 = g.auto_drop_stack.len();
                    for let j: i32 = 0; j < a.body.len(); j++ {
                        let bs: Stmt = a.body.get(j);
                        emit_stmt(g, &bs, depth + 3);
                    }
                    g.emit_block_drops(saved, depth + 3);
                }
                ind(depth + 3);
                println!("goto ".concat(end_label).concat(";"));
                ind(depth + 2);
                println!("}");
                ind(depth + 2);
                println!("}");
            }
            if a.kind == SEL_SEND {
                let chan_ty: *Type = infer_for_codegen(g, a.chan_expr);
                let stripped: *Type = strip_ptr(chan_ty);
                if stripped == null || stripped.kind != TY_GENERIC || !stripped.name.eq("chan") || stripped.args == null || stripped.args.len() == 0 {
                    ind(depth + 2);
                    println!("/* select arm: send receiver is not a chan<T> */");
                    continue;
                }
                let inner: Type = stripped.args.get(0);
                let m: string = mangle_type(&inner);
                ind(depth + 2);
                print!("if (__glide_try_send_".concat(m).concat("("));
                emit_expr(g, a.chan_expr);
                print!(", ");
                emit_expr(g, a.send_value);
                println!(")) {");
                ind(depth + 3);
                print!("__glide_wake_recv_".concat(m).concat("("));
                emit_expr(g, a.chan_expr);
                println!(");");
                ind(depth + 3);
                println!("{");
                if a.body != null {
                    let saved: i32 = g.auto_drop_stack.len();
                    for let j: i32 = 0; j < a.body.len(); j++ {
                        let bs: Stmt = a.body.get(j);
                        emit_stmt(g, &bs, depth + 3);
                    }
                    g.emit_block_drops(saved, depth + 3);
                }
                ind(depth + 3);
                println!("goto ".concat(end_label).concat(";"));
                ind(depth + 2);
                println!("}");
                ind(depth + 2);
                println!("}");
            }
        }
        if default_idx >= 0 {
            let a: SelectArm = arms.get(default_idx);
            ind(depth + 2);
            println!("{");
            if a.body != null {
                let saved: i32 = g.auto_drop_stack.len();
                for let j: i32 = 0; j < a.body.len(); j++ {
                    let bs: Stmt = a.body.get(j);
                    emit_stmt(g, &bs, depth + 3);
                }
                g.emit_block_drops(saved, depth + 3);
            }
            ind(depth + 3);
            println!("goto ".concat(end_label).concat(";"));
            ind(depth + 2);
            println!("}");
        } else {
            ind(depth + 2);
            println!("if (__sel_iters_".concat(id_str).concat(" < 64) { yield_now(); } else { sleep_ms(1); }"));
            ind(depth + 2);
            println!("__sel_iters_".concat(id_str).concat("++;"));
        }
        ind(depth + 1);
        println!("}");
        ind(depth);
        println!(end_label.concat(":;"));
        ind(depth);
        println!("}");
        return;
    }
    if s.kind == ST_WHILE {
        ind(depth);
        print!("while (");
        emit_expr(g, s.cond);
        println!(") {");
        if s.then_body != null {
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth);
        println!("}");
        return;
    }
    if s.kind == ST_FOR {
        ind(depth);
        print!("for (");
        if s.for_init != null {
            if s.for_init.kind == ST_LET {
                let fname: string = c_safe_ident(s.for_init.name);
                if s.for_init.let_ty != null {
                    print!(type_to_c(s.for_init.let_ty), " ", fname);
                    g.declare(s.for_init.name, s.for_init.let_ty);
                } else {
                    // Untyped `for let i = 0; ...`: default to int and register
                    // it in scope so the body's `i` references type-resolve to
                    // int (otherwise printf-style macros emit `%p` → hex).
                    print!("int ", fname);
                    g.declare(s.for_init.name, ty_named("i32"));
                }
                if s.for_init.let_value != null {
                    print!(" = ");
                    emit_expr(g, s.for_init.let_value);
                }
            } else {
                if s.for_init.expr_value != null {
                    emit_expr(g, s.for_init.expr_value);
                }
            }
        }
        print!("; ");
        if s.cond != null {
            emit_expr(g, s.cond);
        }
        print!("; ");
        if s.for_step != null {
            emit_expr(g, s.for_step);
        }
        println!(") {");
        if s.then_body != null {
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth);
        println!("}");
        return;
    }
    if s.kind == ST_MATCH {
        // Compile to: { Type _m = scrut; switch (_m.tag) { case ENUM_VAR: ... } }
        let scrut_ty: *Type = infer_for_codegen(g, s.scrutinee);
        // ?T / !T scrutinees lower to an if/else on .has/.ok — they have no
        // .tag/.data union, so the user-enum switch path below can't apply.
        if _emit_match_opt_res_stmt(g, s, scrut_ty, depth) {
            return;
        }
        // Literal-pattern arms lower to an equality if/else chain.
        if _emit_match_literal_stmt(g, s, scrut_ty, depth) {
            return;
        }
        ind(depth);
        println!("{");
        let mut enum_name: string = "X";
        if scrut_ty != null && scrut_ty.kind == TY_NAMED {
            enum_name = scrut_ty.name;
        }
        ind(depth + 1);
        print!(enum_name, " __m = ");
        emit_expr(g, s.scrutinee);
        println!(";");
        ind(depth + 1);
        println!("switch (__m.tag) {");
        if s.arms != null {
            for let i: i32 = 0; i < s.arms.len(); i++ {
                let a: MatchArm = s.arms.get(i);
                ind(depth + 1);
                if a.variant.eq("_") {
                    print!("default: ");
                } else {
                    print!("case ");
                    print!(enum_name.concat("_").concat(a.variant));
                    print!(": ");
                }
                println!("{");
                if a.bindings != null && a.bindings.len() > 0 {
                    if a.bindings.len() == 1 {
                        ind(depth + 2);
                        let payload: string = "__m.data.v_".concat(a.variant);
                        print!("__typeof__(");
                        print!(payload);
                        print!(") ");
                        print!(c_safe_ident(a.bindings.get(0)));
                        print!(" = ");
                        print!(payload);
                        println!(";");
                    } else {
                        for let k: i32 = 0; k < a.bindings.len(); k++ {
                            ind(depth + 2);
                            let payload: string = "__m.data.v_".concat(a.variant);
                            print!("__typeof__(");
                            print!(payload);
                            print!(".f");
                            print!(k);
                            print!(") ");
                            print!(c_safe_ident(a.bindings.get(k)));
                            print!(" = ");
                            print!(payload);
                            print!(".f");
                            print!(k);
                            println!(";");
                        }
                    }
                }
                if a.body != null {
                    for let k: i32 = 0; k < a.body.len(); k++ {
                        let bb: Stmt = a.body.get(k);
                        emit_stmt(g, &bb, depth + 2);
                    }
                }
                ind(depth + 1);
                println!("break; }");
            }
        }
        ind(depth + 1);
        println!("}");
        ind(depth);
        println!("}");
        return;
    }
    if s.kind == ST_BLOCK {
        ind(depth);
        println!("{");
        if s.then_body != null {
            let saved: i32 = g.auto_drop_stack.len();
            for let i: i32 = 0; i < s.then_body.len(); i++ {
                let b: Stmt = s.then_body.get(i);
                emit_stmt(g, &b, depth + 1);
            }
            g.emit_block_drops(saved, depth + 1);
        }
        ind(depth);
        println!("}");
        return;
    }
    ind(depth);
    println!("/* unknown stmt ", s.kind, " */");
}

// ---- top-level -----------------------------------------------------------

// Resolve a possibly-qualified path to its short C-symbol form. If `prefix`
// is empty the path is already bare; otherwise we look up `<prefix>::<name>`
// in the alias table and return the registered short name. Falls back to the
// last-segment of `prefix` (e.g. `Vector` from `stdlib::vector::Vector`)
// when no alias matches — that lets new user-written paths still resolve to
// the existing flat naming as long as the trailing type name is unique.
fn resolve_path_alias(g: *CG, prefix: string, name: string) -> string {
    if prefix == null || prefix.eq("") {
        return name;
    }
    let qual: string = prefix.concat("::").concat(name);
    if g.module_aliases.contains(qual) {
        return g.module_aliases.get(qual);
    }
    return name;
}

// Resolve the type-prefix of a multi-segment path (e.g. for
// `stdlib::vector::Vector::new`, `prefix` is `stdlib::vector::Vector` and we
// want `Vector` back). Used by EX_PATH normalisation in expression handlers.
pub fn resolve_type_prefix(g: *CG, prefix: string) -> string {
    if prefix == null || prefix.eq("") {
        return prefix;
    }
    if g.module_aliases.contains(prefix) {
        return g.module_aliases.get(prefix);
    }
    // Fallback: trailing segment after the last `::`.
    let n: i32 = prefix.len();
    let mut i: i32 = n - 1;
    while i > 0 {
        if i + 1 < n && prefix.at(i).to_int() == 58 && prefix.at(i + 1).to_int() == 58 {
            // not how we scan — fix: look for the last `::` running backwards
            break;
        }
        i = i - 1;
    }
    // Simple forward scan for last `::` (cheap; module paths are short).
    let mut last: i32 = -1;
    let mut j: i32 = 0;
    while j + 1 < n {
        if prefix.at(j).to_int() == 58 && prefix.at(j + 1).to_int() == 58 {
            last = j;
            j = j + 2;
        } else {
            j = j + 1;
        }
    }
    if last < 0 {
        return prefix;
    }
    return prefix.substring(last + 2, n);
}

// ===================== shadowing -> unique C names =======================
// `let b = e1; let b = b.val;` is valid Glide — the second `b` shadows the
// first. C forbids two declarations of one name in a block, so before emission
// we alpha-rename a binding that shadows an earlier one in the SAME scope (and
// its later references in that scope) to a unique name. A `ren` map carries
// name -> current C name down through nested scopes; each scope records its own
// changes and restores them on exit, so C's real lexical scoping is preserved.
// Runs once over every fn / method / closure body before any C is emitted.
