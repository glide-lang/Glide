// Codegen — AST to C99. Final stage of the pipeline.
//
// Emits a single self-contained translation unit:
//   1. runtime prelude (chan, sched, result template) — substituted from
//      bootstrap/runtime/*.tmpl with `@T@` / `@TC@` / `@M@` placeholders
//      replaced by per-monomorphization names.
//   2. forward declarations for every type the program reaches.
//   3. struct bodies, trait vtables, dyn fat-pointer typedefs.
//   4. function bodies (monomorphized over generic args) with a Glide-named
//      mangling scheme (`Type_method`, `Type_method__T_int`).
//
// Generic monomorphization is driven on demand: a call site with concrete
// type args triggers emission of a dedicated function. Same for any impl
// touched through `*dyn Trait` (a thunk + vtable entry per impl). The
// emitter is a string builder, not an IR — no SSA, no register allocation.
// The downstream C compiler (zig cc / mingw / cl) does the heavy lifting.
import stdlib::hashmap::*;
import bootstrap::syntax::ast::*;
import bootstrap::codegen::runtime; // extracted
import bootstrap::codegen::decls; // extracted

// Naïve string-replace: walk through `s`, copying bytes verbatim except where
// `find` matches — there we splice in `repl` and skip ahead. Used by the
// templated runtime emitters (chan, result) to substitute `@M@` / `@TC@`
// placeholders at codegen time. O(N*M) but only runs a handful of times per
// compile, on ~250-line templates, so the simple algorithm is fine.
// Locate `::` inside a method name encoded by the parser as `NS::method` (used
// for qualified method calls like `s.cores::red()`). Returns the byte index of
// the first `:` of the separator, or -1 if absent. Plain method names (no `::`)
// are the common case and exit fast.
// `c_safe_ident` mangles user-supplied identifier names that would collide
// with C keywords. Applied at every emit site where a Glide ident reaches
// the C output (let bindings, fn params, EX_IDENT references, for-loop
// counters, match-arm payload bindings, struct field decl/access, struct
// literal field designators, top-level const, fn name, struct/enum typedef
// name). The mangling prefix is `_g_`. Glide-side scope tracking still
// uses the original name; only the C-emit side mangles.
//
// Covers C99 + GCC's `asm`. Glide-keywords already collide before reaching
// the value namespace (lexer emits TOK_KEYWORD), so we don't have to mangle
// `if`/`while`/`for`/etc here.
pub fn is_c_reserved(s: string) -> bool {
    if s.eq("asm") {
        return true;
    }
    if s.eq("auto") {
        return true;
    }
    if s.eq("case") {
        return true;
    }
    if s.eq("char") {
        return true;
    }
    if s.eq("default") {
        return true;
    }
    if s.eq("do") {
        return true;
    }
    if s.eq("double") {
        return true;
    }
    if s.eq("float") {
        return true;
    }
    if s.eq("goto") {
        return true;
    }
    if s.eq("inline") {
        return true;
    }
    if s.eq("int") {
        return true;
    }
    if s.eq("long") {
        return true;
    }
    if s.eq("register") {
        return true;
    }
    if s.eq("restrict") {
        return true;
    }
    if s.eq("short") {
        return true;
    }
    if s.eq("signed") {
        return true;
    }
    if s.eq("static") {
        return true;
    }
    if s.eq("switch") {
        return true;
    }
    if s.eq("typedef") {
        return true;
    }
    if s.eq("union") {
        return true;
    }
    if s.eq("unsigned") {
        return true;
    }
    if s.eq("void") {
        return true;
    }
    // stdio.h macros that lower-case Glide users may pick as ident/field
    // names (e.g. ProcessResult.stdout). They expand to function calls in C
    // and break compilation if not mangled.
    if s.eq("stdin") {
        return true;
    }
    if s.eq("stdout") {
        return true;
    }
    if s.eq("stderr") {
        return true;
    }
    // Standard C library MACROS (stdlib/stdio/limits/signal/fcntl/errno). A
    // user const/var/field with one of these names is otherwise emitted into
    // C verbatim and redefines or clashes with the macro the runtime headers
    // already provide — e.g. `const NULL = 42` emits `#define NULL 42`, which
    // breaks every later use of NULL. Mangling is applied uniformly at the
    // definition and every reference through c_safe_ident, so the `_g_` rename
    // stays consistent. These names are never extern/FFI targets (they are
    // macros, not symbols), so the uniform rename is safe. Gated on an
    // uppercase initial (plus the lone lowercase `errno`) to keep the common
    // lowercase-identifier path cheap.
    if s.eq("errno") {
        return true;
    }
    let mut c0: i32 = 0;
    if s.len() > 0 {
        c0 = s.at(0).to_int();
    }
    if c0 >= 65 && c0 <= 90 {
        if s.eq("NULL") || s.eq("EOF") || s.eq("EXIT_SUCCESS") || s.eq("EXIT_FAILURE") {
            return true;
        }
        if s.eq("BUFSIZ") || s.eq("RAND_MAX") || s.eq("CHAR_BIT") || s.eq("MB_CUR_MAX") {
            return true;
        }
        if s.eq("INT_MAX") || s.eq("INT_MIN") || s.eq("UINT_MAX") {
            return true;
        }
        if s.eq("LONG_MAX") || s.eq("LONG_MIN") || s.eq("ULONG_MAX") {
            return true;
        }
        if s.eq("LLONG_MAX") || s.eq("LLONG_MIN") || s.eq("ULLONG_MAX") {
            return true;
        }
        if s.eq("CHAR_MAX") || s.eq("CHAR_MIN") || s.eq("SCHAR_MAX") || s.eq("SCHAR_MIN") {
            return true;
        }
        if s.eq("UCHAR_MAX") || s.eq("SHRT_MAX") || s.eq("SHRT_MIN") || s.eq("USHRT_MAX") {
            return true;
        }
        if s.eq("SIZE_MAX") || s.eq("SSIZE_MAX") || s.eq("PATH_MAX") || s.eq("NAME_MAX") {
            return true;
        }
        if s.eq("SEEK_SET") || s.eq("SEEK_CUR") || s.eq("SEEK_END") {
            return true;
        }
        if s.eq("FILENAME_MAX") || s.eq("FOPEN_MAX") || s.eq("TMP_MAX") {
            return true;
        }
        if s.eq("SIGINT") || s.eq("SIGTERM") || s.eq("SIGKILL") || s.eq("SIGSEGV") {
            return true;
        }
        if s.eq("SIGABRT") || s.eq("SIGFPE") || s.eq("SIGILL") || s.eq("SIGHUP") {
            return true;
        }
        if s.eq("SIGQUIT") || s.eq("SIGALRM") || s.eq("SIGCHLD") || s.eq("SIGPIPE") {
            return true;
        }
        if s.eq("SIGUSR1") || s.eq("SIGUSR2") || s.eq("SIGSTOP") || s.eq("SIGCONT") {
            return true;
        }
        if s.eq("O_RDONLY") || s.eq("O_WRONLY") || s.eq("O_RDWR") || s.eq("O_CREAT") {
            return true;
        }
        if s.eq("O_APPEND") || s.eq("O_TRUNC") || s.eq("O_EXCL") || s.eq("O_NONBLOCK") {
            return true;
        }
        if s.eq("EAGAIN") || s.eq("EINTR") || s.eq("EINVAL") || s.eq("ENOENT") {
            return true;
        }
        if s.eq("EACCES") || s.eq("EEXIST") || s.eq("ENOMEM") || s.eq("EIO") {
            return true;
        }
        if s.eq("EPIPE") || s.eq("EBADF") || s.eq("EBUSY") || s.eq("ERANGE") {
            return true;
        }
    }
    return false;
}

pub fn c_safe_ident(name: string) -> string {
    if is_c_reserved(name) {
        return "_g_".concat(name);
    }
    return name;
}

// Standard C library / POSIX symbol names. A user-defined FREE FUNCTION
// emitted verbatim under one of these collides with the prototype the
// runtime's headers already pull in (stdlib.h / stdio.h / string.h / time.h /
// math.h / ctype.h / unistd.h ...), producing a `conflicting types for 'X'`
// cc error even though the Glide program is perfectly valid (the original
// report was `fn div`). User functions are only ever called from generated
// C, so renaming them is safe; extern/FFI bindings keep their real name and
// are excluded by the body check in `userfn_c_name`. Over-inclusion is
// harmless: a user `fn log` simply emits as the mangled name and still works.
pub fn is_libc_symbol(s: string) -> bool {
    // stdlib.h
    if s.eq("abort") || s.eq("abs") || s.eq("atexit") || s.eq("atof") {
        return true;
    }
    if s.eq("atoi") || s.eq("atol") || s.eq("atoll") || s.eq("bsearch") {
        return true;
    }
    if s.eq("calloc") || s.eq("div") || s.eq("exit") || s.eq("free") {
        return true;
    }
    if s.eq("getenv") || s.eq("labs") || s.eq("ldiv") || s.eq("llabs") {
        return true;
    }
    if s.eq("lldiv") || s.eq("malloc") || s.eq("mblen") || s.eq("qsort") {
        return true;
    }
    if s.eq("rand") || s.eq("realloc") || s.eq("srand") || s.eq("strtod") {
        return true;
    }
    if s.eq("strtof") || s.eq("strtol") || s.eq("strtoll") || s.eq("strtoul") {
        return true;
    }
    if s.eq("strtoull") || s.eq("system") || s.eq("setenv") || s.eq("unsetenv") {
        return true;
    }
    if s.eq("putenv") || s.eq("realpath") || s.eq("random") || s.eq("srandom") {
        return true;
    }
    if s.eq("aligned_alloc") || s.eq("mkstemp") {
        return true;
    }
    // stdio.h
    if s.eq("clearerr") || s.eq("fclose") || s.eq("feof") || s.eq("ferror") {
        return true;
    }
    if s.eq("fflush") || s.eq("fgetc") || s.eq("fgets") || s.eq("fopen") {
        return true;
    }
    if s.eq("fprintf") || s.eq("fputc") || s.eq("fputs") || s.eq("fread") {
        return true;
    }
    if s.eq("freopen") || s.eq("fscanf") || s.eq("fseek") || s.eq("ftell") {
        return true;
    }
    if s.eq("fwrite") || s.eq("getc") || s.eq("getchar") || s.eq("gets") {
        return true;
    }
    if s.eq("perror") || s.eq("printf") || s.eq("putc") || s.eq("putchar") {
        return true;
    }
    if s.eq("puts") || s.eq("remove") || s.eq("rename") || s.eq("rewind") {
        return true;
    }
    if s.eq("scanf") || s.eq("setbuf") || s.eq("setvbuf") || s.eq("snprintf") {
        return true;
    }
    if s.eq("sprintf") || s.eq("sscanf") || s.eq("tmpfile") || s.eq("tmpnam") {
        return true;
    }
    if s.eq("ungetc") || s.eq("fileno") || s.eq("fdopen") || s.eq("popen") {
        return true;
    }
    if s.eq("pclose") || s.eq("getline") {
        return true;
    }
    // string.h
    if s.eq("memchr") || s.eq("memcmp") || s.eq("memcpy") || s.eq("memmove") {
        return true;
    }
    if s.eq("memset") || s.eq("strcat") || s.eq("strchr") || s.eq("strcmp") {
        return true;
    }
    if s.eq("strcoll") || s.eq("strcpy") || s.eq("strcspn") || s.eq("strerror") {
        return true;
    }
    if s.eq("strlen") || s.eq("strncat") || s.eq("strncmp") || s.eq("strncpy") {
        return true;
    }
    if s.eq("strpbrk") || s.eq("strrchr") || s.eq("strspn") || s.eq("strstr") {
        return true;
    }
    if s.eq("strtok") || s.eq("strxfrm") || s.eq("strdup") || s.eq("strndup") {
        return true;
    }
    if s.eq("strcasecmp") || s.eq("strncasecmp") || s.eq("strsep") {
        return true;
    }
    // math.h
    if s.eq("acos") || s.eq("asin") || s.eq("atan") || s.eq("atan2") {
        return true;
    }
    if s.eq("ceil") || s.eq("cos") || s.eq("cosh") || s.eq("exp") {
        return true;
    }
    if s.eq("fabs") || s.eq("floor") || s.eq("fmod") || s.eq("frexp") {
        return true;
    }
    if s.eq("ldexp") || s.eq("log") || s.eq("log10") || s.eq("modf") {
        return true;
    }
    if s.eq("pow") || s.eq("sin") || s.eq("sinh") || s.eq("sqrt") {
        return true;
    }
    if s.eq("tan") || s.eq("tanh") || s.eq("round") || s.eq("lround") {
        return true;
    }
    if s.eq("trunc") || s.eq("cbrt") || s.eq("hypot") || s.eq("log2") {
        return true;
    }
    if s.eq("exp2") || s.eq("fmin") || s.eq("fmax") || s.eq("fma") {
        return true;
    }
    // time.h
    if s.eq("clock") || s.eq("difftime") || s.eq("mktime") || s.eq("time") {
        return true;
    }
    if s.eq("asctime") || s.eq("ctime") || s.eq("gmtime") || s.eq("localtime") {
        return true;
    }
    if s.eq("strftime") || s.eq("nanosleep") || s.eq("gettimeofday") {
        return true;
    }
    // ctype.h
    if s.eq("isalnum") || s.eq("isalpha") || s.eq("iscntrl") || s.eq("isdigit") {
        return true;
    }
    if s.eq("isgraph") || s.eq("islower") || s.eq("isprint") || s.eq("ispunct") {
        return true;
    }
    if s.eq("isspace") || s.eq("isupper") || s.eq("isxdigit") || s.eq("tolower") {
        return true;
    }
    if s.eq("toupper") || s.eq("isblank") {
        return true;
    }
    // unistd.h / POSIX
    if s.eq("read") || s.eq("write") || s.eq("open") || s.eq("close") {
        return true;
    }
    if s.eq("lseek") || s.eq("unlink") || s.eq("link") || s.eq("symlink") {
        return true;
    }
    if s.eq("access") || s.eq("chdir") || s.eq("getcwd") || s.eq("dup") {
        return true;
    }
    if s.eq("dup2") || s.eq("pipe") || s.eq("fork") || s.eq("execve") {
        return true;
    }
    if s.eq("execv") || s.eq("execvp") || s.eq("execl") || s.eq("getpid") {
        return true;
    }
    if s.eq("getppid") || s.eq("getuid") || s.eq("getgid") || s.eq("sleep") {
        return true;
    }
    if s.eq("usleep") || s.eq("alarm") || s.eq("pause") || s.eq("isatty") {
        return true;
    }
    if s.eq("sync") || s.eq("fsync") || s.eq("truncate") || s.eq("ftruncate") {
        return true;
    }
    if s.eq("rmdir") || s.eq("fcntl") || s.eq("ioctl") || s.eq("kill") {
        return true;
    }
    if s.eq("wait") || s.eq("waitpid") || s.eq("select") || s.eq("poll") {
        return true;
    }
    if s.eq("socket") || s.eq("connect") || s.eq("bind") || s.eq("listen") {
        return true;
    }
    if s.eq("accept") || s.eq("send") || s.eq("recv") || s.eq("sendto") {
        return true;
    }
    if s.eq("recvfrom") || s.eq("shutdown") || s.eq("setsockopt") || s.eq("getsockopt") {
        return true;
    }
    if s.eq("gethostname") || s.eq("mmap") || s.eq("munmap") || s.eq("mprotect") {
        return true;
    }
    if s.eq("sigaction") || s.eq("signal") || s.eq("raise") || s.eq("sigprocmask") {
        return true;
    }
    if s.eq("setjmp") || s.eq("longjmp") || s.eq("opendir") || s.eq("readdir") {
        return true;
    }
    if s.eq("closedir") || s.eq("stat") || s.eq("fstat") || s.eq("lstat") {
        return true;
    }
    if s.eq("mkdir") || s.eq("chmod") || s.eq("chown") || s.eq("umask") {
        return true;
    }
    if s.eq("index") || s.eq("rindex") || s.eq("sbrk") || s.eq("brk") {
        return true;
    }
    // libgen.h — a user `fs::basename` / `dirname` must be renamed away from
    // these or the emitted C clashes with the libc prototype.
    if s.eq("basename") || s.eq("dirname") {
        return true;
    }
    return false;
}

// C name for a reference to a user-defined free function. A body-bearing
// (non-extern) free fn whose name collides with a libc symbol is renamed
// into the reserved `__glide_` namespace so it can't clash; everything else
// (extern bindings, methods, plain idents) is left to `c_safe_ident`. The
// `__glide_uf_` prefix lives in the compiler's reserved space, so it can't
// itself collide with a user identifier.
pub fn userfn_mangle(name: string) -> string {
    return "__glide_uf_".concat(name);
}

pub fn ns_split_pos(name: string) -> i32 {
    let n: i32 = name.len();
    let mut i: i32 = 0;
    while i + 1 < n {
        if name.at(i).to_int() == 58 && name.at(i + 1).to_int() == 58 {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

// Emit a chan-method receiver with `deref_n` leading `*`s. Used by
// the `.send` / `.recv` / `.close` method shim so a `*chan<T>` arg
// passes the inner chan pointer to the helper instead of a
// pointer-to-chan-pointer.
fn _emit_chan_recv(g: *CG, e: *Expr, deref_n: i32) {
    if deref_n <= 0 {
        emit_expr(g, e);
        return;
    }
    print!("(");
    for let i: i32 = 0; i < deref_n; i++ {
        print!("*");
    }
    emit_expr(g, e);
    print!(")");
}

// Return type of a closure argument: an inline `fn(...) -> U {}` carries U in
// `.cast_to`; a lifted anon (EX_IDENT) is in g.anon_fns; a named fn in g.fns.
pub fn _closure_ret_ty(g: *CG, cl: *Expr) -> *Type {
    if cl == null {
        return null;
    }
    if cl.kind == EX_FNEXPR {
        return cl.cast_to;
    }
    if cl.kind == EX_IDENT {
        for let i: i32 = 0; i < g.anon_fns.len(); i++ {
            let af: AnonFn = g.anon_fns.get(i);
            if af.name.eq(cl.str_val) {
                return af.ret_ty;
            }
        }
        if g.fns.contains(cl.str_val) {
            return g.fns.get(cl.str_val).fn_ret_ty;
        }
    }
    return null;
}

// Build a TY_FNPTR from a parameter list + return type (for closure/anon-fn
// type inference, mirroring the named-fn branch of infer_for_codegen).
pub fn _build_fnptr_ty(params: *Vector<Param>, ret: *Type) -> *Type {
    let args: *Vector<Type> = Vector::new();
    if params != null {
        for let i: i32 = 0; i < params.len(); i++ {
            let p: Param = params.get(i);
            if p.ty != null {
                args.push(*p.ty);
            }
        }
    }
    let fp: *Type = __glide_palloc(sizeof(Type)) as *Type;
    fp.kind = TY_FNPTR;
    fp.args = args;
    fp.fnptr_ret = ret;
    return fp;
}

// Emit `<closure>(<c_arg>)` with the fn-ptr cast convention (c_arg is raw C; ""
// for a zero-arg call). A direct anon/named fn needs no cast; a fn-ptr value
// (void* slot) is cast to its real signature first.
fn _emit_closure_call(g: *CG, cl: *Expr, c_arg: string) {
    let cty: *Type = infer_for_codegen(g, cl);
    if cty != null && cty.kind == TY_FNPTR {
        print!("((", fnptr_cast_str(cty), ")");
        emit_expr(g, cl);
        print!(")");
    } else {
        emit_expr(g, cl);
    }
    print!("(", c_arg, ")");
}

// Intrinsic methods on OptResult (`?!T`): tag 0=Some, 1=None, 2=Err.
// Same contract as _emit_opt_res_method — true when handled.
fn _emit_optres_method(g: *CG, e: *Expr) -> bool {
    let mname: string = e.lhs.field;
    let recv_e: *Expr = e.lhs.lhs;
    let recv_ty: *Type = infer_for_codegen(g, recv_e);
    let stripped: *Type = strip_ptr(recv_ty);
    let cty: string = type_to_c(stripped);
    let mut derefs: string = "";
    let mut t: *Type = recv_ty;
    while t != null && (t.kind == TY_POINTER || t.kind == TY_BORROW || t.kind == TY_BORROW_MUT) {
        derefs = derefs.concat("*");
        t = t.inner;
    }
    let line: string = int_to_str(e.line);
    let mut nargs: i32 = 0;
    if e.args != null {
        nargs = e.args.len();
    }
    if (mname.eq("is_some") || mname.eq("is_none") || mname.eq("is_err")) && nargs == 0 {
        let mut tag: string = "0";
        if mname.eq("is_none") {
            tag = "1";
        }
        if mname.eq("is_err") {
            tag = "2";
        }
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); (__v.tag == ", tag, "); })");
        return true;
    }
    if mname.eq("unwrap") && nargs == 0 {
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); if (__v.tag != 0) __glide_panic(__v.tag == 2 ? \"called `unwrap()` on an err value\" : \"called `unwrap()` on a none value\", \"\", ", line, "); __v.val; })");
        return true;
    }
    if mname.eq("expect") && nargs == 1 {
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); if (__v.tag != 0) __glide_panic((");
        let msg: Expr = e.args.get(0);
        emit_expr(g, &msg);
        print!("), \"\", ", line, "); __v.val; })");
        return true;
    }
    if mname.eq("unwrap_or") && nargs == 1 {
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); __v.tag == 0 ? __v.val : (");
        let d: Expr = e.args.get(0);
        emit_expr(g, &d);
        print!("); })");
        return true;
    }
    if mname.eq("unwrap_or_else") && nargs == 1 {
        let f0: Expr = e.args.get(0);
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); __v.tag == 0 ? __v.val : ");
        _emit_closure_call(g, &f0, "");
        print!("; })");
        return true;
    }
    if mname.eq("unwrap_err") && nargs == 0 {
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); if (__v.tag != 2) __glide_panic(\"called `unwrap_err()` on a non-err value\", \"\", ", line, "); __v.err; })");
        return true;
    }
    return false;
}

// Intrinsic methods on Option (`?T`) / Result (`!T`). Emits an inline
// statement-expr and returns true when `e` is such a method call; false lets
// the caller fall through to normal dispatch. Mirrors the chan method block.
fn _emit_opt_res_method(g: *CG, e: *Expr) -> bool {
    if e.lhs == null || e.lhs.kind != EX_MEMBER || e.lhs.lhs == null {
        return false;
    }
    let mname: string = e.lhs.field;
    let recv_e: *Expr = e.lhs.lhs;
    let recv_ty: *Type = infer_for_codegen(g, recv_e);
    let stripped: *Type = strip_ptr(recv_ty);
    if stripped == null {
        return false;
    }
    let is_opt: bool = stripped.kind == TY_OPTION;
    let is_res: bool = stripped.kind == TY_RESULT;
    // OptResult (`?!T`) is tag-based (0=Some, 1=None, 2=Err) rather than
    // flag-based, so it gets its own emission block.
    if stripped.kind == TY_OPT_RESULT {
        return _emit_optres_method(g, e);
    }
    if !is_opt && !is_res {
        return false;
    }
    let cty: string = type_to_c(stripped);
    let mut flag: string = "ok";
    if is_opt {
        flag = "has";
    }
    let mut m_inner: string = "";
    if stripped.inner != null {
        m_inner = mangle_type(stripped.inner);
    }
    let mut derefs: string = "";
    let mut t: *Type = recv_ty;
    while t != null && (t.kind == TY_POINTER || t.kind == TY_BORROW || t.kind == TY_BORROW_MUT) {
        derefs = derefs.concat("*");
        t = t.inner;
    }
    let line: string = int_to_str(e.line);
    let mut nargs: i32 = 0;
    if e.args != null {
        nargs = e.args.len();
    }
    // open: `({ <cty> __v = <derefs>(<recv>); `
    if is_opt && mname.eq("is_some") || is_res && mname.eq("is_ok") {
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); (__v.", flag, "); })");
        return true;
    }
    if is_opt && mname.eq("is_none") || is_res && mname.eq("is_err") {
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); (!__v.", flag, "); })");
        return true;
    }
    if mname.eq("unwrap") && nargs == 0 {
        let mut kind: string = "err";
        if is_opt {
            kind = "none";
        }
        // Build the message literal in one piece — multi-arg print! joins with
        // spaces, which would land inside the C string literal.
        let pmsg: string = "\"called `unwrap()` on a ".concat(kind).concat(" value\"");
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); if (!__v.", flag, ") __glide_panic(", pmsg, ", \"\", ", line, "); __v.val; })");
        return true;
    }
    if mname.eq("expect") && nargs == 1 {
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); if (!__v.", flag, ") __glide_panic((");
        let msg: Expr = e.args.get(0);
        emit_expr(g, &msg);
        print!("), \"\", ", line, "); __v.val; })");
        return true;
    }
    if mname.eq("unwrap_or") && nargs == 1 {
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); __v.", flag, " ? __v.val : (");
        let d: Expr = e.args.get(0);
        emit_expr(g, &d);
        print!("); })");
        return true;
    }
    if is_res && mname.eq("unwrap_err") && nargs == 0 {
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); if (__v.ok) __glide_panic(\"called `unwrap_err()` on an ok value\", \"\", ", line, "); __v.err; })");
        return true;
    }
    if mname.eq("unwrap_or_else") && nargs == 1 {
        let f0: Expr = e.args.get(0);
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); __v.", flag, " ? __v.val : ");
        _emit_closure_call(g, &f0, "");
        print!("; })");
        return true;
    }
    if is_opt && mname.eq("ok_or") && nargs == 1 {
        let ea: Expr = e.args.get(0);
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); __v.has ? ".concat("__glide_ok_").concat(m_inner).concat("(__v.val) : ").concat("__glide_err_").concat(m_inner).concat("("));
        emit_expr(g, &ea);
        print!("); })");
        return true;
    }
    if is_res && mname.eq("ok") && nargs == 0 {
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); __v.ok ? ".concat("__glide_some_").concat(m_inner).concat("(__v.val) : ").concat("__glide_none_").concat(m_inner).concat("(); })"));
        return true;
    }
    if is_opt && mname.eq("filter") && nargs == 1 {
        let p0: Expr = e.args.get(0);
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); (__v.has && ");
        _emit_closure_call(g, &p0, "__v.val");
        print!(") ? __v : ".concat("__glide_none_").concat(m_inner).concat("(); })"));
        return true;
    }
    if is_res && mname.eq("map_err") && nargs == 1 {
        let f0: Expr = e.args.get(0);
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        print!("); __v.ok ? __v : ".concat("__glide_err_").concat(m_inner).concat("("));
        _emit_closure_call(g, &f0, "__v.err");
        print!("); })");
        return true;
    }
    if mname.eq("map") && nargs == 1 {
        let cl: Expr = e.args.get(0);
        let u: *Type = _closure_ret_ty(g, &cl);
        let mut mu: string = m_inner;
        if u != null {
            mu = mangle_type(u);
        }
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        if is_opt {
            print!("); __v.has ? ".concat("__glide_some_").concat(mu).concat("("));
            _emit_closure_call(g, &cl, "__v.val");
            print!(") : ".concat("__glide_none_").concat(mu).concat("(); })"));
        } else {
            print!("); __v.ok ? ".concat("__glide_ok_").concat(mu).concat("("));
            _emit_closure_call(g, &cl, "__v.val");
            print!(") : ".concat("__glide_err_").concat(mu).concat("(__v.err); })"));
        }
        return true;
    }
    if mname.eq("and_then") && nargs == 1 {
        let cl: Expr = e.args.get(0);
        let clret: *Type = _closure_ret_ty(g, &cl);
        let mut mu: string = m_inner;
        if clret != null && clret.inner != null {
            mu = mangle_type(clret.inner);
        }
        print!("({ ", cty, " __v = ", derefs, "(");
        emit_expr(g, recv_e);
        if is_opt {
            print!("); __v.has ? ");
            _emit_closure_call(g, &cl, "__v.val");
            print!(" : ".concat("__glide_none_").concat(mu).concat("(); })"));
        } else {
            print!("); __v.ok ? ");
            _emit_closure_call(g, &cl, "__v.val");
            print!(" : ".concat("__glide_err_").concat(mu).concat("(__v.err); })"));
        }
        return true;
    }
    return false;
}

fn format_spec_for(t0: *Type) -> string {
    let mut t: *Type = t0;
    // A borrowed value (`&self` on a primitive) formats as its underlying
    // type — the arg emitter dereferences it, so pick the value's spec.
    if t != null && (t.kind == TY_BORROW || t.kind == TY_BORROW_MUT) && t.inner != null {
        t = t.inner;
    }
    if t == null {
        return "%p";
    }
    if t.kind != TY_NAMED {
        return "%p";
    }
    let n: string = t.name;
    if n.eq("int") || n.eq("i8") || n.eq("i16") || n.eq("i32") {
        return "%d";
    }
    if n.eq("uint") || n.eq("u8") || n.eq("u16") || n.eq("u32") {
        return "%u";
    }
    if n.eq("i64") || n.eq("isize") || n.eq("long") {
        return "%lld";
    }
    if n.eq("u64") || n.eq("usize") || n.eq("ulong") {
        return "%llu";
    }
    // 128-bit ints have no printf length modifier; the arg emit converts them
    // to a string via __glide_i128_to_string / __glide_u128_to_string.
    if n.eq("i128") || n.eq("u128") {
        return "%s";
    }
    // 256-bit ints are software structs, printed via their to_string helper.
    if n.eq("i256") || n.eq("u256") {
        return "%s";
    }
    if n.eq("float") || n.eq("f32") || n.eq("f64") {
        return "%g";
    }
    if n.eq("char") {
        return "%c";
    }
    if n.eq("string") {
        return "%s";
    }
    if n.eq("bool") {
        return "%s";
    }
    return "%p";
}

// ---- Display: struct rendering for println! / print! / format! / dbg! -------
//
// A struct argument used to print as a raw pointer (`%p`). It now renders as
// `Name { field: value, ... }` (Debug-style), or — if the struct has a
// `to_string(self) -> string` method (a `Display` impl) — via that method.
// Strings are quoted, nested structs recurse. The whole thing lowers inline so
// no extra top-level emission / forward decls are needed.

// ---- Errors-as-values: collect + emit per-T runtime ---------------------

// ---- Anonymous tuples: collection + struct emission ---------------------

// ---- Concurrency: chan + spawn collection / emission --------------------

// ---- dyn Trait collection ----
//
// Walk every type appearing in the program; whenever we hit a `dyn Trait`
// (either bare or behind `*`/`&`), register the trait name. Later passes
// emit a vtable struct + fat-pointer typedef + static vtable instance for
// each `(Trait, Type)` pair the program implements.

// `int_to_str` and `digit_str` moved to ast.glide so expander.glide can
// reach them without a circular import.

// Track variable types per scope so method calls (obj.method()) can be
// resolved to Type_method(obj, ...) by stripping pointers and using the
// receiver's named type as the prefix.
// Pending fn monomorphization: original name + concrete type args.
pub struct FnMonoEntry {
    pub name: string,
    pub args: *Vector<Type>,
}

// Anonymous fn that needs lifting to top-level.
pub struct AnonFn {
    pub name: string,
    pub params: *Vector<Param>,
    pub ret_ty: *Type,
    pub body: *Vector<Stmt>,
}

pub struct CG {
    pub scope: *HashMap<Type>,
    pub generic_structs: *HashMap<Stmt>,
    pub generic_fns: *HashMap<Stmt>,
    pub structs: *HashMap<Stmt>,
    pub enums: *HashMap<Stmt>,
    pub fns: *HashMap<Stmt>,
    // Struct names that define a user `eq` method — `==` uses it instead of the
    // automatic field-by-field comparison.
    pub user_eq: *HashMap<bool>,
    pub emitted_monos: *HashMap<bool>,
    pub fn_mono_queue: *Vector<FnMonoEntry>,
    // Struct monos discovered dynamically during prescan (e.g. via chained
    // ctor inference where no static `let_ty` exposes the type). Drained
    // after fn-mono drain, before fn forward decls.
    pub struct_mono_queue: *Vector<Type>,
    pub defer_stack: *Vector<Expr>, // explicit `defer expr;` (fn-scoped)
    pub err_defer_stack: *Vector<Expr>, // `defer_err expr;` — fires only on err return / `?` (fn-scoped)
    pub auto_drop_stack: *Vector<Expr>, // `let v*` cleanups (block-scoped)
    // Per-defer runtime flags (parallel to defer_stack / err_defer_stack). A
    // defer inside a conditional block only runs if reached: `__gdefer_<k>` is
    // set at the defer site and the fn-exit drain guards on it. `defer_flag_ctr`
    // hands out the next `k` within the current fn.
    pub defer_flags: *Vector<i32>,
    pub err_defer_flags: *Vector<i32>,
    pub defer_flag_ctr: i32,
    pub moved_locals: *HashMap<bool>, // owned locals whose ownership moved out (assign/store/pass); their auto-drop is skipped
    // Anonymous fn lifts (collected during codegen, emitted at end).
    pub anon_fns: *Vector<AnonFn>,
    pub anon_count: i32,
    // Concurrency
    pub chan_types: *Vector<Type>,
    pub spawn_count: i32,
    pub uses_pthread: bool,
    // Errors-as-values
    pub result_types: *Vector<Type>,
    pub option_types: *Vector<Type>,
    pub optres_types: *Vector<Type>,
    // Anonymous tuple types `(A, B, ...)`. Each unique element-type combination
    // gets one C struct typedef (`__glide_tuple<N>_..._t`). Collected program-
    // wide, emitted inner-first so nested tuples precede their containers.
    pub tuple_types: *Vector<Type>,
    pub current_ret_ty: *Type,
    // Associated-type lookup for `<Trait>::<Concrete>::<Item>`. Populated
    // up front from every `impl Trait for Type { type Item = X; }`.
    pub assoc_table: *HashMap<Type>,
    // Method-dispatch index for `impl T in NS` blocks. Maps the unqualified
    // `<T>_<method>` name to a `;`-delimited list of full mangled names like
    // `cores_string_red`. O(1) lookup at dispatch time avoids walking g.fns.
    // (Glide HashMap takes a single value type; we encode multi-match as a
    // separator-joined string instead of nesting another Vector.)
    pub method_index: *HashMap<string>,
    // Names that came from an `impl T { ... }` block (mangled `<T>_<m>`).
    // Method dispatch (`obj.method()`) only resolves to entries in this set,
    // so a free fn named `string_legal` won't be sugared into `s.legal()`.
    pub method_fns: *HashMap<bool>,
    // Module-path aliases. Each pub item registers `<module>::<short>` →
    // `<short>`, so user code can write `stdlib::vector::Vector::new()` and
    // codegen can normalise it back to the existing flat C symbol naming.
    // Free functions: key = `<module>::<fn>`, value = `<fn>`.
    // Type names:     key = `<module>::<Type>`, value = `<Type>`.
    pub module_aliases: *HashMap<string>,
    // Named user struct/enum bodies already emitted (e.g. up-front by the
    // chan runtime so chan<UserType> can store T by value). The main body
    // pass skips anything already in here.
    pub emitted_named: *HashMap<bool>,
    // Trait names that appear as `dyn Trait` somewhere in the program.
    // Each one needs a fat-pointer typedef, a vtable struct, and a static
    // vtable instance per `impl Trait for Type`.
    pub dyn_traits: *HashMap<bool>,
    // Trait def index: trait name -> ST_TRAIT Stmt. Populated up front so
    // method-call return types can be looked up when the receiver is a
    // `*dyn Trait`.
    pub traits: *HashMap<Stmt>,
    // Top-level `const NAME: T = ...` table. Populated in the same
    // pre-scan that registers fns/structs/enums, so `infer_for_codegen`
    // can resolve a bare `NAME` ident the same way the typer does.
    // Before this existed, a const-typed string in `println!` codegen'd
    // as `%p` (printf'd a pointer) instead of `%s`.
    pub consts: *HashMap<Type>,
    // Source mapping for crash traces. `current_origin` is the Glide
    // source file currently being emitted (set per-fn / per-impl).
    // `last_line_dir` + `last_origin_dir` track the latest emitted
    // `#line N "file"` directive so we only emit one when the
    // (file, line) pair actually changes — avoids ballooning the C
    // output with a directive per stmt when many stmts share a line.
    pub current_origin: string,
    pub last_line_dir: i32,
    pub last_origin_dir: string,
    // Freestanding / kernel mode: no hosted prelude, no baked runtime
    // (stdlib/scheduler/socket), no `main` wrapper. Set from emit_program's
    // arg. The user code provides its own entry (`kmain`) and, if it uses
    // strings/Vector, its own libc-shaped primitives (malloc/memcpy/...).
    pub freestanding: bool,
    // Tiny / minimal-hosted mode: keep libc + stdlib (println, strings) but,
    // when the program never touches concurrency, the `main` wrapper skips
    // `__glide_sched_init` so the M:N scheduler + reactor are unreferenced and
    // the linker's --gc-sections drops them. `needs_concurrency` is set by the
    // spawn/chan pre-pass; when true the scheduler is kept even under --tiny.
    pub tiny: bool,
    pub needs_concurrency: bool,
    // SDS: recursion guard so the extern-string-return adopt-wrap doesn't
    // re-wrap the same call when it re-emits it.
    pub _sds_adopt_skip: bool,
}

// The local name an auto-drop cleanup frees: `v.free()` -> "v",
// `free(v as *void)` -> "v". Lets a `return <local>` skip the drop of the
// value it moves out to the caller (see emit_deferred_reverse's skip_name).
fn _auto_drop_subject(ex: *Expr) -> string {
    if ex == null || ex.kind != EX_CALL {
        return "";
    }
    if ex.lhs != null && ex.lhs.kind == EX_MEMBER && ex.lhs.lhs != null && ex.lhs.lhs.kind == EX_IDENT {
        return ex.lhs.lhs.str_val;
    }
    if ex.args != null && ex.args.len() > 0 {
        let a: Expr = ex.args.get(0);
        if a.kind == EX_CAST && a.lhs != null && a.lhs.kind == EX_IDENT {
            return a.lhs.str_val;
        }
        if a.kind == EX_IDENT {
            return a.str_val;
        }
    }
    return "";
}

// True when `st` is an auto-dropped (owned) local: `let v: *T = T { .. }`
// (rewritten to malloc+init) or the explicit `let v* = ..` form.
fn _let_is_auto_drop(st: *Stmt) -> bool {
    if st == null {
        return false;
    }
    if st.is_auto_owned {
        return true;
    }
    if st.let_ty != null && st.let_ty.kind == TY_POINTER && st.let_value != null && st.let_value.kind == EX_STRUCT_LIT && st.let_ty.inner != null && st.let_ty.inner.kind == TY_NAMED && st.let_ty.inner.name.eq(st.let_value.str_val) {
        return true;
    }
    return false;
}

// True when `fn_stmt` hands an owned value to its caller: it returns one of its
// own auto-drop locals directly (`let t: *T = T{..}; ...; return t;`). A
// malloc-based constructor does NOT match (it returns a raw malloc, not an
// auto-drop local), so the existing stdlib/compiler are unaffected.
fn _returns_auto_owned_local(g: *CG, fn_stmt: *Stmt, depth: i32) -> bool {
    if fn_stmt == null || fn_stmt.fn_body == null || depth > 8 {
        return false;
    }
    let body: *Vector<Stmt> = fn_stmt.fn_body;
    let owned: *HashMap<bool> = HashMap::new();
    for let i: i32 = 0; i < body.len(); i++ {
        let st: Stmt = body.get(i);
        if st.kind == ST_LET && _let_is_auto_drop(&st) {
            owned.insert(st.name, true);
        } else if st.kind == ST_LET && st.let_value != null && st.let_value.kind == EX_CALL {
            // `let r = make(); ... return r;` - r is owned when `make` itself
            // returns an owned value (recursive, so passthrough chains carry the
            // ownership through). Guarded by depth to stop self-recursion.
            let _k: string = _call_target_key(st.let_value, st.let_ty);
            if !_k.eq("") && g.fns.contains(_k) {
                let _c: Stmt = g.fns.get(_k);
                if _returns_auto_owned_local(g, &_c, depth + 1) {
                    owned.insert(st.name, true);
                }
            }
        }
    }
    let mut hit: bool = false;
    for let i: i32 = 0; i < body.len(); i++ {
        let st: Stmt = body.get(i);
        if st.kind == ST_RETURN && st.expr_value != null && st.expr_value.kind == EX_IDENT && owned.contains(st.expr_value.str_val) {
            hit = true;
        }
    }
    owned.free();
    return hit;
}

// The g.fns key a call resolves to: a free fn by its ident, or a method
// `T::m()` as `<T>_m` using the let binding's annotated type. Empty when it
// cannot be resolved cleanly - the caller then conservatively does nothing
// (a missed move just leaks, never double-frees).
fn _call_target_key(call: *Expr, let_ty: *Type) -> string {
    if call == null || call.lhs == null {
        return "";
    }
    let callee: *Expr = call.lhs;
    if callee.kind == EX_IDENT {
        return callee.str_val;
    }
    if callee.field != null && !callee.field.eq("") && let_ty != null && let_ty.kind == TY_POINTER && let_ty.inner != null && let_ty.inner.kind == TY_NAMED {
        return let_ty.inner.name.concat("_").concat(callee.field);
    }
    return "";
}

// True when `name` is an owned (auto-drop) local in the current fn - i.e. it has
// a pending cleanup on the auto-drop stack. Used to decide whether assigning /
// storing / passing it should move ownership (skip its auto-drop).
fn _is_owned_local(g: *CG, name: string) -> bool {
    if name.eq("") {
        return false;
    }
    let n: i32 = g.auto_drop_stack.len();
    for let i: i32 = 0; i < n; i = i + 1 {
        let ex: Expr = g.auto_drop_stack.get(i);
        if _auto_drop_subject(&ex).eq(name) {
            return true;
        }
    }
    return false;
}

impl CG {
    pub fn new() -> *CG {
        let g: *CG = malloc(sizeof(CG)) as *CG;
        g._sds_adopt_skip = false;
        let s: *HashMap<Type> = HashMap::new();
        let gs: *HashMap<Stmt> = HashMap::new();
        let gf: *HashMap<Stmt> = HashMap::new();
        let st: *HashMap<Stmt> = HashMap::new();
        let en: *HashMap<Stmt> = HashMap::new();
        let fnm: *HashMap<Stmt> = HashMap::new();
        let em: *HashMap<bool> = HashMap::new();
        let q: *Vector<FnMonoEntry> = Vector::new();
        let ds: *Vector<Expr> = Vector::new();
        g.defer_stack = ds;
        let eds: *Vector<Expr> = Vector::new();
        g.err_defer_stack = eds;
        let ads: *Vector<Expr> = Vector::new();
        g.auto_drop_stack = ads;
        let ml: *HashMap<bool> = HashMap::new();
        g.moved_locals = ml;
        let df: *Vector<i32> = Vector::new();
        g.defer_flags = df;
        let edf: *Vector<i32> = Vector::new();
        g.err_defer_flags = edf;
        g.defer_flag_ctr = 0;
        let ueq: *HashMap<bool> = HashMap::new();
        g.user_eq = ueq;
        let af: *Vector<AnonFn> = Vector::new();
        g.anon_fns = af;
        g.anon_count = 0;
        let ct: *Vector<Type> = Vector::new();
        g.chan_types = ct;
        g.spawn_count = 0;
        g.uses_pthread = false;
        let rt: *Vector<Type> = Vector::new();
        g.result_types = rt;
        let ot: *Vector<Type> = Vector::new();
        g.option_types = ot;
        let ort: *Vector<Type> = Vector::new();
        g.optres_types = ort;
        let tt: *Vector<Type> = Vector::new();
        g.tuple_types = tt;
        let at: *HashMap<Type> = HashMap::new();
        g.assoc_table = at;
        g.current_ret_ty = null;
        g.scope = s;
        g.generic_structs = gs;
        g.generic_fns = gf;
        g.structs = st;
        g.enums = en;
        g.fns = fnm;
        g.emitted_monos = em;
        g.fn_mono_queue = q;
        let smq: *Vector<Type> = Vector::new();
        g.struct_mono_queue = smq;
        let mi: *HashMap<string> = HashMap::new();
        g.method_index = mi;
        let mf: *HashMap<bool> = HashMap::new();
        g.method_fns = mf;
        let ma: *HashMap<string> = HashMap::new();
        g.module_aliases = ma;
        let en2: *HashMap<bool> = HashMap::new();
        g.emitted_named = en2;
        let dt: *HashMap<bool> = HashMap::new();
        g.dyn_traits = dt;
        let trts: *HashMap<Stmt> = HashMap::new();
        g.traits = trts;
        let cs: *HashMap<Type> = HashMap::new();
        g.consts = cs;
        g.current_origin = "";
        g.last_line_dir = 0;
        g.last_origin_dir = "";
        g.freestanding = false;
        g.tiny = false;
        g.needs_concurrency = false;
        return g;
    }

    // Emit `#line <line> "<file>"` so the resulting DWARF / debug info
    // points at the Glide source instead of the generated C. We only
    // emit when (file, line) changed from the previous directive, and
    // we forward-slash the path so the C preprocessor accepts it on
    // Windows without escape headaches.
    fn emit_line_dir(self, line: i32, origin: string) {
        if line <= 0 {
            return;
        }
        let path: string;
        if origin == null || origin.eq("") {
            path = self.current_origin;
        } else {
            path = origin;
        }
        if path == null || path.eq("") {
            return;
        }
        if line == self.last_line_dir && path.eq(self.last_origin_dir) {
            return;
        }
        // Normalize backslashes to forward-slashes for C string-literal
        // safety. We don't escape quotes — Glide source paths don't
        // legally contain `"`.
        let n: i32 = path.len();
        let mut norm: string = "";
        for let i: i32 = 0; i < n; i++ {
            if path.at(i).to_int() == 92 {
                norm = norm.concat("/");
            } else {
                norm = norm.concat(path.substring(i, i + 1));
            }
        }
        // println!() inserts a space between each printf arg — that
        // would break the directive ('#line  4  " ".../foo.glide  "').
        // Build the whole line as one string and emit it via a single
        // printf arg. Leading '\n' guarantees column-1 placement even
        // when the previous emit (e.g. a c_raw! block) didn't end with
        // a newline; the C preprocessor requires `#line` at col 1.
        let dir: string = "\n#line ".concat(line.to_string()).concat(" \"").concat(norm).concat("\"");
        println!(dir);
        self.last_line_dir = line;
        self.last_origin_dir = path;
    }

    // Flush err-only deferred cleanups (LIFO). Called from ST_RETURN when
    // returning `err(...)` and from the `?` propagation lowering. Fires
    // BEFORE regular defers so the err handler sees the same outer state
    // as the regular path.
    fn emit_err_defers_reverse(self, depth: i32) {
        let n: i32 = self.err_defer_stack.len();
        for let i: i32 = n - 1; i >= 0; i = i - 1 {
            ind(depth);
            let ex: Expr = self.err_defer_stack.get(i);
            emit_expr(self, &ex);
            println!(";");
        }
    }

    // Flush all pending cleanups in reverse order. Called on return / fn end.
    // Auto-drops fire first (innermost block first), then explicit defers
    // (so e.g. `defer arena.free()` at fn-top fires after auto-drops that
    // allocated inside it).
    // `skip_name` names a local being returned (`return v`): its ownership
    // moves to the caller, so its auto-drop is skipped here (otherwise the
    // returned pointer would dangle). Empty string = drop everything.
    fn emit_deferred_reverse(self, depth: i32, skip_name: string) {
        let na: i32 = self.auto_drop_stack.len();
        for let i: i32 = na - 1; i >= 0; i = i - 1 {
            let ex: Expr = self.auto_drop_stack.get(i);
            let _subj: string = _auto_drop_subject(&ex);
            if !skip_name.eq("") && _subj.eq(skip_name) {
                continue;
            }
            if !_subj.eq("") && self.moved_locals.contains(_subj) && self.moved_locals.get(_subj) {
                continue;
            }
            ind(depth);
            emit_expr(self, &ex);
            println!(";");
        }
        let nd: i32 = self.defer_stack.len();
        for let i: i32 = nd - 1; i >= 0; i = i - 1 {
            ind(depth);
            let ex: Expr = self.defer_stack.get(i);
            print!("if (__gdefer[".concat(self.defer_flags.get(i).to_string()).concat("]) { "));
            emit_expr(self, &ex);
            println!("; }");
        }
    }

    // Block-exit cleanup: emit (in reverse) and pop only auto-drop entries
    // pushed since `saved`. Explicit defers stay on their own stack.
    fn emit_block_drops(self, saved: i32, depth: i32) {
        let n: i32 = self.auto_drop_stack.len();
        for let i: i32 = n - 1; i >= saved; i = i - 1 {
            let ex: Expr = self.auto_drop_stack.get(i);
            let _subj: string = _auto_drop_subject(&ex);
            if !_subj.eq("") && self.moved_locals.contains(_subj) && self.moved_locals.get(_subj) {
                continue;
            }
            ind(depth);
            emit_expr(self, &ex);
            println!(";");
        }
        while self.auto_drop_stack.len() > saved {
            let _ev: Expr = self.auto_drop_stack.pop();
        }
    }

    pub fn free(self) {
        self.scope.free();
        self.generic_structs.free();
        self.generic_fns.free();
        self.structs.free();
        self.enums.free();
        self.fns.free();
        self.emitted_monos.free();
        free(self as *void);
    }

    fn declare(self, name: string, ty: *Type) {
        if ty != null {
            self.scope.insert(name, *ty);
        }
    }

    fn lookup(self, name: string) -> *Type {
        if !self.scope.contains(name) {
            return null;
        }
        let t: Type = self.scope.get(name);
        let p: *Type = malloc(sizeof(Type)) as *Type;
        *p = t;
        return p;
    }
}

// `strip_ptr` moved to ast.glide so typer.glide can reach it without
// importing codegen (which would be a heavy circular dep).

// ---- type to C name ------------------------------------------------------
pub fn type_to_c(t: *Type) -> string {
    if t == null {
        return "void";
    }
    if t.kind == TY_NAMED {
        let n: string = t.name;
        if n.eq("i8") {
            return "int8_t";
        }
        if n.eq("i16") {
            return "int16_t";
        }
        if n.eq("i32") {
            return "int32_t";
        }
        if n.eq("i64") {
            return "int64_t";
        }
        if n.eq("u8") {
            return "uint8_t";
        }
        if n.eq("u16") {
            return "uint16_t";
        }
        if n.eq("u32") {
            return "uint32_t";
        }
        if n.eq("u64") {
            return "uint64_t";
        }
        if n.eq("i128") {
            return "__int128";
        }
        if n.eq("u128") {
            return "unsigned __int128";
        }
        // i256/u256 share one software struct (signed ops reinterpret the bits).
        if n.eq("i256") || n.eq("u256") {
            return "__glide_u256";
        }
        if n.eq("usize") {
            return "size_t";
        }
        if n.eq("isize") {
            return "ptrdiff_t";
        }
        if n.eq("f32") {
            return "float";
        }
        if n.eq("f64") {
            return "double";
        }
        if n.eq("bool") {
            return "bool";
        }
        if n.eq("char") {
            return "char";
        }
        if n.eq("string") {
            return "const char*";
        }
        if n.eq("void") {
            return "void";
        }
        if n.eq("__fn_ptr__") {
            return "void*";
        }
        // User-defined type name (struct/enum). Mangle if it collides with
        // a C keyword so `struct asm { ... }` and friends compile.
        return c_safe_ident(n);
    }
    if t.kind == TY_POINTER {
        // `*dyn Trait` is a fat pointer struct, not a raw pointer.
        if t.inner != null && t.inner.kind == TY_DYN {
            return "__glide_dyn_".concat(t.inner.name);
        }
        return type_to_c(t.inner).concat("*");
    }
    if t.kind == TY_BORROW {
        return type_to_c(t.inner).concat(" const*");
    }
    if t.kind == TY_BORROW_MUT {
        return type_to_c(t.inner).concat("*");
    }
    if t.kind == TY_SLICE {
        return "/* []".concat(type_to_c(t.inner)).concat(" */ void*");
    }
    if t.kind == TY_DYN {
        return "__glide_dyn_".concat(t.name);
    }
    if t.kind == TY_GENERIC {
        if t.name.eq("chan") && t.args != null && t.args.len() > 0 {
            let inner: Type = t.args.get(0);
            return "__glide_chan_".concat(mangle_type(&inner)).concat("_t*");
        }
        return mangle_generic(t.name, t.args);
    }
    if t.kind == TY_FNPTR {
        // Use `void*` for fn-pointer slots; cast at call sites via fnptr_call_str.
        return "void*";
    }
    if t.kind == TY_RESULT {
        return "__glide_result_".concat(mangle_type(t.inner)).concat("_t");
    }
    if t.kind == TY_OPTION {
        return "__glide_option_".concat(mangle_type(t.inner)).concat("_t");
    }
    if t.kind == TY_OPT_RESULT {
        return "__glide_optres_".concat(mangle_type(t.inner)).concat("_t");
    }
    if t.kind == TY_ASSOC {
        // Reaches here only if monomorphization didn't substitute the assoc.
        // Emit a marker so the C compiler errors visibly instead of silently.
        return "/* unresolved-assoc */ void";
    }
    if t.kind == TY_TUPLE {
        return "__glide_".concat(mangle_tuple(t)).concat("_t");
    }
    return "void";
}

// Mangled identifier core for a tuple type: `tuple<N>_<m0>_<m1>...`. The
// arity prefix keeps `((i32,i32),i32)` (tuple2_tuple2_i32_i32_i32) distinct
// from `(i32,i32,i32)` (tuple3_i32_i32_i32).
pub fn mangle_tuple(t: *Type) -> string {
    let n: i32 = if t.args != null { t.args.len() } else { 0 };
    let mut out: string = "tuple".concat(int_to_str(n));
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            out = out.concat("_").concat(mangle_type(&a));
        }
    }
    return out;
}

// Build the C cast prefix for invoking a void* fn-pointer of this signature.
fn fnptr_cast_str(t: *Type) -> string {
    let mut s: string = type_to_c(t.fnptr_ret).concat("(*)(");
    if t.args == null || t.args.len() == 0 {
        s = s.concat("void");
    } else {
        for let i: i32 = 0; i < t.args.len(); i++ {
            if i > 0 {
                s = s.concat(", ");
            }
            let p: Type = t.args.get(i);
            s = s.concat(type_to_c(&p));
        }
    }
    s = s.concat(")");
    return s;
}

pub fn mangle_generic(name: string, args: *Vector<Type>) -> string {
    let mut out: string = name.concat("__");
    if args != null {
        for let i: i32 = 0; i < args.len(); i++ {
            if i > 0 {
                out = out.concat("_");
            }
            let a: Type = args.get(i);
            out = out.concat(mangle_type(&a));
        }
    }
    return out;
}

pub fn mangle_type(t: *Type) -> string {
    if t == null {
        return "void";
    }
    if t.kind == TY_NAMED {
        return t.name;
    }
    if t.kind == TY_POINTER {
        return mangle_type(t.inner).concat("_ptr");
    }
    if t.kind == TY_BORROW {
        return mangle_type(t.inner).concat("_ref");
    }
    if t.kind == TY_BORROW_MUT {
        return mangle_type(t.inner).concat("_refmut");
    }
    if t.kind == TY_SLICE {
        return "slice_".concat(mangle_type(t.inner));
    }
    if t.kind == TY_GENERIC {
        return mangle_generic(t.name, t.args);
    }
    if t.kind == TY_RESULT {
        return "result_".concat(mangle_type(t.inner));
    }
    if t.kind == TY_OPTION {
        return "option_".concat(mangle_type(t.inner));
    }
    if t.kind == TY_OPT_RESULT {
        return "optres_".concat(mangle_type(t.inner));
    }
    // Each trait gets its own mangle: two `Vector<*dyn A>` / `Vector<*dyn B>`
    // must monomorphize separately (falling through to "void" collided them
    // into one instantiation typed after whichever trait registered first).
    if t.kind == TY_DYN {
        return "dyn_".concat(t.name);
    }
    if t.kind == TY_ASSOC {
        return "assoc_".concat(mangle_type(t.inner)).concat("_").concat(t.name);
    }
    if t.kind == TY_TUPLE {
        return mangle_tuple(t);
    }
    return "void";
}

pub fn resolve_method_call_args(g: *CG, call: *Expr, template: *Stmt, recv_args: *Vector<Type>) -> *Vector<Type> {
    if template.type_params == null {
        return recv_args;
    }
    let n_total: i32 = template.type_params.len();
    let n_recv: i32 = 0;
    if recv_args != null {
        n_recv = recv_args.len();
    }
    if n_total <= n_recv {
        return recv_args;
    }
    let bindings: *HashMap<Type> = HashMap::new();
    // Pre-bind struct-level params from the receiver.
    for let i: i32 = 0; i < n_recv; i++ {
        let tn: string = template.type_params.get(i);
        let av: Type = recv_args.get(i);
        bindings.insert(tn, av);
    }
    // Infer extras from call args. fn_params[0] is `self`.
    if call.args != null && template.fn_params != null && template.fn_params.len() > 1 {
        let nargs: i32 = template.fn_params.len() - 1;
        if call.args.len() < nargs {
            nargs = call.args.len();
        }
        for let i: i32 = 0; i < nargs; i++ {
            let p: Param = template.fn_params.get(i + 1);
            let a: Expr = call.args.get(i);
            let at: *Type = infer_for_codegen(g, &a);
            if at != null && p.ty != null {
                unify_for_inference(p.ty, at, template.type_params, bindings);
            }
        }
    }
    let combined: *Vector<Type> = Vector::new();
    for let i: i32 = 0; i < n_recv; i++ {
        combined.push(recv_args.get(i));
    }
    for let i: i32 = n_recv; i < n_total; i++ {
        let tn: string = template.type_params.get(i);
        if !bindings.contains(tn) {
            bindings.free();
            return null;
        }
        combined.push(bindings.get(tn));
    }
    bindings.free();
    return combined;
}

// Try to monomorphize a Call expression. Returns true if the callee was
// rewritten to a mangled mono name. Uses both args and an optional return-
// type hint for inference.
fn try_mono_call(g: *CG, call: *Expr, ret_hint: *Type) -> bool {
    if call == null {
        return false;
    }
    if call.kind != EX_CALL {
        return false;
    }
    let callee: *Expr = call.lhs;
    let mut gname: string = "";
    if callee != null {
        if callee.kind == EX_IDENT {
            gname = callee.str_val;
        }
        if callee.kind == EX_PATH {
            // Map qualified path → short C name before mono lookup.
            let qual: string = callee.str_val.concat("::").concat(callee.field);
            if g.module_aliases.contains(qual) {
                gname = g.module_aliases.get(qual);
            } else {
                gname = resolve_type_prefix(g, callee.str_val).concat("_").concat(callee.field);
            }
        }
    }
    if gname.len() == 0 {
        return false;
    }
    if !g.generic_fns.contains(gname) {
        return false;
    }
    let template: Stmt = g.generic_fns.get(gname);
    let bindings: *HashMap<Type> = HashMap::new();
    // Infer from return-type hint (if provided).
    if ret_hint != null && template.fn_ret_ty != null {
        unify_for_inference(template.fn_ret_ty, ret_hint, template.type_params, bindings);
    }
    // Infer from arg types.
    if call.args != null && template.fn_params != null {
        let n: i32 = template.fn_params.len();
        if call.args.len() < n {
            n = call.args.len();
        }
        for let i: i32 = 0; i < n; i++ {
            let p: Param = template.fn_params.get(i);
            let a: Expr = call.args.get(i);
            let at: *Type = infer_for_codegen(g, &a);
            if at != null && p.ty != null {
                unify_for_inference(p.ty, at, template.type_params, bindings);
            }
        }
    }
    // Build args in declared param order.
    let derived: *Vector<Type> = Vector::new();
    let mut all: bool = true;
    if template.type_params != null {
        for let i: i32 = 0; i < template.type_params.len(); i++ {
            let tn: string = template.type_params.get(i);
            if bindings.contains(tn) {
                derived.push(bindings.get(tn));
            } else {
                all = false;
            }
        }
    }
    if !all || derived.len() == 0 {
        bindings.free();
        return false;
    }
    let mangled: string = mangle_generic(gname, derived);
    callee.kind = EX_IDENT;
    callee.str_val = mangled;
    callee.field = "";
    register_fn_mono_signature(g, mangled, &template, derived);
    if !g.emitted_monos.contains(mangled) {
        g.emitted_monos.insert(mangled, true);
        let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: derived };
        g.fn_mono_queue.push(entry);
    }
    bindings.free();
    return true;
}

// Recursively walks expr/stmt trees, calling try_mono_call on every generic
// call to queue monos and emit forward decls. Called as a pre-pass before
// emitting any fn body so forward decls don't interleave with code.
// For an EX_CALL `e`, return the declared type of the i-th formal parameter,
// or null when the callee isn't a known regular fn / impl method. Lets the
// prescan propagate `*Vector<int>` down into `take(Vector::new())` so the
// generic ctor monomorphizes from the surrounding context.
fn callee_param_ty(g: *CG, e: *Expr, i: i32) -> *Type {
    if e == null || e.lhs == null {
        return null;
    }
    let callee: *Expr = e.lhs;
    if callee.kind == EX_IDENT && callee.str_val != null && g.fns.contains(callee.str_val) {
        let sig: Stmt = g.fns.get(callee.str_val);
        if sig.fn_params != null && i < sig.fn_params.len() {
            let p: Param = sig.fn_params.get(i);
            return p.ty;
        }
    }
    // Method call: `recv.method(args)` — look up the impl method and skip
    // self at index 0, so user arg index `i` maps to method param `i + 1`.
    if callee.kind == EX_MEMBER && callee.lhs != null {
        let rt: *Type = infer_for_codegen(g, callee.lhs);
        let stripped: *Type = strip_ptr(rt);
        if stripped != null && (stripped.kind == TY_NAMED || stripped.kind == TY_GENERIC) {
            let mname: string = stripped.name.concat("_").concat(callee.field);
            if g.fns.contains(mname) {
                let sig: Stmt = g.fns.get(mname);
                if sig.fn_params != null && i + 1 < sig.fn_params.len() {
                    let p: Param = sig.fn_params.get(i + 1);
                    return p.ty;
                }
            }
            if g.generic_fns.contains(mname) {
                let sig: Stmt = g.generic_fns.get(mname);
                if sig.fn_params != null && i + 1 < sig.fn_params.len() {
                    let p: Param = sig.fn_params.get(i + 1);
                    return p.ty;
                }
            }
        }
    }
    return null;
}

// The type params of an EX_CALL's callee (`fn take<T>(...)` -> ["T"]), or
// null for a non-generic / unknown callee. Mirrors callee_param_ty's
// resolution so the two can be used together.
fn callee_type_params(g: *CG, e: *Expr) -> *Vector<string> {
    if e == null || e.lhs == null {
        return null;
    }
    let callee: *Expr = e.lhs;
    if callee.kind == EX_IDENT && callee.str_val != null && g.fns.contains(callee.str_val) {
        let sig: Stmt = g.fns.get(callee.str_val);
        return sig.type_params;
    }
    if callee.kind == EX_MEMBER && callee.lhs != null {
        let rt: *Type = infer_for_codegen(g, callee.lhs);
        let stripped: *Type = strip_ptr(rt);
        if stripped != null && (stripped.kind == TY_NAMED || stripped.kind == TY_GENERIC) {
            let mname: string = stripped.name.concat("_").concat(callee.field);
            if g.fns.contains(mname) {
                let sig: Stmt = g.fns.get(mname);
                return sig.type_params;
            }
            if g.generic_fns.contains(mname) {
                let sig: Stmt = g.generic_fns.get(mname);
                return sig.type_params;
            }
        }
    }
    return null;
}

// True when `t` mentions one of `params` (a generic template's type-param
// names) anywhere in its shape — i.e. it is not yet a concrete type.
fn _ty_mentions_param(t: *Type, params: *Vector<string>) -> bool {
    if t == null || params == null {
        return false;
    }
    if t.kind == TY_NAMED {
        for let i: i32 = 0; i < params.len(); i++ {
            if params.get(i).eq(t.name) {
                return true;
            }
        }
    }
    if t.inner != null && _ty_mentions_param(t.inner, params) {
        return true;
    }
    if t.args != null {
        for let i: i32 = 0; i < t.args.len(); i++ {
            let a: Type = t.args.get(i);
            if _ty_mentions_param(&a, params) {
                return true;
            }
        }
    }
    return false;
}

// Lower a `vec_of!(a, b, c)` macro node in place into a block-expression that
// allocates a `*Vector<T>`, pushes each element, and yields it:
//
//   ({ Vector__T* __vec_of_L_C = Vector_new__T();
//      Vector_push__T(__vec_of_L_C, a); ...; (Vector__T*)__vec_of_L_C; })
//
// We synthesise the equivalent AST — a `let v: *Vector<T> = Vector::new()`, one
// `v.push(x)` per element, and a cast operand yielding `v` — rather than
// emitting C directly, so the existing monomorphization machinery sees ordinary
// generic calls and queues the right `Vector_new` / `Vector_push` / struct
// monos. The cast operand makes the block's type inferable even outside the
// prescan scope where the temp is declared. Idempotent: a node that has already
// been lowered (no longer EX_MACRO) or has no args is left untouched.
fn _vec_of_rewrite(g: *CG, e: *Expr) {
    if e == null || e.kind != EX_MACRO {
        return;
    }
    if e.str_val == null || !e.str_val.eq("vec_of") {
        return;
    }
    if e.args == null || e.args.len() == 0 {
        return;
    }
    let first: Expr = e.args.get(0);
    let elem: *Type = infer_for_codegen(g, &first);
    if elem == null {
        return;
    }
    let vec_ty: *Type = ty_vector_of(elem);
    let tmp: string = "__vec_of_".concat(int_to_str(e.line)).concat("_").concat(int_to_str(e.column));
    let stmts: *Vector<Stmt> = Vector::new();
    let ctor: *Expr = expr_call(expr_path("Vector", "new", e.line, e.column), Vector::new());
    stmts.push(*stmt_let(tmp, vec_ty, ctor, false, e.line, e.column));
    for let i: i32 = 0; i < e.args.len(); i++ {
        let a: Expr = e.args.get(i);
        let pa: *Expr = __glide_palloc(sizeof(Expr)) as *Expr;
        *pa = a;
        let recv: *Expr = expr_ident(tmp, e.line, e.column);
        let push_args: *Vector<Expr> = Vector::new();
        push_args.push(*pa);
        let pcall: *Expr = expr_call(expr_member(recv, "push"), push_args);
        stmts.push(*stmt_expr(pcall));
    }
    let yield_cast: *Expr = expr_cast(expr_ident(tmp, e.line, e.column), vec_ty);
    e.kind = EX_BLOCK;
    e.block_stmts = stmts;
    e.operand = yield_cast;
    e.args = null;
}

fn prescan_expr(g: *CG, e: *Expr, ret_hint: *Type) {
    if e == null {
        return;
    }
    // Lower `vec_of!(...)` to its block form before anything else so the
    // synthesised `Vector::new()` / `push` calls below get monomorphized.
    if e.kind == EX_MACRO && e.str_val != null && e.str_val.eq("vec_of") {
        _vec_of_rewrite(g, e);
    }
    // Bidirectional inference for `inline_generic_ctor().method(args)`:
    // derive T from the chained method's args back to the receiver, so
    // `Vector::new().push(1)` queues the right Vector_new__int / Vector_push__int
    // monos. Must run before try_mono_call so the receiver hint is ready.
    let mut chain_recv_hint: *Type = null;
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER && e.lhs.lhs != null && e.lhs.lhs.kind == EX_CALL && e.lhs.lhs.lhs != null && e.lhs.lhs.lhs.kind == EX_PATH {
        let recv: *Expr = e.lhs.lhs;
        let method: string = e.lhs.field;
        // Resolve `mod::path::Vector::new()` → bare `Vector` family before
        // checking generic-struct registry.
        let mut family: string = recv.lhs.str_val;
        if !g.generic_structs.contains(family) {
            family = resolve_type_prefix(g, family);
        }
        if g.generic_structs.contains(family) {
            let struct_def: Stmt = g.generic_structs.get(family);
            let mname: string = family.concat("_").concat(method);
            if g.generic_fns.contains(mname) && struct_def.type_params != null {
                let mtmpl: Stmt = g.generic_fns.get(mname);
                let bindings: *HashMap<Type> = HashMap::new();
                // Static methods (`Json::wrap(v)`) have no `self`; instance
                // methods (`v.push(x)`) put `self` at fn_params[0]. Detect
                // by name to know whether call args start at param 0 or 1.
                let mut self_off: i32 = 0;
                if mtmpl.fn_params != null && mtmpl.fn_params.len() > 0 {
                    let first_p: Param = mtmpl.fn_params.get(0);
                    if first_p.name != null && first_p.name.eq("self") {
                        self_off = 1;
                    }
                }
                if e.args != null && mtmpl.fn_params != null && mtmpl.fn_params.len() > self_off {
                    let n: i32 = mtmpl.fn_params.len() - self_off;
                    if e.args.len() < n {
                        n = e.args.len();
                    }
                    for let i: i32 = 0; i < n; i++ {
                        let p: Param = mtmpl.fn_params.get(i + self_off);
                        let a: Expr = e.args.get(i);
                        let at: *Type = infer_for_codegen(g, &a);
                        if at != null && p.ty != null {
                            unify_for_inference(p.ty, at, mtmpl.type_params, bindings);
                        }
                    }
                }
                // Also unify against the inner static method's args (e.g.
                // `Json::wrap(v).into_response()` — the outer `.into_response()`
                // has no args of its own, but `wrap`'s arg `v` carries T).
                let inner_method: string = recv.lhs.field;
                let inner_mname: string = family.concat("_").concat(inner_method);
                if g.generic_fns.contains(inner_mname) {
                    let inner_tmpl: Stmt = g.generic_fns.get(inner_mname);
                    let mut inner_off: i32 = 0;
                    if inner_tmpl.fn_params != null && inner_tmpl.fn_params.len() > 0 {
                        let p0: Param = inner_tmpl.fn_params.get(0);
                        if p0.name != null && p0.name.eq("self") {
                            inner_off = 1;
                        }
                    }
                    if recv.args != null && inner_tmpl.fn_params != null && inner_tmpl.fn_params.len() > inner_off {
                        let n2: i32 = inner_tmpl.fn_params.len() - inner_off;
                        if recv.args.len() < n2 {
                            n2 = recv.args.len();
                        }
                        for let i: i32 = 0; i < n2; i++ {
                            let p: Param = inner_tmpl.fn_params.get(i + inner_off);
                            let a: Expr = recv.args.get(i);
                            let at: *Type = infer_for_codegen(g, &a);
                            if at != null && p.ty != null {
                                unify_for_inference(p.ty, at, struct_def.type_params, bindings);
                            }
                        }
                    }
                }
                let derived: *Vector<Type> = Vector::new();
                let mut all: bool = true;
                for let i: i32 = 0; i < struct_def.type_params.len(); i++ {
                    let tn: string = struct_def.type_params.get(i);
                    if bindings.contains(tn) {
                        derived.push(bindings.get(tn));
                    } else {
                        all = false;
                    }
                }
                if all && derived.len() > 0 {
                    chain_recv_hint = ty_pointer(ty_generic(family, derived));
                    // Queue the struct mono — chained inference is the only
                    // way Vector<int> reaches codegen here (no let_ty / no
                    // call-site signature mentions it). Emit the typedef +
                    // body inline so any fn forward-decl that follows in
                    // the same prescan window can name the mangled type.
                    let mangled_struct: string = mangle_generic(chain_recv_hint.inner.name, chain_recv_hint.inner.args);
                    if !g.emitted_monos.contains(mangled_struct) {
                        g.emitted_monos.insert(mangled_struct, true);
                        println!("typedef struct ", mangled_struct, " ", mangled_struct, ";");
                        emit_struct_mono(g, chain_recv_hint.inner);
                    }
                    g.struct_mono_queue.push(*chain_recv_hint.inner);
                    prescan_expr(g, recv, chain_recv_hint);
                }
                bindings.free();
            }
        }
    }
    if e.kind == EX_CALL {
        let _ok: bool = try_mono_call(g, e, ret_hint);
    }
    // Method call on generic receiver: also queue.
    if e.kind == EX_CALL && e.lhs != null && e.lhs.kind == EX_MEMBER {
        let recv: *Expr = e.lhs.lhs;
        let method: string = e.lhs.field;
        // Prefer the bidirectional hint when present — recv may have just
        // been rewritten to a mangled mono whose ret type isn't yet in g.fns.
        let mut stripped: *Type = null;
        if chain_recv_hint != null {
            stripped = chain_recv_hint.inner;
        } else {
            let rt: *Type = infer_for_codegen(g, recv);
            stripped = strip_ptr(rt);
        }
        if stripped != null && stripped.kind == TY_GENERIC {
            // Specialized impl already concrete — nothing to mono.
            let spec_prefix: string = mangle_generic(stripped.name, stripped.args);
            let spec_name: string = spec_prefix.concat("_").concat(method);
            if !g.fns.contains(spec_name) {
                let mname: string = stripped.name.concat("_").concat(method);
                if g.generic_fns.contains(mname) {
                    let template: Stmt = g.generic_fns.get(mname);
                    let full_args: *Vector<Type> = resolve_method_call_args(g, e, &template, stripped.args);
                    if full_args != null {
                        let mangled: string = mangle_generic(mname, full_args);
                        register_fn_mono_signature(g, mangled, &template, full_args);
                        if !g.emitted_monos.contains(mangled) {
                            g.emitted_monos.insert(mangled, true);
                            let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: full_args };
                            g.fn_mono_queue.push(entry);
                        }
                    }
                }
            }
        }
    }
    if e.lhs != null {
        // EX_CAST stores its operand in `lhs`; pass the cast target as the
        // child's expected type so `(Vector::new() as *Vector<int>)` infers T.
        let mut child_hint: *Type = null;
        if e.kind == EX_CAST {
            child_hint = e.cast_to;
        }
        prescan_expr(g, e.lhs, child_hint);
    }
    let no_hint: *Type = null;
    if e.rhs != null {
        prescan_expr(g, e.rhs, no_hint);
    }
    if e.operand != null {
        prescan_expr(g, e.operand, no_hint);
    }
    if e.args != null {
        for let i: i32 = 0; i < e.args.len(); i++ {
            let a: Expr = e.args.get(i);
            // Carry the formal param's declared type as the arg's expected
            // type so inline `Vector::new()` etc. monomorphize correctly.
            let mut arg_hint: *Type = null;
            if e.kind == EX_CALL {
                arg_hint = callee_param_ty(g, e, i);
            }
            // Same for struct-lit field values: pass the declared field type
            // so `Box { items: Vector::new() }` infers Vector<int> from the
            // `items: *Vector<int>` field.
            if e.kind == EX_STRUCT_LIT && e.str_val != null && e.field_names != null && i < e.field_names.len() {
                let fname: string = e.field_names.get(i);
                let mut sf: *Vector<Field> = null;
                if g.structs.contains(e.str_val) {
                    let sd: Stmt = g.structs.get(e.str_val);
                    sf = sd.struct_fields;
                } else {
                    if g.generic_structs.contains(e.str_val) {
                        let sd: Stmt = g.generic_structs.get(e.str_val);
                        sf = sd.struct_fields;
                    }
                }
                if sf != null {
                    for let j: i32 = 0; j < sf.len(); j++ {
                        let f: Field = sf.get(j);
                        if f.name.eq(fname) {
                            arg_hint = f.ty;
                        }
                    }
                } else {
                    if e.cast_to != null && e.cast_to.kind == TY_GENERIC && g.generic_structs.contains(e.cast_to.name) {
                        // Mono struct-lit (`Stack__i32 { items: Vector::new() }`)
                        // inside a generic impl method: the mangled name isn't in
                        // g.structs, but subst_expr left the concrete generic type
                        // on cast_to. Substitute the template's field types with
                        // its args so the field hint is e.g. `*Vector<i32>`.
                        let tmpl: Stmt = g.generic_structs.get(e.cast_to.name);
                        if tmpl.struct_fields != null && tmpl.type_params != null {
                            for let j: i32 = 0; j < tmpl.struct_fields.len(); j++ {
                                let f: Field = tmpl.struct_fields.get(j);
                                if f.name.eq(fname) {
                                    arg_hint = subst_type(f.ty, tmpl.type_params, e.cast_to.args);
                                }
                            }
                        }
                    }
                }
            }
            prescan_expr(g, &a, arg_hint);
        }
    }
    // Block-expression statements (e.g. the lowered body of `vec_of!`, or a
    // user `{ ...; value }` expression): walk them so generic calls inside —
    // `Vector::new()` / `v.push(x)` — queue their monos.
    if e.block_stmts != null {
        for let i: i32 = 0; i < e.block_stmts.len(); i++ {
            let b: Stmt = e.block_stmts.get(i);
            prescan_stmt(g, &b);
        }
    }
}

pub fn prescan_stmt(g: *CG, s: *Stmt) {
    if s == null {
        return;
    }
    // `return X` carries the enclosing fn's return type as a hint so inline
    // generic ctors like `return Vector::new()` monomorphize correctly.
    if s.kind == ST_RETURN {
        if s.expr_value != null {
            prescan_expr(g, s.expr_value, g.current_ret_ty);
        }
        return;
    }
    if s.kind == ST_LET || s.kind == ST_CONST {
        // Declare in scope so receiver-type lookup works. When there's no
        // annotation, infer from the initializer (e.g. `let v = make()`
        // where `make` returns `*Vector<int>`).
        if s.let_ty != null {
            g.declare(s.name, s.let_ty);
        } else {
            if s.let_value != null {
                let inferred: *Type = infer_for_codegen(g, s.let_value);
                if inferred != null {
                    g.declare(s.name, inferred);
                }
            }
        }
        if s.let_value != null {
            prescan_expr(g, s.let_value, s.let_ty);
        }
        // Auto-drop with `let v*` on a generic type: queue the free-method
        // mono so its forward decl is emitted before any user fn body.
        if s.kind == ST_LET && s.is_auto_owned && s.let_ty != null {
            let inner_ty: *Type = strip_ptr(s.let_ty);
            if inner_ty != null && inner_ty.kind == TY_GENERIC {
                let free_name: string = inner_ty.name.concat("_free");
                if g.generic_fns.contains(free_name) {
                    let mangled: string = mangle_generic(free_name, inner_ty.args);
                    if !g.emitted_monos.contains(mangled) {
                        g.emitted_monos.insert(mangled, true);
                        let template: Stmt = g.generic_fns.get(free_name);
                        let entry: FnMonoEntry = FnMonoEntry { name: template.name, args: inner_ty.args };
                        g.fn_mono_queue.push(entry);
                    }
                }
            }
        }
        return;
    }
    let no_hint: *Type = null;
    if s.expr_value != null {
        prescan_expr(g, s.expr_value, no_hint);
    }
    if s.cond != null {
        prescan_expr(g, s.cond, no_hint);
    }
    if s.for_init != null {
        prescan_stmt(g, s.for_init);
    }
    if s.for_step != null {
        prescan_expr(g, s.for_step, no_hint);
    }
    if s.then_body != null {
        for let i: i32 = 0; i < s.then_body.len(); i++ {
            let b: Stmt = s.then_body.get(i);
            prescan_stmt(g, &b);
        }
    }
    if s.else_body != null {
        for let i: i32 = 0; i < s.else_body.len(); i++ {
            let b: Stmt = s.else_body.get(i);
            prescan_stmt(g, &b);
        }
    }
    if s.fn_body != null {
        g.scope.clear();
        if s.fn_params != null {
            for let i: i32 = 0; i < s.fn_params.len(); i++ {
                let p: Param = s.fn_params.get(i);
                g.declare(p.name, p.ty);
            }
        }
        let saved_ret: *Type = g.current_ret_ty;
        g.current_ret_ty = s.fn_ret_ty;
        for let i: i32 = 0; i < s.fn_body.len(); i++ {
            let b: Stmt = s.fn_body.get(i);
            prescan_stmt(g, &b);
        }
        g.current_ret_ty = saved_ret;
    }
    if s.impl_methods != null {
        for let i: i32 = 0; i < s.impl_methods.len(); i++ {
            let m: Stmt = s.impl_methods.get(i);
            prescan_stmt(g, &m);
        }
    }
}

// Build a synthetic Stmt with substituted ret/params and register it under
// `mangled` in g.fns so infer_for_codegen can resolve calls to the mono'd
// function (e.g. an inline `Vector::new()` whose callee was just rewritten to
// `Vector_new__int`). Without this, chained `.method(arg)` after a freshly-
// mono'd ctor can't determine the receiver's type.
fn register_fn_mono_signature(g: *CG, mangled: string, template: *Stmt, args: *Vector<Type>) {
    if g.fns.contains(mangled) {
        return;
    }
    let synth: *Stmt = calloc(1, sizeof(Stmt)) as *Stmt;
    synth.kind = template.kind;
    synth.name = mangled;
    let mut sret: *Type = subst_type(template.fn_ret_ty, template.type_params, args);
    sret = resolve_assoc_recursive(g, sret);
    synth.fn_ret_ty = sret;
    // The mono may have introduced ?T / !T / ?!T inners that the up-front
    // collection pass never saw (it skipped the generic template body).
    // Register them now and emit runtime helpers inline so the forward decl
    // and body that follow can reference the typedef.
    collect_result_in_type(g, sret);
    if template.fn_params != null {
        let ps: *Vector<Param> = Vector::new();
        for let i: i32 = 0; i < template.fn_params.len(); i++ {
            let p: Param = template.fn_params.get(i);
            let pt: *Type = subst_type(p.ty, template.type_params, args);
            let resolved: *Type = resolve_assoc_recursive(g, pt);
            collect_result_in_type(g, resolved);
            let np: Param = Param { name: p.name, ty: resolved, name_line: p.name_line, name_col: p.name_col };
            ps.push(np);
        }
        synth.fn_params = ps;
    }
    g.fns.insert(mangled, *synth);
    // The mono may have introduced ?T / !T / ?!T inners that the up-front
    // collection pass never saw (it skipped the generic template body).
    // Collect them now and re-emit runtime helpers; the templates carry
    // header guards so re-emission of an existing inner is a no-op for cc.
    collect_result_in_type(g, sret);
    if synth.fn_params != null {
        for let i: i32 = 0; i < synth.fn_params.len(); i++ {
            let p: Param = synth.fn_params.get(i);
            collect_result_in_type(g, p.ty);
        }
    }
    emit_result_runtime(g);
    emit_option_runtime(g);
    emit_optres_runtime(g);
}

// Unify a generic pattern type against a concrete type. Adds bindings for
// matching type vars listed in `params`. Returns false on mismatch (currently
// permissive: doesn't fail, just collects what it can).
pub fn unify_for_inference(pat: *Type, actual: *Type, params: *Vector<string>, bindings: *HashMap<Type>) {
    if pat == null {
        return;
    }
    if actual == null {
        return;
    }
    if pat.kind == TY_NAMED {
        // Type var?
        if params != null {
            for let i: i32 = 0; i < params.len(); i++ {
                if pat.name.eq(params.get(i)) {
                    if !bindings.contains(pat.name) {
                        bindings.insert(pat.name, *actual);
                    }
                    return;
                }
            }
        }
    }
    if pat.kind == TY_POINTER && actual.kind == TY_POINTER {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_BORROW && actual.kind == TY_BORROW {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_BORROW_MUT && actual.kind == TY_BORROW_MUT {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_SLICE && actual.kind == TY_SLICE {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_GENERIC && actual.kind == TY_GENERIC {
        if pat.name.eq(actual.name) && pat.args != null && actual.args != null && pat.args.len() == actual.args.len() {
            for let i: i32 = 0; i < pat.args.len(); i++ {
                let pa: Type = pat.args.get(i);
                let aa: Type = actual.args.get(i);
                unify_for_inference(&pa, &aa, params, bindings);
            }
        }
    }
    if pat.kind == TY_OPTION && actual.kind == TY_OPTION {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_RESULT && actual.kind == TY_RESULT {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    if pat.kind == TY_OPT_RESULT && actual.kind == TY_OPT_RESULT {
        unify_for_inference(pat.inner, actual.inner, params, bindings);
        return;
    }
    // Fn-pointer types: `fn(T) -> U` against `fn(int) -> string` should
    // bind T=int, U=string. Without this case, generic fns like
    // `iter_map<T, U>(v: *Vector<T>, f: fn(T) -> U) -> *Vector<U>` couldn't
    // infer U from the fn-pointer arg's return type.
    if pat.kind == TY_FNPTR && actual.kind == TY_FNPTR {
        if pat.args != null && actual.args != null && pat.args.len() == actual.args.len() {
            for let i: i32 = 0; i < pat.args.len(); i++ {
                let pa: Type = pat.args.get(i);
                let aa: Type = actual.args.get(i);
                unify_for_inference(&pa, &aa, params, bindings);
            }
        }
        if pat.fnptr_ret != null && actual.fnptr_ret != null {
            unify_for_inference(pat.fnptr_ret, actual.fnptr_ret, params, bindings);
        }
    }
}

// Recursive type substitution: walk t, replacing Type::Named(n) with the
// matching arg from `params -> args` mapping.
pub fn subst_type(t: *Type, params: *Vector<string>, args: *Vector<Type>) -> *Type {
    if t == null {
        return null;
    }
    if t.kind == TY_NAMED {
        if params != null {
            for let i: i32 = 0; i < params.len(); i++ {
                if t.name.eq(params.get(i)) {
                    let a: Type = args.get(i);
                    let p: *Type = malloc(sizeof(Type)) as *Type;
                    *p = a;
                    return p;
                }
            }
        }
        return t;
    }
    if t.kind == TY_POINTER {
        return ty_pointer(subst_type(t.inner, params, args));
    }
    if t.kind == TY_BORROW {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW;
        p.inner = subst_type(t.inner, params, args);
        return p;
    }
    if t.kind == TY_BORROW_MUT {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_BORROW_MUT;
        p.inner = subst_type(t.inner, params, args);
        return p;
    }
    if t.kind == TY_SLICE {
        let p: *Type = malloc(sizeof(Type)) as *Type;
        p.kind = TY_SLICE;
        p.inner = subst_type(t.inner, params, args);
        return p;
    }
    if t.kind == TY_GENERIC {
        let new_args: *Vector<Type> = Vector::new();
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                let na: *Type = subst_type(&a, params, args);
                if na != null {
                    new_args.push(*na);
                }
            }
        }
        return ty_generic(t.name, new_args);
    }
    if t.kind == TY_OPTION {
        return ty_option(subst_type(t.inner, params, args));
    }
    if t.kind == TY_RESULT {
        return ty_result(subst_type(t.inner, params, args));
    }
    if t.kind == TY_OPT_RESULT {
        return ty_optres(subst_type(t.inner, params, args));
    }
    if t.kind == TY_TUPLE {
        let new_args: *Vector<Type> = Vector::new();
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                let na: *Type = subst_type(&a, params, args);
                if na != null {
                    new_args.push(*na);
                }
            }
        }
        return ty_tuple(new_args);
    }
    if t.kind == TY_FNPTR {
        let new_args: *Vector<Type> = Vector::new();
        if t.args != null {
            for let i: i32 = 0; i < t.args.len(); i++ {
                let a: Type = t.args.get(i);
                let na: *Type = subst_type(&a, params, args);
                if na != null {
                    new_args.push(*na);
                }
            }
        }
        let p: *Type = __glide_palloc(sizeof(Type)) as *Type;
        p.kind = TY_FNPTR;
        p.args = new_args;
        p.fnptr_ret = subst_type(t.fnptr_ret, params, args);
        return p;
    }
    if t.kind == TY_ASSOC {
        // Substitute the owner; the assoc lookup itself happens later when
        // the owner is fully concrete (typer/codegen impl-table consult).
        let new_owner: *Type = subst_type(t.inner, params, args);
        return ty_assoc(new_owner, t.name);
    }
    return t;
}

fn op_to_c(op: i32) -> string {
    if op == OP_ADD {
        return "+";
    }
    if op == OP_SUB {
        return "-";
    }
    if op == OP_MUL {
        return "*";
    }
    if op == OP_DIV {
        return "/";
    }
    if op == OP_MOD {
        return "%";
    }
    if op == OP_EQ {
        return "==";
    }
    if op == OP_NE {
        return "!=";
    }
    if op == OP_LT {
        return "<";
    }
    if op == OP_LE {
        return "<=";
    }
    if op == OP_GT {
        return ">";
    }
    if op == OP_GE {
        return ">=";
    }
    if op == OP_AND {
        return "&&";
    }
    if op == OP_OR {
        return "||";
    }
    if op == OP_BIT_AND {
        return "&";
    }
    if op == OP_BIT_OR {
        return "|";
    }
    if op == OP_BIT_XOR {
        return "^";
    }
    if op == OP_SHL {
        return "<<";
    }
    if op == OP_SHR {
        return ">>";
    }
    if op == OP_ASSIGN {
        return "=";
    }
    if op == OP_PLUS_ASSIGN {
        return "+=";
    }
    if op == OP_MINUS_ASSIGN {
        return "-=";
    }
    if op == OP_STAR_ASSIGN {
        return "*=";
    }
    if op == OP_SLASH_ASSIGN {
        return "/=";
    }
    if op == OP_PERCENT_ASSIGN {
        return "%=";
    }
    if op == OP_BITAND_ASSIGN {
        return "&=";
    }
    if op == OP_BITOR_ASSIGN {
        return "|=";
    }
    if op == OP_BITXOR_ASSIGN {
        return "^=";
    }
    if op == OP_SHL_ASSIGN {
        return "<<=";
    }
    if op == OP_SHR_ASSIGN {
        return ">>=";
    }
    return "?";
}

fn unop_to_c(op: i32) -> string {
    if op == UN_NEG {
        return "-";
    }
    if op == UN_NOT {
        return "!";
    }
    if op == UN_BIT_NOT {
        return "~";
    }
    if op == UN_DEREF {
        return "*";
    }
    if op == UN_ADDR {
        return "&";
    }
    if op == UN_ADDR_MUT {
        return "&";
    }
    return "?";
}

// ---- printing helpers (just print! to stdout) ----------------------------
pub fn ind(n: i32) {
    for let i: i32 = 0; i < n; i++ {
        print!("    ");
    }
}

// `@cfg("windows")` / `@cfg("posix")` brackets a top-level decl with a cpp
// guard so per-platform fns (typically naked asm context switches) compile
// only on the right OS. No-op when cfg is empty.
pub fn emit_cfg_open(cfg: string) {
    if cfg.eq("windows") {
        println!("#ifdef _WIN32");
    } else {
        if cfg.eq("posix") {
            println!("#ifndef _WIN32");
        }
    }
}

pub fn emit_cfg_close(cfg: string) {
    if cfg.eq("windows") || cfg.eq("posix") {
        println!("#endif");
    }
}

// Yield-expression of a match arm body: either a single ST_EXPR (the
// arm wrote `=> expr`) or a block whose trailing `return val;` is the
// value (the arm wrote `=> { stmts; return val; }`).
pub fn arm_value_expr(a: *MatchArm) -> *Expr {
    if a.body == null || a.body.len() == 0 {
        return null;
    }
    let last: Stmt = a.body.get(a.body.len() - 1);
    // A synthesized yield (`=> expr`) or a trailing expression statement is the
    // arm's value. A USER-written `return` is not — it exits the enclosing fn.
    if last.kind == ST_RETURN && last.is_arm_yield {
        return last.expr_value;
    }
    if last.kind == ST_EXPR {
        return last.expr_value;
    }
    return null;
}

fn emit_match_arm_value(g: *CG, a: *MatchArm) {
    if a.body == null || a.body.len() == 0 {
        return;
    }
    let v: *Expr = arm_value_expr(a);
    if v == null {
        // No value: the arm only runs statements. A user-written `return`
        // in here is a REAL return — it exits the enclosing function, so
        // `__r` is never read on this path.
        for let k: i32 = 0; k < a.body.len(); k++ {
            let b: Stmt = a.body.get(k);
            emit_stmt(g, &b, 0);
        }
        return;
    }
    let last_idx: i32 = a.body.len() - 1;
    for let k: i32 = 0; k < last_idx; k++ {
        let b: Stmt = a.body.get(k);
        emit_stmt(g, &b, 0);
    }
    print!("__r = (");
    emit_expr(g, v);
    print!(");");
}

// Probe expression GCC's `__typeof__` resolves to compute the EX_MATCH
// result type. Walks the first arm's value in a sibling stmt-expr that
// declares the same payload bindings — `__typeof__` evaluates the type
// at compile time without executing the body, so the payload reads
// give correct types even though no scrutinee value flows through.
fn emit_arm_typeof_probe(g: *CG, arms: *Vector<MatchArm>) {
    if arms == null || arms.len() == 0 {
        print!("(int)0");
        return;
    }
    // Probe the first arm that actually yields a value; an arm that only runs
    // statements (or returns from the fn) says nothing about the match type.
    let mut pidx: i32 = 0;
    for let pi: i32 = 0; pi < arms.len(); pi++ {
        let pa: MatchArm = arms.get(pi);
        if arm_value_expr(&pa) != null {
            pidx = pi;
            break;
        }
    }
    let a: MatchArm = arms.get(pidx);
    print!("({ ");
    if a.bindings != null && a.bindings.len() > 0 {
        if a.bindings.len() == 1 {
            let payload: string = "__m.data.v_".concat(a.variant);
            print!("__typeof__(");
            print!(payload);
            print!(") ");
            print!(c_safe_ident(a.bindings.get(0)));
            print!(" = ");
            print!(payload);
            print!("; ");
        } else {
            for let k: i32 = 0; k < a.bindings.len(); k++ {
                let payload: string = "__m.data.v_".concat(a.variant);
                print!("__typeof__(");
                print!(payload);
                print!(".f");
                print!(k);
                print!(") ");
                print!(c_safe_ident(a.bindings.get(k)));
                print!(" = ");
                print!(payload);
                print!(".f");
                print!(k);
                print!("; ");
            }
        }
    }
    // Emit the arm's leading statements before the trailing value so locals it
    // declares are in scope inside the __typeof__ probe (GCC type-checks the
    // stmt-expr even though it never runs it). Without this a block arm like
    // `{ let t = 10; return t; }` left `t` undeclared in the probe.
    if a.body != null && a.body.len() > 1 {
        let last_idx: i32 = a.body.len() - 1;
        for let k: i32 = 0; k < last_idx; k++ {
            let b: Stmt = a.body.get(k);
            emit_stmt(g, &b, 0);
        }
    }
    let v: *Expr = arm_value_expr(&a);
    print!("(");
    if v != null {
        emit_expr(g, v);
    } else {
        print!("0");
    }
    print!("); })");
}

// `match` on a value scrutinee with literal-pattern arms (`1 =>`, `"s" =>`)
// lowers to an if/else-if chain on equality — strings compare by bytes,
// everything else natively — ending in the `_` arm (the typer guarantees
// one). Returns false when no arm carries a literal so the caller falls
// through to the enum switch path.

fn _match_has_literal_arm(arms: *Vector<MatchArm>) -> bool {
    if arms == null {
        return false;
    }
    for let i: i32 = 0; i < arms.len(); i++ {
        let a: MatchArm = arms.get(i);
        if a.lit != null {
            return true;
        }
    }
    return false;
}

fn _match_wildcard_idx(arms: *Vector<MatchArm>) -> i32 {
    if arms == null {
        return 0 - 1;
    }
    for let i: i32 = 0; i < arms.len(); i++ {
        let a: MatchArm = arms.get(i);
        if a.lit == null && a.variant.eq("_") {
            return i;
        }
    }
    return 0 - 1;
}

fn _emit_match_lit_cmp(g: *CG, scrut_ty: *Type, a: *MatchArm) {
    if _is_string_ty(scrut_ty) {
        print!("__glide_string_eq(__m, ");
        emit_expr(g, a.lit);
        print!(")");
        return;
    }
    print!("(__m == ");
    emit_expr(g, a.lit);
    print!(")");
}

fn _emit_match_literal_stmt(g: *CG, s: *Stmt, scrut_ty: *Type, depth: i32) -> bool {
    if !_match_has_literal_arm(s.arms) {
        return false;
    }
    let mut cty: string = "int";
    if scrut_ty != null {
        cty = type_to_c(scrut_ty);
    }
    ind(depth);
    println!("{");
    ind(depth + 1);
    print!(cty, " __m = ");
    emit_expr(g, s.scrutinee);
    println!(";");
    let mut first: bool = true;
    for let i: i32 = 0; i < s.arms.len(); i++ {
        let a: MatchArm = s.arms.get(i);
        if a.lit == null {
            continue;
        }
        ind(depth + 1);
        if first {
            print!("if (");
        } else {
            print!("} else if (");
        }
        first = false;
        _emit_match_lit_cmp(g, scrut_ty, &a);
        println!(") {");
        if a.body != null {
            for let k: i32 = 0; k < a.body.len(); k++ {
                let b: Stmt = a.body.get(k);
                emit_stmt(g, &b, depth + 2);
            }
        }
    }
    let wi: i32 = _match_wildcard_idx(s.arms);
    ind(depth + 1);
    println!("} else {");
    if wi >= 0 {
        let w: MatchArm = s.arms.get(wi);
        if w.body != null {
            for let k: i32 = 0; k < w.body.len(); k++ {
                let b: Stmt = w.body.get(k);
                emit_stmt(g, &b, depth + 2);
            }
        }
    }
    ind(depth + 1);
    println!("}");
    ind(depth);
    println!("}");
    return true;
}

fn _emit_match_literal_expr(g: *CG, e: *Expr, scrut_ty: *Type) -> bool {
    if !_match_has_literal_arm(e.match_arms) {
        return false;
    }
    let mut cty: string = "int";
    if scrut_ty != null {
        cty = type_to_c(scrut_ty);
    }
    print!("({ ", cty, " __m = ");
    emit_expr(g, e.lhs);
    print!("; __typeof__(");
    emit_arm_typeof_probe(g, e.match_arms);
    print!(") __r; ");
    let mut first: bool = true;
    for let i: i32 = 0; i < e.match_arms.len(); i++ {
        let a: MatchArm = e.match_arms.get(i);
        if a.lit == null {
            continue;
        }
        if first {
            print!("if (");
        } else {
            print!(" else if (");
        }
        first = false;
        _emit_match_lit_cmp(g, scrut_ty, &a);
        print!(") { ");
        emit_match_arm_value(g, &a);
        print!(" }");
    }
    print!(" else { ");
    let wi: i32 = _match_wildcard_idx(e.match_arms);
    if wi >= 0 {
        let w: MatchArm = e.match_arms.get(wi);
        emit_match_arm_value(g, &w);
    } else {
        print!("__r = 0;");
    }
    print!(" } __r; })");
    return true;
}

// `match` over a ?T/!T scrutinee lowers to an if/else on the .has/.ok
// discriminant rather than the user-enum `switch (.tag)` path: Option and
// Result are plain structs (`{int has; T val;}` / `{int ok; T val; const
// char* err;}`) with no .tag/.data union, so the generic match lowering emits
// references that don't exist. These helpers mirror the working `if let
// some/ok` path. Without them codegen leaked the placeholder type name `X`
// and `case X_some` into the C and cc failed.

// Index of the some/ok arm, the none/err arm and the `_` arm in `arms`
// (each -1 if absent). Written into the three out-pointers.
fn _classify_opt_res_arms(arms: *Vector<MatchArm>, truthy: *i32, falsy: *i32, wild: *i32) {
    *truthy = 0 - 1;
    *falsy = 0 - 1;
    *wild = 0 - 1;
    if arms == null {
        return;
    }
    for let i: i32 = 0; i < arms.len(); i++ {
        let a: MatchArm = arms.get(i);
        if a.variant.eq("_") {
            *wild = i;
        } else {
            if a.variant.eq("some") || a.variant.eq("ok") {
                *truthy = i;
            } else {
                if a.variant.eq("none") || a.variant.eq("err") {
                    *falsy = i;
                }
            }
        }
    }
}

// Emit the payload binding for one arm: some/ok bind from `__m.val`, err from
// `__m.err`, none binds nothing. Space-form (no newline) so it works in both
// the statement and the stmt-expr lowerings.
fn _emit_opt_res_bind(_g: *CG, a: *MatchArm, truthy: bool) {
    if a == null || a.bindings == null || a.bindings.len() != 1 {
        return;
    }
    let mut payload: string = "__m.err";
    if truthy {
        payload = "__m.val";
    }
    print!("__typeof__(", payload, ") ");
    print!(c_safe_ident(a.bindings.get(0)), " = ", payload, "; ");
}

// Statement-form `match` on ?T/!T. Returns false if the scrutinee is not an
// Option/Result so the caller falls through to the user-enum path.
fn _emit_match_opt_res_stmt(g: *CG, s: *Stmt, scrut_ty: *Type, depth: i32) -> bool {
    if scrut_ty == null {
        return false;
    }
    let is_opt: bool = scrut_ty.kind == TY_OPTION;
    let is_res: bool = scrut_ty.kind == TY_RESULT;
    if !is_opt && !is_res {
        return false;
    }
    let m: string = mangle_type(scrut_ty.inner);
    let mut cty: string = "__glide_result_".concat(m).concat("_t");
    let mut flag: string = "ok";
    if is_opt {
        cty = "__glide_option_".concat(m).concat("_t");
        flag = "has";
    }
    let mut ti: i32 = 0;
    let mut fi: i32 = 0;
    let mut wi: i32 = 0;
    _classify_opt_res_arms(s.arms, &ti, &fi, &wi);
    if ti < 0 {
        ti = wi;
    }
    if fi < 0 {
        fi = wi;
    }
    ind(depth);
    println!("{");
    ind(depth + 1);
    print!(cty, " __m = ");
    emit_expr(g, s.scrutinee);
    println!(";");
    ind(depth + 1);
    print!("if (__m.");
    print!(flag);
    println!(") {");
    _emit_opt_res_branch_stmt(g, s, ti, true, scrut_ty.inner, depth + 2);
    ind(depth + 1);
    println!("} else {");
    _emit_opt_res_branch_stmt(g, s, fi, false, scrut_ty.inner, depth + 2);
    ind(depth + 1);
    println!("}");
    ind(depth);
    println!("}");
    return true;
}

fn _emit_opt_res_branch_stmt(g: *CG, s: *Stmt, idx: i32, truthy: bool, inner: *Type, depth: i32) {
    if idx < 0 {
        return;
    }
    let a: MatchArm = s.arms.get(idx);
    if a.bindings != null && a.bindings.len() == 1 {
        // Declare the payload binding so println!/format! and any later
        // inference in the arm body resolve its type (some/ok -> inner T,
        // err -> string) instead of defaulting to a pointer format.
        if truthy {
            g.declare(a.bindings.get(0), inner);
        } else {
            g.declare(a.bindings.get(0), ty_named("string"));
        }
        ind(depth);
        _emit_opt_res_bind(g, &a, truthy);
        println!("");
    }
    if a.body != null {
        for let k: i32 = 0; k < a.body.len(); k++ {
            let bb: Stmt = a.body.get(k);
            emit_stmt(g, &bb, depth);
        }
    }
}

// Expression-form `match` on ?T/!T (GCC stmt-expr yielding a value). Returns
// false when the scrutinee is not Option/Result.
fn _emit_match_opt_res_expr(g: *CG, e: *Expr, scrut_ty: *Type) -> bool {
    if scrut_ty == null {
        return false;
    }
    let is_opt: bool = scrut_ty.kind == TY_OPTION;
    let is_res: bool = scrut_ty.kind == TY_RESULT;
    if !is_opt && !is_res {
        return false;
    }
    let m: string = mangle_type(scrut_ty.inner);
    let mut cty: string = "__glide_result_".concat(m).concat("_t");
    let mut flag: string = "ok";
    if is_opt {
        cty = "__glide_option_".concat(m).concat("_t");
        flag = "has";
    }
    let mut ti: i32 = 0;
    let mut fi: i32 = 0;
    let mut wi: i32 = 0;
    _classify_opt_res_arms(e.match_arms, &ti, &fi, &wi);
    if ti < 0 {
        ti = wi;
    }
    if fi < 0 {
        fi = wi;
    }
    print!("({ ", cty, " __m = ");
    emit_expr(g, e.lhs);
    print!("; ");
    // Result type probe: prefer the truthy arm (it carries the .val payload),
    // but skip an arm with no value (it only runs stmts / returns from the fn).
    let mut pi: i32 = ti;
    let mut probe_truthy: bool = true;
    let mut _ti_has_v: bool = false;
    if ti >= 0 {
        let _ta: MatchArm = e.match_arms.get(ti);
        _ti_has_v = arm_value_expr(&_ta) != null;
    }
    if !_ti_has_v && fi >= 0 {
        let _fa: MatchArm = e.match_arms.get(fi);
        if arm_value_expr(&_fa) != null {
            pi = fi;
            probe_truthy = false;
        }
    }
    if pi < 0 {
        pi = fi;
        probe_truthy = false;
    }
    print!("__typeof__(({ ");
    if pi >= 0 {
        let pa: MatchArm = e.match_arms.get(pi);
        _emit_opt_res_bind(g, &pa, probe_truthy);
        let pv: *Expr = arm_value_expr(&pa);
        print!("(");
        if pv != null {
            emit_expr(g, pv);
        } else {
            print!("0");
        }
        print!(");");
    } else {
        print!("(int)0;");
    }
    print!(" })) __r; ");
    print!("if (__m.");
    print!(flag);
    print!(") { ");
    _emit_opt_res_branch_expr(g, e, ti, true, scrut_ty.inner);
    print!(" } else { ");
    _emit_opt_res_branch_expr(g, e, fi, false, scrut_ty.inner);
    print!(" } __r; })");
    return true;
}

fn _emit_opt_res_branch_expr(g: *CG, e: *Expr, idx: i32, truthy: bool, inner: *Type) {
    if idx < 0 {
        print!("__r = 0;");
        return;
    }
    let a: MatchArm = e.match_arms.get(idx);
    if a.bindings != null && a.bindings.len() == 1 {
        if truthy {
            g.declare(a.bindings.get(0), inner);
        } else {
            g.declare(a.bindings.get(0), ty_named("string"));
        }
        _emit_opt_res_bind(g, &a, truthy);
    }
    emit_match_arm_value(g, &a);
}

// True iff `t` is `*dyn Trait` — i.e. a pointer to a dyn trait
// object. The C representation is the fat-pointer struct
// `__glide_dyn_<Trait>` (vtable + data), not a raw pointer, so any
// site that handles `null` against this type needs special-casing
// (struct-zero-init for assignment; .vtable field for compare).
fn _is_dyn_ptr(t: *Type) -> bool {
    if t == null {
        return false;
    }
    if t.kind != TY_POINTER {
        return false;
    }
    if t.inner == null {
        return false;
    }
    return t.inner.kind == TY_DYN;
}

fn _is_string_ty(t: *Type) -> bool {
    return t != null && t.kind == TY_NAMED && t.name.eq("string");
}

// Method name an arithmetic operator dispatches to (`+`->add …), or "".
fn _emit_arith_method(op: i32) -> string {
    if op == OP_ADD { return "add"; }
    if op == OP_SUB { return "sub"; }
    if op == OP_MUL { return "mul"; }
    if op == OP_DIV { return "div"; }
    if op == OP_MOD { return "rem"; }
    return "";
}

// Method a compound arithmetic assignment dispatches to (`+=`->add …), or "".
fn _compound_arith_method(op: i32) -> string {
    if op == OP_PLUS_ASSIGN { return "add"; }
    if op == OP_MINUS_ASSIGN { return "sub"; }
    if op == OP_STAR_ASSIGN { return "mul"; }
    if op == OP_SLASH_ASSIGN { return "div"; }
    if op == OP_PERCENT_ASSIGN { return "rem"; }
    return "";
}

// Emit a C bool expression comparing two same-typed values, given as C-expr
// strings `a` / `b`. Recurses structurally: strings via the byte-compare
// runtime, structs/tuples field-by-field (null-safe behind a pointer), and
// everything else via C `==`. Powers value equality for structs and tuples.
//
// `seen` holds the struct names on the current recursion PATH. A self-
// referential struct (e.g. `Node { next: *Node }`) would otherwise recurse
// forever at emit time and blow up RAM — when a struct type reappears on the
// path we stop and compare that field by pointer identity instead. `depth` is
// a hard backstop.
fn _emit_eq_of(g: *CG, ty: *Type, a: string, b: string, seen: *Vector<string>, depth: i32) {
    if depth > 64 {
        print!("(".concat(a).concat(" == ").concat(b).concat(")"));
        return;
    }
    let s: *Type = strip_ptr(ty);
    if _is_string_ty(s) {
        print!("__glide_string_eq(".concat(a).concat(", ").concat(b).concat(")"));
        return;
    }
    let is_ptr: bool = ty != null && (ty.kind == TY_POINTER || ty.kind == TY_BORROW || ty.kind == TY_BORROW_MUT);
    if s != null && s.kind == TY_NAMED && g.structs.contains(s.name) {
        // Cycle guard: this struct is already being compared up the path, so
        // recursing again would never terminate. Fall back to pointer identity.
        if seen.contains(s.name) {
            print!("(".concat(a).concat(" == ").concat(b).concat(")"));
            return;
        }
        let sd: Stmt = g.structs.get(s.name);
        seen.push(s.name);
        _emit_agg_eq(g, sd.struct_fields, a, b, is_ptr, seen, depth + 1);
        let _p: string = seen.pop();
        return;
    }
    if s != null && s.kind == TY_TUPLE {
        _emit_tuple_eq(g, s.args, a, b, is_ptr, seen, depth + 1);
        return;
    }
    // Primitive / pointer / enum: identity compare is the value compare.
    print!("(".concat(a).concat(" == ").concat(b).concat(")"));
}

// AND together the per-field comparisons of a struct. When the values are
// behind a pointer, guard nulls: equal if pointer-equal (covers both-null),
// unequal if exactly one is null, else compare fields.
fn _emit_agg_eq(g: *CG, fields: *Vector<Field>, a: string, b: string, is_ptr: bool, seen: *Vector<string>, depth: i32) {
    let acc: string = if is_ptr { "->" } else { "." };
    if is_ptr {
        print!("((".concat(a).concat(" == ").concat(b).concat(") || (").concat(a).concat(" && ").concat(b).concat(" && "));
    }
    print!("(");
    if fields == null || fields.len() == 0 {
        print!("1");
    } else {
        for let i: i32 = 0; i < fields.len(); i++ {
            if i > 0 {
                print!(" && ");
            }
            let f: Field = fields.get(i);
            let fc: string = c_safe_ident(f.name);
            _emit_eq_of(g, f.ty, a.concat(acc).concat(fc), b.concat(acc).concat(fc), seen, depth);
        }
    }
    print!(")");
    if is_ptr {
        print!("))");
    }
}

// Same, for anonymous tuples: fields are `_0`, `_1`, … with element types in
// `elems`.
fn _emit_tuple_eq(g: *CG, elems: *Vector<Type>, a: string, b: string, is_ptr: bool, seen: *Vector<string>, depth: i32) {
    let acc: string = if is_ptr { "->" } else { "." };
    if is_ptr {
        print!("((".concat(a).concat(" == ").concat(b).concat(") || (").concat(a).concat(" && ").concat(b).concat(" && "));
    }
    print!("(");
    if elems == null || elems.len() == 0 {
        print!("1");
    } else {
        for let i: i32 = 0; i < elems.len(); i++ {
            if i > 0 {
                print!(" && ");
            }
            let et: Type = elems.get(i);
            let fld: string = "_".concat(int_to_str(i));
            _emit_eq_of(g, &et, a.concat(acc).concat(fld), b.concat(acc).concat(fld), seen, depth);
        }
    }
    print!(")");
    if is_ptr {
        print!("))");
    }
}

// Emit a C bool comparing two enum values: tags must match, and for the active
// payload variant its fields must match (recursively, so string/struct
// payloads compare by value). Enums lower to `{ int tag; union { … } data; }`,
// so `struct == struct` isn't valid C — this replaces it.
fn _emit_enum_eq(g: *CG, es: *Stmt, a: string, b: string, is_ptr: bool) {
    let acc: string = if is_ptr { "->" } else { "." };
    let ename: string = c_safe_ident(es.name);
    if is_ptr {
        print!("((".concat(a).concat(" == ").concat(b).concat(") || (").concat(a).concat(" && ").concat(b).concat(" && "));
    }
    print!("(".concat(a).concat(acc).concat("tag == ").concat(b).concat(acc).concat("tag"));
    if es.enum_variants != null {
        let seen: *Vector<string> = Vector::new();
        for let i: i32 = 0; i < es.enum_variants.len(); i++ {
            let v: EnumVariant = es.enum_variants.get(i);
            if v.fields == null || v.fields.len() == 0 {
                continue;
            }
            // Only the active variant's payload matters: `tag != V || fields eq`.
            print!(" && (".concat(a).concat(acc).concat("tag != ").concat(ename).concat("_").concat(v.name).concat(" || ("));
            for let j: i32 = 0; j < v.fields.len(); j++ {
                if j > 0 {
                    print!(" && ");
                }
                let ft: Type = v.fields.get(j);
                let mut af: string = a.concat(acc).concat("data.v_").concat(v.name);
                let mut bf: string = b.concat(acc).concat("data.v_").concat(v.name);
                if v.fields.len() > 1 {
                    af = af.concat(".f").concat(int_to_str(j));
                    bf = bf.concat(".f").concat(int_to_str(j));
                }
                _emit_eq_of(g, &ft, af, bf, seen, 0);
            }
            print!("))");
        }
        seen.free();
    }
    print!(")");
    if is_ptr {
        print!("))");
    }
}

// Emit a "null" appropriate for the expected type. For `*dyn Trait`
// the fat-pointer struct gets zero-initialised (vtable=NULL,
// data=NULL); for everything else, plain `NULL`.
fn _emit_null_for(t: *Type) {
    if _is_dyn_ptr(t) {
        print!("((", type_to_c(t), "){0})");
        return;
    }
    print!("NULL");
}

// Look up the type of `field_name` on `struct_name` via g.structs.
// Returns null when the struct or field isn't found (codegen falls
// back to plain NULL emit, which is the existing behaviour).
fn _field_ty_in_struct(g: *CG, struct_name: string, field_name: string) -> *Type {
    if g.structs == null || !g.structs.contains(struct_name) {
        return null;
    }
    let sd: Stmt = g.structs.get(struct_name);
    if sd.struct_fields == null {
        return null;
    }
    for let i: i32 = 0; i < sd.struct_fields.len(); i++ {
        let f: Field = sd.struct_fields.get(i);
        if f.name.eq(field_name) {
            let p: *Type = malloc(sizeof(Type)) as *Type;
            *p = *f.ty;
            return p;
        }
    }
    return null;
}

// Rewrite a bare `some`/`none`/`ok`/`err` call in `e` to its monomorphized
// `__glide_<ctor>_<mangle>` name, given the expected `want` type. Mirrors the
// let-init / return rewriting so these ctors also resolve in struct-literal
// field and field-assignment position (where no `let: ?T` annotation exists
// to carry the type). No-op when `e` isn't such a call or `want` isn't an
// Option / Result / opt-Result type.
fn _rewrite_opt_ctor(e: *Expr, want: *Type) {
    if e == null || want == null {
        return;
    }
    if e.kind != EX_CALL || e.lhs == null || e.lhs.kind != EX_IDENT {
        return;
    }
    if want.kind == TY_RESULT {
        let m: string = mangle_type(want.inner);
        if e.lhs.str_val.eq("ok") {
            e.lhs.str_val = "__glide_ok_".concat(m);
        }
        if e.lhs.str_val.eq("err") {
            e.lhs.str_val = "__glide_err_".concat(m);
        }
    } else {
        if want.kind == TY_OPTION {
            let m: string = mangle_type(want.inner);
            if e.lhs.str_val.eq("some") {
                e.lhs.str_val = "__glide_some_".concat(m);
            }
            if e.lhs.str_val.eq("none") {
                e.lhs.str_val = "__glide_none_".concat(m);
            }
        } else {
            if want.kind == TY_OPT_RESULT {
                let m: string = mangle_type(want.inner);
                if e.lhs.str_val.eq("some") {
                    e.lhs.str_val = "__glide_optres_some_".concat(m);
                }
                if e.lhs.str_val.eq("none") {
                    e.lhs.str_val = "__glide_optres_none_".concat(m);
                }
                if e.lhs.str_val.eq("err") {
                    e.lhs.str_val = "__glide_optres_err_".concat(m);
                }
            }
        }
    }
}

// ---- expressions ---------------------------------------------------------
fn _sds_is_hex(c: i32) -> bool {
    return c >= 48 && c <= 57 || c >= 97 && c <= 102 || c >= 65 && c <= 70;
}

// The decoded BYTE length of a string literal whose source form is `s` (C-escape
// compatible). Counts each escape (incl. NUL-valued \x00 / \0) as one byte so
// the SDS length header matches the real byte count — Glide strings are
// length-prefixed and carry embedded NULs, so the count must NOT stop at a NUL.
fn _sds_lit_len(s: string) -> i32 {
    let n: i32 = s.len();
    let mut i: i32 = 0;
    let mut len: i32 = 0;
    while i < n {
        let c: i32 = s.at(i).to_int();
        if c == 92 && i + 1 < n {
            let e: i32 = s.at(i + 1).to_int();
            if e == 120 || e == 88 {
                // `\xNN` is EXACTLY two hex digits (Rust/Python semantics), one
                // byte — not C's greedy "consume all following hex". So
                // `"\x00cd"` is NUL,'c','d' (3 more chars here), and a NUL
                // escape is a real byte, not a terminator.
                i = i + 2;
                let mut got: i32 = 0;
                while got < 2 && i < n && _sds_is_hex(s.at(i).to_int()) {
                    i = i + 1;
                    got = got + 1;
                }
                len = len + 1;
            } else {
                if e >= 48 && e <= 55 {
                    i = i + 1;
                    let mut cnt: i32 = 0;
                    while cnt < 3 && i < n && s.at(i).to_int() >= 48 && s.at(i).to_int() <= 55 {
                        i = i + 1;
                        cnt = cnt + 1;
                    }
                    len = len + 1;
                } else {
                    i = i + 2;
                    len = len + 1;
                }
            }
        } else {
            i = i + 1;
            len = len + 1;
        }
    }
    return len;
}

// One byte as a 3-digit octal C escape (`\NNN`). Octal is fixed 3 digits, so it
// never merges with following digit/hex data (a `\xNN` prefix would).
fn _sds_octal(b: i32) -> string {
    return "\\".concat(int_to_str(b / 64 & 7)).concat(int_to_str(b / 8 & 7)).concat(int_to_str(b & 7));
}

fn _sds_hex_val(c: i32) -> i32 {
    if c >= 48 && c <= 57 { return c - 48; }
    if c >= 97 && c <= 102 { return c - 87; }
    if c >= 65 && c <= 70 { return c - 55; }
    return 0;
}

// Emit a string literal's data into a C string literal. Each `\xNN` (exactly
// two hex digits) is rewritten as a fixed-width octal escape so the C compiler
// can't greedily extend it into the following character (`"\x00cd"` must stay
// NUL,'c','d', not one `\x00cd` byte). Every other source escape passes through
// to C unchanged.
fn _sds_emit_data(s: string) {
    let n: i32 = s.len();
    let mut i: i32 = 0;
    while i < n {
        let c: i32 = s.at(i).to_int();
        if c == 92 && i + 1 < n {
            let e: i32 = s.at(i + 1).to_int();
            if e == 120 || e == 88 {
                let mut val: i32 = 0;
                let mut got: i32 = 0;
                let mut j: i32 = i + 2;
                while got < 2 && j < n && _sds_is_hex(s.at(j).to_int()) {
                    val = val * 16 + _sds_hex_val(s.at(j).to_int());
                    j = j + 1;
                    got = got + 1;
                }
                print!(_sds_octal(val & 255));
                i = j;
                continue;
            }
        }
        print!(s.substring(i, i + 1));
        i = i + 1;
    }
}

// True when `e` is a direct call `foo(...)` to an extern (bodyless) fn that
// returns `string` — its result is a raw, headerless C string, so it must be
// `adopt`ed into a managed (headered) string before any `.len()`/`.eq`/`.concat`.
fn _is_extern_string_call(g: *CG, e: *Expr) -> bool {
    if e.lhs == null || e.lhs.kind != EX_IDENT {
        return false;
    }
    let name: string = e.lhs.str_val;
    // The runtime's own string builders (__glide_string_from_buf, concat,
    // substring, str_alloc, ...) already return headered strings — don't wrap
    // them (a double adopt would strlen-truncate binary data containing NULs).
    if name.starts_with("__glide_str") {
        return false;
    }
    // __glide_read_bytes already returns a headered string and its result is
    // freed by the caller — wrapping it would leak the buffer and truncate
    // binary reads at the first NUL.
    if name.eq("__glide_read_bytes") {
        return false;
    }
    // _bytes_to_string (net/ip.glide) delegates to __glide_string_from_buf, so
    // its result is already headered — every socket read flows through it, and
    // a double adopt would strlen-truncate any binary body at its first NUL.
    if name.eq("_bytes_to_string") {
        return false;
    }
    if !g.fns.contains(name) {
        return false;
    }
    let f: Stmt = g.fns.get(name);
    if f.fn_body != null {
        return false;
    } // has a Glide body -> not extern
    if f.fn_ret_ty == null {
        return false;
    }
    return f.fn_ret_ty.kind == TY_NAMED && f.fn_ret_ty.name.eq("string");
}

pub fn emit_expr(g: *CG, e: *Expr) {
    if e == null {
        print!("/* null */");
        return;
    }
    if e.kind == EX_CALL && !g._sds_adopt_skip && _is_extern_string_call(g, e) {
        print!("__glide_string_adopt(");
        g._sds_adopt_skip = true; // skip the wrap when we re-emit this call
        emit_expr(g, e);
        print!(")");
        return;
    }
    if e.kind == EX_INT {
        // A type-suffixed literal (`200u8`, `5i64`) carries its C type via a
        // cast so the value is stored/compared at the right width.
        if e.cast_to != null {
            print!("(", type_to_c(e.cast_to), ")(", e.int_val, ")");
            return;
        }
        print!(e.int_val);
        return;
    }
    if e.kind == EX_FLOAT {
        if e.cast_to != null {
            print!("(", type_to_c(e.cast_to), ")(", e.float_val, ")");
            return;
        }
        print!(e.float_val);
        return;
    }
    if e.kind == EX_STRING {
        // SDS literal: a 4-byte little-endian length header (octal-escaped)
        // precedes the data, and the value points past it (`+ 4`), so the C
        // literal stays NUL-terminated and FFI-compatible while `.len()` is O(1).
        let blen: i32 = _sds_lit_len(e.str_val);
        print!("((const char*)(\"");
        print!(_sds_octal(blen & 255));
        print!(_sds_octal(blen / 256 & 255));
        print!(_sds_octal(blen / 65536 & 255));
        print!(_sds_octal(blen / 16777216 & 255));
        _sds_emit_data(e.str_val);
        print!("\" + 4))");
        return;
    }
    if e.kind == EX_CHAR {
        // Emit as `(char)NNN` decimal — C interprets `'\xNN'` as hex digits,
        // not decimal, so a decimal int_val would silently re-encode.
        print!("(char)");
        print!(e.int_val);
        return;
    }
    if e.kind == EX_BOOL {
        if e.bool_val {
            print!("true");
        } else {
            print!("false");
        }
        return;
    }
    if e.kind == EX_NULL {
        print!("NULL");
        return;
    }
    if e.kind == EX_IDENT {
        let nm: string = e.str_val;
        // A body-bearing user fn renamed away from a libc collision at its
        // definition (emit_fn_signature) must use the same name at every
        // value/call reference. A local binding of the same name shadows the
        // fn, so an in-scope ident is emitted plainly.
        if is_libc_symbol(nm) && !g.scope.contains(nm) && g.fns.contains(nm) {
            let f: Stmt = g.fns.get(nm);
            if f.fn_body != null {
                print!(userfn_mangle(nm));
                return;
            }
        }
        // A borrowed PRIMITIVE (`&self` on `string`/`int`, or a `&x` of a
        // value type) used as a bare value must be dereferenced — the binding
        // is a pointer, but the value is wanted here. Member/method/index uses
        // go through other Expr kinds and keep the pointer.
        if g.scope.contains(nm) {
            let bt: Type = g.scope.get(nm);
            if (bt.kind == TY_BORROW || bt.kind == TY_BORROW_MUT) && bt.inner != null && bt.inner.kind == TY_NAMED && is_stdlib_primitive(bt.inner.name) {
                print!("(*");
                print!(c_safe_ident(nm));
                print!(")");
                return;
            }
        }
        print!(c_safe_ident(nm));
        return;
    }
    if e.kind == EX_IF {
        // Lower expression-position if to a C ternary. Both branches
        // are guaranteed to be single expressions by the parser, so
        // they fit cleanly. Nested else-if chains nest naturally:
        // `(c1 ? a : (c2 ? b : c))`.
        print!("(");
        emit_expr(g, e.lhs);
        print!(" ? ");
        emit_expr(g, e.rhs);
        print!(" : ");
        if e.operand != null {
            emit_expr(g, e.operand);
        } else {
            print!("0");
        }
        print!(")");
        return;
    }
    if e.kind == EX_BLOCK {
        // GCC statement-expression `({ stmts; value; })`. Stmts run for
        // side effects; trailing comma-expr yields the value.
        print!("({ ");
        if e.block_stmts != null {
            for let i: i32 = 0; i < e.block_stmts.len(); i++ {
                let b: Stmt = e.block_stmts.get(i);
                emit_stmt(g, &b, 0);
            }
        }
        print!("(");
        if e.operand != null {
            emit_expr(g, e.operand);
        } else {
            print!("0");
        }
        print!("); })");
        return;
    }
    if e.kind == EX_MATCH {
        // GCC stmt-expr lowering. The result type is inferred via
        // `__typeof__` over the first arm's value evaluated in a sibling
        // stmt-expr — GCC computes the type at compile time without
        // running the body, so payload bindings resolve naturally.
        let scrut_ty: *Type = infer_for_codegen(g, e.lhs);
        // ?T / !T scrutinees lower to an if/else on .has/.ok (no .tag/.data).
        if _emit_match_opt_res_expr(g, e, scrut_ty) {
            return;
        }
        // Literal-pattern arms lower to an equality if/else chain.
        if _emit_match_literal_expr(g, e, scrut_ty) {
            return;
        }
        let mut enum_name: string = "X";
        if scrut_ty != null && scrut_ty.kind == TY_NAMED {
            enum_name = scrut_ty.name;
        }
        print!("({ ");
        print!(enum_name);
        print!(" __m = ");
        emit_expr(g, e.lhs);
        print!("; ");
        print!("__typeof__(");
        emit_arm_typeof_probe(g, e.match_arms);
        print!(") __r; ");
        print!("switch (__m.tag) { ");
        if e.match_arms != null {
            for let i: i32 = 0; i < e.match_arms.len(); i++ {
                let a: MatchArm = e.match_arms.get(i);
                if a.variant.eq("_") {
                    print!("default: ");
                } else {
                    print!("case ");
                    print!(enum_name);
                    print!("_");
                    print!(a.variant);
                    print!(": ");
                }
                print!("{ ");
                if a.bindings != null && a.bindings.len() > 0 {
                    if a.bindings.len() == 1 {
                        let payload: string = "__m.data.v_".concat(a.variant);
                        print!("__typeof__(");
                        print!(payload);
                        print!(") ");
                        print!(c_safe_ident(a.bindings.get(0)));
                        print!(" = ");
                        print!(payload);
                        print!("; ");
                    } else {
                        for let k: i32 = 0; k < a.bindings.len(); k++ {
                            let payload: string = "__m.data.v_".concat(a.variant);
                            print!("__typeof__(");
                            print!(payload);
                            print!(".f");
                            print!(k);
                            print!(") ");
                            print!(c_safe_ident(a.bindings.get(k)));
                            print!(" = ");
                            print!(payload);
                            print!(".f");
                            print!(k);
                            print!("; ");
                        }
                    }
                }
                emit_match_arm_value(g, &a);
                print!(" break; } ");
            }
        }
        print!("} __r; })");
        return;
    }
    if e.kind == EX_BINARY {
        if e.op_code == OP_COALESCE {
            // `??` fallback. LHS is ?T or !T. RHS is either a plain value
            // (yields T) or an `err(...)` call (yields !T, intended to be
            // chained with `?`). Detect the err() form by looking at the
            // RHS Expr shape — if it's a bare `err(s)` call we stay in
            // Result-shape; otherwise we extract the inner value.
            let lt: *Type = infer_for_codegen(g, e.lhs);
            let mut is_err_form: bool = false;
            if e.rhs != null && e.rhs.kind == EX_CALL && e.rhs.lhs != null && e.rhs.lhs.kind == EX_IDENT && e.rhs.lhs.str_val.eq("err") {
                is_err_form = true;
            }
            if lt != null && lt.kind == TY_OPTION {
                let m_in: string = mangle_type(lt.inner);
                // Plain fallback: extract the inner.
                if !is_err_form {
                    print!("({ __glide_option_".concat(m_in).concat("_t __o = ("));
                    emit_expr(g, e.lhs);
                    print!("); __o.has ? __o.val : (");
                    emit_expr(g, e.rhs);
                    print!("); })");
                    return;
                }
                // is_err_form: substitute None → Err. Result is __glide_result_<T>_t.
                print!("({ __glide_option_".concat(m_in).concat("_t __o = ("));
                emit_expr(g, e.lhs);
                print!("); __o.has ? __glide_ok_".concat(m_in).concat("(__o.val) : __glide_err_").concat(m_in).concat("("));
                let arg: Expr = e.rhs.args.get(0);
                emit_expr(g, &arg);
                print!("); })");
                return;
            }
            if lt != null && lt.kind == TY_RESULT {
                let m_in: string = mangle_type(lt.inner);
                if !is_err_form {
                    print!("({ __glide_result_".concat(m_in).concat("_t __r = ("));
                    emit_expr(g, e.lhs);
                    print!("); __r.ok ? __r.val : (");
                    emit_expr(g, e.rhs);
                    print!("); })");
                    return;
                }
                // Replace existing Err msg with the new one.
                print!("({ __glide_result_".concat(m_in).concat("_t __r = ("));
                emit_expr(g, e.lhs);
                print!("); __r.ok ? __r : __glide_err_".concat(m_in).concat("("));
                let arg: Expr = e.rhs.args.get(0);
                emit_expr(g, &arg);
                print!("); })");
                return;
            }
            // OptResult LHS: tag 0=Some extracts; None/Err take the fallback.
            if lt != null && lt.kind == TY_OPT_RESULT {
                let m_in: string = mangle_type(lt.inner);
                if !is_err_form {
                    print!("({ __glide_optres_".concat(m_in).concat("_t __o = ("));
                    emit_expr(g, e.lhs);
                    print!("); __o.tag == 0 ? __o.val : (");
                    emit_expr(g, e.rhs);
                    print!("); })");
                    return;
                }
                // err-form collapses `?!T` to `!T`: Some → Ok, None/Err →
                // the fallback Err.
                print!("({ __glide_optres_".concat(m_in).concat("_t __o = ("));
                emit_expr(g, e.lhs);
                print!("); __o.tag == 0 ? __glide_ok_".concat(m_in).concat("(__o.val) : __glide_err_").concat(m_in).concat("("));
                let arg: Expr = e.rhs.args.get(0);
                emit_expr(g, &arg);
                print!("); })");
                return;
            }
            // Pointer nullable: `*T ?? default` → null check.
            if lt != null && lt.kind == TY_POINTER {
                let tc: string = type_to_c(lt);
                print!("({ ".concat(tc).concat(" __p = ("));
                emit_expr(g, e.lhs);
                print!("); __p ? __p : (");
                emit_expr(g, e.rhs);
                print!("); })");
                return;
            }
            // Fallback: simple ternary using a non-zero-ness of LHS.
            print!("((");
            emit_expr(g, e.lhs);
            print!(") ? (");
            emit_expr(g, e.lhs);
            print!(") : (");
            emit_expr(g, e.rhs);
            print!("))");
            return;
        }
        // `*dyn Trait` compares to null: the C representation is a
        // fat-pointer struct, so `(x == NULL)` doesn't compile.
        // Translate to a check on the `vtable` slot (NULL when the
        // dyn was zero-initialised, set to a real vtable otherwise).
        if e.op_code == OP_EQ || e.op_code == OP_NE {
            let lt: *Type = infer_for_codegen(g, e.lhs);
            let rt: *Type = infer_for_codegen(g, e.rhs);
            let lhs_dyn: bool = _is_dyn_ptr(lt);
            let rhs_dyn: bool = _is_dyn_ptr(rt);
            let lhs_null: bool = e.lhs != null && e.lhs.kind == EX_NULL;
            let rhs_null: bool = e.rhs != null && e.rhs.kind == EX_NULL;
            if lhs_dyn && rhs_null {
                print!("((");
                emit_expr(g, e.lhs);
                print!(").vtable ", op_to_c(e.op_code), " NULL)");
                return;
            }
            if rhs_dyn && lhs_null {
                print!("(NULL ", op_to_c(e.op_code), " (");
                emit_expr(g, e.rhs);
                print!(").vtable)");
                return;
            }
        }
        // 256-bit ints are software structs; C `+`/`<`/... don't apply, so
        // route every operator to its `__glide_<ty>_<op>` runtime helper.
        let mut bn256: string = _u256_ty(infer_for_codegen(g, e.lhs));
        if bn256.eq("") {
            bn256 = _u256_ty(infer_for_codegen(g, e.rhs));
        }
        if !bn256.eq("") {
            if e.op_code == OP_EQ || e.op_code == OP_NE || e.op_code == OP_LT || e.op_code == OP_LE || e.op_code == OP_GT || e.op_code == OP_GE {
                print!("(__glide_".concat(bn256).concat("_cmp("));
                emit_expr(g, e.lhs);
                print!(", ");
                emit_expr(g, e.rhs);
                print!(") ", op_to_c(e.op_code), " 0)");
                return;
            }
            let afn: string = _u256_arith_fn(e.op_code);
            if !afn.eq("") {
                print!("__glide_".concat(bn256).concat("_").concat(afn).concat("("));
                emit_expr(g, e.lhs);
                print!(", ");
                emit_expr(g, e.rhs);
                print!(")");
                return;
            }
        }
        // String value equality: `==` / `!=` compare CONTENTS (byte compare via
        // the runtime), not the underlying char* pointers. `!=` negates.
        if e.op_code == OP_EQ || e.op_code == OP_NE {
            if _is_string_ty(infer_for_codegen(g, e.lhs)) && _is_string_ty(infer_for_codegen(g, e.rhs)) {
                print!("(");
                if e.op_code == OP_NE {
                    print!("!");
                }
                print!("__glide_string_eq(");
                emit_expr(g, e.lhs);
                print!(", ");
                emit_expr(g, e.rhs);
                print!("))");
                return;
            }
            // Struct / tuple value equality: compare field-by-field. Bind both
            // operands to temps first so a non-trivial operand is evaluated
            // once. `!=` negates the whole comparison.
            let elt: *Type = infer_for_codegen(g, e.lhs);
            let est: *Type = strip_ptr(elt);
            // A user `eq` method overrides the automatic field comparison.
            if est != null && est.kind == TY_NAMED && g.user_eq.contains(est.name) {
                let eqargs: *Vector<Expr> = Vector::new();
                eqargs.push(*e.rhs);
                print!("(");
                if e.op_code == OP_NE {
                    print!("!");
                }
                emit_expr(g, expr_call(expr_member(e.lhs, "eq"), eqargs));
                print!(")");
                return;
            }
            if est != null && ((est.kind == TY_NAMED && g.structs.contains(est.name)) || est.kind == TY_TUPLE) {
                let tc: string = type_to_c(elt);
                print!("(");
                if e.op_code == OP_NE {
                    print!("!");
                }
                print!("({ ".concat(tc).concat(" __eqa = ("));
                emit_expr(g, e.lhs);
                print!("); ".concat(tc).concat(" __eqb = ("));
                emit_expr(g, e.rhs);
                print!("); ");
                let eq_seen: *Vector<string> = Vector::new();
                _emit_eq_of(g, elt, "__eqa", "__eqb", eq_seen, 0);
                eq_seen.free();
                print!("; }))");
                return;
            }
            // Enums lower to tagged structs; compare by tag (+ active payload).
            if est != null && est.kind == TY_NAMED && g.enums.contains(est.name) {
                let tc: string = type_to_c(elt);
                let is_ptr: bool = elt != null && (elt.kind == TY_POINTER || elt.kind == TY_BORROW || elt.kind == TY_BORROW_MUT);
                print!("(");
                if e.op_code == OP_NE {
                    print!("!");
                }
                print!("({ ".concat(tc).concat(" __eqa = ("));
                emit_expr(g, e.lhs);
                print!("); ".concat(tc).concat(" __eqb = ("));
                emit_expr(g, e.rhs);
                print!("); ");
                let _es: Stmt = g.enums.get(est.name);
                _emit_enum_eq(g, &_es, "__eqa", "__eqb", is_ptr);
                print!("; }))");
                return;
            }
        }
        // Operator overloading for structs / strings: ordering dispatches to a
        // `cmp(self, other) -> i32` method (`a < b` -> `a.cmp(b) < 0`), and
        // arithmetic to add/sub/mul/div/rem (`string + string` = concat). Both
        // synthesize a method call and emit it, reusing the normal call path
        // (self adaptation, single-eval of each operand).
        let ov_ty: *Type = strip_ptr(infer_for_codegen(g, e.lhs));
        if ov_ty != null && ov_ty.kind == TY_NAMED {
            let ov_struct: bool = g.structs.contains(ov_ty.name);
            let ov_string: bool = ov_ty.name.eq("string");
            if (e.op_code == OP_LT || e.op_code == OP_LE || e.op_code == OP_GT || e.op_code == OP_GE) && (ov_struct || ov_string) {
                let cargs: *Vector<Expr> = Vector::new();
                cargs.push(*e.rhs);
                let ccall: *Expr = expr_call(expr_member(e.lhs, "cmp"), cargs);
                print!("(");
                emit_expr(g, ccall);
                print!(" ", op_to_c(e.op_code), " 0)");
                return;
            }
            let cam: string = _emit_arith_method(e.op_code);
            if !cam.eq("") && ov_struct {
                let aargs: *Vector<Expr> = Vector::new();
                aargs.push(*e.rhs);
                emit_expr(g, expr_call(expr_member(e.lhs, cam), aargs));
                return;
            }
            if e.op_code == OP_ADD && ov_string {
                let sargs: *Vector<Expr> = Vector::new();
                sargs.push(*e.rhs);
                emit_expr(g, expr_call(expr_member(e.lhs, "concat"), sargs));
                return;
            }
        }
        print!("(");
        emit_expr(g, e.lhs);
        print!(" ", op_to_c(e.op_code), " ");
        emit_expr(g, e.rhs);
        print!(")");
        return;
    }
    if e.kind == EX_UNARY {
        if e.op_code == UN_TRY {
            // Postfix `?`: GCC stmt-expr that unpacks the Result/Option/OptRes
            // in the current fn. The dispatch matrix:
            //   inner !T  in fn !U   -> propagate Err
            //   inner ?T  in fn ?U   -> propagate None
            //   inner ?T  in fn !U   -> coerce None -> Err{"none-coerced"}
            //   inner ?T  in fn ?!U  -> propagate None
            //   inner ?!T in fn ?!U  -> propagate Err and None
            //   inner ?!T in fn !U   -> propagate Err; None coerces
            // err-defer cleanups fire on every propagating arm.
            let inner_ty: *Type = infer_for_codegen(g, e.operand);
            let ret_ty: *Type = g.current_ret_ty;
            if inner_ty == null || ret_ty == null {
                print!("/* invalid `?` */ 0");
                return;
            }
            let inner_kind: i32 = inner_ty.kind;
            let ret_kind: i32 = ret_ty.kind;
            if inner_kind != TY_RESULT && inner_kind != TY_OPTION && inner_kind != TY_OPT_RESULT {
                print!("/* invalid `?` */ 0");
                return;
            }
            if ret_kind != TY_RESULT && ret_kind != TY_OPTION && ret_kind != TY_OPT_RESULT {
                print!("/* invalid `?` */ 0");
                return;
            }
            let m_in: string = mangle_type(inner_ty.inner);
            let m_out: string = mangle_type(ret_ty.inner);
            // The value the `?` stmt-expr produces. A `!void` result (a void
            // payload) has no `.val` member, so `foo()?;` yields a void instead
            // of reading a non-existent member.
            let mut vtail: string = "__r.val";
            if m_in.eq("void") { vtail = "(void)0"; }
            // Pick struct typedef + propagation snippets per (inner, ret) combo.
            let mut struct_pref: string = "__glide_result_";
            if inner_kind == TY_OPTION {
                struct_pref = "__glide_option_";
            }
            if inner_kind == TY_OPT_RESULT {
                struct_pref = "__glide_optres_";
            }
            print!("({ ".concat(struct_pref).concat(m_in).concat("_t __r = ("));
            emit_expr(g, e.operand);
            print!("); ");
            // Build the err/none-propagation block(s) for this combo.
            // Common err-defer prelude for any propagating arm.
            let nd: i32 = g.err_defer_stack.len();
            // Helper: write defer drains.
            // Inner = !T: check !__r.ok, propagate Err.
            if inner_kind == TY_RESULT {
                print!("if (!__r.ok) { ");
                for let i: i32 = nd - 1; i >= 0; i = i - 1 {
                    let ex: Expr = g.err_defer_stack.get(i);
                    emit_expr(g, &ex);
                    print!("; ");
                }
                if ret_kind == TY_RESULT {
                    print!("return __glide_err_".concat(m_out).concat("(__r.err); } ").concat(vtail).concat("; })"));
                } else {
                    if ret_kind == TY_OPT_RESULT {
                        print!("return __glide_optres_err_".concat(m_out).concat("(__r.err); } ").concat(vtail).concat("; })"));
                    } else {
                        // ?U fn cannot represent Err — typer should have rejected.
                        print!("return __glide_none_".concat(m_out).concat("(); } ").concat(vtail).concat("; })"));
                    }
                }
                return;
            }
            // Inner = ?T: check !__r.has, propagate None (or coerce).
            if inner_kind == TY_OPTION {
                print!("if (!__r.has) { ");
                for let i: i32 = nd - 1; i >= 0; i = i - 1 {
                    let ex: Expr = g.err_defer_stack.get(i);
                    emit_expr(g, &ex);
                    print!("; ");
                }
                if ret_kind == TY_OPTION {
                    print!("return __glide_none_".concat(m_out).concat("(); } ").concat(vtail).concat("; })"));
                } else {
                    if ret_kind == TY_OPT_RESULT {
                        print!("return __glide_optres_none_".concat(m_out).concat("(); } ").concat(vtail).concat("; })"));
                    } else {
                        // !U fn: coerce None → Err{"none-coerced"}.
                        print!("return __glide_err_".concat(m_out).concat("(\"none-coerced\"); } ").concat(vtail).concat("; })"));
                    }
                }
                return;
            }
            // Inner = ?!T: dispatch on tag. 0=Some, 1=None, 2=Err.
            print!("if (__r.tag != 0) { ");
            for let i: i32 = nd - 1; i >= 0; i = i - 1 {
                let ex: Expr = g.err_defer_stack.get(i);
                emit_expr(g, &ex);
                print!("; ");
            }
            if ret_kind == TY_OPT_RESULT {
                print!("__glide_optres_".concat(m_out).concat("_t __pr; __pr.tag = __r.tag; __pr.err = __r.err; return __pr; } ").concat(vtail).concat("; })"));
            } else {
                if ret_kind == TY_RESULT {
                    // None coerces to Err{"none-coerced"}; Err passes msg through.
                    print!("if (__r.tag == 1) return __glide_err_".concat(m_out).concat("(\"none-coerced\"); ").concat("return __glide_err_").concat(m_out).concat("(__r.err); } ").concat(vtail).concat("; })"));
                } else {
                    // ?U fn: drop Err msg, propagate None.
                    print!("return __glide_none_".concat(m_out).concat("(); } ").concat(vtail).concat("; })"));
                }
            }
            return;
        }
        print!("(".concat(unop_to_c(e.op_code)));
        emit_expr(g, e.operand);
        print!(")");
        return;
    }
    if e.kind == EX_ASSIGN {
        // Compound arithmetic assignment on a struct: `a += b` -> `a = a.add(b)`.
        // Re-enters the plain-assign path below, which evaluates the RHS into a
        // temp before freeing the old `a`, so reading `a` in `a.add(b)` is safe.
        let ca_m: string = _compound_arith_method(e.op_code);
        if !ca_m.eq("") && e.lhs != null && e.rhs != null {
            let lty: *Type = strip_ptr(infer_for_codegen(g, e.lhs));
            if lty != null && lty.kind == TY_NAMED && g.structs.contains(lty.name) {
                let cargs: *Vector<Expr> = Vector::new();
                cargs.push(*e.rhs);
                let mc: *Expr = expr_call(expr_member(e.lhs, ca_m), cargs);
                emit_expr(g, expr_assign(OP_ASSIGN, e.lhs, mc));
                return;
            }
        }
        // Destination overwrite: `c = ...` where c is an owned local that still
        // holds its value frees that old value first (so it does not leak),
        // unless c was already moved away (then someone else owns it).
        let mut _ov: bool = false;
        if e.lhs != null && e.lhs.kind == EX_IDENT && op_to_c(e.op_code).eq("=") && _is_owned_local(g, e.lhs.str_val) && !(g.moved_locals.contains(e.lhs.str_val) && g.moved_locals.get(e.lhs.str_val)) {
            _ov = true;
        }
        // Move-on-assign / move-on-store: a plain `=` whose RHS is an owned
        // local transfers that ownership to the target (a variable or a struct
        // field), so the local must NOT auto-drop afterwards.
        if e.rhs != null && e.rhs.kind == EX_IDENT && op_to_c(e.op_code).eq("=") && _is_owned_local(g, e.rhs.str_val) {
            g.moved_locals.insert(e.rhs.str_val, true);
        }
        let _lty: *Type = if _ov { g.lookup(e.lhs.str_val) } else { null };
        if _ov && _lty != null {
            // Evaluate the RHS into a temp BEFORE freeing the old value, so a
            // self-referencing RHS (`a = a + b`, `a = f(a)`) reads the live
            // value, not freed memory.
            let _ci: *Type = strip_ptr(_lty);
            let mut _ovhasown: bool = false;
            if _ci != null && _ci.kind == TY_NAMED && g.structs.contains(_ci.name) {
                let _osd: Stmt = g.structs.get(_ci.name);
                if _osd.struct_fields != null {
                    for let _fi: i32 = 0; _fi < _osd.struct_fields.len(); _fi = _fi + 1 {
                        let _ff: Field = _osd.struct_fields.get(_fi);
                        if _ff.is_own {
                            _ovhasown = true;
                        }
                    }
                }
            }
            print!("({ ".concat(type_to_c(_lty)).concat(" __ovnew = ("));
            emit_expr(g, e.rhs);
            print!("); ");
            if _ci != null && _ci.kind == TY_NAMED && g.fns.contains(_ci.name.concat("_free")) {
                print!(_ci.name.concat("_free("));
                emit_expr(g, e.lhs);
                print!("); ");
            } else if _ovhasown {
                print!("__glide_drop_".concat(_ci.name).concat("("));
                emit_expr(g, e.lhs);
                print!("); ");
            } else {
                print!("free((void*)(");
                emit_expr(g, e.lhs);
                print!(")); ");
            }
            emit_expr(g, e.lhs);
            print!(" = __ovnew; })");
            if e.lhs != null && e.lhs.kind == EX_IDENT {
                g.moved_locals.insert(e.lhs.str_val, false);
            }
            return;
        }
        print!("(");
        emit_expr(g, e.lhs);
        print!(" ", op_to_c(e.op_code), " ");
        emit_expr(g, e.rhs);
        print!(")");
        // c now holds a fresh value: un-move it so its new value drops at scope
        // (it may have been moved away earlier and then reassigned here).
        if e.lhs != null && e.lhs.kind == EX_IDENT && op_to_c(e.op_code).eq("=") {
            g.moved_locals.insert(e.lhs.str_val, false);
        }
        return;
    }
    if e.kind == EX_CALL {
        g._sds_adopt_skip = false; // re-enable adopt-wrap for nested arg calls
        // Move-on-pass: an owned local passed by value to a `*T` param moves
        // ownership to the callee, so skip the caller's auto-drop of it (the
        // callee owns it now). A `&T` param borrows - no move.
        if e.args != null {
            for let _mi: i32 = 0; _mi < e.args.len(); _mi = _mi + 1 {
                let _ma: Expr = e.args.get(_mi);
                if _ma.kind == EX_IDENT && _is_owned_local(g, _ma.str_val) {
                    let _mpt: *Type = callee_param_ty(g, e, _mi);
                    if _mpt != null && _mpt.kind == TY_POINTER {
                        g.moved_locals.insert(_ma.str_val, true);
                    }
